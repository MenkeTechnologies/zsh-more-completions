#compdef helm-monitor
# helm-monitor: monitor a Helm release and rollback on metrics failure
# https://github.com/ContainerSolutions/helm-monitor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--prometheus=[Prometheus endpoint]:url' \
  '--elasticsearch=[Elasticsearch endpoint]:url' \
  '--sentry=[Sentry endpoint]:url' \
  '--dogstatsd=[Datadog endpoint]:url' \
  '--interval=[polling interval]:duration' \
  '--timeout=[timeout for rollback]:duration' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--kube-context=[Kubernetes context]:context' \
  '--namespace=[Kubernetes namespace]:namespace:_guard "^-*" namespace' \
  '--tiller-namespace=[Tiller namespace]:namespace' \
  '--debug[enable verbose logging]' \
  '1:release name' \
  '2:query'
