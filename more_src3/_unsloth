#compdef unsloth
# Documentation: https://github.com/unslothai/unsloth
# Reference accessed: 2026-05-23
# Verified: unsloth --help and subcommand help (Typer CLI).

# Zsh completion for unsloth - Unsloth fine-tuning and Studio CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'unsloth command' \
      'train[launch Unsloth training]' \
      'inference[run single inference]' \
      'export[export checkpoint to merged/GGUF/LoRA]' \
      'list-checkpoints[list checkpoints in outputs dir]' \
      'run[alias for unsloth studio run]' \
      'studio[Unsloth Studio commands]' && ret=0
    ;;
  args)
    case $line[1] in
      studio)
        if (( CURRENT == 2 )); then
          _values 'studio command' \
            'run[start Studio and load model]' \
            'stop[stop running Studio server]' \
            'update[update Studio dependencies]' \
            'reset-password[reset Studio admin password]' && ret=0
        fi
        ;;
      train)
        _arguments \
          '--model[model name or path]:model:' \
          '--dataset[dataset id or path]:dataset:' \
          '--output-dir[output directory]:directory:_files -/' \
          '--num-epochs[training epochs]:n:' \
          '--learning-rate[learning rate]:rate:' \
          '--batch-size[batch size]:n:' && ret=0
        ;;
    esac
    ;;
esac

return ret
