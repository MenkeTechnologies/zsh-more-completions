#compdef kubectl-confirm
# Documentation: https://github.com/brianpursley/kubectl-confirm
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-confirm wraps an arbitrary kubectl command, showing config + dry-run
# diff and asking for confirmation before executing. Args are a kubectl command.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*:kubectl command:_default'
