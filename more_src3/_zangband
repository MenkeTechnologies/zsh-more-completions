#compdef zangband
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man6/zangband.6.html
# Reference accessed: 2026-05-21
# Verified: Ubuntu jammy zangband(6) manpage OPTIONS section.

# ZAngband: Angband roguelike variant
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show usage]' \
  '-n[start a new character]' \
  '-f[fiddle mode (no high score entry)]' \
  '-w[wizard mode (no high score entry)]' \
  '-v[sound mode]' \
  '-g[graphics mode]' \
  '-o[original keyset]' \
  '-r[rogue-like keyset]' \
  '-s-[show N high scores]:n:' \
  '-u-[savefile name]:who:_users' \
  '-m-[force main-<sys>.c usage]:sys:' \
  '-d-[define lib sub-path]:lib=path:' \
  '*::extra args:_files' && ret=0
return ret
