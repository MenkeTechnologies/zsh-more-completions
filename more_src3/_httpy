#compdef httpy
# Documentation: https://github.com/knid/httpy
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httpy - modern, user-friendly, programmable command-line HTTP client.

_arguments -s -S \
  '(-h)-h[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-H --header)'{-H,--header}'[show response headers only]' \
  '(-B --body)'{-B,--body}'[show response body only]' \
  '(-S --status)'{-S,--status}'[show status only]' \
  '(-V --verbose)'{-V,--verbose}'[verbose request/response]' \
  '(-r --allow-redirect)'{-r,--allow-redirect}'[follow redirects]' \
  '(-X --exec)'{-X+,--exec=}'[execute httpcli command]:command:' \
  '1:url:_urls' \
  '*:header query or body key\:value:_default'
