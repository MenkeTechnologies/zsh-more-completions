#compdef kubearmor-operator
# _kubearmor-operator — KubeArmor cluster operator (kubearmor/KubeArmor)
# upstream: https://github.com/kubearmor/KubeArmor
# Flags from pkg/KubeArmorOperator/cmd/operator/main.go on tip.

_kubearmor-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--lsm=[LSM preference order]:order:' \
        '--pathprefix=[host rootfs mount path prefix]:dir:_files -/' \
        '--deploymentName=[operator deployment name]:name:' \
        '--providerHostname=[IMDS hostname for cluster name lookup]:host:_hosts' \
        '--providerEndpoint=[IMDS endpoint path for cluster name lookup]:path:' \
        '--initDeploy=[deploy init container]:bool:(true false)' \
        '--loglevel=[log level]:level:(debug info warn error)' \
        '--annotateResource=[apply AppArmor annotations to k8s resources]:bool:(true false)' \
        '--annotateExisting=[restart and annotate existing resources]:bool:(true false)' \
        '--socket-file=[CRI socket path passed to snitch]:file:_files'
}

_kubearmor-operator "$@"
