#compdef pw-link
# Documentation: https://docs.pipewire.org/page_man_pw-link_1.html
# Source: PipeWire — list / create / destroy links between node ports.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --remote)'{-r+,--remote=}'[remote instance name to monitor]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-o --output)'{-o,--output}'[list output ports]' \
    '(-i --input)'{-i,--input}'[list input ports]' \
    '(-l --links)'{-l,--links}'[list links]' \
    '(-t --latency)'{-t,--latency}'[list port latencies]' \
    '(-m --monitor)'{-m,--monitor}'[monitor links and ports]' \
    '(-I --id)'{-I,--id}'[list IDs (unique link and port IDs)]' \
    '(-v --verbose)'{-v,--verbose}'[verbose port properties]' \
    '(-L --linger)'{-L,--linger}'[link persists after pw-link exits]' \
    '(-P --passive)'{-P,--passive}'[passive link]' \
    '(-p --props)'{-p+,--props=}'[properties as JSON object]:json:' \
    '(-d --disconnect)'{-d,--disconnect}'[disconnect ports]' \
    '*:src port then dst port:' \
    && ret=0

return ret
