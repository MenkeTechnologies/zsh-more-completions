#compdef wgquick wg-quick wg_quick
# _wgquick — Jason A. Donenfeld WireGuard wgquick CLI command-line bash-script helper around wg the WireGuard userspace utility setting up tearing-down WireGuard network interfaces parsing the standard interface-config-file with PostUp PreUp PostDown PreDown DNS Table-Address MTU PersistentKeepalive directives for systemd-resolvconf-integration (Jason A. Donenfeld team, bash); getopt
# upstream: https://www.wireguard.com/

_wgquick() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '*:command:(up down save strip)' \
        '*:config:_files -g "*.conf"'
}

_wgquick "$@"
