#compdef so-deny
# _so-deny — Security Onion so-deny CLI for managing firewall deny-list rules removing IP addresses from host_groups updating iptables and minion mine data revoking access to Security Onion services (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-deny() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[ip address or CIDR]:str:' \
        '--ip=+[ip address or CIDR]:str:' \
        '-r+[role]:r:(analyst nginx logstash beats syslog osquery wazuh mongo elasticsearch kibana fleet strelka misp playbook hunt thehive cortex docker registry minion master ssh)' \
        '--role=+[role]:r:(analyst nginx logstash beats syslog osquery wazuh mongo elasticsearch kibana fleet strelka misp playbook hunt thehive cortex docker registry minion master ssh)' \
        '-d+[description]:str:' \
        '--description=+[description]:str:' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-f[force]' \
        '--force[force]' \
        '-l[list current denials]' \
        '--list[list current denials]' \
        '-x[dry-run]' \
        '--dry-run[dry-run]' \
        '-a[apply now]' \
        '--apply[apply now]'
}

_so-deny "$@"
