_lunite() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '1: :_lunite_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                run|compile|debug|sandbox)
                    _arguments '1:Lunite source file:_files -g "*.luna"' && ret=0 ;;
                build|clean|version)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_lunite_commands] )) ||
_lunite_commands() {
    local -a commands
    commands=(
        'run:execute a Lunite source file via the interpreter'
        'compile:compile a Lunite source file to .lunb bytecode (LBVM)'
        'debug:run a source file with full debug tracing (tokens + AST + execution log)'
        'sandbox:run a source file with restricted I/O / FS / network capability'
        'build:interactive build wizard (bundles source + deps + LBVM runtime)'
        'clean:clean build artifacts / cached bytecode'
        'version:print Lunite version information'
    )
    _describe -t commands 'lunite command' commands
}

_lunite "$@"
