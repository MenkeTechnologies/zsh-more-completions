#compdef hsmtool hsm_tool
# _hsmtool — Core Lightning hsmtool CLI for managing Core Lightning hsm_secret file backups passphrase encryption decryption seed phrases recovery dump-onchain-secrets derive node-id show-channel-secret (ElementsProject team, C); getopt
# upstream: https://github.com/ElementsProject/lightning

_hsmtool() {
    local -a sub=(
        'encrypt:encrypt hsm_secret'
        'decrypt:decrypt hsm_secret'
        'dumpcommitments:dump on-chain commitments'
        'dump-onchain-secrets:dump on-chain secrets'
        'guesstoremote:guess to_remote address'
        'generatehsm:generate new hsm_secret'
        'checkhsm:check hsm_secret integrity'
        'dumphsm:dump hsm_secret as hex'
        'node-id:show node ID'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--testnet[use testnet]' \
        '--bitcoin[use mainnet]' \
        '--regtest[use regtest]' \
        '--signet[use signet]' \
        '--liquid[use liquid]' \
        '--password=+[password]:str:' \
        '--no-stdin-password[no stdin password]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hsmtool subcommand' sub ;;
        args)
            case $words[1] in
                encrypt|decrypt|dumphsm|node-id|checkhsm) _arguments \
                    '*:hsm_secret file:_files -g "hsm_secret"' ;;
                dumpcommitments) _arguments \
                    '*:peer-node-id channel-id commitment-id hsm_secret:' ;;
                guesstoremote) _arguments \
                    '*:p2wpkh-addr key-id max-channels hsm_secret:' ;;
                generatehsm) _arguments \
                    '*:output hsm_secret file:_files' ;;
            esac
            ;;
    esac
}

_hsmtool "$@"
