#compdef sstableofflinerelevel
# Documentation: https://cassandra.apache.org/doc/4.1/cassandra/tools/sstable/sstableofflinerelevel.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '--dry-run[print actions without performing them]' \
  '1:keyspace:' \
  '2:column family:' && ret=0

return ret
