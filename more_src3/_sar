#compdef sar
# Documentation: https://man7.org/linux/man-pages/man1/sar.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sar - system activity reporter (sysstat)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help / equivalent to --pretty --human]' \
  '(- *)-V[show version]' \
  '-A[report all activities]' \
  '-b[report I/O and transfer rate statistics]' \
  '-B[report paging statistics]' \
  '-C[include comments from data file]' \
  '-d[report block device activity]' \
  '-D[use saYYYYMMDD instead of saDD filename]' \
  '-e+[end time (HH\:MM\:SS)]:end time' \
  '-F[display filesystem statistics]' \
  '-f+[read data from file]:file:_files' \
  '-H[report hugepages utilization]' \
  '-I+[report interrupt statistics]:interrupt:(ALL)' \
  '-i+[interval seconds between displayed records]:seconds:' \
  '-j+[display persistent device names]:type:(ID LABEL PATH UUID)' \
  '-m+[report power management statistics]:keyword:(CPU FAN FREQ IN TEMP USB ALL)' \
  '-n+[report network statistics]:keyword:(DEV EDEV NFS NFSD SOCK IP EIP ICMP EICMP TCP ETCP UDP ALL)' \
  '-o+[save data to file]:file:_files' \
  '-P+[report per-processor statistics]:cpu list:(ALL)' \
  '-p[pretty-print device names]' \
  '-q[report queue length and load averages]' \
  '-r[report memory utilization statistics]' \
  '-s+[start time (HH\:MM\:SS)]:start time' \
  '-S[report swap space utilization]' \
  '-t[display timestamps in original locale time]' \
  '-u[report CPU utilization]' \
  '-v[report kernel tables status]' \
  '-w[report task creation and system switching]' \
  '-W[report swapping statistics]' \
  '-x[extended reports with min/max values]' \
  '-y[report TTY device activity]' \
  '-z[omit activities with zero values]' \
  '1:interval (seconds)' \
  '2:count' \
  && ret=0

return ret
