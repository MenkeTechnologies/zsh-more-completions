#compdef swipl-win
# Documentation: https://www.swi-prolog.org/pldoc/man?section=cmdline
# Reference accessed: 2026-05-21
# Verified: upstream SWI-Prolog command-line manual at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--abi-version[show ABI version]' \
  '(- *)--arch[show architecture]' \
  '(- *)--dump-runtime-variables=-[dump link info]:format:' \
  '-g+[execute goal before top level]:goal:' \
  '-t+[use custom interactive top level goal]:goal:' \
  '-f+[initialization file (use none to skip)]:file:_files' \
  '-s+[load script file after initialization]:file:_files' \
  '-l+[load file (compat with other Prolog systems)]:file:_files' \
  '-F+[startup script in home directory]:script:' \
  '-x+[boot from specific boot file]:bootfile:_files' \
  '-b+[bootstrap compilation init file]:initfile:_files' \
  '-o+[output executable]:file:_files' \
  '-c[compile file]' \
  '-q[suppress informational messages]' \
  '--quiet[suppress informational messages]' \
  '--no-debug[disable debugging]' \
  '--no-threads[disable threading]' \
  '--no-packs[do not attach extension packages]' \
  '--stack-limit=[limit combined Prolog stacks]:size:' \
  '--table-space=[limit tabling memory]:size:' \
  '--shared-table-space=[limit shared table space]:size:' \
  '*:Prolog source file:_files -g "*.(pl|pro|prolog)"' && ret=0

return ret
