#compdef hclfmt
# Documentation: https://github.com/hashicorp/hcl/tree/main/cmd/hclfmt
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '-check[syntax check, no rewrite]' \
  '-require-no-change[non-zero exit if file would change]' \
  '-w[overwrite source files]' \
  '(- *)-version[print version]' \
  '*:hcl file:_files -g "*.(hcl|tf|tfvars)"'
