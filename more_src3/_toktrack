#compdef toktrack
# Documentation: https://github.com/mag123c/toktrack
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for toktrack (LLM token & cost tracker)

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'daily:overview with daily view'
  'weekly:overview with weekly view'
  'monthly:overview with monthly view'
  'stats:open the Stats tab'
  'report:generate a usage report'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[Print help message]' \
  '(- *)'{-V,--version}'[Show version information]' \
  '--json[Output in JSON format]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'toktrack command' commands && ret=0
    ;;
  args)
    case $words[1] in
      report)
        _arguments \
          '--month[report covering the last 30 days]' \
          '--days=[custom day range]:days:' \
          '--svg[also write SVG output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
