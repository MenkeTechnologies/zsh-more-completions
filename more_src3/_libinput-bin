#compdef libinput
# _libinput-bin — libinput debug + analysis CLI (Peter Hutterer, Red Hat); user-space input device driver suite for Wayland/X
# upstream: https://gitlab.freedesktop.org/libinput/libinput

_libinput-bin() {
    local -a sub=(
        'list-devices:print all libinput devices and their config'
        'debug-events:print events as libinput sees them'
        'debug-gui:GUI debugger for evdev events'
        'measure:run a measurement script'
        'record:record device events to a YAML file'
        'replay:replay a recorded YAML file'
        'analyze:analyze a recorded session'
        'quirks:device quirks list/match'
        'test:run libinput test suite'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'libinput subcommand' sub ;;
        args)
            case $words[1] in
                record|replay|analyze|debug-events) _arguments '*:device or file:_files' ;;
                quirks) _arguments '1:quirks cmd:(list match show)' '*:args:' ;;
            esac
            ;;
    esac
}

_libinput-bin "$@"
