#compdef smassh
# _smassh — Kraanzu typing speed test TUI in textual (kraanzu team, Python); custom argparse
# upstream: https://github.com/kraanzu/smassh

_smassh() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--list-languages[list available languages]' \
        '--list-themes[list available themes]' \
        '--config=+[config file]:file:_files' \
        '--language=+[language]:str:' \
        '--theme=+[theme]:str:' \
        '--reset[reset config]'
}

_smassh "$@"
