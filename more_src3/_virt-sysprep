#compdef virt-sysprep
# _virt-sysprep — libguestfs virt-sysprep (reset a virtual machine image so it can be cloned: clean SSH host keys, machine-id, logs, NIC udev rules; -a domain disk file, -d domain name, --connect URI, --enable list of operations, --operations selector, --selinux-relabel, --no-logfile)
# upstream: https://github.com/libguestfs/libguestfs (sysprep)
# Flags from libguestfs sysprep/sysprep_main.ml on tip.

_virt-sysprep() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[trace libguestfs calls]' \
        '-q[quiet]' \
        '*-a+[disk image]:file:_files' \
        '*--add+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '*--domain+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '--connect+[libvirt URI]:uri:' \
        '--enable=*[ops to enable]:ops:' \
        '--operations=*[ops list]:ops:' \
        '--list-operations[list operations]' \
        '--selinux-relabel[relabel SELinux]' \
        '--mount-options=*[mount options]:options:' \
        '--no-logfile[do not write logfile]' \
        '--keep-user-accounts=*[users to keep]:users:' \
        '--firstboot+[firstboot script]:file:_files' \
        '--scrub=*[file/glob to scrub]:glob:' \
        '--dry-run[dry run]'
}

_virt-sysprep "$@"
