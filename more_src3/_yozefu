#compdef yozefu
# Documentation: https://github.com/MAIF/yozefu
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'configure:define and register new Kafka clusters'
  'create-filter:build custom search filters in Rust'
  'import-filter:load WebAssembly-based user filters'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--cluster=[registered cluster to connect to]:cluster:' \
  '--headless[run in CLI mode rather than TUI]' \
  '--topics=[filter specific topics]:topics:' \
  '--format=[serialization format]:format:(json xml text)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'yozefu command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
