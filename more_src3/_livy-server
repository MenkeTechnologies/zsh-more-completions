#compdef livy-server
# Documentation: https://github.com/apache/incubator-livy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'start:start the Livy server'
  'stop:stop the Livy server'
  'status:show server status'
)

_arguments -C \
  '1: :->action' && ret=0

case $state in
  (action)
    _describe -t actions 'livy-server action' actions && ret=0
    ;;
esac

return ret
