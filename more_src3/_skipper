#compdef skipper
# Documentation: https://github.com/zalando/skipper
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Skipper: HTTP router and reverse proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-routes-file=[routes file]:file:_files' \
  '-eskip-file=[routes file (eskip)]:file:_files' \
  '-routes-url=[routes URL]:url:' \
  '-address=[listen address]:addr:' \
  '-kubernetes[enable kubernetes data source]' \
  '-kubernetes-in-cluster[in-cluster kubernetes]' \
  '-kubernetes-url=[kubernetes API URL]:url:' \
  '-kubernetes-token-file=[token file]:file:_files' \
  '-kubernetes-namespace=[namespace]:ns:' \
  '-kubernetes-ingress-class=[ingress class]:class:' \
  '-kubernetes-https-redirect[enable HTTPS redirect]' \
  '-application-log-output=[application log path]:file:_files' \
  '-application-log-level=[application log level]:level:(panic fatal error warn info debug)' \
  '-access-log-output=[access log path]:file:_files' \
  '-access-log-disabled[disable access log]' \
  '-debug-listener=[debug listener address]:addr:' \
  '-metrics-listener=[metrics listener address]:addr:' \
  '-prometheus-metrics[enable Prometheus metrics format]' \
  '-tls-cert=[TLS cert file]:file:_files' \
  '-tls-key=[TLS key file]:file:_files' \
  '-tls-min-version=[TLS min version]:ver:' \
  '-proxy-preserve-host[preserve Host header]' \
  '-write-timeout-server=[server write timeout]:duration:' \
  '-read-timeout-server=[server read timeout]:duration:' \
  '-idle-timeout-server=[server idle timeout]:duration:' \
  '-max-loopbacks=[max loopbacks]:n:' \
  '*::skipper args:_files' && ret=0
return ret
