#compdef prettier
# Documentation: https://prettier.io/docs/cli
# Source: prettier/prettier — opinionated code formatter CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-w --write -c --check -l --list-different)'{-w,--write}'[rewrite processed files in place]' \
    '(-w --write -c --check -l --list-different)'{-c,--check}'[check formatting and list unformatted files]' \
    '(-w --write -c --check -l --list-different)'{-l,--list-different}'[print filenames differing from Prettier]' \
    '--debug-check[error if code correctness might have changed]' \
    '--find-config-path[locate config file for a given file]:file:_files' \
    '(--config --no-config)--config=[custom configuration file]:file:_files' \
    '(--config --no-config)--no-config[do not look for a config file]' \
    '--ignore-path=[file containing ignore patterns]:file:_files' \
    '--config-precedence=[config-vs-CLI precedence]:mode:(cli-override file-override prefer-file)' \
    '--no-editorconfig[do not honor .editorconfig]' \
    '--with-node-modules[do not ignore files in node_modules]' \
    '--log-level=[CLI log level]:level:(silent error warn log debug)' \
    '--stdin-filepath=[file path that stdin should be treated as]:path:_files' \
    '(-u --ignore-unknown)'{-u,--ignore-unknown}'[ignore unknown files matched by patterns]' \
    '--no-error-on-unmatched-pattern[no error when patterns match no files]' \
    '--cache[enable formatting cache]' \
    '--no-cache[disable formatting cache]' \
    '--cache-location=[cache file path]:path:_files' \
    '--cache-strategy=[cache strategy]:strategy:(metadata content)' \
    '--parser=[explicit parser]:parser:(babel babel-ts flow typescript css less scss html angular vue lwc json json5 jsonc graphql markdown mdx yaml glimmer)' \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '*:file or glob:_files' \
    && ret=0

return ret
