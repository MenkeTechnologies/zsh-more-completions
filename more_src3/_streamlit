#compdef streamlit
# Documentation: https://docs.streamlit.io/develop/api-reference/cli
# Reference accessed: 2026-05-21
# Verified: docs.streamlit.io CLI reference (run, hello, config show,
# cache clear, docs, version, help, init). `activate` retained as it
# is still recognized by the upstream CLI. Run-time config flags
# follow the documented period-prefix pattern (e.g. --server.port);
# only canonical TOML keys are listed.
# Removed from prior file: bogus man.archlinux.org search URL.

# Streamlit CLI completion

_streamlit_subcommands() {
  local -a subcmds=(
    'run:Run a Streamlit app'
    'hello:Run the Streamlit hello demo'
    'init:Scaffold files for a new Streamlit app'
    'config:Manage Streamlit configuration'
    'cache:Manage the Streamlit cache'
    'docs:Open Streamlit docs in browser'
    'help:Show available CLI commands'
    'version:Print the Streamlit version'
    'activate:Activate Streamlit'
  )
  _describe -t commands 'streamlit subcommand' subcmds
}

_streamlit() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_streamlit_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        run)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--server.port=[server port]:port' \
            '--server.address=[server address]:address' \
            '--server.headless=[run headless]:headless:(true false)' \
            '--server.runOnSave=[rerun on file save]:run on save:(true false)' \
            '--theme.base=[base theme]:theme:(light dark)' \
            '--theme.primaryColor=[primary color]:color' \
            '--browser.serverAddress=[browser server address]:address' \
            '--logger.level=[log level]:level:(error warning info debug)' \
            '--client.showErrorDetails=[show error details]:show:(true false)' \
            '1:script file:_files -g "*.py"' \
            '*:args:'
          ;;
        hello)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
        config)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(show)'
          ;;
        cache)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '1:action:(clear)'
          ;;
        init|docs|help|version|activate)
          _arguments \
            '(- *)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_streamlit "$@"
