#compdef starship
# _starship — Starship cross-shell prompt (Rust-based minimal/fast prompt for zsh/bash/fish/pwsh/nu)
# upstream: https://github.com/starship/starship
# Subcommands + flags from src/main.rs on tip (clap-derive).

_starship() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'bug-report:create a pre-populated GitHub issue with environment info'
                'completions:emit shell completion script to stdout'
                'config:edit the starship configuration TOML'
                'explain:explain the currently shown prompt modules'
                'init:print the shell function used to install the prompt'
                'module:print a single prompt module'
                'preset:print or write a preset config'
                'print-config:print the computed starship config'
                'prompt:print the full starship prompt'
                'session:generate a random session key'
                'statusline:print the statusline for a given provider'
                'timings:print timings for all active modules'
                'toggle:toggle a starship module on/off'
                'help:show help for any subcommand'
            )
            _describe -t commands 'starship command' subs
            ;;
        args)
            case $line[1] in
                completions)
                    _arguments '1: :->shell'
                    case $state in
                        shell) _describe -t commands 'shell' '(bash elvish fish nushell powershell zsh)' ;;
                    esac
                    ;;
                init)
                    _arguments \
                        '--print-full-init[emit the full init source instead of the boot stub]' \
                        '1:shell:(bash zsh fish powershell nushell elvish tcsh ion xonsh)'
                    ;;
                module)
                    _arguments \
                        '(-l --list)'{-l,--list}'[list all supported modules]' \
                        '1:module:'
                    ;;
                preset)
                    _arguments \
                        '(-l --list)'{-l,--list}'[list preset names]' \
                        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
                        '(-f --force)'{-f,--force}'[overwrite existing output file]' \
                        '1:preset:'
                    ;;
                print-config)
                    _arguments \
                        '(-d --default)'{-d,--default}'[print default config instead of computed]' \
                        '*:keys:'
                    ;;
                prompt)
                    _arguments \
                        '--right[print the right prompt]' \
                        '--profile=[use this profile name]:name:' \
                        '--continuation[print the continuation prompt]'
                    ;;
                statusline)
                    _arguments \
                        '--profile=[profile name]:name:' \
                        '1:provider:(claude-code)'
                    ;;
                toggle)
                    _arguments \
                        '1:module:' \
                        '2:key:'
                    ;;
            esac
            ;;
    esac
}

_starship "$@"
