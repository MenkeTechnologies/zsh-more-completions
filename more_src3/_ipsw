#compdef ipsw
# Documentation: https://blacktop.github.io/ipsw/docs/cli/ipsw/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (blacktop/ipsw CLI).

# ipsw: download and parse Apple firmware (IPSW/OTA)
local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'appstore:interact with the App Store Connect API'
  'class-dump:dump Objective-C class information'
  'comp:compress files'
  'decomp:decompress files'
  'device-info:lookup device info'
  'device-list:list all iOS devices'
  'diff:diff IPSWs'
  'disk:disk commands'
  'download:download Apple firmware files'
  'dtree:parse DeviceTree'
  'dyld:parse dyld_shared_cache'
  'ent:search IPSW filesystem for entitlements'
  'extract:extract parts from IPSWs'
  'fw:firmware commands'
  'idev:device commands'
  'img3:parse img3 files'
  'img4:parse img4 files'
  'info:display IPSW/OTA info'
  'kernel:parse kernelcache'
  'lsbom:list contents of a bom file'
  'macho:parse MachO files'
  'mdevs:list mobile devices'
  'mount:mount DMG from IPSW'
  'ota:parse OTA files'
  'pbzx:decompress pbzx files'
  'pkg:parse a Apple package file'
  'plist:dump plist as JSON'
  'pongo:PongoOS commands'
  'sb:profile parsing'
  'ssh:SSH into a jailbroken device'
  'swift-dump:dump Swift information'
  'symbolicate:symbolicate crashlogs'
  'version:print the version number'
  'watch:watch git commits'
  'help:help about any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --verbose)'{-V,--verbose}'[verbose output]' \
  '--config=[config file]:file:_files' \
  '--color[colorize output]' \
  '--no-color[disable colorized output]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ipsw subcommand' subcommands && ret=0
    ;;
  (args)
    _files
    ret=0
    ;;
esac

return ret
