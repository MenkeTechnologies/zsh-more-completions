#compdef vkeybd
# _vkeybd — virtual MIDI keyboard for X (tiwai/vkeybd)
# upstream: https://github.com/tiwai/vkeybd
# Flags from vkeybd.man.

_vkeybd() {
    _arguments \
        '--device[output device mode]:mode:(awe midi alsa)' \
        '--config[config file]:file:_files' \
        '--preset[preset list file]:file:_files' \
        '--channel[normal channel number]:num:' \
        '--drum[drum channel number]:num:' \
        '--octave[number of octaves to display]:num:' \
        '--addr[ALSA client:port destination]:addr:' \
        '--name[client / port name]:name:' \
        '--bankmsb[bank select sent to MSB only (0/1)]:flag:(0 1)' \
        '--seqdev[OSS sequencer device]:file:_files' \
        '--seqidx[synth device index for AWE]:num:' \
        '--mididev[MIDI device file path]:file:_files'
}

_vkeybd "$@"
