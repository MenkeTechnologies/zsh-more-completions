#compdef innxbatch
# Documentation: man innxbatch(8)
# Source: InterNetNews/inn backends/innxbatch.c — send XBATCH files to NNTP host (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D[debug output]' \
    '-i[read filenames from stdin]' \
    '-t+[connect timeout seconds]:secs:_default' \
    '-T+[total transmit timeout seconds]:secs:_default' \
    '-v[verbose statistics]' \
    '1:host:_hosts' \
    '*:xbatch file:_files' \
    && ret=0

return ret
