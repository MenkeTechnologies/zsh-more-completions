#compdef tpm2_hmac
# _tpm2_hmac — tpm2-software tpm2_hmac perform an HMAC using a TPM2 HMAC key (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_hmac() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[hmac key context]:file:_files' \
        '--key-context=+[hmac key context]:file:_files' \
        '-C+[hmac key context]:file:_files' \
        '-p+[key auth password]:str:' \
        '--auth=+[key auth password]:str:' \
        '-P+[key auth password]:str:' \
        '-g+[hash algorithm]:a:(sha1 sha256 sha384 sha512)' \
        '--hash-algorithm=+[hash algorithm]:a:(sha1 sha256 sha384 sha512)' \
        '-o+[hmac output]:file:_files' \
        '--output=+[hmac output]:file:_files' \
        '-t+[validation ticket]:file:_files' \
        '--ticket=+[validation ticket]:file:_files' \
        '-S+[session]:str:' \
        '--session=+[session]:str:' \
        '--hex[hex encode hmac]' \
        '-Q[do not output anything]' \
        '*:input file:_files'
}

_tpm2_hmac "$@"
