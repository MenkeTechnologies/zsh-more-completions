#compdef libfsapfs-tools
# _libfsapfs2 — libfsapfs tools alias (single-binary entry-point bundling fsapfsinfo + fsapfsmount via argv[0] dispatch on systems that ship libfsapfs as a one-stop CLI; -h help, -V version, -v verbose, -o image offset, -p password, -r recovery key, -X exclusive; positional argument is the APFS image)
# upstream: https://github.com/libyal/libfsapfs
# Common flag shape from libyal/libfsapfs fsapfstools/* on tip.

_libfsapfs2() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-r+[recovery key]:key:' \
        '-X[exclusive]' \
        '*:APFS image:_files'
}

_libfsapfs2 "$@"
