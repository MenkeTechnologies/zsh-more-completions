#compdef secrets-cli teller
# _secrets-cli — SpectralOps Teller secrets/env manager CLI alias (SpectralOps / Jonathan Spw, Go); spf13/cobra
# upstream: https://github.com/tellerops/teller

_secrets-cli() {
    local -a sub=(
        'copy:copy secrets between providers'
        'delete:delete secrets'
        'env:print env vars'
        'export:export to format'
        'graph:visualize secret graph'
        'init:scaffold .teller.yml'
        'mirror-drift:detect mirror drift'
        'new:scaffold provider'
        'put:put a secret'
        'redact:redact stdin'
        'run:run command with env'
        'scan:scan filesystem for secrets'
        'sh:print POSIX shell exports'
        'show:show secrets'
        'sync:sync secrets between providers'
        'template:render template'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".teller.yml *.yml *.yaml"' \
        '-c+[config file]:file:_files -g ".teller.yml *.yml *.yaml"' \
        '--silent[silent]' \
        '--no-prompt[no prompt]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'teller subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--reset[reset env]' \
                    '-r[reset env]' \
                    '--shell-script[shell script mode]' \
                    '-s[shell script mode]' \
                    '*:cmd:_command_names -e' ;;
                env|sh|export|show|graph) _arguments \
                    '--no-mask[no mask]' \
                    '*:provider:' ;;
                copy) _arguments \
                    '--from=+[from provider]:str:' \
                    '--to=+[to provider]:str:' \
                    '--sync-name=+[sync name]:str:' ;;
                sync) _arguments \
                    '--from=+[from provider]:str:' \
                    '--to=+[to provider]:str:' ;;
                scan) _arguments \
                    '--silent[silent]' \
                    '*:path:_files' ;;
                redact) _arguments \
                    '--in=+[input file]:file:_files' \
                    '--out=+[output file]:file:_files' ;;
                put) _arguments '*:key=value:' ;;
                delete) _arguments '*:provider-key:' ;;
                init) _arguments \
                    '--providers=+[providers list]:list:' \
                    '--gitignore[add to gitignore]' ;;
                mirror-drift) _arguments \
                    '--source=+[source]:str:' \
                    '--target=+[target]:str:' ;;
                template) _arguments \
                    '--in=+[input file]:file:_files' \
                    '--out=+[output file]:file:_files' ;;
                new) _arguments \
                    '1:provider:' ;;
            esac
            ;;
    esac
}

_secrets-cli "$@"
