#compdef hgrep
# Documentation: https://github.com/rhysd/hgrep
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --min-context)'{-c+,--min-context=}'[minimum lines of context]:lines:' \
  '(-C --max-context)'{-C+,--max-context=}'[maximum lines of context]:lines:' \
  '(-G --no-grid)'{-G,--no-grid}'[remove borderlines for compact output]' \
  '--tab=[spaces per tab]:n:' \
  '--theme=[syntax highlighting theme]:theme:' \
  '--list-themes[list available themes]' \
  '--printer=[printer to use]:printer:(bat syntect)' \
  '--term-width=[terminal width]:n:' \
  '--wrap=[text wrapping mode]:mode:(char never)' \
  '(-f --first-only)'{-f,--first-only}'[show only first match per file]' \
  '(-E --encoding)'{-E+,--encoding=}'[specify text encoding]:encoding:' \
  '--no-ignore[do not respect .gitignore]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case insensitive matching]' \
  '(-S --smart-case)'{-S,--smart-case}'[smart case sensitivity]' \
  '--hidden[search hidden files]' \
  '*'{-u,--unrestricted}'[reduce filtering (repeatable)]' \
  '*'{-g+,--glob=}'[include/exclude glob pattern]:glob:' \
  '--glob-case-insensitive[case-insensitive glob matching]' \
  '(-F --fixed-strings)'{-F,--fixed-strings}'[literal string search]' \
  '(-w --word-regexp)'{-w,--word-regexp}'[match whole words]' \
  '(-L --follow)'{-L,--follow}'[follow symbolic links]' \
  '(-U --multiline)'{-U,--multiline}'[multi-line matching]' \
  '--multiline-dotall[dot matches newlines]' \
  '--crlf[treat CRLF as line terminator]' \
  '--mmap[use memory mapping]' \
  '(-m --max-count)'{-m+,--max-count=}'[max matches per file]:n:' \
  '--max-depth=[max directory depth]:n:' \
  '--max-filesize=[max file size]:size:' \
  '(-x --line-regexp)'{-x,--line-regexp}'[line boundary matching]' \
  '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
  '(-P --pcre2)'{-P,--pcre2}'[use PCRE2 regex engine]' \
  '*'{-t+,--type=}'[file type filter]:type:' \
  '*'{-T+,--type-not=}'[negate file type filter]:type:' \
  '--type-list[show supported file types]' \
  '--one-file-system[do not cross filesystems]' \
  '--no-unicode[disable unicode matching]' \
  '(-j --threads)'{-j+,--threads=}'[number of threads]:n:' \
  '--ignore-file=[additional ignore file]:file:_files' \
  '--background[paint background colors]' \
  '--ascii-lines[ASCII borders instead of Unicode]' \
  '--custom-assets[load bat custom assets]' \
  '--generate-man-page[generate manual page]' \
  '1:pattern:' \
  '*:path:_files' && ret=0

return ret
