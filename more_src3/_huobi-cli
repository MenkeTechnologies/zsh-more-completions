#compdef huobi-cli huobi htx-cli htx
# _huobi-cli — HTX formerly Huobi huobi-cli CLI command-line frontend wrapping the HTX Huobi Global cryptocurrency exchange Spot Margin Futures Coin-Swap USDT-Swap REST WebSocket API managing accounts wallets orders trades positions market kline tickers depth funding deposit withdrawal transfer sub-account contract-account (HTX team, Go); cobra
# upstream: https://www.htx.com/

_huobi-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'wallet:wallet operations'
        'deposit:deposit operations'
        'withdrawal:withdrawal operations'
        'transfer:transfer operations'
        'subaccount:sub-account management'
        'spot:spot operations'
        'margin:margin operations'
        'futures:futures operations'
        'swap:swap operations'
        'market:market data'
        'kline:kline candlestick data'
        'ticker:ticker operations'
        'depth:order book depth'
        'symbol:symbol operations'
        'currency:currency operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-key=+[key]:str:' \
        '--secret-key=+[secret]:str:' \
        '--api-url=+[url]:str:' \
        '--account-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'huobi-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel cancel-all history)' \
                    '--symbol=+[sym]:str:' \
                    '--type=+[t]:t:(buy-market sell-market buy-limit sell-limit buy-ioc sell-ioc buy-limit-maker sell-limit-maker buy-stop-limit sell-stop-limit buy-limit-fok sell-limit-fok)' \
                    '--amount=+[N]:str:' \
                    '--price=+[N]:str:' \
                    '*:order id:' ;;
                account|trade|position|wallet|deposit|withdrawal|transfer|subaccount|spot|margin|futures|swap|symbol|currency) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                market|kline|ticker|depth) _arguments \
                    '--symbol=+[sym]:str:' \
                    '--period=+[p]:p:(1min 5min 15min 30min 60min 4hour 1day 1mon 1week 1year)' \
                    '--size=+[N]:n:' ;;
            esac
            ;;
    esac
}

_huobi-cli "$@"
