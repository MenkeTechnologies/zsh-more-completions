#compdef iio_reg
# _iio_reg — read/write IIO device registers (analogdevicesinc/libiio)
# upstream: https://github.com/analogdevicesinc/libiio
# Common flags from utils/iio_common.c (getopt_long). Positional: <device> <register> [<value>]

_iio_reg() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-u --uri)'{-u+,--uri=}'[IIO context URI]:uri:' \
        '(-S --scan)'{-S+,--scan=}'[scan backends]:backends:' \
        '(-a --auto)'{-a+,--auto=}'[auto-detect context]:backends:' \
        '(-T --timeout)'{-T+,--timeout=}'[I/O timeout (ms)]:ms:' \
        '1:device:' \
        '2:register address:' \
        '3:value (omit to read):'
}

_iio_reg "$@"
