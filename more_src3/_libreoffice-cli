#compdef libreoffice-cli
# _libreoffice-cli — Document Foundation LibreOffice productivity suite CLI alias (LibreOffice team, C++); custom argparse
# upstream: https://github.com/LibreOffice/core

_libreoffice-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--writer[start Writer]' \
        '--calc[start Calc]' \
        '--impress[start Impress]' \
        '--draw[start Draw]' \
        '--math[start Math]' \
        '--base[start Base]' \
        '--global[create global document]' \
        '--web[create new HTML document]' \
        '--show=+[file]:file:_files -g "*.{odp,pptx,ppt,pps}"' \
        '--view=+[file]:file:_files' \
        '--norestore[no restore]' \
        '--safe-mode[safe mode]' \
        '--quickstart[enable quickstart]' \
        '--quickstart=+[bool]:b:(yes no)' \
        '--nofirststartwizard[no first start wizard]' \
        '--accept=+[connection string]:str:' \
        '--unaccept=+[connection string]:str:' \
        '--language=+[language]:str:' \
        '--pidfile=+[file]:file:_files' \
        '--display=+[X display]:str:' \
        '--headless[headless]' \
        '--invisible[invisible]' \
        '--nologo[no logo]' \
        '--nolockcheck[no lock check]' \
        '--nodefault[no default]' \
        '--minimized[minimized]' \
        '--convert-to=+[format]:str:' \
        '--outdir=+[output dir]:dir:_files -/' \
        '--print-to-file=+[file]:file:_files' \
        '--printer-name=+[printer]:str:' \
        '--cat=+[file]:file:_files' \
        '--terminate_after_init[terminate after init]' \
        '--unattended[unattended]' \
        '--writer[as Writer]' \
        '--xmlversion[show xml version]' \
        '--remote=+[document]:file:_files' \
        '--noquickstart[no quickstart]' \
        '--protector=+[protector lib]:file:_files' \
        '--p[print]' \
        '*:files:_files -g "*.{odt,docx,doc,rtf,txt,odp,pptx,ppt,ods,xlsx,xls,csv,odg,svg,odb,odm}"'
}

_libreoffice-cli "$@"
