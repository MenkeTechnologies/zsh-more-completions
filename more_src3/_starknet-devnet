#compdef starknet-devnet
# Documentation: https://github.com/0xSpaceShard/starknet-devnet (crates/starknet-devnet/src/cli.rs)
# Reference accessed: 2026-05-29
# Local Starknet testnet (Rust rewrite of starknet-devnet).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--accounts=[number of accounts to be predeployed]:n:' \
  '--account-class=[class used by predeployed accounts]:class:(cairo0 cairo1)' \
  '--account-class-custom=[path to a Cairo Sierra artifact for predeployed accounts]:path:_files' \
  '--predeclare-argent[predeclare Argent account contract classes]' \
  '(-e --initial-balance)'{-e,--initial-balance=}'[initial balance of accounts]:amount:' \
  '--seed=[seed for randomness of accounts]:seed:' \
  '--host=[address to listen at (default localhost)]:host:_hosts' \
  '--port=[port to listen at (default 5050)]:port:' \
  '--timeout=[server timeout in seconds (default 20)]:seconds:' \
  '--gas-price=[gas price in wei per L1 gas unit]:wei:' \
  '--gas-price-fri=[gas price in FRI per L1 gas unit]:fri:' \
  '--data-gas-price=[data gas pricing in wei]:wei:' \
  '--data-gas-price-fri=[data gas pricing in FRI]:fri:' \
  '--l2-gas-price=[L2 gas pricing in wei]:wei:' \
  '--l2-gas-price-fri=[L2 gas pricing in FRI]:fri:' \
  '--start-time=[start time in seconds]:seconds:' \
  '--block-generation-on=[block creation timing]:mode:(transaction interval demand)' \
  '--state-archive-capacity=[state archive capacity]:n:(none full)' \
  '--dump-on=[when to dump the state]:mode:(exit block transaction request)' \
  '--dump-path=[dump file path (required if --dump-on is exit or block)]:file:_files' \
  '--lite-mode[skip block hash calculation]' \
  '--proof-mode=[proof calculation strategy]:mode:(devnet skip strict)' \
  '--chain-id=[chain id]:id:(MAINNET TESTNET SEPOLIA)' \
  '--fork-network=[URL of network to fork from]:url:_urls' \
  '--fork-block=[block number for forking]:n:' \
  '--fork-upstream-caching=[enable upstream caching]:bool:(true false)' \
  '--maximum-contract-class-size=[max contract class size (bytes)]:bytes:' \
  '--maximum-contract-bytecode-size=[max contract bytecode size (felts)]:felts:' \
  '--maximum-sierra-length=[max Sierra length (felts)]:felts:' \
  '*--restrictive-mode=[forbidden JSON-RPC methods]:method:' \
  '--metrics-host=[metrics server address]:host:_hosts' \
  '--metrics-port=[metrics server port (default 9090)]:port:' && ret=0

return ret
