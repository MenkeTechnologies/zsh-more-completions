#compdef Xephyr xephyr
# Documentation: man Xephyr (X.Org)
# Source: X server that runs in an X11 window on another X server.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-screen+[screen size WxH]:geom:' \
    '-parent+[parent window id to embed into]:id:' \
    '-host-cursor[use host server cursor]' \
    '-resizeable[allow the window to be resized]' \
    '-no-host-grab[do not grab keyboard/pointer]' \
    '-fullscreen[fullscreen on the host display]' \
    '-output+[host RandR output to attach to]:output:' \
    && ret=0

return ret
