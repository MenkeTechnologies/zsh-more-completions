#compdef run-mailcap see edit compose print
# Documentation: man run-mailcap(1)
# Source: Debian mime-support run-mailcap (man) — execute mailcap entries (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--action=[action to perform]:action:(view cat compose composetyped edit print)' \
    '--debug[show extra debug info]' \
    '--nopager[ignore copiousoutput; send to stdout]' \
    '--norun[show command, do not execute]' \
    '*:[MIME-TYPE\:[ENCODING\:]]FILE:_files' \
    && ret=0

return ret
