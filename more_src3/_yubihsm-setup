#compdef yubihsm-setup
# _yubihsm-setup — Yubico yubihsm-setup CLI initial provisioning tool for YubiHSM2 device generating wrapping keys SSH CA host keys importing PGP key materials with M-of-N threshold sharing for new-hardware-out-of-box-experience hardened deployment (Yubico team, C++); cli11
# upstream: https://github.com/Yubico/yubihsm-shell

_yubihsm-setup() {
    local -a sub=(
        'ksp:setup Key Storage Provider deployment'
        'ejbca:setup EJBCA HSM signer'
        'dump:dump existing configuration'
        'export:export wrapped objects'
        'restore:restore wrapped objects'
        'reset:factory reset device'
        'version:print version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--connector=+[url]:str:' \
        '--authkey=+[id]:n:' \
        '--password=+[pw]:str:' \
        '-d[debug]' \
        '--debug[debug]' \
        '--no-new-authkey[do not create new auth key]' \
        '--shares=+[n]:n:' \
        '--threshold=+[t]:n:' \
        '--wrap-id=+[id]:n:' \
        '--out-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yubihsm-setup subcommand' sub ;;
    esac
}

_yubihsm-setup "$@"
