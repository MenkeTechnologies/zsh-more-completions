#compdef keymgr
# Documentation: https://www.knot-dns.cz/docs/latest/html/man_keymgr.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Corrected from prior file: added real -e/--extended and -j/--json
# options; replaced fabricated list-zones/list-keys/list-policies/
# list-keystores/cds/import-skr command stubs with the real keymgr
# command set (list, generate, import-*, set, ds, dnskey, delete,
# share, nsec3-salt, master-serial, keystore-test, keystore-bench,
# pregenerate, show-offline, del-offline, del-all-old, generate-ksr,
# sign-ksr, validate-skr, import-skr).

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show program help]' \
  '(- *)'{-V,--version}'[display program version]' \
  '(-c --config)'{-c+,--config=}'[textual configuration file]:file:_files -g "*.conf"' \
  '(-C --confdb)'{-C+,--confdb=}'[binary configuration database directory]:dir:_files -/' \
  '(-D --dir)'{-D+,--dir=}'[KASP database path with default configuration]:dir:_files -/' \
  '(-t --tsig)'{-t+,--tsig=}'[generate TSIG key (name [algorithm [bits]])]:tsig:' \
  '(-e --extended)'{-e,--extended}'[display keys with full description]' \
  '(-j --json)'{-j,--json}'[output zones or keys in JSON format]' \
  '(-l --list)'{-l,--list}'[list zones with stored keys]' \
  '(-x --mono)'{-x,--mono}'[disable colorized output]' \
  '(-X --color)'{-X,--color}'[force colorized output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

local -a top_cmds=(
  'list:display key IDs and parameters of a zone'
  'generate:generate a new DNSSEC key'
  'import-bind:import a BIND-style key'
  'import-pub:import a public key only'
  'import-pem:import a key from a PEM file'
  'import-pkcs11:import a key from a PKCS#11 store'
  'set:modify key timing or ksk/zsk parameters'
  'ds:generate a DS record for a key'
  'dnskey:generate a DNSKEY record for a key'
  'delete:remove a key'
  'share:share a key between zones'
  'nsec3-salt:print or set the NSEC3 salt'
  'master-serial:display or change the SOA serial'
  'keystore-test:test keystore functionality'
  'keystore-bench:run a keystore performance benchmark'
  'pregenerate:pre-generate ZSKs for a period'
  'show-offline:display pre-generated offline records'
  'del-offline:remove pre-generated offline records'
  'del-all-old:delete obsolete key files'
  'generate-ksr:create a Key Signing Request (KSR)'
  'sign-ksr:sign a KSR producing an SKR'
  'validate-skr:verify a Signed Key Response'
  'import-skr:import signatures from a Signed Key Response'
)

case $state in
  (cmd) _describe -t cmds 'keymgr command' top_cmds && ret=0 ;;
  (args)
    case $line[1] in
      (import-bind|import-pem|import-pub)
        _arguments '*::file:_files' && ret=0 ;;
      (sign-ksr|validate-skr|import-skr)
        _arguments '*::file:_files' && ret=0 ;;
    esac ;;
esac

return ret
