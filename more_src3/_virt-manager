#compdef virt-manager
# Documentation: https://manpages.org/virt-manager
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --connect)'{-c+,--connect=}'[hypervisor connection URI]:uri:' \
  '--debug[debug output to console (implies --no-fork)]' \
  '--no-fork[do not background; block current terminal]' \
  '--no-conn-autostart[do not autostart libvirt connections]' \
  '--show-domain-creator[open new-VM wizard]' \
  '--show-domain-editor=[edit VM properties]:vm:' \
  '--show-domain-performance=[show VM performance]:vm:' \
  '--show-domain-console=[show VM console]:vm:' \
  '--show-host-summary[show host summary window]' \
  '--spice-disable-auto-usbredir[disable automatic SPICE USB redirection]'
