#compdef ykchalresp
# Documentation: https://developers.yubico.com/yubikey-personalization/Manuals/ykchalresp.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '-1[send challenge to slot 1 (default)]' \
  '-2[send challenge to slot 2]' \
  '-H[send 64-byte HMAC challenge (default)]' \
  '-Y[send 6-byte Yubico OTP challenge]' \
  '-N[non-blocking; abort if button required]' \
  '-x[challenge is hex-encoded]' \
  '-v[verbose mode]' \
  '-6[output response in OATH 6-digit format]' \
  '-8[output response in OATH 8-digit format]' \
  '-t[use current time as challenge]' \
  '-i+[read challenge from file (- for stdin)]:file:_files' \
  '-n+[send challenge to nth key found]:n:' \
  '(- *)-V[print version]' \
  ':challenge:'
