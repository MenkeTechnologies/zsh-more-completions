#compdef haklistgen
# _haklistgen — hakluke haklistgen CLI minimal wordlist mutation generator written in Go consuming words on stdin emitting per-word case-permutation prefix-suffix-mutation special-char-injection number-injection variants for bug-bounty fuzzing brute-force enumeration directory-discovery password-spray pipelines (hakluke team, Go); pflag
# upstream: https://github.com/hakluke/haklistgen

_haklistgen() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c[case mutate]' \
        '--case[case mutate]' \
        '-n[number suffix]' \
        '--numbers[number suffix]' \
        '-s+[special chars]:str:' \
        '--special=+[chars]:str:' \
        '-p+[prefixes]:str:' \
        '--prefixes=+[list]:str:' \
        '-x+[suffixes]:str:' \
        '--suffixes=+[list]:str:' \
        '-l+[leet substitutions]:str:' \
        '--leet=+[list]:str:' \
        '-d[dedupe output]' \
        '--dedupe[dedupe output]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '*:input file:_files'
}

_haklistgen "$@"
