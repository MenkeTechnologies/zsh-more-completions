#compdef wxhexeditor wxHexEditor
# _wxhexedit — Erdem U. Altinyurt wxHexEditor (wxWidgets cross-platform hex editor that can edit huge files (1TB+) and raw block devices; --read-only opens RO, --no-backup skips .bak, --geometry WxH+X+Y, positional list of files to open in tabs)
# upstream: https://sourceforge.net/projects/wxhexeditor/
# Flags from wxHexEditor src/wxHexEditor.cpp on tip.

_wxhexedit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--read-only[read-only]' \
        '--no-backup[no .bak backup file]' \
        '--geometry+[WxH+X+Y]:geom:' \
        '*:file:_files'
}

_wxhexedit "$@"
