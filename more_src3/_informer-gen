#compdef informer-gen
# _informer-gen — Kubernetes SharedIndexInformer generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/informer-gen/args/args.go on tip.

_informer-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-dir=[output directory]:dir:_files -/' \
        '--output-pkg=[output Go package path]:pkg:' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '--internal-clientset-package=[internal clientset package path]:pkg:' \
        '--versioned-clientset-package=[versioned clientset package path]:pkg:' \
        '--listers-package=[listers package path]:pkg:' \
        '--single-directory=[emit all informers into a single directory]:bool:(true false)' \
        '--plural-exceptions=[singular=plural exceptions (comma-sep)]:list:' \
        '*--lint-rules=[gengo lint rules to enable (comma-sep)]:rules:' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_informer-gen "$@"
