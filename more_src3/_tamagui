#compdef tamagui
# Documentation: https://github.com/tamagui/tamagui/tree/main/code/core/cli
# Reference accessed: 2026-05-21
# Verified: upstream src at code/core/cli/src/cli.ts.

# Zsh completion for Tamagui CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check for inconsistent versions, duplicate installs, lockfile issues, missing config'
  'generate:build your entire tamagui configuration and output any CSS'
  'generate-css:generate the tamagui.generated.css file from your config'
  'generate-themes:pre-build your themes'
  'add:add fonts and icons to your monorepo'
  'build:pre-build a Tamagui component directory with optimization'
  'upgrade:upgrade all tamagui packages in your workspace to latest version'
  'update-template:update your git repo with the source template (e.g. Takeout)'
  'generate-prompt:generate an LLM-friendly markdown file from your Tamagui config'
)

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'tamagui command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build|b)
        _arguments -s -S \
          '--debug[enable debug output]' \
          '--verbose[enable detailed debug output]' \
          '--dry-run[preview changes]' \
          '--target=[target platform]:target:' \
          '--include=[glob pattern for files to include]:pattern:' \
          '--exclude=[glob pattern for files to exclude]:pattern:' \
          '--output=[output directory]:dir:_directories' \
          '--output-around[place output next to source files]' \
          '--expect-optimizations=[expected optimization count]:n:' \
          '--help[show help]' \
          '1:path:_files' && ret=0
        ;;
      (check|generate|generate-css|generate-themes|add)
        _arguments -s -S \
          '--help[show help]' \
          '--debug[enable debug output]' \
          '--verbose[enable detailed debug output]' \
          '--output=[output path]:file:_files' && ret=0
        ;;
      (upgrade|up)
        _arguments -s -S \
          '--help[show help]' \
          '--debug[enable debug output]' \
          '--from=[upgrade from version]:version:' \
          '--to=[upgrade to version]:version:' \
          '--changelog-only[show changelog only]' \
          '--dry-run[preview changes]' && ret=0
        ;;
      (update-template|ut)
        _arguments -s -S \
          '--help[show help]' \
          '--template-repo=[template repo]:repo:' \
          '--ignored-patterns=[patterns to ignore]:patterns:' && ret=0
        ;;
      (generate-prompt)
        _arguments -s -S \
          '--help[show help]' \
          '--debug[enable debug output]' \
          '--output=[output path]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
