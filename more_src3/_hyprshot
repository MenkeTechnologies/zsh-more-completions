#compdef hyprshot
# Documentation: https://github.com/Gustash/Hyprshot
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hyprshot — utility to easily take screenshots in Hyprland using grim and slurp

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-m --mode)'{-m+,--mode=}'[capture mode]:mode:(output window region active)' \
  '(-o --output-folder)'{-o+,--output-folder=}'[save folder]:dir:_files -/' \
  '(-f --filename)'{-f+,--filename=}'[output filename]:file:' \
  '(-D --delay)'{-D+,--delay=}'[delay seconds before capture]:secs' \
  '(-t --notif-timeout)'{-t+,--notif-timeout=}'[notification timeout (ms)]:ms' \
  '(-z --freeze)'{-z,--freeze}'[freeze screen during init]' \
  '(-d --debug)'{-d,--debug}'[print debug info]' \
  '(-s --silent)'{-s,--silent}'[suppress notifications]' \
  '(-r --raw)'{-r,--raw}'[output raw image data to stdout]' \
  '--clipboard-only[copy to clipboard only, do not save]' \
  '*::open-command:_normal' && ret=0

return ret
