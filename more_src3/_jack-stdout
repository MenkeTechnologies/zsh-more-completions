#compdef jack-stdout
# _jack-stdout — capture audio from JACK and write raw data to stdout (x42/jack-stdout)
# upstream: https://github.com/x42/jack-stdout
# Flags from jack-stdout(1) man page.

_jack-stdout() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-b --bitdepth)'{-b+,--bitdepth=}'[sample bit depth (16 or 24)]:bits:(16 24)' \
        '(-d --duration)'{-d+,--duration=}'[run duration in seconds (<1 = infinite)]:sec:' \
        '(-e --encoding)'{-e+,--encoding=}'[output encoding]:format:(signed-integer unsigned-integer floating-point)' \
        '(-L --little-endian -B --big-endian)'{-L,--little-endian}'[little-endian / native float]' \
        '(-L --little-endian -B --big-endian)'{-B,--big-endian}'[big-endian / byte-swapped float]' \
        '(-q --quiet)'{-q,--quiet}'[suppress info / overflow warnings]' \
        '(-S --bufsize)'{-S+,--bufsize=}'[internal ring-buffer size in samples]:samples:' \
        '*:JACK port:'
}

_jack-stdout "$@"
