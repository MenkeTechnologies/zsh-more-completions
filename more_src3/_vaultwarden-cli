#compdef vaultwarden-cli vaultwarden
# _vaultwarden-cli — Vaultwarden Bitwarden-compatible self-hosted vault CLI alias (dani-garcia team, Rust); custom argparse
# upstream: https://github.com/dani-garcia/vaultwarden

_vaultwarden-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.{env,toml}"' \
        '-c+[config file]:file:_files -g "*.{env,toml}"' \
        '--data-folder=+[data folder]:dir:_files -/' \
        '-d+[data folder]:dir:_files -/' \
        '--database-url=+[database URL]:str:' \
        '--database-max-conns=+[max conns]:n:' \
        '--domain=+[public domain]:url:_urls' \
        '--admin-token=+[admin token]:str:' \
        '--rocket-port=+[port]:port:' \
        '-p+[port]:port:' \
        '--rocket-address=+[bind address]:host:_hosts' \
        '--rocket-workers=+[workers]:n:' \
        '--rocket-tls=+[tls config]:str:' \
        '--rocket-env=+[env]:e:(development staging production)' \
        '--web-vault-folder=+[web vault dir]:dir:_files -/' \
        '--web-vault-enabled=+[bool]:b:(true false)' \
        '--signups-allowed=+[bool]:b:(true false)' \
        '--signups-verify=+[bool]:b:(true false)' \
        '--signups-domains-whitelist=+[domains csv]:str:' \
        '--smtp-host=+[smtp host]:host:_hosts' \
        '--smtp-port=+[smtp port]:port:' \
        '--smtp-from=+[smtp from address]:str:' \
        '--smtp-username=+[smtp user]:user:_users' \
        '--smtp-password=+[smtp password]:str:' \
        '--smtp-ssl=+[bool]:b:(true false)' \
        '--smtp-explicit-tls=+[bool]:b:(true false)' \
        '--websocket-enabled=+[bool]:b:(true false)' \
        '--websocket-address=+[ws address]:host:_hosts' \
        '--websocket-port=+[ws port]:port:' \
        '--push-enabled=+[bool]:b:(true false)' \
        '--push-relay-uri=+[relay uri]:url:_urls' \
        '--push-installation-id=+[install id]:str:' \
        '--push-installation-key=+[install key]:str:' \
        '--icon-cache-folder=+[icon cache dir]:dir:_files -/' \
        '--icon-blacklist-regex=+[regex]:str:' \
        '--show-password-hint=+[bool]:b:(true false)' \
        '--invitations-allowed=+[bool]:b:(true false)' \
        '--emergency-access-allowed=+[bool]:b:(true false)' \
        '--user-attachment-limit=+[mb]:n:' \
        '--org-attachment-limit=+[mb]:n:' \
        '--extended-logging=+[bool]:b:(true false)' \
        '--log-file=+[log file]:file:_files' \
        '--log-level=+[level]:l:(trace debug info warn error off)' \
        '--ip-header=+[header]:str:' \
        '--reload-templates=+[bool]:b:(true false)' \
        '*:arg:'
}

_vaultwarden-cli "$@"
