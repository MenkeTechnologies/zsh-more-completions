#compdef jps
# Documentation: https://docs.oracle.com/en/java/javase/21/docs/specs/man/jps.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-help[display help message]' \
  '-q[suppress output of class/JAR name and arguments]' \
  '-m[display arguments passed to the main method]' \
  '-l[display full package name of main class or JAR path]' \
  '-v[display arguments passed to the JVM]' \
  '-V[suppress output of class/JAR name and arguments]' \
  '*:hostid:_hosts'
