#compdef hackrf_info hackrf_transfer hackrf_clock hackrf_debug hackrf_operacake hackrf_sweep hackrf_spiflash hackrf_cpldjtag hackrf
# _hackrf — Great Scott Gadgets HackRF One open-source SDR command-line utilities for capture transmit firmware (greatscottgadgets team, C); getopt
# upstream: https://github.com/greatscottgadgets/hackrf

_hackrf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[device serial]:str:' \
        '-r+[receive file or "-"]:file:_files' \
        '-t+[transmit file or "-"]:file:_files' \
        '-w[receive with hackrf_one]' \
        '-f+[frequency Hz]:n:' \
        '-i+[IF frequency Hz]:n:' \
        '-o+[LO frequency Hz]:n:' \
        '-m+[image reject]:m:(bypass low high)' \
        '-a+[antenna power]:b:(0 1)' \
        '-p+[amp enable]:b:(0 1)' \
        '-l+[LNA gain dB]:n:' \
        '-g+[VGA gain dB]:n:' \
        '-x+[TX gain dB]:n:' \
        '-s+[sample rate Hz]:n:' \
        '-n+[N samples]:n:' \
        '-b+[baseband filter bandwidth Hz]:n:' \
        '-S[show output]' \
        '-c+[CW signal]:n:' \
        '-R[receive after transmit]' \
        '-B[binary output]' \
        '-T+[total time s]:n:' \
        '-w+[wait time s]:f:' \
        '-W+[total transfer bytes]:n:' \
        '-N+[N writes]:n:' \
        '-q[quiet]' \
        '-D+[device debug]' \
        '-A+[antenna A]' \
        '-z+[verbosity]:n:' \
        '*:command:'
}

_hackrf "$@"
