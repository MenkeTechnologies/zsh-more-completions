#compdef taiko
# _taiko — node browser automation library/REPL (getgauge/taiko)
# upstream: https://github.com/getgauge/taiko
# Flags from packages/taiko/bin/taiko.js (commander).

_taiko() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-o --observe)'{-o,--observe}'[headful mode with 3000ms default delay]' \
        '(-l --load)'{-l,--load}'[run file then start REPL to record further steps]' \
        '(-w --wait-time)'{-w+,--wait-time=}'[delay in ms between actions]:ms:' \
        '--emulate-device=[simulate device viewport]:device:' \
        '--emulate-network=[simulate network condition]:type:(GPRS Regular2G Good2G Regular3G Good3G Regular4G DSL WiFi Offline)' \
        '--plugin=[load taiko plugins (comma-separated)]:plugins:' \
        '--no-log[disable log output of taiko]' \
        '*:script file:_files -g "*.js"'
}

_taiko "$@"
