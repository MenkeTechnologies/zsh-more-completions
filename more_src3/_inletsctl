#compdef inletsctl
# _inletsctl — inlets/inlets-pro exit-server provisioner CLI (provisions inlets tunnel servers on AWS/GCP/Azure/DigitalOcean/Linode/Scaleway/OVH/Hetzner/Vultr)
# upstream: https://github.com/inlets/inletsctl
# Subcommands + flags from cmd/inletsctl.go + cmd/{create,delete,download,kfwd,update}.go on tip.

_inletsctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'create:provision a new inlets exit-server on a cloud provider'
                'delete:delete a previously provisioned exit-server'
                'download:download the inlets binary'
                'kfwd:forward a kubernetes service from this cluster to a remote inlets server'
                'update:update inletsctl to the latest version'
                'version:show version'
            )
            _describe -t commands 'inletsctl command' subs
            ;;
        args)
            local -a providers=(digitalocean gce ec2 azure scaleway linode hetzner ovh vultr)
            case $line[1] in
                create)
                    _arguments \
                        '(-p --provider)'{-p+,--provider=}'[cloud provider]:provider:('"${providers[*]}"')' \
                        '(-r --region)'{-r+,--region=}'[region]:region:' \
                        '(-s --plan)'{-s+,--plan=}'[plan or instance size]:plan:' \
                        '(-z --zone)'{-z+,--zone=}'[zone (gce)]:zone:' \
                        '(-t --inlets-token)'{-t+,--inlets-token=}'[auth token (blank = auto)]:token:' \
                        '(-a --access-token)'{-a+,--access-token=}'[cloud access token]:token:' \
                        '(-f --access-token-file)'{-f+,--access-token-file=}'[file with cloud access token]:file:_files' \
                        '--vpc-id=[VPC ID (ec2)]:id:' \
                        '--subnet-id=[Subnet ID (ec2)]:id:' \
                        '--secret-key=[cloud secret key]:key:' \
                        '--secret-key-file=[file with cloud secret key]:file:_files' \
                        '--session-token=[ec2 session token]:token:' \
                        '--session-token-file=[file with ec2 session token]:file:_files' \
                        '--organisation-id=[organisation ID (scaleway)]:id:' \
                        '--project-id=[project ID (gce, ovh)]:id:' \
                        '--subscription-id=[subscription ID (azure)]:id:' \
                        '--endpoint=[API endpoint (ovh)]:url:' \
                        '--consumer-key=[OVH consumer key]:key:' \
                        '--tcp[provision in inlets TCP server mode]' \
                        '--aws-key-name=[existing SSH key on AWS for the EC2 instance]:name:' \
                        '*--letsencrypt-domain=[domain for a LE cert (repeatable)]:domain:' \
                        '--letsencrypt-issuer=[LE issuer]:issuer:(prod staging)' \
                        '(-n --poll)'{-n+,--poll=}'[poll interval]:dur:' \
                        '--inlets-version=[inlets binary version]:ver:'
                    ;;
                delete)
                    _arguments \
                        '(-p --provider)'{-p+,--provider=}'[cloud provider]:provider:('"${providers[*]}"')' \
                        '(-r --region)'{-r+,--region=}'[region]:region:' \
                        '(-z --zone)'{-z+,--zone=}'[zone (gce)]:zone:' \
                        '(-a --access-token)'{-a+,--access-token=}'[cloud access token]:token:' \
                        '(-f --access-token-file)'{-f+,--access-token-file=}'[file with cloud access token]:file:_files' \
                        '(-i --id)'{-i+,--id=}'[host ID]:id:' \
                        '--ip=[host IP]:ip:' \
                        '--secret-key=[cloud secret key]:key:' \
                        '--secret-key-file=[file with cloud secret key]:file:_files' \
                        '--session-token=[ec2 session token]:token:' \
                        '--session-token-file=[file with ec2 session token]:file:_files' \
                        '--organisation-id=[organisation ID (scaleway)]:id:' \
                        '--project-id=[project ID (gce)]:id:' \
                        '--subscription-id=[subscription ID (azure)]:id:' \
                        '--endpoint=[API endpoint (ovh)]:url:' \
                        '--consumer-key=[OVH consumer key]:key:'
                    ;;
                download)
                    _arguments \
                        '--version=[specific inlets version to download]:ver:' \
                        '--download-to=[install directory]:dir:_files -/' \
                        '(-v --verbose)'{-v,--verbose}'[show download URL]'
                    ;;
                kfwd)
                    _arguments \
                        '(-f --from)'{-f+,--from=}'[k8s Service to forward (name)]:svc:' \
                        '(-i --if)'{-i+,--if=}'[laptop address inlets server connects to]:addr:' \
                        '(-n --namespace)'{-n+,--namespace=}'[source service namespace]:ns:' \
                        '--license=[inlets PRO license key]:key:' \
                        '--tcp[use inlets PRO TCP mode (false=HTTP)]'
                    ;;
            esac
            ;;
    esac
}

_inletsctl "$@"
