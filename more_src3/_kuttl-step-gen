#compdef kuttl-step-gen
# _kuttl-step-gen — Vertica Kubernetes operator helper that generates one iteration of randomized kuttl test steps from /tmp/local-soak.cfg
# upstream: https://github.com/vertica/vertica-kubernetes
# Source: cmd/kuttl-step-gen/main.go on tip; no CLI flags — config is read from the hard-coded path /tmp/local-soak.cfg.

_kuttl-step-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_kuttl-step-gen "$@"
