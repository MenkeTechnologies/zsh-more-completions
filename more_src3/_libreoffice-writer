#compdef swriter
# _libreoffice-writer — LibreOffice swriter / soffice --writer (word processor entrypoint; same headless/convert-to/outdir flags as the rest of the LO family, plus --writer to force document type and --view to open read-only)
# upstream: https://git.libreoffice.org/core
# Flags from libreoffice core/desktop/source/app on tip.

_libreoffice-writer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--headless[run without UI]' \
        '--norestore[skip restoring previous session]' \
        '--nologo[no splash]' \
        '--nofirststartwizard[skip wizard]' \
        '--safe-mode[start in safe mode]' \
        '--view[open read-only]' \
        '--convert-to+[convert to format]:format:(pdf docx odt doc rtf html epub fb2 fods)' \
        '--outdir+[output directory]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name+[printer]:printer:_printers' \
        '*-env+[env var]:key=value:' \
        '*:document:_files -g "*.(odt|docx|doc|rtf|txt|fodt|fb2|epub|html|md|md.txt)"'
}

_libreoffice-writer "$@"
