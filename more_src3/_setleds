#compdef setleds
# _setleds — Linux kbd setleds (set/clear NumLock/CapsLock/ScrollLock indicator + flag states on console keyboards; -F selects flags, -D default flags, -L LEDs, -v verbose; +/-num/+/-caps/+/-scroll toggle)
# upstream: https://github.com/legionus/kbd
# Flags from kbd src/setleds.c on tip.

_setleds() {
    _arguments \
        '-F[change current flag state]' \
        '-D[change default flag state]' \
        '-L[change LED state only]' \
        '-v[verbose]' \
        '*:state:(+num -num +caps -caps +scroll -scroll)'
}

_setleds "$@"
