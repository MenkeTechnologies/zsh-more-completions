#compdef imagor imagor-cli
# _imagor — Cshum imagor fast secure image processing server CLI for on-the-fly thumbor-compatible URL processing (cshum team, Go); pflag
# upstream: https://github.com/cshum/imagor

_imagor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--port=+[server port]:port:_ports' \
        '--debug[debug mode]' \
        '--auto-webp[auto serve WebP]' \
        '--auto-avif[auto serve AVIF]' \
        '--avif-speed=+[N]:n:' \
        '--secret=+[HMAC secret]:str:' \
        '--signer-type=+[type]:t:(sha1 sha256 sha512)' \
        '--signer-truncate=+[N]:n:' \
        '--unsafe[allow unsafe URLs]' \
        '--cache-header-ttl=+[seconds]:n:' \
        '--cache-header-swr=+[seconds]:n:' \
        '--cache-header-no-cache[no cache header]' \
        '--cache-header-private[private cache]' \
        '--http-loader-default-scheme=+[scheme]:s:(http https)' \
        '--http-loader-max-allowed-size=+[bytes]:n:' \
        '--http-loader-block-loopback-networks[block loopback]' \
        '--http-loader-block-private-networks[block private]' \
        '--http-loader-allowed-sources=+[hosts csv]:str:' \
        '--s3-loader-bucket=+[bucket]:str:' \
        '--s3-loader-base-dir=+[dir]:str:' \
        '--s3-loader-path-style[s3 path style]' \
        '--gcs-loader-bucket=+[bucket]:str:' \
        '--gcs-loader-base-dir=+[dir]:str:' \
        '--file-loader-base-dir=+[dir]:dir:_files -/' \
        '--file-storage-base-dir=+[dir]:dir:_files -/' \
        '--file-storage-path-prefix=+[prefix]:str:' \
        '--file-storage-mkdir-permission=+[mode]:str:' \
        '--file-storage-write-permission=+[mode]:str:' \
        '--file-storage-expiration=+[duration]:str:' \
        '--file-result-storage-base-dir=+[dir]:dir:_files -/' \
        '--s3-storage-bucket=+[bucket]:str:' \
        '--s3-storage-base-dir=+[dir]:str:' \
        '--s3-storage-acl=+[acl]:str:' \
        '--gcs-storage-bucket=+[bucket]:str:' \
        '--gcs-storage-base-dir=+[dir]:str:' \
        '--result-storage-stale-ttl=+[duration]:str:' \
        '--storage-expiration=+[duration]:str:' \
        '--server-cors[allow CORS]' \
        '--server-strip-query-string[strip query]' \
        '--server-path-prefix=+[prefix]:str:' \
        '--server-access-log[access log]' \
        '--server-keepalive-period=+[seconds]:n:' \
        '--server-read-timeout=+[seconds]:n:' \
        '--server-write-timeout=+[seconds]:n:' \
        '--imagor-request-timeout=+[seconds]:n:' \
        '--imagor-cache-header-ttl=+[seconds]:n:' \
        '--imagor-process-concurrency=+[N]:n:' \
        '--imagor-process-timeout=+[seconds]:n:' \
        '--vips-concurrency-level=+[N]:n:' \
        '--vips-max-filter-ops=+[N]:n:' \
        '--vips-disable-blur=+[bool]:b:(true false)' \
        '--vips-mozjpeg=+[bool]:b:(true false)' \
        '--vips-avif-speed=+[N]:n:' \
        '--vips-disable-filters=+[csv]:str:' \
        '--vips-strip-metadata=+[bool]:b:(true false)' \
        '--metrics-prometheus[enable Prometheus]'
}

_imagor "$@"
