#compdef tcksift
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tcksift.html
# Source: MRtrix3/mrtrix3 cmd/tcksift.cpp — SIFT: Spherical-deconvolution Informed Filtering of Tracts (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-nofilter[do not filter; build model for debugging output only]' \
    '-output_at_counts+[comma-separated counts at which to output filtered tracks]:counts:_default' \
    '-out_selection+[output text file with binary streamline selection]:path:_files' \
    '-output_debug[output debug images]' \
    '-proc_mask+[image processing mask]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-act+[ACT 5TT image for anatomical constraints]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-fd_scale_gm[scale GM fibre density (with -act)]' \
    '-no_dilate_lut[do not dilate FOD lobe lookup table]' \
    '-make_null_lobes[add null FOD lobes for unmatched stream contributions]' \
    '-remove_untracked[remove FOD lobes not reached by any streamline]' \
    '-fd_thresh+[fibre density threshold]:value:_default' \
    '-csv+[per-iteration CSV stats output]:path:_files' \
    '-mu+[output final mu coefficient to text file]:path:_files' \
    '-term_number+[terminate at this streamline count]:n:_default' \
    '-term_ratio+[terminate at this cost-function gradient ratio]:value:_default' \
    '-term_mu+[terminate when mu reaches this value]:value:_default' \
    '1:in_tracks:_files -g "*.{tck,trk}"' \
    '2:in_fod (SH FOD image):_files -g "*.{nii,nii.gz,mif}"' \
    '3:out_tracks (filtered):_files' \
    && ret=0

return ret
