#compdef ibchecknet
# Documentation: https://man7.org/linux/man-pages/man8/ibchecknet.8.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ibchecknet: scan IB subnet and check links for errors.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-N[use mono rather than color mode]' \
  '-nocolor[use mono rather than color mode]' \
  '-C+[channel adapter name]:ca name:' \
  '-P+[channel adapter port]:ca port:' \
  '-t+[override default timeout for solicited MADs]:timeout (ms):' \
  '*:topology file:_files' && ret=0
return ret
