#compdef tshark-cli
# _tshark-cli — Wireshark tshark terminal protocol analyzer CLI alias (wireshark team, C); custom argparse
# upstream: https://gitlab.com/wireshark/wireshark

_tshark-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-i+[interface]:_net_interfaces' \
        '-f+[capture filter]:str:' \
        '-s+[snapshot len]:n:' \
        '-p[no promiscuous mode]' \
        '-I[monitor mode (wifi)]' \
        '-B+[buffer size]:n:' \
        '-y+[link type]:str:' \
        '-D[list interfaces]' \
        '-L[list link types]' \
        '--list-time-stamp-types[list time stamp types]' \
        '--time-stamp-type=+[type]:str:' \
        '-c+[stop after n packets]:n:' \
        '-a+[stop condition]:str:' \
        '-b+[ring buffer condition]:str:' \
        '-n[no name resolution]' \
        '-N+[name resolution]:str:' \
        '-d+[decode as]:str:' \
        '-O+[only show these protos]:str:' \
        '-Y+[display filter]:str:' \
        '-w+[output file]:file:_files -g "*.pcap*"' \
        '-r+[read file]:file:_files -g "*.pcap*"' \
        '-R+[read filter]:str:' \
        '-T+[output format]:f:(ek fields json jsonraw pdml ps psml tabs text)' \
        '-e+[field]:str:' \
        '-E+[option=value]:str:' \
        '-F+[file format]:str:' \
        '-G+[report type]:r:(currentprefs decodes defaultprefs dissector-tables dissectors elastic-mapping fields ftypes heuristic-decodes plugins protocols values)' \
        '-V[verbose decode]' \
        '-x[print hex and ASCII dump]' \
        '-z+[statistics]:str:' \
        '-q[quiet]' \
        '-l[flush stdout after each packet]' \
        '-X+[eXtensions]:str:' \
        '-K+[kerberos keytab]:file:_files' \
        '-M+[max packet count]:n:' \
        '-S+[separator]:str:' \
        '-P[print packet summary]' \
        '-o+[name:value preference]:str:' \
        '-2[two-pass analysis]' \
        '--enable-protocol=+[protocol]:str:' \
        '--disable-protocol=+[protocol]:str:' \
        '--only-protocols=+[protocols]:str:' \
        '--disable-all-protocols[disable all]' \
        '--print[print parsed]' \
        '--export-objects=+[protocol,dir]:str:' \
        '--enable-heuristic=+[heuristic]:str:' \
        '--disable-heuristic=+[heuristic]:str:' \
        '--temp-dir=+[dir]:dir:_files -/' \
        '--color[colorize output]' \
        '--no-duplicate-keys[no dup keys json]' \
        '*:capture filter:'
}

_tshark-cli "$@"
