#compdef virt-tail
# _virt-tail — KubeVirt sidecar that tails a virt-launcher logfile into stdout
# upstream: https://github.com/kubevirt/kubevirt
# Flags from cmd/virt-tail/main.go on tip.

_virt-tail() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--logfile=[path of the logfile to be streamed]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_virt-tail "$@"
