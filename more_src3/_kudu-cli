#compdef kudu-cli kuductl
# _kudu-cli — Apache Kudu kudu-cli CLI command-line frontend wrapping the Apache Kudu cluster master tablet table-management columnar distributed storage low-latency analytics fast random-access write-optimized tablet leadership rebalance metadata schema column-name backup restore Spark-Impala-connectors integration scan (Apache Kudu team, C++); custom argparse
# upstream: https://kudu.apache.org/

_kudu-cli() {
    local -a sub=(
        'cluster:cluster operations'
        'master:master operations'
        'tserver:tablet-server operations'
        'tablet:tablet operations'
        'table:table operations'
        'fs:filesystem operations'
        'pbc:protobuf container'
        'remote_replica:remote replica operations'
        'wal:WAL operations'
        'test:test operations'
        'diagnose:diagnose operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-master_addresses=+[addrs]:str:' \
        '--master_addresses=+[addrs]:str:' \
        '-tserver_addresses=+[addrs]:str:' \
        '--tserver_addresses=+[addrs]:str:' \
        '--timeout_ms=+[ms]:n:' \
        '--negotiation_timeout_ms=+[ms]:n:' \
        '--auth_token_file=+[file]:file:_files' \
        '--principal=+[principal]:str:' \
        '--keytab=+[file]:file:_files' \
        '--columns=+[list]:str:' \
        '--num_threads=+[N]:n:' \
        '--num_buckets=+[N]:n:' \
        '--predicates=+[predicates]:str:' \
        '-format+[fmt]:f:(json pretty space tsv csv)' \
        '--format=+[format]:f:(json pretty space tsv csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kudu-cli subcommand' sub ;;
        args)
            case $words[1] in
                cluster) _arguments '1:op:(ksck rebalance status)' ;;
                master|tserver) _arguments '1:op:(status list dump_memtrackers get_flags set_flag list_metrics)' ;;
                table) _arguments '1:op:(list describe scan rename delete create alter add_range_partition drop_range_partition list_in_flight statistics)' '*:table name:' ;;
                tablet) _arguments '1:op:(list change_config status copy_from_remote leader_step_down get_flags set_flag)' '*:tablet id:' ;;
            esac
            ;;
    esac
}

_kudu-cli "$@"
