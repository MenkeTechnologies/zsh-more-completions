#compdef s6-socklog
# _s6-socklog — s6 daemontools-extras s6-socklog (syslog-receive daemon: bind a unix socket (-x) or UDP socket (-i), receive RFC 3164 syslog datagrams, and emit each line on stdout for downstream s6-log)
# upstream: https://github.com/skarnet/s6
# Flags from src/daemontools-extras/s6-socklog.c on tip.

_s6-socklog() {
    _arguments \
        '-d+[notification fd]:fd:' \
        '-r[chroot to its own directory]' \
        '(-U -u)-U[get UID/GID from $UID/$GID/$GIDLIST]' \
        '(-U -u)-u+[setuid to UID]:uid:_users' \
        '-g+[setgid to GID]:gid:_groups' \
        '-G+[set supplementary group list (csv)]:gids:' \
        '-l+[max line length]:bytes:' \
        '-t+[lame-duck timeout (ms)]:ms:' \
        '(-x -i)-x+[bind to unix socket]:file:_files' \
        '(-x -i)-i+[bind to UDP ip:port]:hostport:'
}

_s6-socklog "$@"
