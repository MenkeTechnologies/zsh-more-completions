#compdef thanos-cli thanosctl
# _thanos-cli — Thanos Prometheus HA tooling kingpin CLI subcommand alias (Thanos Project, Go); alecthomas/kingpin
# upstream: https://github.com/thanos-io/thanos

_thanos-cli() {
    local -a sub=(
        'sidecar:run sidecar alongside Prometheus'
        'store:run object-storage store gateway'
        'query:run querier'
        'query-frontend:run query frontend'
        'rule:run ruler'
        'compact:run compactor'
        'downsample:run downsampler'
        'receive:run receive component'
        'tools:misc tools'
        'check:run config check'
        'reshard:reshard receive ring'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--log.level=+[log level]:level:(debug info warn error)' \
        '--log.format=+[log format]:fmt:(logfmt json)' \
        '--tracing.config=+[tracing config]:file:_files' \
        '--tracing.config-file=+[tracing config file]:file:_files' \
        '--objstore.config=+[objstore config]:str:' \
        '--objstore.config-file=+[objstore config file]:file:_files' \
        '--http-address=+[http address]:addr:' \
        '--grpc-address=+[grpc address]:addr:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'thanos subcommand' sub ;;
        args)
            case $words[1] in
                sidecar) _arguments \
                    '--prometheus.url=+[prom url]:url:_urls' \
                    '--tsdb.path=+[tsdb path]:dir:_files -/' \
                    '--shipper.upload-compacted[upload compacted]' ;;
                store) _arguments \
                    '--data-dir=+[data dir]:dir:_files -/' \
                    '--chunk-pool-size=+[chunk pool size]:size:' \
                    '--index-cache-size=+[index cache size]:size:' \
                    '--max-time=+[max time]:time:' \
                    '--min-time=+[min time]:time:' ;;
                query) _arguments \
                    '--store=+[store address]:addr:' \
                    '--query.replica-label=+[replica label]:str:' \
                    '--query.timeout=+[query timeout]:dur:' \
                    '--query.partial-response[partial response]' \
                    '--web.external-prefix=+[external prefix]:str:' ;;
                compact) _arguments \
                    '--data-dir=+[data dir]:dir:_files -/' \
                    '--wait[wait after compaction]' \
                    '--retention.resolution-raw=+[raw retention]:dur:' \
                    '--retention.resolution-5m=+[5m retention]:dur:' \
                    '--retention.resolution-1h=+[1h retention]:dur:' \
                    '--compact.concurrency=+[concurrency]:n:' ;;
                tools) _arguments \
                    '1:tool:(bucket bench rules-check resharding receive)' \
                    '*:arg:' ;;
                receive) _arguments \
                    '--label=+[external label]:str:' \
                    '--tsdb.path=+[tsdb path]:dir:_files -/' \
                    '--remote-write.address=+[remote write address]:addr:' \
                    '--receive.local-endpoint=+[local endpoint]:addr:' ;;
            esac
            ;;
    esac
}

_thanos-cli "$@"
