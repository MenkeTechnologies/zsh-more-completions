#compdef luksdeinfo
# Documentation: https://github.com/libyal/libluksde
# Source: libyal/libluksde manuals/luksdeinfo.1 — display info about a Linux Unified Key Setup (LUKS) volume.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-k[volume master key in base16]:key:' \
    '-o[volume offset]:offset:' \
    '-p[password]:password:' \
    '-u[unattended (disable user interaction)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
