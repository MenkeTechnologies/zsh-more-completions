#compdef svelte-cli sv
# _svelte-cli — Svelte Team svelte-cli CLI command-line frontend wrapping the Svelte CLI sv command-line tool for the Svelte cybernetically-enhanced web apps and SvelteKit framework open-source written in TypeScript Node provides project scaffolding migration adders and other useful tools rich-harris Svelte Team CLI create migrate add check version help check sync preview vite kit Svelte 5 runes adapter-auto adapter-node adapter-static adapter-vercel adapter-netlify adapter-cloudflare adapter-cloudflare-workers (Svelte Team Rich Harris Pelle Wessman, TypeScript); commander
# upstream: https://svelte.dev/

_svelte-cli() {
    local -a sub=(
        'create:create a new Svelte project'
        'add:add a Svelte feature'
        'check:run Svelte check'
        'migrate:run automated migrations'
        'sync:sync generated files'
        'preview:preview production build'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--template=+[t]:t:(minimal demo library skeleton kit-minimal kit-demo kit-library)' \
        '-t+[template]:str:' \
        '--types=+[t]:t:(typescript jsdoc null)' \
        '--no-types[no types]' \
        '--no-add-ons[no add-ons]' \
        '--no-install[no install]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--svelte-version=+[v]:v:(4 5)' \
        '--package-manager=+[m]:m:(npm pnpm yarn bun deno)' \
        '--no-git-init[no git init]' \
        '--git[git init]' \
        '--workspace=+[name]:str:' \
        '--tsconfig=+[file]:file:_files -g "tsconfig.json *.json"' \
        '--watch[watch mode]' \
        '-w[watch]' \
        '--threshold=+[t]:t:(error warning hint)' \
        '--diagnostic-sources=+[sources]:str:' \
        '--ignore=+[paths]:str:' \
        '*--ignore=+[paths]:str:' \
        '--fail-on-warnings[fail on warnings]' \
        '--output=+[fmt]:f:(human human-verbose machine machine-verbose)' \
        '-o+[output]:f:(human human-verbose machine machine-verbose)' \
        '--no-tsconfig[no tsconfig]' \
        '--language=+[l]:l:(ts js)' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--https[use HTTPS]' \
        '--open[open browser]' \
        '--from=+[v]:v:(svelte-4 sveltekit-2 self-closing-tags)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sv subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments '*:feature:(prettier eslint vitest playwright tailwindcss drizzle storybook lucia mdsvex paraglide routify storyblok supabase auth typography forms i18n stripe contentful)' ;;
                create) _arguments '*:name:' ;;
                migrate) _arguments '1:from:(svelte-4 sveltekit-2 routes self-closing-tags app.html)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_svelte-cli "$@"
