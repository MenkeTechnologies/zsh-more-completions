#compdef zfind
# Documentation: https://github.com/laktak/zfind
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated GNU find-style flags (-name, -iname,
#   -regex, -size, -delete, -exec, -j, -L, -z, -maxdepth, -mindepth, etc.).
#   zfind takes a SQL-like <where> expression as positional arg, not flags.

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '-l[display results in long listing format]' \
  '--csv[show results in CSV format]' \
  '--csv-no-head[show results in CSV format without header row]' \
  '(-n --no-archive)'{-n,--no-archive}'[disable archive support]' \
  '-0[null-terminated output for piping to xargs]' \
  '1:where expression:' \
  '*:path:_files'
