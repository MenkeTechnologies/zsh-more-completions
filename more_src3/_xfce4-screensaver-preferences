#compdef xfce4-screensaver-preferences
# Documentation: https://github.com/xfce-mirror/xfce4-screensaver/blob/master/src/xfce4-screensaver-preferences.c
# Reference accessed: 2026-05-21
# Verified: GOptionEntry table in xfce4-screensaver-preferences.c plus gtk_init_with_args.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '(-s --socket-id)'{-s+,--socket-id=}'[settings manager socket]:socket_id:' \
  '--display=[X display to use]:display:' && ret=0
return ret
