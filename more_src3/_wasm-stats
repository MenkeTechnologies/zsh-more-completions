#compdef wasm-stats
# Documentation: https://github.com/WebAssembly/wabt
# Source: WebAssembly/wabt src/tools/wasm-stats.cc — emit per-opcode histogram and section sizes for a .wasm binary.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-v,--verbose}'[verbose (use multiple times)]' \
    '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files' \
    '(-c --cutoff)'{-c+,--cutoff=}'[cutoff for reporting counts less than N]:n:' \
    '(-s --separator)'{-s+,--separator=}'[separator between element and count]:sep:' \
    '*:input .wasm:_files -g "*.wasm"' \
    && ret=0

return ret
