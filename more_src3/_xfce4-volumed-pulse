#compdef xfce4-volumed-pulse
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/xfce4-volumed.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: xfce4-volumed(1) is the predecessor; same flag set per upstream.

# xfce4-volumed-pulse: PulseAudio volume daemon for XFCE
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-all[show all options]' \
  '--help-gtk[show GTK options]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-daemon[do not fork to background]' \
  '--display=[X display to use]:display:' && ret=0
return ret
