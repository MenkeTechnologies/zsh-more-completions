#compdef kim
# Documentation: https://github.com/rancher/kim
# Source: https://github.com/rancher/kim/blob/master/pkg/cli/cli.go
# Reference accessed: 2026-06-01
# Kubernetes Image Manager — build container images on k3s clusters via BuildKit.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _kim_cmds
_kim_cmds=(
    'image:manage images (subcommands: build/list/pull/push/remove/tag)'
    'builder:manage builders (install/uninstall/list)'
    'agent:internal agent subcommand'
    'build:shortcut for `image build`'
    'images:shortcut for `image list`'
    'pull:shortcut for `image pull`'
    'push:shortcut for `image push`'
    'rmi:shortcut for `image remove`'
    'tag:shortcut for `image tag`'
    'help:show help'
)

local -a _kim_image
_kim_image=(
    'build:build an image'
    'list:list images'
    'pull:pull an image'
    'push:push an image'
    'remove:remove an image'
    'tag:tag an image'
)

local -a _kim_builder
_kim_builder=(
    'install:install a builder into the cluster'
    'uninstall:remove the builder from the cluster'
    'list:list builders'
)

_arguments -C \
    '--debug[enable debug logging]' \
    '--kubeconfig=[path to kubeconfig file]:file:_files' \
    '--namespace=[Kubernetes namespace]:ns:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'kim command' _kim_cmds && ret=0
        ;;
    args)
        case $line[1] in
            image)
                _arguments -s -S \
                    '1:subcommand:->image-sub' \
                    '*::positional:_default' && ret=0
                case $state in
                    image-sub) _describe -t image 'image subcommand' _kim_image && ret=0 ;;
                esac
                ;;
            builder)
                _arguments -s -S \
                    '1:subcommand:->builder-sub' \
                    '*::positional:_default' && ret=0
                case $state in
                    builder-sub) _describe -t builder 'builder subcommand' _kim_builder && ret=0 ;;
                esac
                ;;
        esac
        ;;
esac

return ret
