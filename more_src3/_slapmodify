#compdef slapmodify
# _slapmodify — OpenLDAP slapmodify (offline LDIF modify importer that bypasses ACLs; -F config dir, -f slapd.conf, -b suffix, -l input LDIF, -n database number, -c continue on error, -g do not generate context CSN, -q quick mode, -u dry run, -d debug, -v verbose, -V version, -s stop after N entries)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slapmodify)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slapmodify() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-b+[suffix]:dn:' \
        '-l+[input LDIF]:file:_files -g "*.ldif"' \
        '-n+[database number]:n:' \
        '-c[continue on error]' \
        '-g[skip context CSN]' \
        '-q[quick mode]' \
        '-u[dry run]' \
        '-d+[debug level]:level:' \
        '-v[verbose]' \
        '-s+[stop after N entries]:n:'
}

_slapmodify "$@"
