#compdef hb-subset
# Documentation: hb-subset --help-all (HarfBuzz)
# Source: subset a font to a specified glyph / codepoint / text set.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--help-all[show all help options]' \
    '(- *)--help-face[font face help]' \
    '(- *)--help-subset-glyphset[subsetting glyph-set help]' \
    '(- *)--help-subset-other[subsetting other help]' \
    '(- *)--help-subset-flags[subsetting boolean help]' \
    '(- *)--help-output[output destination help]' \
    '(- *)--version[show version]' \
    {-n+,--num-iterations=}'[run subsetter N times]:n:' \
    '--face-index=[font face index]:n:' \
    {-o+,--output-file=}'[output file]:file:_files' \
    {-O+,--output-format=}'[output format]:fmt:(ttf otf woff woff2)' \
    {-u+,--unicodes=}'[codepoints]:list:' \
    '--unicodes-file=[codepoints file]:file:_files' \
    {-g+,--glyphs=}'[glyph indices]:list:' \
    '--glyphs-file=[glyph indices file]:file:_files' \
    '--text=[text to keep]:text:' \
    '--text-file=[text file]:file:_files' \
    '--gids=[glyph IDs]:list:' \
    '--name-IDs=[name IDs to keep]:list:' \
    '--name-languages=[name languages to keep]:list:' \
    '--layout-features=[layout features]:list:' \
    '--layout-scripts=[layout scripts]:list:' \
    '--drop-tables=[tables to drop]:list:' \
    '--variations=[variation axis pinning]:list:' \
    '--instance=[instance variations]:list:' \
    '--preprocess-face[preprocess the face]' \
    '--no-prune-unicode-ranges[do not prune unicode ranges]' \
    '--no-prune-codepage-ranges[do not prune codepage ranges]' \
    '--retain-gids[retain glyph IDs]' \
    '--desubroutinize[desubroutinize CFF]' \
    '--no-hinting[strip hinting]' \
    '--passthrough-tables[passthrough unknown tables]' \
    '--glyph-names[keep glyph names]' \
    '--no-notdef-outline[no notdef outline]' \
    '--set-overlaps-flag[set OVERLAP_SIMPLE flag]' \
    '--no-recalc-bounds[do not recompute bbox]' \
    '*:font file:_files -g "*.(ttf|otf|woff|woff2|ttc|otc)"' \
    && ret=0

return ret
