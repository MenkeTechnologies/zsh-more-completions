#compdef schedctl
# Documentation: man schedctl(8)
# Source: netbsd/src usr.sbin/schedctl — thread scheduling control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[processor affinity (comma-separated CPUs, -1 unsets)]:cpus:_default' \
    '-C+[scheduling policy]:class:(SCHED_OTHER SCHED_FIFO SCHED_RR)' \
    '-P+[priority (0-63, SCHED_FIFO/SCHED_RR only)]:priority:_default' \
    '-p+[target process ID]:pid:_pids' \
    '-t+[thread (LWP) ID within process]:lid:_default' \
    '*:::command:_normal' \
    && ret=0

return ret
