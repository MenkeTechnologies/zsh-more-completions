#compdef lammps lmp lmp_serial lmp_mpi
# Documentation: https://docs.lammps.org/Run_options.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '-help[show help]' \
  '-i+[input script]:file:_files -g "*.lmp"' \
  '-in+[input script]:file:_files -g "*.lmp"' \
  '-var+[set variable]:name value:' \
  '-v+[set variable]:name value:' \
  '-echo+[echo style]:style:(none screen log both)' \
  '-e+[echo style]:style:(none screen log both)' \
  '-log+[log file]:file:_files' \
  '-l+[log file]:file:_files' \
  '-screen+[screen output]:file:(none _files)' \
  '-sc+[screen output]:file:(none _files)' \
  '-nocite[do not print citation]' \
  '-nc[do not print citation]' \
  '-cite+[control citation output]:setting:(both none screen log)' \
  '-c+[control citation output]:setting:(both none screen log)' \
  '-suffix+[suffix for accelerated styles]:suffix:(opt omp gpu intel kk hybrid)' \
  '-sf+[suffix for accelerated styles]:suffix:(opt omp gpu intel kk hybrid)' \
  '-package+[package options]:package:' \
  '-pk+[package options]:package:' \
  '-kokkos+[Kokkos options]:options:' \
  '-k+[Kokkos options]:options:' \
  '-partition+[partition sizes]:sizes:' \
  '-p+[partition sizes]:sizes:' \
  '-plog+[per-partition log file]:file:_files' \
  '-pl+[per-partition log file]:file:_files' \
  '-pscreen+[per-partition screen output]:file:_files' \
  '-ps+[per-partition screen output]:file:_files' \
  '-restart2data+[convert restart to data file]:restart data:' \
  '-r2data+[convert restart to data file]:restart data:' \
  '-restart2dump+[convert restart to dump file]:restart dump:' \
  '-r2dump+[convert restart to dump file]:restart dump:' \
  '-restart2info+[show restart file information]:restart:' \
  '-r2info+[show restart file information]:restart:' \
  '-reorder+[reorder MPI ranks]:type:' \
  '-ro+[reorder MPI ranks]:type:' \
  '-mdi+[MolSSI Driver Interface flags]:flags:' \
  '-mpicolor+[MPI communicator split color]:color:' \
  '-m+[MPI communicator split color]:color:' \
  '-nonbuf[disable buffering for screen/log output]' \
  '-nb[disable buffering for screen/log output]' \
  '-skiprun[skip main simulation loops]' \
  '-sr[skip main simulation loops]' \
  '*:input file:_files' && ret=0

return ret
