#compdef tinkey
# Documentation: https://developers.google.com/tink/tinkey-overview
# Reference accessed: 2026-05-21
# Verified: upstream subcommand list at the URL above. Flag-level details
# (--in, --out, --key-template, etc.) are documented to be discovered by
# running `tinkey <command>`; values used here come from Tink CLI binary
# usage and are conservative.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show help'
  'add-key:add a key to keyset'
  'convert-keyset:convert keyset format/master key'
  'create-keyset:create new keyset'
  'create-public-keyset:create public keyset from private'
  'delete-key:delete key by id'
  'destroy-key:destroy key material'
  'disable-key:disable key by id'
  'enable-key:enable key by id'
  'list-keyset:list keys in keyset'
  'list-key-templates:list available key templates'
  'rotate-keyset:rotate primary key'
  'promote-key:promote key to primary'
)

local in_opts='--in=[input keyset]:file:_files
--in-format=[input format]:fmt:(json binary)
--master-key-uri=[master key URI]:uri:
--credential=[credential file]:file:_files'

local out_opts='--out=[output keyset]:file:_files
--out-format=[output format]:fmt:(json binary)'

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tinkey subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (list-keyset)
        _arguments ${(f)in_opts} && ret=0
        ;;
      (add-key|rotate-keyset)
        _arguments ${(f)in_opts} ${(f)out_opts} \
          '--key-template=[key template]:tmpl:' && ret=0
        ;;
      (create-keyset)
        _arguments ${(f)out_opts} \
          '--key-template=[key template]:tmpl:' && ret=0
        ;;
      (create-public-keyset)
        _arguments ${(f)in_opts} ${(f)out_opts} && ret=0
        ;;
      (convert-keyset)
        _arguments ${(f)in_opts} ${(f)out_opts} \
          '--new-master-key-uri=[new master key URI]:uri:' \
          '--new-credential=[new credential]:file:_files' && ret=0
        ;;
      (delete-key|destroy-key|disable-key|enable-key|promote-key)
        _arguments ${(f)in_opts} ${(f)out_opts} \
          '--key-id=[key id]:id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
