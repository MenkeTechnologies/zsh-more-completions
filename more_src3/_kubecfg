#compdef kubecfg
# Documentation: https://github.com/kubecfg/kubecfg/blob/main/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubecfg (Kubernetes Jsonnet config tool)
# Persistent flags taken from cmd/root.go (cobra root command).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'show:show expanded resource definitions'
  'diff:display differences between server and local config'
  'update:update Kubernetes resources with local config'
  'delete:delete Kubernetes resources described in local config'
  'validate:validate Kubernetes resources against API schemas'
  'eval:evaluate the jsonnet and print the result'
  'pack:pack the jsonnet sources into a single file'
  'httpd:serve the jsonnet over HTTP'
  'version:print version information'
  'completion:generate shell completion'
  'help:help about any command'
)

local -a global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '--alpha[enable alpha features]'
  '*'{-v,--verbose}'[increase verbosity, may be repeated]'
  '*'{-J+,--jpath=}'[additional Jsonnet library search path]:directory:_files -/'
  '*'{-U+,--jurl=}'[additional Jsonnet library search path given as a URL]:url'
  '*'{-V+,--ext-str=}'[external variable string values]:key=value'
  '*--ext-str-file=[read external string variables from files]:key=file:_files'
  '*--ext-code=[external variables supplied as Jsonnet code]:key=code'
  '*--ext-code-file=[read external code variables from files]:key=file:_files'
  '*'{-A+,--tla-str=}'[top level argument string values]:key=value'
  '*--tla-str-file=[read top level string arguments from files]:key=file:_files'
  '*--tla-code=[top level arguments supplied as Jsonnet code]:key=code'
  '*--tla-code-file=[read top level code arguments from files]:key=file:_files'
  '--resolve-images=[implementation of resolveImage native function]:resolver'
  '--resolve-images-error=[action when resolveImage fails]:action'
  '--qps-limit=[override k8s REST client-side rate limiting]:qps'
  '--kubeconfig=[path to a kube config]:kubeconfig:_files'
)

_arguments -s -S -C \
  $global_flags \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kubecfg command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (show|diff|update|validate|delete|eval|pack)
        _arguments -s -S \
          $global_flags \
          '*:jsonnet file:_files -g "*.(jsonnet|libsonnet|json|yaml|yml)(N)"' && ret=0
        ;;
      (help)
        _describe -t commands 'kubecfg command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
