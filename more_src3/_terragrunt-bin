#compdef terragrunt
# _terragrunt-bin — Gruntwork Terragrunt Terraform wrapper (Gruntwork, Go); keep configurations DRY across environments
# upstream: https://github.com/gruntwork-io/terragrunt

_terragrunt-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--terragrunt-config+[terragrunt config]:file:_files' \
        '--terragrunt-tfpath+[terraform binary]:file:_files' \
        '--terragrunt-no-auto-init[skip auto init]' \
        '--terragrunt-no-auto-retry[skip auto retry]' \
        '--terragrunt-non-interactive[non-interactive]' \
        '--terragrunt-working-dir+[working dir]:dir:_files -/' \
        '--terragrunt-download-dir+[download dir]:dir:_files -/' \
        '--terragrunt-source+[source]:src:' \
        '--terragrunt-source-update[update sources]' \
        '--terragrunt-source-map+[source map]:str:' \
        '--terragrunt-iam-role+[IAM role]:role:' \
        '--terragrunt-iam-assume-role-duration+[duration]:duration:' \
        '--terragrunt-iam-assume-role-session-name+[session name]:str:' \
        '--terragrunt-include-module-prefix[include module prefix]' \
        '--terragrunt-ignore-dependency-errors[ignore dependency errors]' \
        '--terragrunt-ignore-dependency-order[ignore dependency order]' \
        '--terragrunt-ignore-external-dependencies[ignore external deps]' \
        '--terragrunt-include-external-dependencies[include external deps]' \
        '--terragrunt-exclude-dir+[exclude dir]:dir:_files -/' \
        '--terragrunt-include-dir+[include dir]:dir:_files -/' \
        '--terragrunt-strict-include[strict include]' \
        '--terragrunt-strict-validate[strict validate]' \
        '--terragrunt-modules-that-include+[modules]:str:' \
        '--terragrunt-log-level+[log level]:level:(debug info warn error)' \
        '--terragrunt-debug[debug]' \
        '--terragrunt-check[check formatting]' \
        '--terragrunt-diff[show diff]' \
        '--terragrunt-hclfmt-file+[hclfmt file]:file:_files' \
        '--terragrunt-parallelism+[parallelism]:n:' \
        '--terragrunt-fetch-dependency-output-from-state[fetch from state]' \
        '--terragrunt-use-partial-parse-config-cache[use partial parse cache]' \
        '*:terraform args:'
}

_terragrunt-bin "$@"
