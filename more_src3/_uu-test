#compdef uu-test
# Documentation: https://uutils.github.io/coreutils/docs/utils/test.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: uutils test only honors --help/--version (no -h/-v) per
# POSIX-style test semantics; all other behavior is expression-based
# (operators like -e, -f, -d, -n, -z, -eq, etc.) not options.

autoload -U is-at-least

_uu-test() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--help[Print help]' \
'--version[Print version]' \
'*::expression:_default' \
&& ret=0
}

(( $+functions[_uu-test_commands] )) ||
_uu-test_commands() {
    local commands; commands=()
    _describe -t commands 'uu-test commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-test" ]; then
    _uu-test "$@"
else
    compdef _uu-test uu-test
fi
