#compdef starfetch
# _starfetch — terminal constellation viewer (Haruno19/starfetch)
# upstream: https://github.com/Haruno19/starfetch
# Flags from src/starfetch.cpp (argv switch).

_starfetch() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-l[list available constellations]'
        '-r[print a random constellation]'
        '-t[print a random constellation (alias of -r)]'
        '-n[select a constellation by name (optional "norse" set)]:type:(norse)'
        '-p[print the named constellation (legacy)]:name:'
        '-c[set output color (optionally then constellation name)]:color:(black white cyan magenta yellow red blue green)'
    )
    _arguments $args
}

_starfetch "$@"
