#compdef ser2net
# Documentation: https://manpages.debian.org/bookworm/ser2net/ser2net.8.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm ser2net(8) manpage.

# ser2net: serial-to-network proxy daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-c[config file (default /etc/ser2net/ser2net.yaml)]:file:_files' \
  '-C[old-style config line]:line:' \
  '-Y[YAML config string]:yaml:' \
  '-n[no fork (foreground)]' \
  '-d[debug mode (no fork, log to stdout)]' \
  '-P[PID file]:file:_files' \
  '-u[disable UUCP locks]' \
  '-b[Cisco IOS baud (ignored, kept for compat)]' \
  '-v[show version]' \
  '-t[number of threads]:n:' \
  '-p[admin accepter]:accepter:' \
  '-s[RFC2217 signature]:signature:' && ret=0
return ret
