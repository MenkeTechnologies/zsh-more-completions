#compdef userdel-cli
# _userdel-cli — shadow userdel delete a user account and related files CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_userdel-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-f[force]' \
        '--force[force]' \
        '-r[remove home and mail spool]' \
        '--remove[remove home and mail spool]' \
        '-Z[remove SELinux user mapping]' \
        '--selinux-user[remove SELinux user mapping]' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '-R+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '*:login:_users'
}

_userdel-cli "$@"
