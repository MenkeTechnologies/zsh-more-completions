#compdef kubectl-cache
# Documentation: https://github.com/yhlooo/kubectl-cache
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (pkg/commands source).

# kubectl-cache (yhlooo/kubectl-cache): get/list resources via a local cache.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '-v+[log level verbosity (0, 1, or 2)]:level:(0 1 2)' \
  '--data-root=[path to data directory]:dir:_files -/' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'get:get or list Kubernetes resources'
      'describe:describe Kubernetes resources'
      'proxy:run a proxy for the Kubernetes APIServer locally'
      'proxies:list running proxies'
      'shutdown:shut down running proxies'
      'version:print version'
    )
    _describe -t commands 'kubectl cache command' commands && ret=0
    ;;
  args)
    case $line[1] in
      get|describe)
        _arguments -s -S \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
          '(-A --all-namespaces)'{-A,--all-namespaces}'[list across all namespaces]' \
          '(-l --selector)'{-l+,--selector=}'[label selector]:selector:' \
          '--field-selector=[field selector]:selector:' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(wide yaml json name)' && ret=0
        ;;
      proxy)
        _arguments -s -S \
          '--port=[proxy port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
