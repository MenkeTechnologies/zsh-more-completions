#compdef virt-chroot
# _virt-chroot — KubeVirt privileged helper invoked from virt-handler (mount/umount, selinux, tap/mdev, cgroups)
# upstream: https://github.com/kubevirt/kubevirt
# Subcommands/flags from cmd/virt-chroot/main.go on tip.

_virt-chroot() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                exec:'exec a command inside the chroot'
                mount:'mount a filesystem inside the chroot'
                umount:'umount a filesystem inside the chroot'
                selinux:'manage SELinux labels inside the chroot'
                create-tap:'create a tap network device'
                create-mdev:'create a mediated (vGPU) device'
                remove-mdev:'remove a mediated (vGPU) device'
                cgroups:'apply cgroup resources to a process'
            )
            _describe -t commands 'virt-chroot subcommand' subs
            ;;
        args)
            case $line[1] in
                mount)
                    _arguments \
                        '(-o --options)'{-o,--options}'=[comma separated list of mount options]:opts:' \
                        '(-t --type)'{-t,--type}'=[filesystem type]:fstype:'
                    ;;
                create-tap)
                    _arguments \
                        '--tap-name=[name of the tap device]:name:' \
                        '--uid=[owner uid of the tap device]:uid:' \
                        '--gid=[owner gid of the tap device]:gid:' \
                        '--queue-number=[number of queues on multi-queued devices]:n:' \
                        '--mtu=[link MTU of the tap device]:mtu:'
                    ;;
                create-mdev)
                    _arguments \
                        '--type=[mediated device type]:type:' \
                        '--parent=[parent PCI id]:parent:' \
                        '--uuid=[uuid for the new mediated device]:uuid:'
                    ;;
                remove-mdev)
                    _arguments \
                        '--uuid=[uuid of the mediated device to remove]:uuid:'
                    ;;
                cgroups)
                    _arguments \
                        '--subsystem-paths=[base64 marshalled map[string]string of subsystem paths]:b64:' \
                        '--resources=[base64 marshalled runc Resources type]:b64:' \
                        '--rootless=[run rootless]:bool:(true false)' \
                        '--isV2=[treat as cgroups v2]:bool:(true false)'
                    ;;
            esac
            ;;
    esac
}

_virt-chroot "$@"
