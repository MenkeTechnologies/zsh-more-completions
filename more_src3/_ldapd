#compdef ldapd
# _ldapd — OpenBSD ldapd (LDAPv3 server daemon; reads /etc/ldapd.conf and stores its database under /var/db/ldap by default; controlled at runtime by ldapctl(8))
# upstream: https://github.com/openbsd/src (usr.sbin/ldapd)
# Flags from usr.sbin/ldapd/ldapd.8 on tip.

_ldapd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-v[verbose]' \
        '*-D+[define macro=value]:macro=value:' \
        '-f+[config file (default /etc/ldapd.conf)]:file:_files' \
        '-r+[database directory]:dir:_files -/' \
        '-s+[control socket]:file:_files'
}

_ldapd "$@"
