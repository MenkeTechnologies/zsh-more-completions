#compdef sort-cli
# _sort-cli — GNU coreutils sort lines of text files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_sort-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[ignore leading blanks]' \
        '--ignore-leading-blanks[ignore leading blanks]' \
        '-d[dictionary order]' \
        '--dictionary-order[dictionary order]' \
        '-f[ignore case]' \
        '--ignore-case[ignore case]' \
        '-g[general numeric sort]' \
        '--general-numeric-sort[general numeric sort]' \
        '-i[ignore non-printing]' \
        '--ignore-nonprinting[ignore non-printing]' \
        '-M[month sort]' \
        '--month-sort[month sort]' \
        '-h[human numeric sort]' \
        '--human-numeric-sort[human numeric sort]' \
        '-n[numeric sort]' \
        '--numeric-sort[numeric sort]' \
        '-R[random shuffle]' \
        '--random-sort[random shuffle]' \
        '--random-source=+[file]:file:_files' \
        '-r[reverse]' \
        '--reverse[reverse]' \
        '--sort=+[mode]:m:(general-numeric human-numeric month numeric random version)' \
        '-V[version sort]' \
        '--version-sort[version sort]' \
        '--batch-size=+[n merge]:n:' \
        '-c[check sorted]' \
        '--check[check sorted]' \
        '-C[check sorted no warn]' \
        '--check=+[mode]:m:(silent quiet)' \
        '--compress-program=+[prog]:str:' \
        '--debug[debug]' \
        '--files0-from=+[file]:file:_files' \
        '-k+[key def]:str:' \
        '--key=+[key def]:str:' \
        '-m[merge already sorted]' \
        '--merge[merge already sorted]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-s[stable sort]' \
        '--stable[stable sort]' \
        '-S+[buffer size]:str:' \
        '--buffer-size=+[buffer size]:str:' \
        '-t+[separator]:str:' \
        '--field-separator=+[separator]:str:' \
        '-T+[temp dir]:dir:_files -/' \
        '--temporary-directory=+[temp dir]:dir:_files -/' \
        '--parallel=+[n]:n:' \
        '-u[unique]' \
        '--unique[unique]' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:files:_files'
}

_sort-cli "$@"
