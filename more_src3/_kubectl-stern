#compdef kubectl-stern
# kubectl-stern (krew plugin): multi pod and container log tailing
# https://github.com/stern/stern

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[match pods in all namespaces]' \
  '--color=[force color output]:when:(auto always never)' \
  '(-c --container)'{-c+,--container=}'[container name filter (regex)]:container' \
  '--container-state=[container states to tail]:state:(running waiting terminated all)' \
  '--context=[kubernetes context]:context' \
  '--diff-container[show diff between containers in a pod]' \
  '(-e --exclude)'{-e+,--exclude=}'[exclude log messages matching regex]:pattern' \
  '-E+[exclude container name matching regex]:pattern' \
  '--exclude-container=[exclude container names matching regex]:pattern' \
  '--exclude-pod=[exclude pod names matching regex]:pattern' \
  '--field-selector=[kubernetes field selector]:selector' \
  '--highlight=[highlight matching log messages]:pattern' \
  '(-i --include)'{-i+,--include=}'[include only log messages matching regex]:pattern' \
  '--init-containers[include init containers]' \
  '--ephemeral-containers[include ephemeral containers]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
  '--max-log-requests=[max concurrent log requests]:number' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--no-follow[do not follow logs]' \
  '--node=[node name to filter on]:node' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(default raw json extjson ppextjson)' \
  '(-p --prompt)'{-p,--prompt}'[toggle interactive prompt for selecting pods]' \
  '(-s --since)'{-s+,--since=}'[return logs newer than duration]:duration' \
  '--since-time=[return logs after timestamp]:timestamp' \
  '-t[print timestamps]' \
  '--timestamps[print timestamps]' \
  '--tail=[number of recent log lines to display]:lines' \
  '--template=[go template for output]:template' \
  '--template-file=[go template file]:file:_files' \
  '--verbosity=[log verbosity level]:level:(0 1 2 3 4 5 6)' \
  '1:pod query'
