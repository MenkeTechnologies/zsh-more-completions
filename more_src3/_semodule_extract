#compdef semodule_extract
# _semodule_extract — SELinux semodule_extract (decompose a compiled policy.pp module back into the source .te/.fc/.if/.cil text; -o output dir, -v verbose, -V version, -h help; positional argument is the policy module .pp file)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux libsemanage tools/semodule_extract.c on tip.

_semodule_extract() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-o+[output dir]:dir:_files -/' \
        '-v[verbose]' \
        '1:policy.pp:_files -g "*.pp"'
}

_semodule_extract "$@"
