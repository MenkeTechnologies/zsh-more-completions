#compdef s6-svlink
# _s6-svlink — s6 supervision s6-svlink (atomically register a service in a scandir by symlinking servicedir into it and notifying s6-svscan to start supervising it; safe replacement for ln+s6-svscanctl)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-svlink.c on tip.

_s6-svlink() {
    _arguments \
        '(-d -D)-d[remove on failure]' \
        '(-d -D)-D[also unlink the underlying servicedir on failure]' \
        '-f[force: replace an existing symlink with the same name]' \
        '-P[do not wait for supervise to come up]' \
        '-t+[timeout (ms)]:ms:' \
        '1:scandir:_files -/' \
        '2:servicedir:_files -/' \
        '3:name:'
}

_s6-svlink "$@"
