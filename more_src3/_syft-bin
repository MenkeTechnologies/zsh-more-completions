#compdef syft
# _syft-bin — Syft SBOM generator (Anchore, Go); produce SPDX/CycloneDX SBOMs from images and dirs
# upstream: https://github.com/anchore/syft

_syft-bin() {
    local -a sub=(
        'attest:create attested SBOM (in-toto)'
        'cataloger:list catalogers'
        'completion:print shell completion'
        'convert:convert between SBOM formats'
        'help:show help'
        'login:login to registry'
        'logout:logout'
        'packages:scan image/dir for packages'
        'power-user:advanced inspection (legacy)'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '-o+[output format]:fmt:(syft-json cyclonedx-json cyclonedx-xml spdx-json spdx-tag-value github-json table text)' \
        '--output+[output format]:fmt:' \
        '-s+[scope]:scope:(Squashed AllLayers)' \
        '--scope+[scope]:scope:' \
        '--name+[image name]:name:' \
        '--catalogers+[catalogers]:catalogers:' \
        '--exclude+[exclude path]:glob:' \
        '--base-path+[base path]:dir:_files -/' \
        '--file+[output file]:file:_files' \
        '--platform+[platform]:platform:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'syft subcommand' sub ;;
        args)
            case $words[1] in
                packages|attest) _arguments '*:target:' ;;
                convert) _arguments '*:sbom file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_syft-bin "$@"
