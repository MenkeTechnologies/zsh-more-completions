#compdef virtlogd
# _virtlogd — libvirt virtlogd (per-host daemon receiving guest-console log streams from running QEMU instances and rotating them on disk so very long-running VMs do not balloon /var/log; -d daemonize, -f config file, -p pidfile, -t timeout seconds, -v verbose)
# upstream: https://gitlab.com/libvirt/libvirt (src/logging/log_daemon.c)
# Flags from libvirt src/logging/log_daemon.c on tip.

_virtlogd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-d[daemonize]' \
        '-f+[config file]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-t+[timeout seconds]:seconds:'
}

_virtlogd "$@"
