#compdef laravel-pint pint-cli
# _laravel-pint — Nuno Maduro Laravel Pint opinionated PHP code-style fixer CLI alias (laravel team, PHP); symfony console wrapping php-cs-fixer
# upstream: https://github.com/laravel/pint

_laravel-pint() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--config=+[config file]:file:_files -g "pint.json"' \
        '--preset=+[preset]:p:(laravel psr12 symfony per per-cs)' \
        '--test[test only]' \
        '--dirty[only dirty files]' \
        '--repair[repair only fixable]' \
        '--bail[bail on first failure]' \
        '--list-fixers[list fixers]' \
        '--format=+[format]:f:(txt json)' \
        '--diff[show diff]' \
        '*:files or directories:_files'
}

_laravel-pint "$@"
