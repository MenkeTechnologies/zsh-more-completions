#compdef taskiq
# Documentation: https://taskiq-python.github.io/guide/cli.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'worker:run taskiq workers'
      'scheduler:run the scheduler'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (worker)
        _arguments \
          '--workers=[number of child processes]:workers:' \
          '--use-process-pool[use ProcessPoolExecutor]' \
          '--max-process-pool-processes=[worker processes]:n:' \
          '--max-threadpool-threads=[ThreadPoolExecutor threads]:n:' \
          '--max-async-tasks=[max concurrent async tasks]:count:' \
          '--max-prefetch=[tasks to prefetch]:count:' \
          '--ack-type=[when to acknowledge tasks]:when:(when_received when_executed when_saved)' \
          '--no-parse[disable automatic type casting]' \
          '--fs-discover[discover tasks from filesystem]' \
          '-fsd[discover tasks from filesystem]' \
          '--tasks-pattern=[task file glob pattern]:pattern:' \
          '-tp[task file glob pattern]:pattern:' \
          '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '(-r --reload)'{-r,--reload}'[auto-reload on file changes]' \
          '--reload-dir=[directory to watch]:dir:_directories' \
          '--do-not-use-gitignore[disable .gitignore support during reload]' \
          '--app-dir=[application directory]:dir:_directories' \
          '--wait-tasks-timeout=[graceful shutdown timeout]:seconds:' \
          '1:broker module path:' && ret=0
        ;;
      (scheduler)
        _arguments \
          '--log-level=[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '--fs-discover[discover tasks from filesystem]' \
          '-fsd[discover tasks from filesystem]' \
          '--tasks-pattern=[task file glob pattern]:pattern:' \
          '-tp[task file glob pattern]:pattern:' \
          '--app-dir=[application directory]:dir:_directories' \
          '--skip-first-run[skip immediate task execution after start]' \
          '--update-interval=[check interval for new tasks]:seconds:' \
          '1:scheduler module path:' && ret=0
        ;;
    esac
    ;;
esac

return ret
