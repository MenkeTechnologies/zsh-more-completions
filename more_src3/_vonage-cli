#compdef vonage-cli vonage2
# _vonage-cli — Vonage Nexmo vonage-cli CLI command-line frontend wrapping the Vonage formerly Nexmo Communications APIs platform SMS Voice Verify Video Number-Insight Conversation Messaging Dispatch Applications JWT-API-key managing account numbers applications messages calls verifications conversations users members SDP NCCO (Vonage team, Node.js); commander
# upstream: https://www.vonage.com/

_vonage-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'config:configuration'
        'account:account operations'
        'numbers:number operations'
        'application:application operations'
        'sms:SMS operations'
        'voice:voice operations'
        'verify:verify operations'
        'verify2:verify v2 operations'
        'video:video operations'
        'number-insight:number insight'
        'conversation:conversation operations'
        'user:user operations'
        'member:member operations'
        'messages:messages operations'
        'dispatch:dispatch operations'
        'jwt:JWT operations'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--application-id=+[id]:str:' \
        '--private-key=+[file]:file:_files' \
        '--api-url=+[url]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vonage-cli subcommand' sub ;;
        args)
            case $words[1] in
                numbers|application|sms|voice|verify|verify2|video|number-insight|conversation|user|member|messages|dispatch|jwt|webhook) _arguments '1:op:(list get create update delete buy cancel verify check)' '*:id:' ;;
            esac
            ;;
    esac
}

_vonage-cli "$@"
