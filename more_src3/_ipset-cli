#compdef ipset-cli
# _ipset-cli — Jozsef Kadlecsik ipset administer IP sets in Linux kernel CLI alias (netfilter team, C); custom argparse
# upstream: https://git.netfilter.org/ipset/

_ipset-cli() {
    local -a sub=(
        'create:create a set'
        'add:add an entry to set'
        'del:delete entry from set'
        'test:test entry in set'
        'destroy:destroy a set'
        'list:list sets'
        'save:save sets'
        'restore:restore sets'
        'flush:flush sets'
        'rename:rename a set'
        'swap:swap two sets'
        'help:show help'
        'version:show version'
        'quit:quit interactive mode'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-!:exist[exist]' \
        '-q:quiet[quiet]' \
        '-r:resolve[resolve]' \
        '-o+[output format]:o:(plain save xml)' \
        '-s:sorted[sorted output]' \
        '-n:name[name only]' \
        '-t:terse[terse output]' \
        '-X:exist[exist for delete]' \
        '-e:exist[exist for create]' \
        '-f+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ipset subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:set name:' \
                    '2:set type:(bitmap:ip bitmap:ip,mac bitmap:port hash:ip hash:net hash:net,net hash:ip,port hash:net,port hash:ip,port,ip hash:ip,port,net hash:net,port,net hash:ip,mark hash:net,iface hash:mac list:set)' \
                    'range=+[range]:str:' \
                    'netmask=+[netmask]:n:' \
                    'family=+[family]:f:(inet inet6)' \
                    'timeout=+[timeout]:n:' \
                    'counters[counters]' \
                    'comment[comment]' \
                    'skbinfo[skb info]' \
                    'hashsize=+[hash size]:n:' \
                    'maxelem=+[max elements]:n:' \
                    'bucketsize=+[bucket size]:n:' \
                    'initval=+[hash init value]:n:' \
                    'forceadd[force add]' \
                    'size=+[size]:n:' ;;
                add|del|test) _arguments \
                    '1:set name:' \
                    '2:entry:' \
                    'timeout=+[timeout]:n:' \
                    'packets=+[packets]:n:' \
                    'bytes=+[bytes]:n:' \
                    'comment=+[comment]:str:' \
                    'skbmark=+[skb mark]:str:' \
                    'skbprio=+[skb prio]:str:' \
                    'skbqueue=+[skb queue]:n:' ;;
                destroy|list|flush|save) _arguments '*:set name:' ;;
                rename|swap) _arguments '1:from set:' '2:to set:' ;;
                restore) _arguments '-f+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_ipset-cli "$@"
