#compdef typsite
# ============================================================================
# typsite - static site generator for Typst (Rust, MIT)
#
# Author : Glomzzz
# Upstream: https://github.com/Glomzzz/typsite
# crates : typsite (binary: typsite)
#
# `typsite` is a static site generator that takes a tree
# of `.typ` (Typst) source files and produces a fully-
# rendered HTML/CSS/JS site - the SSG equivalent of
# Hugo / Zola / mdBook but built around the Typst
# typesetting system rather than Markdown. The output is
# a deployable static site with code highlighting (via
# syntect), per-page slugs, watch-mode live reload, and
# the full power of Typst's typesetting engine (math,
# layout, figures, references) available inside each
# article source.
#
# Usage:
#   typsite <command> [options]
#
# Commands (clap derive subcommand):
#   init      - scaffold a new typsite project in the
#               target directory
#   compile   - compile the .typ tree to a static site
#               (alias: c)
#   clean     - clean the cache + output directories
#   syntect   - check syntect syntaxes + themes (alias: s)
#
# init flags:
#   -d, --dir <dir>             - project root (default ./)
#
# compile flags:
#       --host <host>           - serve host
#                                 (default localhost)
#       --port <port>            - serve port; non-zero
#                                  triggers watch mode
#                                  with live reload
#                                  (default 0)
#       --config <dir>          - project config dir
#                                 (default ./.typsite,
#                                  alias --cfg)
#       --cache <dir>           - cache dir (default
#                                 ./.cache)
#   -i, --input <dir>           - Typst source root
#                                 (default ./root)
#   -o, --output <dir>          - output dir (default
#                                 ./publish)
#   -p, --packages <dir>        - extra Typst packages
#                                 dir (synced to @local)
#   -t, --typst <path>          - Typst executable path
#                                 (default typst)
#       --no-pretty-url         - keep .html suffix on
#                                 emitted URLs
#       --no-short-slug         - keep parent slug in
#                                 the displayed slug
#
# clean flags:
#   -o, --output <dir>          - output dir (default
#                                 ./publish)
#   -c, --cache <dir>           - cache dir (default
#                                 ./.cache)
#
# syntect flags:
#       --config <dir>          - project config dir
#                                 (default ./.typsite)
#
# Global:
#   -h, --help                  - print help
#   -V, --version               - print version
#
# The toml lane is built on `toml = "*"` (declared at
# upstream Cargo.toml HEAD as a direct dep, imported from
# `src/compile/options.rs` as `toml::from_str(&content)?`
# to load the project's `options.toml`), the canonical
# Rust TOML library by the toml-rs working group +
# Alex Crichton (originally created by Crichton in 2014
# while at Mozilla, now maintained by toml-rs org with
# Ed Page as the primary maintainer) - github.com/toml-
# rs/toml, 1100+ stars. The crate implements TOML v1.0.0
# (the stabilized 2021 spec) end-to-end: tokenizer +
# parser + serializer + Serde adapter. It is the de-facto
# Rust TOML implementation - depended on by Cargo itself,
# rustfmt, every clippy lint config, and approximately
# every Rust CLI's config-file path.
#
# typsite uses `toml::from_str` with a Serde-derived
# `CompileOptions` struct to load the project's
# `options.toml` at compile time, mapping the on-disk
# TOML to a typed in-memory config value used by the
# rest of the compilation pipeline.
#
# ----------------------------------------------------------------------------
# AXIS 243 :: TOML parsing (TOML v1.0.0 spec compliant
#              parsers + serializers)
# Round 1427 :: Rust slot 1 of 4 :: OPENS Axis 243
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : toml-rs/toml                 - the original
#                                            Rust TOML
#                                            crate by
#                                            Alex Crichton
#                                            (2014); now
#                                            maintained
#                                            by toml-rs
#                                            org with Ed
#                                            Page as
#                                            primary
#                                            maintainer;
#                                            depended on
#                                            by Cargo
#   Go      : BurntSushi/toml              - the Andrew
#                                            Gallant (rg
#                                            / xsv / fst /
#                                            quickcheck-rs
#                                            author) Go
#                                            TOML library
#                                            from 2013;
#                                            Gallant also
#                                            authored
#                                            BurntSushi/
#                                            toml-test
#                                            (the spec's
#                                            official
#                                            conformance
#                                            suite)
#   TS/Node : iarna/iarna-toml             - the Rebecca
#                                            Turner
#                                            (iarna)
#                                            TOML library
#                                            from 2017;
#                                            the de-facto
#                                            Node TOML
#                                            parser with
#                                            ~250k weekly
#                                            downloads;
#                                            depended on
#                                            by Yarn,
#                                            taplo's
#                                            VS Code
#                                            extension,
#                                            and many
#                                            others
#
# TOML is a clean spec-bound axis - the TOML v1.0.0
# specification (released Jan 2021) defines the
# grammar end-to-end as a context-free PEG, and the
# BurntSushi/toml-test conformance corpus provides a
# canonical reference for what "compliant" means at the
# byte level. All three lanes' library implementations
# pass the toml-test corpus.
#
# Structural commentary on the canonical libraries:
#   - toml-rs/toml (Rust): the original Crichton-authored
#     2014 library; co-evolved with Cargo's TOML adoption
#     for Cargo.toml; the *only* Rust TOML crate that
#     ships zero-copy span tracking + offset reporting
#     for compiler-grade error messages
#   - BurntSushi/toml (Go): Andrew Gallant's library is
#     the *spec-author-adjacent canonical* in the Go
#     ecosystem because Gallant also wrote the conformance
#     suite that all libraries are graded against. His
#     decoder is intentionally strict about spec
#     conformance
#   - iarna/iarna-toml (Node): Rebecca Turner's library
#     covers TOML v1.0.0 + the older 0.5.0 spec with
#     parser-mode switching for legacy configs; performance-
#     tuned for very-large TOML documents (Yarn's
#     lockfile-style use)
#
# Cross-language interop happens at the wire format
# level (TOML is text-based, byte-identical across
# parsers for the same input). The in-memory representation
# differs per lane (Serde-derived structs in Rust,
# struct tags in Go, plain JS objects in Node), but
# round-tripping TOML <-> JSON in any lane produces
# identical JSON across the three libraries (this is
# what toml-test asserts).
#
# Axis 243 opens with the Rust slot at the Crichton-
# authored canonical library that co-evolved with Cargo.
# ============================================================================

_typsite() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_typsite_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '(-d --dir)'{-d,--dir}'[project root directory]:dir:_files -/' \
                        '(- *)'{-h,--help}'[print help]'
                    ;;
                compile|c)
                    _arguments \
                        '--host[serve host]:host:' \
                        '--port[serve port (non-zero triggers watch mode)]:port:' \
                        '--config[project config dir]:dir:_files -/' \
                        '--cfg[project config dir (alias)]:dir:_files -/' \
                        '--cache[cache dir]:dir:_files -/' \
                        '(-i --input)'{-i,--input}'[Typst source root]:dir:_files -/' \
                        '(-o --output)'{-o,--output}'[output dir]:dir:_files -/' \
                        '(-p --packages)'{-p,--packages}'[extra Typst packages dir]:dir:_files -/' \
                        '(-t --typst)'{-t,--typst}'[Typst executable path]:path:_command_names -e' \
                        '--no-pretty-url[keep .html suffix on URLs]' \
                        '--no-short-slug[keep parent slug in displayed slug]' \
                        '(- *)'{-h,--help}'[print help]'
                    ;;
                clean)
                    _arguments \
                        '(-o --output)'{-o,--output}'[output dir]:dir:_files -/' \
                        '(-c --cache)'{-c,--cache}'[cache dir]:dir:_files -/' \
                        '(- *)'{-h,--help}'[print help]'
                    ;;
                syntect|s)
                    _arguments \
                        '--config[project config dir]:dir:_files -/' \
                        '--cfg[project config dir (alias)]:dir:_files -/' \
                        '(- *)'{-h,--help}'[print help]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_typsite_cmds() {
    local -a cmds
    cmds=(
        'init:scaffold a new typsite project'
        'compile:compile the .typ tree to a static site (alias c)'
        'c:compile alias'
        'clean:clean cache + output directories'
        'syntect:check syntect syntaxes + themes (alias s)'
        's:syntect alias'
    )
    _describe -t commands 'typsite command' cmds
}

_typsite "$@"
