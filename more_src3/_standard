#compdef standard standard-cli
# _standard — Feross Aboukhadijeh standard JavaScript style guide CLI alias (Feross / standard team, JavaScript); meow
# upstream: https://github.com/standard/standard

_standard() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--fix[automatically fix]' \
        '--verbose[verbose]' \
        '--global=+[global variable]:list:' \
        '--plugin=+[plugin]:list:' \
        '--env=+[environment]:list:' \
        '--parser=+[parser]:str:' \
        '--ext=+[extension]:list:' \
        '--rulesdir=+[rules dir]:dir:_files -/' \
        '--ignore[use ignore]' \
        '--no-ignore[no ignore]' \
        '--ignore-pattern=+[ignore pattern]:list:' \
        '--stdin[read from stdin]' \
        '--stdin-filename=+[stdin filename]:str:' \
        '--use-stdin[read from stdin]' \
        '--quiet[only show errors]' \
        '-q[only show errors]' \
        '*:file:_files'
}

_standard "$@"
