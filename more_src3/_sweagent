#compdef sweagent
# Documentation: https://github.com/SWE-agent/SWE-agent
# Reference accessed: 2026-05-22
# Verified: docs/usage/hello_world.md sweagent subcommands.

# Zsh completion for sweagent - SWE-agent software engineering CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'sweagent command' \
      'run[run on a single problem]' \
      'run-batch[run on a batch of problems]' \
      'run-replay[replay a trajectory]' \
      'traj-to-demo[convert trajectory to demo]' \
      'merge-preds[merge predictions]' \
      'inspect[inspect trajectories]' \
      'inspect-demos[inspect demo files]' \
      'extract-pred[extract predictions]' \
      'run-api[run via API]' && ret=0
    ;;
  args)
    case $line[1] in
      run|run-batch|run-replay)
        _arguments \
          '--agent.model.name[model name]:model:' \
          '--agent.model.per_instance_cost_limit[cost limit USD]:usd:' \
          '--env.repo.github_url[GitHub repository URL]:url:' \
          '--env.repo.path[local repository path]:directory:_directories' \
          '--problem_statement.github_url[GitHub issue URL]:url:' \
          '--problem_statement.path[problem statement file]:file:_files' \
          '--env.deployment.type[deployment type]:type:(docker modal local)' \
          '--env.deployment.image[docker image]:image:' \
          '--env.post_startup_commands[post-startup commands]:commands:' \
          '*:config overrides:' && ret=0
        ;;
      *)
        _arguments '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
