#compdef lyx
# Documentation: https://manpages.debian.org/bookworm/lyx/lyx.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-userdir+[user directory]:dir:_files -/' \
  '-sysdir+[system directory]:dir:_files -/' \
  '-geometry+[X11 geometry]:geom:' \
  '-dbg+[enable debug categories]:cats:' \
  '(-x --execute)-x+[execute LFUN]:lfun:' \
  '(-x --execute)--execute=[execute LFUN]:lfun:' \
  '(-e --export)-e+[export format]:format:(latex pdflatex xelatex luatex pdf pdf2 pdf3 pdf4 pdf5 html docbook docbook5 odt epub txt xhtml)' \
  '(-e --export)--export=[export format]:format:(latex pdflatex xelatex luatex pdf pdf2 pdf3 pdf4 pdf5 html docbook docbook5 odt epub txt xhtml)' \
  '(-E --export-to)-E+[export to format and exit]:fmt_out:' \
  '(-E --export-to)--export-to=[export to format and exit]:fmt_out:' \
  '(-i --import)-i+[import format from file]:fmt_file:' \
  '(-i --import)--import=[import format from file]:fmt_file:' \
  '(-f --force-overwrite)-f+[force overwrite]:bool:(all main none)' \
  '(-f --force-overwrite)--force-overwrite=[force overwrite]:bool:(all main none)' \
  '--ignore-error-message=[ignore specific error message]:which:' \
  '(-n --no-remote)'{-n,--no-remote}'[do not use running LyX instance]' \
  '(-r --remote)'{-r,--remote}'[attempt to use running LyX instance]' \
  '(-v --verbose)'{-v,--verbose}'[be verbose]' \
  '-batch[exit after processing files]' \
  '*:lyx_file:_files -g "*.{lyx,tex,lyx.bak}"' && ret=0

return ret
