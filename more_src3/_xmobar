#compdef xmobar
# Documentation: https://manpages.debian.org/bookworm/xmobar/xmobar.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-f+,--font=}'[set font]:font:' \
  {-B+,--bgcolor=}'[set background color]:color:' \
  {-F+,--fgcolor=}'[set foreground color]:color:' \
  '(-o --top -b --bottom)'{-o,--top}'[position at top of screen]' \
  '(-o --top -b --bottom)'{-b,--bottom}'[position at bottom of screen]' \
  {-a+,--alignsep=}'[alignment separators]:sep:' \
  {-s+,--sepchar=}'[command separator character]:char:' \
  {-t+,--template=}'[output template]:template:' \
  {-c+,--commands=}'[list of commands]:commands:' \
  {-C+,--add-commands=}'[additional commands]:commands:' \
  {-x+,--screen=}'[screen number]:screen:' \
  '*:config file:_files' && ret=0

return ret
