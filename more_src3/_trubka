local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _trubka_cmds _trubka_sasl
_trubka_cmds=(
    'list:list topics / brokers / groups / partitions'
    'describe:describe topics / brokers / groups / cluster'
    'deletion:delete topics / groups / records'
    'consume:consume messages from topics'
    'create:create topics / ACLs'
    'produce:produce messages to topics'
    'version:show trubka version'
    'help:show help for a subcommand'
)
_trubka_sasl=(
    'plain:SASL/PLAIN'
    'scram-sha-256:SASL/SCRAM-SHA-256'
    'scram-sha-512:SASL/SCRAM-SHA-512'
    'oauth:SASL/OAUTH'
)

_arguments -C \
    '*'{-v,--verbose}'[increase verbosity (counter)]' \
    '--colour[enable colored output (default true)]' \
    '--no-colour[disable colored output]' \
    '--color[enable colored output (alias for --colour)]' \
    '--no-color[disable colored output (alias)]' \
    '(-b --brokers)'{-b+,--brokers=}'[comma-separated broker list (host:port)]:brokers:_default' \
    '--kafka-version=[Kafka cluster version]:version:_default' \
    '--tls[enable TLS (unverified by default)]' \
    '--ca-cert=[CA certificate file for server verification]:cert:_files' \
    '--client-cert=[client certificate file (mTLS)]:cert:_files' \
    '--client-key=[client private key file (mTLS)]:key:_files' \
    '--sasl-mechanism=[SASL authentication mechanism]:mechanism:(plain scram-sha-256 scram-sha-512 oauth)' \
    '--sasl-username=[SASL username]:user:_users' \
    '--sasl-password=[SASL password]:password:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'trubka subcommand' _trubka_cmds && ret=0
        ;;
    args)
        case $words[1] in
            list)
                _values 'list subcommand' \
                    'topics[list topics]' \
                    'brokers[list brokers]' \
                    'groups[list consumer groups]' \
                    'partitions[list partitions]' \
                    'group-offsets[list group offsets]' \
                    && ret=0
                ;;
            describe)
                _values 'describe subcommand' \
                    'topic[describe topic]' \
                    'broker[describe broker]' \
                    'group[describe consumer group]' \
                    'cluster[describe cluster]' \
                    && ret=0
                ;;
            consume)
                _values 'consume subcommand' \
                    'proto[consume protobuf messages]' \
                    'json[consume JSON messages]' \
                    'plain[consume plain-text messages]' \
                    && ret=0
                ;;
            produce)
                _values 'produce subcommand' \
                    'proto[produce protobuf messages]' \
                    'json[produce JSON messages]' \
                    'plain[produce plain-text messages]' \
                    && ret=0
                ;;
            create)
                _values 'create subcommand' \
                    'topic[create a new topic]' \
                    'acl[create an ACL]' \
                    && ret=0
                ;;
            deletion)
                _values 'deletion subcommand' \
                    'topic[delete a topic]' \
                    'group[delete a consumer group]' \
                    'records[delete records]' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _trubka_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
