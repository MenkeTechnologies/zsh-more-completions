#compdef zfs-diff
# _zfs-diff — OpenZFS zfs diff compare snapshot/dataset CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-diff() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-F[show file type info]' \
        '-H[script mode, no headers]' \
        '-t[print inode change time]' \
        '-h[show help]' \
        '*:snapshot1 snapshot2 or dataset:'
}

_zfs-diff "$@"
