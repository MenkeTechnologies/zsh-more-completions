#compdef ksh ksh93
# Documentation: https://manpages.debian.org/ksh93.1
# Source: AT&T KornShell 93 — David Korn's POSIX shell with set-style options.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a set_opts
set_opts=(
    'allexport:auto-export every variable assignment'
    'bgnice:run background jobs at lower priority'
    'braceexpand:enable {a,b,c} brace expansion'
    'emacs:emacs-style line editing'
    'errexit:exit on any non-zero command'
    'globstar:enable ** recursive globbing'
    'histexpand:enable ! history expansion'
    'ignoreeof:do not exit on EOF (Ctrl-D)'
    'interactive:interactive shell'
    'keyword:legacy keyword-assignment scanning'
    'login:login shell'
    'markdirs:append / to expanded directory names'
    'monitor:enable job control'
    'noclobber:do not overwrite existing files with >'
    'noexec:read but do not execute (syntax check)'
    'noglob:disable pathname expansion'
    'nolog:do not save function defs in history'
    'notify:notify of bg-job completion immediately'
    'nounset:error on unset variable expansion'
    'pipefail:pipeline exit = rightmost non-zero status'
    'posix:strict POSIX compatibility mode'
    'privileged:do not source user startup files'
    'restricted:restricted shell mode'
    'showme:display commands without execution'
    'trackall:track all command lookups via hash table'
    'verbose:echo input lines as read'
    'vi:vi-style line editing'
    'xtrace:trace execution (PS4)'
)

_arguments -s \
    '-a[allexport]' \
    '+a[unset allexport]' \
    '-b[notify]' \
    '+b[unset notify]' \
    '-c[read commands from string]:command:' \
    '-e[errexit]' \
    '+e[unset errexit]' \
    '-f[noglob]' \
    '+f[unset noglob]' \
    '-h[trackall (track command paths)]' \
    '+h[unset trackall]' \
    '-i[interactive shell]' \
    '+i[non-interactive]' \
    '-k[obsolete keyword-assignment scanning]' \
    '+k[unset keyword]' \
    '-l[login shell]' \
    '+l[non-login]' \
    '-m[monitor (job control)]' \
    '+m[unset monitor]' \
    '-n[noexec (parse only)]' \
    '+n[unset noexec]' \
    '-o+[set long-form option]:option:->setopts' \
    '+o+[unset long-form option]:option:->setopts' \
    '-p[privileged (skip user rc)]' \
    '+p[unset privileged]' \
    '-r[restricted shell]' \
    '+r[unset restricted]' \
    '-s[read from stdin]' \
    '+s[unset read-stdin]' \
    '-t[exit after single command]' \
    '+t[unset single-command exit]' \
    '-u[nounset]' \
    '+u[unset nounset]' \
    '-v[verbose (echo input)]' \
    '+v[unset verbose]' \
    '-x[xtrace]' \
    '+x[unset xtrace]' \
    '-B[braceexpand]' \
    '+B[unset braceexpand]' \
    '-C[noclobber]' \
    '+C[unset noclobber]' \
    '-E[ENV-file auto-source]' \
    '+E[disable ENV-file auto-source]' \
    '-G[globstar]' \
    '+G[unset globstar]' \
    '-H[histexpand]' \
    '+H[unset histexpand]' \
    '(- *)--version[show version]' \
    '*:script + arguments:_files' \
    && ret=0

case $state in
    setopts)
        _describe -t ksh-setopts 'set/setopt option' set_opts && ret=0
        ;;
esac

return ret
