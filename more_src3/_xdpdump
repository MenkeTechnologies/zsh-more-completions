#compdef xdpdump xdp-dump
# _xdpdump — tcpdump-like packet capture for XDP programs (xdp-project/xdp-tools)
# upstream: https://github.com/xdp-project/xdp-tools
# Flags from xdp-dump/xdpdump.8.

_xdpdump() {
    local -a args
    args=(
        '--rx-capture=[which side of the XDP program to capture from]:mode:(entry exit entry+exit)'
        '(-D --list-interfaces)'{-D,--list-interfaces}'[list XDP-capable interfaces and exit]'
        '--load-xdp-mode=[mode for auto-loaded xdpdump program]:mode:(native skb hw unspecified)'
        '--load-xdp-program[load a tracing XDP program if none is attached]'
        '(-i --interface)'{-i+,--interface=}'[interface to capture on]:ifname:_net_interfaces'
        '--perf-wakeup=[events between perf-buffer wakeups]:events:'
        '(-p --program-names)'{-p+,--program-names=}'[which XDP program(s) to attach to]:program:(all)'
        '(-P --promiscuous-mode)'{-P,--promiscuous-mode}'[enable promiscuous mode on the interface]'
        '(-s --snapshot-length)'{-s+,--snapshot-length=}'[bytes to capture per packet]:snaplen:'
        '--use-pcap[force the legacy pcap file format]'
        '(-w --write)'{-w+,--write=}'[output capture file]:file:_files'
        '(-x --hex)'{-x,--hex}'[print packet contents in hex]'
        '*'{-v,--verbose}'[increase verbosity]'
        '--version[show version]'
        '(- *)'{-h,--help}'[show help]'
    )
    _arguments -s -S $args
}

_xdpdump "$@"
