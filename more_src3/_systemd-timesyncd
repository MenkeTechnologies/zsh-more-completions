#compdef systemd-timesyncd
# _systemd-timesyncd (systemd's minimal SNTP client daemon; reads /etc/systemd/timesyncd.conf for the upstream NTP server list and falls back to the fallback list; controlled at runtime by timedatectl(1) timesync-status / show-timesync subcommands; daemon binary accepts only standard systemd unit args)
# upstream: https://github.com/systemd/systemd (src/timesync)
# Argument shape from systemd src/timesync/timesyncd.c on tip.

_systemd-timesyncd() {
    _arguments \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-timesyncd "$@"
