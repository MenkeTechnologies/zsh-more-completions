#compdef zig2
# _zig2 — Andrew Kelley Zig Software Foundation zig2 CLI command-line frontend wrapping the Zig general-purpose programming language and toolchain for maintaining robust optimal and reusable software open-source written in Zig originally Andrew Kelley now Zig Software Foundation general-purpose programming language and toolchain manual memory management generic data structures comptime cross-compilation no hidden control flow no hidden allocations build run translate-c init init-exe init-lib build-exe build-lib build-obj build-test fmt fetch ar dlltool lib ranlib objcopy cc c++ env ld.lld lld nm objdump readelf strip targets test version zen LTO MIR (Andrew Kelley Zig Software Foundation team, Zig); custom argparse
# upstream: https://ziglang.org/

_zig2() {
    local -a sub=(
        'build:Run the build.zig script'
        'fetch:Fetch a package and add to build.zig.zon'
        'init:Initialize a Zig project'
        'init-exe:Initialize a project with executable'
        'init-lib:Initialize a project with library'
        'build-exe:Create executable from source'
        'build-lib:Create library from source'
        'build-obj:Create object from source'
        'test:Perform unit testing'
        'run:Create executable and run immediately'
        'fmt:Reformat Zig source into canonical form'
        'translate-c:Convert C code to Zig code'
        'ar:Use Zig as a drop-in archiver'
        'cc:Use Zig as a drop-in C compiler'
        'c++:Use Zig as a drop-in C++ compiler'
        'dlltool:Use Zig as a drop-in dlltool.exe'
        'lib:Use Zig as a drop-in lib.exe'
        'ranlib:Use Zig as a drop-in ranlib'
        'objcopy:Use Zig as a drop-in objcopy'
        'rc:Use Zig as a drop-in rc.exe'
        'env:Print lib path, std path, cache directory, and version'
        'help:Print help'
        'reduce:Minimize crashing source code'
        'libc:Display native libc paths'
        'libcxx:Display native libcxx paths'
        'targets:List available compilation targets'
        'version:Print version number and exit'
        'zen:Print Zen of Zig and exit'
        'std:View standard library documentation'
        'ld.lld:Use Zig as a drop-in LLD linker'
        'lld:Use Zig as a drop-in LLD linker'
        'nm:Use Zig as a drop-in nm'
        'objdump:Use Zig as a drop-in objdump'
        'readelf:Use Zig as a drop-in readelf'
        'strip:Use Zig as a drop-in strip'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--verbose-link[verbose linker]' \
        '--verbose-cc[verbose CC]' \
        '--verbose-air[verbose AIR]' \
        '--verbose-mir[verbose MIR]' \
        '--verbose-llvm-ir[verbose LLVM IR]' \
        '--verbose-cimport[verbose cimport]' \
        '--verbose-llvm-cpu-features[verbose LLVM CPU features]' \
        '-O+[optimization]:m:(Debug ReleaseSafe ReleaseFast ReleaseSmall)' \
        '-target+[arch-os-abi]:str:' \
        '-mcpu=+[cpu]:str:' \
        '-mcmodel=+[model]:m:(default tiny small kernel medium large)' \
        '-fLTO[enable LTO]' \
        '-fno-LTO[disable LTO]' \
        '-fstack-check[enable stack check]' \
        '-fno-stack-check[disable stack check]' \
        '-fsanitize-c[sanitize C]' \
        '-fno-sanitize-c[no sanitize C]' \
        '-fvalgrind[enable Valgrind]' \
        '-fno-valgrind[no Valgrind]' \
        '-fsanitize-thread[sanitize thread]' \
        '-fno-sanitize-thread[no sanitize thread]' \
        '-fdll-export-fns[dll export fns]' \
        '-fno-dll-export-fns[no dll export fns]' \
        '-funwind-tables[unwind tables]' \
        '-fno-unwind-tables[no unwind tables]' \
        '-femit-bin=+[file]:file:_files' \
        '-fno-emit-bin[no emit bin]' \
        '-femit-asm=+[file]:file:_files' \
        '-fno-emit-asm[no emit asm]' \
        '-femit-h=+[file]:file:_files' \
        '-fno-emit-h[no emit h]' \
        '-femit-docs=+[dir]:dir:_files -/' \
        '-fno-emit-docs[no emit docs]' \
        '-femit-implib=+[file]:file:_files' \
        '-fno-emit-implib[no emit implib]' \
        '-femit-llvm-ir=+[file]:file:_files' \
        '-femit-llvm-bc=+[file]:file:_files' \
        '-fcompiler-rt[link compiler-rt]' \
        '-fno-compiler-rt[no compiler-rt]' \
        '-fsingle-threaded[single threaded]' \
        '-fno-single-threaded[no single threaded]' \
        '-fpic[enable PIC]' \
        '-fno-pic[disable PIC]' \
        '-fpie[enable PIE]' \
        '-fno-pie[disable PIE]' \
        '-flld[use LLD]' \
        '-fno-lld[no LLD]' \
        '-fformatted-panics[formatted panics]' \
        '-fno-formatted-panics[no formatted panics]' \
        '-ofmt=+[format]:f:(elf c coff macho wasm raw plan9 hex)' \
        '--name=+[name]:str:' \
        '--mod=+[name:deps:path]:str:' \
        '*--mod=+[name:deps:path]:str:' \
        '--deps=+[mods]:str:' \
        '--dep=+[mod]:str:' \
        '-rcflags=+[args]:str:' \
        '--main-pkg-path=+[dir]:dir:_files -/' \
        '--main-mod-path=+[dir]:dir:_files -/' \
        '-fexec-builds[exec builds]' \
        '-fno-exec-builds[no exec builds]' \
        '-fbin-cache-dir=+[dir]:dir:_files -/' \
        '-fcache-dir=+[dir]:dir:_files -/' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--global-cache-dir=+[dir]:dir:_files -/' \
        '--zig-lib-dir=+[dir]:dir:_files -/' \
        '--enable-cache[enable cache]' \
        '-I+[include dir]:dir:_files -/' \
        '*-I+[include dir]:dir:_files -/' \
        '-isystem+[dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '*-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '*-l+[library]:str:' \
        '-D+[k=v]:str:' \
        '*-D+[k=v]:str:' \
        '-rdynamic[rdynamic]' \
        '-dynamic[dynamic]' \
        '-static[static]' \
        '-pie[PIE]' \
        '-no-pie[no PIE]' \
        '--strip[strip]' \
        '-z+[arg]:str:' \
        '*-z+[arg]:str:' \
        '--summary=+[level]:str:' \
        '-fno-summary[no summary]' \
        '-freference-trace=+[N]:n:' \
        '-fno-reference-trace[no reference trace]' \
        '-j+[jobs]:n:' \
        '--prefix=+[dir]:dir:_files -/' \
        '-p+[prefix]:dir:_files -/' \
        '--prefix-exe-dir=+[dir]:dir:_files -/' \
        '--prefix-lib-dir=+[dir]:dir:_files -/' \
        '--prefix-include-dir=+[dir]:dir:_files -/' \
        '--watch[watch]' \
        '--time-report[time report]' \
        '--stack-report[stack report]' \
        '--listen=+[host:port]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zig subcommand' sub ;;
        args)
            case $words[1] in
                build|run|fmt|test|build-exe|build-lib|build-obj|translate-c) _arguments '*:source:_files -g "*.zig *.c *.cpp *.h"' ;;
                fetch) _arguments '*:url:' ;;
            esac
            ;;
    esac
}

_zig2 "$@"
