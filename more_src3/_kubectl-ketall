#compdef kubectl-ketall
# kubectl-ketall (krew plugin): show really all Kubernetes resources
# https://github.com/corneliusweig/ketall

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--selector=[label selector]:selector' \
  '--since=[show resources newer than duration]:duration' \
  '--use-cache[use cached discovery information]' \
  '--exclude=[exclude resource types]:resources' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml wide name)' \
  '--no-headers[do not print headers]' \
  '--show-group[show API group]' \
  '--sort[sort output]'
