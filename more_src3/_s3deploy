#compdef s3deploy
# _s3deploy — fast static-site deploy to S3 (bep/s3deploy)
# upstream: https://github.com/bep/s3deploy
# Flags from lib/config.go (flag).

_s3deploy() {
    _arguments \
        '(- *)-h[show help]' \
        '-V[print version and exit]' \
        '-key=[AWS access key ID]:key:' \
        '-secret=[AWS secret access key]:secret:' \
        '-region=[AWS region]:region:' \
        '-bucket=[destination S3 bucket]:bucket:' \
        '-path=[optional bucket sub-path]:path:' \
        '-source=[source directory of files to upload]:dir:_files -/' \
        '-endpoint-url=[optional S3 endpoint URL]:url:' \
        '-config=[config file]:file:_files -g "*.(yml|yaml)"' \
        '-max-delete=[max files to delete per deploy]:n:' \
        '-public-access[DEPRECATED, use -acl=public-read]' \
        '-strip-index-html[strip index.html from non-root dirs]' \
        '-acl=[ACL for uploaded objects]:acl:(private public-read public-read-write authenticated-read aws-exec-read bucket-owner-read bucket-owner-full-control)' \
        '-force[upload even if etags match]' \
        '-try[trial run, no remote updates]' \
        '-v[verbose logging]' \
        '-quiet[silent mode]' \
        '-workers=[number of upload workers]:n:'
}

_s3deploy "$@"
