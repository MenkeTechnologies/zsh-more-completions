#compdef lfe
# Documentation: https://github.com/lfe/lfe
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lfe (Lisp Flavoured Erlang).
# lfe accepts Erlang VM/erl-style flags plus a script filename and args.

local ret=1

_arguments -s -S \
  '-h[show help]' \
  '-e[evaluate expression]:expression:' \
  '-eval[evaluate expression]:expression:' \
  '-pa[prepend path to code path]:directory:_directories' \
  '-pz[append path to code path]:directory:_directories' \
  '-noshell[start without interactive shell]' \
  '-noinput[disable standard input]' \
  '-s[start a module]:module:' \
  '*:script or arg:_files' && ret=0

return ret
