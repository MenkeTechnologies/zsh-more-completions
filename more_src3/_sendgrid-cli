#compdef sendgrid-cli sg
# Documentation: https://github.com/sendgrid/sendgrid-cli
# Reference accessed: 2026-05-21
# Verified: upstream README. Repository is `sendgrid/sendgrid-cli`
# (script is invoked as `./sg` not `sendgrid`).
# STUB-ish: minimal stable command set; flags are passed through to the
# subcommands and not documented in the README.

local curcontext="$curcontext" ret=1 state line
local -a commands=(
  'list-apikeys:list API keys'
  'subuser-admins:iterate over subusers and list teammates with roles'
  'contacts:contacts management (upload from CSV)'
  'webhooks:manage Event and Inbound Parse webhooks'
)
_arguments -C \
  '1:command:->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'sendgrid-cli command' commands && ret=0 ;;
esac
return ret
