#compdef tarantoolctl
# Documentation: https://www.tarantool.io/en/doc/latest/reference/tooling/tarantoolctl/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start a Tarantool instance'
  'stop:stop a Tarantool instance'
  'status:show instance status'
  'restart:restart instance'
  'logrotate:rotate logs'
  'check:check instance config'
  'enter:enter admin console'
  'eval:eval Lua file'
  'connect:connect to URI'
  'cat:dump snap or xlog'
  'play:replay snap/xlog to URI'
  'rocks:LuaRocks helper'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tarantoolctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (cat|play)
        _arguments \
          '*--space=[only this space ID]:n:' \
          '--show-system[show system spaces]' \
          '--from=[from LSN]:n:' \
          '--to=[to LSN]:n:' \
          '*--replica=[only this replica ID]:n:' \
          '--format=[output format]:fmt:(yaml json lua)' \
          '*:file:_files' && ret=0
        ;;
      (enter)
        _arguments '--language=[REPL language]:lang:(lua sql)' && ret=0
        ;;
      (rocks)
        _values 'rocks subcommand' \
          build config doc download help init install lint list make \
          make_manifest new_version pack purge remove show search unpack \
          which write_rockspec && ret=0
        ;;
    esac
    ;;
esac

return ret
