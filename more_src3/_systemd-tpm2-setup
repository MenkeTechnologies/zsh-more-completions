#compdef systemd-tpm2-setup
# _systemd-tpm2-setup — systemd TPM2 PCR setup CLI (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_systemd-tpm2-setup() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--tpm2-device=+[tpm2 device]:dev:' \
        '--early=+[early setup]:b:(yes no)' \
        '--graceful[graceful]' \
        '*:arg:'
}

_systemd-tpm2-setup "$@"
