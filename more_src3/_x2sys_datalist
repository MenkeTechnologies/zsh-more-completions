#compdef x2sys_datalist
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_datalist.html
# Source: GenericMappingTools/gmt supplements/x2sys — list track-file data records by TAG.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[x2sys TAG identifying data attributes]:tag:_default' \
    '-A[distribute crossover errors via weights]' \
    '-E[write GMT segment headers between tracks]' \
    '-F+[select output column subset]:names:_default' \
    '-I+[exclude tracks listed in file]:file:_files' \
    '-L+[apply optimal correction table]:file:_files' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S[skip records where all data are NaN]' \
    '*-V[verbose (stackable)]' \
    '-bo+[binary output format]:format:_default' \
    '-do+[NaN output → nodata replacement]:value:_default' \
    '-h+[header records]:n:_default' \
    '*:track file:_files' \
    && ret=0

return ret
