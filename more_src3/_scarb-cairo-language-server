#compdef scarb-cairo-language-server
# Documentation: https://docs.swmansion.com/scarb
# Reference accessed: 2026-05-21
# Verified: scarb-cairo-language-server is the LSP server bundled with
# scarb. No published CLI flag table; typically launched by IDEs over
# stdio. Pre-existing flags (--port, --stdio, --logfile) were
# unverifiable.
# STUB: LSP servers are launched programmatically by editors.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0

return ret
