#compdef s6-svperms
# _s6-svperms — s6 supervision s6-svperms (show or modify per-service control-FIFO permissions; common idiom for letting a non-root group send commands to a supervised service)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-svperms.c on tip.

_s6-svperms() {
    _arguments \
        '-v[verbose / show permissions]' \
        '(-u -g -G -o -O)-u[only the supervised user can send commands]' \
        '(-u -g -G -o -O)-g+[allow GID also to send commands]:group:_groups' \
        '(-u -g -G -o -O)-G+[allow GID only (not the supervised user)]:group:_groups' \
        '(-u -g -G -o -O)-o[allow anyone (other-readable)]' \
        '(-u -g -G -o -O)-O+[allow anyone in GID]:group:_groups' \
        '(-e -E)-e[allow death-tally read by everyone]' \
        '(-e -E)-E+[allow death-tally read by this group]:group:_groups' \
        '*:servicedir:_files -/'
}

_s6-svperms "$@"
