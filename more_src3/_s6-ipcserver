#compdef s6-ipcserver
# _s6-ipcserver — s6 conn-tools s6-ipcserver (Unix-domain server super-server: binds path, listens, applies access rules and per-uid connection limits, then forks the child program for each client — UCSPI-style)
# upstream: https://github.com/skarnet/s6
# Flags from src/conn-tools/s6-ipcserver.c on tip.

_s6-ipcserver() {
    _arguments \
        '(-q -Q -v)-q[quiet]' \
        '(-q -Q -v)-Q[normal verbosity]' \
        '(-q -Q -v)-v[verbose]' \
        '(-d -D)-d[bind in dgram mode]' \
        '(-d -D)-D[bind in stream mode (default)]' \
        '(-p -P)-p[look up uid/gid for connecting peers]' \
        '(-p -P)-P[skip peer uid/gid lookup]' \
        '-1[print bound socket path on fd 1]' \
        '-c+[max simultaneous connections]:n:' \
        '-C+[max simultaneous connections per local uid]:n:' \
        '-b+[listen() backlog]:n:' \
        '-a+[socket permissions]:perms:' \
        '-G+[supplementary GIDs (csv)]:gids:' \
        '-g+[set GID]:gid:_groups' \
        '-u+[set UID]:uid:_users' \
        '-U[get UID/GID/groups from $UID/$GID/$GIDLIST]' \
        '1:socket-path:_files' \
        '*::program:_command_names -e'
}

_s6-ipcserver "$@"
