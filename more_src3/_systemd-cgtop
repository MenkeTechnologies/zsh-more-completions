#compdef systemd-cgtop
# _systemd-cgtop — systemd systemd-cgtop (per-cgroup top(1)-style live view of resource usage; -c sort by CPU, -m memory, -t IO, -i tasks, -n iterations, -d delay seconds, -P/-k/-r control cgroup tree depth, --raw show raw values, --cpu=percentage|time, --no-pager; positional cgroup path optional)
# upstream: https://github.com/systemd/systemd (src/cgtop)
# Flags from systemd src/cgtop/cgtop.c on tip.

_systemd-cgtop() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-c[order by CPU]' \
        '-m[order by memory]' \
        '-t[order by IO]' \
        '-i[order by tasks]' \
        '-n+[iterations]:n:' \
        '--iterations+[iterations]:n:' \
        '-d+[delay seconds]:seconds:' \
        '--delay+[delay seconds]:seconds:' \
        '-p[order by path]' \
        '-r[recursive task counting]' \
        '-P[show PIDs not tasks]' \
        '-k[show kernel threads]' \
        '--cpu=*[cpu format]:fmt:(percentage time)' \
        '--raw[raw values]' \
        '--depth+[tree depth]:depth:' \
        '-M+[machine]:machine:' \
        '--machine+[machine]:machine:' \
        '--no-pager[no pager]' \
        '--batch[batch mode]' \
        '1:cgroup path:'
}

_systemd-cgtop "$@"
