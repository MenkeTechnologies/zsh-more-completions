#compdef tmuxomatic
# Documentation: https://github.com/oxidane/tmuxomatic
# Reference accessed: 2026-05-21
# Verified: upstream README flag list.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[verbose]' \
  '(-n --renaming)'{-n,--renaming}'[auto rename]' \
  '(-p --printonly)'{-p,--printonly}'[print only]' \
  '(-x --noexecute)'{-x,--noexecute}'[no execute]' \
  '(-F --files)'{-F,--files}'[list examples]' \
  '(-t --tests)'{-t,--tests}'[run tests]' \
  '(-r --recreate)'{-r,--recreate}'[recreate session]' \
  '(-d --destroy)'{-d,--destroy}'[destroy on disconnect]' \
  '(-f --flex)'{-f,--flex}'[flex console]' \
  '*:filename:_files'
