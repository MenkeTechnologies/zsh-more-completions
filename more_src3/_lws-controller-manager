#compdef lws-controller-manager leaderworkerset-controller-manager
# _lws-controller-manager — LeaderWorkerSet (sigs.k8s.io/lws) controller
# upstream: https://github.com/kubernetes-sigs/lws
# Flags from cmd/main.go on tip.

_lws-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--metrics-bind-address=[DEPRECATED: metrics bind host\:port (prefer --config)]:host\:port:' \
        '--health-probe-bind-address=[DEPRECATED: health probe bind host\:port]:host\:port:' \
        '--kube-api-qps=[max QPS to K8s API]:f:' \
        '--kube-api-burst=[max burst to K8s API]:n:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--leader-elect-resource-lock=[lease resource lock kind]:kind:(leases configmaps endpoints configmapsleases endpointsleases)' \
        '--leader-elect-resource-name=[leader-election lease name]:name:' \
        '--config=[LWS configuration file]:file:_files' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_lws-controller-manager "$@"
