#compdef lz4-cli unlz4-cli lz4cat-cli
# _lz4-cli — Yann Collet LZ4 extremely fast lossless compression CLI alias (lz4 team, C); custom argparse
# upstream: https://github.com/lz4/lz4

_lz4-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-H[full help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[decompress]' \
        '--decompress[decompress]' \
        '--uncompress[decompress]' \
        '-z[force compression]' \
        '--compress[force compression]' \
        '-f[force overwrite]' \
        '--force[force overwrite]' \
        '-k[keep input files]' \
        '--keep[keep input files]' \
        '--rm[remove input after success]' \
        '-c[output to stdout]' \
        '--stdout[output to stdout]' \
        '-t[test]' \
        '--test[test]' \
        '-l[legacy format]' \
        '--legacy[legacy format]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-B+[block size 4-7]:n:(4 5 6 7)' \
        '-BD[block dependency]' \
        '-BI[block independence]' \
        '-BX[block checksum]' \
        '-SX[stream checksum]' \
        '-C+[content size]:b:(yes no)' \
        '--content-size[content size]' \
        '--list[list info]' \
        '--no-frame-crc[no frame crc]' \
        '--frame-crc[frame crc]' \
        '--no-progress[no progress]' \
        '--no-sparse[no sparse]' \
        '--sparse[sparse]' \
        '--favor-decSpeed[favor decompression speed]' \
        '--best[best]' \
        '--fast[fast]' \
        '--fast=+[n]:n:' \
        '-A+[favor mode]:str:' \
        '-D+[dictionary]:file:_files' \
        '-1[level 1]' \
        '-2[level 2]' \
        '-3[level 3]' \
        '-4[level 4]' \
        '-5[level 5]' \
        '-6[level 6]' \
        '-7[level 7]' \
        '-8[level 8]' \
        '-9[level 9]' \
        '-10[level 10]' \
        '-11[level 11]' \
        '-12[level 12 (best)]' \
        '-m[multiple input files]' \
        '--multiple[multiple input files]' \
        '-T+[threads]:n:' \
        '*:files:_files -g "*.{lz4,tar.lz4,tlz4}"'
}

_lz4-cli "$@"
