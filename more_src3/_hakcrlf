#compdef hakcrlf
# _hakcrlf — Luke Stephens hakcrlf CLI for testing URLs for HTTP CRLF response-splitting vulnerabilities injecting carriage-return line-feed payloads into URL parameters and analysing response headers for unexpected splits (hakluke team, Go); flag
# upstream: https://github.com/hakluke/hakcrlf

_hakcrlf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-r[follow redirects]' \
        '--follow-redirects[follow redirects]' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '--payloads=+[file]:file:_files' \
        '--header-name=+[name]:str:' \
        '--insecure[insecure TLS]' \
        '--silent[silent]' \
        '*:URL or file:_files'
}

_hakcrlf "$@"
