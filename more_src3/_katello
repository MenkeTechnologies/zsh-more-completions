#compdef katello katello-installer katello-service katello-tweaks katello-backup katello-restore katello-disk-usage katello-upgrade-info
# _katello — Red Hat Katello CLI for managing Katello and Red Hat Satellite content management organizations products repositories sync plans subscriptions errata host content-views activation-keys lifecycle environments (Katello team, Ruby); Thor
# upstream: https://github.com/Katello/katello

_katello() {
    local -a sub=(
        'installer:run katello installer'
        'service:service management'
        'backup:backup Katello'
        'restore:restore Katello'
        'disk-usage:show disk usage'
        'tweaks:run system tweaks'
        'upgrade-info:show upgrade info'
        'reset:reset Katello'
        'self-tune:self tune'
        'monitor:monitor health'
        'enable-foreman-plugin-tasks-async:enable tasks async'
        'foreman-rake:foreman rake helper'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'katello subcommand' sub ;;
        args)
            case $words[1] in
                installer) _arguments \
                    '--scenario=+[s]:s:(katello capsule foreman-proxy foreman foreman-content-proxy)' \
                    '--noop[noop]' \
                    '--upgrade[upgrade]' \
                    '--reset[reset]' ;;
                service) _arguments \
                    '1:action:(start stop restart status reload enable disable list)' \
                    '*:service:_services' ;;
                backup) _arguments \
                    '--features=+[csv]:str:' \
                    '--snapshot[snapshot]' \
                    '--online-backup[online backup]' \
                    '--incremental=+[dir]:dir:_files -/' \
                    '*:backup dir:_files -/' ;;
                restore) _arguments \
                    '*:backup dir:_files -/' ;;
            esac
            ;;
    esac
}

_katello "$@"
