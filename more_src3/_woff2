#compdef woff2_compress woff2_decompress woff2_info
# Documentation: https://github.com/google/woff2
# Reference accessed: 2026-05-21
# Verified: upstream main() of each tool accepts a single positional filename
# and no flags.

local ret=1

case $service in
  woff2_compress)
    _arguments -s -S '1:TTF/OTF font:_files -g "*.(ttf|otf)(-.)"' && ret=0
    ;;
  woff2_decompress|woff2_info)
    _arguments -s -S '1:WOFF2 font:_files -g "*.woff2(-.)"' && ret=0
    ;;
  *)
    return 1
    ;;
esac

return ret
