#compdef kea-lfc
# Documentation: https://kea.readthedocs.io/en/kea-2.6.1/man/kea-lfc.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kea-lfc: Kea lease file cleanup utility. Corrected from prior file:
# -x is the previous/ex-lease file (not config), -c is the finish file
# (kept), per upstream man page; -h is documented for kea-lfc.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print the usage string]' \
  '-v[display the Kea version]' \
  '-V[display the extended Kea version]' \
  '-W[display the configuration report]' \
  '-d[set logging level to debug with extra verbosity]' \
  '-4[lease files are DHCPv4]' \
  '-6[lease files are DHCPv6]' \
  '-c[configuration file for the kea-lfc process]:file:_files' \
  '-p[PID file]:file:_files' \
  '-x[previous (ex-lease) file]:file:_files' \
  '-i[input (copy) lease file]:file:_files' \
  '-o[output lease file]:file:_files' \
  '-f[finish (completion) file]:file:_files' \
  '*::kea-lfc args:_files' && ret=0
return ret
