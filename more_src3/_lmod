#compdef lmod
# _lmod — Lua-based environment module system
# upstream: https://github.com/TACC/Lmod

_lmod() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '-D[debug output]' \
        '-d[debug output]' \
        '--debug=[debug level]:level:' \
        '-q[quiet mode]' \
        '--quiet[quiet mode]' \
        '-t[terse output]' \
        '--terse[terse output]' \
        '--default[only show default modules]' \
        '--expert[expert mode]' \
        '--force[force operation]' \
        '--json[JSON output]' \
        '--redirect[send output to stdout]' \
        '--no_redirect[send output to stderr]' \
        '--show_hidden[show hidden modules]' \
        '--spider_timeout=[spider timeout]:seconds:' \
        '--timer[report timing data]' \
        '--width=[terminal width]:width:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'avail:list available modules'
                'help:show help for a module'
                'keyword:search by keyword'
                'list:list loaded modules'
                'load:load module(s)'
                'overview:overview of available modules'
                'purge:unload all modules'
                'reset:reset to system defaults'
                'restore:restore a saved collection'
                'save:save current modules as a collection'
                'savelist:list saved collections'
                'show:show module file content'
                'spider:search for modules'
                'swap:swap one module for another'
                'try-load:try to load module(s)'
                'unload:unload module(s)'
                'unuse:remove directory from MODULEPATH'
                'update:update loaded modules'
                'use:add directory to MODULEPATH'
                'whatis:show module whatis info'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                use|unuse)
                    _arguments '*:directory:_directories'
                    ;;
                save|restore)
                    _arguments '1:collection name:'
                    ;;
                *)
                    _arguments '*:module name:'
                    ;;
            esac
            ;;
    esac
}

_lmod "$@"
