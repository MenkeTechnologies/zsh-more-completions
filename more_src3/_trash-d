#compdef trash trash-d
# _trash-d — rm-compatible trash CLI written in D (rushsteve1/trash-d)
# upstream: https://github.com/rushsteve1/trash-d
# Flags from source/trash/opts.d (D getopt).

_trash-d() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-d --dir)'{-d,--dir}'[remove empty directories]' \
        '(-r -R --recursive)'{-r,-R,--recursive}'[delete directories recursively]' \
        '(-v --verbose)'{-v,--verbose}'[print more info]' \
        '(-i --interactive)'{-i,--interactive}'[prompt before each deletion]' \
        '(-I --interact-once)'{-I,--interact-once}'[prompt once if ≥3 deletions]' \
        '(-f --force)'{-f,--force}'[no prompt, ignore errors]' \
        '--list[list files in the trash]' \
        '--orphans[list orphaned files in the trash]' \
        '--restore=[restore a file from the trash]:file:_files' \
        '--delete=[permanently delete from trash]:file:_files' \
        '--empty[empty the trash bin]' \
        '--rm[permanently delete (escape hatch)]' \
        '*:file:_files'
}

_trash-d "$@"
