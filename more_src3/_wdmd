#compdef wdmd
# Documentation: source-direct extraction from upstream
# nirs/sanlock (mirror of upstream pagure.io/sanlock) —
#   wdmd/main.c lines 1759-1779 (the print_usage_and_exit()
#     block with the full flag list)
#   wdmd/main.c lines 1800-1815 (the static struct option
#     long_options[] array and the short-option getopt_long
#     string "hpdVDH:G:S:s:k:w:t:F")
# Reference accessed: 2026-05-30 via gh api.
#
# wdmd is the **Watchdog Multiplexing Daemon** — a sister tool
# to R216's sanlock.  Multiplexes a single hardware watchdog
# device (/dev/watchdog) across multiple registered clients
# (sanlock is the canonical client; multiple sanlock daemons or
# scripts may register independently).  Each client renews its
# keepalive via the wdmd IPC socket; if ANY client fails to
# renew within its registered fire timeout, wdmd stops petting
# /dev/watchdog and the hardware watchdog will reset the
# machine.  Used in the sanlock fence-arm workflow to guarantee
# a sanlock node whose lease has expired WILL be forcibly
# reset before another node takes the lease over.
#
# Critical extraction note: wdmd has a SPLIT flag-style — 6
# flags are long+short (in long_options[] at main.c:1804-
# 1811) and 6 are SHORT-ONLY (only in the getopt_long short-
# option string "hpdVDH:G:S:s:k:w:t:F").  The short-only flags
# are admin/daemon-control flags (`-D`, `-H`, `-G`, `-S`, `-s`,
# `-k`, `-w`) that lack long aliases.  Documented in completion.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print usage and exit]' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '(-d --dump)'{-d,--dump}'[print debug from running daemon and exit]' \
  '(-p --probe)'{-p,--probe}'[print path of functional watchdog device and exit]' \
  '(-t --trytimeout)'{-t+,--trytimeout=}'[set timeout value for watchdog device and probe]:seconds:' \
  '(-F --forcefire)'{-F,--forcefire}'[force watchdog to fire and reset machine (use with -t)]' \
  '-D[debug: no fork and print all logging to stderr (short-only)]' \
  '-H+[use high-priority features (short-only)]:0|1:(0 1)' \
  '-G+[group ownership for the wdmd IPC socket (short-only)]:name:_groups' \
  '-S+[allow script tests (short-only)]:0|1:(0 1)' \
  '-s+[path to scripts dir (short-only; default /etc/wdmd.d)]:dir:_files -/' \
  '-k+[kill unfinished scripts after N seconds (short-only)]:sec:' \
  '-w+[path to the watchdog device to try first (short-only)]:device:_files -g "/dev/watchdog*"'
