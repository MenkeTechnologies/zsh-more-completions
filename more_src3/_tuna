#compdef tuna
# Documentation: https://github.com/nschloe/tuna
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tuna - Python profile viewer

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --outdir)'{-o,--outdir}'=[output directory for static files]:dir:_directories' \
  '--no-browser[do not start a web browser]' \
  '(-p --port)'{-p,--port}'=[webserver port (default: first free port from 8000)]:port' \
  '*:profile file:_files'
