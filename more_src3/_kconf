#compdef kconf
# Documentation: https://github.com/particledecay/kconf/blob/master/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cobra command/flag defs).

# Zsh completion for kconf (kubeconfig manager)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[display debug messages]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'add:add a kubeconfig file'
      'list:list available contexts'
      'ls:list available contexts'
      'namespace:set a preferred namespace for a context'
      'ns:set a preferred namespace for a context'
      'rm:remove a context from kubeconfig'
      'rename:rename a context'
      'rn:rename a context'
      'use:switch to a context'
      'u:switch to a context'
      'verify:verify a kubeconfig'
      'view:view kubeconfig for a context'
      'v:view kubeconfig for a context'
      'version:show version'
      'completion:generate shell completion'
      'help:show help for a subcommand'
    )
    _describe -t commands 'kconf subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _files && ret=0
        ;;
      rm|use|u|view|v|namespace|ns|rename|rn|verify)
        _message 'context name' && ret=0
        ;;
      completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
