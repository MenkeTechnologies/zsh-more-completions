#compdef s6-svc
# Documentation: https://skarnet.org/software/s6/s6-svc.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-u[bring the service up]' \
  '-d[bring the service down, prevent restart]' \
  '-U[bring up with persistence (remove ./down)]' \
  '-D[bring down with persistence (create ./down)]' \
  '-o[run service once (equivalent to -uO)]' \
  '-O[mark service to run once at most]' \
  '-Q[once with persistence (create ./down)]' \
  '-x[exit supervisor when service dies]' \
  '-r[restart by killing then restarting]' \
  '-a[send SIGALRM]' \
  '-b[send SIGABRT]' \
  '-q[send SIGQUIT]' \
  '-h[send SIGHUP]' \
  '-k[send SIGKILL]' \
  '-t[send SIGTERM]' \
  '-i[send SIGINT]' \
  '-1[send SIGUSR1]' \
  '-2[send SIGUSR2]' \
  '-p[send SIGSTOP]' \
  '-c[send SIGCONT]' \
  '-y[send SIGWINCH]' \
  '-s+[send signal by name or number]:signal' \
  '-wd[wait until service terminates]' \
  '-wD[wait until process dies and finish completes]' \
  '-wu[wait until service starts]' \
  '-wU[wait until service starts and signals ready]' \
  '-wr[wait until service is started/restarted]' \
  '-wR[wait until restarted and ready]' \
  '-T+[timeout in ms for wait]:timeout ms' \
  '-P[send SIGSTOP to process group]' \
  '-C[send SIGCONT to process group]' \
  '-K[send SIGKILL to process group]' \
  '1:service directory:_files -/' && ret=0

return ret
