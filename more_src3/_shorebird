#compdef shorebird
# Documentation: https://docs.shorebird.dev
# Source: shorebirdtech/shorebird — Code Push CLI for Flutter apps.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _sb_cmds
_sb_cmds=(
    'cache:manage the Shorebird cache'
    'doctor:show information about installed tooling'
    'flutter:manage your Shorebird Flutter installation'
    'init:initialize Shorebird in the current project'
    'login:log in as a new Shorebird user'
    'login:ci:log in as a CI user'
    'logout:log out the current user'
    'patch:create a Shorebird patch for the given target platforms'
    'patches:manage Shorebird patches'
    'preview:preview a specific release on a device'
    'release:create a Shorebird release for the given target platforms'
    'releases:manage Shorebird releases'
    'upgrade:upgrade your copy of Shorebird'
    'help:show help'
)

_arguments -C \
    '--verbose[show verbose output]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'shorebird command' _sb_cmds && ret=0
        ;;
esac

return ret
