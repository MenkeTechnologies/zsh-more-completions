#compdef syz-crush
# _syz-crush — replay syzkaller corpus/log against kernel to reproduce crashes (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-crush/crush.go (flag).

_syz-crush() {
    _arguments \
        '-config=[manager configuration file]:file:_files -g "*.cfg"' \
        '-debug[dump all VM output to console]' \
        '-restart_time=[how long to run the test]:duration:' \
        '-infinite=[run test forever (false stops on crash)]:val:(true false)' \
        '-strace[run under strace (binary must be in config)]' \
        '1:program or log file:_files'
}

_syz-crush "$@"
