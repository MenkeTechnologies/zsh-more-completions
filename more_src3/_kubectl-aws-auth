#compdef kubectl-aws-auth
# Documentation: https://github.com/keikoproj/aws-auth
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# aws-auth (keikoproj/aws-auth): manage the aws-auth configmap for EKS.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'upsert:add or update a user or role in the aws-auth configmap'
      'remove:remove a user or role from the aws-auth configmap'
      'remove-by-username:remove all mappings matching a username'
      'get:display mapping information in table format'
      'version:show aws-auth version'
      'help:display command documentation'
    )
    _describe -t commands 'kubectl aws-auth command' commands && ret=0
    ;;
  args)
    case $line[1] in
      upsert)
        _arguments -s -S \
          '--mapusers[map a user]' \
          '--maproles[map a role]' \
          '--userarn=[target user ARN]:arn:' \
          '--rolearn=[target role ARN]:arn:' \
          '--username=[username/role name]:username:' \
          '*--groups=[kubernetes groups]:groups:' \
          '--append[add groups without overwriting existing]' \
          '--update-username=[preserve existing username]:bool:(true false)' \
          '--retry[enable exponential backoff retries]' \
          '--retry-max-count=[maximum retry attempts]:count:' \
          '--retry-max-time=[maximum wait interval]:duration:' \
          '--retry-min-time=[minimum wait interval]:duration:' \
          '--as=[impersonate user]:user:' \
          '--as-group=[impersonate group]:group:' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '--mapusers[map a user]' \
          '--maproles[map a role]' \
          '--userarn=[target user ARN]:arn:' \
          '--rolearn=[target role ARN]:arn:' \
          '--username=[user/role name]:username:' \
          '*--groups=[associated groups]:groups:' && ret=0
        ;;
      remove-by-username)
        _arguments -s -S \
          '--username=[username to remove]:username:' && ret=0
        ;;
    esac
    ;;
esac

return ret
