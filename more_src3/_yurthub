#compdef yurthub
# _yurthub — OpenYurt edge hub agent (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Flags from cmd/yurthub/app/options/options.go (pflag).

_yurthub() {
    _arguments \
        '--bind-address=[YurtHub server bind IP]:ip:' \
        '--serve-port=[HTTP serve port]:port:' \
        '--bind-proxy-address=[YurtHub proxy server bind IP]:ip:' \
        '--proxy-port=[HTTP proxy port to kube-apiserver]:port:' \
        '--proxy-secure-port=[HTTPS proxy port to kube-apiserver]:port:' \
        '--multiplexer-port=[multiplexer HTTPS proxy port]:port:' \
        '--namespace=[YurtHub server namespace]:ns:' \
        '--server-addr=[Kubernetes kube-apiserver address]:url:' \
        '--gc-frequency=[storage GC frequency (minutes)]:n:' \
        '--node-name=[node name running the hub agent]:name:' \
        '--node-ip=[node IP used by kubelet]:ip:' \
        '--lb-mode=[load balancer mode]:mode:(round-robin priority)' \
        '--heartbeat-failed-retry=[heartbeat retries after failure]:n:' \
        '--heartbeat-healthy-threshold=[consecutive successes for healthy]:n:' \
        '--heartbeat-timeout-seconds=[heartbeat timeout]:s:' \
        '--heartbeat-interval-seconds=[heartbeat interval]:s:' \
        '--max-requests-in-flight=[max parallel requests]:n:' \
        '--join-token=[bootstrapping join token]:token:' \
        '--bootstrap-mode=[bootstrap mode]:mode:(token kubeletcertificate)' \
        '--bootstrap-file=[bootstrap file]:file:_files' \
        '--root-dir=[hub agent root directory]:dir:_files -/' \
        '--version[print version and exit]' \
        '--profiling[enable pprof web interface]' \
        '--enable-dummy-if[enable dummy interface]' \
        '--enable-iptables[enable iptables manager]' \
        '--dummy-if-ip=[dummy interface IP]:ip:' \
        '--dummy-if-name=[dummy interface name]:name:' \
        '--disk-cache-path=[storage path for cached metadata]:dir:_files -/' \
        '--enable-resource-filter[enable response filter from reverse proxy]' \
        '--nodepool-name=[node pool name]:name:'
}

_yurthub "$@"
