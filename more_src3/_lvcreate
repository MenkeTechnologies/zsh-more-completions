#compdef lvcreate
# _lvcreate — create logical volume (LVM2); allocate new lv from a vg
# upstream: https://gitlab.com/lvmteam/lvm2

_lvcreate() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-L --size)'{-L,--size}'+[size]:size:' \
        '(-l --extents)'{-l,--extents}'+[extents]:str:' \
        '(-n --name)'{-n,--name}'+[lv name]:name:' \
        '(-T --thin)'{-T,--thin}'[create thin lv]' \
        '(-V --virtualsize)'{-V,--virtualsize}'+[thin virtual size]:size:' \
        '(-s --snapshot)'{-s,--snapshot}'[create snapshot]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-Z --zero)'{-Z,--zero}'+[zero first sector]:bool:(y n)' \
        '(-W --wipesignatures)'{-W,--wipesignatures}'+[wipe signatures]:bool:(y n)' \
        '(-m --mirrors)'{-m,--mirrors}'+[mirrors]:n:' \
        '(-i --stripes)'{-i,--stripes}'+[stripes]:n:' \
        '(-I --stripesize)'{-I,--stripesize}'+[stripe size]:size:' \
        '(-a --activate)'{-a,--activate}'+[activate]:mode:(y n ay)' \
        '(-K --ignoreactivationskip)'{-K,--ignoreactivationskip}'[ignore activation skip]' \
        '(-r --readahead)'{-r,--readahead}'+[read ahead]:n:' \
        '(-p --permission)'{-p,--permission}'+[permission]:mode:(r rw)' \
        '--type+[lv type]:type:(linear striped mirror raid0 raid1 raid4 raid5 raid6 raid10 thin thin-pool cache cache-pool snapshot)' \
        '--cachemode+[cache mode]:mode:(writethrough writeback passthrough)' \
        '--poolmetadata+[metadata lv]:lv:' \
        '--poolmetadatasize+[metadata size]:size:' \
        '--virtualsize+[virtual size]:size:' \
        '--chunksize+[chunk size]:size:' \
        '*:vg or pv:'
}

_lvcreate "$@"
