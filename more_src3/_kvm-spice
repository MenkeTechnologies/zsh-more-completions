#compdef kvm-spice
# _kvm-spice — qemu-kvm-spice wrapper (legacy distro alias for qemu-kvm with Spice pre-configured; forwards every QEMU CLI option to qemu-system-x86_64: -machine, -cpu host, -smp, -m, -hda/-drive, -boot, -netdev, -spice, -vga qxl, -monitor, -daemonize)
# upstream: https://gitlab.com/qemu-project/qemu (qemu-kvm wrapper)
# Common QEMU flags shared with qemu-kvm; see qemu vl.c on tip.

_kvm-spice() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-machine+[machine]:machine:' \
        '-M+[machine]:machine:' \
        '-cpu+[cpu]:cpu:(host max qemu64 qemu32 Skylake-Server-noTSX-IBRS Cascadelake-Server EPYC-Milan)' \
        '-smp+[smp]:smp:' \
        '-m+[memory]:memory:' \
        '*-hda+[hda image]:file:_files' \
        '*-cdrom+[cdrom iso]:file:_files -g "*.iso"' \
        '*-drive+[drive spec]:spec:' \
        '-boot+[boot spec]:spec:' \
        '*-netdev+[netdev spec]:spec:' \
        '*-device+[device spec]:spec:' \
        '-spice+[spice spec]:spec:' \
        '-vga+[vga]:vga:(std cirrus vmware qxl virtio none)' \
        '-display+[display]:display:(none sdl gtk vnc spice-app curses egl-headless cocoa)' \
        '-monitor+[monitor]:dev:' \
        '-daemonize[daemonize]' \
        '-pidfile+[pidfile]:file:_files' \
        '-runas+[user]:user:_users' \
        '-snapshot[snapshot mode]' \
        '-name+[name]:name:'
}

_kvm-spice "$@"
