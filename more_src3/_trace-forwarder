#compdef trace-forwarder kata-trace-forwarder
# _trace-forwarder — Kata Containers host-side trace forwarder (VSOCK ← agent → Jaeger UDP collector)
# upstream: https://github.com/kata-containers/kata-containers
# Flags from src/tools/trace-forwarder/src/main.rs on tip (clap).

_trace-forwarder() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-l --log-level)'{-l,--log-level}'=[log level]:level:(trace debug info warn error critical)' \
        '--trace-name=[trace name to emit]:name:' \
        '--vsock-port=[VSOCK port to listen on for agent trace data]:port:' \
        '--vsock-cid=[VSOCK CID to filter on (use "any" for all)]:cid:' \
        '--hybrid-vsock[expect the Firecracker-style hybrid VSOCK protocol]' \
        '--hybrid-vsock-uds=[hybrid VSOCK master socket path prefix]:socket:_files' \
        '--jaeger-host=[Jaeger collector host]:host:' \
        '--jaeger-port=[Jaeger collector UDP port]:port:' \
        '--jaeger-service-name=[service name reported to Jaeger]:name:' \
        '--dump-only[dump received trace records to stderr instead of forwarding]'
}

_trace-forwarder "$@"
