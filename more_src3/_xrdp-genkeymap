#compdef xrdp-genkeymap
# _xrdp-genkeymap — generate xrdp keymap files (neutrinolabs/xrdp)
# upstream: https://github.com/neutrinolabs/xrdp
# Flags from genkeymap/genkeymap.c (getopt "c:k:").

_xrdp-genkeymap() {
    _arguments \
        '*-c+[comment line added to header (repeatable)]:comment:' \
        '-k+[keycode set]:set:(evdev base)' \
        '*:output filename:_files -g "*.toml"'
}

_xrdp-genkeymap "$@"
