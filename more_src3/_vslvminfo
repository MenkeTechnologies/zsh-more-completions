#compdef vslvminfo
# Documentation: https://github.com/libyal/libvslvm
# Source: libyal/libvslvm manuals/vslvminfo.1 — display info about Linux Logical Volume Manager (LVM) volume groups.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-o[volume offset in bytes]:offset:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
