#compdef vab
# Documentation: https://github.com/vlang/vab
# Reference accessed: 2026-05-27
# Verified: upstream vab README options table and --help text.

# vab - V Android Builder (compile, package, sign, deploy V apps on Android)

local curcontext="$curcontext" state line ret=1

local -a _vab_subcommands
_vab_subcommands=(
  'install:install dependencies (sdk, ndk, build-tools, platforms)'
  'remove:remove installed components'
  'doctor:print environment diagnostics'
  'run:build, package, deploy and launch on device'
  'test-runtime:run runtime tests'
  'test-all:run all tests'
  'complete:shell completion management'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level]:level:(0 1 2 3)' \
  '--version[show version]' \
  '--archs=[comma-separated CPU architectures]:archs:(armeabi-v7a arm64-v8a x86 x86_64)' \
  '--prod[production/release build mode]' \
  '--name=[application name]:name:' \
  '--package-id=[application package identifier]:id:' \
  '--icon=[application icon file path]:file:_files -g "*.{png,jpg,svg}"' \
  '--icon-mipmaps[generate icon mipmaps]' \
  '--version-code=[Android version code (integer)]:code:' \
  '--api=[target Android API level]:level:' \
  '--min-sdk-version=[minimum Android SDK version]:level:' \
  '--package-format=[output package format]:format:(apk aab)' \
  '(-o --output)'{-o+,--output=}'[output file path]:path:_files' \
  '--keystore=[keystore file path]:file:_files' \
  '--keystore-alias=[keystore alias name]:alias:' \
  '--keystore-password=[keystore password]:password:' \
  '--keystore-alias-password=[keystore alias password]:password:' \
  '--device=[target device id (or auto)]:device:' \
  '--list-apis[list installed API levels]' \
  '--list-ndks[list installed NDKs]' \
  '--list-build-tools[list installed build-tools]' \
  '--list-platforms[list installed platforms]' \
  '--lib-name=[shared library name]:name:' \
  '--activity-name=[Java/Kotlin activity name]:name:' \
  '--ndk-version=[NDK version to use]:version:' \
  '--build-tools=[build-tools version to use]:version:' \
  '--gradle-build[build with gradle]' \
  '--no-printf-hijack[do not hijack printf to logcat]' \
  '--cflags=[extra cflags for the V compiler]:flags:' \
  '--assets-extra=[extra assets directory to bundle]:dir:_directories' \
  '--libs-extra=[extra libs directory to bundle]:dir:_directories' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'vab subcommand' _vab_subcommands && ret=0
    _files && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
