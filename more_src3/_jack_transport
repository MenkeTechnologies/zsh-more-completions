#compdef jack_transport
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/tools/transport.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jack_transport: interactive JACK transport control REPL.
# Source main() parses NO command-line options; commands are typed at
# the interactive prompt. Real command table (transport.c commands[]):
# activate avr exit deactivate help locate master play quit release
# stop tempo timeout toggle ?
# Removed fabricated start/pause/status (not in source command table).
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:transport command:(activate avr exit deactivate help locate master play quit release stop tempo timeout toggle)' && ret=0
return ret
