#compdef dscl
# Documentation: https://www.unix.com/man-page/osx/1/dscl/
# Source: Apple macOS — Directory Service Command-Line client (Open Directory / local DB).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '-p[prompt for password]' \
    '-u[authenticate as user]:user:_users' \
    '-P[authentication password]:password:' \
    '-f[targeted local node database file path]:file:_files' \
    '-raw[do not strip prefix from DirectoryService API constants]' \
    '-plist[print records/attributes as XML plist]' \
    '-url[print attribute values in URL-style encoding]' \
    '-q[quiet (no interactive prompt)]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            '-read:print a directory or its keys'
            '-create:create a record, property, or value'
            '-delete:delete a directory, property, or value'
            '-append:append value(s) to a property'
            '-merge:append value(s) only if not present'
            '-change:replace old value with new in record'
            '-list:list subdirectories of given directory'
            '-search:search for records matching a pattern'
            '-cd:set current directory'
            '-pushd:push current dir + set new'
            '-popd:pop dir stack'
            '-auth:authenticate as named user or root'
            '-authonly:verify password of a named user'
            '-quit:end processing and exit'
            '.:local node'
            '/Search:Open Directory search node'
            '/LDAPv3:LDAP node'
        )
        _describe -t subcmds 'dscl command or node' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
