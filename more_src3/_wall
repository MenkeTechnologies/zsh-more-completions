#compdef wall
# Documentation: man wall(1) (BSD)
# Source: BSD wall — write a message to all logged-in users (or to a group).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-g+[restrict to users in group]:group:_groups' \
    '1:file:_files' \
    && ret=0

return ret
