#compdef sccainfo
# _libscca — libyal Windows Prefetch (.pf) parser; prints executable name, run count, last run times (up to 8 since Win8), volume info, file metrics array, MFT references
# upstream: https://github.com/libyal/libscca

_libscca() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-X[exclusive]' \
        '*:Prefetch file:_files -g "*.pf"'
}

_libscca "$@"
