#compdef swift-format
# Documentation: https://github.com/swiftlang/swift-format
# Source: swiftlang/swift-format — Swift formatter and linter (Apple-maintained).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '(- *)'{-v,--version}'[print version]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'format:format Swift source files (or stdin)'
            'lint:check Swift source files for style violations'
            'dump-configuration:print default configuration as JSON'
        )
        _describe -t subcmds 'swift-format command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            format)
                _arguments \
                    '(-i --in-place)'{-i,--in-place}'[overwrite input files]' \
                    '--assume-filename=[file path used in diagnostics for stdin]:path:_files' \
                    '(--color-diagnostics --no-color-diagnostics)--color-diagnostics[force colored diagnostics]' \
                    '(--color-diagnostics --no-color-diagnostics)--no-color-diagnostics[force non-colored diagnostics]' \
                    '--configuration=[JSON configuration file]:file:_files' \
                    '--ignore-unparsable-files[ignore source files with syntax errors]' \
                    '(-p --parallel)'{-p,--parallel}'[process files in parallel]' \
                    '(-r --recursive)'{-r,--recursive}'[recurse into directories for .swift sources]' \
                    '*:Swift file:_files -g "*.swift"' \
                    && ret=0
                ;;
            lint)
                _arguments \
                    '(-s --strict)'{-s,--strict}'[lint warnings cause non-zero exit]' \
                    '--assume-filename=[file path used in diagnostics for stdin]:path:_files' \
                    '(--color-diagnostics --no-color-diagnostics)--color-diagnostics[force colored diagnostics]' \
                    '(--color-diagnostics --no-color-diagnostics)--no-color-diagnostics[force non-colored diagnostics]' \
                    '--configuration=[JSON configuration file]:file:_files' \
                    '--ignore-unparsable-files[ignore source files with syntax errors]' \
                    '(-p --parallel)'{-p,--parallel}'[process files in parallel]' \
                    '(-r --recursive)'{-r,--recursive}'[recurse into directories for .swift sources]' \
                    '*:Swift file:_files -g "*.swift"' \
                    && ret=0
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac

return ret
