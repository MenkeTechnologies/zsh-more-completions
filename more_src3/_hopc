#compdef hopc
# ============================================================================
# _hopc — zsh completion for the Hop multi-tier web compiler
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/manuel-serrano/hop
#   Homepage   : http://hop.inria.fr
#   Author     : Manuel Serrano (INRIA)
#   License    : GPL-2.0
#   Stars      : 164
#   Language   : Scheme (Bigloo) compiler; targets JavaScript and Scheme
#                source files
#   Last push  : 2026-02-16
#
# WHAT IT IS
#   Hop is "a multitier environment for Web applications" developed at
#   INRIA Sophia Antipolis by Manuel Serrano.  Hop applications can be
#   authored in either JavaScript / TypeScript or Scheme;  the `hopc`
#   compiler in this completion handles the JavaScript/TypeScript and
#   Scheme source files, transpiling and compiling them through the
#   Bigloo Scheme toolchain to native binaries that share a unified
#   client / server runtime model (the same source can describe both
#   pages and their server endpoints).  The companion `hop` binary
#   (already in this corpus as `more_src/_hop`) is the runtime server;
#   `hopc` is the compiler.  Outputs:  AST dumps for tooling, JavaScript
#   transpilation across ES5 / ES6 / ES2017 targets, CommonJS-export
#   modules, server / client / worker code partitions, and native
#   executables via Bigloo's downstream compiler.
#
# CLI ARGUMENT GRAMMAR  (verbatim from hopc/parseargs.scm args-parse chain;
#                       214 flag positions cover both short and long
#                       variants of 100+ unique options — the completion
#                       below surfaces the most user-facing subset)
#   hopc [OPTIONS] [SOURCE_FILES...] -- [BIGLOO_OPTIONS...]
#
#   Standard options:
#     -h, --help            Show help
#     --version             Print version and exit
#     --buildtag            Print buildtag and exit
#     -v[N]                 Increase / set verbosity level
#                           (`-v0` = "crystal silence")
#     -q                    Do not load an init file
#     --rc-file <FILE>      Load alternate rc file
#     --rc-dir <DIR>        Set rc directory
#     --lib-dir=<DIR>       Set Hop lib directory
#     --share-dir <DIR>     Set hopc share directory
#     -L <DIR>              Add a Hop library search path (repeatable)
#
#   AST / output:
#     --ast                 Print the parsed AST
#     --ast-file <FILE>     Write the AST to a file
#     --afile <FILE>        Write a Bigloo .afile
#     --configure           Print Hop configure information
#
#   ECMAScript target version (mutually exclusive):
#     --js-es5              Target ECMAScript 5
#     --js-es6              Target ECMAScript 6
#     --js-es2017           Target ECMAScript 2017 (default)
#     --js-target-es5       Output ES5-compatible code
#
#   JS / TypeScript module options:
#     --language <LANG>     Force language (`js` / `ts` / `scheme`)
#     --js-typescript       Enable TypeScript parsing
#     --js-type-annotations    Preserve type annotations
#     --js-no-type-annotations Strip type annotations
#     --js-sealed-decorator    Generate sealed-decorator code
#     --js-no-sealed-decorator Don't generate sealed-decorator
#     --js-commonjs-export     Emit a CommonJS export (default)
#     --js-no-commonjs-export  Don't emit CommonJS export
#     --js-module-main <NAME>  Set the module's main entry name
#     --js-no-module-main      Don't set a module main
#     --js-module-name <NAME>  Override the module name
#     --js-module-path <PATH>  Override the module path
#     --js-node-modules-dir <DIR>
#                              Path to node_modules
#     --js-require-hop         Inject `require('hop')` into the bundle
#     --js-ignore-unresolved-modules
#                              Skip missing-module errors
#     --js-loader <FILE>       Custom Hop JavaScript loader
#     --js-header              Emit a `Hopc-Header` comment
#     --js-no-header           Omit the header
#     --js-return-as-exit      Treat top-level `return` as exit
#     --js-no-return-as-exit   Disable
#
#   Workers / drivers:
#     --js-worker              Enable Web Worker code generation
#     --js-no-worker           Disable workers
#     --js-worker-slave        Generate worker-slave glue
#     --js-no-worker-slave     Disable worker-slave glue
#     --js-driver <NAME>       Select a compilation driver
#     --js-drivers-list        List available drivers
#     --js-show-driver         Show the active driver
#
#   Other:
#     --client-js <FILE>       Path to the client-side runtime
#     --bootstrap-mode         Bootstrap-mode compilation
#     --eval <EXPR>            Evaluate a Scheme expression
#     --arity-check            Insert function-arity runtime checks
#     --js-config <FILE>       JS configuration file
#     --js-option <K=V>        Set a backend option (repeatable)
#     --js-preprocessor <CMD>  External JS preprocessor command
#
#   Bigloo passthrough:
#     `--` separator passes all remaining options to the underlying
#     Bigloo compiler invocation.
#
# LANGUAGE-CORPUS POSITION
#   Hop (the multi-tier Web programming language) is the 145th programming
#   language entry in this completion corpus, closing the 3+1 micro-cycle
#   that began at R849 (_pushpin-publish/zmq Rust=120 opens Axis 65) and
#   continued through R850 (_gophernotes/go-zeromq Go=120) and R851
#   (_jwt-cracker-server/zmq TS-Node=120 CLOSES Axis 65 ZeroMQ Messaging
#   Library at 1/1/1 + TRIPLE-120 ROUND-NUMBER LANDMARK + 58 axes at
#   1/1/1).  Hop joins the roster of exotic languages already in the
#   corpus including Lustre (R848 144th), Ravi (R844 143rd), ZetZ (R840
#   142nd), Granule (R836 141st), Sixten (R832 140th — round-number
#   language milestone), Imba (R828 139th), Tao (R824 138th), Dada (R820
#   137th), Acton (R816 136th), Stanza (R812 135th), Rune, Egel, Mlatu,
#   Gwion, Silq (quantum), Mirth, Lawvere/bill, Cognac/Cognate, and
#   Scrapscript.
#
#   No completion for `hopc` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.  The
#   sibling `more_src/_hop` exists in this corpus for the Hop runtime
#   server;  `hopc` is the compiler component of the same project.
# ============================================================================

_hopc() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print the version and exit]' \
        '(- *)--buildtag[print the buildtag and exit]' \
        '-v-[verbosity level (-v0 silent)]:level:(0 1 2 3)' \
        '-q[do not load an init file]' \
        '--rc-file=[load alternate rc file]:rc file:_files' \
        '--rc-dir=[set rc directory]:rc dir:_files -/' \
        '--lib-dir=[set Hop lib directory]:lib dir:_files -/' \
        '--share-dir=[set hopc share directory]:share dir:_files -/' \
        '*-L+[add a Hop library search path]:library dir:_files -/' \
        '--ast[print the parsed AST]' \
        '--ast-file=[write the AST to a file]:ast file:_files' \
        '--afile=[write a Bigloo .afile]:afile:_files' \
        '--configure[print Hop configure information]' \
        '(--js-es5 --js-es6 --js-es2017 --js-target-es5)--js-es5[target ECMAScript 5]' \
        '(--js-es5 --js-es6 --js-es2017 --js-target-es5)--js-es6[target ECMAScript 6]' \
        '(--js-es5 --js-es6 --js-es2017 --js-target-es5)--js-es2017[target ECMAScript 2017 (default)]' \
        '(--js-es5 --js-es6 --js-es2017 --js-target-es5)--js-target-es5[output ES5-compatible code]' \
        '--language=[force language]:language:(js ts scheme typescript javascript)' \
        '--js-typescript[enable TypeScript parsing]' \
        '(--js-type-annotations --js-no-type-annotations)--js-type-annotations[preserve type annotations]' \
        '(--js-type-annotations --js-no-type-annotations)--js-no-type-annotations[strip type annotations]' \
        '(--js-sealed-decorator --js-no-sealed-decorator)--js-sealed-decorator[generate sealed-decorator code]' \
        '(--js-sealed-decorator --js-no-sealed-decorator)--js-no-sealed-decorator[disable sealed-decorator]' \
        '(--js-commonjs-export --js-no-commonjs-export)--js-commonjs-export[emit CommonJS export (default)]' \
        '(--js-commonjs-export --js-no-commonjs-export)--js-no-commonjs-export[do not emit CommonJS export]' \
        '--js-module-main=[set module main entry name]:main:' \
        '--js-no-module-main[do not set a module main]' \
        '--js-module-name=[override the module name]:name:' \
        '--js-module-path=[override the module path]:path:' \
        '--js-node-modules-dir=[path to node_modules]:node_modules dir:_files -/' \
        '--js-require-hop[inject require("hop") into the bundle]' \
        '--js-ignore-unresolved-modules[skip missing-module errors]' \
        '--js-loader=[custom Hop JS loader]:loader:_files' \
        '(--js-header --js-no-header)--js-header[emit a Hopc-Header comment]' \
        '(--js-header --js-no-header)--js-no-header[omit the header]' \
        '(--js-return-as-exit --js-no-return-as-exit)--js-return-as-exit[treat top-level return as exit]' \
        '(--js-return-as-exit --js-no-return-as-exit)--js-no-return-as-exit[disable]' \
        '(--js-worker --js-no-worker)--js-worker[enable Web Worker codegen]' \
        '(--js-worker --js-no-worker)--js-no-worker[disable workers]' \
        '(--js-worker-slave --js-no-worker-slave)--js-worker-slave[generate worker-slave glue]' \
        '(--js-worker-slave --js-no-worker-slave)--js-no-worker-slave[disable worker-slave glue]' \
        '--js-driver=[select compilation driver]:driver:' \
        '--js-drivers-list[list available drivers]' \
        '--js-show-driver[show the active driver]' \
        '--client-js=[path to client-side runtime]:client.js:_files -g "*.js"' \
        '--bootstrap-mode[bootstrap-mode compilation]' \
        '--eval=[evaluate a Scheme expression]:expression:' \
        '--arity-check[insert function-arity runtime checks]' \
        '--js-config=[JS configuration file]:config:_files -g "*.(json|js)"' \
        '*--js-option=[set a backend option (K=V; repeatable)]:option:' \
        '--js-preprocessor=[external JS preprocessor command]:command:' \
        '*:Hop source file:_files -g "*.(scm|js|ts|hop|hop.js)"'
}

_hopc "$@"
