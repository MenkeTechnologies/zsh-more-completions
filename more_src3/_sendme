#compdef sendme
# Documentation: https://github.com/n0-computer/sendme (src/main.rs clap)
# Reference accessed: 2026-05-21
# Verified: upstream sendme main.rs clap definitions.

local curcontext="$curcontext" ret=1 expl

local -a common_opts=(
  '(-h --help)'{-h,--help}'[help]'
  '--magic-ipv4-addr=[IPv4 magicsocket listen addr]:addr:'
  '--magic-ipv6-addr=[IPv6 magicsocket listen addr]:addr:'
  '--format=[output format]:format:(hex cid)'
  '*'{-v,--verbose}'[increase verbosity]'
  '--no-progress[suppress progress bars]'
  '--relay=[relay mode or URL]:relay:(disabled default)'
  '--show-secret[print secret key]'
  '(-j --jobs)'{-j+,--jobs=}'[parallel import jobs]:count:'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'sendme command' compadd -- send receive
  ;;
rest)
  case $line[1] in
    send)
      _arguments -s -S \
        $common_opts \
        '--ticket-type=[ticket type]:type:(id addresses relay relay-and-addresses)' \
        '(-c --clipboard)'{-c,--clipboard}'[store receive command in clipboard]' \
        '1:file or directory:_files' && ret=0
      ;;
    receive)
      _arguments -s -S \
        $common_opts \
        '1:blob ticket:' && ret=0
      ;;
  esac
  ;;
esac

return ret
