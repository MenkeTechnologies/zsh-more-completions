#compdef verible-verilog-syntax
# Documentation: https://github.com/chipsalliance/verible/blob/master/verible/verilog/tools/syntax/verilog-syntax.cc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--helpfull[show all options]' \
  '--lang=[language variant to parse]:lang:(auto sv lib)' \
  '--export_json[output JSON for use by other tools]' \
  '--printtree[print the tree]' \
  '--printtokens[print all lexed and filtered tokens]' \
  '--printrawtokens[print all lexed tokens including filtered]' \
  '--error_limit=[max syntax errors reported (0: unlimited)]:n:' \
  '--verifytree[verify all tokens parsed into tree, print unmatched]' \
  '--show_diagnostic_context[print additional line with position marker]' \
  '*:file:_files -g "*.{v,sv,vh,svh}"' && ret=0

return ret
