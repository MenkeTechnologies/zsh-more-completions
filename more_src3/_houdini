#compdef houdini
# =============================================================================
# houdini — HoudiniGraphql's "The disappearing GraphQL
#          framework" — a TypeScript codegen-based
#          GraphQL framework that compiles `.gql` query
#          fragments + `houdini.config.js` into fully-
#          typed Svelte / React / vanilla-Node runtime
#          code at build time, eliminating the GraphQL
#          client boilerplate (no manual loader
#          functions, no manual cache key calculations,
#          no manual TypeScript type definitions) from
#          the application code.  Named "disappearing"
#          because the framework's runtime footprint
#          shrinks to essentially zero in the final
#          bundle.
#          Distinguishing from Apollo Client (large
#          runtime; manual `useQuery` invocations
#          everywhere), URQL (smaller runtime but still
#          needs imperative loading), Relay (Facebook's
#          codegen-driven client; React-only;
#          historically complex configuration),
#          Tanstack Query (data fetching without
#          GraphQL-specific niceties), and SWR
#          (general data fetching; not GraphQL-native)
#          by:
#            - GRAPHQL-YOGA FOUNDATION — uses graphql-
#              yoga v4.0 (this is the headline CLI
#              library that CLOSES Axis 46 on the
#              TS-Node side at 1/1/1; see taxonomy
#              notes below) as the embedded GraphQL
#              server for development + schema-pull
#              functionality.  graphql-yoga is The
#              Guild's modern Apollo-Server
#              alternative; ~8,000+ stars on the
#              upstream library
#            - CODEGEN-FIRST WORKFLOW — `houdini
#              generate` reads `houdini.config.js` +
#              `.gql` files + emits typed Svelte
#              stores / React hooks / Node clients
#              that the application imports directly.
#              The framework lives in the BUILD
#              process; the runtime is a thin
#              shim
#            - SCHEMA INTROSPECTION — `houdini pull-
#              schema` issues an HTTPS GET to the
#              configured GraphQL endpoint, retrieves
#              the schema via introspection, and
#              caches it locally for use by
#              subsequent `generate` runs.
#              `--headers <KEY=VALUE>` allows
#              authentication headers
#            - HEADERS via KEY=VALUE — every command
#              that contacts the upstream API
#              supports `-h, --headers Auth=Bearer
#              token X-API-Key=secret`; passed
#              through as HTTP headers to the
#              introspection endpoint.  Critical for
#              authenticated GraphQL APIs
#            - QUERY MAP OUTPUT — `houdini generate -
#              o queries.json` persists a query→hash
#              map file suitable for CDN-cached
#              persisted-query deployment;
#              dramatically reduces over-the-wire
#              size of POST bodies in production
#            - SVELTE-NATIVE INTEGRATION — primary
#              target is Svelte / SvelteKit (the
#              maintainer's home ecosystem); houdini-
#              svelte package generates Svelte
#              stores that handle reactive data
#              fetching natively
#            - REACT INTEGRATION — secondary
#              houdini-react package generates React
#              hooks; useful for React + GraphQL
#              projects wanting Houdini's codegen
#              workflow
#            - VITE PLUGIN INTEGRATION — vite-plugin-
#              watch-and-run integrates with Vite's
#              dev server to re-run `houdini
#              generate` when `.gql` files change;
#              users see updated typed code
#              immediately
#            - LOG LEVEL CONTROL — `-l, --log
#              [level]` accepts log levels enumerated
#              in the LogLevel enum (Quiet/Info/
#              Verbose/Debug); `-v, --verbose` is a
#              shortcut for the most verbose level
#            - CLACK PROMPTS — uses @clack/prompts
#              v0.6 for the interactive `houdini
#              init` setup wizard; the Clack family
#              of prompts has become the de-facto
#              alternative to inquirer in the
#              modern Vite + Vue + Svelte ecosystem
#            - ADAPTER ECOSYSTEM — adapter-auto +
#              adapter-cloudflare + adapter-node +
#              adapter-static packages for
#              deployment-target-specific output;
#              uses Vite SSR adapter semantics
#            - 972+ STARS ON HoudiniGraphql/houdini
#              — well-regarded in the Svelte
#              ecosystem; recommended by the Svelte
#              team's official documentation for
#              GraphQL integration; MIT licensed;
#              active development
#          Used by: SvelteKit applications consuming
#          GraphQL APIs, React projects wanting
#          codegen-driven GraphQL with minimal
#          runtime cost, and developers tired of
#          manual `useQuery` calls + manual type
#          synchronization between schema and
#          application code.
#
# Author:  HoudiniGraphql organization at GitHub.
#          "The disappearing GraphQL client for the
#          Svelte ecosystem" per organization
#          tagline.  Active maintainer team led by
#          AlecAivazis (Alec Aivazis, Houdini
#          original author) + contributors from the
#          Svelte community.
# Source:  https://github.com/HoudiniGraphql/houdini
#          https://github.com/HoudiniGraphql/houdini/blob/main/packages/houdini/src/cmd/index.ts
#          https://github.com/HoudiniGraphql/houdini/blob/main/packages/houdini/package.json
# Manpage: No traditional manpage; `houdini --help`
#          shows commander-derived subcommand list;
#          `houdini <sub> --help` per-subcommand
#          options.  Full documentation at https://
#          houdinigraphql.com
# Library: graphql-yoga ^4.0.4 (The Guild's
#          "Featured GraphQL Server with focus on
#          easy setup, performance and great
#          developer experience").  This is the
#          headline dependency for this completion's
#          axis-46 closing role; see taxonomy notes
#          below.  Also commander ^9.4 (Axis 1
#          argparse — TJ Holowaychuk's Node CLI
#          parser), @graphql-tools/merge + @graphql-
#          tools/schema (schema utilities),
#          @clack/prompts ^0.6 (interactive
#          prompts), @babel/parser ^7.24 (parsing
#          user JS for codegen), ast-types ^0.16
#          + estree-walker ^3 + recast ^0.23 (AST
#          manipulation), glob ^11 + micromatch
#          ^4.0 + minimatch ^5.1 (file matching),
#          fs-extra ^10 (filesystem utilities),
#          graphql ^15.8 (graphql-js core), memfs
#          ^3.4 (in-memory FS for codegen),
#          node-fetch ^3.2, deepmerge ^4.2,
#          vite-plugin-watch-and-run ^1.7 (Vite
#          integration), @whatwg-node/server ^0.9
#          (WHATWG fetch server adapter), npx-import
#          ^1.1.
# License: MIT
# Status:  972+ stars on HoudiniGraphql/houdini;
#          active maintenance; well-integrated with
#          SvelteKit + React ecosystem; published
#          to npm as `houdini` package
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — AXIS 46 CLOSES AT 1/1/1:
#   GRAPHQL SERVER / GRAPHQL RUNTIME
# -----------------------------------------------------------------------------
# This completion **CLOSES AXIS 46 AT 1/1/1 THREE-
# LANGUAGE SYMMETRY** in the cross-language CLI
# library taxonomy: GraphQL Server / GraphQL
# Runtime.
#
# Pattern: R772 125th language (Cogent) closes the
# prior 3+1 cycle → R773 Rust=101 (tailcall/async-
# graphql OPENS Axis 46) → R774 Go=101 (stash/
# 99designs/gqlgen continues Axis 46) → R775
# TS-Node=101 (houdini/graphql-yoga CLOSES Axis 46
# AT 1/1/1 THIS ROUND).  Next R776 will be the
# 126th language closing the 3+1 micro-cycle.
#
# THE COMPLETE AXIS 46 PICTURE (NOW 1/1/1):
#
#   * RUST = async-graphql (R773 tailcall)
#     - Sun Li's async-graphql library; ~3,660
#       stars
#     - CODE-FIRST: write Rust structs + proc-
#       macros generate the GraphQL schema
#     - Pattern: HIGH-PERFORMANCE GRAPHQL RUNTIME
#       (tailcall composes REST/gRPC/GraphQL
#       backends declaratively into unified
#       GraphQL endpoints)
#
#   * GO = 99designs/gqlgen (R774 stash)
#     - 99designs's gqlgen library; ~10,723 stars
#     - SCHEMA-FIRST: write .graphql SDL, run go
#       generate, get typed Go resolver
#       interfaces
#     - Pattern: GRAPHQL-EVERYWHERE APPLICATION
#       (stash uses GraphQL for ALL UI + scraping
#       + integration calls; every feature is
#       API-first)
#
#   * TS-NODE = graphql-yoga (R775 THIS)
#     - The Guild's graphql-yoga library; ~8,000+
#       stars on the upstream library
#     - SCHEMA-FIRST + EXECUTABLE-SCHEMA: combine
#       @graphql-tools/schema executableSchema
#       with graphql-yoga's createYoga server
#       for a complete GraphQL endpoint
#     - Pattern: CODEGEN-DRIVEN GRAPHQL CLIENT
#       FRAMEWORK (houdini uses graphql-yoga
#       internally for development server +
#       schema-pull, but the user-facing tool is
#       the codegen pipeline that emits typed
#       client code)
#
# THE AXIS 46 ARC TELLS THE COMPLETE GRAPHQL-
# ECOSYSTEM STORY:
#   - R773 tailcall (Rust SERVER) — high-throughput
#     production GraphQL gateway composing backend
#     services
#   - R774 stash (Go SERVER) — GraphQL-everywhere
#     application architecture (server + scraper +
#     UI all via GraphQL)
#   - R775 houdini (TS-Node CLIENT FRAMEWORK) —
#     codegen-driven typed GraphQL client for
#     Svelte/React frontends
#
# Across three languages: gateway (Rust), full-
# stack application (Go), frontend framework (TS-
# Node).  Together they trace the data flow from
# backend orchestration to UI consumption through
# the GraphQL ecosystem.
#
# Cross-language CLI library taxonomy after R775:
#   * 125 languages
#   * 483 total CLI library variants (Rust 101 /
#     Go 101 / TS-Node 101)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 39 axes at 1/1/1 three-language symmetric
#     (axes 7 + 8 + 11 + 12 + 15-46)
#
# WHY graphql-yoga IS A DISTINCTIVE AXIS-46
# CLOSER:
#
#   graphql-yoga by The Guild (Charly Poly + team)
#   is the modern alternative to Apollo Server in
#   the Node.js GraphQL ecosystem.  Distinguishing
#   characteristics:
#     1. WHATWG FETCH-NATIVE — built on the WHATWG
#        Request/Response API rather than Express
#        req/res; works in Node.js + Deno + Bun +
#        Cloudflare Workers + Vercel Edge from
#        the same codebase
#     2. EXECUTABLE SCHEMA — accepts an
#        executableSchema (from @graphql-tools/
#        schema) directly; integrates naturally
#        with schema-first development patterns
#     3. SCHEMA STITCHING + FEDERATION — first-
#        class support for schema stitching (the
#        Guild's own stitching approach) AND
#        Apollo Federation v2
#     4. PLUGIN ARCHITECTURE — Envelop plugin
#        ecosystem provides query logging, depth
#        limiting, complexity analysis, Sentry
#        integration, Newrelic instrumentation
#     5. SUBSCRIPTIONS via SSE + WEBSOCKET —
#        supports both Server-Sent Events
#        subscriptions (newer, simpler) AND
#        graphql-ws WebSocket subscriptions
#        (legacy compatibility)
#     6. ~8,000+ STARS — second-largest GraphQL
#        server library in the Node ecosystem
#        after Apollo Server (~14,000 stars)
#     7. THE GUILD ECOSYSTEM INTEGRATION — works
#        natively with @graphql-tools/schema +
#        @envelop/core + graphql-mesh + meshql,
#        the Guild's broader GraphQL toolchain
#     8. ECOSYSTEM-DOMINANT for MODERN PROJECTS
#        — used by houdini (this completion),
#        cedar (RedwoodJS rebrand), ponder.sh,
#        graffle, kadena.js, knackstedt/
#        shokupan, and many other modern
#        TypeScript GraphQL projects
#
# Maintained by The Guild + contributors at
# graphql-hive/graphql-yoga.  License: MIT.
#
# Comparison to other Axis 46 candidates (TS-Node):
#   * houdini (R775 THIS) — disappearing GraphQL
#     framework with graphql-yoga as direct dep;
#     972 stars; codegen-driven workflow
#   * keystone — already in corpus (in blacklist)
#   * codeceptjs — Apollo GraphQL testing
#     integration but not direct dep
#   * cedar — RedwoodJS rebrand; 135 stars but
#     redirect from main repo
#   * ponder.sh — already in corpus
#   * graffle — GraphQL client lib (Jason Kuhrt);
#     library not standalone CLI
#   * nitro-graphql — Nitro module; 123 stars,
#     niche
#   * apollo-server itself — would be ideal as
#     headline lib but no clear CLI binary
#   * The Guild's own @graphql-yoga/node — used
#     by Yoga itself; library not CLI
#
# houdini is the chosen Axis 46 TS-Node closer
# because:
#   - It uses graphql-yoga as a DIRECT runtime
#     dependency in the houdini package's
#     package.json
#   - The CODEGEN-DRIVEN FRAMEWORK pattern is
#     distinct from R773 tailcall (server-side
#     gateway) + R774 stash (server-side
#     application) — completing the three-language
#     arc with a CLIENT-FRAMEWORK use case
#   - 972 stars + active maintenance + Svelte +
#     React ecosystem integration provide stable
#     taxonomy positioning
#   - The MIT license + commander-based CLI +
#     @clack/prompts interactive setup match the
#     modern TS-Node CLI design patterns
#   - It demonstrates how graphql-yoga's WHATWG-
#     native architecture enables Houdini's
#     "framework that disappears at build time"
#     positioning (the dev server uses graphql-
#     yoga internally; the production runtime
#     has no GraphQL server at all)
#
# -----------------------------------------------------------------------------
#
# THE houdini CLI
#
# houdini is a multi-subcommand CLI built on
# commander v9.x.  Invocation:
#   houdini <subcommand> [args] [options]
#
# Subcommands:
#   generate                          generate the
#                                     application
#                                     runtime
#   init [path]                       initialize a new
#                                     houdini project
#   pull-schema                       pull latest
#                                     schema from your
#                                     API
#
# generate flags:
#   -p, --pull-schema                 pull schema
#                                     before generating
#   -o, --output [PATH]               persist queries
#                                     to queryMap file
#   -h, --headers <KV...>             headers for
#                                     schema-pull
#                                     (KEY=VALUE
#                                     repeatable)
#   -v, --verbose                     verbose error
#                                     messages
#   -l, --log [LEVEL]                 log level
#
# init flags:
#   [path]                            target folder
#                                     for new project
#                                     (default ".")
#   -h, --headers <KV...>             headers for
#                                     schema-pull
#   -y, --yes                         don't prompt;
#                                     use defaults
#
# pull-schema flags:
#   -o, --output [PATH]               destination for
#                                     schema contents
#   -h, --headers <KV...>             headers for
#                                     schema-pull
#
# Common invocations:
#   # Generate the application runtime (typical
#   # development workflow; run after schema or .gql
#   # file changes)
#   houdini generate
#
#   # Generate + pull latest schema first
#   houdini generate -p
#   houdini generate --pull-schema
#
#   # Generate with persisted queries
#   houdini generate -o ./public/queries.json
#
#   # Generate with auth headers
#   houdini generate -p -h Authorization="Bearer $TOKEN"
#   houdini generate --pull-schema --headers \
#     X-API-Key="$KEY" X-Tenant-ID="$TENANT"
#
#   # Verbose generation
#   houdini generate -v
#
#   # Custom log level
#   houdini generate -l verbose
#   houdini generate --log debug
#
#   # Initialize a new project in cwd
#   houdini init
#
#   # Initialize in specific path
#   houdini init ./my-houdini-app
#
#   # Non-interactive init with defaults
#   houdini init -y
#   houdini init ./my-app --yes
#
#   # Init with auth headers (for schema-pull during setup)
#   houdini init -h Authorization="Bearer $TOKEN"
#
#   # Pull schema only
#   houdini pull-schema
#
#   # Pull schema to specific file
#   houdini pull-schema -o ./schema.graphql
#   houdini pull-schema --output ./schema.json
#
#   # Pull schema with auth
#   houdini pull-schema -h Authorization="Bearer $TOKEN"
#
# OPTIONS (sourced directly from
# https://github.com/HoudiniGraphql/houdini/blob/main/packages/houdini/src/cmd/index.ts):
#
# generate:
#   -p, --pull-schema                 pull schema first
#   -o, --output [PATH]               queryMap output
#   -h, --headers <KV...>             auth headers
#   -v, --verbose                     verbose errors
#   -l, --log [LEVEL]                 log level
#
# init [path]:
#   -h, --headers <KV...>             auth headers
#   -y, --yes                         use defaults
#
# pull-schema:
#   -o, --output [PATH]               schema dest path
#   -h, --headers <KV...>             auth headers
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _houdini_subcommands
_houdini_subcommands=(
    'generate:generate the application runtime from .gql files + houdini.config.js'
    'init:initialize a new Houdini project (interactive setup)'
    'pull-schema:pull the latest GraphQL schema from your API endpoint'
)

local -a _houdini_log_levels
_houdini_log_levels=(
    'Quiet:errors only'
    'Info:default informational output'
    'Verbose:detailed progress messages'
    'Debug:internal debug tracing'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:subcommand:->subcmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    subcmd)
        _describe -t subcmds 'houdini subcommand' _houdini_subcommands && ret=0
        ;;
    args)
        case $words[1] in
            generate)
                _arguments \
                    '(-p --pull-schema)'{-p,--pull-schema}'[pull schema before generating]' \
                    '(-o --output)'{-o,--output}'+[persist queries to queryMap file]:path:_files' \
                    '*'{-h,--headers}'=[header for schema-pull (KEY=VALUE)]:KEY=VALUE: ' \
                    '(-v --verbose)'{-v,--verbose}'[verbose error messages]' \
                    '(-l --log)'{-l,--log}'+[log level]:level:->loglevel' \
                    && ret=0
                ;;
            init)
                _arguments \
                    '*'{-h,--headers}'=[header for schema-pull (KEY=VALUE)]:KEY=VALUE: ' \
                    '(-y --yes)'{-y,--yes}'[do not prompt; use defaults]' \
                    '1:project path:_directories' \
                    && ret=0
                ;;
            pull-schema)
                _arguments \
                    '(-o --output)'{-o,--output}'+[destination for schema contents]:path:_files -g "*.(graphql|json)"' \
                    '*'{-h,--headers}'=[header for schema-pull (KEY=VALUE)]:KEY=VALUE: ' \
                    && ret=0
                ;;
        esac
        ;;
esac

case $state in
    loglevel)
        _describe -t loglevels 'log level' _houdini_log_levels && ret=0
        ;;
esac

return ret
