#compdef powermetrics
# Documentation: https://www.unix.com/man-page/osx/1/powermetrics/
# Source: Apple macOS — per-sampler CPU/GPU/SoC/memory/network power-and-frequency tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help]' \
    '(-u --output-file)'{-u+,--output-file=}'[output file (instead of stdout)]:file:_files' \
    '(-b --buffer-size)'{-b+,--buffer-size=}'[output buffer size (0=none / 1=line)]:size:(0 1)' \
    '(-i --sample-interval)'{-i+,--sample-interval=}'[sample every N ms (default 5000)]:ms:' \
    '(-n --sample-count)'{-n+,--sample-count=}'[periodic samples (0=infinite)]:n:' \
    '(-t --wakeup-cost)'{-t+,--wakeup-cost=}'[package idle wakeup CPU cost (us)]:usec:' \
    '(-o --order)'{-o+,--order=}'[process-list ordering method]:order:(composite cputime power gputime energy_impact wakeup_count idle_wakeups)' \
    '(-f --format)'{-f+,--format=}'[display format]:fmt:(text plist)' \
    '(-a --poweravg)'{-a+,--poweravg=}'[display poweravg every N samples (0=disabled)]:n:' \
    '--hide-platform-power[hide platform power data]' \
    '--hide-cpu-duty-cycle[hide CPU duty cycle data]' \
    '--hide-gpu-duty-cycle[hide GPU duty cycle data]' \
    '--show-initial-usage[print initial sample for entire uptime]' \
    '--show-usage-summary[print final usage summary on exit]' \
    '*--samplers=[samplers to enable]:sampler:(cpu_power gpu_power thermal smc battery network disk interrupts tasks ane_power agpm cpu_power_thermal cpu_dvfm_stats gpu_dvfm_stats all)' \
    '--samplers-help[list available samplers]' \
    && ret=0

return ret
