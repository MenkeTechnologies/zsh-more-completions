#compdef zpool-split
# _zpool-split — OpenZFS zpool split (detach one disk from each mirrored vdev to form a new pool that is a point-in-time copy; -g show pool config, -L resolve symlinks, -n dry-run, -o property=value for new pool, -P full paths, -R altroot for new pool import; positional source then new pool then optional disk selection per mirror)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_split) on tip.

_zpool-split() {
    _arguments \
        '-g[show pool config]' \
        '-L[resolve symlinks]' \
        '-n[dry run]' \
        '-P[full paths]' \
        '-l[load encryption keys before mounting]' \
        '*-o+[property=value]:property=value:' \
        '-R+[altroot]:dir:_files -/' \
        '1:source pool:' \
        '2:new pool:' \
        '*:device:'
}

_zpool-split "$@"
