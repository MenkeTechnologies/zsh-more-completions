#compdef libp2p-cli libp2p
# _libp2p-cli — libp2p P2P networking stack CLI alias (libp2p team, Go); custom argparse
# upstream: https://github.com/libp2p/go-libp2p

_libp2p-cli() {
    local -a sub=(
        'identity:identity commands'
        'identity create:create identity'
        'identity show:show identity'
        'host:host commands'
        'host start:start host'
        'host stop:stop host'
        'host status:show host status'
        'peer:peer commands'
        'peer list:list peers'
        'peer connect:connect to peer'
        'peer disconnect:disconnect from peer'
        'peer info:show peer info'
        'pubsub:pubsub commands'
        'pubsub subscribe:subscribe to topic'
        'pubsub publish:publish to topic'
        'pubsub list:list topics'
        'pubsub peers:list topic peers'
        'dht:DHT commands'
        'dht put:put value to DHT'
        'dht get:get value from DHT'
        'dht find-peer:find peer via DHT'
        'dht provide:provide content via DHT'
        'dht find-providers:find providers via DHT'
        'autonat:autonat commands'
        'autonat status:show autonat status'
        'autonat probe:probe NAT'
        'relay:relay commands'
        'relay enable:enable relay'
        'relay disable:disable relay'
        'addrs:list listening addresses'
        'ping:ping peer'
        'help:show help'
        'version:show version'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--config=+[config file]:file:_files -g "*.{json,yaml,yml,toml}"' \
        '--listen=+[multiaddr]:str:' \
        '--nat[enable NAT]' \
        '--quic[enable QUIC]' \
        '--tls[enable TLS]' \
        '--noise[enable Noise]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'libp2p subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_libp2p-cli "$@"
