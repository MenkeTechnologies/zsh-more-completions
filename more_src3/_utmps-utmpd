#compdef utmps-utmpd utmps-write utmps-wtmpd
# Documentation: source-direct extraction from upstream
# skarnet/utmps src/utmps/utmps-{utmpd,write,wtmpd}.c USAGE
# strings + subgetopt_r option-string specs + case-arm decoding
# (utmps-write -u/-w are independent bit flags via `what |= 1|2`,
# NOT mutex - both can be combined to write the same record into
# both utmp AND wtmp simultaneously).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet utmps R127c — 3-stem multi-binary harvest of the utmps
# utmp/wtmp/btmp replacement framework. utmps replaces glibc's
# system-wide utmpx-mutex-locked file approach with a UCSPI socket
# protocol talking to dedicated long-running daemons, eliminating
# the historical setuid binaries + race-condition class.

case $service in

  utmps-utmpd)
    # Long-running daemon serving the utmpx UCSPI socket protocol.
    # Reads/writes utmp entries on behalf of clients (login, getty,
    # sshd) so those programs no longer need setuid root. Takes no
    # CLI arguments (configuration is by env vars + socket path).
    _arguments -s -S \
      ': :_default'
    ;;

  utmps-wtmpd)
    # Long-running daemon serving the wtmpx UCSPI socket protocol.
    # Single optional positional: wtmp file path override (defaults
    # to /var/log/wtmpx).
    _arguments -s -S \
      '1:wtmp file path:_files'
    ;;

  utmps-write)
    # CLI client that writes a single utmp/wtmp entry by talking to
    # utmps-utmpd / utmps-wtmpd via their UCSPI sockets. -u and -w
    # are independent bit flags: both may be set to write the SAME
    # record into both utmp AND wtmp simultaneously.
    _arguments -s -S \
      '-u[write the entry into utmp (via utmps-utmpd)]' \
      '-w[write the entry into wtmp (via utmps-wtmpd)]' \
      '-U+[utmpd socket path override]:socket:_files' \
      '-W+[wtmpd socket path override]:socket:_files' \
      '-t+[operation timeout in ms]:ms:' \
      '-T+[timestamp override (seconds since epoch)]:timestamp:' \
      '-h+[hostname field]:host:_hosts' \
      '-i+[remote IP field]:ip:' \
      '-l+[user (login name) field]:user:_users' \
      '-p+[process pid field]:pid:_pids' \
      '1:entry id (utmp identifier):' \
      '2:entry type:(EMPTY RUN_LVL BOOT_TIME NEW_TIME OLD_TIME INIT_PROCESS LOGIN_PROCESS USER_PROCESS DEAD_PROCESS ACCOUNTING)' \
      '3:tty line:'
    ;;

esac
