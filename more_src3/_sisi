#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/frost-beta/sisi/blob/main/src/cli.ts clipanion
# Command class definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
    'index:build or update index for images under target directory'
    'search:search the query string from indexed images'
    'list-index:list the directories in the index'
    'remove-index:remove index for all items under target directory'
)

_arguments -s -C \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case "$state" in
    cmd)
        _describe -t commands 'sisi subcommand' commands && ret=0
        ;;
    args)
        case "${words[1]}" in
            index|remove-index)
                _arguments -s '1:directory:_directories' && ret=0
                ;;
            search)
                _arguments -s \
                    '--in=[directory where images are searched]:directory:_directories' \
                    '--max=[maximum number of results to return (default 20)]:count:' \
                    '--print[print results to stdout instead of opening browser]' \
                    '1:query text or image URL/path:' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
