#compdef litgpt
# Documentation: https://github.com/Lightning-AI/litgpt
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for litgpt - Lightning AI's LLM training/serving CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'litgpt command' \
      'download[retrieve model weights and tokenizers]' \
      'chat[interactive conversation with model]' \
      'finetune[adapt pretrained models to tasks]' \
      'pretrain[train from scratch on custom data]' \
      'evaluate[test model performance on benchmarks]' \
      'serve[deploy model as a web API]' \
      'generate[text generation]' \
      'convert[export to other model formats]' && ret=0
    ;;
  args)
    _arguments \
      '--config[YAML configuration file]:path:_files' \
      '--out_dir[output directory for checkpoints]:dir:_directories' \
      '--data[dataset type]:data:(JSON TextFiles Alpaca AlpacaGPT4 Deita Dolly FLAN LIMA LongForm Tinyllama OpenWebText)' \
      '--devices[number of GPUs/devices]:n:' \
      '--precision[training precision]:prec:(bf16-true bf16-mixed 32-true 16-true 16-mixed)' \
      '--tasks[evaluation task names]:tasks:' && ret=0
    ;;
esac

return ret
