#compdef snapcraft
# Documentation: https://documentation.ubuntu.com/snapcraft/en/latest/reference/commands/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for snapcraft - snap package builder

local curcontext="$curcontext" state line ret=1

# Subcommand list per upstream "Commands" reference (lifecycle, store,
# plugin/extension, validation, account, key, snap-name, release, track,
# utility sections). Speculative subcommands (e.g. promote, list-revisions
# rename) only kept when present in upstream listing.
local -a subcommands=(
  'build:lifecycle: build artifacts defined for a part'
  'clean:lifecycle: remove parts content or snap artifacts'
  'pack:lifecycle: create a snap file from a directory'
  'prime:lifecycle: prepare snap for distribution'
  'pull:lifecycle: download or retrieve artifacts'
  'stage:lifecycle: stage a parts content'
  'test:lifecycle: run snap tests'
  'try:lifecycle: try a snap in the host'
  'remote-build:lifecycle: dispatch a build to Launchpad'
  'plugins:list available plugins'
  'expand-extensions:expand extensions in snapcraft.yaml'
  'extensions:list available extensions'
  'login:account: login to the snap store'
  'logout:account: logout from the snap store'
  'whoami:account: show current login information'
  'create-key:key: create a signing key'
  'keys:key: list local signing keys'
  'register-key:key: register a signing key'
  'register:snap-name: register a snap name'
  'names:snap-name: list registered snap names'
  'metrics:snap-name: show metrics for a snap'
  'upload:release: upload a snap to the store'
  'release:release a revision to a channel'
  'promote:release: promote snap to a different channel'
  'status:release: show channel status'
  'revisions:release: list snap revisions in the store'
  'tracks:track: list tracks'
  'set-default-track:track: set default track'
  'init:utility: initialize a snapcraft project'
  'lint:utility: lint snapcraft.yaml'
  'version:utility: show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      pack)
        _arguments ':directory:_directories' && ret=0
        ;;
      upload)
        _arguments ':snap file:_files -g "*.snap"' && ret=0
        ;;
      clean|build|prime|pull|stage)
        _arguments '*:part name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
