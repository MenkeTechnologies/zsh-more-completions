#compdef wpaperd
# Documentation: https://github.com/danyspin97/wpaperd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (daemon/src/opts.rs).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to configuration file]:file:_files' \
  '(-d --daemon)'{-d,--daemon}'[detach and run in the background]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '--notify=[readiness fd to signal startup]:fd:'
