#compdef securityonion securityonion-setup so-setup so-config so-firewall so-checkconfig so-saltstack
# _securityonion — Security Onion securityonion-setup so-setup so-config CLI wrappers for orchestrating sensor manager standalone or evaluation installs network configuration salt-stack provisioning and node bootstrap (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_securityonion() {
    local -a sub=(
        'setup:run interactive setup wizard'
        'config:show/edit configuration'
        'firewall:firewall configuration'
        'checkconfig:check configuration'
        'saltstack:manage salt-stack'
        'status:show service status'
        'reload:reload services'
        'restart:restart services'
        'stop:stop services'
        'start:start services'
        'update:update Security Onion'
        'upgrade:upgrade Security Onion'
        'backup:backup configuration'
        'reset:reset Security Onion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node name]:str:' \
        '--node=+[node name]:str:' \
        '-r+[role]:r:(manager managersearch search standalone evalmode forward heavy storage receiver fleet idh searchnode)' \
        '--role=+[role]:r:(manager managersearch search standalone evalmode forward heavy storage receiver fleet idh searchnode)' \
        '--no-confirm[no confirm]' \
        '--unattended[unattended mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'securityonion subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments \
                    '--role=+[r]:r:(manager managersearch search standalone evalmode forward heavy)' \
                    '--no-firewall[no firewall]' \
                    '--no-network[no network setup]' ;;
                update|upgrade) _arguments \
                    '--check[check only]' \
                    '--apply[apply update]' ;;
            esac
            ;;
    esac
}

_securityonion "$@"
