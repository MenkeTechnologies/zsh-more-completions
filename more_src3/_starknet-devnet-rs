#compdef starknet-devnet starknet-devnet-rs
# _starknet-devnet-rs — Shard Labs starknet-devnet-rs Rust local development node emulating the Starknet sequencer and gateway with prefunded accounts and forking support (0xSpaceShard team, Rust); clap
# upstream: https://github.com/0xSpaceShard/starknet-devnet-rs

_starknet-devnet-rs() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--seed=+[N]:n:' \
        '--accounts=+[N]:n:' \
        '--initial-balance=+[wei]:n:' \
        '--account-class=+[c]:c:(cairo0 cairo1)' \
        '--account-class-custom=+[file]:file:_files -g "*.json *.sierra.json"' \
        '--host=+[addr]:str:' \
        '--port=+[port]:n:' \
        '--timeout=+[s]:n:' \
        '--gas-price=+[fri]:n:' \
        '--data-gas-price=+[fri]:n:' \
        '--gas-price-strk=+[strk]:n:' \
        '--data-gas-price-strk=+[strk]:n:' \
        '--chain-id=+[id]:i:(MAINNET TESTNET SEPOLIA)' \
        '--dump-on=+[trigger]:t:(exit block transaction request)' \
        '--dump-path=+[file]:file:_files' \
        '--state-archive-capacity=+[c]:c:(none full)' \
        '--block-generation-on=+[mode]:m:(transaction demand)' \
        '--blocks-on-demand[blocks on demand]' \
        '--lite-mode[lite mode]' \
        '--start-time=+[unix]:n:' \
        '--fork-network=+[url]:str:' \
        '--fork-block=+[N]:n:' \
        '--allow-zero-max-fee[allow zero max fee]' \
        '--request-body-size-limit=+[bytes]:n:' \
        '--log-request[log requests]' \
        '--log-response[log responses]' \
        '--load-path=+[file]:file:_files'
}

_starknet-devnet-rs "$@"
