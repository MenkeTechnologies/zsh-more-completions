#compdef labelstats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/labelstats.html
# Source: MRtrix3/mrtrix3 cmd/labelstats.cpp — compute volume + centre of mass per label (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-output+[print field only]:choice:(mass centre)' \
    '-voxelspace[report parcel centres in voxel space (not scanner)]' \
    '1:input label image:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
