#compdef hyprlauncher
# _hyprlauncher — Hyprland app launcher (hyprwm/hyprlauncher)
# upstream: https://github.com/hyprwm/hyprlauncher
# Flags from src/main.cpp.

_hyprlauncher() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(-d --daemon)'{-d,--daemon}'[do not open after initializing (run as daemon)]'
        '(-o --options)'{-o+,--options=}'[explicit comma-separated option array]:options:'
        '(-m --dmenu)'{-m,--dmenu}'[read newline-separated options from stdin (dmenu mode)]'
        '(-t --toggle)'{-t,--toggle}'[toggle the launcher instead of opening]'
        '--quiet[disable all logging]'
        '--verbose[enable maximum logging]'
    )
    _arguments -s $args
}

_hyprlauncher "$@"
