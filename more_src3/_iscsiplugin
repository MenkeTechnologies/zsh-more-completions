#compdef iscsiplugin
# _iscsiplugin — Kubernetes CSI iSCSI driver (block-storage volumes over iSCSI)
# upstream: https://github.com/kubernetes-csi/csi-driver-iscsi
# Flags from cmd/iscsiplugin/main.go on tip.

_iscsiplugin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--nodeid=[node id]:id:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_iscsiplugin "$@"
