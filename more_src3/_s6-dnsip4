#compdef s6-dnsip4 s6-dnsip6
# Documentation: https://skarnet.org/software/s6-dns/s6-dnsip4.html + s6-dnsip6.html
# Reference accessed: 2026-05-30
# s6-dnsip4 / s6-dnsip6 — DNS resolver clients (IPv4 / IPv6). Print resolved addresses to stdout.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-q[qualify <domain> before resolution per /etc/resolv.conf suffixes ($DNSQUALIFY)]' \
  '(-h -H)-H[do not use data from /etc/hosts (default)]' \
  '(-h -H)-h[use data from /etc/hosts (prefers .cdb if newer; skips DNS on hosts hit)]' \
  '-r[random-permute results before printing]' \
  '-t+[resolution timeout in ms (default 0=none; exit 99 if exceeded)]:ms:' \
  '*:domain:' \
  && ret=0

return ret
