#compdef kdig
# Documentation: https://www.knot-dns.cz/docs/latest/html/man_kdig.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kdig: Knot DNS dig-like query tool. Corrected from prior file: only
# -h/--help and -V/--version have long forms (the rest are short-only);
# removed invented --source/--class/--debug/--name/--server/--type/
# --verbose/--reverse/--tsig long options and bogus -s/-v flags; +time
# is actually +timeout; added -E/-G dnstap, +no* and =value forms per
# upstream man page.

local -a query_options
query_options=(
  '+multiline[wrap long records to more lines]'
  '+nomultiline[do not wrap long records]'
  '+short[show record data only]'
  '+noshort[show full output]'
  '+generic[use generic representation format]'
  '+nogeneric[do not use generic format]'
  '+all[show all packet sections]'
  '+noall[clear all display flags]'
  '+question[show question section]'
  '+noquestion[hide question section]'
  '+answer[show answer section]'
  '+noanswer[hide answer section]'
  '+authority[show authority section]'
  '+noauthority[hide authority section]'
  '+additional[show additional section]'
  '+noadditional[hide additional section]'
  '+stats[show query statistics]'
  '+nostats[hide query statistics]'
  '+dnssec[set the DO flag (request DNSSEC)]'
  '+nodnssec[do not set the DO flag]'
  '+tcp[use TCP protocol]'
  '+notcp[use UDP protocol]'
  '+tls[use DNS over TLS]'
  '+notls[do not use DNS over TLS]'
  '+https=-[use DNS over HTTPS]:url:'
  '+nohttps[do not use DNS over HTTPS]'
  '+quic[use DNS over QUIC]'
  '+noquic[do not use DNS over QUIC]'
  '+nsid[request NSID]'
  '+nonsid[do not request NSID]'
  '+cookie=-[send an EDNS cookie]:hex:'
  '+nocookie[do not send an EDNS cookie]'
  '+timeout=[set query timeout]:seconds:'
  '+retry=[set number of UDP retries]:retries:'
  '+bufsize=[set EDNS UDP buffer size]:size:'
  '+edns=-[set EDNS version]:version:'
  '+noedns[disable EDNS]'
  '+json[output in JSON format (RFC 8427)]'
  '+nojson[do not output JSON]'
)

_arguments \
  '(- *)'{-h,--help}'[print program help]' \
  '(- *)'{-V,--version}'[print program version]' \
  '-4[use IPv4 protocol only]' \
  '-6[use IPv6 protocol only]' \
  '-b+[set source IP address]:address:' \
  '-c+[set query class]:class:(IN CH HS ANY)' \
  '*-d[enable debug messages (repeat for more)]' \
  '-k+[TSIG key file]:file:_files' \
  '-p+[nameserver port]:port:' \
  '-q+[query name]:name:' \
  '-t+[query type]:type:(A AAAA CNAME MX NS PTR SOA SRV TXT ANY AXFR IXFR)' \
  '-x+[reverse (PTR) query]:address:' \
  '-y+[TSIG authentication ([alg:]name:key)]:key:' \
  '-E+[export a dnstap trace into a file]:file:_files' \
  '-G+[generate a query from a dnstap file]:file:_files' \
  $query_options \
  '*::query name or option:' \
  && return 0
