#compdef strapi
# Documentation: https://docs.strapi.io/cms/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Strapi - headless CMS

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'develop:start Strapi in development mode with auto-reloading'
  'dev:alias for develop'
  'start:start Strapi in production mode (no auto-reload)'
  'build:build Strapi admin panel'
  'console:start server with interactive REPL'
  'login:log into Strapi Cloud'
  'logout:log out from Strapi Cloud'
  'deploy:deploy to Strapi Cloud'
  'export:export project data'
  'import:import data into project'
  'transfer:transfer data between Strapi instances'
  'report:print debug information'
  'telemetry\:disable:disable telemetry data collection'
  'telemetry\:enable:enable telemetry data collection'
  'version:display installed version'
  'help:list CLI commands'
  'configuration\:dump:dump configurations to file'
  'configuration\:restore:restore configuration dump'
  'config\:dump:alias for configuration:dump'
  'config\:restore:alias for configuration:restore'
  'admin\:create-user:create administrator'
  'admin\:create:alias for admin:create-user'
  'admin\:reset-user-password:reset admin password'
  'admin\:reset-password:alias for admin:reset-user-password'
  'admin\:list-users:list all administrators'
  'admin\:list:alias for admin:list-users'
  'admin\:active-user:set admin active status'
  'admin\:active:alias for admin:active-user'
  'admin\:block-user:set admin blocked status'
  'admin\:block:alias for admin:block-user'
  'admin\:delete-user:delete administrator'
  'admin\:delete:alias for admin:delete-user'
  'generate:generate APIs, controllers, content-types, etc.'
  'openapi:OpenAPI subcommands (generate)'
  'templates\:generate:create template from current project'
  'ts\:generate-types:generate TypeScript typings'
  'routes\:list:list available routes'
  'policies\:list:list registered policies'
  'middlewares\:list:list registered middlewares'
  'content-types\:list:list existing content-types'
  'hooks\:list:list available hooks'
  'controllers\:list:list registered controllers'
  'services\:list:list registered services'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'strapi command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      develop|dev)
        _arguments \
          '--watch-admin[watch admin panel for changes]' \
          '--polling[use polling for file watching]'
        ;;
      build)
        _arguments \
          '--clean[clean build directory first]' \
          '--no-optimization[skip admin optimization]'
        ;;
      export)
        _arguments \
          '--file=[output file]:file:_files' \
          '--key=[encryption key]:key:' \
          '--no-encrypt[skip encryption]' \
          '--no-compress[skip compression]' \
          '--only=[export only specific content]:content:(content files config)'
        ;;
      import)
        _arguments \
          '--file=[input file]:file:_files' \
          '--key=[encryption key]:key:' \
          '--force[force import]'
        ;;
      openapi)
        _arguments '1:subcommand:(generate)'
        ;;
    esac
    ;;
esac

return ret
