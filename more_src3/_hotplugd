#compdef hotplugd
# Documentation: man hotplugd(8)
# Source: openbsd/src usr.sbin/hotplugd — device attach/detach event daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[hotplug event device (default /dev/hotplug)]:device:_files' \
    && ret=0

return ret
