#compdef taplo-fmt
# Documentation: https://taplo.tamasfe.dev/cli/introduction.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at github.com/tamasfe/taplo/tree/master/site/site/cli/usage.
# STUB: taplo-fmt is the `taplo fmt` shim; delegate to _taplo when available.

local curcontext="$curcontext" state line ret=1

(( $+functions[_taplo] )) || autoload -Uz _taplo 2>/dev/null
if (( $+functions[_taplo] )); then
  _taplo "$@"
  return
fi

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--check[check if files are formatted]' \
  '--force[format files with syntax errors]' \
  '*'{-o,--option}'=[formatter option override]:key=value:' \
  '*:TOML file:_files -g "*.toml"' && ret=0

return ret
