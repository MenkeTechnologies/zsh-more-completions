#compdef venom
# Documentation: https://github.com/ovh/venom
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_venom_commands() {
  local -a commands=(
    'run:run test suites'
    'update:update venom binary to latest release'
    'version:print version'
  )
  _describe 'command' commands
}

_venom() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--help[show help]' \
    '1:command:_venom_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        run)
          _arguments \
            '--format=[output format]:format:(xml json yaml tap)' \
            '--output-dir=[output directory]:dir:_directories' \
            '--lib-dir=[lib directory for custom executors]:dir:_directories' \
            '--stop-on-failure[stop on first failure]' \
            '*'{-v,--verbose}'[increase verbosity]' \
            '*--var=[set variable KEY=VALUE]:var:' \
            '*--var-from-file=[set variables from file]:file:_files -g "*.(yml|yaml|json)"' \
            '--html-report[generate HTML report]' \
            '*:test files:_files -g "*.(yml|yaml)"'
          ;;
      esac
      ;;
  esac
}

_venom "$@"
