#compdef tiffcp
# Documentation: tiffcp usage on libtiff 4.7.1
# Source: libtiff tiffcp — copy, convert, or combine TIFF files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[append to output instead of overwriting]' \
    '-o+[set initial directory offset]:offset:' \
    '-p+[pack samples]:layout:(contig separate)' \
    '(-s -t)-s[write output in strips]' \
    '(-s -t)-t[write output in tiles]' \
    '-x[force merged TIFF pages in sequence]' \
    '-8[write BigTIFF instead of ClassicTIFF]' \
    '(-B -L)-B[write big-endian byte order]' \
    '(-B -L)-L[write little-endian byte order]' \
    '-M[disable memory-mapped files]' \
    '-C[disable strip chopping]' \
    '-i[ignore read errors]' \
    '-b+[bias (dark) monochrome image]:file[,N]:_files' \
    '-,=+[use % rather than , to separate image numbers]:char:' \
    '-m+[max memory allocation size (MiB; 0 = no limit)]:size:' \
    '-r+[max rows per strip]:n:' \
    '-w+[output tile width (pixels)]:n:' \
    '-l+[output tile length (pixels)]:n:' \
    '-f+[force FillOrder for output]:order:(lsb2msb msb2lsb)' \
    '-c+[output compression scheme]:scheme:(lzw zip lzma zstd jpeg packbits g3 g4 sgilog none)' \
    '*:input TIFF + output:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
