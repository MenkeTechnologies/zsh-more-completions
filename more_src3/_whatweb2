#compdef whatweb2
# _whatweb2 — Andrew Horton urbanadventurer Brendan Coles whatweb2 CLI command-line frontend wrapping the WhatWeb next-generation web scanner identifying web technologies content management systems CMS blogging-platforms statistic-analytics-packages JavaScript-libraries web-servers embedded-devices open-source written in Ruby 1800-plus-plugins-Wordpress-Drupal-Joomla-Movable-Type-aggressiveness-1-to-4-stealth-passive-aggressive-heavy URL-targets URL-list-input verbose log-brief log-verbose log-xml log-json log-magic-tree log-mongo log-elastic log-sql log-error log-Errors-out-to-output-log RFC1918-skip-private user-agent (Andrew Horton urbanadventurer Brendan Coles team, Ruby); custom argparse
# upstream: https://github.com/urbanadventurer/WhatWeb

_whatweb2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files' \
        '--input-file=+[file]:file:_files' \
        '-a+[aggression level]:l:(1 2 3 4)' \
        '--aggression=+[l]:l:(1 2 3 4)' \
        '-l[list plugins]' \
        '--list-plugins[list plugins]' \
        '-L[plugin info]' \
        '--info-plugins=+[search]:str:' \
        '-p+[plugins]:str:' \
        '--plugins=+[plugins]:str:' \
        '-x[run grepable plugins]' \
        '--grep=+[regex]:str:' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-U+[user-agent]:str:' \
        '--user-agent=+[ua]:str:' \
        '-c+[cookie]:str:' \
        '--cookie=+[c]:str:' \
        '-H+[header]:str:' \
        '*-H+[header]:str:' \
        '--header=+[hdr]:str:' \
        '--proxy=+[host:port]:str:' \
        '--proxy-user=+[user:password]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--colour=+[c]:c:(auto always never)' \
        '--color=+[c]:c:(auto always never)' \
        '--max-redirects=+[N]:n:' \
        '--max-threads=+[N]:n:' \
        '-t+[threads]:n:' \
        '--open-timeout=+[sec]:n:' \
        '--read-timeout=+[sec]:n:' \
        '--retries=+[N]:n:' \
        '--wait=+[sec]:n:' \
        '--log-brief=+[file]:file:_files' \
        '--log-verbose=+[file]:file:_files' \
        '--log-xml=+[file]:file:_files -g "*.xml"' \
        '--log-json=+[file]:file:_files -g "*.json"' \
        '--log-json-verbose=+[file]:file:_files -g "*.json"' \
        '--log-magictree=+[file]:file:_files' \
        '--log-mongo-database=+[name]:str:' \
        '--log-elastic-url=+[url]:str:' \
        '--log-elastic-index=+[name]:str:' \
        '--log-sql=+[file]:file:_files' \
        '--log-sql-create=+[file]:file:_files' \
        '--log-errors=+[file]:file:_files' \
        '--no-follow-redirect[no follow redirect]' \
        '--no-errors[suppress errors]' \
        '--custom-plugin=+[plugin]:str:' \
        '--no-cache[no cache]' \
        '--cache-ttl=+[sec]:n:' \
        '*:target:'
}

_whatweb2 "$@"
