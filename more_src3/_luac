#compdef luac luac5.4 luac5.3 luac5.2 luac5.1
# Documentation: luac usage
# Source: Lua luac — Lua bytecode compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-l[list (use -l -l for full listing)]' \
    '-o+[output filename (default luac.out)]:file:_files' \
    '-p[parse only (no output)]' \
    '-s[strip debug information]' \
    '(- *)-v[show version information]' \
    '*:Lua source file:_files -g "*.lua"' \
    && ret=0

return ret
