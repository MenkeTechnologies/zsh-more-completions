#compdef ImageSetStatistics
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ImageSetStatistics.cxx — voxel-wise statistics across an image set (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:controlslist.txt:_files -g "*.txt"' \
    '3:outimage.nii:_files -g "*.{nii,nii.gz}"' \
    '4:whichstat:_default' \
    '5::roi.nii:_files -g "*.{nii,nii.gz}"' \
    '6::imagelist2forsimilarityweightedstats.txt:_files -g "*.txt"' \
    && ret=0

return ret
