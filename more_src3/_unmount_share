#compdef unmount_share
# Documentation: none found (user shell function, not a system tool)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: user-local helper function from Alby11/dotfiles_linux that lists mount points under ~/mnt; not a system binary.
# vim: filetype=zsh

_unmount_share() {
    local -a mount_points
    local cur

    cur="${words[CURRENT]}"

    # Generate the list of mounted directories
    mount_points=(${HOME}/mnt/*/*(N:t))

    # Apply completion
    if (( ${#mount_points} )); then
        _describe 'mount point' mount_points -W "${HOME}/mnt" -- $cur
    else
        _message 'no mounted shares to unmount'
    fi
}

_unmount_share
