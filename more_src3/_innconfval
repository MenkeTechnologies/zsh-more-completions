#compdef innconfval
# Documentation: man innconfval(8)
# Source: InterNetNews/inn frontends/innconfval.c — print inn.conf values (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[check syntax of configuration file]' \
    '-f+[configuration file to read]:file:_files' \
    '-F+[which config to read]:config:(inn.conf inn-secrets.conf)' \
    '-i+[alternate inn.conf path]:file:_files' \
    '(-p -s -t)-p[Perl quoting]' \
    '(-p -s -t)-s[shell quoting]' \
    '(-p -s -t)-t[Tcl quoting]' \
    '-v[print version]' \
    '*:parameter:_default' \
    && ret=0

return ret
