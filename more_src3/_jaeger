#compdef jaeger
# Documentation: https://www.jaegertracing.io/docs/2.9/deployment/configuration/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Jaeger v2 single binary (OpenTelemetry Collector based). Configured
# entirely via a YAML config file; the prior file's v1-component flags
# (--collector.* / --query.* / --span-storage.type / --es.* /
# --cassandra.* / --processor.* / --reporter.*) do not exist on the v2
# `jaeger` binary and were removed.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--config=[YAML configuration file or URI]:config:_files -g "*.(yml|yaml)(-.)"' \
  '*--set=[override a config value (path=value)]:override:' \
  '--feature-gates=[enable/disable feature gates (comma-separated)]:gates:' && ret=0
return ret
