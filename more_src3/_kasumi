#compdef kasumi
# Documentation: https://manpages.debian.org/bookworm/kasumi/kasumi.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm kasumi(1) manpage. GTK GUI; CLI selects
# launch mode.
# Removed from prior file: bogus man.archlinux.org search URL.

# kasumi: Anthy personal dictionary editor (GTK)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-a --add -e --exclusive)'{-m,--manage}'[run in manage mode]' \
  '(-m --manage -e --exclusive)'{-a,--add}'[run in add mode]' \
  '(-m --manage -a --add)'{-e,--exclusive}'[run in exclusive mode]' \
  '--sound=[sound value (add mode)]:value:' \
  '--spelling=[spelling value (add mode)]:value:' \
  '--wordclass=[word class (add mode)]:class:' \
  '(-i --import)'{-i,--import}'[import selected text as spelling]' \
  '(-I --ignore)'{-I,--ignore}'[ignore selected text]' \
  '(-E --eucjp)'{-E,--eucjp}'[use EUC-JP encoding for dictionary]' && ret=0
return ret
