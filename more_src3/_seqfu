#compdef seqfu sfu
# Documentation: https://github.com/telatin/seqfu2
# Source: telatin/seqfu2 src/sfu.nim — sequence FASTX utilities (Nim).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _seqfu_cmds
_seqfu_cmds=(
    'cat:concatenate FASTA/FASTQ files'
    'check:check FASTQ file for errors'
    'count:count reads'
    'bases:count bases in FASTA/FASTQ files'
    'stats:sequence statistics'
    'list:list sequences (experimental)'
    'sort:sort sequences'
    'qual:quality histogram'
    'view:view sequences with colored quality and oligo matches'
    'less:interactive viewer for sequences (like less)'
    'grep:select sequences with patterns'
    'head:print first sequences'
    'tail:view last sequences'
    'metadata:print metadata'
    'trim:trim FASTQ sequences based on quality'
    'orf:extract ORFs from nucleotide sequences'
    'tofasta:convert multiple formats to FASTA'
    'subtract:print sequences absent from another file'
    'interleave:interleave FASTQ pairs'
    'deinterleave:deinterleave FASTQ pairs'
    'derep:dereplicate sequences'
    'rc:reverse complement strings or files'
    'tab:tabulate reads to TSV (and back)'
    'tabcheck:validate TSV/CSV field consistency'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'seqfu command' _seqfu_cmds && ret=0
        ;;
esac

return ret
