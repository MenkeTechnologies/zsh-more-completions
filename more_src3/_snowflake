#compdef snowflake snowflake-client snowflake-server snowflake-broker snowflake-proxy
# _snowflake — Tor Project snowflake pluggable transport CLI for the WebRTC-based censorship circumvention proxy connecting client to volunteer proxy to bridge server using ICE STUN candidates (torproject team, Go); flag
# upstream: https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/snowflake

_snowflake() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-version[show version]' \
        '-ice=+[ice servers csv]:str:' \
        '--ice=+[ice servers csv]:str:' \
        '-url=+[broker url]:str:' \
        '--url=+[broker url]:str:' \
        '-front=+[front domain]:str:' \
        '--front=+[front domain]:str:' \
        '-log=+[file]:file:_files' \
        '--log=+[file]:file:_files' \
        '-keep-local-addresses[keep local addrs]' \
        '-unsafe-logging[unsafe logging]' \
        '-utls-nosni[no SNI]' \
        '-utls-imitate=+[fingerprint]:f:(HelloChrome HelloFirefox HelloIOS HelloRandomized)' \
        '-max=+[N max clients]:n:' \
        '--max=+[N max clients]:n:' \
        '-capacity=+[N capacity]:n:' \
        '-broker=+[broker URL]:str:' \
        '-relay=+[relay URL]:str:' \
        '-stun=+[stun servers csv]:str:' \
        '-poll-interval=+[d]:str:' \
        '-disable-tls[disable TLS]' \
        '-num-proxies=+[N]:n:' \
        '-acme-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '-acme-key=+[file]:file:_files -g "*.pem *.key"' \
        '-acme-hostnames=+[csv]:str:' \
        '-acme-email=+[email]:str:' \
        '-bridge-fingerprint=+[hex]:str:' \
        '-ephemeral-ports-range=+[low-high]:str:'
}

_snowflake "$@"
