#compdef zita-j2n zita-n2j
# _zita-njbridge — JACK clients to transport multichannel audio over local network (Fons Adriaensen)
# upstream: https://kokkinizita.linuxaudio.org/linuxaudio/index.html
# Flags from zita-j2n(1) / zita-n2j(1) man pages.

_zita-njbridge() {
    _arguments \
        '(- *)--help[show help]' \
        '--jname[JACK client name (default zita-j2n / zita-n2j)]:name:' \
        '--jserv[JACK server to connect to]:server:' \
        '--ipv4[use IPv4 only]' \
        '--ipv6[use IPv6 only]' \
        '--chan[number / list of channels]:channels:' \
        '--16bit[16-bit signed integer samples]' \
        '--24bit[24-bit signed integer samples (default for j2n)]' \
        '--float[32-bit float samples (JACK internal format)]' \
        '--mtu[path MTU (default 1500)]:mtu:' \
        '--hops[max multicast hops (default 1)]:hops:' \
        '--buff[playout buffer time in ms]:ms:' \
        '--filt[receiver filter delay in ms]:ms:' \
        '--info[print received stream info and exit]' \
        '*:address:port:'
}

_zita-njbridge "$@"
