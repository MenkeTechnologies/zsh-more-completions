#compdef shortwave
# _shortwave — Shortwave internet radio (GNOME, Rust); browse + play streams from radio-browser.info
# upstream: https://gitlab.gnome.org/World/Shortwave

_shortwave() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '--debug[debug log]' \
        '*:stream URL:_urls'
}

_shortwave "$@"
