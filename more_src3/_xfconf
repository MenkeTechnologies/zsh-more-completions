#compdef xfconf xfconfd
# _xfconf — Xfce4 xfconfd config daemon CLI alias (Xfce.org, C); custom argparse
# upstream: https://gitlab.xfce.org/xfce/xfconf

_xfconf() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--daemon[run as daemon]' \
        '-d[run as daemon]' \
        '--no-daemon[run in foreground]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--syslog[log to syslog]' \
        '*:arg:'
}

_xfconf "$@"
