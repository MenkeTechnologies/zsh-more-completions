#compdef hadoop-streaming
# _hadoop-streaming — Apache Hadoop streaming wrapper (runs arbitrary executables / scripts as MapReduce jobs via the streaming jar; -input HDFS input path, -output HDFS output path, -mapper command, -reducer command, -file ship side-files, -archives, -inputformat, -outputformat, -cmdenv KEY=VAL, -numReduceTasks, -combiner)
# upstream: https://github.com/apache/hadoop (tools/hadoop-streaming)
# Flags from Apache Hadoop hadoop-streaming src/main/java/org/apache/hadoop/streaming/StreamJob.java on tip.

_hadoop-streaming() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-input+[HDFS input]:path:' \
        '-output+[HDFS output]:path:' \
        '-mapper+[mapper command]:command:' \
        '-reducer+[reducer command]:command:' \
        '-combiner+[combiner command]:command:' \
        '*-file+[ship file]:file:_files' \
        '*-files+[ship files (comma)]:files:' \
        '*-archives+[archives]:archives:' \
        '-inputformat+[input format class]:class:' \
        '-outputformat+[output format class]:class:' \
        '*-cmdenv+[KEY=VAL]:env:' \
        '*-D+[KEY=VAL]:property:' \
        '*-jobconf+[KEY=VAL]:property:' \
        '-numReduceTasks+[reducer count]:n:' \
        '-mapdebug+[debug script]:script:_files' \
        '-reducedebug+[debug script]:script:_files' \
        '-lazyOutput[lazy output]' \
        '-verbose[verbose]' \
        '-info[print info]' \
        '*-libjars+[ship jars (comma)]:jars:' \
        '*-conf+[config file]:file:_files'
}

_hadoop-streaming "$@"
