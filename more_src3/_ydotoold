#compdef ydotoold
# Documentation: https://github.com/ReimuNotMoe/ydotool/blob/master/manpage/ydotoold.8.scd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --socket-path)'{-p+,--socket-path=}'[set socket path]:path:_files' \
  '(-P --socket-perm)'{-P+,--socket-perm=}'[set socket permission]:perm:' \
  '(-o --socket-own)'{-o+,--socket-own=}'[socket ownership UID:GID]:owner:' \
  '(-m --mouse-off)'{-m,--mouse-off}'[disable mouse (EV_REL)]' \
  '(-k --keyboard-off)'{-k,--keyboard-off}'[disable keyboard (EV_KEY)]' \
  '(-T --touch-on)'{-T,--touch-on}'[enable touchscreen (EV_ABS)]' && ret=0

return ret
