#compdef zprint
# Documentation: zprint -h (macOS 26)
# Source: display Mach zone allocator statistics.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-w[show wasted memory for each zone]' \
    '-s[sort zones by wasted memory]' \
    '(-C)-c[display output formatted in columns (default)]' \
    '(-c)-C[disable column-formatted output]' \
    '(-h)-H[hide column names]' \
    '(-T)-t[show total size of allocations over life of the zone]' \
    '(-t)-T[disable total-size display]' \
    '(-D)-d[show deltas over time]' \
    '(-d)-D[disable delta display]' \
    '(-L)-l[display wired memory info (default)]' \
    '(-l)-L[do not show wired memory info]' \
    '-k[coalesce all kalloc zones for specific size]' \
    '-kt[coalesce kalloc type/kext zones with default]' \
    '-kd[coalesce kalloc data zones with default]' \
    '1:zone name:' \
    && ret=0

return ret
