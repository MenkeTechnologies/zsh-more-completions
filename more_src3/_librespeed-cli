#compdef librespeed-cli
# Documentation: https://github.com/librespeed/speedtest-cli
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-4 --ipv4)'{-4,--ipv4}'[force IPv4]' \
  '(-6 --ipv6)'{-6,--ipv6}'[force IPv6]' \
  '--no-download[skip download test]' \
  '--no-upload[skip upload test]' \
  '--no-icmp[disable ICMP ping]' \
  '--concurrent=[concurrent HTTP requests]:n:' \
  '--bytes[display values in bytes instead of bits]' \
  '--mebibytes[use 1024 bytes per kilobyte]' \
  '--distance=[distance unit in ISP info]:unit:(mi km NM)' \
  '--share[generate share URL]' \
  '--simple[terse output]' \
  '--csv[CSV output]' \
  '--csv-delimiter=[CSV delimiter]:char:' \
  '--csv-header[print CSV header row]' \
  '--json[JSON output]' \
  '--list[list servers]' \
  '*--server=[server id (repeatable)]:id:' \
  '*--exclude=[exclude server id]:id:' \
  '--server-json=[remote server list URL]:url:' \
  '--local-json=[local server list file]:file:_files' \
  '--source=[source IP address]:ip:' \
  '--interface=[bind interface]:iface:_net_interfaces' \
  '--timeout=[HTTP timeout in seconds]:seconds:' \
  '--duration=[upload/download duration in seconds]:seconds:' \
  '--chunks=[chunks to download from server]:n:' \
  '--upload-size=[upload payload size in KiB]:n:' \
  '--secure[use HTTPS]' \
  '--ca-cert=[CA cert]:file:_files' \
  '--skip-cert-verify[skip TLS verification]' \
  '--no-pre-allocate[disable upload buffer pre-allocation]' \
  '--telemetry-json=[telemetry config file]:file:_files' \
  '--telemetry-level=[telemetry level]:level:(disabled basic full debug)' \
  '--telemetry-server=[telemetry server URL]:url:' \
  '--telemetry-path=[telemetry upload path]:path:' \
  '--telemetry-share=[telemetry share path]:path:' \
  '--telemetry-extra=[extra telemetry message]:msg:' && ret=0

return ret
