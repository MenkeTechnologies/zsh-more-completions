#compdef ubi
# Documentation: https://github.com/houseabsolute/ubi
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ubi (Universal Binary Installer)

_arguments -s -S \
  '(-p --project)'{-p,--project}'[project to install (owner/repo)]:project:' \
  '(-t --tag)'{-t,--tag}'[release version to download]:tag:' \
  '(-u --url)'{-u,--url}'[direct download URL]:url:_urls' \
  '(-i --in)'{-i,--in}'[directory to install into]:dir:_files -/' \
  '(-e --exe)'{-e,--exe}'[filename to extract from archive]:name:' \
  '(-m --matching)'{-m,--matching}'[filter assets by substring]:pattern:' \
  '(-r --matching-regex)'{-r,--matching-regex}'[filter assets by regex]:regex:' \
  '--min-age-days[minimum age in days for releases]:days:' \
  '--rename-exe[rename installed executable]:name:' \
  '--extract-all[extract entire archive]' \
  '--forge[forge type]:forge:(github gitlab)' \
  '--api-base-url[base URL for forge API]:url:_urls' \
  '--self-upgrade[upgrade ubi itself]' \
  '(-q --quiet)'{-q,--quiet}'[suppress most output]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
