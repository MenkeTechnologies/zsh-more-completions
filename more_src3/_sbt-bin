#compdef sbt
# _sbt-bin — Scala Build Tool (Lightbend/Scala, Scala); de facto Scala build system
# upstream: https://github.com/sbt/sbt

_sbt-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-w[wait for changes]' \
        '--warn[warn level]' \
        '-W+[warn level]:level:(error warn info debug)' \
        '--error[error level]' \
        '-info[info level]' \
        '-color+[color]:when:(true false auto)' \
        '--color+[color]:when:(true false auto)' \
        '-no-colors[no colors]' \
        '-supershell+[supershell]:val:(auto true false)' \
        '--supershell+[supershell]:val:(auto true false)' \
        '-script+[script file]:file:_files' \
        '--script+[script file]:file:_files' \
        '-sbt-create[sbt create]' \
        '--sbt-create[sbt create]' \
        '-sbt-dir+[sbt dir]:dir:_files -/' \
        '--sbt-dir+[sbt dir]:dir:_files -/' \
        '-sbt-boot+[sbt boot dir]:dir:_files -/' \
        '--sbt-boot+[sbt boot dir]:dir:_files -/' \
        '-ivy+[ivy dir]:dir:_files -/' \
        '--ivy+[ivy dir]:dir:_files -/' \
        '-J+[JVM flag]:flag:' \
        '-D+[system property]:KEY=VAL:' \
        '-Dsbt.+[sbt property]:KEY=VAL:' \
        '-mem+[heap MB]:n:' \
        '--mem+[heap MB]:n:' \
        '-S+[scala args]:str:' \
        '-sbt-version+[sbt version]:str:' \
        '--sbt-version+[sbt version]:str:' \
        '-sbt-jar+[sbt jar]:file:_files' \
        '--sbt-jar+[sbt jar]:file:_files' \
        '-sbt-launch-dir+[sbt launch dir]:dir:_files -/' \
        '--sbt-launch-dir+[sbt launch dir]:dir:_files -/' \
        '-batch[batch mode]' \
        '--batch[batch mode]' \
        '-no-colors[no colors]' \
        '-no-share[no share]' \
        '-no-global[no global]' \
        '-jvm-debug+[jvm debug port]:port:' \
        '--jvm-debug+[jvm debug port]:port:' \
        '*:task:'
}

_sbt-bin "$@"
