#compdef sfsmooth
# Documentation: http://www.ahay.org/RSF/sfsmooth.html
# Source: ahay/src system/generic/Msmooth.c — apply triangle (or box) smoothing on each axis.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'repeat=[repeat the smoothing N times]: :_default' \
    'rect1=[smoothing radius, 1st axis]: :_default' \
    'rect2=[smoothing radius, 2nd axis]: :_default' \
    'rect3=[smoothing radius, 3rd axis]: :_default' \
    'diff1=[(y/n) differentiate on 1st axis]: :(y n)' \
    'diff2=[(y/n) differentiate on 2nd axis]: :(y n)' \
    'diff3=[(y/n) differentiate on 3rd axis]: :(y n)' \
    'box1=[(y/n) box (not triangle) smoothing on 1st axis]: :(y n)' \
    'box2=[(y/n) box (not triangle) smoothing on 2nd axis]: :(y n)' \
    'box3=[(y/n) box (not triangle) smoothing on 3rd axis]: :(y n)' \
    'adj=[(y/n) run in adjoint mode]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
