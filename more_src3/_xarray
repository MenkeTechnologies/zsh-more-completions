#compdef xarray xrcli xarray-cli
# _xarray — pydata xarray N-D labeled array and dataset toolkit Python library CLI for inspect convert merge (pydata team, Python); argparse
# upstream: https://github.com/pydata/xarray

_xarray() {
    local -a sub=(
        'info:show dataset info'
        'show:show dataset summary'
        'meta:show metadata'
        'subset:subset a dataset'
        'merge:merge datasets'
        'concat:concatenate datasets'
        'to-netcdf:convert to netCDF'
        'to-zarr:convert to Zarr'
        'to-csv:convert to CSV'
        'to-parquet:convert to Parquet'
        'rechunk:rechunk a dataset'
        'plot:plot a variable'
        'mean:compute mean'
        'sum:compute sum'
        'max:compute maximum'
        'min:compute minimum'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--engine=+[engine]:e:(netcdf4 scipy h5netcdf pynio cfgrib pseudonetcdf zarr cdms2 store rasterio)' \
        '--chunks=+[chunks]:str:' \
        '--decode-cf=+[bool]:b:(true false)' \
        '--decode-times=+[bool]:b:(true false)' \
        '--decode-coords=+[bool]:b:(true false)' \
        '--mask-and-scale=+[bool]:b:(true false)' \
        '--use-cftime=+[bool]:b:(true false)' \
        '--compat=+[compat]:c:(broadcast_equals equals identical no_conflicts override)' \
        '--combine=+[combine]:c:(by_coords nested)' \
        '--parallel=+[bool]:b:(true false)' \
        '--no-color[disable color]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xarray subcommand' sub ;;
        args)
            case $words[1] in
                info|show|meta|subset|to-netcdf|to-zarr|to-csv|to-parquet|rechunk|mean|sum|max|min|plot) _arguments \
                    '--variable=+[variable name]:str:' \
                    '-V+[variable name]:str:' \
                    '--dimension=+[dim:slice]:str:' \
                    '-d+[dim:slice]:str:' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '*:file:_files -g "*.nc *.nc4 *.h5 *.zarr *.cdf *.grib *.parquet *.csv"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_xarray "$@"
