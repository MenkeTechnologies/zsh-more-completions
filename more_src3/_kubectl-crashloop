#compdef kubectl-crashloop
# Documentation: https://github.com/rohankaran/kubectl-crashloop
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[override namespace from kubeconfig context]:namespace:' \
  '--context=[kubeconfig context name]:context:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '(-c --container)'{-c+,--container=}'[limit output to one container]:container:' \
  '--tail=[previous log lines fetched per container]:lines:' \
  '--limit=[cap the number of crash entries shown]:count:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json)' \
  '--color=[ANSI color output]:when:(auto always never)' \
  '1:command or pod:->main' \
  '*::arg:_default' && ret=0

case $state in
  main)
    local -a cmds=(
      'demo:print a stable non-cluster report for screenshots'
      'version:print build metadata'
    )
    _describe -t commands 'kubectl-crashloop command' cmds && ret=0
    ;;
esac

return ret
