#compdef socat
# Documentation: man socat(1) on socat 1.8.x
# Source: socat (Multipurpose relay / SOcket CAT) — bidirectional address-to-address byte stream relay.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[print version and feature info]' \
    '(- *)-h[short help (command-line + address types)]' \
    '(- *)-hh[help + short names of all address options]' \
    '(- *)-hhh[help + all address-option names]' \
    '*-d[increase log verbosity (one step per repeat)]' \
    '-d0[only fatal/error messages]' \
    '-D[log fd info before transfer phase]' \
    '--experimental[enable not-well-tested / future-change features]' \
    '-ly+[log to syslog (optional facility, default daemon)]::facility:' \
    '-lf+[log to file instead of stderr]:logfile:_files' \
    '-ls[log to stderr (default)]' \
    '-lp+[override program name in error messages]:progname:' \
    '-lu[microsecond timestamp in error messages]' \
    '-lm+[mixed log mode (stderr at start, syslog at transfer)]::facility:' \
    '-lh[add hostname to log messages]' \
    '-v[also log transferred data to stderr (text)]' \
    '-x[also log transferred data to stderr (hex)]' \
    '-r+[dump left-to-right raw stream to file]:file:_files' \
    '-R+[dump right-to-left raw stream to file]:file:_files' \
    '-b+[data-transfer block size]:size:' \
    '-s[continue on non-fatal errors]' \
    '-S+[set of caught signals (bitmap)]:bitmap:' \
    '-t+[shutdown-write-side timeout after EOF (s)]:timeval:' \
    '-T+[total inactivity timeout (s; <0 = infinite)]:timeval:' \
    '(-u -U)-u[unidirectional left→right]' \
    '(-u -U)-U[unidirectional right→left]' \
    '*:address:' \
    && ret=0

return ret
