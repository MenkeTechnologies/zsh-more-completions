#compdef kontrol
# Documentation: https://github.com/runtimeverification/kontrol (src/kontrol/__main__.py)
# Reference accessed: 2026-05-29
# Kontrol — Foundry+K formal verification for Solidity smart contracts.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'version:show Kontrol version'
  'init:initialize a new Kontrol project'
  'build:compile the project using K framework (make K definitions from Foundry)'
  'clean:remove build artifacts'
  'prove:execute formal proofs for test cases'
  'load-state:load recorded state dumps or diffs for initialization'
  'setup-storage:generate storage layout configuration'
  'list:show available tests and proof statistics'
  'show:display proof configuration details'
  'view-kcfg:visualize the K configuration graph (KCFG visualizer)'
  'minimize-proof:reduce proof complexity'
  'refute-node:mark a proof node as refuted'
  'unrefute-node:remove refutation status from a proof node'
  'split-node:divide a proof node on a branch condition'
  'remove-node:delete a proof node'
  'simplify-node:reduce a proof node term complexity'
  'step-node:execute a single step in proof execution'
  'merge-nodes:combine multiple proof nodes'
  'section-edge:partition proof edges into sections'
  'get-model:retrieve SMT solver model output'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-h --help)'{-h,--help}'[show help]'
  '--verbose[verbose output]'
  '--debug[enable debug output]'
  '--bug-report[bundle inputs into a bug-report zip]'
  '--config-file=[Kontrol/foundry.toml config file]:file:_files -g "*.toml"'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'kontrol subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          $_global \
          '--regen[regenerate the K module]' \
          '--rekompile[rekompile (re-run kompile)]' \
          '--require=[require additional K source file]:file:_files' \
          '--metadata[include metadata]' \
          '--no-metadata[exclude metadata]' \
          '--enum-constraints[enable enum constraints]' \
          '*--target=[K backend target]:backend:(haskell maude llvm)' \
          '*-I+[K include path]:dir:_directories' && ret=0
        ;;
      prove)
        _arguments \
          $_global \
          '*--match-test=[match tests by regex pattern]:pattern:' \
          '--test=[fully-qualified test name]:test:' \
          '--reinit[reinitialize proof from scratch]' \
          '--no-simplify-init[skip simplify-init pass]' \
          '--max-depth=[max symbolic execution depth]:n:' \
          '--max-iterations=[max iterations]:n:' \
          '--bug-report[bundle inputs for bug report]' \
          '--use-booster[use booster backend for faster proofs]' \
          '--no-booster[disable booster backend]' \
          '--smt-timeout=[SMT solver timeout in ms]:ms:' \
          '--smt-retry-limit=[SMT retry limit]:n:' \
          '--workers=[number of parallel workers]:n:' \
          '--break-on-calls[break execution on function calls]' \
          '--no-break-on-calls[skip breaking on function calls]' \
          '--break-on-storage[break execution on storage reads/writes]' \
          '--break-on-jumpi[break execution on conditional jumps]' \
          '--break-every-step[break on every step]' \
          '--auto-abstract-gas[auto-abstract gas usage]' \
          '--use-gas[track gas consumption]' \
          '--no-use-gas[ignore gas consumption]' \
          '--storage-condition=[storage condition mode]:mode:(checked unchecked)' \
          '--counterexample-info[print counterexample info on failure]' \
          '--xml-test-report[emit JUnit XML test report]' \
          '--minimize-proofs[minimize proofs while proving]' \
          '--include-summaries=[paths of proof summaries to include]:path:_files' \
          '--with-non-general-state[disable non-general state pruning]' \
          '--enum-constraints[enable enum constraints]' \
          '--symbolic-immutables[treat immutables as symbolic]' \
          '--cse[enable common-subexpression elimination]' \
          '--hide-status-bar[hide proof status bar]' \
          '--max-frontier-parallel=[parallel frontier exploration size]:n:' && ret=0
        ;;
      show)
        _arguments \
          $_global \
          '--test=[test name to show]:test:' \
          '--version=[proof version]:n:' \
          '--node-deltas=[show only node deltas]' \
          '--failure-info[include failure info]' \
          '--counterexample-info[include counterexample info]' \
          '--to-kevm-claims[serialize as KEVM claims]' \
          '--to-module-name=[K module name for serialization]:name:' \
          '--minimize[minimize before showing]' \
          '--pending[only show pending nodes]' \
          '--failing[only show failing nodes]' && ret=0
        ;;
      view-kcfg)
        _arguments \
          $_global \
          '--test=[test name to view]:test:' \
          '--version=[proof version]:n:' && ret=0
        ;;
      list)
        _arguments \
          $_global \
          '--proof-dir=[directory containing proofs]:dir:_directories' && ret=0
        ;;
      load-state)
        _arguments \
          $_global \
          '--name=[name of the loaded state]:name:' \
          '--from-state-diff[load from state diff (vs full dump)]' \
          ':accesses file (JSON):_files -g "*.json"' && ret=0
        ;;
      setup-storage)
        _arguments \
          $_global \
          '--contract-name=[contract whose storage to set up]:name:' && ret=0
        ;;
      init)
        _arguments \
          $_global \
          '--project-root=[project root directory]:dir:_directories' \
          ':project name:' && ret=0
        ;;
      clean)
        _arguments \
          $_global \
          '--proof-dir=[directory containing proofs]:dir:_directories' && ret=0
        ;;
      refute-node|unrefute-node|remove-node|simplify-node|step-node|split-node)
        _arguments \
          $_global \
          '--test=[test name]:test:' \
          ':node id:' && ret=0
        ;;
      merge-nodes)
        _arguments \
          $_global \
          '--test=[test name]:test:' \
          '*--node-id=[node id to merge]:id:' && ret=0
        ;;
      section-edge)
        _arguments \
          $_global \
          '--test=[test name]:test:' \
          ':source node:' \
          ':target node:' \
          '--sections=[number of sections]:n:' && ret=0
        ;;
      get-model)
        _arguments \
          $_global \
          '--test=[test name]:test:' \
          ':node id:' && ret=0
        ;;
      minimize-proof)
        _arguments \
          $_global \
          '--test=[test name]:test:' && ret=0
        ;;
    esac
    ;;
esac

return ret
