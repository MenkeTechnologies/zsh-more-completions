#compdef sdl2-config
# Documentation: https://github.com/libsdl-org/SDL/blob/SDL2/sdl2-config.in
# Reference accessed: 2026-05-21
# Verified: upstream sdl2-config.in usage string and case statement.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--cflags[print C compiler flags]' \
  '--libs[print linker flags]' \
  '--static-libs[print linker flags for static linking]' && ret=0

return ret
