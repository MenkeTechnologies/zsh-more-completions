#compdef tiffdump
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/tiffdump.c — dump TIFF directory/tag structure for low-level inspection (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[print values in hex]' \
    '-o+[seek to file offset]:offset:_default' \
    '-m+[max items per field]:maxitems:_default' \
    '*:tiff files:_files -g "*.{tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
