#compdef linkerd-cni
# _linkerd-cni — Linkerd CNI plugin (chained CNI binary that programs iptables/nftables redirect rules for injected pods, replacing the proxy-init initContainer)
# upstream: https://github.com/linkerd/linkerd2-proxy-init
# Source: cni-plugin/main.go on tip; runtime configuration comes from the CNI conflist JSON (CNI_COMMAND/CNI_NETNS/CNI_IFNAME/CNI_ARGS/CNI_CONTAINERID env vars) supplied by kubelet, not from CLI flags.

_linkerd-cni() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_linkerd-cni "$@"
