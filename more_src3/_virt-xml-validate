#compdef virt-xml-validate
# _virt-xml-validate — libvirt virt-xml-validate (validate a libvirt XML file against its bundled RelaxNG schema; positional argument is the XML filename, optional second positional is the schema type override (e.g. domain network storagepool capabilities))
# upstream: https://gitlab.com/libvirt/libvirt (tools/virt-xml-validate.in)
# Flags from libvirt tools/virt-xml-validate.in on tip.

_virt-xml-validate() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '1:xml file:_files -g "*.xml"' \
        '2:schema:(domain domainsnapshot network networkport storagepool storagevol nodedev secret nwfilter nwfilterbinding interface capabilities domaincaps storagepoolcaps cpu)'
}

_virt-xml-validate "$@"
