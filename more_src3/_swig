#compdef swig
# Documentation: swig -help
# Source: generate scripting language wrappers for C/C++ code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '(-c++ -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-csharp[generate C# wrappers]' \
    '(-csharp -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-d[generate D wrappers]' \
    '(-csharp -d -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-go[generate Go wrappers]' \
    '(-csharp -d -go -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-guile[generate Guile wrappers]' \
    '(-csharp -d -go -guile -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-java[generate Java wrappers]' \
    '(-csharp -d -go -guile -java -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-javascript[generate Javascript wrappers]' \
    '(-csharp -d -go -guile -java -javascript -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-lua[generate Lua wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-octave[generate Octave wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -php7 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-perl5[generate Perl 5 wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -python -r -ruby -scilab -tcl8 -xml -c -ocaml)-php7[generate PHP 8+ wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -r -ruby -scilab -tcl8 -xml -c -ocaml)-python[generate Python wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -ruby -scilab -tcl8 -xml -c -ocaml)-r[generate R wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -scilab -tcl8 -xml -c -ocaml)-ruby[generate Ruby wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -tcl8 -xml -c -ocaml)-scilab[generate Scilab wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -xml -c -ocaml)-tcl8[generate Tcl 8 wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -c -ocaml)-xml[generate XML wrappers]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -ocaml)-c[generate C wrappers (experimental)]' \
    '(-csharp -d -go -guile -java -javascript -lua -octave -perl5 -php7 -python -r -ruby -scilab -tcl8 -xml -c)-ocaml[generate OCaml wrappers (experimental)]' \
    '-c++[enable C++ processing]' \
    '-addextern[add extra extern declarations]' \
    '-co+[check file out of SWIG library]:file:_files' \
    '-copyctor[generate copy constructors]' \
    '-cpperraswarn[treat #error as #warning (default)]' \
    '-cppext+[extension for generated C++ files]:ext:' \
    '-copyright[show copyright notices]' \
    '*-D+[define preprocessor symbol]:symbol[=value]:' \
    '-E[preprocess only, no wrapper]' \
    '-external-runtime[export SWIG runtime stack]:file:_files' \
    '-fcompact[compact mode]' \
    '-features+[set feature list]:list:' \
    '-Fmicrosoft[Visual Studio file/line format]' \
    '-Fstandard[Unix file/line format]' \
    '-help[show help]' \
    '-includeall[follow all #include statements]' \
    '*-I+[add include directory]:dir:_files -/' \
    '-ignoremissing[ignore missing include files]' \
    '*-l+[include SWI library file]:file:_files' \
    '-M[list all dependencies]' \
    '-MM[list dependencies excluding system files]' \
    '-MD[generate makefile dependency rules]' \
    '-MMD[like -MD without system files]' \
    '-MF+[write dependencies to file]:file:_files' \
    '-MT+[set target for dependency rule]:target:' \
    '-module+[set module name]:name:' \
    '-nopreprocess[skip preprocessor]' \
    '-O[enable common optimizations]' \
    '-o+[output file]:file:_files' \
    '-oh+[output C header file]:file:_files -g "*.(h|hpp|hxx)"' \
    '-outdir+[output dir for language-specific files]:dir:_files -/' \
    '-outcurrentdir[set output dir to CWD]' \
    '-pcreversion[show PCRE version]' \
    '-small[generate small wrappers]' \
    '-swiglib[show SWIG library directory]' \
    '-thread[wrap with threading support]' \
    '-v[verbose mode]' \
    '-W+[turn on/off warning suppression]:setting:' \
    '-Wall[remove all warning suppression]' \
    '-Werror[treat warnings as errors]' \
    '-Wextra[adds new warnings]' \
    '*:interface file:_files -g "*.(i|swg)"' \
    && ret=0

return ret
