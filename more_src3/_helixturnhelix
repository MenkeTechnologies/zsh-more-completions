#compdef helixturnhelix
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/helixturnhelix.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# EMBOSS helixturnhelix: identify HTH DNA-binding motifs in protein
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompts]' \
  '-debug[debug]' \
  '-verbose[verbose]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal]' \
  '-die[dying]' \
  '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-mean=[mean score for population]:mean:' \
  '-sdvalue=[SD value for scoring]:sdvalue:' \
  '-minsd=[minimum SD per residue]:minsd:' \
  '-eightyseven[use 1987 weights instead of 1990]' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(motif embl genbank gff excel table feattable gff3 listfile pir simple swiss tagseq)' \
  '*:protein USA:_files' && ret=0
return ret
