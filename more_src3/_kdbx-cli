#compdef kdbx-cli kdbx
# _kdbx-cli — kdbx-cli CLI command-line client for KeePass v2 .kdbx KDBX database files with KDBX 3.1 4.0 encryption providing get set add remove list copy move tag groups attachments search rename merge export keyfile master-password challenge-response YubiKey HMAC integration for password vault workflow (kdbx-cli authors team, Rust); clap
# upstream: https://github.com/keepassxreboot/keepassxc

_kdbx-cli() {
    local -a sub=(
        'list:list entries and groups'
        'show:show entry'
        'add:add new entry'
        'edit:edit existing entry'
        'remove:remove entry'
        'rename:rename entry'
        'move:move entry to group'
        'copy:copy field to clipboard'
        'search:search the database'
        'merge:merge another database'
        'export:export database'
        'import:import from another format'
        'create:create new database'
        'attach:attach a file to entry'
        'detach:detach a file from entry'
        'change-password:change master password'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[database file]:file:_files -g "*.kdbx"' \
        '--database=+[file]:file:_files -g "*.kdbx"' \
        '-k+[keyfile]:file:_files' \
        '--keyfile=+[file]:file:_files' \
        '-Y+[yubikey slot]:n:(1 2)' \
        '--yubikey=+[slot]:n:(1 2)' \
        '--master-password=+[password]:str:' \
        '--read-only[read only]' \
        '-f+[format]:f:(plain json yaml csv xml table)' \
        '--format=+[format]:f:(plain json yaml csv xml table)' \
        '--show-password[show password]' \
        '-c[copy to clipboard]' \
        '--clipboard[copy to clipboard]' \
        '--otp[show TOTP]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kdbx-cli subcommand' sub ;;
        args)
            case $words[1] in
                show|edit|remove|rename|copy|move|attach|detach) _arguments '*:entry path:' ;;
                search) _arguments '*:query:' ;;
                merge|import) _arguments '*:db file:_files -g "*.kdbx *.csv *.xml *.json"' ;;
                export) _arguments '*:output file:_files' ;;
            esac
            ;;
    esac
}

_kdbx-cli "$@"
