#compdef helia-verified-fetch
# _helia-verified-fetch — download IPFS content via @helia/verified-fetch (SgtPooki/helia-verified-fetch-cli)
# upstream: https://github.com/SgtPooki/helia-verified-fetch-cli
# Flags from src/index.ts (yargs).

_helia-verified-fetch() {
    _arguments \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '(-d --data)'{-d+,--data=}'[persistent data/blockstore directory]:dir:_files -/' \
        '(-b --use-bitswap)'{-b,--use-bitswap}'[use bitswap (default true)]' \
        '(-t --use-trustless-gateways)'{-t,--use-trustless-gateways}'[use trustless gateways (default true)]' \
        '*--trustless-gateways=[trustless gateway URLs]:url:' \
        '(-a --accept)'{-a+,--accept=}'[Accept header]:mime:' \
        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
        '--debug=[explicit DEBUG value]:pattern:' \
        '1:resource URL:'
}

_helia-verified-fetch "$@"
