#compdef virt-p2v-make-disk
# _virt-p2v-make-disk — virt-v2v virt-p2v-make-disk (build a bootable virt-p2v(1) USB stick image from the host installation; -o output disk, --arch arch, --inject-ssh-identity inject ssh key, --no-warn-if-partitions, --keep-temp, --skip-rebuild, --boot-uuid override; positional argument is the temporary build directory)
# upstream: https://github.com/libguestfs/virt-v2v (p2v/virt-p2v-make-disk.in)
# Flags from virt-v2v p2v/virt-p2v-make-disk.in on tip.

_virt-p2v-make-disk() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-o+[output disk]:file:_files' \
        '--output+[output disk]:file:_files' \
        '--arch=*[arch]:arch:(x86_64 aarch64 ppc64le s390x)' \
        '--inject-ssh-identity+[ssh identity file]:file:_files' \
        '--no-warn-if-partitions[skip partition warning]' \
        '--keep-temp[keep temp files]' \
        '--skip-rebuild[skip rebuild step]' \
        '--boot-uuid+[boot uuid]:uuid:' \
        '1:temp build dir:_files -/'
}

_virt-p2v-make-disk "$@"
