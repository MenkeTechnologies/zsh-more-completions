#compdef zenstack
# Documentation: https://zenstack.dev/docs/reference/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'generate:run code generation plugins'
  'init:initialize an existing project for ZenStack'
  'info:show installed ZenStack package info'
  'check:check a ZModel schema for syntax/semantic errors'
  'format:format a ZModel schema file'
  'migrate:database migrations'
  'db:database schema management'
  'proxy:start the ZenStack proxy server'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zen command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (generate)
        _arguments \
          '--schema=[ZModel schema file]:file:_files -g "*.zmodel"' \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '(-w --watch)'{-w,--watch}'[watch for changes]' \
          '--lite[generate lite version]' \
          '--lite-only[only generate lite version]' \
          '--silent[suppress non-error output]' && ret=0 ;;
      (migrate)
        local -a migrate_subs=(
          'dev:create and apply migrations'
          'reset:reset database and apply all migrations'
          'deploy:deploy pending migrations'
          'status:check migration status'
          'resolve:resolve deployment migration issues'
        )
        _describe -t mcmds 'migrate subcommand' migrate_subs && ret=0
        _arguments \
          '--schema=[schema file]:file:_files -g "*.zmodel"' \
          '(-n --name)'{-n+,--name=}'[migration name]:name:' \
          '--create-only[create without applying]' \
          '--migrations=[migrations directory]:dir:_files -/' \
          '--force[skip confirmation]' \
          '--applied=[record migration as applied]:migration:' \
          '--rolled-back=[record migration as rolled back]:migration:' \
          '--random-prisma-schema-name[append random UUID]' && ret=0 ;;
      (db)
        local -a db_subs=(
          'push:push schema state to database'
          'pull:introspect and generate schema'
          'seed:seed the database'
        )
        _describe -t dbcmds 'db subcommand' db_subs && ret=0
        _arguments \
          '--schema=[schema file]:file:_files -g "*.zmodel"' \
          '--accept-data-loss[ignore data loss warnings]' \
          '--force-reset[force database reset]' \
          '(-o --output)'{-o+,--output=}'[output path]:path:_files' \
          '--model-casing=[generated model casing]:casing:(pascal camel snake none)' \
          '--field-casing=[generated field casing]:casing:(pascal camel snake none)' \
          '--always-map[add @map / @@map]' \
          '--quote=[quote style]:style:(double single)' \
          '--indent=[indentation level]:n:' \
          '--no-version-check[skip version check]' && ret=0 ;;
      (proxy)
        _arguments \
          '--schema=[schema file]:file:_files -g "*.zmodel"' \
          '(-p --port)'{-p+,--port=}'[server port]:port:' \
          '(-o --output)'{-o+,--output=}'[output directory]:dir:_files -/' \
          '(-d --databaseUrl)'{-d+,--databaseUrl=}'[database URL]:url:' \
          '*'{-l+,--logLevel=}'[query log level]:level:(query info warn error)' \
          '--no-version-check[skip version check]' && ret=0 ;;
      (init|info)
        _arguments '*::path:_files -/' && ret=0 ;;
      (check|format)
        _arguments \
          '--schema=[schema file]:file:_files -g "*.zmodel"' && ret=0 ;;
    esac ;;
esac

return ret
