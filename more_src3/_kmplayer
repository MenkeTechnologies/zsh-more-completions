#compdef kmplayer
# Documentation: https://github.com/KDE/kmplayer/blob/master/src/app/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream src/app/main.cpp — one positional "+[File]" (file/
# URL to open); otherwise KAboutData::setupCommandLine standard set.
# STUB: KDE/Qt standard options plus file/URL positional.

# KMPlayer: KDE media player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '*:file/URL:_files' && ret=0
return ret
