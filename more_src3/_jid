#compdef jid
# Documentation: https://github.com/simeji/jid
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# Zsh completion for jid (JSON incremental digger)

_arguments \
  '-q[output query mode (for jq)]' \
  '-M[monochrome output mode]' \
  '(-h -help)'{-h,-help}'[print help]' \
  '-version[print version and exit]' \
  '1:initial query:' \
  '*:json file:_files -g "*.json"' && return 0
