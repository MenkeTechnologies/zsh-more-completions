#compdef tpm2_createak tpm2_createek tpm2_getekcertificate tpm2_changeauth tpm2_verifysignature tpm2_clear
# Documentation: source-direct extraction from upstream
# tpm2-software/tpm2-tools.  Per-tool `struct option topts[]`
# table decoded source-direct from each tools/tpm2_<name>.c.
# Shared $tpm2_common + $tpm2_hierarchy + $tpm2_hashalgs +
# $tpm2_keyalgs + $tpm2_signschemes re-extracted source-direct
# from lib/tpm2_options.c / lib/tpm2_alg_util.c — see R193/
# R194/R195 HARVEST_LOG entries for the full extraction notes.
# Reference accessed: 2026-05-30 via gh api.
# tpm2-software tpm2-tools R196 — follow-up to R195's hunt-skip
# on "next-priority candidates: tpm2_createak/createek/
# getekcertificate, tpm2_changeauth, tpm2_clear, ...".  This
# round covers the EK/AK provisioning + auth-mgmt + signature-
# verify family: tpm2_createak (TPM2 attestation-key creation
# under an existing EK), tpm2_createek (TPM2 endorsement-key
# creation in the endorsement hierarchy), tpm2_getek-
# certificate (retrieve the EK certificate from TPM NV or
# manufacturer URL), tpm2_changeauth (change auth value of a
# TPM object), tpm2_verifysignature (verify a signature with a
# TPM-resident public key), tpm2_clear (TPM2_Clear to reset the
# entire TPM to factory defaults).  Sister tools to R193's
# getrandom/getcap/pcrread/hash/nvread/nvwrite, R194's create/
# createprimary/load/loadexternal/evictcontrol/flushcontext,
# and R195's sign/quote/unseal/startauthsession/pcrextend/
# readpublic already in the corpus.

local -a tpm2_common=(
  '(-T --tcti)'{-T+,--tcti=}'[TCTI library + options (e.g. "device:/dev/tpmrm0" or "swtpm:port=2321")]:tcti:'
  '(-h --help)'{-h-,--help=-}'[print help (optional arg = topic)]::topic:'
  '(-v --version)'{-v,--version}'[print version and exit]'
  '(-V --verbose)'{-V,--verbose}'[verbose mode]'
  '(-Q --quiet)'{-Q,--quiet}'[quiet mode]'
  '(-Z --enable-errata)'{-Z,--enable-errata}'[enable TPM2 errata workarounds]'
  '(-z --pwd-session)'{-z,--pwd-session}'[use password-authorized session]'
)
local -a tpm2_hierarchy=(owner endorsement platform null o e p n)
local -a tpm2_hashalgs=(sha1 sha256 sha384 sha512 sm3_256)
local -a tpm2_keyalgs=(rsa rsa1024 rsa2048 rsa3072 rsa4096
                      ecc ecc_nist_p192 ecc_nist_p224 ecc_nist_p256
                      ecc_nist_p384 ecc_nist_p521 ecc_sm2_p256
                      ecc_bn_p256 ecc_bn_p638
                      aes aes128 aes192 aes256
                      keyedhash xor null)
local -a tpm2_signschemes=(rsassa rsapss ecdsa ecdaa ecschnorr sm2 hmac null)

case $service in

  tpm2_createak)
    # Create an attestation key (AK) under a previously-created
    # endorsement key (EK) — typical TPM2 attestation flow.
    _arguments -s -S \
      $tpm2_common \
      '(-P --eh-auth)'{-P+,--eh-auth=}'[endorsement-hierarchy authorization]:auth:' \
      '(-p --ak-auth)'{-p+,--ak-auth=}'[AK authorization (new)]:auth:' \
      '(-C --ek-context)'{-C+,--ek-context=}'[EK context (parent: handle or context file)]:ek:' \
      '(-c --ak-context)'{-c+,--ak-context=}'[output AK context file]:file:_files' \
      '(-n --ak-name)'{-n+,--ak-name=}'[output AK name file]:file:_files' \
      '(-G --key-algorithm)'{-G+,--key-algorithm=}'[AK key algorithm]:alg:($tpm2_keyalgs)' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm for AK signing]:alg:($tpm2_hashalgs)' \
      '(-a --attributes)'{-a+,--attributes=}'[AK object attributes bitmask]:attrs:' \
      '(-s --signing-algorithm)'{-s+,--signing-algorithm=}'[signing scheme for AK]:scheme:($tpm2_signschemes)' \
      '(-f --format)'{-f+,--format=}'[output format for --public]:format:(tss pem der)' \
      '(-u --public)'{-u+,--public=}'[output AK public-key file]:file:_files' \
      '(-r --private)'{-r+,--private=}'[output AK private-blob file]:file:_files' \
      '(-q --ak-qualified-name)'{-q+,--ak-qualified-name=}'[output AK qualified-name file]:file:_files' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush AK after creation]'
    ;;

  tpm2_createek)
    # Create an endorsement key (EK) in the endorsement
    # hierarchy.  Critical extraction note: tpm2_createek has
    # TWO hierarchy-auth flags — -P/--eh-auth for endorsement
    # hierarchy (where EK is created) and -w/--owner-auth for
    # owner hierarchy (for persisting the EK via TPM2_
    # EvictControl).
    _arguments -s -S \
      $tpm2_common \
      '(-P --eh-auth)'{-P+,--eh-auth=}'[endorsement-hierarchy authorization]:auth:' \
      '(-w --owner-auth)'{-w+,--owner-auth=}'[owner-hierarchy authorization (for evictcontrol-persist)]:auth:' \
      '(-G --key-algorithm)'{-G+,--key-algorithm=}'[EK key algorithm]:alg:($tpm2_keyalgs)' \
      '(-u --public)'{-u+,--public=}'[output EK public-key file]:file:_files' \
      '(-f --format)'{-f+,--format=}'[output format for --public]:format:(tss pem der)' \
      '(-c --ek-context)'{-c+,--ek-context=}'[EK context (handle for persist, or output context file)]:ek:' \
      '(-t --template)'{-t,--template}'[print EK template + nonce (per TCG EK Credential Profile)]' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush EK after creation]'
    ;;

  tpm2_getekcertificate)
    # Retrieve the EK certificate from the TPM's NV storage
    # (typical Intel/AMD-fTPM) OR fetch from the manufacturer's
    # EK Credential URL (Infineon/STMicro/Nuvoton discrete TPMs).
    _arguments -s -S \
      $tpm2_common \
      '(-o --ek-certificate)'{-o+,--ek-certificate=}'[output EK certificate file (default stdout)]:file:_files' \
      '(-X --allow-unverified)'{-X,--allow-unverified}'[skip TLS certificate verification when fetching from URL]' \
      '(-u --ek-public)'{-u+,--ek-public=}'[input EK public-key file (used for hash lookup in URL fetch mode)]:file:_files' \
      '(-x --offline)'{-x,--offline}'[work offline: do not contact manufacturer EK URL]' \
      '(-E --encoding)'{-E+,--encoding=}'[output encoding]:enc:(plain pem)' \
      '--raw[emit the raw cert bytes (no decoding)]' \
      '(-t --x509-trunc)'{-t,--x509-trunc}'[truncate non-X.509 metadata from the certificate]' \
      '*:EK manufacturer URL (omit to use TPM NV):'
    ;;

  tpm2_changeauth)
    # Change the authorization value (password) of a TPM2
    # object — TPM2_ObjectChangeAuth for child keys or TPM2_
    # HierarchyChangeAuth for hierarchies.
    _arguments -s -S \
      $tpm2_common \
      '(-p --object-auth)'{-p+,--object-auth=}'[NEW authorization value]:new-auth:' \
      '(-c --object-context)'{-c+,--object-context=}'[object whose auth to change]:object:' \
      '(-C --parent-context)'{-C+,--parent-context=}'[parent context (required for non-hierarchy objects)]:parent:' \
      '(-r --private)'{-r+,--private=}'[output re-encrypted private-blob file]:file:_files' \
      '--cphash=[output command-parameter hash for off-line audit]:file:_files' \
      '--rphash=[output response-parameter hash for off-line audit]:file:_files' \
      '(-S --session)'{-S+,--session=}'[authorization session context file (OLD-auth-bearing)]:file:_files' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush object after operation]'
    ;;

  tpm2_verifysignature)
    # Verify a signature with a TPM-resident public key,
    # optionally producing a ticket for restricted-key chaining.
    _arguments -s -S \
      $tpm2_common \
      '(-d --digest)'{-d+,--digest=}'[input digest file (alternative to --message)]:file:_files' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm (for --message hashing)]:alg:($tpm2_hashalgs)' \
      '(-m --message)'{-m+,--message=}'[input message file (will be hashed)]:file:_files' \
      '--format=[input signature format]:format:(tss plain)' \
      '(-f --scheme)'{-f+,--scheme=}'[signing scheme override]:scheme:($tpm2_signschemes)' \
      '(-s --signature)'{-s+,--signature=}'[input signature file]:file:_files' \
      '(-t --ticket)'{-t+,--ticket=}'[output verification ticket file]:file:_files' \
      '(-c --key-context)'{-c+,--key-context=}'[public key context for verification (handle or context file)]:key:'
    ;;

  tpm2_clear)
    # TPM2_Clear: reset the entire TPM2 to factory defaults
    # (resets EPS, EHR, all hierarchies, NV storage).
    # DANGEROUS: typically requires platform-hierarchy or
    # lockout-hierarchy auth and a physical-presence assertion
    # on production TPMs.
    _arguments -s -S \
      $tpm2_common \
      '(-c --auth-hierarchy)'{-c+,--auth-hierarchy=}'[hierarchy to authorize the clear (lockout|platform)]:hierarchy:(lockout platform l p)' \
      '--cphash=[output command-parameter hash for off-line audit]:file:_files'
    ;;

esac
