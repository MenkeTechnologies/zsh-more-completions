#compdef tcpsynbl tcpsynbl-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpsynbl.py argparse)
# Reference accessed: 2026-05-29
# tcpsynbl — TCP SYN backlog as a histogram (BCC/eBPF). Tracks accept-queue depth.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  && ret=0

return ret
