#compdef istioctl2
# _istioctl2 — Istio CNCF istioctl2 CLI command-line frontend wrapping the Istio service mesh CLI istioctl for installing and managing Istio open-source written in Go CNCF Graduated 2023 control plane install operator-init analyze authz dashboard delete-helm-revision experimental kube-inject manifest profile remote-clusters revisions tag uninstall upgrade verify-install version waypoint x ztunnel proxy-config proxy-status validate Status ProxyConfig ProxyStatus declarative-API installation-CRD-CR Helm hierarchical-config-file IstioOperator AnalyzeMessage CertificateAuthority injection (Istio CNCF team Daniel Berg Louis Ryan Lin Sun, Go); cobra
# upstream: https://istio.io/

_istioctl2() {
    local -a sub=(
        'admin:admin operations'
        'analyze:analyze Istio configuration'
        'authz:authz operations'
        'completion:generate shell completion'
        'create-remote-secret:create remote secret'
        'dashboard:open dashboards'
        'experimental:experimental commands'
        'install:install Istio'
        'kube-inject:inject sidecar into manifest'
        'manifest:manifest operations'
        'operator:Istio operator install'
        'profile:profile operations'
        'proxy-config:proxy config operations'
        'proxy-status:proxy status'
        'remote-clusters:list remote clusters'
        'revisions:Istio revisions operations'
        'tag:tag operations'
        'uninstall:uninstall Istio'
        'upgrade:upgrade Istio'
        'validate:validate configuration'
        'verify-install:verify installation'
        'version:show version'
        'waypoint:ambient waypoint ops'
        'ztunnel-config:ztunnel config ops'
        'x:experimental shortcut'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '-c+[context]:str:' \
        '--context=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[ns]:str:' \
        '-i+[istio namespace]:str:' \
        '--istioNamespace=+[ns]:str:' \
        '--vklog=+[N]:n:' \
        '--log_output_level=+[scope:level]:str:' \
        '--log_caller=+[scopes]:str:' \
        '--log_target=+[files]:str:' \
        '--log_rotate=+[file]:file:_files' \
        '--log_rotate_max_age=+[d]:n:' \
        '--log_rotate_max_backups=+[N]:n:' \
        '--log_rotate_max_size=+[MB]:n:' \
        '--log_stacktrace_level=+[scope:level]:str:' \
        '--log_as_json[log as JSON]' \
        '-o+[output format]:f:(short yaml json table)' \
        '--output=+[fmt]:f:(short yaml json table)' \
        '--revision=+[name]:str:' \
        '-r+[revision]:str:' \
        '--skip-confirmation[skip confirmation]' \
        '-y[skip confirmation]' \
        '--charts=+[dir]:dir:_files -/' \
        '--manifests=+[dir]:dir:_files -/' \
        '-f+[file]:file:_files -g "*.yaml *.yml"' \
        '*-f+[file]:file:_files -g "*.yaml *.yml"' \
        '--filename=+[file]:file:_files -g "*.yaml *.yml"' \
        '-s+[set value]:str:' \
        '*-s+[set value]:str:' \
        '--set=+[k=v]:str:' \
        '--dry-run[dry run]' \
        '--cluster-context=+[name]:str:' \
        '--server-side[server side apply]' \
        '--force[force]' \
        '-A[all namespaces]' \
        '--all-namespaces[all namespaces]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'istioctl subcommand' sub ;;
        args)
            case $words[1] in
                proxy-config|pc) _arguments '1:type:(bootstrap cluster ecds endpoint listener log route secret all)' '*:pod:' ;;
                proxy-status|ps) _arguments '*:pod:' ;;
                manifest) _arguments '1:op:(generate diff apply install translate)' '*:arg:' ;;
                profile) _arguments '1:op:(diff dump list)' '*:arg:' ;;
                operator) _arguments '1:op:(init dump remove)' '*:arg:' ;;
                dashboard) _arguments '1:type:(controlz envoy grafana jaeger kiali prometheus zipkin proxy)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                analyze) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_istioctl2 "$@"
