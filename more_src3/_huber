_huber() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-l --log-level)'{-l,--log-level}'=[log level]:level:(off error warn info debug trace)' \
        '--github-token=[GitHub token (env GITHUB_TOKEN)]:token:' \
        '1: :_huber_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                install|uninstall|update|current|lock|unlock)
                    _arguments '*:package:' && ret=0 ;;
                info|search)
                    _arguments '1:package or query:' && ret=0 ;;
                save|load)
                    _arguments '1:huber package list file:_files -g "*.yaml *.yml"' && ret=0 ;;
                completions)
                    _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
                show|flush|reset|self-update|config|repo)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_huber_commands] )) ||
_huber_commands() {
    local -a commands
    commands=(
        'install:install packages'
        'uninstall:uninstall packages'
        'update:update installed packages to their latest released versions'
        'current:update the current package versions'
        'show:show installed packages'
        'info:show package information'
        'search:search package registry'
        'lock:lock packages (or show locked packages with no args)'
        'unlock:unlock packages'
        'save:save the installed-package list to a file'
        'load:load installed packages from a file generated by save'
        'flush:remove outdated installed artifacts'
        'reset:reset Huber (clears the local prefix)'
        'self-update:update Huber itself'
        'config:manage Huber configurations'
        'repo:manage repositories (add/remove/list third-party Huber registries)'
        'completions:show command completions for the specified shell'
    )
    _describe -t commands 'huber command' commands
}

_huber "$@"
