#compdef xen-detect
# Documentation: https://github.com/xen-project/xen/blob/master/tools/misc/xen-detect.c
# Reference accessed: 2026-05-21
# Verified: upstream xen-detect.c usage() text quoted from source. Real flags
# are -h/--help, -q/--quiet, -P/--pv, -H/--hvm, -N/--none. No -v/--verbose.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-q --quiet)'{-q,--quiet}'[quiesce normal informational output]' \
  '(-P --pv)'{-P,--pv}'[exit status 1 if not running as PV guest]' \
  '(-H --hvm)'{-H,--hvm}'[exit status 1 if not running as HVM or PVH guest]' \
  '(-N --none)'{-N,--none}'[exit status 1 if running on Xen (PV or HVM)]' && ret=0
return ret
