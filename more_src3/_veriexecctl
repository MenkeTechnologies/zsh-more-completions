#compdef veriexecctl
# Documentation: man veriexecctl(8)
# Source: netbsd/src sbin/veriexecctl — Veriexec file integrity control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-e[evaluate fingerprint on load, not at access]' \
    '-k[keep filenames in entries for logging]' \
    '-v[verbose output]' \
    '1:command:(load delete dump flush query)' \
    '*::file or mount point:_files' \
    && ret=0

return ret
