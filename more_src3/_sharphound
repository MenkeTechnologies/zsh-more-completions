#compdef sharphound SharpHound SharpHound.exe
# _sharphound — SpecterOps sharphound CLI C# BloodHound data collection tool for Active Directory enumeration querying domain controllers via LDAP SAMR Win32 API gathering users groups computers OUs GPOs Active-Directory-Certificate-Services trust relationships ACLs sessions producing JSON zip output for BloodHound graph analysis (SpecterOps team, C#); custom argparse
# upstream: https://github.com/BloodHoundAD/SharpHound

_sharphound() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[collection methods]:m:(Default Group LocalAdmin Session GPOLocalGroup Container LoggedOn Trusts ACL ObjectProps SPNTargets DCOnly RDP DCOM PSRemote ComputerOnly UserSession DCSync All)' \
        '--collectionmethods=+[methods]:str:' \
        '-d+[domain]:str:' \
        '--domain=+[domain]:str:' \
        '--ldapfilter=+[filter]:str:' \
        '--searchbase=+[base]:str:' \
        '--ou=+[ou]:str:' \
        '--excludedomaincontrollers[exclude DCs]' \
        '--computer=+[computer]:str:' \
        '-s+[stealth]' \
        '--stealth[stealth mode]' \
        '--ldapusername=+[user]:str:' \
        '--ldappassword=+[pw]:str:' \
        '--domaincontroller=+[dc]:_hosts' \
        '--secureldap[ldap over TLS]' \
        '--disablecertverification[disable cert verification]' \
        '--collectallproperties[collect all properties]' \
        '--zipfilename=+[name]:str:' \
        '--randomfilenames[random filenames]' \
        '--zippassword=+[pw]:str:' \
        '--nozip[no zip]' \
        '--outputdirectory=+[dir]:dir:_files -/' \
        '--outputprefix=+[prefix]:str:' \
        '--cachefilename=+[name]:str:' \
        '--rebuildcache[rebuild cache]' \
        '--invalidatecache[invalidate cache]' \
        '--throttle=+[ms]:n:' \
        '--jitter=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--portscantimeout=+[ms]:n:' \
        '--statusinterval=+[sec]:n:' \
        '--prettyjson[pretty JSON]' \
        '--encryptzip[encrypt zip]' \
        '--nosaveCache[no save cache]' \
        '--realdnsname=+[name]:str:' \
        '--collectallproperties[collect all properties]' \
        '--exclude-dcs[exclude DCs]' \
        '-v+[verbosity]:l:(0 1 2 3 4 5)' \
        '*::'
}

_sharphound "$@"
