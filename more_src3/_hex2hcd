#compdef hex2hcd
# Documentation: https://github.com/bluez/bluez/blob/master/tools/hex2hcd.c
# Source: BlueZ tools/hex2hcd.c — convert Broadcom Intel-HEX firmware to the .hcd patch format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-T --table)'{-T,--table}'[print version table]' \
    '(-o --output)'{-o+,--output=}'[firmware output file]:file:_files' \
    '(- *)'{-v,--version}'[print version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:input .hex:_files -g "*.hex"' \
    && ret=0

return ret
