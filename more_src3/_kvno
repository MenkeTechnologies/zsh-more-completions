#compdef kvno
# _kvno — MIT Kerberos kvno (acquire a service ticket for a given principal so its kvno (key version number) can be read from the resulting ticket; -c credential cache, -e enctype, -k keytab, -P canonicalize, -S server, -U authdata, --version, --help; positional argument is the list of principals to look up)
# upstream: https://github.com/krb5/krb5
# Flags from krb5/krb5 src/clients/kvno/kvno.c on tip.

_kvno() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-c+[credential cache]:file:_files' \
        '-e+[enctype]:enctype:(aes256-cts aes128-cts aes256-cts-hmac-sha384-192 aes128-cts-hmac-sha256-128 camellia256-cts camellia128-cts arcfour-hmac des3-cbc-sha1)' \
        '-k+[keytab]:file:_files' \
        '-P[canonicalize]' \
        '-q[quiet]' \
        '-S+[server]:server:_hosts' \
        '-U+[authdata]:authdata:' \
        '*:principal:'
}

_kvno "$@"
