#compdef sysz
# Documentation: https://github.com/joehillen/sysz
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sysz - fzf terminal UI for systemctl

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[display version information]' \
  '(-u --user)'{-u,--user}'[display only user units]' \
  '(--sys --system)'{--sys,--system}'[display only system units]' \
  '*'{-s+,--state=}'[filter units by state]:state:(active inactive failed running listening)' \
  '(-V --verbose)'{-V,--verbose}'[print the systemctl command being run]' \
  '1:command:(start stop r restart s stat status ed edit reload en enable d dis disable c cat)' \
  '*:unit pattern:'
