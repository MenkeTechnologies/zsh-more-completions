#compdef lasmerge
# Zsh completion for lasmerge - merge multiple LAS files
# https://github.com/LAStools/LAStools

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '*'{-i,--input=}'[specify input LAS/LAZ file]:input file:_files' \
  {-o,--output=}'[specify output LAS/LAZ file]:output file:_files' \
  '-merged[treat all input as merged]' \
  '--verbose[verbose output]' \
  '*:file:_files'
