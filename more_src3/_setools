#compdef setools
# Documentation: https://github.com/SELinuxProject/setools
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: setools is the project name, not an actual executable; the package
# ships discrete binaries (sechecker, sediff, sedta, seinfo, seinfoflow,
# sesearch, apol). This dispatcher exists only because some packagers create
# a `setools` wrapper.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sechecker:configuration file-driven automated analysis'
  'sediff:compare two policies to find differences'
  'sedta:perform domain transition analyses'
  'seinfo:list policy components'
  'seinfoflow:perform information flow analyses'
  'sesearch:search rules (allow, type_transition, etc.)'
  'apol:graphical Qt-based policy analyzer'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:_files' && ret=0

case $state in
  (cmd) _describe -t cmds 'setools tool' commands && ret=0 ;;
esac

return ret
