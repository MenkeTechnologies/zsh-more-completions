#compdef sarif
# Documentation: https://github.com/microsoft/sarif-tools
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sarif (Microsoft sarif-tools CLI)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'blame:augment SARIF with git blame info'
  'codeclimate:generate Code Climate JSON for GitLab'
  'copy:create new SARIF files with optional filtering'
  'csv:export issues as CSV'
  'diff:compare two sets of SARIF files'
  'emacs:format results for emacs'
  'html:generate HTML summary'
  'info:display SARIF file structure details'
  'ls:list SARIF files in directories'
  'summary:print text summary with issue counts'
  'trend:generate time-series CSV from timestamped SARIF files'
  'upgrade-filter:convert v1 to v2-style filter files'
  'usage:display usage information'
  'version:show version number'
  'word:create MS Word (.docx) summary'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--debug[print debug information]' \
  '(-x --check)'{-x,--check}'[exit with error if issues at this level exist]:level:(error warning note)' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'sarif command' commands && ret=0
    ;;
  args)
    _arguments '*:file:_files -g "*.sarif"' && ret=0
    ;;
esac

return ret
