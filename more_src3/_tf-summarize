#compdef tf-summarize
# Documentation: https://github.com/dineshba/tf-summarize
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-h[show help]' \
  '-v[show version]' \
  '-draw[draw trees instead of plain tree]' \
  '-html[output changes in HTML format]' \
  '-json[output changes in JSON format]' \
  '-json-sum[print summary of changes in JSON format]' \
  '-md[output table as markdown]' \
  '-out=[write output to file]:file:_files' \
  '-separate-tree[print changes in tree format for add/delete/change/recreate]' \
  '-tree[output changes in tree format]' \
  '*:terraform plan file (tfplan or tf-plan.json):_files'
