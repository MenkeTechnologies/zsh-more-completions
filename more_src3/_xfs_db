#compdef xfs_db
# _xfs_db — xfsprogs xfs_db (offline debugger/explorer for XFS metadata; -r read-only, -x expert mode, -c run command, -f treat target as file (image), -p set program name, -l logdev for external log, -i ignore corruption; positional argument is the block device or image)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs db/init.c on tip.

_xfs_db() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[run command]:command:' \
        '-f[interpret target as file]' \
        '-i[ignore corruption]' \
        '-l+[external log device]:device:' \
        '-p+[program name]:name:' \
        '-r[read-only]' \
        '-x[expert mode]' \
        '1:device or image:_files'
}

_xfs_db "$@"
