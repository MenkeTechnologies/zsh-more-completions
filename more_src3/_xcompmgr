#compdef xcompmgr
# Documentation: man xcompmgr (X.Org)
# Source: lightweight compositing manager for X11.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[X display]:display:' \
    '-r+[shadow blur radius]:radius:' \
    '-o+[window opacity]:opacity:' \
    '-l+[shadow left offset]:left:' \
    '-t+[shadow top offset]:top:' \
    '-I+[fade-in step]:step:' \
    '-O+[fade-out step]:step:' \
    '-D+[fade delta ms]:delta:' \
    '(-a -c -n -s)-a[automatic server-side compositing]' \
    '(-a -c -n -s)-c[client-side compositing with soft shadows]' \
    '(-a -c -n -s)-n[simple client-side compositing (default)]' \
    '(-a -c -n -s)-s[server-side compositing with hard shadows]' \
    '-f[fade transient windows (requires -c)]' \
    '-C[skip shadows on selected windows (requires -c)]' \
    '-F[fade on window open/close (requires -f)]' \
    '-S[synchronous operation (debugging)]' \
    && ret=0

return ret
