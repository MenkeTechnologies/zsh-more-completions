#compdef kohya kohya-ss kohya-cli
# _kohya — kohya-ss Stable Diffusion training scripts CLI alias (Kohya-ss / Bmaltais GUI fork, Python); custom argparse
# upstream: https://github.com/kohya-ss/sd-scripts

_kohya() {
    local -a sub=(
        'train:train a model (sd_train style)'
        'train-lora:train LoRA'
        'train-textual-inversion:train Textual Inversion'
        'train-dreambooth:train Dreambooth'
        'train-controlnet:train ControlNet'
        'merge-lora:merge LoRA into model'
        'convert-lora:convert LoRA format'
        'caption:caption images'
        'gui:open Bmaltais GUI'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config_file=+[config toml/json]:file:_files -g "*.toml *.json"' \
        '--dataset_config=+[dataset config]:file:_files' \
        '--pretrained_model_name_or_path=+[pretrained model]:str:' \
        '--v2[SD v2]' \
        '--v_parameterization[v_parameterization]' \
        '--sdxl[SDXL]' \
        '--output_dir=+[output dir]:dir:_files -/' \
        '--output_name=+[output name]:str:' \
        '--save_model_as=+[save format]:f:(ckpt safetensors diffusers)' \
        '--max_train_steps=+[max train steps]:n:' \
        '--max_train_epochs=+[max train epochs]:n:' \
        '--save_every_n_steps=+[save every n steps]:n:' \
        '--save_every_n_epochs=+[save every n epochs]:n:' \
        '--learning_rate=+[learning rate]:f:' \
        '--text_encoder_lr=+[text encoder lr]:f:' \
        '--unet_lr=+[unet lr]:f:' \
        '--train_batch_size=+[batch size]:n:' \
        '--gradient_accumulation_steps=+[grad accum]:n:' \
        '--mixed_precision=+[mixed precision]:p:(no fp16 bf16)' \
        '--xformers[use xformers]' \
        '--sdpa[use SDPA]' \
        '--cache_latents[cache latents]' \
        '--enable_bucket[enable aspect ratio bucketing]' \
        '--resolution=+[resolution]:str:' \
        '--lr_scheduler=+[lr scheduler]:s:(linear cosine cosine_with_restarts polynomial constant constant_with_warmup adafactor)' \
        '--optimizer_type=+[optimizer]:o:(AdamW AdamW8bit Lion SGDNesterov SGDNesterov8bit DAdaptation AdaFactor Prodigy)' \
        '--network_module=+[network module]:m:(networks.lora networks.lora_fa networks.dylora networks.oft)' \
        '--network_dim=+[network dim]:n:' \
        '--network_alpha=+[network alpha]:f:' \
        '--network_train_unet_only[train UNet only]' \
        '--network_train_text_encoder_only[train text encoder only]' \
        '--noise_offset=+[noise offset]:f:' \
        '--min_snr_gamma=+[min SNR gamma]:f:' \
        '--max_token_length=+[max token length]:n:' \
        '--clip_skip=+[clip skip]:n:' \
        '--logging_dir=+[logging dir]:dir:_files -/' \
        '--log_with=+[log with]:l:(tensorboard wandb all)' \
        '--sample_every_n_epochs=+[sample every n epochs]:n:' \
        '--sample_every_n_steps=+[sample every n steps]:n:' \
        '--sample_prompts=+[sample prompts file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kohya subcommand' sub ;;
    esac
}

_kohya "$@"
