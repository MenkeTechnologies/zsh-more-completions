#compdef lspmux
# Documentation: https://codeberg.org/p2502/lspmux
# Reference accessed: 2026-05-16
# Verified: codeberg p2502/lspmux README (formerly ra-multiplex).
# Removed from prior file: bogus man.archlinux.org search URL;
# missing subcommands.

# lspmux: LSP multiplexer (share one LSP server across editors)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'client:client mode (default, transparent)'
  'server:server mode (background daemon)'
  'status:show server status'
  'config:print effective config'
  'reload:reload server config'
  'sync:sync clients'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'lspmux command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (client)
        _arguments \
          '--server-path=[server binary path (override LSPMUX_SERVER env)]:path:_files' && ret=0
        ;;
    esac
    ;;
esac
return ret
