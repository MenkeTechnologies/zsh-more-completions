#compdef vtcode
# Documentation: https://github.com/vinhnx/vtcode/blob/main/docs/user-guide/commands.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (subcommand list).
# Note: per-subcommand flag completion is intentionally minimal —
# upstream docs only enumerate common flags, not full per-cmd tables.

local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'ask:generate code from a natural-language prompt'
  'exec:execute a shell command via the agent'
  'login:authenticate with a provider'
  'grep_file:high-speed code search'
  'list_files:list directory contents'
  'read_file:read file contents'
  'write_file:create or modify files'
  'edit_file:edit file content (whitespace tolerant)'
  'resume:reopen archived/latest session'
  'fork-session:branch a session into a new archive'
  'schema:inspect built-in tool schemas'
  'stats:show configuration and performance metrics'
  'update:check for/install binary updates'
  'dependencies:manage optional tools (ripgrep, ast-grep, etc.)'
  'check:run repository checks'
  'pods:manage remote GPU-backed model pods'
  'schedule:create durable scheduled tasks'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[custom configuration path]:file:_files' \
  '--continue[resume the most recent session]' \
  '--resume=[reopen specific archived session]:session id:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'vtcode command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (ask|exec) _message 'prompt or command' && ret=0 ;;
      (login) _values 'provider' copilot && ret=0 ;;
      (dependencies) _values 'subcommand' install && ret=0 ;;
      (update) _arguments '--check[check only]' '--force[force update]' && ret=0 ;;
      (schema) _arguments '--mode=[output mode]:mode:(minimal progressive full)' \
                          '--name=[filter by tool name]:tool:' \
                          '--detailed[detailed tool information]' && ret=0 ;;
      (*) _default && ret=0 ;;
    esac
    ;;
esac
return ret
