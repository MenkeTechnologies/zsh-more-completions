#compdef klayout
# Documentation: https://www.klayout.de/command_args.html
# Source: KLayout/klayout — main IC layout editor / viewer (Qt GUI + headless mode).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-z -zz)-b[batch mode (same as -zz -nc -rx)]' \
    '-c[use specified configuration file]:config:_files' \
    '-nc[do not use a configuration file (implies -t)]' \
    '-d[verbosity of log output]:level:' \
    '(-ne)-e[enter edit mode]' \
    '(-e)-ne[enter viewer mode]' \
    '(-ni)-i[disable undo buffering]' \
    '(-i)-ni[enable undo buffering (default)]' \
    '*-j[add path to macro project paths]:path:_directories' \
    '-k[copy log messages to file]:file:_files' \
    '-l[use specified layer properties (.lyp) file]:lyp:_files' \
    '-lx[add other layers to layer properties (with -l)]' \
    '-lf[use .lyp file as-is, no expansion (with -l)]' \
    '*-m[load report database together with previous layout]:rdb:_files' \
    '*-mn[load L2N/LVS database together with previous layout]:l2n:_files' \
    '*-n[technology to use for next layouts]:tech:' \
    '*-nn[technology file (.lyt) for next layouts]:lyt:_files' \
    '*-p[load plugin (shared object)]:plugin:_files' \
    '-r[run script in interpreter mode and exit]:script:_files' \
    '-rr[run script in interpreter mode, do not exit]:script:_files' \
    '-rm[run script before GUI starts]:script:_files' \
    '*-rd[define variable in Ruby/Python context (var=value)]:var=value:' \
    '-rx[ignore all implicit macros (*.rbm, rbainit, *.lym)]' \
    '-s[load files into same view]' \
    '(-nt)-t[do not update configuration file on exit (amnesia)]' \
    '(-t)-nt[update configuration file on exit (default)]' \
    '-u[restore session from file]:session:_files' \
    '(* -v)-v[print version and exit]' \
    '*-wd[define variable for use within expressions (var=value)]:var=value:' \
    '-x[synchronous drawing mode (non-threaded)]' \
    '-y[automatic package installation mode]' \
    '-yd[automatically include dependencies (with -y)]' \
    '(-b -z -zz)-z[non-GUI mode (no UI brought up)]' \
    '(-b -z -zz)-zz[headless mode (GUI entirely disabled)]' \
    '-gr[record GUI actions to file]:gui rec:_files' \
    '-gp[replay GUI actions from file]:gui play:_files' \
    '-gb[stop replaying at given line]:line:' \
    '-gx[replay rate for GUI test file]:rate:' \
    '-gi[incremental crash-safe GUI record logs]' \
    '*:layout file:_files' \
    && ret=0

return ret
