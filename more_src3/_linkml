#compdef linkml
# _linkml — top-level LinkML CLI umbrella (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Subcommands from src/linkml/cli/main.py (click group).

_linkml() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_linkml_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                generate)
                    _arguments \
                        '1: :_linkml_generate_commands' \
                        '*::generate args:' && ret=0 ;;
                dev)
                    _arguments \
                        '1: :_linkml_dev_commands' \
                        '*::dev args:' && ret=0 ;;
                convert|lint|validate|sqldb|fix|examples)
                    _arguments '*:command args:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_linkml_commands] )) ||
_linkml_commands() {
    local -a commands
    commands=(
        'generate:generate formats from a LinkML schema'
        'convert:convert data between formats validated against a LinkML schema'
        'lint:lint LinkML schema YAML files'
        'validate:validate data instances against a LinkML schema'
        'sqldb:work with the schema-backed SQLite database'
        'fix:apply automatic fixes to a LinkML schema'
        'examples:run examples from a LinkML workspace'
        'dev:developer-oriented helper tools'
    )
    _describe -t commands 'linkml command' commands
}

(( $+functions[_linkml_generate_commands] )) ||
_linkml_generate_commands() {
    local -a commands
    commands=(
        'jsonld-context:emit a JSON-LD @context'
        'prefix-map:emit a curie → URI prefix map'
        'csv:emit a flattened CSV view'
        'graphviz:render the schema as a Graphviz dot graph'
        'golang:emit Go structs'
        'cpp-header:emit a C++ header'
        'golr-views:emit GOLR (BBOP) views'
        'graphql:emit a GraphQL schema'
        'java:emit Java classes'
        'jsonld:emit a JSON-LD document'
        'json-schema:emit a JSON Schema'
        'linkml:emit a normalized LinkML YAML schema'
        'markdown-datadict:emit a Markdown data dictionary'
        'mermaid-class-diagram:emit a Mermaid class diagram'
        'namespaces:emit a Python module of rdflib Namespaces'
        'openapi:emit an OpenAPI schema'
        'owl:emit an OWL ontology'
        'pandera:emit Pandera DataFrameModels'
        'plantuml:emit a PlantUML class diagram'
        'project:emit a multi-artifact project'
        'proto:emit a Protobuf schema'
        'python:emit Python dataclasses (alias of py-classes)'
        'py-classes:emit Python dataclasses'
        'pydantic:emit Pydantic models'
        'rdf:emit RDF'
        'rust:emit Rust types'
        'shacl:emit SHACL shapes'
        'shex:emit ShEx shapes'
        'sparql:emit per-class SPARQL queries'
        'sqla:emit SQLAlchemy ORM classes'
        'sqltables:emit SQL DDL (alias of sqlddl)'
        'sqlvalidation:emit SQL validation queries'
        'sssom:emit SSSOM mappings'
        'summary:emit a Markdown summary'
        'terminusdb:emit a TerminusDB schema'
        'typescript:emit TypeScript interfaces'
        'yaml:emit (re)normalized YAML'
        'yarrrml:emit YARRRML mapping rules'
        'dbml:emit DBML (Database Markup Language)'
        'doc:emit Markdown documentation'
        'erdiagram:emit a Mermaid ER diagram'
        'excel:emit an Excel workbook'
        'typedb:emit a TypeDB schema'
    )
    _describe -t commands 'linkml generate command' commands
}

(( $+functions[_linkml_dev_commands] )) ||
_linkml_dev_commands() {
    local -a commands
    commands=(
        'run-tutorial:execute the LinkML tutorial notebook'
    )
    _describe -t commands 'linkml dev command' commands
}

_linkml "$@"
