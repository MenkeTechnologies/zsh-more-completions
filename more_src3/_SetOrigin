#compdef SetOrigin
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/SetOrigin.cxx — overwrite image-origin in an image header (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:Dimension:(2 3 4)' \
    '2:infile.hdr:_files -g "*.{nii,nii.gz,hdr,img,mha,nrrd}"' \
    '3:outfile.nii:_files' \
    '4:OriginX:_default' \
    '5:OriginY:_default' \
    '6::OriginZ:_default' \
    '7::OriginT:_default' \
    && ret=0

return ret
