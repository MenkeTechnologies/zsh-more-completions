#compdef hakyll-init hakyll
# Documentation: https://github.com/jaspervdj/hakyll/blob/master/src/Init.hs
# Documentation: https://github.com/jaspervdj/hakyll/blob/master/lib/Hakyll/Main.hs
# Reference accessed: 2026-05-27
# Verified: upstream Hakyll source (src/Init.hs for hakyll-init,
# lib/Hakyll/Main.hs commandParser/defaultCommands for the user-built site CLI).

# Zsh completion for hakyll. The repo ships two entry points:
#   * hakyll-init - scaffolds an example site (takes [-f] <directory>)
#   * the user's site executable, built on top of the Hakyll library, exposing
#     the standard subcommands defined in Hakyll.Main (build, check, clean,
#     deploy, preview, rebuild, server, watch). Many users name that binary
#     "hakyll" or "site"; this completion handles "hakyll" too.

local curcontext="$curcontext" state line ret=1

case ${service} in
  hakyll-init)
    _arguments \
      '-f[force overwrite of existing files]' \
      '*:directory:_directories' && ret=0
    return ret
    ;;
esac

local -a _hakyll_subcommands
_hakyll_subcommands=(
  'build:generate the site'
  'check:validate the site output'
  'clean:clean up and remove cache'
  'deploy:upload/deploy your site'
  'preview:[deprecated] start a preview server (use watch instead)'
  'rebuild:clean and build again'
  'server:start a preview server'
  'watch:autocompile on changes and start a preview server'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[run in verbose mode]' \
  '(- *)'{-h,--help}'[show help and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'hakyll subcommand' _hakyll_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          '--dry-run[do not build, only print out-of-date items]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      check)
        _arguments \
          '--internal-links[check internal links only]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      preview)
        _arguments \
          '--port=[port to listen on]:port:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      server)
        _arguments \
          '--host=[host to bind on]:host:_hosts' \
          '--port=[port to listen on]:port:' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      watch)
        _arguments \
          '--host=[host to bind on]:host:_hosts' \
          '--port=[port to listen on]:port:' \
          '--no-server[disable the built-in web server]' \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      clean|deploy|rebuild)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
