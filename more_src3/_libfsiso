#compdef fsisoinfo fsisomount
# _libfsiso — libfsiso tools (libyal ISO 9660 / Joliet / Rock Ridge / UDF parser; fsisoinfo dumps volume descriptors + path tables + directory records, fsisomount FUSE-mounts the ISO read-only; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E entry filter, -F path filter, -X exclusive; positional argument is the .iso image)
# upstream: https://github.com/libyal/libfsiso
# Flags from libyal/libfsiso fsisotools/fsisoinfo.c on tip.

_libfsiso() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[entry filter]:entry:' \
        '-F+[path filter]:path:' \
        '-X[exclusive]' \
        '*:ISO image:_files -g "*.iso"'
}

_libfsiso "$@"
