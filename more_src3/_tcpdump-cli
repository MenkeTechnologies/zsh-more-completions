#compdef tcpdump-cli
# _tcpdump-cli — Van Jacobson tcpdump dump traffic on a network CLI alias (tcpdump team, C); custom argparse
# upstream: https://github.com/the-tcpdump-group/tcpdump

_tcpdump-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[read filenames from file]' \
        '-A[print packets in ASCII]' \
        '-b[print AS in BGP packets]' \
        '-B+[buffer size kb]:n:' \
        '--buffer-size=+[buffer size kb]:n:' \
        '-c+[stop after n packets]:n:' \
        '--count[print packet count]' \
        '-C+[file size limit mb]:n:' \
        '-d[dump compiled packet matching code]' \
        '-dd[dump as C code]' \
        '-ddd[dump as decimal numbers]' \
        '-D[list interfaces]' \
        '--list-interfaces[list interfaces]' \
        '-e[print link-level header]' \
        '-E+[spi@ipaddr algo:secret]:str:' \
        '-f[print foreign network addresses numerically]' \
        '-F+[BPF filter file]:file:_files' \
        '-G+[rotate seconds]:n:' \
        '-i+[interface]:_net_interfaces' \
        '--interface=+[interface]:_net_interfaces' \
        '-I[monitor mode]' \
        '--monitor-mode[monitor mode]' \
        '-j+[timestamp type]:t:(host host_lowprec host_hiprec adapter adapter_unsynced)' \
        '--time-stamp-type=+[timestamp type]:t:(host host_lowprec host_hiprec adapter adapter_unsynced)' \
        '-J[list timestamp types]' \
        '--list-time-stamp-types[list timestamp types]' \
        '-K[no checksum verification]' \
        '--dont-verify-checksums[no checksum verification]' \
        '-l[buffered line output]' \
        '-L[list link types]' \
        '--list-data-link-types[list link types]' \
        '-m+[smi MIB module]:file:_files' \
        '-M+[secret for TCP-MD5]:str:' \
        '-n[no name resolution]' \
        '-nn[no port name resolution either]' \
        '-N[no domain name]' \
        '--number[print packet number]' \
        '-O[no optimizer]' \
        '--no-optimize[no optimizer]' \
        '-p[no promiscuous mode]' \
        '--no-promiscuous-mode[no promiscuous mode]' \
        '-q[quiet, less verbose]' \
        '-Q+[direction]:d:(in out inout)' \
        '--direction=+[direction]:d:(in out inout)' \
        '-r+[read from file]:file:_files -g "*.pcap*"' \
        '-s+[snaplen]:n:' \
        '--snapshot-length=+[snaplen]:n:' \
        '-S[print absolute TCP sequence numbers]' \
        '-t[no timestamps]' \
        '-tt[seconds since epoch timestamps]' \
        '-ttt[delta in microseconds]' \
        '-tttt[unformatted date+time]' \
        '-ttttt[delta since first packet]' \
        '-T+[type]:t:(aodv carp cnfp lmp pgm pgm_zmtp1 ptp radius rpc rtp rtcp snmp someip tftp vat vxlan wb zmtp1)' \
        '-u[print undecoded NFS handles]' \
        '-U[unbuffered]' \
        '--packet-buffered[unbuffered]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-vvv[most verbose]' \
        '-w+[write to file]:file:_files -g "*.pcap*"' \
        '-W+[file count limit]:n:' \
        '-x[print packet in hex]' \
        '-xx[print packet in hex with link]' \
        '-X[print packet in hex+ASCII]' \
        '-XX[print packet in hex+ASCII with link]' \
        '-y+[link type]:str:' \
        '--linktype=+[link type]:str:' \
        '-z+[postrotate command]:str:' \
        '--postrotate-command=+[postrotate command]:str:' \
        '-Z+[user]:_users' \
        '--relinquish-privileges=+[user]:_users' \
        '--time-stamp-precision=+[precision]:m:(nano micro)' \
        '*:filter:'
}

_tcpdump-cli "$@"
