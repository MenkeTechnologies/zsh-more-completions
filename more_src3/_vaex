#compdef vaex
# _vaex — Maarten Breddels Vaex out-of-core hybrid Apache-Arrow + memory-mapped HDF5 DataFrame library CLI (vaexio team, Python); argparse
# upstream: https://github.com/vaexio/vaex

_vaex() {
    local -a sub=(
        'server:run jupyter style server'
        'meta:show metadata for a dataset'
        'convert:convert formats'
        'export:export dataset'
        'alias:alias subcommands'
        'cluster:start cluster'
        'distributed:start distributed'
        'webserver:start web server'
        'settings:show settings'
        'docs:open docs'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--colored[force color]' \
        '--no-color[disable color]' \
        '--logging=+[level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--logging-format=+[format]:str:' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vaex subcommand' sub ;;
        args)
            case $words[1] in
                convert|export) _arguments \
                    '--input=+[input file]:file:_files -g "*.hdf5 *.h5 *.arrow *.parquet *.csv *.feather *.json *.fits"' \
                    '-i+[input file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--format=+[format]:f:(hdf5 arrow parquet csv feather)' \
                    '--shuffle[shuffle rows]' \
                    '--virtual=+[virtual columns]:str:' \
                    '*:file:_files' ;;
                server|webserver) _arguments \
                    '--host=+[bind host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--workers=+[N]:n:' \
                    '--allow-origin=+[origin]:str:' \
                    '--add-example-datasets[include example datasets]' \
                    '*:dataset:_files' ;;
                meta) _arguments '*:file:_files' ;;
                cluster|distributed) _arguments \
                    '--scheduler=+[scheduler url]:url:_urls' \
                    '--n-workers=+[N]:n:' ;;
            esac
            ;;
    esac
}

_vaex "$@"
