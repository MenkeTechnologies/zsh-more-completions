#compdef sphinx-build sphinx-quickstart sphinx-apidoc
# Documentation: https://www.sphinx-doc.org/en/master/man/sphinx-build.html
# Reference accessed: 2026-05-21
# Verified: sphinx-doc.org master manpages for sphinx-build,
# sphinx-quickstart, sphinx-apidoc. Modern long-form aliases
# (--builder, --write-all, --fresh-env, --doctree-dir, --conf-dir,
# --isolated, --define, --html-define, --no-color, --silent,
# --warning-file, --fail-on-warning, --show-traceback, --pdb,
# --exception-on-warning, --tocfile, --remove-old) are documented
# upstream; legacy short flags retained for compatibility.

# Zsh completion for Sphinx documentation tools

_sphinx() {
  local curcontext="$curcontext" state line ret=1
  local prog=${words[1]:t}

  case $prog in
    sphinx-build)
      _arguments -s -S \
        '-M+[use make-mode builder]:builder:(html dirhtml singlehtml htmlhelp qthelp devhelp epub latex latexpdf latexpdfja text man texinfo info gettext changes xml pseudoxml linkcheck doctest coverage clean)' \
        '(-b --builder)'{-b+,--builder=}'[select a builder]:builder:(html dirhtml singlehtml htmlhelp qthelp devhelp epub latex latexpdf latexpdfja text man texinfo info gettext changes xml pseudoxml linkcheck doctest coverage)' \
        '(-a --write-all)'{-a,--write-all}'[write all files (default: only write new and changed files)]' \
        '(-E --fresh-env)'{-E,--fresh-env}'[do not use a saved environment, always read all files]' \
        '(-d --doctree-dir)'{-d+,--doctree-dir=}'[path for the cached environment and doctree files]:cache dir:_files -/' \
        '(-j --jobs)'{-j+,--jobs=}'[build in parallel with N processes]:n:' \
        '(-c --conf-dir)'{-c+,--conf-dir=}'[path where configuration file is located]:config dir:_files -/' \
        '(-C --isolated)'{-C,--isolated}'[use no configuration file at all]' \
        '*'{-D+,--define=}'[override a setting in configuration file]:setting=value:' \
        '*'{-A+,--html-define=}'[pass a value into HTML templates]:name=value:' \
        '*'{-t+,--tag=}'[define tag]:tag:' \
        '(-n --nitpicky)'{-n,--nitpicky}'[nit-picky mode, warn about all missing references]' \
        '(-N --no-color)'{-N,--no-color}'[do not emit colored output]' \
        '--color[emit colored output (default if terminal)]' \
        '*'{-v,--verbose}'[increase verbosity]' \
        '(-q --quiet)'{-q,--quiet}'[no output on stdout, only warnings on stderr]' \
        '(-Q --silent)'{-Q,--silent}'[no output at all]' \
        '(-w --warning-file)'{-w+,--warning-file=}'[write warnings to a file]:warning file:_files' \
        '(-W --fail-on-warning)'{-W,--fail-on-warning}'[turn warnings into errors]' \
        '--keep-going[with -W, keep going when getting warnings]' \
        '--exception-on-warning[raise exception on warning]' \
        '(-T --show-traceback)'{-T,--show-traceback}'[show full traceback on exception]' \
        '(-P --pdb)'{-P,--pdb}'[run Pdb on exception]' \
        '(-h --help)'{-h,--help}'[show help message]' \
        '--version[show version]' \
        '1:source dir:_files -/' \
        '2:output dir:_files -/' \
        '*:filenames:_files' \
        && ret=0
      ;;
    sphinx-quickstart)
      _arguments -s -S \
        '-q[quiet mode]' \
        '--quiet[quiet mode]' \
        '-p+[project name]:project name:' \
        '--project=[project name]:project name:' \
        '-a+[author name]:author:' \
        '--author=[author name]:author:' \
        '-v+[version of project]:version:' \
        '-r+[release of project]:release:' \
        '--release=[release of project]:release:' \
        '-l+[document language]:language:' \
        '--language=[document language]:language:' \
        '--suffix=[source file suffix]:suffix:' \
        '--master=[master document name]:name:' \
        '--sep[separate source and build dirs]' \
        '--no-sep[do not separate source and build dirs]' \
        '(-m --use-make-mode)'{-m,--use-make-mode}'[use make-mode for Makefile/make.bat]' \
        '--dot=[replacement for dot in _templates]:replacement:' \
        '--ext-autodoc[enable autodoc extension]' \
        '--ext-doctest[enable doctest extension]' \
        '--ext-intersphinx[enable intersphinx extension]' \
        '--ext-todo[enable todo extension]' \
        '--ext-coverage[enable coverage extension]' \
        '--ext-imgmath[enable imgmath extension]' \
        '--ext-mathjax[enable mathjax extension]' \
        '--ext-ifconfig[enable ifconfig extension]' \
        '--ext-viewcode[enable viewcode extension]' \
        '--ext-githubpages[enable GitHub Pages extension]' \
        '--extensions=[enable given extensions]:extensions:' \
        '--makefile[create Makefile]' \
        '--no-makefile[do not create Makefile]' \
        '--batchfile[create batchfile]' \
        '--no-batchfile[do not create batchfile]' \
        '-t+[define tag]:tag:' \
        '-d+[define templatevar]:name=value:' \
        '(-h --help)'{-h,--help}'[show help message]' \
        '1:root path:_files -/' \
        && ret=0
      ;;
    sphinx-apidoc)
      _arguments -s -S \
        '-o+[output directory]:output dir:_files -/' \
        '-q[quiet output]' \
        '-f[overwrite existing files]' \
        '--force[overwrite existing files]' \
        '-l[follow symbolic links]' \
        '--follow-links[follow symbolic links]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-s+[file suffix]:suffix:' \
        '--suffix=[file suffix]:suffix:' \
        '-d+[max depth of TOC]:depth:' \
        '--maxdepth=[max depth of TOC]:depth:' \
        '--tocfile=[TOC filename]:name:' \
        '--remove-old[remove obsolete generated files]' \
        '-T[do not create a table of contents file]' \
        '--no-toc[do not create a table of contents file]' \
        '-F[generate a full project]' \
        '--full[generate a full project]' \
        '-e[put each module file in its own page]' \
        '--separate[put each module file in its own page]' \
        '-E[do not create headings for modules/packages]' \
        '--no-headings[do not create headings for modules/packages]' \
        '-P[include "_private" modules]' \
        '--private[include "_private" modules]' \
        '--implicit-namespaces[interpret module paths as implicit namespace packages]' \
        '-M[put module documentation before submodule documentation]' \
        '--module-first[put module documentation before submodule documentation]' \
        '-a+[append module_path to sys.path]:module path:_files -/' \
        '-H+[project name]:name:' \
        '-A+[project author]:author:' \
        '-V+[project version]:version:' \
        '-R+[project release]:release:' \
        '-t+[template directory]:template dir:_files -/' \
        '--templatedir=[template directory]:template dir:_files -/' \
        '(-h --help)'{-h,--help}'[show help message]' \
        '--version[show version]' \
        '1:module path:_files -/' \
        '*:exclude pattern:' \
        && ret=0
      ;;
  esac

  return ret
}

_sphinx "$@"
