#compdef verco
# Documentation: https://github.com/matheuslessarodrigues/verco (archived; mirror: git.sr.ht/~lessa/verco)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: verco is a TUI client launched bare (no documented CLI flags beyond default --help/--version)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:directory:_directories' && ret=0

return ret
