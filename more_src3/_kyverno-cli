#compdef kyverno-cli
# Documentation: https://kyverno.io/docs/kyverno-cli/reference/kyverno/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# `kyverno-cli` is the package name used by some distributions; the actual
# binary is `kyverno`. This delegates to the _kyverno completion if it is
# present on the $fpath, otherwise we recreate the minimal command list.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:apply policies to resources'
  'completion:generate the autocompletion script'
  'create:create various Kyverno resources'
  'docs:generate reference documentation'
  'fix:fix policies and tests'
  'jp:command-line interface to JMESPath'
  'json:run tests against JSON-compatible payloads (experimental)'
  'migrate:convert resources to stored version'
  'oci:manage Kyverno OCI artifacts'
  'test:run tests on policies'
  'version:print version information'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '(-v --v)'{-v+,--v=}'[log level verbosity]:level:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kyverno-cli command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      jp)
        _arguments '1:subcommand:(function parse query)' && ret=0
        ;;
      json)
        _arguments '1:subcommand:(scan)' && ret=0
        ;;
      oci)
        _arguments '1:subcommand:(pull push)' && ret=0
        ;;
      create)
        _arguments '1:subcommand:(cluster-role exception metrics-config test user-info values)' && ret=0
        ;;
    esac
    ;;
esac

return ret
