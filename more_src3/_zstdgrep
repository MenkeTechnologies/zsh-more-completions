#compdef zstdgrep
# Documentation: https://manpages.debian.org/unstable/zstd/zstdgrep.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# zstdgrep(1) passes grep-flags and pattern to grep(1); only `--` is a
# native separator. We delegate to grep flag completion via _grep where
# possible and present common pass-through flags.

local -a arguments

arguments=(
    '-c[count matching lines (passed to grep)]'
    '-h[suppress filename prefix (passed to grep)]'
    '-i[case insensitive (passed to grep)]'
    '-l[list matching files (passed to grep)]'
    '-n[show line numbers (passed to grep)]'
    '-v[invert match (passed to grep)]'
    '-e[specify pattern (passed to grep)]:pattern'
    '-G[use basic regular expressions (passed to grep)]'
    '-E[use extended regular expressions (passed to grep)]'
    '-F[use fixed strings (passed to grep)]'
    '-P[use Perl regular expressions (passed to grep)]'
    '--color=[color output (passed to grep)]:when:(auto always never)'
    '--[end of options]'
    '1:pattern:'
    '*:zstd file:_files -g "*.{zst,zstd}"'
)

_arguments -s -S $arguments
