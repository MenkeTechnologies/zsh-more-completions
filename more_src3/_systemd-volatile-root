#compdef systemd-volatile-root
# _systemd-volatile-root (systemd helper that remounts /usr read-only and stacks a tmpfs over / when systemd.volatile=yes/overlay is set on the kernel command line; takes no positional arguments — runs once during initrd boot)
# upstream: https://github.com/systemd/systemd (src/volatile-root)
# Argument shape from systemd src/volatile-root/volatile-root.c on tip.

_systemd-volatile-root() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]'
}

_systemd-volatile-root "$@"
