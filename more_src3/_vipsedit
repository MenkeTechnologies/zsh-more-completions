#compdef vipsedit
# Documentation: https://www.libvips.org/API/current/vipsedit.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above and libvips/libvips
# tools/vipsedit.c master source.

# vipsedit: edit fields/metadata of a libvips .v image header in place
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-n --endian)'{-n+,--endian=}'[set byte order]:endian:(little big)' \
  '(-w --width -x --xsize)'{-w+,--width=,-x+,--xsize=}'[set width]:n:' \
  '(-h --height -y --ysize)'{-y+,--ysize=}'[set height]:n:' \
  '(-b --bands)'{-b+,--bands=}'[set number of bands]:n:' \
  '(-f --format)'{-f+,--format=}'[set band format]:format:(uchar char ushort short uint int float double complex dpcomplex)' \
  '(-i --interpretation -t --type)'{-i+,--interpretation=,-t+,--type=}'[set interpretation type]:type:(multiband b-w histogram xyz lab cmyk labq rgb cmc lch labs srgb yxy fourier rgb16 grey16 matrix scrgb hsv)' \
  '(-c --coding)'{-c+,--coding=}'[set coding]:coding:(none labq rad)' \
  '(-X --xres)'{-X+,--xres=}'[set Xres header field]:n:' \
  '(-Y --yres)'{-Y+,--yres=}'[set Yres header field]:n:' \
  '(-u --xoffset)'{-u+,--xoffset=}'[set Xoffset header field]:n:' \
  '(-v --yoffset)'{-v+,--yoffset=}'[set Yoffset header field]:n:' \
  '(-e --setext)'{-e,--setext}'[replace metadata from stdin]' \
  '*:vips images:_files -g "*.(v|vips)"' && ret=0
return ret
