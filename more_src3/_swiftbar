#compdef swiftbar
# _swiftbar — Alex Ostrovsky SwiftBar BitBar-like macOS menu bar app CLI (swiftbar / Alex Ostrovsky, Swift); custom argparse
# upstream: https://github.com/swiftbar/SwiftBar

_swiftbar() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--add-plugin=+[install plugin from URL]:url:_urls' \
        '--remove-plugin=+[remove plugin by name]:str:' \
        '--enable-plugin=+[enable plugin]:str:' \
        '--disable-plugin=+[disable plugin]:str:' \
        '--run-plugin=+[run plugin]:str:' \
        '--refresh-plugin=+[refresh plugin]:str:' \
        '--refresh-all[refresh all plugins]' \
        '--list-plugins[list plugins]' \
        '--get-folder[print plugin folder path]' \
        '--set-folder=+[set plugin folder path]:dir:_files -/' \
        '--toggle-icon[toggle icon visibility]' \
        '--set-icon=+[set icon visibility]:b:(true false)' \
        '--show[show menu bar]' \
        '--hide[hide menu bar]' \
        '--quit[quit SwiftBar]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '*:arg:'
}

_swiftbar "$@"
