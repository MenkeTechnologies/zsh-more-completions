#compdef spamass-milter
# Documentation: https://manpages.debian.org/bookworm/spamass-milter/spamass-milter.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian manpage at the URL above.

# spamass-milter: SpamAssassin integration as a sendmail/postfix milter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[milter socket pathname]:path:_files' \
  '-b[forward tagged spam to address (removes original recipients)]:addr:' \
  '-B[forward tagged spam to address (keeps original recipients)]:addr:' \
  '-C[override SpamAssassin rejection code (default 5.7.1)]:code:' \
  '-d[debug flags/tokens]:flags:' \
  '-D[remote spamd host (deprecated)]:host:_hosts' \
  '-e[default domain (passes user@domain to spamc)]:domain:' \
  '-f[fork milter into background]' \
  '-i[ignore mail from networks (CIDR list)]:networks:' \
  '-I[ignore mail from SMTP AUTH authenticated senders]' \
  '-m[disable subject/content-type and body modifications]' \
  '-M[disable all SpamAssassin header creation]' \
  '-P[PID file]:file:_files' \
  '-r[reject mail scoring at or above threshold]:score:' \
  '-R[custom rejection message text]:text:' \
  '-S[path to sendmail (used with -x)]:file:_files' \
  '-u[default username (passes to spamc for user preferences)]:user:_users' \
  '-x[expand recipient address through sendmail]' \
  '*::spamc args:_files' && ret=0
return ret
