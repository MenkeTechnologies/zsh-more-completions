#compdef hotspot
# Documentation: https://github.com/KDAB/hotspot
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--sysroot=[path to sysroot for remote profiling]:directory:_directories' \
  '--kallsyms=[path to kallsyms file]:file:_files' \
  '--debugPaths=[colon-separated debug symbol paths]:paths' \
  '--extraLibPaths=[colon-separated extra library paths]:paths' \
  '--appPath=[folder with application executables/libraries]:directory:_directories' \
  '--sourcePaths=[colon-separated source code search paths]:paths' \
  '--arch=[target architecture for unwinding]:architecture:' \
  '--perf-binary=[path to perf binary]:path:_files' \
  '--objdump-binary=[path to objdump binary]:path:_files' \
  '--exportTo=[export analyzed data to .perfparser file]:path:_files' \
  '*:perf data file:_files'

