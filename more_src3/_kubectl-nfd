#compdef kubectl-nfd
# _kubectl-nfd — NFD kubectl plugin (kubernetes-sigs/node-feature-discovery)
# upstream: https://github.com/kubernetes-sigs/node-feature-discovery
# Subcommands from cmd/kubectl-nfd/subcmd/{root,dryrun,test,validate}.go on tip.

_kubectl-nfd() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--context=[kubeconfig context]:ctx:' \
        '--cluster=[kubeconfig cluster]:cluster:' \
        '--user=[kubeconfig user]:user:' \
        '(-n --namespace)'{-n,--namespace=}'[Kubernetes namespace]:ns:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                dryrun:'render a NodeFeatureRule into the labels it would produce'
                test:'test a NodeFeatureRule against live cluster features'
                validate:'validate NodeFeatureRule and config files'
            )
            _describe -t commands 'kubectl-nfd command' cmds
            ;;
        args)
            case $words[1] in
                dryrun|test|validate)
                    _arguments \
                        '(-f --file)'{-f,--file=}'[NodeFeatureRule or config YAML file]:file:_files -g "*.(yml|yaml)(-.)"'
                    ;;
            esac
            ;;
    esac
}

_kubectl-nfd "$@"
