#compdef virt-rescue
# _virt-rescue — libguestfs virt-rescue (boot a rescue shell against a libvirt VM image; -a disk, -d domain, -c libvirt URI, -m mount, --network enable virtual networking, --suggest print mount commands, --ro read-only, --append kernel cmdline, --scratch add scratch disks, --selinux force SELinux)
# upstream: https://github.com/libguestfs/libguestfs (rescue)
# Flags from libguestfs rescue/rescue_main.ml on tip.

_virt-rescue() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*-a+[disk image]:file:_files' \
        '*-d+[domain]:domain:' \
        '-c+[libvirt URI]:uri:' \
        '*-m+[mount spec]:mountspec:' \
        '--ro[read-only]' \
        '--rw[read-write]' \
        '--append+[kernel cmdline append]:cmdline:' \
        '--network[enable virtual network]' \
        '--scratch+[scratch disks count]:n:' \
        '--smp+[smp]:n:' \
        '--memsize+[memory MiB]:mb:' \
        '--selinux[enable SELinux]' \
        '--suggest[print mount suggestions]' \
        '--format=*[disk format]:fmt:(raw qcow2 vmdk vdi)'
}

_virt-rescue "$@"
