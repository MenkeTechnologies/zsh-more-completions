#compdef llama-fit-params
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/tools/fit-params/fit-params.cpp
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/common/arg.cpp
# Reference accessed: 2026-05-27
# Verified: upstream common_params_parse(LLAMA_EXAMPLE_FIT_PARAMS) in tools/fit-params/fit-params.cpp + --fit* flags in common/arg.cpp

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[model path]:model:_files -g "*.gguf"' \
  '--model=[model path]:model:_files -g "*.gguf"' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-ngl+[number of layers to store in VRAM]:layers' \
  '--gpu-layers=[number of layers to store in VRAM]:layers' \
  '--split-mode=[how to split the model]:mode:(none layer row)' \
  '--main-gpu=[main GPU]:gpu' \
  '--tensor-split=[how to split tensors]:split' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force keep model in RAM]' \
  '-fit+[whether to adjust unset arguments to fit in device memory]:state:(on off)' \
  '--fit=[whether to adjust unset arguments to fit in device memory]:state:(on off)' \
  '-fitp+[print the estimated required memory]:state:(on off)' \
  '--fit-print=[print the estimated required memory]:state:(on off)' \
  '-fitt+[target margin per device for --fit, comma-separated MiB list]:targets' \
  '--fit-target=[target margin per device for --fit, comma-separated MiB list]:targets' \
  '-fitc+[minimum ctx size that can be set by --fit]:n' \
  '--fit-ctx=[minimum ctx size that can be set by --fit]:n' \
  '--check-tensors[check model tensor data for invalid values]' \
  '--override-kv=[override model metadata by key]:kv' && ret=0

return ret
