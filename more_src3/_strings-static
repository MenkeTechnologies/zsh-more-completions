#compdef strings-static
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/strings.1.html
# Reference accessed: 2026-05-21
# Verified: GNU binutils strings(1) manpage. strings-static is the
# statically linked variant shipped by some distributions; flag
# surface is identical to strings.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-a,--all}'[scan whole file, not only data section]' \
  {-d,--data}'[only loaded initialized data sections]' \
  {-f,--print-file-name}'[print name of file before each string]' \
  {-n+,--bytes=}'[minimum string length]:n:' \
  '-w[do not require strings to be terminated]' \
  {-o,--radix=o}'[print offset in octal]' \
  {-t+,--radix=}'[print offset; specify radix]:radix:(o d x)' \
  {-T+,--target=}'[binary file format]:bfd:' \
  {-e+,--encoding=}'[character encoding]:encoding:(s S b l B L)' \
  {-U+,--unicode=}'[Unicode display mode]:mode:(default invalid locale escape hex highlight)' \
  {-s+,--output-separator=}'[output separator]:sep:' \
  '--include-all-whitespace[include all whitespace as graphic chars]' \
  '--help[show help]' \
  '(-v -V --version)'{-v,-V,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
