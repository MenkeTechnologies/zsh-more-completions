#compdef uobjnew uobjnew-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/lib/uobjnew.py argparse)
# Reference accessed: 2026-05-29
# uobjnew — summarize new object allocations in high-level languages via USDT (BCC/eBPF). C/Java/Ruby/Tcl.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --language)'{-l,--language=}'[language to trace]:lang:(c java ruby tcl)' \
  '(-C --top-count)'{-C,--top-count=}'[number of most frequently allocated types to print]:N:' \
  '(-S --top-size)'{-S,--top-size=}'[number of largest types by allocated bytes to print]:N:' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (process id to attach to):_pids' \
  '2:interval (seconds, optional):' \
  && ret=0

return ret
