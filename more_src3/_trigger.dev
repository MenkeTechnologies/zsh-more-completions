#compdef trigger.dev
# Documentation: https://trigger.dev/docs/cli-introduction
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Trigger.dev CLI

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'login:Authenticate with Trigger.dev'
  'init:Initialize Trigger.dev in a project'
  'dev:Run tasks locally'
  'deploy:Deploy tasks'
  'update:Update Trigger.dev packages'
  'whoami:Show logged-in user details'
  'logout:Log out'
  'list-profiles:List CLI profiles'
  'switch:Switch between profiles'
)

_arguments -s -S \
  '(-v --version)'{-v,--version}'[display version]' \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-l --log-level)'{-l,--log-level}'[set logging verbosity]:level:(debug info log warn error none)' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'trigger.dev command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (login)
        _arguments -s -S \
          '--api-url=[self-hosted API URL]:url:' \
          '--profile=[profile name]:profile:' && ret=0
        ;;
      (dev)
        _arguments -s -S \
          '(-c --config)'{-c,--config}'[path to config file]:file:_files' \
          '(-p --project-ref)'{-p,--project-ref}'[project reference]:ref:' \
          '--env-file=[path to env file]:file:_files' && ret=0
        ;;
      (deploy)
        _arguments -s -S \
          '(-e --env)'{-e,--env}'[environment]:env:(prod staging preview)' && ret=0
        ;;
      (switch)
        _arguments -s -S '1:profile:' && ret=0
        ;;
    esac
    ;;
esac

return ret
