#compdef hex
# _hex-bin — Hex Erlang/Elixir package manager (Hex project, Erlang); used by mix and rebar3 to fetch packages
# upstream: https://github.com/hexpm/hex

_hex-bin() {
    local -a sub=(
        'audit:audit installed packages'
        'build:build package'
        'config:configure hex'
        'docs:open docs'
        'info:show package info'
        'organization:organization commands'
        'outdated:show outdated'
        'owner:owner commands'
        'package:package commands'
        'publish:publish package'
        'registry:registry commands'
        'repo:repo commands'
        'retire:retire package'
        'search:search packages'
        'unretire:unretire package'
        'user:user commands'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hex subcommand' sub ;;
        args)
            case $words[1] in
                user) _arguments '1:user cmd:(register list_keys delete_keys auth deauth passphrase reset_password whoami)' ;;
                package) _arguments '1:package cmd:(fetch diff)' '*:args:' ;;
                owner) _arguments '1:owner cmd:(add transfer list remove)' '*:args:' ;;
                organization) _arguments '1:org cmd:(auth deauth list key generate)' '*:args:' ;;
            esac
            ;;
    esac
}

_hex-bin "$@"
