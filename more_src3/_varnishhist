#compdef varnishhist
# Documentation: https://manpages.debian.org/testing/varnish/varnishhist.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for varnishhist - varnish request histogram

_arguments -s -S \
  '-h[show help]' \
  '-V[show version]' \
  '-B+[factor to bend time by (when reading from a vsl file)]:factor:' \
  '-d[process log records at head of log then exit]' \
  '-g+[grouping of log records]:grouping:(request vxid)' \
  '-n+[varnish working directory of instance]:workdir:' \
  '-p+[seconds between screen refreshes]:seconds:' \
  '-P+[profile (responsetime, reqbodytime, size, Bereqtime, Beresptime, BerespBodytime, Besize, custom)]:profile:' \
  '-q+[VSL query]:query:' \
  '-r+[read log in binary file format]:file:_files' \
  '-t+[initial VSM connection timeout (seconds or off)]:seconds:'
