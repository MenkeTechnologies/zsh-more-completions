#compdef surfaceMeshTriangulate
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceMeshTriangulate — triangulate boundary patches into a surface (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-time+[restrict to selected times]:times:_default' \
    '-latestTime[use latest time]' \
    '-excludeProcPatches[exclude processor patches]' \
    '-patches+[wildcard list of patches]:list:_default' \
    '-faceZones+[wildcard list of faceZones]:list:_default' \
    '-region+[region name]:region:_default' \
    '1:output surface file:_files' \
    && ret=0

return ret
