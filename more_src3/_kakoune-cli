#compdef kakoune-cli kak-cli
# _kakoune-cli — Kakoune modal editor convenience CLI wrapper (mawww, C++); kak entrypoint
# upstream: https://github.com/mawww/kakoune

_kakoune-cli() {
    _arguments \
        '--help[show help]' \
        '-help[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-c+[connect to session]:session:' \
        '-e+[execute initial command]:cmd:' \
        '-E+[execute final command]:cmd:' \
        '-n[no kakrc]' \
        '-s+[create session with name]:session:' \
        '-l[list sessions]' \
        '-clear[clear orphan sessions]' \
        '-d[run in daemon mode]' \
        '-p+[pipe stdin to session]:session:' \
        '-f+[filter mode with selections]:keystrokes:' \
        '-i+[backup files extension]:ext:' \
        '-q[quiet]' \
        '-ui=+[ui]:ui:(ncurses dummy json)' \
        '-r+[ro]:file:_files' \
        '-debug=+[debug categories]:cats:' \
        '*:file:_files'
}

_kakoune-cli "$@"
