#compdef snmp_exporter
# Documentation: https://github.com/prometheus/snmp_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--snmp.module-concurrency=[max number of modules to query concurrently]:count:' \
  '--snmp.wrap-large-counters[wrap 64-bit counters that exceed max value]' \
  '--config.file=[path to configuration file]:file:_files' \
  '--config.expand-environment-variables[expand environment variables in config file]' && ret=0

return ret
