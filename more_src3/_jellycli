#compdef jellycli
# Documentation: https://github.com/tryffel/jellycli
# Source: tryffel/jellycli cmd/ — terminal music player for Jellyfin (Go, spf13/cobra).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _jc_cmds
_jc_cmds=(
    'env:print environment information'
    'gui:start the TUI explicitly'
    'refresh:refresh local library cache'
    'version:print version'
)

_arguments -C \
    '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
    '--no-gui[disable GUI / TUI]' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'jellycli command' _jc_cmds && ret=0
        ;;
esac

return ret
