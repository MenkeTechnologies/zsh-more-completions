#compdef xfsdist xfsdist-bpfcc
# _xfsdist — XFS operation latency distribution histogram (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/xfsdist.py (argparse).

_xfsdist() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-T --notimestamp)'{-T,--notimestamp}'[do not include timestamp on interval output]'
        '(-m --milliseconds)'{-m,--milliseconds}'[output in milliseconds]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '1:interval seconds:'
        '2:output count:'
    )
    _arguments $args
}

_xfsdist "$@"
