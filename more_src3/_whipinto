# WHAT IT IS
#   whipinto is one of eight binaries in the live777 workspace — a
#   "very simple, high performance, edge WebRTC SFU" project.  whipinto
#   converts an RTSP / RTP / SDP media source into a WebRTC-HTTP Ingestion
#   Protocol (WHIP, RFC 9725-track) stream and pushes it to a WHIP-compatible
#   media server endpoint (such as live777 itself, MediaMTX, or Cloudflare
#   Stream).  Companion binary `whepfrom` does the reverse — it subscribes
#   via WebRTC-HTTP Egress Protocol (WHEP) and emits RTSP/RTP locally.
#   Together with `live777` (the SFU server), `liveman` (a multi-instance
#   manager), and `livecam` they form a complete clap-derive Rust toolchain
#   for WebRTC media ingest/egress at the edge.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/whipinto.rs clap Args derive)
#   whipinto [OPTIONS] --whip <WHIP>
#
#   Options:
#     -v                          Verbose mode (repeatable: -v info, -vv debug,
#                                 -vvv trace; default warn)
#     -i, --input <INPUT>         rtsp://[user]:[pass]@[ip]:[port]/[stream]
#                                 OR a path to <stream.sdp>
#                                 [default: rtsp://0.0.0.0:8554]
#     -w, --whip <WHIP>           The WHIP server endpoint to POST the SDP
#                                 offer to.   Required.
#                                 e.g. https://example.com/whip/777
#     -t, --token <TOKEN>         Authentication token, sent as
#                                 'Authorization: Bearer <TOKEN>'
#         --command <COMMAND>     Run a command as a child process (e.g. an
#                                 ffmpeg pipeline producing the RTP source)
#     -h, --help                  Print help
#     -V, --version               Print version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `webrtc` crate from the webrtc-rs project
#   (https://github.com/webrtc-rs/webrtc) — the pure-Rust port of Pion's
#   reference WebRTC stack — pinned via the workspace.dependencies block
#   in Cargo.toml at rev 4da5280.  Verified via:
#     gh api repos/binbat/live777/contents/Cargo.toml
#       → [workspace.dependencies] webrtc = { git = ".../webrtc", rev = ... }
#   This entry is the Rust=111 leader bump that OPENS Axis 56
#   (WebRTC Media Library), pairing with future Go=pion/webrtc and
#   TS-Node=node-webrtc/simple-peer poles to close the axis at 1/1/1.
#
#   No completion for `whipinto` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_whipinto() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '*-v[verbose mode (repeatable: -v info, -vv debug, -vvv trace)]' \
        '(-i --input)'{-i+,--input=}'[input RTSP URL or SDP file]:input source:_whipinto_input' \
        '(-w --whip)'{-w+,--whip=}'[WHIP server endpoint to POST SDP offer to (required)]:whip endpoint URL:_urls' \
        '(-t --token)'{-t+,--token=}'[Bearer auth token sent in HTTP header]:bearer token:' \
        '--command=[run a command as child process (e.g. ffmpeg pipeline)]:child command:_command_names -e' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' && ret=0

    return ret
}

(( $+functions[_whipinto_input] )) ||
_whipinto_input() {
    if [[ -prefix rtsp:// || -prefix rtp:// || -prefix udp:// ]]; then
        _message 'RTSP/RTP URL (rtsp://user:pass@host:port/stream)'
    else
        _alternative \
            'sdp-files:SDP file:_files -g "*.sdp"' \
            'urls:RTSP URL:(rtsp://0.0.0.0:8554)'
    fi
}

_whipinto "$@"
