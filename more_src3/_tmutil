#compdef tmutil
# Documentation: tmutil usage (macOS 26 Time Machine)
# Source: command-line Time Machine controller.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'addexclusion:add files/volumes to backup exclusion'
    'associatedisk:associate disk with previous backup directory'
    'calculatedrift:compute drift in a backup machine-directory'
    'compare:compare two snapshots or paths'
    'delete:delete a backup'
    'deleteinprogress:delete in-progress backup'
    'deletelocalsnapshots:delete local APFS snapshots'
    'destinationinfo:print configured backup destinations'
    'disable:disable automatic backups'
    'enable:enable automatic backups'
    'help:show help for a verb'
    'inheritbackup:inherit ownership of a machine directory'
    'isexcluded:test whether a path is excluded'
    'latestbackup:print path to latest backup'
    'listbackups:list available backups'
    'listlocalsnapshotdates:list local snapshot dates'
    'listlocalsnapshots:list local snapshots'
    'localsnapshot:create a local snapshot now'
    'machinedirectory:print current machine directory'
    'removedestination:remove a destination ID'
    'removeexclusion:remove exclusion entries'
    'restore:restore files from a backup'
    'setdestination:add or set a backup destination'
    'snapshot:create a backup snapshot now'
    'startbackup:start a backup'
    'status:print current backup status'
    'stopbackup:stop a running backup'
    'thinlocalsnapshots:thin local snapshots'
    'uniquesize:size of unique data in a backup'
    'verifychecksums:verify checksums on a backup'
    'version:print version'
)

_arguments -C -s \
    '1:command:->verbs' \
    '*::args:_files' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
