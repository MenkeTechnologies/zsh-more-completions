#compdef llvm-debuginfod
# _llvm-debuginfod — LLVM debuginfod server (LLVM project, C++); serve debug info over HTTP per debuginfod protocol
# upstream: https://github.com/llvm/llvm-project

_llvm-debuginfod() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-p+[listen port]:port:' \
        '--port=+[listen port]:port:' \
        '-t+[min interval seconds]:sec:' \
        '--scan-interval=+[scan interval]:sec:' \
        '--max-concurrency=+[max concurrency]:n:' \
        '--host-interface=+[host interface]:iface:_net_interfaces' \
        '--use-thread-pool[use thread pool]' \
        '--verbose-logging[verbose logging]' \
        '*:dir:_files -/'
}

_llvm-debuginfod "$@"
