#compdef huffc
# Documentation: https://github.com/huff-language/huffc
# Source: huff-language/huffc src/bin.ts — Huff (low-level EVM assembly) compiler.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--base-path=[base path to the contracts]:dir:_files -/' \
    '--output-directory=[output directory]:dir:_files -/' \
    '--bytecode[generate and log bytecode]' \
    '-o+[output file]:file:_files' \
    '(-p --paste)'{-p,--paste}'[paste the output to the terminal]' \
    '(-n --no-linebreak)'{-n,--no-linebreak}'[omit newline character]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:file:_files -g "*.huff"' \
    && ret=0

return ret
