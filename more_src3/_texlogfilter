#compdef texlogfilter
# Documentation: texlogfilter --help
# Source: filter and colorize LaTeX/pdfLaTeX/LuaLaTeX/XeLaTeX engine output or log file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[print help]' \
    '(- *)--version[print version]' \
    '(--box --no-box)--box[show box warnings]' \
    '(--box --no-box)--no-box[mask box warnings]' \
    '(--ref --no-ref)--ref[show reference/citation warnings]' \
    '(--ref --no-ref)--no-ref[mask reference/citation warnings]' \
    '(--info --no-info)--info[show LaTeX info messages]' \
    '(--info --no-info)--no-info[mask LaTeX info messages]' \
    '(--filename --no-filename)--filename[print current file name]' \
    '(--filename --no-filename)--no-filename[do not print current file name]' \
    '--files-ext=[regex matching file extensions]:regex:' \
    '(--skips --no-skips)--skips[indicate skipped lines]' \
    '(--skips --no-skips)--no-skips[mask skipped lines]' \
    '--skip-marker=[marker for skipped lines (default ...)]:marker:' \
    '*--add-filter=[add user filter pattern (Perl regex)]:regex:' \
    '--full-log[show full log (colorize only)]' \
    '--errors-color=[color for error lines]:color:(red blue green yellow magenta cyan white black bold underline)' \
    '--warnings-color=[color for warning lines]:color:(red blue green yellow magenta cyan white black bold underline)' \
    '--infos-color=[color for info lines]:color:(red blue green yellow magenta cyan white black bold underline)' \
    '--skips-color=[color for skipped-line markers]:color:(red blue green yellow magenta cyan white black bold underline)' \
    '--user-color=[color for user-filter matches]:color:(red blue green yellow magenta cyan white black bold underline)' \
    '*:log file:_files -g "*.log"' \
    && ret=0

return ret
