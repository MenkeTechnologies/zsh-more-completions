#compdef tsc-watch
# _tsc-watch — TypeScript compiler with hooks on each compilation (gilamran/tsc-watch)
# upstream: https://github.com/gilamran/tsc-watch
# Flags from src/lib/args-manager.ts (custom argv parsing).

_tsc-watch() {
    _arguments \
        '--noWatch[do not pass --watch to tsc]' \
        '--onFirstSuccess=[command on first success]:cmd:' \
        '--onSuccess=[command on each success]:cmd:' \
        '--onFailure=[command on failure]:cmd:' \
        '--onEmit=[command on file emit]:cmd:' \
        '--onEmitDebounceMs=[debounce ms for --onEmit]:ms:' \
        '--onCompilationStarted=[command when compilation starts]:cmd:' \
        '--onCompilationComplete=[command when compilation completes]:cmd:' \
        '--noColors[suppress color output]' \
        '--noClear[do not clear console between compiles]' \
        '--silent[suppress all output]' \
        '--signalEmittedFiles[signal emitted file list]' \
        '--listEmittedFiles[pass through tsc --listEmittedFiles]' \
        '--compileCommand=[override the compile command (e.g. ttsc)]:cmd:' \
        '--maxNodeMem=[max old-space size for node (MB)]:mb:' \
        '--compiler=[path to alternate tsc binary]:file:_files' \
        '*::tsc args:'
}

_tsc-watch "$@"
