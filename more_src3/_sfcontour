#compdef sfcontour
# Documentation: http://www.ahay.org/RSF/sfcontour.html
# Source: ahay/src plot/main/contour.c — contour-line plot to vplot.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'cfile=[file containing contour values]: :_files -g "*.rsf(-.)"' \
    'nc=[number of contours]: :_default' \
    'c=[contour values (comma-separated vector)]: :_default' \
    'dc=[contour increment]: :_default' \
    'c0=[first contour value]: :_default' \
    'transp=[(y/n) transpose axes]: :(y n)' \
    'wantscalebar=[(y/n) draw scalebar]: :(y n)' \
    'scalebar=[(y/n) draw scalebar (alias)]: :(y n)' \
    'barlabel=[scale-bar label]: :_default' \
    'minval=[scalebar minimum value]: :_default' \
    'maxval=[scalebar maximum value]: :_default' \
    'allpos=[(y/n) contour only positive values]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
