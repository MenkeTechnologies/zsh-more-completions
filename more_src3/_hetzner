#compdef hetzner hetzner-cloud-cli
# _hetzner — Hetzner Cloud team hetzner Python CLI legacy and meta CLI for the Hetzner Cloud API predecessor to hcloud (hetznercloud team, Python); argparse
# upstream: https://github.com/hetznercloud/hcloud-python

_hetzner() {
    local -a sub=(
        'context:context subcommands'
        'datacenter:datacenter subcommands'
        'floating-ip:floating IP subcommands'
        'iso:ISO subcommands'
        'image:image subcommands'
        'location:location subcommands'
        'network:network subcommands'
        'placement-group:placement group subcommands'
        'primary-ip:primary IP subcommands'
        'server:server subcommands'
        'server-type:server type subcommands'
        'ssh-key:SSH key subcommands'
        'volume:volume subcommands'
        'load-balancer:load balancer subcommands'
        'load-balancer-type:LB type subcommands'
        'certificate:TLS certificate subcommands'
        'firewall:firewall subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--token=+[API token]:str:' \
        '--endpoint=+[API endpoint]:url:_urls' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--debug[debug logs]' \
        '--debug-file=+[debug log file]:file:_files' \
        '--poll-interval=+[seconds]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[disable color]' \
        '-o+[format]:f:(noheader table json yaml csv)' \
        '--output=+[format]:f:(noheader table json yaml csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hetzner subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments '1:server cmd:(list create delete describe poweron poweroff reboot reset rescue disable-rescue rebuild change-type create-image enable-backup disable-backup attach-iso detach-iso update enable-protection disable-protection request-console reset-password attach-to-network detach-from-network change-alias-ips ip metrics ssh)' ;;
                volume|network|firewall|load-balancer|floating-ip|primary-ip|placement-group|certificate|ssh-key) _arguments '1:cmd:(list create delete describe update enable-protection disable-protection)' ;;
                image|iso|datacenter|location|server-type|load-balancer-type) _arguments '1:cmd:(list describe)' ;;
                context) _arguments '1:context cmd:(create use delete list active)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_hetzner "$@"
