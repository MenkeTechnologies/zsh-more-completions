#compdef kfontview
# Documentation: https://docs.kde.org/stable5/en/plasma-desktop/kfontview/
# Reference accessed: 2026-05-17
# Verified: KDE Font Viewer GUI app (plasma-desktop kcms/kfontinst/apps).
# Uses KAboutData::setupCommandLine; accepts a font-file argument.
# Corrected from prior file: removed fabricated --display= (KDE3/X11-era,
# not present in the KF6 Qt6 command line).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options including Qt options]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '*:font file:_files -g "*.{ttf,otf,pfa,pfb,ttc,otc,woff,woff2}"' && ret=0

return ret
