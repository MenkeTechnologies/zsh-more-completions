#compdef shawl
# Documentation: https://github.com/mtkennerly/shawl/blob/master/docs/cli.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'add:Create a new Windows service'
  'run:Run a command as a service (invoked by Windows SCM)'
  'help:Show help for a command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'shawl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      add|run)
        _arguments \
          '--name=[Service name]:name:' \
          '(--restart --no-restart)--restart[Always restart on exit]' \
          '(--restart --no-restart)--no-restart[Never restart]' \
          '*--restart-if=[Restart if exit code matches]:codes:' \
          '*--restart-if-not=[Restart if exit code does not match]:codes:' \
          '--stop-timeout=[Milliseconds before SIGKILL]:ms:' \
          '--log-dir=[Directory for log files]:dir:_files -/' \
          '--log-as=[Log target name]:name:' \
          '--log-cmd-as=[Command log target name]:name:' \
          '--priority=[Process priority]:priority:(realtime high above-normal normal below-normal idle)' \
          '--kill-process-tree[Kill all child processes on stop]' \
          '--cwd=[Working directory]:dir:_files -/' \
          '*--dependencies=[Required dependencies]:deps:' \
          '*:program args:_default' && ret=0
        ;;
    esac
    ;;
esac
return ret
