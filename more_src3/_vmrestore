#compdef vmrestore
# Documentation: https://docs.victoriametrics.com/vmrestore/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '-src=[backup source (gs/s3/azblob/fs URL)]:url:' \
  '-storageDataPath=[restore destination dir]:dir:_files -/' \
  '-skipBackupCompleteCheck[skip backup complete marker check]' \
  '-concurrency=[concurrent download workers]:n:' \
  '-maxBytesPerSecond=[download speed limit]:bps:' \
  '-configFilePath=[S3 config file]:file:_files' \
  '-configProfile=[AWS profile name]:profile:' \
  '-credsFilePath=[GCS/S3 credentials file]:file:_files' \
  '-customS3Endpoint=[custom S3 endpoint]:url:' \
  '-s3ForcePathStyle[force S3 path style]' \
  '-s3SSEKMSKeyId=[S3 SSE KMS key ID]:keyid:' \
  '-s3TLSInsecureSkipVerify[skip S3 TLS verify]' \
  '-httpListenAddr=[HTTP metrics listen addr]:addr:' \
  '-tls[enable TLS]' \
  '-tlsCertFile=[TLS cert]:file:_files' \
  '-tlsKeyFile=[TLS key]:file:_files' \
  '-mtls[enable mTLS (Enterprise)]' \
  '-loggerLevel=[log level]:level:(INFO WARN ERROR FATAL PANIC)' \
  '-loggerFormat=[log format]:format:(default json)' \
  '-license=[Enterprise license key]:key:' \
  '-licenseFile=[Enterprise license file]:file:_files' \
  '-eula[accept Enterprise EULA]'
