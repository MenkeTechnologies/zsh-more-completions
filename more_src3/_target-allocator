#compdef target-allocator otel-target-allocator
# _target-allocator — OpenTelemetry Operator Prometheus target allocator
# upstream: https://github.com/open-telemetry/opentelemetry-operator
# Flags from cmd/otel-allocator/internal/config/flags.go on tip.

_target-allocator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-file=[path to allocator config file]:file:_files' \
        '--listen-addr=[plain HTTP listen address]:host\:port:' \
        '--enable-prometheus-cr-watcher[enable Prometheus CRs as target sources]' \
        '--kubeconfig-path=[absolute path to kubeconfig]:file:_files' \
        '--enable-https-server[enable additional HTTPS server]' \
        '--listen-addr-https=[HTTPS listen address]:host\:port:' \
        '--https-ca-file=[HTTPS server TLS CA file]:file:_files' \
        '--https-tls-cert-file=[HTTPS server TLS cert file]:file:_files' \
        '--https-tls-key-file=[HTTPS server TLS key file]:file:_files' \
        '--allow-insecure-auth-secrets[serve scrape configs with secret values over plain HTTP]' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)'
}

_target-allocator "$@"
