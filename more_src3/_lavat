#compdef lavat
# Documentation: https://github.com/AngelJumbo/lavat
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lavat is a lava lamp TUI with hand-written single-letter argv parsing
# (not clap). Flag set taken from the upstream README.
_arguments -s -S \
  '-h[show help]' \
  '-g[enable truecolor gradient mode]' \
  '-G[enable gravity and buoyancy movement]' \
  '-c[metaball color (named color or hex in gradient mode)]:color:' \
  '-k[rim color]:color:' \
  '-s[speed 1-10 (default 5)]:speed:({1..10})' \
  '-r[metaball radius 1-10 (default 5)]:radius:({1..10})' \
  '-R[rim thickness 1-5]:rim:({1..5})' \
  '-b[number of metaballs 5-20 (default 10)]:nballs:' \
  '-F[custom ASCII characters for rendering]:chars:' \
  '-C[keep lava contained within terminal]' \
  '-p[party mode (p1/p2/p3)]:mode:(p1 p2 p3)' \
  '*:ignored:_default'
