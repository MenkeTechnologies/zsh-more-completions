#compdef testcafe2 testcafe-cli
# _testcafe2 — DevExpress testcafe2 CLI command-line frontend for the TestCafe end-to-end cross-browser automated test framework running tests in Chrome Firefox Safari Edge headless concurrency selector clicks typing assertions video-recording reporters spec list xunit json minimal nunit allure for CI integration (DevExpress team, JavaScript); custom argparse
# upstream: https://testcafe.io/

_testcafe2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-b[list available browsers]' \
        '--list-browsers[list available browsers]' \
        '-c+[concurrency]:n:' \
        '--concurrency=+[N]:n:' \
        '-r+[reporters]:r:(spec list minimal xunit json nunit-junit nunit3 dashboard allure)' \
        '--reporter=+[name]:r:(spec list minimal xunit json nunit-junit nunit3 dashboard allure)' \
        '-s+[screenshots dir]:dir:_files -/' \
        '--screenshots=+[dir]:dir:_files -/' \
        '--screenshots-on-fails[take screenshots on failures]' \
        '-S[screenshots on failures]' \
        '-p+[base path]:str:' \
        '--screenshot-path-pattern=+[pattern]:str:' \
        '-q+[quarantine retries]:n:' \
        '--quarantine-mode[quarantine mode]' \
        '--debug-mode[debug mode]' \
        '--debug-on-fail[debug on fail]' \
        '--skip-js-errors[skip JS errors]' \
        '--skip-uncaught-errors[skip uncaught errors]' \
        '--test-grep=+[regex]:str:' \
        '--fixture-grep=+[regex]:str:' \
        '-f+[fixture name]:str:' \
        '--fixture=+[name]:str:' \
        '-t+[test name]:str:' \
        '--test=+[name]:str:' \
        '--test-meta=+[k=v]:str:' \
        '--fixture-meta=+[k=v]:str:' \
        '--proxy=+[host]:str:' \
        '--proxy-bypass=+[hosts]:str:' \
        '--retry-test-pages[retry test pages]' \
        '-a+[app cmd]:str:' \
        '--app=+[cmd]:str:' \
        '--app-init-delay=+[ms]:n:' \
        '--selector-timeout=+[ms]:n:' \
        '--assertion-timeout=+[ms]:n:' \
        '--page-load-timeout=+[ms]:n:' \
        '--ports=+[port1,port2]:str:' \
        '--hostname=+[host]:_hosts' \
        '--speed=+[N]:str:' \
        '--ssl=+[opts]:str:' \
        '--video=+[dir]:dir:_files -/' \
        '--video-options=+[opts]:str:' \
        '--video-encoding-options=+[opts]:str:' \
        '--color[force color]' \
        '--no-color[disable color]' \
        '*:browser+files:_files'
}

_testcafe2 "$@"
