#compdef rustdoc
# Documentation: rustdoc --help
# Source: Rust rustdoc — documentation generator from Rust source code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-w --output-format)'{-w,--output-format=}'[output format]:format:(html)' \
    '--output=[output directory (deprecated; use --out-dir)]:dir:_files -/' \
    '(-o --out-dir)'{-o,--out-dir=}'[output directory]:dir:_files -/' \
    '--crate-name=[crate name]:name:' \
    '*--crate-type=[crate type list (comma-separated)]:type:(bin lib rlib dylib cdylib staticlib proc-macro)' \
    '*'{-L,--library-path=}'[directory to add to crate search path]:dir:_files -/' \
    '*--cfg=[pass --cfg to rustc]:cfg:' \
    '*--check-cfg=[pass --check-cfg to rustc]:check-cfg:' \
    '*--extern=[pass --extern to rustc]:name[=path]:' \
    '*--extern-html-root-url=[base URL for dependencies]:name=url:' \
    '--extern-html-root-takes-precedence[prefer --extern-html-root-url over html_root_url]' \
    '*'{-C,--codegen=}'[codegen option]:opt[=value]:' \
    '--document-private-items[document private items]' \
    '--document-hidden-items[document doc(hidden) items]' \
    '--test[run doctests]' \
    '--test-args=[args to pass to test runner]:args:' \
    '--test-run-directory=[doctest working directory]:dir:_files -/' \
    '--target=[target triple]:triple:' \
    '*--markdown-css=[CSS files for Markdown link]:files:_files -g "*.css"' \
    '*--html-in-header=[files inline in <head>]:files:_files' \
    '*--html-before-content=[files between <body> and content]:files:_files' \
    '*--html-after-content=[files between content and </body>]:files:_files' \
    '*--markdown-before-content=[Markdown before-content files]:files:_files' \
    '*--markdown-after-content=[Markdown after-content files]:files:_files' \
    '--markdown-playground-url=[URL for code-snippet runner]:url:' \
    '--markdown-no-toc[skip table of contents]' \
    '(-e --extend-css)'{-e,--extend-css=}'[append CSS rules from file]:file:_files -g "*.css"' \
    '*-Z+[unstable / nightly options]:flag:' \
    '--sysroot=[system root override]:dir:_files -/' \
    '--playground-url=[URL for code-snippet runner]:url:' \
    '--display-doctest-warnings[show doctest warnings]' \
    '--crate-version=[crate version embedded in docs]:version:' \
    '--sort-modules-by-appearance[do not sort modules alphabetically]' \
    '--default-theme=[default theme name]:theme:' \
    '*--default-setting=[default rustdoc setting]:setting[=value]:' \
    '*--theme=[additional theme files]:files:_files -g "*.css"' \
    '*--check-theme=[validate theme files]:files:_files -g "*.css"' \
    '--no-run[compile doctests but do not run]' \
    '--show-coverage[show item-documentation coverage]' \
    '--enable-per-target-ignores[honor per-target ignores]' \
    '--runtool=[program to run doctests]:program:_command_names -e' \
    '*--runtool-arg=[arg passed to --runtool]:arg:' \
    '--test-builder=[binary used to compile doctests]:program:_command_names -e' \
    '--test-builder-wrapper=[wrapper around test-builder]:wrapper:_command_names -e' \
    '--no-run-doctests[compile but do not execute doctests]' \
    '--persist-doctests=[directory to store doctest binaries]:dir:_files -/' \
    '*-r+[run lint on warning level]:lint:' \
    '*-W+[warn-by-default lint]:lint:' \
    '*-D+[deny-by-default lint]:lint:' \
    '*-A+[allow lint]:lint:' \
    '*-F+[forbid lint]:lint:' \
    '*:input file:_files -g "*.{rs,md}"' \
    && ret=0

return ret
