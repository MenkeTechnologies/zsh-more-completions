#compdef xrepo
# Documentation: https://github.com/xmake-io/xmake/tree/dev/xmake/modules/private/xrepo/action
# Reference accessed: 2026-05-21
# Verified: upstream Lua action sources at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install the given packages'
  'remove:remove (uninstall) packages'
  'info:display package information'
  'fetch:fetch package library info'
  'search:search packages'
  'env:manage package virtual environments'
  'scan:scan installed packages'
  'export:export packages'
  'import:import packages'
  'download:download package source code'
  'clean:clean package caches'
  'add-repo:add a repository'
  'rm-repo:remove a repository'
  'list-repo:list registered repositories'
  'update-repo:update repositories'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose output]' \
  '-D[diagnostic output]' \
  '-y[answer yes to all prompts]' \
  '-q[quiet output]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'xrepo command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install)
        _arguments \
          {-k,--kind}'+[library kind]:kind:(static shared)' \
          {-p,--plat}'+[target platform]:platform:' \
          {-a,--arch}'+[target architecture]:arch:' \
          {-m,--mode}'+[build mode]:mode:(release debug)' \
          {-f,--configs}'+[extra package configs]:configs:' \
          {-j,--jobs}'+[parallel compile jobs]:n:' \
          '--linkjobs=[parallel link jobs]:n:' \
          '--includes=[extra lua config files]:files:' \
          '--policies=[set policies]:policies:' \
          '--vs=[Visual Studio version]:ver:' \
          '--vs_toolset=[VS toolset version]:ver:' \
          '--vs_sdkver=[Windows SDK version]:ver:' \
          '--ndk=[Android NDK directory]:dir:_directories' \
          '--ndk_sdkver=[NDK SDK version]:ver:' \
          '--android_sdk=[Android SDK directory]:dir:_directories' \
          '--build_toolver=[Android SDK build tool version]:ver:' \
          '--ndk_stdcxx[use stdc++ library for NDK]' \
          '--ndk_cxxstl=[stdc++ stl library for NDK]:stl:(c++_static c++_shared gnustl_static gnustl_shared stlport_shared stlport_static)' \
          '--sdk=[cross toolchain SDK directory]:dir:_directories' \
          '--toolchain=[toolchain name]:name:' \
          '--toolchain_host=[host toolchain name]:name:' \
          '--mingw=[MingW SDK directory]:dir:_directories' \
          '--xcode=[Xcode application directory]:dir:_directories' \
          '--xcode_sdkver=[Xcode SDK version]:ver:' \
          '--target_minver=[target minimal version]:ver:' \
          '--appledev=[Apple device type]:type:(simulator iphone watchtv appletv catalyst)' \
          {-d,--debugdir}'+[source directory for debugging]:dir:_directories' \
          '--force[force reinstall all package dependencies]' \
          '--shallow[do not install dependent packages]' \
          '--build[always build and install from source]' \
          '*:package:' && ret=0
        ;;
      (search|info|remove|download)
        _arguments '*:package:' && ret=0
        ;;
      (fetch)
        _arguments \
          '--linkdirs[output link directories]' \
          '--includedirs[output include directories]' \
          '--links[output link libraries]' \
          '--cflags[output C flags]' \
          '--ldflags[output linker flags]' \
          '*:package:' && ret=0
        ;;
      (add-repo)
        _arguments \
          '--global[register globally]' \
          '*:name url:' && ret=0
        ;;
      (rm-repo)
        _arguments \
          '--global[remove from global]' \
          '*:name:' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
