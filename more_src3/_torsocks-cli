#compdef torsocks-cli
# _torsocks-cli — Tor Project torsocks shell wrapper to use Tor SOCKS proxy CLI alias (torproject team, C); custom argparse
# upstream: https://gitlab.torproject.org/tpo/core/torsocks

_torsocks-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--shell[start shell with Tor environment]' \
        '--on[enable torsocks for current shell]' \
        '--off[disable torsocks for current shell]' \
        '--isolate[use isolated stream]' \
        '-i[use isolated stream]' \
        '--port=+[port]:port:' \
        '-P+[port]:port:' \
        '--address=+[host]:host:_hosts' \
        '-a+[host]:host:_hosts' \
        '--user=+[user]:_users' \
        '-u+[user]:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--allow-inbound[allow inbound]' \
        '--socks5-host=+[host]:host:_hosts' \
        '--socks5-port=+[port]:port:' \
        '*:command:_command_names'
}

_torsocks-cli "$@"
