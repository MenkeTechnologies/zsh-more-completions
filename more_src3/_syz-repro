#compdef syz-repro
# _syz-repro — find minimal syzkaller reproducer for a crash (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-repro/repro.go (flag).

_syz-repro() {
    _arguments \
        '-config=[manager configuration file]:file:_files -g "*.cfg"' \
        '-count=[number of VMs to use]:n:' \
        '-debug[print debug output]' \
        '-output=[output syz repro file]:file:_files' \
        '-crepro=[output C reproducer file]:file:_files' \
        '-title=[file to save reproduced bug title]:file:_files' \
        '-strace=[output strace log file]:file:_files' \
        '1:crash log file:_files'
}

_syz-repro "$@"
