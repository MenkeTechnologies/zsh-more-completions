#compdef kuberay-operator ray-operator manager
# _kuberay-operator — KubeRay operator (reconciles RayCluster + RayJob + RayService CRs into Ray head/worker pods)
# upstream: https://github.com/ray-project/kuberay
# Flags from ray-operator/main.go on tip + controller-runtime zap.Options.

_kuberay-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-addr=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--enable-leader-election[enable leader election]' \
        '--leader-election-namespace=[leader election namespace]:ns:' \
        '--reconcile-concurrency=[max reconcile concurrency]:n:' \
        '--watch-namespace=[comma-separated namespaces to watch]:list:' \
        '--forced-cluster-upgrade[force upgrade Ray clusters on operator restart]' \
        '--log-file-path=[log file path]:file:_files' \
        '--log-file-encoder=[log file encoder]:enc:(json console)' \
        '--log-stdout-encoder=[log stdout encoder]:enc:(json console)' \
        '--enable-batch-scheduler[enable batch scheduler integration]' \
        '--batch-scheduler=[batch scheduler]:sched:(volcano yunikorn)' \
        '--config=[structured config file (flags ignored if set)]:file:_files' \
        '--use-kubernetes-proxy[use k8s API proxy for client communication]' \
        '--feature-gates=[key=value pairs to enable feature gates]:gates:' \
        '--enable-metrics[emit control-plane metrics]' \
        '--qps=[client QPS]:n:' \
        '--burst=[client burst]:n:' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)'
}

_kuberay-operator "$@"
