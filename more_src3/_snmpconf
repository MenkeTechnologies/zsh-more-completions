#compdef snmpconf
# Documentation: snmpconf -h (Net-SNMP)
# Source: interactive helper that builds snmp.conf / snmpd.conf / snmptrapd.conf.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[overwrite existing files without prompting]' \
    '(-p -I)-i[install created files into /opt/homebrew/share/snmp]' \
    '(-i -I)-p[install created files into ~/.snmp]' \
    '(-i -p)-I+[install created files into DIR]:dir:_files -/' \
    '-a[do not ask any questions, comment current .conf files]' \
    '-r+[read all or none of the .conf files]:mode:(all none)' \
    '*-R+[read particular list of .conf files (CSV)]:files:' \
    '-g+[ask GROUPed questions]:group:' \
    '-G[list known GROUPs]' \
    '-c+[alternate configuration directory]:dir:_files -/' \
    '-q[run more quietly]' \
    '-d[turn on debugging output]' \
    '-D[turn on debugging dumper output]' \
    '*:file to create:(snmp.conf snmpd.conf snmptrapd.conf)' \
    && ret=0

return ret
