#compdef instruments-cli
# _instruments-cli — Apple Instruments performance profiler CLI alias (Apple, Objective-C); custom argparse (deprecated by xctrace)
# upstream: https://developer.apple.com/xcode/

_instruments-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-s[list known templates and devices]' \
        '-t+[template]:str:' \
        '-D+[output document]:file:_files -g "*.trace"' \
        '-l+[limit recording duration ms]:n:' \
        '-i+[record on instrument index]:n:' \
        '-p+[target pid]:pid:_pids' \
        '-v[verbose]' \
        '-w+[target device]:str:' \
        '*:target-app-and-args:_files'
}

_instruments-cli "$@"
