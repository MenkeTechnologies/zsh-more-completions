#compdef kpack-completion
# _kpack-completion — kpack build completion helper (signing + reporting phase)
# upstream: https://github.com/buildpacks-community/kpack
# Flags from cmd/completion/main.go on tip.

_kpack-completion() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cache-tag=[image cache tag]:tag:' \
        '--termination-message-path=[termination message file path]:file:_files' \
        '--notary-v1-url=[Notary V1 server URL]:url:_urls' \
        '*--basic-docker=[docker basic auth: secret=domain]:spec:' \
        '*--dockercfg=[path to dockercfg credential]:path:_files' \
        '*--dockerconfig=[path to docker config.json credential]:path:_files' \
        '*--basic-git=[git basic auth: secret=domain]:spec:' \
        '*--ssh-git=[git SSH auth: secret=domain]:spec:' \
        '*--blob=[blob auth: secret=domain]:spec:' \
        '*--cosign-annotations=[Cosign custom signing annotations]:annotation:' \
        '*--cosign-repositories=[Cosign signing repository: secret=registry/project]:spec:' \
        '*--cosign-docker-media-types=[Cosign legacy docker media types: secret=1]:spec:'
}

_kpack-completion "$@"
