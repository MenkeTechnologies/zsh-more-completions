#compdef tcktransform
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/tcktransform.html
# Source: MRtrix3/mrtrix3 cmd/tcktransform.cpp — apply non-linear transformation to track file (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '1:tracks (input):_files -g "*.{tck,trk}"' \
    '2:transform (warp image):_files -g "*.{nii,nii.gz,mif}"' \
    '3:output tracks:_files' \
    && ret=0

return ret
