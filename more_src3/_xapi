#compdef xapi xapi-to
# Documentation: https://github.com/xapi-labs/xapi-cli
# Reference accessed: 2026-05-22
# Verified: src/index.ts HELP and command router.

# Zsh completion for xapi - agent-friendly xAPI action CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--format[output format]:format:(json pretty table)' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'xapi command' \
      'list[list actions]' \
      'search[search actions by keyword]' \
      'categories[list action categories]' \
      'services[list services]' \
      'get[get action schema]' \
      'call[execute an action]' \
      'oauth[OAuth bindings]' \
      'register[create account and API key]' \
      'balance[show account balance]' \
      'topup[generate payment URL]' \
      'health[check backend connectivity]' \
      'config[manage CLI config]' && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments \
          '--source[filter source]:source:(capability api)' \
          '--page[page number]:n:' \
          '--page-size[page size]:n:' \
          '--category[category filter]:category:' \
          '--service-id[service ID]:id:' && ret=0
        ;;
      search)
        _arguments \
          '--source[filter source]:source:(capability api)' \
          '--category[category filter]:category:' \
          '--page[page number]:n:' \
          '--page-size[page size]:n:' \
          '1:query:' && ret=0
        ;;
      categories)
        _arguments '--source[filter source]:source:(capability api)' && ret=0
        ;;
      services)
        _arguments \
          '--page[page number]:n:' \
          '--page-size[page size]:n:' \
          '--category[category filter]:category:' && ret=0
        ;;
      get)
        _arguments \
          '--method[HTTP method]:method:(GET POST PUT PATCH DELETE)' \
          '--code[code snippet target]:code:(curl py js ts go)' \
          '1:action id:' && ret=0
        ;;
      call)
        _arguments \
          '--input[JSON input payload]:json:' \
          '--method[HTTP method]:method:(GET POST PUT PATCH DELETE)' \
          '--code[code snippet target]:code:(curl py js ts go python)' \
          '1:action id:' && ret=0
        ;;
      oauth)
        case $line[2] in
          bind)
            _arguments '--provider[OAuth provider]:provider:(twitter)' && ret=0
            ;;
          unbind)
            _arguments '1:binding id:' && ret=0
            ;;
          status|providers)
            ret=0
            ;;
          *)
            _values 'oauth command' bind status unbind providers && ret=0
            ;;
        esac
        ;;
      register)
        _arguments \
          '--referral-code[referral code]:code:' \
          '1:referral code:' && ret=0
        ;;
      topup)
        _arguments \
          '--amount[USD amount]:usd:' \
          '--method[payment method]:method:(stripe x402)' && ret=0
        ;;
      config)
        case $line[2] in
          set)
            _arguments '1:setting:(apiKey)' '2:value:' && ret=0
            ;;
          show|health)
            ret=0
            ;;
          *)
            _values 'config command' show set health && ret=0
            ;;
        esac
        ;;
      balance|health)
        ret=0
        ;;
    esac
    ;;
esac

return ret
