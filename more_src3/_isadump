#compdef isadump
# Documentation: man isadump(8)
# Source: lm-sensors/lm-sensors prog/dump/isadump.c (master) — dump ISA Super-I/O registers (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-k+[Super-I/O config access key V1,V2...]:keys:_default' \
    '-f[enable flat address space mode]' \
    '-y[assume yes to all prompts]' \
    '(-W -L)-W[read/display word (16-bit) values]' \
    '(-W -L)-L[read/display long (32-bit) values]' \
    '*::addrreg datareg [bank [bankreg]]:_default' \
    && ret=0

return ret
