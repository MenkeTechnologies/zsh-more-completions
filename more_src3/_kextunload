#compdef kextunload
# Documentation: https://www.unix.com/man-page/osx/8/kextunload/
# Source: Apple macOS — legacy kernel-extension unloader (superseded by `kmutil unload` on Catalina+).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-b,-bundle-id=}'[unload by CFBundleIdentifier]:bundle id:' \
    '*'{-c,-class=}'[terminate all instances of class in IOService plane]:classname:' \
    '(- *)'{-h,-help}'[print help]' \
    '*-m[bundle id (backward compat with -b)]:bundle id:' \
    '(-p -personalities-only)'{-p,-personalities-only}'[remove personalities; do not unload kexts]' \
    '(-q -quiet)'{-q,-quiet}'[quiet mode]' \
    '*'{-v,-verbose=-}'[verbose level 0-6 or 0x####]:level:(0 1 2 3 4 5 6)' \
    '*:kext path:_files -/' \
    && ret=0

return ret
