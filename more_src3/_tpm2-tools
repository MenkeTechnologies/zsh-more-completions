#compdef tpm2-tools tpm2
# _tpm2-tools — tpm2-software TPM2.0 tools dispatcher CLI (tpm2-software, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2-tools() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--tcti=+[TCTI module]:t:(device tabrmd swtpm mssim cmd none libtss2-tcti-mssim libtss2-tcti-swtpm libtss2-tcti-cmd libtss2-tcti-device libtss2-tcti-tabrmd)' \
        '-T+[TCTI module]:t:(device tabrmd swtpm mssim cmd none)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-Q[quiet]' \
        '*:command:'
}

_tpm2-tools "$@"
