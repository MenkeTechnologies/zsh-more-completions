#compdef tikzit
# Documentation: https://github.com/tikzit/tikzit
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# tikzit: GUI graph diagram editor; upstream README does not document CLI flags
# beyond passing a .tikz file as positional argument.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '*:TikZ file:_files -g "*.tikz"' && ret=0
return ret
