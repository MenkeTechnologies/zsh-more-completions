#compdef xeol
# Documentation: https://github.com/xeol-io/xeol/blob/main/cmd/xeol/cli/options/xeol.go
#                https://github.com/xeol-io/xeol/blob/main/internal/format/format.go
# Reference accessed: 2026-05-21
# Verified: upstream Xeol option struct (cobra/clio AddFlags) and AvailableFormats.

_xeol() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '*'{-o,--output=}'[report output formatter]:format:(json table)' \
        '--file=[file to write report output to]:file:_files' \
        '--name=[set name of the target being analyzed]:name:' \
        '--project-name=[set name of the project being analyzed for xeol.io]:name:' \
        '--api-key=[API key for xeol.io]:key:' \
        '(-f --fail-on-eol-found)'{-f,--fail-on-eol-found}'[set exit code 1 if an EOL package is found]' \
        '(-l --lookahead)'{-l,--lookahead=}'[lookahead specifier (e.g. 1d, 1w, 1m, 1y)]:duration:' \
        '--distro=[distro to match against in format distro:version]:distro:' \
        '--platform=[optional platform specifier for container images]:platform:' \
        '--show-vuln-count[show number of vulnerabilities for each package]' \
        '(-s --scope)'{-s,--scope=}'[selection of layers to analyze]:scope:(squashed all-layers)' \
        '1:image-or-path:_files'
}

_xeol "$@"
