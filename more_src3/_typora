#compdef typora Typora
# Documentation: https://support.typora.io/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Typora is a GUI markdown editor with no documented CLI flags;
# only accepts file path argument to open.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files -g "*.(md|markdown|mdown|mkd|txt)"' && ret=0
return ret
