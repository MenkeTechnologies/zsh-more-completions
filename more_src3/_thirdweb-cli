#compdef thirdweb-cli
# Documentation: https://www.npmjs.com/package/thirdweb
# Reference accessed: 2026-05-23
# Verified: npx thirdweb-cli --help (thirdweb npm package).

# Zsh completion for thirdweb-cli - thirdweb web3 development CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install thirdweb into a project'
  'create:create a web3 app from templates'
  'build:compile contracts and detect extensions'
  'deploy:deploy contract to an EVM network'
  'publish:publish contract with shareable page'
  'upload:upload files to decentralized storage'
  'detect:detect project type'
  'generate:generate contract-related code'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--skip-update-check[skip auto update check]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'thirdweb-cli command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
