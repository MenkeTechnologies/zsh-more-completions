#compdef hb-view hb-shape
# Documentation: hb-view --help / hb-shape --help (HarfBuzz)
# Source: HarfBuzz preview / shape text with a given font.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--help-all[show all help options]' \
    '(- *)--help-face[font face help]' \
    '(- *)--help-font[font instance help]' \
    '(- *)--help-variations[variations help]' \
    '(- *)--help-text[input text help]' \
    '(- *)--help-text-context[input context text help]' \
    '(- *)--help-shape[shaping process help]' \
    '(- *)--help-features[font features help]' \
    '(- *)--help-view[output rendering help (hb-view)]' \
    '(- *)--help-output[destination/output help]' \
    '(- *)--help-output-syntax[output syntax help (hb-shape)]' \
    '(- *)--version[show version]' \
    {-n+,--num-iterations=}'[run N iterations]:n:' \
    '--font-file=[font file name]:file:_files -g "*.(ttf|otf|ttc|otc|woff|woff2)"' \
    {-y+,--face-index=}'[face index]:index:' \
    '--face-loader=[face loader]:loader:(ot ft coretext)' \
    '--list-face-loaders[list available face loaders]' \
    '--font-size=[font size]:size:' \
    '--font-ppem=[pixels per EM]:size:' \
    '--font-ptem=[point size]:size:' \
    '--font-bold=[synthetic bold]:value:' \
    '--font-grade=[synthetic grade]:value:' \
    '--font-slant=[synthetic slant]:value:' \
    '--font-funcs=[font funcs impl]:impl:(ot ft coretext)' \
    '--list-font-funcs[list available font funcs]' \
    '--ft-load-flags=[FreeType load flags]:n:' \
    '--named-instance=[named-instance index]:index:' \
    '--variations=[CSV list of variations]:list:' \
    '--list-shapers[list available shapers]' \
    '*--shaper=[shaper to use]:shaper:(ot fallback graphite2 coretext)' \
    '*--shapers=[CSV list of shapers]:list:' \
    '--features=[CSV list of features to apply]:list:' \
    '--list-features[list features]' \
    '--direction=[text direction]:dir:(ltr rtl ttb btt)' \
    '--language=[BCP47 language]:lang:' \
    '--script=[ISO 15924 script]:script:' \
    {-u+,--unicodes=}'[hex Unicode codepoint list]:list:' \
    '--text=[text]:text:' \
    '--text-file=[text file]:file:_files' \
    '--text-before=[context text before]:text:' \
    '--text-after=[context text after]:text:' \
    '--utf8-clusters[use UTF-8 cluster indexing]' \
    '--cluster-level=[cluster level]:level:(0 1 2)' \
    '--remove-default-ignorables[remove default-ignorable chars]' \
    '--show-extents[print extent info]' \
    '--show-flags[print buffer flags]' \
    '--ned[remove cluster info]' \
    '--no-glyph-names[print numeric glyph IDs]' \
    '--no-positions[do not print position info]' \
    '--no-advances[do not print glyph advances]' \
    '--no-clusters[do not print cluster info]' \
    '--bot[treat as beginning of text]' \
    '--eot[treat as end of text]' \
    '--output-format=[output format]:fmt:(png svg pdf eps ansi text json)' \
    {-o+,--output-file=}'[output file]:file:_files' \
    '--background=[background color]:color:' \
    '--foreground=[foreground color]:color:' \
    '--font-extents[draw font extents]' \
    '--annotate[annotate glyph extents]' \
    '--line-space=[line spacing]:value:' \
    '--margin=[margin]:value:' \
    '*:font file or text:_files -g "*.(ttf|otf|ttc|otc|woff|woff2)"' \
    && ret=0

return ret
