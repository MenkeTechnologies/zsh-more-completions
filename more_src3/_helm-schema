#compdef helm-schema
# helm-schema: Helm plugin to generate JSON schema from values.yaml
# https://github.com/dadav/helm-schema

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --chart-path)'{-c+,--chart-path=}'[path to Helm chart directory]:dir:_directories' \
  '(-o --output-file)'{-o+,--output-file=}'[output file name]:file:_files' \
  '(-d --draft)'{-d+,--draft=}'[JSON schema draft version]:draft:(4 6 7 2019 2020)' \
  '(-i --indent)'{-i+,--indent=}'[indentation spaces]:spaces' \
  '--append-newline[append newline at end of file]' \
  '--no-default[do not add default values to schema]' \
  '--keep-full-comment[keep full comment as description]' \
  '--strict[enable strict mode]' \
  '--value-files=[additional value files]:files:_files' \
  '*:chart directories:_directories'
