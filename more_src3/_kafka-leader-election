#compdef kafka-leader-election
# Documentation: https://kafka.apache.org/documentation/ (kafka-leader-election.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--admin.config[(DEPRECATED) Configuration properties file for the admin client]:file:_files'
    '--all-topic-partitions[Perform election on all of the eligible topic partitions]'
    '--bootstrap-server[REQUIRED. A hostname and port for the broker to connect to]:host\:port:'
    '--command-config[Config properties file to pass to the admin client]:file:_files'
    '--election-type[REQUIRED. Type of election to attempt]:type:(preferred unclean)'
    '--help[Print usage information]'
    '--partition[Partition id for which to perform an election]:partition:'
    '--path-to-json-file[The JSON file with the list of partitions]:file:_files'
    '--topic[Name of topic for which to perform an election]:topic:'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
