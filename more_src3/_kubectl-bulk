#compdef kubectl-bulk
# Documentation: https://github.com/emreodabas/kubectl-plugins
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# bulk-action (emreodabas/kubectl-plugins), binary kubectl-bulk.
# Usage: kubectl bulk <resourceType> [params] <action> [action-parameters]
# % wildcards are supported in resource selection.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:resourceType:_default' \
  '*::arg:->args' && ret=0

case $state in
  args)
    local -a actions=(
      'get:retrieve field values from resources'
      'list:list resource definitions (yaml/json)'
      'create:create new resources with modified metadata'
      'update:modify existing resource definitions'
      'delete:remove resources or specific fields'
      'remove:remove resources or fields from definitions'
      'rollout:rollout history|pause|resume|status|undo'
      'scale:scale resources to a replica count'
    )
    _describe -t actions 'kubectl bulk action' actions && ret=0
    ;;
esac

return ret
