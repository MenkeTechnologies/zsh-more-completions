#compdef wasm-reduce
# Documentation: https://github.com/WebAssembly/binaryen/blob/main/src/tools/wasm-reduce/wasm-reduce.cpp
# Documentation: https://github.com/WebAssembly/binaryen/blob/main/src/tools/tool-options.h
# Reference accessed: 2026-05-27
# Verified: upstream src/tools/wasm-reduce/wasm-reduce.cpp + ToolOptions feature/common flag list

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[output version information and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to stderr]:context (optional):' \
  '(-cmd --command)'{-cmd+,--command=}'[command to run on the test (return code and stdout are preserved)]:command:' \
  '(-t --test)'{-t+,--test=}'[test file written for each run]:file:_files' \
  '(-w --working)'{-w+,--working=}'[working file holding the best result]:file:_files' \
  '(-b --binaries)'{-b+,--binaries=}'[binaryen binaries location (bin/ directory)]:directory:_files -/' \
  '(-S --text)'{-S,--text}'[emit intermediate files as text instead of binary]' \
  '--denan[avoid NaNs when reducing]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output mode]' \
  '(-g --debugInfo)'{-g,--debugInfo}'[keep debug info in binaries]' \
  '(-f --force)'{-f,--force}'[force the reduction attempt even if unlikely to succeed]' \
  '(-to --timeout)'{-to+,--timeout=}'[timeout per command execution in seconds (default: 2)]:seconds:' \
  '(-ef --extra-flags)'{-ef+,--extra-flags=}'[extra commandline flags to pass to wasm-opt while reducing]:flags:' \
  '(-saw --save-all-working)'{-saw,--save-all-working}'[save all intermediate working files as \$WORKING.0, .1, ...]' \
  '(-mvp --mvp-features)'{-mvp,--mvp-features}'[disable all non-MVP features]' \
  '(-all --all-features)'{-all,--all-features}'[enable all features]' \
  '--detect-features[deprecated - this flag does nothing]' \
  '(-q --quiet)'{-q,--quiet}'[emit less verbose output and hide trivial warnings]' \
  '--experimental-poppy[parse wast files as Poppy IR for testing purposes]' \
  '--enable-sign-ext[enable sign extension operations]' \
  '--disable-sign-ext[disable sign extension operations]' \
  '--enable-threads[enable atomic operations]' \
  '--disable-threads[disable atomic operations]' \
  '--enable-mutable-globals[enable mutable globals]' \
  '--disable-mutable-globals[disable mutable globals]' \
  '--enable-nontrapping-float-to-int[enable nontrapping float-to-int operations]' \
  '--disable-nontrapping-float-to-int[disable nontrapping float-to-int operations]' \
  '--enable-simd[enable SIMD operations and types]' \
  '--disable-simd[disable SIMD operations and types]' \
  '--enable-bulk-memory[enable bulk memory operations]' \
  '--disable-bulk-memory[disable bulk memory operations]' \
  '--enable-bulk-memory-opt[enable memory.copy and memory.fill]' \
  '--disable-bulk-memory-opt[disable memory.copy and memory.fill]' \
  '--enable-call-indirect-overlong[enable LEB encoding of call-indirect]' \
  '--disable-call-indirect-overlong[disable LEB encoding of call-indirect]' \
  '--enable-exception-handling[enable exception handling operations]' \
  '--disable-exception-handling[disable exception handling operations]' \
  '--enable-tail-call[enable tail call operations]' \
  '--disable-tail-call[disable tail call operations]' \
  '--enable-reference-types[enable reference types]' \
  '--disable-reference-types[disable reference types]' \
  '--enable-multivalue[enable multivalue functions]' \
  '--disable-multivalue[disable multivalue functions]' \
  '--enable-gc[enable garbage collection]' \
  '--disable-gc[disable garbage collection]' \
  '--enable-memory64[enable memory64]' \
  '--disable-memory64[disable memory64]' \
  '--enable-relaxed-simd[enable relaxed SIMD]' \
  '--disable-relaxed-simd[disable relaxed SIMD]' \
  '--enable-extended-const[enable extended const expressions]' \
  '--disable-extended-const[disable extended const expressions]' \
  '--enable-strings[enable strings]' \
  '--disable-strings[disable strings]' \
  '--enable-multimemory[enable multimemory]' \
  '--disable-multimemory[disable multimemory]' \
  '--enable-stack-switching[enable stack switching]' \
  '--disable-stack-switching[disable stack switching]' \
  '--enable-shared-everything[enable shared-everything threads]' \
  '--disable-shared-everything[disable shared-everything threads]' \
  '--enable-fp16[enable float 16 operations]' \
  '--disable-fp16[disable float 16 operations]' \
  '--enable-custom-descriptors[enable custom descriptors (RTTs) and exact references]' \
  '--disable-custom-descriptors[disable custom descriptors (RTTs) and exact references]' \
  '--enable-multibyte[enable multibyte array loads and stores]' \
  '--disable-multibyte[disable multibyte array loads and stores]' \
  '--enable-relaxed-atomics[enable acquire/release atomic memory operations]' \
  '--disable-relaxed-atomics[disable acquire/release atomic memory operations]' \
  '--enable-custom-page-sizes[enable custom page sizes]' \
  '--disable-custom-page-sizes[disable custom page sizes]' \
  '--enable-wide-arithmetic[enable wide arithmetic]' \
  '--disable-wide-arithmetic[disable wide arithmetic]' \
  '--enable-typed-function-references[deprecated compatibility flag]' \
  '--disable-typed-function-references[deprecated compatibility flag]' \
  '(-n --no-validation)'{-n,--no-validation}'[disable validation, assume inputs are correct]' \
  '*'{-pa+,--pass-arg=}'[argument passed along to optimization passes (KEY@VALUE)]:arg:' \
  '(-cw --closed-world)'{-cw,--closed-world}'[assume code outside the module does not inspect GC/function refs]' \
  '--preserve-type-order[preserve the order of types from the input]' \
  '--generate-stack-ir[generate StackIR during writing]' \
  '--optimize-stack-ir[optimize StackIR during writing]' \
  '--print-stack-ir[print StackIR during writing]' \
  '*:input file:_files -g "*.{wasm,wat}"' && ret=0

return ret
