#compdef yap
# Documentation: https://manpages.debian.org/testing/yap/yap.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian yap(1) man page at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-?[print a short error message]' \
  '-s+[K bytes for local and global stacks]:n:' \
  '-h+[K bytes for heap and auxiliary stacks]:n:' \
  '-t+[K bytes for the trail stack]:n:' \
  '-l+[compile Prolog file before entering top-level]:file:_files -g "*.(pl|yap|P)"' \
  '-L+[compile Prolog file then halt (script mode)]:file:_files -g "*.(pl|yap|P)"' \
  '-g+[run goal before top-level]:goal:' \
  '-z+[run goal as top-level]:goal:' \
  '-b+[boot code Prolog file (must define $live/0)]:file:_files' \
  '-c+[connect standard streams to host port]:ip-host port:' \
  '*: :_files' && ret=0

return ret
