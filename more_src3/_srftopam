#compdef srftopam
# Documentation: man srftopam (Netpbm)
# Source: convert a Garmin SRF tile image to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:srf file:_files -g "*.srf"' \
    && ret=0

return ret
