#compdef livetail
# Documentation: https://github.com/SumoLogic/livetail-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-i --accessId)'{-i,--accessId=}'[Sumo Logic access id]:id:' \
  '(-k --accessKey)'{-k,--accessKey=}'[Sumo Logic access key]:key:' \
  '(-d --deployment)'{-d,--deployment=}'[deployment-specific Sumo Logic API URL]:url:' \
  '(-c --clear)'{-c,--clear}'[clear stored Live Tail credentials]' \
  '*::filter:' && ret=0

return ret
