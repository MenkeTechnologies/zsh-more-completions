#compdef sshuttle
# Documentation: https://sshuttle.readthedocs.io/en/stable/manpage.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sshuttle - transparent proxy server / poor man's VPN over SSH.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-r --remote)'{-r,--remote}'[remote SSH server]:remote host:_hosts' \
  '(-l --listen)'{-l,--listen}'[transparent proxy listen address:port]:address:' \
  '(-H --auto-hosts)'{-H,--auto-hosts}'[scan remote hostnames and update local /etc/hosts]' \
  '(-N --auto-nets)'{-N,--auto-nets}'[ask server which subnets to route]' \
  '*'{-x,--exclude}'[exclude subnet]:subnet:' \
  '(-X --exclude-from)'{-X,--exclude-from}'[exclude subnets from file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity (can repeat)]' \
  '(-e --ssh-cmd)'{-e,--ssh-cmd}'[ssh command to use]:ssh command:' \
  '(-D --daemon)'{-D,--daemon}'[fork into background after connecting]' \
  '(-s --subnets)'{-s,--subnets}'[read subnets from file]:file:_files' \
  '(-t --tmark)'{-t,--tmark}'[traffic mark for tproxy method (hex)]:mark:' \
  '--method=[firewall method]:method:(auto nat nft tproxy pf ipfw)' \
  '--dns[capture and forward DNS requests]' \
  '--ns-hosts=[intercept DNS queries to specified servers]:servers:' \
  '--to-ns=[DNS to forward requests to]:server:' \
  '--python=[path to remote python interpreter]:python path:_files' \
  '--remote-shell=[remote shell (Windows targets)]:shell:' \
  '--no-cmd-delimiter[omit double-dash before remote Python invocation]' \
  '--seed-hosts=[initial comma-separated hostnames for scan]:hosts:' \
  '--no-latency-control[prioritize bandwidth over latency]' \
  '--latency-buffer-size=[buffer size for latency control]:bytes:' \
  '--syslog[log to syslog instead of stderr]' \
  '--pidfile=[save daemon PID to file]:pid file:_files' \
  '--disable-ipv6[disable IPv6 support]' \
  '--sudoers-no-modify[print passwordless sudo configuration]' \
  '--sudoers-user=[user for passwordless operation]:user:_users' \
  '--version[display version]' \
  '*:subnet:' && ret=0

return ret
