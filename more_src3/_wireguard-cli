#compdef wireguard-cli wg-cli
# _wireguard-cli — Jason A. Donenfeld WireGuard wireguard-cli CLI command-line interface wrapping the wg userspace utility for managing WireGuard kernel module userspace-wireguard-go device peer add remove preshared-key endpoint persistent-keepalive allowed-ips listen-port private-key public-key showconf set syncconf wg-quick (Jason A. Donenfeld team, C); getopt
# upstream: https://www.wireguard.com/

_wireguard-cli() {
    local -a sub=(
        'show:show wg interface state'
        'showconf:show config'
        'set:set wg interface options'
        'setconf:set entire config'
        'addconf:add additional peers'
        'syncconf:sync config'
        'genkey:generate private key'
        'genpsk:generate preshared key'
        'pubkey:derive public key'
        'up:bring an interface up'
        'down:bring an interface down'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wireguard-cli subcommand' sub ;;
        args)
            case $words[1] in
                show|set|setconf|addconf|syncconf|showconf|up|down) _arguments \
                    '1:interface:_net_interfaces' \
                    '*::'
                    ;;
            esac
            ;;
    esac
}

_wireguard-cli "$@"
