#compdef syz-cover
# _syz-cover — generate syzkaller coverage reports (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-cover/syz-cover.go (flag).

_syz-cover() {
    _arguments \
        '-config=[configuration file]:file:_files -g "*.cfg"' \
        '-modules=[kernel modules path]:list:' \
        '-period=[time period]:period:(day month quarter)' \
        '-to=[end date YYYY-MM-DD]:date:' \
        '-for-file=[show coverage for specific file]:file:' \
        '-repo=[git repo URL]:url:_urls' \
        '-commit=[commit for -for-file]:sha:' \
        '-namespace=[coverage namespace]:ns:' \
        '-debug[enable detailed output]' \
        '-source-commit=[filter input commit]:sha:' \
        '-exports=[output type]:exports:(cover lines)' \
        '-force[create coverage report despite warnings]' \
        '*:coverage file:_files'
}

_syz-cover "$@"
