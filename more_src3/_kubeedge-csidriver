#compdef kubeedge-csidriver csidriver
# _kubeedge-csidriver — KubeEdge CSI driver (proxies CSI controller RPCs from the cluster down to edge-side CSI plugins via the kubeedge socket)
# upstream: https://github.com/kubeedge/kubeedge
# Flags from cloud/cmd/csidriver/app/{server,options/options}.go on tip.

_kubeedge-csidriver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--drivername=[name of the driver]:name:' \
        '--nodeid=[node id used to create/delete volumes]:id:' \
        '--kubeedge-endpoint=[kubeedge socket endpoint]:uri:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)'
}

_kubeedge-csidriver "$@"
