#compdef waf-cli
# _waf-cli — Waf python build system CLI alias (Thomas Nagy, Python); custom argparse
# upstream: https://gitlab.com/ita1024/waf

_waf-cli() {
    local -a sub=(
        'configure:configure project'
        'build:build (default)'
        'clean:clean build'
        'distclean:remove build dir'
        'install:install built artifacts'
        'uninstall:uninstall artifacts'
        'dist:create tarball distribution'
        'distcheck:check tarball'
        'list:list targets'
        'step:build step by step'
        'shutdown:shutdown waf'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--zones=+[zones]:list:' \
        '--targets=+[targets csv]:list:' \
        '--top=+[top dir]:dir:_files -/' \
        '-t+[top dir]:dir:_files -/' \
        '--out=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--no-msvc-lazy[no msvc lazy]' \
        '--prefix=+[prefix]:dir:_files -/' \
        '--mandir=+[mandir]:dir:_files -/' \
        '--docdir=+[docdir]:dir:_files -/' \
        '--bindir=+[bindir]:dir:_files -/' \
        '--libdir=+[libdir]:dir:_files -/' \
        '--datadir=+[datadir]:dir:_files -/' \
        '--includedir=+[includedir]:dir:_files -/' \
        '--cwd=+[change to dir]:dir:_files -/' \
        '--mtime[use mtime]' \
        '--alltargets[build all targets]' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[parallel jobs]:n:' \
        '-k[keep going]' \
        '--keep[keep going]' \
        '--profile[python profile]' \
        '--pdb[debug with pdb]' \
        '--progress[show progress]' \
        '-p[show progress]' \
        '--color=+[color]:c:(yes no auto)' \
        '--zones=+[debug zones]:list:' \
        '--nocache[no cache]' \
        '*:target:'
}

_waf-cli "$@"
