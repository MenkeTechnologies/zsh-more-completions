#compdef scutil
# Documentation: https://www.unix.com/man-page/osx/8/scutil/
# Source: Apple macOS — System Configuration framework / dynamic-store CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--prefs[CLI to the raw stored preference data]' \
    '(-r -w)-r[check reachability of a host / IP / IP pair]:host or addr:' \
    '-W[watch reachability changes (with -r)]' \
    '(-r -w)-w[watch / wait for dynamic-store key]:key:' \
    '-t[timeout for -w]:seconds:' \
    '--get[get a persistent system preference]:pref:(ComputerName HostName LocalHostName)' \
    '--set[set a persistent system preference]:pref:(ComputerName HostName LocalHostName)' \
    '--dns[report current DNS configuration]' \
    '--proxy[report current system proxy configuration]' \
    '--nc[monitor / interact with VPN connections]:subcommand:(list status statistics show start stop trigger select select-bytagid)' \
    '*:argument:' \
    && ret=0

return ret
