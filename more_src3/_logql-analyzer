#compdef logql-analyzer
# _logql-analyzer — Grafana Loki LogQL query analyzer HTTP server (grafana/loki)
# upstream: https://github.com/grafana/loki
# Flags from cmd/logql-analyzer/main.go + dskit server.Config on tip.

_logql-analyzer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-server.http-listen-address=[HTTP server bind address]:ip:' \
        '-server.http-listen-port=[HTTP server bind port]:port:' \
        '-server.grpc-listen-address=[gRPC server bind address]:ip:' \
        '-server.grpc-listen-port=[gRPC server bind port]:port:' \
        '-server.http-read-timeout=[HTTP read timeout]:dur:' \
        '-server.http-write-timeout=[HTTP write timeout]:dur:' \
        '-server.http-idle-timeout=[HTTP idle timeout]:dur:' \
        '-server.graceful-shutdown-timeout=[graceful shutdown timeout]:dur:' \
        '-server.path-prefix=[HTTP path prefix]:prefix:' \
        '-log.level=[log level]:level:(debug info warn error)' \
        '-log.format=[log format]:fmt:(logfmt json)'
}

_logql-analyzer "$@"
