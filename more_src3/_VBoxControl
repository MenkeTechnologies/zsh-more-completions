#compdef VBoxControl
# Documentation: https://github.com/mirror/vbox/blob/master/src/VBox/Additions/common/VBoxControl/VBoxControl.cpp
# Reference accessed: 2026-05-21
# Verified: upstream VirtualBox VBoxControl.cpp source.

# VBoxControl: VirtualBox guest-side control tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'getvideoacceleration:display video acceleration status'
  'setvideoacceleration:enable/disable video acceleration'
  'videoflags:manage video flags'
  'listcustommodes:list custom display modes'
  'addcustommode:add custom resolution'
  'removecustommode:remove custom resolution'
  'setvideomode:set display resolution'
  'guestproperty:manage guest properties'
  'sharedfolder:manage shared folders'
  'writecoredump:generate core dump'
  'writelog:write log message'
  'takesnapshot:create VM snapshot'
  'savestate:save VM state'
  'suspend:suspend VM'
  'poweroff:power off VM'
  'version:display version'
  'help:display help'
)
_arguments -C \
  '(- *)'{-V,--version}'[print version and exit]' \
  '--nologo[suppress logo output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'VBoxControl command' commands && ret=0 ;;
esac
return ret
