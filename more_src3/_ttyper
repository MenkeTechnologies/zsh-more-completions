#compdef ttyper
# Documentation: https://github.com/max-niederman/ttyper
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ttyper - terminal typing test

_arguments -s -S \
    '(- *)'{-h,--help}'[print help]' \
    '(- *)'{-V,--version}'[print version]' \
    '(-d --debug)'{-d,--debug}'[enable debug mode]' \
    '--list-languages[list installed languages]' \
    '--no-backtrack[prevent backtracking to completed words]' \
    '--sudden-death[restart on first error]' \
    '--no-backspace[disable backspace]' \
    '(-w --words)'{-w,--words}'=[number of words to test (default 50)]:number:' \
    '(-l --language)'{-l,--language}'=[language for word list]:language:' \
    '--language-file=[path to a custom language file]:file:_files' \
    '(-c --config)'{-c,--config}'=[path to config file]:file:_files' \
    '*:contents:_files'
