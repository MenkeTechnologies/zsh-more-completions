#compdef teeworlds
# Documentation: https://manpages.debian.org/bookworm/teeworlds/teeworlds.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm teeworlds(6) manpage. Args are console
# variables (key value), not POSIX flags.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# teeworlds: 2D online multiplayer shooter
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:console variable:(connect player_name password gfx_screen_width gfx_screen_height gfx_fullscreen snd_volume cl_predict cl_nameplates cl_showfps player_skin exec logfile)' && ret=0
return ret
