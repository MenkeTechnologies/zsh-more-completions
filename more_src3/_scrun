#compdef scrun
# _scrun — SchedMD Slurm scrun (OCI-runtime-spec shim that translates docker/podman run-style commands into srun submissions inside an existing Slurm allocation; create/start/state/delete/kill/list subcommands match runc; --bundle bundle dir, --pid-file, --console-socket, --log, --debug)
# upstream: https://github.com/SchedMD/slurm
# Subcommands from SchedMD/slurm src/scrun on tip.

_scrun() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--debug[debug]' \
        '--log+[log file]:file:_files' \
        '--log-format=*[log format]:fmt:(text json)' \
        '--root+[runtime state dir]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'scrun command' '(create start state delete kill list ps exec spec checkpoint restore)' ;;
        args)
            case $line[1] in
                create|start)
                    _arguments \
                        '--bundle+[bundle dir]:dir:_files -/' \
                        '--pid-file+[pid file]:file:_files' \
                        '--console-socket+[console socket]:file:_files' \
                        '1:container id:' ;;
                delete) _arguments '--force[force]' '1:container id:' ;;
                kill) _arguments '1:container id:' '2:signal:(HUP INT QUIT KILL TERM USR1 USR2)' ;;
                list) _arguments '--format=*[format]:format:(table json)' '--quiet[id only]' ;;
            esac
            ;;
    esac
}

_scrun "$@"
