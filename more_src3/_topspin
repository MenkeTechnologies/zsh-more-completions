#compdef topspin TopSpin xwinnmr
# _topspin — Bruker BioSpin TopSpin NMR data acquisition processing and analysis software launcher (bruker team, Java/C); custom argparse
# upstream: https://www.bruker.com/en/products-and-solutions/mr/nmr-software/topspin.html

_topspin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-noload[do not load dataset]' \
        '-noprompt[no prompt]' \
        '-cmd=+[command]:str:' \
        '--command=+[command]:str:' \
        '-mac+[macro file]:file:_files -g "*.mac *.au"' \
        '--macro=+[macro file]:file:_files -g "*.mac *.au"' \
        '-au=+[automation file]:file:_files -g "*.au"' \
        '-bg[run in background]' \
        '-window=+[window]:w:(left right center frame normal max)' \
        '-jvm-args=+[JVM args]:str:' \
        '-Xmx=+[max heap size]:str:' \
        '-Xms=+[min heap size]:str:' \
        '-logon=+[user]:user:_users' \
        '-bgserver[background server]' \
        '-server[NMR server]' \
        '-client[NMR client]' \
        '-spec[spectrometer mode]' \
        '-licfile=+[license file]:file:_files' \
        '-licsrv=+[license server]:host:_hosts' \
        '-datadir=+[data dir]:dir:_files -/' \
        '-cmd_window[command window]' \
        '-ddmode[debug-debug mode]' \
        '-installpath=+[install path]:dir:_files -/' \
        '*:dataset:_files'
}

_topspin "$@"
