#compdef vscode-html-language-server vscode-css-language-server vscode-json-language-server vscode-eslint-language-server vscode-markdown-language-server efm-langserver astro-ls
# Documentation: source-direct extraction from upstream
# hrsh7th/vscode-langservers-extracted bin/<name> -> 5 LSP-
# server binaries that wrap VSCode's bundled language servers
# for use outside VSCode (Neovim, Emacs, helix, kakoune, etc).
# Each bin/<name> is a 3-line Node.js stub that requires the
# corresponding VSCode-bundled JS module:
#   bin/vscode-html-language-server   -> lib/html-language-server/node/htmlServerMain.js
#   bin/vscode-css-language-server    -> lib/css-language-server/node/cssServerMain.js
#   bin/vscode-json-language-server   -> lib/json-language-server/node/jsonServerMain.js
#   bin/vscode-eslint-language-server -> lib/eslint-language-server/node/eslintServerMain.js
#   bin/vscode-markdown-language-server -> lib/markdown-language-server/node/main.js
# All 5 are stdin/stdout LSP servers using the standard
# microsoft/vscode-languageserver-node transport flag set:
# --stdio / --node-ipc / --socket=PORT / --clientProcessId=PID.
# mattn/efm-langserver main.go: 6 Go-stdlib flag.* declarations
# decoded source-direct (-c yaml config, -logfile, -loglevel,
# -d dump, -v version, -q quiet).
# withastro/language-tools astro-ls: bin/nodeServer.js only
# inspects --version then defers to the LSP transport.
# Reference accessed: 2026-05-30 via gh api.
# R191 — pivot to LSP server flag completion sister to the
# heavily-covered LSP family (pyright, pylsp, pylyzer, ruff-lsp,
# rust-analyzer, gopls, clangd, ccls, sourcekit-lsp,
# typescript-language-server, bash-language-server, ltex-ls,
# texlab, ocamllsp, yaml-language-server, tinymist) already in
# the corpus.

case $service in

  vscode-html-language-server|vscode-css-language-server|vscode-json-language-server|vscode-eslint-language-server|vscode-markdown-language-server)
    # All 5 use the standard microsoft/vscode-languageserver-node
    # transport flag set.  Listed under a mutex group since
    # --stdio XOR --node-ipc XOR --socket are transport options
    # at startup (only one can be active).
    _arguments -s -S \
      '(--node-ipc --socket --stdio)--stdio[use stdin/stdout for LSP transport (default for most editors)]' \
      '(--node-ipc --socket --stdio)--node-ipc[use Node IPC channel for LSP transport]' \
      '(--node-ipc --socket --stdio)--socket=[use TCP socket for LSP transport]:port:' \
      '--clientProcessId=[parent PID to monitor (exit when parent dies)]:pid:' \
      '--encoding=[wire encoding (default utf-8)]:enc:(utf-8 ucs-2)' \
      '--version[print version and exit]' \
      '--help[print help and exit]'
    ;;

  efm-langserver)
    # mattn/efm-langserver main.go: 6 flag.* declarations.
    _arguments -s -S \
      '-c+[path to config.yaml]:file:_files -g "*.(yml|yaml)"' \
      '-logfile+[path to log file]:file:_files' \
      '-loglevel+[log level (default 1)]:n:(0 1 2 3 4 5)' \
      '-d[dump configuration to stdout]' \
      '-v[print version and exit]' \
      '-q[run quieter]'
    ;;

  astro-ls)
    # withastro/language-tools bin/nodeServer.js only checks
    # --version then defers to the LSP transport (same as the
    # vscode-* group above).
    _arguments -s -S \
      '(--node-ipc --socket --stdio)--stdio[use stdin/stdout for LSP transport]' \
      '(--node-ipc --socket --stdio)--node-ipc[use Node IPC channel for LSP transport]' \
      '(--node-ipc --socket --stdio)--socket=[use TCP socket for LSP transport]:port:' \
      '--clientProcessId=[parent PID to monitor]:pid:' \
      '--version[print version and exit]'
    ;;

esac
