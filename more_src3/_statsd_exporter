#compdef statsd_exporter
# Documentation: https://github.com/prometheus/statsd_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--statsd.listen-udp=[UDP address to receive StatsD metrics]:address:' \
  '--statsd.listen-tcp=[TCP address to receive StatsD metrics]:address:' \
  '--statsd.listen-unixgram=[Unix datagram socket path to receive StatsD metrics]:path:_files' \
  '--statsd.unixsocket-mode=[permission mode for the unix socket]:mode:' \
  '--statsd.mapping-config=[metric mapping configuration file]:file:_files' \
  '--statsd.read-buffer=[size of the operating system read buffer for UDP and Unixgram sockets]:size:' \
  '--statsd.cache-size=[maximum size of the metric mapping cache]:size:' \
  '--statsd.cache-type=[type of metric mapping cache]:type:(lru random)' \
  '--statsd.event-queue-size=[size of internal queue for processing events]:size:' \
  '--statsd.event-flush-threshold=[number of events to hold before flushing]:count:' \
  '--statsd.event-flush-interval=[time interval before flushing events]:interval:' \
  '--statsd.parse-dogstatsd-tags[parse DogStatsD style tags]' \
  '--statsd.parse-influxdb-tags[parse InfluxDB style tags]' \
  '--statsd.parse-librato-tags[parse Librato style tags]' \
  '--statsd.parse-signalfx-tags[parse SignalFX style tags]' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--web.enable-lifecycle[enable shutdown and reload via HTTP request]' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
