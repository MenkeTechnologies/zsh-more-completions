#compdef wiremock
# Documentation: https://wiremock.org/docs/standalone/java-jar/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wiremock - flexible API mocking for development/testing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--port=[HTTP port to listen on]:port' \
  '--https-port=[HTTPS port to listen on]:port' \
  '--bind-address=[network interface to bind to]:address' \
  '--disable-http[disable plain HTTP listener]' \
  '--disable-http2-plain[disable HTTP/2 over plain text]' \
  '--disable-http2-tls[disable HTTP/2 over TLS]' \
  '--https-keystore=[keystore file for HTTPS]:file:_files' \
  '--keystore-password=[keystore password]:password' \
  '--keystore-type=[keystore type]:type:(JKS PKCS12)' \
  '--key-manager-password=[key manager password]:password' \
  '--https-truststore=[truststore file]:file:_files' \
  '--truststore-password=[truststore password]:password' \
  '--truststore-type=[truststore type]:type:(JKS PKCS12)' \
  '--https-require-client-cert[require client cert for HTTPS]' \
  '--admin-api-basic-auth=[require HTTP Basic auth (user\:pass)]:auth:' \
  '--admin-api-require-https[HTTPS-only admin API access]' \
  '--root-dir=[root directory (mappings and __files)]:dir:_directories' \
  '--load-resources-from-classpath=[load files/mappings from classpath]:path:' \
  '--filename-template=[Handlebars template for recorded filenames]:template:' \
  '--proxy-all=[proxy all requests to the given URL]:url' \
  '--preserve-host-header[preserve Host header when proxying]' \
  '--preserve-user-agent-proxy-header[preserve User-Agent header when proxying]' \
  '--proxy-via=[upstream proxy URL]:url' \
  '--supported-proxy-encodings=[acceptable compression methods]:encodings:' \
  '--enable-browser-proxying[run as browser proxy]' \
  '--ca-keystore=[CA keystore for certificate signing]:file:_files' \
  '--ca-keystore-password=[CA keystore password]:password' \
  '--ca-keystore-type=[CA keystore format]:type:' \
  '--trust-all-proxy-targets[trust all remote certificates]' \
  '--trust-proxy-target=[trust specific remote endpoints]:target:' \
  '--record-mappings[record all received requests as mappings]' \
  '--match-headers=[headers to match when recording]:headers' \
  '--proxy-timeout=[proxy request timeout (ms)]:ms:' \
  '--proxy-pass-through=[enable/disable pass-through for unmatched]:bool:(true false)' \
  '--allow-proxy-targets=[whitelist proxy target addresses]:targets:' \
  '--deny-proxy-targets=[blacklist proxy target addresses]:targets:' \
  '--container-threads=[threads for incoming requests]:count:' \
  '--async-response-enabled=[enable async responses]:bool:(true false)' \
  '--async-response-threads=[async response thread pool size]:count' \
  '--no-request-journal[disable in-memory request journal]' \
  '--max-request-journal-entries=[max request journal entries]:count' \
  '--global-response-templating[enable response templating for all stub mappings]' \
  '--local-response-templating[enable response templating per stub]' \
  '--max-template-cache-entries=[max template cache entries]:count' \
  '--use-chunked-encoding=[transfer-encoding policy]:policy:(always never body_file)' \
  '--disable-gzip[disable gzip compression of responses]' \
  '--disable-request-logging[prevent request/response logging]' \
  '--disable-response-templating[disable Handlebars processing]' \
  '--disable-connection-reuse[disable HTTP connection reuse]' \
  '--permitted-system-keys=[regex of system env keys permitted]:regex' \
  '--logged-response-body-size-limit=[truncate large response bodies in logs]:bytes:' \
  '--jetty-acceptor-threads=[Jetty acceptor thread count]:count' \
  '--jetty-accept-queue-size=[Jetty accept queue size]:size' \
  '--jetty-header-request-size=[Jetty request header buffer size]:bytes' \
  '--jetty-header-response-size=[Jetty response header buffer size]:bytes' \
  '--jetty-idle-timeout=[idle connection timeout (ms)]:ms:' \
  '--jetty-stop-timeout=[server shutdown timeout (ms)]:ms:' \
  '--disable-strict-http-headers[disable strict HTTP header handling]' \
  '--websocket-idle-timeout=[WebSocket idle timeout]:ms:' \
  '--websocket-max-text-message-size=[max text message size]:bytes:' \
  '--websocket-max-binary-message-size=[max binary message size]:bytes:' \
  '--max-http-client-connections=[max HTTP client connections]:count:' \
  '--extensions=[comma-separated extension class names]:extensions' \
  '--disable-extensions-scanning[prevent classpath extension scanning]' \
  '--enable-stub-cors[enable automatic CORS headers]' \
  '--webhook-threadpool-size=[threads for webhook processing]:count:' \
  '--print-all-network-traffic[print raw network traffic to console]' \
  '--verbose[enable verbose logging]' \
  '--disable-banner[hide WireMock logo on startup]' \
  '--disable-optimize-xml-factories-loading[disable XML factory optimization]' \
  '--timeout=[global default timeout]:ms:' \
  '--version[show version]' \
  '--help[show help]' && ret=0

return ret
