#compdef skabus-rpc-client
# _skabus-rpc-client — skabus skabus-rpc-client (super-server fronting skabus-rpcc: opens a local socket, accepts clients, forks skabus-rpcc for each; clients then talk to the remote rpcdpath through this rpcc bridge)
# upstream: https://github.com/skarnet/skabus
# Flags from src/rpc/skabus-rpc-client.c on tip.

_skabus-rpc-client() {
    _arguments \
        '-v+[verbosity]:n:' \
        '(-d -D)-d[bind in dgram mode]' \
        '(-d -D)-D[bind in stream mode (default)]' \
        '-1[print local socket info on fd 1]' \
        '-c+[max simultaneous local clients]:n:' \
        '-b+[listen() backlog]:n:' \
        '-t+[per-request timeout (ms)]:ms:' \
        '-T+[lame-duck timeout (ms)]:ms:' \
        '-C+[per-message dispatcher (prog:sep:flags)]:spec:' \
        '*-y+[register interface (ifname:ifprog:sep:flags)]:spec:' \
        '1:rpccpath:_files' \
        '2:rpcdpath:_files' \
        '3:client-name:'
}

_skabus-rpc-client "$@"
