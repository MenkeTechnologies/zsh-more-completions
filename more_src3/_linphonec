#compdef linphonec
# linphonec — console-based SIP VoIP client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-c,--config}'=[specify config file]:config file:_files' \
  {-s,--sip-address}'=[SIP address to call]:SIP URI:' \
  {-a,--auto-answer}'[auto-answer incoming calls]' \
  {-C,--call-id}'=[call ID]:call ID:' \
  {-d,--debug}'=[set debug level 0-6]:debug level:(0 1 2 3 4 5 6)' \
  {-l,--logfile}'=[log to file]:log file:_files' \
  '--pipe[use pipe for commands]' \
  '*:SIP address:' && ret=0

return ret
