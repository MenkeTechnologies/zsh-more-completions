#compdef subzy
# _subzy — Christophe Tafani-Dereeper LukaSikic subzy CLI subdomain takeover scanner detecting vulnerable subdomain hijack opportunities AWS S3 CloudFront Heroku Azure GitHub-Pages Shopify Tumblr Fastly Cargo-Collective Ghost-Pro Strikingly Tilda Webflow Surge Pantheon Acquia Apigee Bitbucket Brightcove (LukaSikic team, Go); pflag
# upstream: https://github.com/LukaSikic/subzy

_subzy() {
    local -a sub=(
        'run:scan a list of subdomains'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--targets=+[file]:file:_files -g "*.txt"' \
        '--target=+[domain]:str:' \
        '--hide_fails[hide failed lookups]' \
        '--https[force HTTPS]' \
        '--concurrency=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--vuln[only show vulnerable]' \
        '--verify_ssl=+[bool]:s:(true false)' \
        '--output=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--proxy=+[url]:str:' \
        '--retry=+[N]:n:' \
        '--user_agent=+[ua]:str:' \
        '--fingerprints=+[file]:file:_files -g "*.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'subzy subcommand' sub ;;
    esac
}

_subzy "$@"
