#compdef xset
# Documentation: man xset(1)
# Source: openbsd/xenocara app/xset/xset.c (master) — user preference utility for X (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-display -d)'{-display+,-d+}'[X display]:display:_x_display' \
    '-version[show version]' \
    '*::option:->opt' \
    && ret=0

case $state in
    opt)
        _values 'xset option' \
            'b[bell volume/pitch/duration]' \
            '-b[turn bell off]' \
            'bc[enable bug-compat mode]' \
            '-bc[disable bug-compat mode]' \
            'c[keyclick volume]' \
            '-c[turn keyclick off]' \
            'dpms[set DPMS timeouts]' \
            '+dpms[enable DPMS]' \
            '-dpms[disable DPMS]' \
            'fc[font cache marks]' \
            'fp=[set font path]' \
            'fp[font path command (default rehash)]' \
            '+fp[append to font path]' \
            '-fp[remove from font path]' \
            'fp+[append to font path]' \
            'fp-[remove from font path]' \
            'led[set LED states on]' \
            '-led[set LED states off]' \
            'm[mouse acceleration/threshold]' \
            'p[set pixel colors]' \
            'r[auto-repeat options]' \
            '-r[turn auto-repeat off]' \
            's[screen-saver control]' \
            'q[print status]' \
            && ret=0
        ;;
esac

return ret
