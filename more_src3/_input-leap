#compdef input-leaps input-leapc input-leapd barriers barrierc barrierd
# Documentation: input-leap server/client
# Source: input-leap/input-leap src/lib/inputleap/ArgParser.cpp (master) — mouse/keyboard sharing (C++, fork of barrier/synergy).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --address)'{-a+,--address=}'[server address[\:port]]:addr:_default' \
    '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
    '--screen-change-script=[script on screen change]:script:_files' \
    '--disable-client-cert-checking[disable client cert verify]' \
    '--yscroll=[Y scroll delta]:N:_default' \
    '--service[run as service]' \
    '--exit-pause[pause before exit]' \
    '--stop-on-desk-switch[stop on Windows desk switch]' \
    '--use-x11[force X11 backend]' \
    '-display+[X display]:display:_x_display' \
    '--display=[X display]:display:_x_display' \
    '--use-ei[force libei backend]' \
    '--disable-portal[disable XDG Portal]' \
    '(-d --debug)'{-d+,--debug=}'[log level]:level:(FATAL ERROR WARNING NOTE INFO DEBUG DEBUG1 DEBUG2)' \
    '(-l --log)'{-l+,--log=}'[log file]:file:_files' \
    '(-f --no-daemon)'{-f,--no-daemon}'[do not daemonize]' \
    '--daemon[daemonize]' \
    '(-n --name)'{-n+,--name=}'[screen name]:name:_default' \
    '(-1 --no-restart)'{-1,--no-restart}'[do not restart on failure]' \
    '--restart[automatically restart]' \
    '--no-hooks[do not install hooks]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--no-tray[no tray icon]' \
    '--ipc[enable IPC interface]' \
    '--server[run as server]' \
    '--client[run as client]' \
    && ret=0

return ret
