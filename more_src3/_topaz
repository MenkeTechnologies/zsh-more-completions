#compdef topaz
# _topaz — Aserto Topaz authorization service CLI (aserto-dev team, Go); cobra
# upstream: https://github.com/aserto-dev/topaz

_topaz() {
    local -a sub=(
        'auth:auth subcommands'
        'auth:login:login to control plane'
        'auth:logout:logout'
        'auth:whoami:show current user'
        'configure:create or edit configuration'
        'console:open the Topaz console UI'
        'directory:directory subcommands'
        'directory:check:check relations'
        'directory:export:export directory'
        'directory:import:import directory'
        'directory:list:list directory objects'
        'directory:get-object:get object'
        'directory:get-relation:get relation'
        'directory:get-manifest:show manifest'
        'directory:set-manifest:set manifest'
        'directory:delete-manifest:delete manifest'
        'directory:test:run directory tests'
        'directory:stats:show directory stats'
        'install:install topaz container'
        'load:load manifest+data into directory'
        'manifest:get:get manifest'
        'manifest:set:set manifest'
        'manifest:delete:delete manifest'
        'restart:restart container'
        'run:run topaz in foreground'
        'save:export and save manifest+data'
        'start:start topaz container'
        'status:show topaz status'
        'stop:stop topaz container'
        'templates:install:install a template'
        'templates:list:list templates'
        'templates:apply:apply template'
        'uninstall:uninstall container'
        'update:update topaz cli'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-file=+[config file]:file:_files -g "*.{yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{yaml,yml}"' \
        '--config-name=+[config name]:str:' \
        '-n+[config name]:str:' \
        '--no-color[no color]' \
        '--verbosity=+[level]:l:(0 1 2 3)' \
        '-v+[level]:l:(0 1 2 3)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'topaz subcommand' sub ;;
        args)
            case $words[1] in
                start|stop|restart|run|install|uninstall|update) _arguments \
                    '--container-name=+[container name]:str:' \
                    '--container-version=+[container version]:str:' \
                    '--container-platform=+[platform]:p:(linux/amd64 linux/arm64)' \
                    '--container-hostname=+[hostname]:host:_hosts' \
                    '--wait[wait for service ready]' ;;
                templates:apply|templates:install) _arguments \
                    '1:template:' \
                    '--no-tests[skip tests]' ;;
                directory:import|directory:export|load|save) _arguments \
                    '--directory=+[dir]:dir:_files -/' \
                    '-d+[dir]:dir:_files -/' \
                    '--file=+[file]:file:_files' \
                    '-f+[file]:file:_files' \
                    '--format=+[format]:f:(json yaml)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_topaz "$@"
