#compdef xwd
# Documentation: https://man.archlinux.org/man/xwd.1.en
# Reference accessed: 2026-05-30
# xwd — X Window Dumper. Dump an X11 window into a file (XWD format).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show usage syntax summary]' \
  '(- *)-version[show version]' \
  '-debug[activate debug mode]' \
  '(-d -display)'{-d,-display}'+[X server to connect to]:display:' \
  '-nobdrs[exclude window border pixels from the dump]' \
  '-out+[output file (default stdout)]:file:_files' \
  '-xy[use XY format instead of default Z format (color displays only)]' \
  '-add+[signed value added to every pixel]:value:' \
  '-frame[include window manager frame in selection]' \
  '(-root -id -name)-root[dump the root window automatically]' \
  '(-root -id -name)-id+[dump window with this resource ID]:id:' \
  '(-root -id -name)-name+[dump window with this WM_NAME property]:name:' \
  '-icmap[use first installed colormap instead of window'\''s colormap]' \
  '-screen[capture image from root window (overlapping windows + popups)]' \
  '-silent[suppress bell sounds during dumping]' \
  && ret=0

return ret
