#compdef kubectl-oidc-login
# Documentation: https://github.com/int128/kubelogin
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:subcommand:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'get-token:exec plugin entrypoint (used in kubeconfig)'
      'setup:setup helper (dump ID token claims)'
      'clean:delete cached tokens'
      'version:print version'
    )
    _describe -t commands 'kubectl-oidc-login command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--oidc-issuer-url=[OIDC issuer URL]:url:' \
      '--oidc-client-id=[OIDC client ID]:id:' \
      '--oidc-client-secret=[OIDC client secret]:secret:' \
      '--oidc-extra-scope=[extra OIDC scope]:scope:' \
      '--oidc-use-pkce[use PKCE]' \
      '--grant-type=[grant type]:type:(auto authcode authcode-keyboard password client-credentials device-code)' \
      '--listen-address=[address to listen on for authcode]:addr:' \
      '--skip-open-browser[do not open browser]' \
      '--certificate-authority=[CA certificate file]:file:_files' \
      '--insecure-skip-tls-verify[skip TLS verification]' \
      '-v+[log verbosity level]:level:' \
      '*: : _default' && ret=0
    ;;
esac

return ret
