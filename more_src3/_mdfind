#compdef mdfind
# Documentation: https://www.unix.com/man-page/osx/1/mdfind/
# Source: Apple macOS — Spotlight metadata search CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-0[print NUL after each result path (for xargs -0)]' \
    '-live[live-update count of matching files]' \
    '-count[print total matches instead of paths]' \
    '-onlyin[limit search to this directory]:dir:_directories' \
    '-name[match against file name only]:filename:' \
    '(-literal -interpret)-literal[treat query string literally]' \
    '(-literal -interpret)-interpret[interpret as if typed into Spotlight menu]' \
    '*:query:' \
    && ret=0

return ret
