#compdef webpack
# Documentation: https://webpack.js.org/api/cli/
# Source: webpack-cli — JS module bundler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '*--entry=[entry point(s) (e.g. ./src/main.js)]:file:_files' \
    '(-c --config)'{-c+,--config=}'[webpack config file]:file:_files' \
    '*--config-name=[name of configuration to use (multi-config)]:name:' \
    '--name=[name of configuration]:name:' \
    '(--color --no-color)--color[enable console colors]' \
    '(--color --no-color)--no-color[disable console colors]' \
    '(-m --merge)'{-m,--merge}'[merge configurations with webpack-merge]' \
    '*--env=[environment passed to config function]:env:' \
    '--config-node-env=[set process.env.NODE_ENV]:env:' \
    '--progress=-[print compilation progress (optional value)]:format:' \
    '(- *)--help[show help]' \
    '(-o --output-path)'{-o+,--output-path=}'[output dir]:dir:_directories' \
    '*'{-t,--target=}'[build target]:target:(node web webworker electron-main electron-preload electron-renderer node-webkit nwjs es2015 es2017 es5)' \
    '(-w --watch --no-watch)'{-w,--watch}'[watch for file changes]' \
    '(-w --watch --no-watch)--no-watch[do not watch]' \
    '(--watch-options-stdin --no-watch-options-stdin)--watch-options-stdin[stop watching when stdin ends]' \
    '(--watch-options-stdin --no-watch-options-stdin)--no-watch-options-stdin[keep watching after stdin ends]' \
    '(-d --devtool --no-devtool)'{-d+,--devtool=}'[source map type]:devtool:(eval eval-source-map cheap-eval-source-map cheap-source-map inline-source-map inline-cheap-source-map inline-cheap-module-source-map source-map nosources-source-map hidden-source-map)' \
    '(-d --devtool --no-devtool)--no-devtool[do not generate source maps]' \
    '(-j --json)'{-j-,--json=-}'[print result as JSON / write to file]:file:_files' \
    '--mode=[mode]:mode:(development production none)' \
    '(- *)'{-v,--version}'[show version]' \
    '(--stats --no-stats)--stats=[stats output format]:stats:' \
    '(--stats --no-stats)--no-stats[disable stats output]' \
    '--disable-interpret[disable interpret for config loading]' \
    '--fail-on-warnings[non-zero exit on warnings]' \
    '--analyze[invoke webpack-bundle-analyzer]' \
    '*'{-e,--extends=}'[extend existing config]:file:_files' \
    '--no-hot[disable hot reloading]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'build:run webpack (default)'
            'bundle:run webpack (alias)'
            'b:run webpack (alias)'
            'configtest:validate a webpack configuration'
            't:validate a webpack configuration (alias)'
            'help:display help'
            'h:display help (alias)'
            'info:output system information'
            'i:output system information (alias)'
            'serve:run webpack-dev-server'
            'server:run webpack-dev-server (alias)'
            's:run webpack-dev-server (alias)'
            'version:print version'
            'v:print version (alias)'
            'watch:run webpack and watch'
            'w:run webpack and watch (alias)'
            'init:scaffold a new webpack project'
            'loader:scaffold a loader'
            'plugin:scaffold a plugin'
        )
        _describe -t subcmds 'webpack command' subcmds && ret=0
        ;;
    args)
        _files && ret=0
        ;;
esac

return ret
