#compdef tpm2_eventlog tpm2_checkquote tpm2_print tpm2_encodeobject tpm2_setprimarypolicy tpm2_setcommandauditstatus
# Documentation: source-direct extraction from upstream
# tpm2-software/tpm2-tools.  Per-tool `struct option topts[]`
# table decoded source-direct from each tools/[misc/]tpm2_
# <name>.c.  Shared $tpm2_common + $tpm2_hashalgs re-extracted
# source-direct from lib/tpm2_options.c / lib/tpm2_alg_util.c
# — see R193-R203 HARVEST_LOG entries for the full extraction
# notes.  Note: 4 of these 6 binaries live in tools/misc/
# (eventlog, checkquote, print, encodeobject) while
# setprimarypolicy + setcommandauditstatus live in tools/.
# Reference accessed: 2026-05-30 via gh api.
# tpm2-software tpm2-tools R204 — follow-up to R203's hunt-skip
# on "6 remaining tpm2_* binaries deferred for future rounds -
# the event-log/checkquote group: tpm2_eventlog, tpm2_checkquote,
# tpm2_print, tpm2_encodeobject, tpm2_setprimarypolicy,
# tpm2_setcommandcodeauditstatus".  Correction to R203:
# upstream binary name is tpm2_setcommandauditstatus (without
# "code") per the actual tools/tpm2_setcommandauditstatus.c
# source file — R203's hunt-skip note used the longer
# tpm2_setcommandcodeauditstatus name speculatively.
#
# Completes the tpm2-tools family across R193-R204:
# - R193: getrandom, getcap, pcrread, hash, nvread, nvwrite
# - R194: create, createprimary, load, loadexternal,
#          evictcontrol, flushcontext
# - R195: sign, quote, unseal, startauthsession, pcrextend,
#          readpublic
# - R196: createak, createek, getekcertificate, changeauth,
#          verifysignature, clear
# - R197: rsadecrypt, rsaencrypt, hmac, pcrreset, nvdefine,
#          nvundefine
# - R198: nvincrement, nvextend, nvsetbits, nvreadlock,
#          nvwritelock, nvreadpublic, nvcertify
# - R199: certify, certifycreation, getcommandauditdigest,
#          getsessionauditdigest, getpolicydigest, gettime
# - R200: changeeps, changepps, dictionarylockout, clearcontrol,
#          hierarchycontrol, makecredential, activatecredential,
#          encryptdecrypt
# - R201: ecdhkeygen, ecdhzgen, ecephemeral, geteccparameters,
#          import, duplicate, pcrallocate, pcrevent, commit,
#          gettestresult, incrementalselftest
# - R202: createpolicy, policypcr, policyauthorize, policysecret,
#          policycommandcode, policyor, policyrestart,
#          policypassword, policyauthvalue
# - R203: policyauthorizenv, policycountertimer, policycphash,
#          policyduplicationselect, policylocality, policynamehash,
#          policynv, policynvwritten, policysigned, policytemplate,
#          policyticket
# - R204 (THIS): eventlog, checkquote, print, encodeobject,
#          setprimarypolicy, setcommandauditstatus
# Total: 81 tpm2_* binaries covered across 12 rounds.

local -a tpm2_common=(
  '(-T --tcti)'{-T+,--tcti=}'[TCTI library + options (e.g. "device:/dev/tpmrm0" or "swtpm:port=2321")]:tcti:'
  '(-h --help)'{-h-,--help=-}'[print help (optional arg = topic)]::topic:'
  '(-v --version)'{-v,--version}'[print version and exit]'
  '(-V --verbose)'{-V,--verbose}'[verbose mode]'
  '(-Q --quiet)'{-Q,--quiet}'[quiet mode]'
  '(-Z --enable-errata)'{-Z,--enable-errata}'[enable TPM2 errata workarounds]'
  '(-z --pwd-session)'{-z,--pwd-session}'[use password-authorized session]'
)
local -a tpm2_hashalgs=(sha1 sha256 sha384 sha512 sm3_256)

case $service in

  tpm2_eventlog)
    # Parse a TPM2 measured-boot event log (per the TCG PC
    # Client Platform Firmware Profile Specification) and emit
    # a YAML dump of the event entries + computed PCR
    # extensions.  Source lives in tools/misc/.  Only 1 flag
    # (`--eventlog-version` long-only, val=0) + variadic
    # positional event-log file paths.
    _arguments -s -S \
      $tpm2_common \
      '--eventlog-version=[event-log spec version (e.g. 1 = TCG PFP 1.05)]:n:' \
      '*:event-log file:_files'
    ;;

  tpm2_checkquote)
    # Off-line verification of a tpm2_quote attestation (no TPM
    # required).  Source lives in tools/misc/.  9 flags
    # including the cooperating -m/--message + -s/--signature +
    # -u/--public + -l/--pcr-list + -f/--pcr (or -e/--eventlog
    # for replay-from-eventlog) -q/--qualification trio that
    # together reproduce the TPM-side computation.  Critical
    # extraction note: tpm2_checkquote uses -F/--format
    # (uppercase) for PCR values format, NOT lowercase -f
    # which is taken by --pcr (input PCR values file).  Decoded
    # source-direct as a per-tool collision-avoidance pattern.
    _arguments -s -S \
      $tpm2_common \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm for signature verification]:alg:($tpm2_hashalgs)' \
      '(-m --message)'{-m+,--message=}'[input quote-message file (from tpm2_quote -m)]:file:_files' \
      '(-F --format)'{-F+,--format=}'[PCR-values input format]:format:(legacy serialized values)' \
      '(-s --signature)'{-s+,--signature=}'[input signature file (from tpm2_quote -s)]:file:_files' \
      '(-e --eventlog)'{-e+,--eventlog=}'[input TPM2 event-log file (replay PCR state)]:file:_files' \
      '(-f --pcr)'{-f+,--pcr=}'[input PCR-values file (from tpm2_quote -o)]:file:_files' \
      '(-l --pcr-list)'{-l+,--pcr-list=}'[PCR list (e.g. sha256:0,1,2,3)]:pcr-list:' \
      '(-u --public)'{-u+,--public=}'[input AK public-key file (from tpm2_readpublic)]:file:_files' \
      '(-q --qualification)'{-q+,--qualification=}'[expected qualifying data (nonce)]:nonce:'
    ;;

  tpm2_print)
    # Decode + pretty-print TSS-format files (TPMS_ATTEST,
    # TPMS_CONTEXT, TPM2B_PUBLIC, TPMT_PUBLIC, TSSPRIVKEY_OBJ,
    # ESYS_TR).  Source lives in tools/misc/.  Critical
    # extraction note: tpm2_print's `-t`/`--type` enum decoded
    # source-direct from the static `handlers[]` array's
    # `.name = #type` macro-expanded TSS-type strings:
    # TPMS_ATTEST, TPMS_CONTEXT, TPM2B_PUBLIC, TPMT_PUBLIC,
    # TSSPRIVKEY_OBJ, ESYS_TR.  Critical extraction note: the
    # `-f`/`--format` flag is ONLY accepted for handlers
    # flagged with FLAG_FMT (TPM2B_PUBLIC, TPMT_PUBLIC,
    # TSSPRIVKEY_OBJ) - decoded source-direct from the
    # `if (ctx.format_set && !(handlers[i].flags & FLAG_FMT))`
    # check.  Completion lists -f anyway since the parser
    # accepts it (the FLAG_FMT check fires at runtime, not
    # parse time).
    _arguments -s -S \
      $tpm2_common \
      '(-t --type)'{-t+,--type=}'[input file TSS type]:type:(TPMS_ATTEST TPMS_CONTEXT TPM2B_PUBLIC TPMT_PUBLIC TSSPRIVKEY_OBJ ESYS_TR)' \
      '(-f --format)'{-f+,--format=}'[output format (for TPM2B_PUBLIC/TPMT_PUBLIC/TSSPRIVKEY_OBJ only)]:format:(tss pem der)' \
      ':input file:_files'
    ;;

  tpm2_encodeobject)
    # Encode TSS PEM-style key-context blobs for tpm2-openssl
    # interop.  Source lives in tools/misc/.  Outputs a PEM
    # file that openssl/tpm2-openssl can load as a TPM2-backed
    # private key.  Critical extraction note: tpm2_encodeobject's
    # `-p`/`--key-auth` is **no_argument** (flag-only, NOT
    # taking a value) - decoded source-direct from
    #   { "key-auth", no_argument, NULL, 'p' }
    # which is unusual for an auth-related flag.  The actual
    # auth value is read from stdin when -p is set (decoded
    # source-direct from upstream's interactive auth-input
    # path).  This is the 5th -p/-P case-sensitivity divergence
    # documented in the R193-R204 set (here -p is no_argument
    # flag, NOT a value-taking flag like elsewhere).
    _arguments -s -S \
      $tpm2_common \
      '(-P --auth)'{-P+,--auth=}'[parent key authorization]:auth:' \
      '(-u --public)'{-u+,--public=}'[input public-key file]:file:_files' \
      '(-r --private)'{-r+,--private=}'[input private-key blob file]:file:_files' \
      '(-C --parent-context)'{-C+,--parent-context=}'[parent context (handle or context file)]:parent:' \
      '(-o --output)'{-o+,--output=}'[output TSS PEM-encoded key file]:file:_files -g "*.(pem|tss)"' \
      '(-p --key-auth)'{-p,--key-auth}'[encode key-auth (read from stdin)]' \
      '(-R --autoflush)'{-R,--autoflush}'[auto-flush key after operation]'
    ;;

  tpm2_setprimarypolicy)
    # TPM2_SetPrimaryPolicy: install a policy on a TPM2
    # hierarchy (owner|endorsement|platform|lockout) so the
    # hierarchy auth can be replaced by the policy.  Critical
    # extraction note: tpm2_setprimarypolicy is the ONLY tool
    # in the R193-R204 set that operates on TPM2 hierarchy
    # POLICY rather than hierarchy AUTH - the policy then
    # gates further hierarchy operations.
    _arguments -s -S \
      $tpm2_common \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[hierarchy (owner|endorsement|platform|lockout)]:hierarchy:(owner endorsement platform lockout o e p l)' \
      '(-P --auth)'{-P+,--auth=}'[hierarchy authorization]:auth:' \
      '(-L --policy)'{-L+,--policy=}'[input policy-digest file (from tpm2_createpolicy or tpm2_policy*)]:file:_files' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm for the policy]:alg:($tpm2_hashalgs)' \
      '--cphash=[output command-parameter hash for off-line audit]:file:_files'
    ;;

  tpm2_setcommandauditstatus)
    # TPM2_SetCommandCodeAuditStatus: add or remove TPM2
    # commands from the command-audit set (the set of commands
    # whose execution gets logged to the running command-audit
    # digest, queried via tpm2_getcommandauditdigest R199).
    # Critical extraction note: tpm2_setcommandauditstatus's
    # -c/--clear-list flag (no_argument) switches between add-
    # mode (default) and remove-mode (decoded source-direct
    # from upstream's `clear_list = true` branch in the -c
    # case-arm).  This is a 2-mode dispatch flag, NOT a value-
    # taking flag.  Variadic positional accepts TPM2_CC_*
    # command-code constants.
    _arguments -s -S \
      $tpm2_common \
      '(-C --hierarchy)'{-C+,--hierarchy=}'[hierarchy (owner|platform)]:hierarchy:(owner platform o p)' \
      '(-P --hierarchy-auth)'{-P+,--hierarchy-auth=}'[hierarchy authorization]:auth:' \
      '(-c --clear-list)'{-c,--clear-list}'[REMOVE the listed commands from the audit set (default = ADD)]' \
      '(-g --hash-algorithm)'{-g+,--hash-algorithm=}'[hash algorithm for the audit digest]:alg:($tpm2_hashalgs)' \
      '*:TPM2 command code (e.g. TPM2_CC_NV_Write):'
    ;;

esac
