#compdef stata stata-mp stata-se stata-ic xstata xstata-mp xstata-se xstata-ic
# _stata — StataCorp stata CLI Stata statistical software for data management analysis and graphics command-line shell supporting OLS GLS panel-data discrete-choice maximum-likelihood survey-weights mixed-effects survival-analysis time-series ARIMA VECM Bayesian-MCMC structural-equation programming via do-files (StataCorp team, C); custom argparse
# upstream: https://www.stata.com/

_stata() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[suppress logo]' \
        '-b+[batch script]:file:_files -g "*.do *.ado"' \
        '-e+[script with exit]:file:_files -g "*.do *.ado"' \
        '-d[do log]' \
        '-s[set search mode]' \
        '-mt+[threads]:n:' \
        '--multithread=+[N]:n:' \
        '--init-do=+[file]:file:_files -g "*.do"' \
        '*:do file:_files -g "*.do *.ado *.dta *.csv *.txt"'
}

_stata "$@"
