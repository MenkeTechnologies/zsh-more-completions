#compdef hedgedoc
# _hedgedoc — HedgeDoc collaborative real-time markdown notes platform forked from CodiMD (hedgedoc team, Node.js); standard argv
# upstream: https://github.com/hedgedoc/hedgedoc

_hedgedoc() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "config.json *.yml *.yaml"' \
        '-c+[config file]:file:_files' \
        '--host=+[bind host]:host:_hosts' \
        '--port=+[http port]:port:_ports' \
        '-p+[http port]:port:_ports' \
        '--path=+[unix socket]:file:_files' \
        '--protocol-use-ssl[force ssl protocol]' \
        '--use-cdn[use CDN]' \
        '--allow-anonymous[allow anonymous editing]' \
        '--allow-anonymous-edits[allow anonymous edits]' \
        '--allow-free-url[allow free url]' \
        '--allow-email-register[allow email register]' \
        '--allow-pdf-export[allow pdf export]' \
        '--require-email-validation[require email validation]' \
        '--enable-stats-api[enable stats api]' \
        '--db=+[database url]:str:' \
        '--db-dialect=+[dialect]:d:(sqlite mariadb mysql postgres mssql)' \
        '--session-secret=+[session secret]:str:' \
        '--session-life=+[ms]:n:' \
        '--csp-enable[enable csp]' \
        '--csp-report-uri=+[report uri]:url:_urls' \
        '--csp-allow-pdf-embed[allow pdf in csp]' \
        '--access-log[enable access log]' \
        '--loglevel=+[level]:l:(debug verbose info warn error)' \
        '--image-upload-type=+[backend]:b:(filesystem imgur s3 minio azure lutim)' \
        '--upload-path=+[upload dir]:dir:_files -/' \
        '--email-domain-blacklist=+[domains csv]:str:' \
        '--enable-tos[enable terms]' \
        '--enable-privacystatement[enable privacy statement]'
}

_hedgedoc "$@"
