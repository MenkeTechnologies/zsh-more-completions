#compdef haskell-language-server-wrapper
# Documentation: https://haskell-language-server.readthedocs.io/en/latest/configuration.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--numeric-version[print numeric version]' \
  '--probe-tools[probe ghcup tools]' \
  '--print-libdir[print libdir]' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '(-l --log-file)'{-l,--log-file}'+[log file]:file:_files' \
  '(-c --compiler-only)'{-c,--compiler-only}'[only build compiler]' \
  '--cwd=+[working dir]:dir:_files -/' \
  '--shake-profiling=+[shake profile dir]:dir:_files -/' \
  '--test[run tests]' \
  '--example[example project]' \
  '*:project:_files -/' && ret=0

return ret
