#compdef lxterminal
# _lxterminal — LXDE lxterminal (lightweight GTK VTE terminal; --tabs comma-separated tab titles, --working-directory CWD, --command runs a single command, --geometry WxH, --title window title, --no-remote forces a new instance instead of attaching to running daemon)
# upstream: https://github.com/lxde/lxterminal
# Flags from lxterminal src/lxterminal.c on tip.

_lxterminal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--tabs+[tab titles, comma-separated]:titles:' \
        '--working-directory=*[working directory]:dir:_files -/' \
        '-e+[run command]:command:_command_names -e' \
        '--command=*[run command]:command:_command_names -e' \
        '--geometry=*[WxH]:geom:' \
        '-t+[window title]:title:' \
        '--title=*[window title]:title:' \
        '--no-remote[skip remote-instance attach]' \
        '--loginshell[run as login shell]'
}

_lxterminal "$@"
