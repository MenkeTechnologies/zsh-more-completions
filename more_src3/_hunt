#compdef hunt
# Documentation: man hunt(6)
# Source: openbsd/src games/hunt/hunt/hunt.c — multi-player maze game (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-l -n)-l+[player name]:name:_default' \
    '(-l -n)-n+[player name (alias)]:name:_default' \
    '-t+[team number]:team:_default' \
    '-o[otto (autopilot) mode]' \
    '-m[monitor mode]' \
    '-S[show top scores]' \
    '-q[query whether driver is running]' \
    '-w+[broadcast message]:message:_default' \
    '-h+[hunt driver host]:host:_hosts' \
    '-p+[hunt driver port]:port:_default' \
    '(-c -f -s)-c[enter cloaked]' \
    '(-c -f -s)-f[enter flying]' \
    '(-c -f -s)-s[enter scanning]' \
    '-b[toggle beep on quit]' \
    '1::host:_hosts' \
    && ret=0

return ret
