#compdef smartgit smartgithg
# _smartgit — Syntevo SmartGit Java-based Git GUI CLI (Syntevo, Java); custom argparse
# upstream: https://www.syntevo.com/smartgit

_smartgit() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--shutdown[shutdown running instance]' \
        '--logfile=+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--config=+[settings dir]:dir:_files -/' \
        '-c+[settings dir]:dir:_files -/' \
        '--data=+[data dir]:dir:_files -/' \
        '--clean[clean cache]' \
        '--repo=+[repository path]:dir:_files -/' \
        '-r+[repository path]:dir:_files -/' \
        '--newinstance[new instance]' \
        '-n[new instance]' \
        '--vm=+[JVM]:file:_files' \
        '--vmargs=+[JVM args]:str:' \
        '--language=+[language]:str:' \
        '--locale=+[locale]:str:' \
        '--debug[debug]' \
        '--print-arguments[print arguments and exit]' \
        '--print-version[print version and exit]' \
        '*:path:_files'
}

_smartgit "$@"
