#compdef tiptop
# Documentation: https://github.com/nschloe/tiptop
# Reference accessed: 2026-05-21
# Verified: upstream README OPTIONS list.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-l --log)'{-l,--log}'[debug log file]:log:_files' \
  '(-n --net)'{-n,--net}'[network interface]:interface:' && ret=0

return ret
