#compdef verilator_coverage verilator_gantt verilator_includer verilator_profcfunc verilator_ccache_report verilator_difftree
# Documentation: source-direct extraction from upstream
# verilator/verilator
#   bin/verilator_coverage (Perl wrapper passes flags through to
#     verilator_coverage_bin_dbg) — actual flag surface in
#     src/VlcMain.cpp `DECL_OPTION(...)` table.
#   bin/verilator_gantt — argparse parser.add_argument(...).
#   bin/verilator_includer — bare positional `-Ddef=val FILE...`
#     pattern read from `sys.argv[1:]` argv-walking loop.
#   bin/verilator_profcfunc — argparse parser.add_argument(...).
#   bin/verilator_ccache_report — argparse parser.add_argument(...).
#   bin/verilator_difftree — argparse parser.add_argument(...).
# Reference accessed: 2026-05-30 via gh api.
# verilator R164 — 6-stem multi-binary harvest of the verilator
# companion tooling shipped in the same bin/ directory as the
# already-covered `verilator` Perl driver.  Sister tools to the
# already-covered verilator main driver + verilator_bin.
# verilator_coverage merges per-test coverage databases;
# verilator_gantt plots multi-threaded execution timelines;
# verilator_includer generates a stub `.cpp` re-exporter from
# `-Ddef=val FILE.h ...` argv;
# verilator_profcfunc post-processes gprof output produced by
# --prof-cfuncs builds;
# verilator_ccache_report scans a build log directory and
# reports ccache hit-rate;
# verilator_difftree diffs two Verilator debug-tree dumps with
# pointer-difference suppression.

case $service in

  verilator_coverage)
    # verilator parses both -flag and --flag for every switch, so
    # each entry is registered under both prefixes.  Source:
    # DECL_OPTION("-x", ...) in src/VlcMain.cpp.
    _arguments -s -S \
      '(--annotate)-annotate=[annotate sources into output directory]:dir:_files -/' \
      '(-annotate)--annotate=[annotate sources into output directory]:dir:_files -/' \
      '(--annotate-all)-annotate-all[annotate covered points as well as uncovered]' \
      '(-annotate-all)--annotate-all[annotate covered points as well as uncovered]' \
      '(--annotate-min)-annotate-min=[minimum hit-count for a point to be considered covered (default 10)]:n:' \
      '(-annotate-min)--annotate-min=[minimum hit-count for a point to be considered covered (default 10)]:n:' \
      '(--annotate-points)-annotate-points[annotate per-coverage-point detail]' \
      '(-annotate-points)--annotate-points[annotate per-coverage-point detail]' \
      '(--debug)-debug[enable debug output]' \
      '(-debug)--debug[enable debug output]' \
      '(--debugi)-debugi=[set debug level]:n:' \
      '(-debugi)--debugi=[set debug level]:n:' \
      '(--filter-type)-filter-type=[wildcard filter on coverage-point type (default *)]:glob:' \
      '(-filter-type)--filter-type=[wildcard filter on coverage-point type (default *)]:glob:' \
      '(--include-reset-arcs)-include-reset-arcs[include reset arcs in coverage]' \
      '(-include-reset-arcs)--include-reset-arcs[include reset arcs in coverage]' \
      '(--rank)-rank[rank input coverage databases by goodness]' \
      '(-rank)--rank[rank input coverage databases by goodness]' \
      '(--unlink)-unlink[unlink input coverage databases after merging]' \
      '(-unlink)--unlink[unlink input coverage databases after merging]' \
      '-V[verbose: print version and configuration then exit]' \
      '--V[verbose: print version and configuration then exit]' \
      '-version[print version and exit]' \
      '--version[print version and exit]' \
      '(--write)-write=[output merged coverage database]:file:_files' \
      '(-write)--write=[output merged coverage database]:file:_files' \
      '(--write-info)-write-info=[output annotated .info (LCOV-compatible) file]:file:_files -g "*.info"' \
      '(-write-info)--write-info=[output annotated .info (LCOV-compatible) file]:file:_files -g "*.info"' \
      '*:coverage database (.dat):_files -g "*.dat"'
    ;;

  verilator_gantt)
    _arguments -s -S \
      '--debug[enable debug output]' \
      '--no-vcd[disable creating vcd output]' \
      '--vcd=[output vcd filename (default profile_exec.vcd)]:file:_files -g "*.vcd"' \
      '1:input profile_exec.dat (default profile_exec.dat):_files -g "*.dat"'
    ;;

  verilator_includer)
    # No flags - each argv is either -Ddef=value or a header path.
    # Pattern is `-D<name>=<value>` decoded source-direct from
    # `re_arg_d = re.compile(r"^-D([^=]+)=(.*)")`.
    _arguments -s -S \
      '*:-D<name>=<value> macro OR header file:_files -g "*.(h|hpp|hh|hxx)"'
    ;;

  verilator_profcfunc)
    _arguments -s -S \
      '--debug[enable debug output]' \
      '1:input gprof output file:_files'
    ;;

  verilator_ccache_report)
    _arguments -s -S \
      '-o+[output file (required)]:file:_files' \
      '1:log directory:_files -/'
    ;;

  verilator_difftree)
    _arguments -s -S \
      '--debug[enable debug output]' \
      '--no-lineno[do not show differences in line numbering]' \
      '1:input file a or directory a:_files' \
      '2:input file b or directory b:_files'
    ;;

esac
