#compdef trogdor
# Documentation: https://github.com/apache/kafka/blob/trunk/bin/trogdor.sh
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'agent:run the trogdor agent'
  'coordinator:run the trogdor coordinator'
  'client:run the client communicating with the coordinator'
  'agent-client:run the client communicating with the agent'
  'help:show help'
)

_arguments -C \
  '1: :->action' \
  '*::option:->options' && ret=0

case $state in
  (action)
    _describe -t actions 'trogdor action' actions && ret=0
    ;;
esac

return ret
