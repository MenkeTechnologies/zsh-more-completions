#compdef hindent
# Documentation: https://github.com/mihaimaruseac/hindent
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--line-length=[desired line length]:n:' \
  '--indent-size=[indentation size]:n:' \
  '--tab-size=[same as --indent-size]:n:' \
  '--no-force-newline[do not force trailing newline]' \
  '--sort-imports[sort imports in groups]' \
  '--no-sort-imports[do not sort imports]' \
  '--style=[style (historical, ignored)]:style:' \
  '--validate[check formatting without changing files]' \
  '*-X+[GHC language extension]:ext:' \
  '*:file:_files -g "*.(hs|lhs)"'
