#compdef ksuid
# Documentation: https://github.com/segmentio/ksuid/blob/master/cmd/ksuid/main.go
# Reference accessed: 2026-05-19
# Verified: upstream cmd/ksuid/main.go flag definitions - single-dash
# Go flags only. Removed from prior file: invented --count/--format/
# --template/--verbose/--version/--help long forms and wrong -f enum
# (real values: string inspect time timestamp payload raw template).

local curcontext="$curcontext" ret=1

_arguments -s \
  '-n+[number of KSUIDs to generate]:count:' \
  '-f+[output format]:format:(string inspect time timestamp payload raw template)' \
  '-t+[Go template used to format the output]:template:' \
  '-v[turn on verbose mode]' \
  '*:ksuid to inspect:' && ret=0

return ret
