#compdef tinyproxy-cli
# _tinyproxy-cli — Tinyproxy lightweight HTTP/HTTPS proxy daemon CLI alias (tinyproxy team, C); custom argparse
# upstream: https://github.com/tinyproxy/tinyproxy

_tinyproxy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d[do not daemonize, run in foreground]' \
        '-c+[config file]:file:_files -g "tinyproxy.conf"' \
        '-l[show license]' \
        '*:arg:'
}

_tinyproxy-cli "$@"
