#compdef zita-resampler zita-resampler-test zresample
# _zita-resampler — Fons Adriaensen zita-resampler high-quality polyphase sample-rate converter CLI for audio file rate conversion with selectable filter quality (kokkinizita team, C++); getopt
# upstream: http://kokkinizita.linuxaudio.org/linuxaudio/zita-resampler/

_zita-resampler() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[output Hz]:n:(8000 11025 16000 22050 32000 44100 48000 88200 96000 176400 192000)' \
        '--rate=+[output Hz]:n:(8000 11025 16000 22050 32000 44100 48000 88200 96000 176400 192000)' \
        '-q+[quality 16-96]:n:' \
        '--quality=+[quality 16-96]:n:' \
        '-g+[gain dB]:f:' \
        '--gain=+[gain dB]:f:' \
        '-b+[bit depth]:n:(8 16 24 32)' \
        '--bits=+[bit depth]:n:(8 16 24 32)' \
        '-f+[format]:f:(wav flac ogg opus aiff au snd raw)' \
        '--format=+[format]:f:(wav flac ogg opus aiff au snd raw)' \
        '-d[dither]' \
        '--dither[dither]' \
        '-D+[dither shape]:s:(rectangular triangular highpass)' \
        '-o+[output file]:file:_files -g "*.wav *.flac *.ogg *.aiff *.au *.snd"' \
        '--output=+[output file]:file:_files -g "*.wav *.flac *.ogg *.aiff *.au *.snd"' \
        '*:input audio:_files -g "*.wav *.flac *.ogg *.aiff *.au *.snd *.opus *.mp3"'
}

_zita-resampler "$@"
