#compdef hyper
# _hyper-bin — Hyper Electron-based terminal (Vercel); JS/CSS configurable terminal with plugin ecosystem
# upstream: https://github.com/vercel/hyper

_hyper-bin() {
    local -a sub=(
        'install:install a plugin'
        'uninstall:uninstall a plugin'
        'list:list installed plugins'
        'ls:alias for list'
        'docs:open plugin docs'
        'd:alias for docs'
        'search:search npm for plugins'
        's:alias for search'
        'lsr:list installed plugins (remote)'
        'help:show help'
        'version:show version'
        'i:alias for install'
        'u:alias for uninstall'
        '<file>:open file in hyper'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--verbose[verbose log]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hyper subcommand' sub ;;
        args)
            case $words[1] in
                install|i|uninstall|u|docs|d|search|s) _arguments '*:plugin:' ;;
            esac
            ;;
    esac
}

_hyper-bin "$@"
