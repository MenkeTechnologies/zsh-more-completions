#compdef dec265 enc265 libde265 dehevc enhevc
# _libde265 — Struktur AG libde265 dec265 enc265 open-source H.265 HEVC encoder and decoder implementation (struktur team, C++); getopt
# upstream: https://github.com/strukturag/libde265

_libde265() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.h265 *.hevc *.bit *.265 *.bin *.yuv"' \
        '--input=+[input file]:file:_files -g "*.h265 *.hevc *.bit *.265 *.bin *.yuv"' \
        '-o+[output file]:file:_files -g "*.yuv *.y4m *.bin *.h265 *.hevc *.bit *.265"' \
        '--output=+[output file]:file:_files -g "*.yuv *.y4m *.bin *.h265 *.hevc *.bit *.265"' \
        '-q+[QP]:n:' \
        '--qp=+[QP]:n:' \
        '-Q[quiet]' \
        '--quiet[quiet]' \
        '-c+[check hash]:n:' \
        '--check-hash=+[check hash]:n:' \
        '-d[disable deblocking]' \
        '--no-deblock[disable deblocking]' \
        '-s[disable SAO]' \
        '--no-sao[disable SAO]' \
        '--frames=+[N]:n:' \
        '--threads=+[N]:n:' \
        '-T+[N]:n:' \
        '--width=+[N]:n:' \
        '-w+[N]:n:' \
        '--height=+[N]:n:' \
        '-h+[N]:n:' \
        '--input-frame-rate=+[fps]:f:' \
        '--cb-size=+[N]:n:' \
        '--tb-size=+[N]:n:' \
        '--profile=+[profile]:p:(main main10 main12 main-still-picture monochrome scc)' \
        '--level=+[N]:f:' \
        '--tier=+[tier]:t:(main high)' \
        '--bit-depth=+[N]:n:(8 10 12 16)' \
        '--input-chroma=+[chroma]:c:(400 420 422 444)' \
        '--chroma=+[chroma]:c:(400 420 422 444)' \
        '--no-mv[no MV]' \
        '--no-residual[no residual]' \
        '-n[print frame numbers]' \
        '--measure-time[measure time]' \
        '-m[measure time]' \
        '--limit=+[N]:n:' \
        '*:input file:_files -g "*.h265 *.hevc *.bit *.265 *.bin *.yuv *.y4m"'
}

_libde265 "$@"
