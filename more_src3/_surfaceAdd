#compdef surfaceAdd
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceAdd — add two surfaces and write output surface (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-points+[file with additional points]:file:_files' \
    '-mergeRegions[combine regions from both surfaces]' \
    '1:surface 1:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '2:surface 2:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '3:output surface:_files' \
    && ret=0

return ret
