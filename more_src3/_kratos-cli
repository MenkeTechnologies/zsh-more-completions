#compdef kratos-cli
# _kratos-cli — Ory Kratos identity and user-management API CLI alias (ory team, Go); cobra
# upstream: https://github.com/ory/kratos

_kratos-cli() {
    local -a sub=(
        'serve:run the server'
        'migrate:run migrations'
        'migrate:status:show migration status'
        'migrate:sql:run sql migrations'
        'migrate:up:run pending migrations'
        'migrate:down:rollback migrations'
        'identities:list:list identities'
        'identities:get:get identity'
        'identities:import:import identities'
        'identities:delete:delete identity'
        'identities:patch:patch identity'
        'identities:validate:validate schema'
        'hashers:list:list available hashers'
        'jsonnet:format:format jsonnet file'
        'jsonnet:lint:lint jsonnet file'
        'remote:status:show remote status'
        'remote:version:show remote version'
        'courier:watch:run courier'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.{yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{yaml,yml}"' \
        '--endpoint=+[admin api]:url:_urls' \
        '-e+[admin api]:url:_urls' \
        '--format=+[format]:f:(default json json-pretty yaml table)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--skip-tls-verify[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kratos subcommand' sub ;;
        args)
            case $words[1] in
                identities:list) _arguments \
                    '--page=+[page]:n:' \
                    '--per-page=+[per page]:n:' \
                    '--include-credential=+[type]:t:(password totp oidc lookup_secret webauthn passkey code)' ;;
                identities:get|identities:delete|identities:patch) _arguments '*:identity id:' ;;
                identities:import) _arguments '*:identity file:_files -g "*.{json,yaml,yml}"' ;;
                migrate:status|migrate:sql|migrate:up|migrate:down) _arguments \
                    '--yes[skip confirmation]' \
                    '-y[skip confirmation]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kratos-cli "$@"
