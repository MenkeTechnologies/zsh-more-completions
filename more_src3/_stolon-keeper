#compdef stolon-keeper
# Documentation: https://github.com/sorintlab/stolon
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)--help[show help]' \
  '--cluster-name[cluster name]:name' \
  '--store-backend[store backend type]:backend:(consul etcdv2 etcdv3 kubernetes)' \
  '--store-endpoints[comma-separated list of store endpoints]:endpoints' \
  '--store-cert-file[path to store client certificate]:cert file:_files' \
  '--store-key[path to store client key]:key file:_files' \
  '--store-ca-file[path to store CA certificate]:CA file:_files' \
  '--store-skip-tls-verify[skip TLS verification for store]' \
  '--data-dir[data directory]:directory:_directories' \
  '--pg-su-username[PostgreSQL superuser username]:username' \
  '--pg-su-password[PostgreSQL superuser password]:password' \
  '--pg-su-passwordfile[PostgreSQL superuser password file]:file:_files' \
  '--pg-repl-username[PostgreSQL replication username]:username' \
  '--pg-repl-password[PostgreSQL replication password]:password' \
  '--pg-repl-passwordfile[PostgreSQL replication password file]:file:_files' \
  '--pg-bin-path[path to PostgreSQL binaries]:path:_directories' \
  '--pg-listen-address[PostgreSQL listen address]:address' \
  '--pg-port[PostgreSQL port]:port' \
  '--pg-advertise-address[PostgreSQL advertise address]:address' \
  '--pg-advertise-port[PostgreSQL advertise port]:port' \
  '--uid[keeper unique identifier]:uid' \
  '--log-color[enable colored log output]' \
  '--log-level[log level]:level:(info debug warn error)' \
  '--metrics-listen-address[metrics listen address]:address' \
  '--can-be-master[whether this keeper can be promoted to master]' \
  '--can-be-synchronous-replica[whether this keeper can be a synchronous replica]'
