#compdef urban-terror urbanterror
# Documentation: https://www.urbanterror.info/
# Reference accessed: 2026-05-21
# Verified: no upstream CLI manpage. Urban Terror runs on the ioquake3
# engine; '+' commands are stuffed into the Quake3 command buffer
# (Cbuf_AddText). Listed +commands are id Tech 3 / ioquake3 conventions.

# Urban Terror: tactical FPS on ioquake3
local curcontext="$curcontext" ret=1
_arguments -C \
  '+set[set cvar before init]:cvar:: :' \
  '+exec[execute config at startup]:file:_files -g "*.cfg"' \
  '+map[load map at startup]:map:' \
  '+devmap[load map in dev mode]:map:' \
  '+demo[play demo at startup]:name:' \
  '+connect[connect to server at startup]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
