#compdef sriov-network-operator-webhook
# _sriov-network-operator-webhook — SR-IoV operator validating/mutating webhook (k8snetworkplumbingwg/sriov-network-operator)
# upstream: https://github.com/k8snetworkplumbingwg/sriov-network-operator
# Flags from cmd/webhook/start.go on tip.

_sriov-network-operator-webhook() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the SR-IoV admission webhook daemon'
            )
            _describe -t commands 'sriov-network-operator-webhook command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--tls-cert-file=[TLS server cert]:file:_files' \
                        '--tls-private-key-file=[TLS server key]:file:_files' \
                        '--port=[webhook bind port]:port:' \
                        '--enable-http2[allow HTTP/2 on metrics/webhook]'
                    ;;
            esac
            ;;
    esac
}

_sriov-network-operator-webhook "$@"
