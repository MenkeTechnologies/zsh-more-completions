#compdef varnishadm
# Documentation: https://manpages.debian.org/testing/varnish/varnishadm.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_varnishadm() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '-h[print program usage and exit]' \
        '-n[varnish working directory of the instance]:workdir:' \
        '-p[force pass mode (output follows VCLI protocol)]' \
        '-S[authentication secret file]:file:_files' \
        '-T[connect to management interface address\:port]:address\:port:' \
        '-t[max seconds to wait for an operation]:seconds:' \
        '1:command:_varnishadm_commands' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                vcl.load)
                    _arguments '1:configname:' '2:filename:_files'
                    ;;
                vcl.use|vcl.discard|vcl.show)
                    _arguments '1:configname:'
                    ;;
                param.set)
                    _arguments '1:param:' '2:value:'
                    ;;
                param.show)
                    _arguments '-l[show long descriptions]' '1:param:'
                    ;;
                ban)
                    _arguments '1:expression:'
                    ;;
                backend.set_health)
                    _arguments '1:backend:' '2:state:(auto healthy sick)'
                    ;;
            esac
            ;;
    esac
}

_varnishadm_commands() {
    local -a commands
    commands=(
        'auth:authenticate'
        'backend.list:list backends'
        'backend.set_health:set backend health status'
        'ban:mark objects for ban'
        'ban.list:list active bans'
        'help:show command help'
        'panic.clear:clear the last panic'
        'panic.show:show the last panic'
        'param.set:set a parameter'
        'param.show:show parameters'
        'ping:ping the backend process'
        'quit:close connection'
        'start:start the worker process'
        'status:check status of varnish process'
        'stop:stop the worker process'
        'storage.list:list storage devices'
        'vcl.discard:discard a VCL configuration'
        'vcl.inline:compile and load inline VCL'
        'vcl.list:list available VCL configurations'
        'vcl.load:compile and load a VCL file'
        'vcl.show:display a loaded VCL'
        'vcl.state:force the state of a loaded VCL'
        'vcl.use:switch to a named VCL configuration'
    )
    _describe -t commands 'varnishadm command' commands
}

_varnishadm "$@"
