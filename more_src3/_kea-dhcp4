#compdef kea-dhcp4
# Documentation: https://kea.readthedocs.io/en/kea-2.6.1/man/kea-dhcp4.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kea-dhcp4: Kea DHCPv4 server. Corrected from prior file: removed
# invented -X flag and undocumented -h; added -T (extended config
# check), -p (server port), -P (client port) per upstream man page.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[display the Kea version]' \
  '-V[display the extended Kea version]' \
  '-W[display the configuration report]' \
  '-d[enable debug mode with extra verbosity]' \
  '-c[configuration file]:file:_files -g "*.(conf|json)"' \
  '-t[check the configuration file and report the first error]:file:_files -g "*.(conf|json)"' \
  '-T[check configuration with extended validation]:file:_files -g "*.(conf|json)"' \
  '-p[server port number (1-65535)]:port:' \
  '-P[client port number (1-65535)]:port:' \
  '*::kea-dhcp4 args:_files' && ret=0
return ret
