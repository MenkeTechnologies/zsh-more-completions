#compdef hyprwayland-scanner
# _hyprwayland-scanner — Hyprland C++23 wayland-scanner replacement (hyprwm/hyprwayland-scanner)
# upstream: https://github.com/hyprwm/hyprwayland-scanner
# Flags from src/main.cpp.

_hyprwayland-scanner() {
    local -a args
    args=(
        '(- *)'{-v,--version}'[show version]'
        '(-c --client)'{-c,--client}'[generate client-side code instead of server-side]'
        '--no-interfaces[skip the interface table generation]'
        '--wayland-enums[use wayland enum naming (snake_case) instead of camelCase]'
        '1:wayland protocol XML:_files -g "*.xml"'
        '2:output directory:_files -/'
    )
    _arguments -s $args
}

_hyprwayland-scanner "$@"
