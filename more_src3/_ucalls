#compdef ucalls ucalls-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/lib/ucalls.py argparse)
# Reference accessed: 2026-05-29
# ucalls — summarize method calls in high-level languages via USDT (BCC/eBPF). Java/Perl/PHP/Python/Ruby/Tcl.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --language)'{-l,--language=}'[language to trace (none = syscalls only)]:lang:(java perl php python ruby tcl none)' \
  '(-T --top)'{-T,--top=}'[print only top N most frequent/slow calls]:N:' \
  '(-L --latency)'{-L,--latency}'[record method latency from enter to exit (excluding recursive)]' \
  '(-S --syscalls)'{-S,--syscalls}'[record syscall latency (adds overhead)]' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '(-m --milliseconds)'{-m,--milliseconds}'[report times in milliseconds (default microseconds)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (process id to attach to):_pids' \
  '2:interval (seconds, optional):' \
  && ret=0

return ret
