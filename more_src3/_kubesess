#compdef kubesess
# Documentation: https://github.com/Ramilito/kubesess
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubesess (per-shell kubeconfig sessions). Subcommands and
# flags derived from src/main.rs (clap derive macros) in the upstream repo.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[print version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'context:switch to a context (session-specific)'
      'namespace:switch to a namespace (session-specific)'
      'default-context:switch to a context (global, modifies kubeconfig)'
      'default-namespace:switch to a namespace (global, modifies kubeconfig)'
      'completion-context:output completions for context'
      'completion-namespace:output completions for namespace'
      'init:initialize shell integration'
      'help:print this message or the help of the given subcommand'
    )
    _describe -t commands 'kubesess command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      (context|namespace|default-context|default-namespace|completion-context|completion-namespace)
        _arguments -s -S \
          '(-v --value)'{-v+,--value=}'[specify the value directly instead of interactive selection]:value:' \
          '(-c --current)'{-c,--current}'[print the current context/namespace]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      (init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
