#compdef swarm-code swarm
# Documentation: https://github.com/kingjulio8238/swarm-code
# Reference accessed: 2026-05-22
# Verified: src/main.ts buildHelp and command routing.

# Zsh completion for swarm-code / swarm - parallel coding agent orchestrator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dir[target repository directory]:directory:_directories' \
  '--orchestrator[orchestrator model]:model:' \
  '--agent[default agent backend]:backend:(opencode claude-code codex)' \
  '--dry-run[plan only without spawning threads]' \
  '--max-budget[maximum session budget in USD]:usd:' \
  '--verbose[detailed progress]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-essential output]' \
  '--json[machine-readable JSON output]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'swarm command' \
      'mcp[start MCP server over stdio]' \
      'run[RLM single-shot query mode]' \
      'viewer[browse trajectory files]' \
      'benchmark[run benchmark]' && ret=0
    ;;
  args)
    case $line[1] in
      mcp)
        _arguments '--dir[default directory]:directory:_directories' && ret=0
        ;;
      run)
        _arguments \
          '--model[model id]:model:' \
          '--file[context file]:file:_files' \
          '--url[context URL]:url:' \
          '--stdin[read context from stdin]' \
          '--verbose[iteration progress]' \
          '*:query:' && ret=0
        ;;
      benchmark)
        _arguments '1:benchmark name:' '--idx[benchmark index]:idx:' && ret=0
        ;;
      *)
        _arguments '*:task:' && ret=0
        ;;
    esac
    ;;
esac

return ret
