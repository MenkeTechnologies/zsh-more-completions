#compdef tsk_gettimes
# Documentation: https://www.sleuthkit.org/sleuthkit/man/tsk_gettimes.html
# Source: sleuthkit/sleuthkit man/tsk_gettimes.1 — collect MAC times from an image in mactime body-file format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-i[format of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-b[device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-o[sector offset for a volume (only recover that volume)]:sector offset:' \
    '-s[time skew of original system in seconds]:seconds:' \
    '-z[ASCII time zone string of original system]:zone:' \
    '*:image file:_files' \
    && ret=0

return ret
