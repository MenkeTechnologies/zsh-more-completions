#compdef lazysql
# Documentation: https://github.com/jorgerojas26/lazysql
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--read-only[block all mutation queries]' \
  '*:connection url:' && ret=0
return ret
