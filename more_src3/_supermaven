#compdef supermaven
# _supermaven — Supermaven supermaven AI code-completion CLI for the Babble large-context completion model with 1-million-token context window for editor integrations (supermaven team, Rust); clap
# upstream: https://supermaven.com/

_supermaven() {
    local -a sub=(
        'login:login to account'
        'logout:logout'
        'status:show status'
        'whoami:show current user'
        'serve:start LSP server'
        'enable:enable completions'
        'disable:disable completions'
        'cache-stats:show cache stats'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "*.toml *.json"' \
        '--log-file=+[file]:file:_files' \
        '--log-level=+[level]:l:(error warn info debug trace)' \
        '--api-url=+[url]:str:' \
        '--auth-token=+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'supermaven subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--socket=+[file]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
            esac
            ;;
    esac
}

_supermaven "$@"
