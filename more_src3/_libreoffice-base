#compdef sbase
# _libreoffice-base — LibreOffice sbase / soffice --base (database front-end + HSQLDB-backed .odb files; --convert-to converts to fodb/sql, --outdir, --headless, --norestore, opens .odb files natively)
# upstream: https://git.libreoffice.org/core
# Flags from libreoffice core/desktop/source/app on tip.

_libreoffice-base() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--headless[run without UI]' \
        '--norestore[skip restoring previous session]' \
        '--nologo[no splash]' \
        '--convert-to+[convert to format]:format:(fodb sql odb)' \
        '--outdir+[output directory]:dir:_files -/' \
        '*-env+[env var]:key=value:' \
        '*:database:_files -g "*.(odb|fodb|mdb|accdb|dbf)"'
}

_libreoffice-base "$@"
