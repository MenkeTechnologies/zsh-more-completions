#compdef thinkjettopbm
# Documentation: man thinkjettopbm (Netpbm)
# Source: convert an HP ThinkJet/QuietJet printer-command stream back to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-debug[debug output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:thinkjet file:_files' \
    && ret=0

return ret
