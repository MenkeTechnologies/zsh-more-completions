#compdef surfaceBooleanFeatures
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceBooleanFeatures — boolean intersection of two surfaces yielding feature edges (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-perturb[slightly perturb degenerate intersections]' \
    '-invertedSpace[invert resulting space (in/outside)]' \
    '1:surface 1:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '2:surface 2:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    '3:action:(intersection union difference all)' \
    && ret=0

return ret
