#compdef kubectl-rbac-tool
# kubectl-rbac-tool (krew plugin): RBAC analysis and visualization
# https://github.com/alcideio/rbac-tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'lookup:who can perform the given verb on the given resource'
      'policy-rules:list RBAC policy rules for a subject'
      'visualize:generate a graph of the RBAC bindings'
      'analysis:analyze RBAC permissions'
      'whoami:show the subject associated with the current context'
      'generate:generate ClusterRole from given permissions'
    )
    _describe -t commands 'rbac-tool command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--context=[kubernetes context]:context' \
      '--kubeconfig=[path to kubeconfig]:file:_files' \
      '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
      '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
      '--cluster-context=[cluster context]:context' \
      '*:args' && ret=0
    ;;
esac

return ret
