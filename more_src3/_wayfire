#compdef wayfire
# Documentation: https://github.com/WayfireWM/wayfire
# Reference accessed: 2026-05-21
# Verified: upstream src/main.cpp at github.com/WayfireWM/wayfire.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[config file path]:file:_files' \
  '(-B --config-backend)'{-B,--config-backend}'+[config backend]:backend' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-D --damage-debug)'{-D,--damage-debug}'[enable damage debug mode]' \
  '(-R --damage-rerender)'{-R,--damage-rerender}'[rerender damaged regions]' \
  '(-l --legacy-wl-drm)'{-l,--legacy-wl-drm}'[use legacy drm for wayland clients]' && ret=0

return ret
