#compdef kdigger
# Documentation: https://github.com/quarkslab/kdigger/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kdigger: Kubernetes focused container assessment tool. Corrected
# from prior file: real subcommands are dig/gen/ls/completion/version/
# help (removed invented list/color); global flags are -o/--output,
# -w/--width, -h/--help; removed invented --active, --human-readable,
# -c/--config, --color enum, --namespace global; added gen subcommand
# and real dig flags (-c/--color, -n/--namespace, --kubeconfig,
# -s/--side-effects, --admission-create, --admission-force).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'dig:use all buckets or specific ones'
  'gen:generate a template for a pod with security features disabled'
  'ls:list available buckets or describe specific ones'
  'completion:generate the autocompletion script for the specified shell'
  'version:print the version information'
  'help:help about any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(human json)' \
  '(-w --width)'{-w+,--width=}'[width for the human output]:width:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kdigger command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (dig|d)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-c --color)'{-c,--color}'[enable color in output]' \
          '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace to use]:namespace:' \
          '--kubeconfig=[absolute path to the kubeconfig file]:file:_files' \
          '(-s --side-effects)'{-s,--side-effects}'[enable all buckets that might have side effects]' \
          '--admission-create[actually create pods to scan admission instead of dry run]' \
          '--admission-force[force creation of pods to scan admission]' \
          '*::bucket:' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
