#compdef spectrwm
# Documentation: https://raw.githubusercontent.com/conformal/spectrwm/master/spectrwm.1
# Reference accessed: 2026-05-21
# Verified: upstream spectrwm.1 manpage source. Only three documented
# flags: -c (config file), -d (debug+stderr logging), -v (version).
# Removed prior fabricated -d X-display semantics.

_arguments -s -S \
  '-c[specify config file]:config file:_files' \
  '-d[enable debug mode (log to stderr)]' \
  '-v[display version]'
