#compdef lutris
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/lutris.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lutris - open gaming platform

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help options]' \
  '--help-all[show all help options]' \
  '--help-gapplication[show GApplication options]' \
  '--help-gtk[show GTK+ options]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-i --install)'{-i,--install}'[install a game from a YAML file]:file:_files -g "*.y(a|)ml"' \
  '(-b --output-script)'{-b,--output-script}'[generate a bash script to run a game]:file:_files' \
  '(-e --exec)'{-e,--exec}'[execute a program with the Lutris runtime]:command:_command_names -e' \
  '(-l --list-games)'{-l,--list-games}'[list all games in database]' \
  '(-o --installed)'{-o,--installed}'[only list installed games]' \
  '(-s --list-steam-games)'{-s,--list-steam-games}'[list available Steam games]' \
  '--list-steam-folders[list all known Steam library folders]' \
  '(-j --json)'{-j,--json}'[display output in JSON format]' \
  '--reinstall[reinstall game]' \
  '--submit-issue[submit an issue]' \
  '--display=[X display to use]:display:' \
  '*:URI or game slug:' && ret=0

return ret
