#compdef taskwarrior-tui
# Documentation: https://github.com/kdheepak/taskwarrior-tui
# Reference accessed: 2026-05-21
# Verified: upstream source at src/cli.rs (clap argument definitions).

_taskwarrior-tui() {
    _arguments \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-V --version)'{-V,--version}'[print version]' \
        '(-c --config)'{-c,--config}'=[config directory]:folder:_directories' \
        '(-d --data)'{-d,--data}'=[data directory]:folder:_directories' \
        '--taskdata=[taskdata directory]:folder:_directories' \
        '--taskrc=[taskrc file]:file:_files' \
        '(-r --report)'{-r,--report}'=[report to display]:report:'
}

_taskwarrior-tui "$@"
