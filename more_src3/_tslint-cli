#compdef tslint-cli
# _tslint-cli — Palantir TSLint TypeScript linter CLI alias (Palantir / TSLint team, TypeScript); commander (deprecated in favor of @typescript-eslint)
# upstream: https://github.com/palantir/tslint

_tslint-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "tslint.json *.json"' \
        '-c+[config file]:file:_files -g "tslint.json *.json"' \
        '--exclude=+[exclude glob]:list:' \
        '-e+[exclude glob]:list:' \
        '--fix[fix]' \
        '--force[force]' \
        '--init[generate tslint.json]' \
        '-i[generate tslint.json]' \
        '--out=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--outputAbsolutePaths[output absolute paths]' \
        '--project=+[tsconfig]:file:_files -g "tsconfig.json *.json"' \
        '-p+[tsconfig]:file:_files -g "tsconfig.json *.json"' \
        '--rules-dir=+[rules dir]:list:_files -/' \
        '-r+[rules dir]:list:_files -/' \
        '--formatters-dir=+[formatters dir]:list:_files -/' \
        '-s+[formatters dir]:list:_files -/' \
        '--format=+[output format]:f:(prose verbose json checkstyle codeFrame filesList junit pmd msbuild stylish tap vso)' \
        '-t+[output format]:f:(prose verbose json checkstyle codeFrame filesList junit pmd msbuild stylish tap vso)' \
        '--quiet[only show errors]' \
        '-q[only show errors]' \
        '--print-config=+[print config]:file:_files' \
        '--test[run tests]' \
        '--type-check[type check]' \
        '*:file:_files -g "*.ts *.tsx"'
}

_tslint-cli "$@"
