#compdef iptraf-ng iptraf
# _iptraf-ng — Gerard Paul Java's IPTraf-ng (ncurses IP LAN traffic monitor: TCP/UDP counters, ICMP/OSPF, Ethernet load, LAN station stats; live or one-shot facility mode)
# upstream: https://github.com/iptraf-ng/iptraf-ng
# Flags from src/iptraf-ng.8 on tip; one facility option (-i/-g/-d/-s/-z/-l) must be combined with -t/-B/-L if specified.

_iptraf-ng() {
    _arguments \
        '(- *)-h[show command summary]' \
        '-i+[start IP traffic monitor on iface (or "all")]:iface:_net_interfaces' \
        '-g[start general interface stats]' \
        '-d+[start detailed stats on iface]:iface:_net_interfaces' \
        '-s+[start TCP/UDP stats on iface]:iface:_net_interfaces' \
        '-z+[show packet counts by size on iface]:iface:_net_interfaces' \
        '-l+[start LAN station monitor on iface (or "all")]:iface:_net_interfaces' \
        '-t+[run facility for N minutes only]:min:' \
        '-B[background mode (close stdin, fork)]' \
        '-L+[log file path]:file:_files' \
        '-f[clear all locks + counters (recovery)]'
}

_iptraf-ng "$@"
