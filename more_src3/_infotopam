#compdef infotopam
# Documentation: man infotopam (Netpbm)
# Source: convert a GNU Info file (or pieces thereof) to a PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-forcecolor[force color output]' \
    '-numcolors+[number of colors]:n:' \
    '-selected[render only selected text]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:index color or info file:_files' \
    && ret=0

return ret
