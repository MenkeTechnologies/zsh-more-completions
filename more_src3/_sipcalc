#compdef sipcalc
# Documentation: https://manpages.debian.org/bookworm/sipcalc/sipcalc.1.en.html
# Reference accessed: 2026-05-21
# Verified: Debian bookworm sipcalc(1) man page.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display commandline help]' \
  '(- *)'{-v,--version}'[display version information]' \
  '(-a --all)'{-a,--all}'[give all possible information about address/interface]' \
  '(-b --cidr-bitmap)'{-b,--cidr-bitmap}'[CIDR-based bitmaps for IPv4]' \
  '(-c --classfull-addr)'{-c,--classfull-addr}'[classfull address details for IPv4]' \
  '(-d --resolve)'{-d,--resolve}'[enable name resolution]' \
  '(-I --addr-int)'{-I,--addr-int}'=[explicitly specify an interface]:interface:' \
  '(-n --subnets)'{-n,--subnets}'=[display NUM extra subnets]:n:' \
  '(-s --v4split)'{-s,--v4split}'=[split IPv4 network into smaller subnets]:mask:' \
  '(-S --v6split)'{-S,--v6split}'=[split IPv6 network into smaller subnets]:mask:' \
  '(-u --split-verbose)'{-u,--split-verbose}'[verbose network splitting]' \
  '(-w --wildcard)'{-w,--wildcard}'[Cisco wildcard to standard netmask]' \
  '(-x --classful-bitmap)'{-x,--classful-bitmap}'[classfull bitmap representation]' \
  '(-4 --addr-ipv4)'{-4,--addr-ipv4}'=[specify IPv4 address]:ipv4:' \
  '(-6 --addr-ipv6)'{-6,--addr-ipv6}'=[specify IPv6 address]:ipv6:' \
  '*:address/mask or interface' && ret=0

return ret
