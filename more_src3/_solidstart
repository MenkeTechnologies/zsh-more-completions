#compdef solidstart
# _solidstart — Ryan Carniato SolidStart Solid.js meta-framework CLI alias (solidjs team, TypeScript); vinxi/custom argparse
# upstream: https://github.com/solidjs/solid-start

_solidstart() {
    local -a sub=(
        'dev:start dev server'
        'build:build for production'
        'start:run production server'
        'preview:preview production build'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'solid-start subcommand' sub ;;
        args)
            case $words[1] in
                dev|build|start|preview) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--root=+[dir]:dir:_files -/' \
                    '--mode=+[mode]:m:(development production)' \
                    '--debug[debug]' \
                    '--clearScreen=+[bool]:b:(true false)' \
                    '--logLevel=+[level]:l:(info warn error silent)' \
                    '-l+[level]:l:(info warn error silent)' \
                    '--force[force re-optimize]' \
                    '--open=+[bool/path]:str:' \
                    '-o+[bool/path]:str:' \
                    '--ssr=+[bool]:b:(true false)' \
                    '--router=+[router]:r:(string-array array regex glob)' \
                    '--preset=+[preset]:p:(node-server vercel netlify cloudflare-pages cloudflare-workers deno-server bun aws-lambda aws-lambda-edge static)' ;;
            esac
            ;;
    esac
}

_solidstart "$@"
