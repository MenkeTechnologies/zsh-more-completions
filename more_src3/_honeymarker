#compdef honeymarker
# Documentation: https://github.com/honeycombio/honeymarker
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:create a new marker'
  'list:display all markers'
  'rm:delete a marker'
  'update:modify an existing marker'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-k --writekey --api-key)'{-k+,--writekey=,--api-key=}'[Honeycomb API/write key]:key:' \
  '(-d --dataset)'{-d+,--dataset=}'[dataset (use __all__ for env-wide)]:dataset:' \
  '--api_host=[Honeycomb API host]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'honeymarker command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (add)
        _arguments \
          '(-m --msg)'{-m+,--msg=}'[marker message]:msg:' \
          '(-t --type)'{-t+,--type=}'[marker type]:type:' \
          '(-u --url)'{-u+,--url=}'[marker URL]:url:' \
          '(-s --start_time)'{-s+,--start_time=}'[unix start time]:n:' \
          '(-e --end_time)'{-e+,--end_time=}'[unix end time]:n:' && ret=0 ;;
      (list)
        _arguments \
          '--json[output as JSON]' \
          '--unix_time[display times as unix timestamps]' && ret=0 ;;
      (update)
        _arguments \
          '(-i --id)'{-i+,--id=}'[marker id]:id:' \
          '(-m --msg)'{-m+,--msg=}'[marker message]:msg:' \
          '(-t --type)'{-t+,--type=}'[marker type]:type:' \
          '(-u --url)'{-u+,--url=}'[marker URL]:url:' \
          '(-s --start_time)'{-s+,--start_time=}'[unix start time]:n:' \
          '(-e --end_time)'{-e+,--end_time=}'[unix end time]:n:' && ret=0 ;;
      (rm)
        _arguments '(-i --id)'{-i+,--id=}'[marker id]:id:' && ret=0 ;;
    esac ;;
esac

return ret
