#compdef winemenubuilder winemenubuilder.exe
# Documentation: https://github.com/wine-mirror/wine/blob/master/programs/winemenubuilder/winemenubuilder.c
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

# winemenubuilder: Wine internal helper that installs desktop integration
# from Windows shortcuts / URL files. Invoked automatically by Wine.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[refresh file type associations]' \
  '-r[clean up menus]' \
  '-u[process URLs instead of links]' \
  '-w[wait/defer mode (retry if icon extraction fails)]' \
  '-t[generate thumbnail: link file and output file]:link file:_files -g "*.(lnk|url)":output file:_files' \
  '*:lnk/url file:_files -g "*.(lnk|url)"' && ret=0

return ret
