#compdef twiggy
# Documentation: https://rustwasm.github.io/twiggy/
# Reference accessed: 2026-05-21
# Verified: upstream source AlexEne/twiggy opt/definitions.rs (StructOpt).

local curcontext="$curcontext" state line ret=1

_twiggy_commands() {
  local -a commands=(
    'top:list the top code size offenders in a binary'
    'paths:find paths to a function in the binary call graph'
    'monos:find generic function monomorphizations'
    'dominators:compute dominator tree for the call graph'
    'diff:diff old and new binary versions'
    'garbage:find unreferenced code and data'
  )
  _describe -t commands 'twiggy command' commands
}

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:_twiggy_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      top)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n+[max items]:max items' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(text json csv)' \
          '(-o)-o+[output file]:file:_files' \
          '(-r --retaining-paths)'{-r,--retaining-paths}'[print retaining paths]' \
          '--retained[sort by retained size]' \
          '--mode=[parse mode]:mode:(wasm dwarf auto)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      paths)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-d+[max depth]:depth' \
          '-r+[max paths]:count' \
          '--descending[print descending]' \
          '--regex[treat function args as regex]' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(text json csv)' \
          '(-o)-o+[output file]:file:_files' \
          '--mode=[parse mode]:mode:(wasm dwarf auto)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      monos)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-g --only-generics)'{-g,--only-generics}'[only show generics]' \
          '(-m --max-generics)'{-m+,--max-generics=}'[max generics]:n' \
          '(-n --max-monos)'{-n+,--max-monos=}'[max monomorphizations]:n' \
          '(-a --all)'{-a,--all}'[show all]' \
          '--all-generics[show all generics]' \
          '--all-monos[show all monomorphizations]' \
          '--regex[treat args as regex]' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(text json csv)' \
          '(-o)-o+[output file]:file:_files' \
          '--mode=[parse mode]:mode:(wasm dwarf auto)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      dominators)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-d+[max depth]:depth' \
          '-r+[max rows]:rows' \
          '--regex[treat args as regex]' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(text json csv)' \
          '(-o)-o+[output file]:file:_files' \
          '--mode=[parse mode]:mode:(wasm dwarf auto)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
      diff)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n+[max items]:count' \
          '(-a --all)'{-a,--all}'[show all]' \
          '--regex[treat args as regex]' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(text json csv)' \
          '(-o)-o+[output file]:file:_files' \
          '--mode=[parse mode]:mode:(wasm dwarf auto)' \
          '1:old wasm file:_files -g "*.wasm"' \
          '2:new wasm file:_files -g "*.wasm"' && ret=0
        ;;
      garbage)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '-n+[max items]:count' \
          '(-a --all)'{-a,--all}'[show all]' \
          '--show-data-segments[include data segments]' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(text json csv)' \
          '(-o)-o+[output file]:file:_files' \
          '--mode=[parse mode]:mode:(wasm dwarf auto)' \
          '*:wasm file:_files -g "*.wasm"' && ret=0
        ;;
    esac
    ;;
esac

return ret
