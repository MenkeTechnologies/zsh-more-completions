#compdef kubectl-node-shell
# kubectl-node-shell (krew plugin): spawn a root shell on a node via a Pod
# https://github.com/kvaps/kubectl-node-shell

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace for the shell pod]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--image=[container image to use]:image' \
  '-x[use host network for the shell pod]' \
  '1:node name' \
  '(-)--[command to execute]' \
  '*:command arguments'
