#compdef sirna
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/sirna.html
# Reference accessed: 2026-05-21
# Verified: EMBOSS 6.6 sirna documentation page.

# EMBOSS sirna: design candidate siRNA probes for RNAi experiments.
# Applies common selection criteria (e.g. Tuschl rules, RNA pol III
# promoter compatibility, AA-prefix and TT-suffix requirements).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[mRNA / cDNA target sequence]:DNA/RNA USA:_files' \
  '-poliii[restrict to candidates compatible with pol-III promoter]' \
  '-aa[require AA dinucleotide at 5-prime of probe]' \
  '-tt[allow TT dinucleotide at 3-prime of probe]' \
  '-polybase[reject probes with >3 consecutive identical bases]' \
  '-context[print 19-nt context around each probe]' \
  '-outseq=[output sequence file (candidate probes)]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:target sequence:_files' && ret=0

return ret
