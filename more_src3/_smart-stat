#compdef smart-stat
# _smart-stat — smartmontools/distro-shipped smart-stat helper (small wrapper around smartctl(8) that prints normalised SMART summary stats for every block device under /dev; -d disk filter, -f format (plain|csv|json), -t threshold, -v verbose, --version, --help; uses NVMe + ATA + SCSI controllers transparently)
# upstream: distro-shipped helpers wrapping smartctl on tip.
# Common flag shape from smartmontools smartctl + downstream smart-stat scripts.

_smart-stat() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[disk filter]:device:_files -g "/dev/sd* /dev/nvme* /dev/hd*"' \
        '-f+[format]:format:(plain csv json)' \
        '-t+[threshold]:value:' \
        '-v[verbose]'
}

_smart-stat "$@"
