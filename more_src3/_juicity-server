#compdef juicity-server
# _juicity-server — QUIC-based proxy server (juicity/juicity)
# upstream: https://github.com/juicity/juicity
# Subcommands & flags from cmd/server/* and cmd/internal/shared/arguments.go (cobra).

_juicity-server() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
        '--log-output=[log outputs]:targets:(console file console,file)' \
        '--log-disable-color[disable colorful log output]' \
        '--log-disable-timestamp[disable timestamps in log]' \
        '--log-file=[log file path]:file:_files' \
        '--log-file-format=[log format]:fmt:(raw json)' \
        '--log-file-max-size=[max log file size (MB)]:size:' \
        '--log-file-max-backups=[max old log files retained]:n:' \
        '--log-file-max-age=[max log retention days]:days:' \
        '--log-file-compress[enable log compression]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:run juicity-server in the foreground'
                'generate-sharelink:generate a sharelink from the config file'
                'generate-certchain-hash:hash of a full-chain certificate'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                generate-certchain-hash) _arguments '1:fullchain file:_files' ;;
            esac
            ;;
    esac
}

_juicity-server "$@"
