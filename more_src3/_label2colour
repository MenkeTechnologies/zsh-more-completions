#compdef label2colour
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/label2colour.html
# Source: MRtrix3/mrtrix3 cmd/label2colour.cpp — convert parcellation image to colour image via LUT (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-lut+[colour lookup table]:file:_files -g "*.txt"' \
    '1:nodes_in (parcellation image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:colour_out (output colour image):_files' \
    && ret=0

return ret
