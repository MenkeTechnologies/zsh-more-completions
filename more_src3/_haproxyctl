#compdef haproxyctl
# _haproxyctl — HAProxy haproxyctl management CLI alias (HAProxy team, Bash); custom argparse
# upstream: https://github.com/haproxy/haproxy

_haproxyctl() {
    local -a sub=(
        'status:show daemon status'
        'reload:reload config'
        'restart:restart daemon'
        'start:start daemon'
        'stop:stop daemon'
        'show:show data'
        'enable:enable server/frontend/backend'
        'disable:disable server/frontend/backend'
        'set:set state of a server'
        'clear:clear counters'
        'shutdown:shutdown a session'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-S+[socket path]:file:_files' \
        '--socket=+[socket path]:file:_files' \
        '-c+[config file]:file:_files -g "*.cfg"' \
        '--config=+[config file]:file:_files -g "*.cfg"' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-p+[pid file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'haproxyctl subcommand' sub ;;
        args)
            case $words[1] in
                show) _arguments \
                    '1:topic:(info session stat health errors resolvers map peers pools threads servers state activity events env startup-logs frontends backends servers-state schema cpu pools tasks events watchdog)' \
                    '*:arg:' ;;
                enable|disable|set|clear|shutdown) _arguments \
                    '*:target:' ;;
            esac
            ;;
    esac
}

_haproxyctl "$@"
