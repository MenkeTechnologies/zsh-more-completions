#compdef llvm-otool
# _llvm-otool — LLVM otool-compatible Mach-O dumper (LLVM project, C++); display Mach-O sections, libraries, segments
# upstream: https://github.com/llvm/llvm-project

_llvm-otool() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-arch+[arch]:arch:' \
        '-mcpu+[cpu]:cpu:' \
        '-h[print Mach-O header]' \
        '-l[print load commands]' \
        '-L[print shared library names]' \
        '-D[print library install name]' \
        '-s+[print contents of section]:segment section:' \
        '-X[print no leading address]' \
        '-t[print text segment]' \
        '-T[print table of contents]' \
        '-R[print reference table]' \
        '-d[print data segment]' \
        '-o[print Objective-C info]' \
        '-r[print relocation info]' \
        '-S[print contents of __.SYMDEF]' \
        '-c[print argument strings of a core file]' \
        '-V[print disassembled vector operands symbolically]' \
        '-v[verbose]' \
        '-I[print indirect symbol table]' \
        '-G[print data in code]' \
        '-x[hex dump section]' \
        '-q[do not print fat headers]' \
        '-m[do not use archive(member) syntax]' \
        '-Q[use llvm-disassembler]' \
        '-p+[print after symbol]:symbol:' \
        '-non-verbose[non-verbose]' \
        '-objc-meta-data[print Objective-C metadata]' \
        '-no-show-raw-insn[no raw instruction bytes]' \
        '-no-leading-addr[no leading address]' \
        '-bind[print dyld bind]' \
        '-data-in-code[print data in code]' \
        '-dyld-info[print dyld info]' \
        '-dylib-id[print dylib id]' \
        '-dylibs-used[print used dylibs]' \
        '-headers[print headers]' \
        '-info-plist[print info plist]' \
        '-link-opt-hints[print link opt hints]' \
        '-segs-and-sections[print segments + sections]' \
        '-version[show version]' \
        '*:file:_files'
}

_llvm-otool "$@"
