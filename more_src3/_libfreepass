#compdef libfreepass libfreepass-cli
# _libfreepass — libfreepass CLI (command-line front-end to the Rust libfreepass deterministic password manager; subcommands: list, add, remove, password, vault new, vault open, vault import, vault export; -V version, -h help, --vault path; positional argument is the entry name)
# upstream: https://github.com/freepass-project/freepass
# Subcommands from freepass src/cli on tip.

_libfreepass() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '--vault+[vault file]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'freepass command' '(list add remove password vault)' ;;
        args)
            case $line[1] in
                vault) _describe -t commands 'vault subcommand' '(new open import export)' ;;
            esac
            ;;
    esac
}

_libfreepass "$@"
