#compdef jpeg-recompress
# _jpeg-recompress — SSIM-driven JPEG recompressor (danielgtaylor/jpeg-archive)
# upstream: https://github.com/danielgtaylor/jpeg-archive
# Flags from jpeg-recompress.c (getopt_long).

_jpeg-recompress() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-t --target)'{-t+,--target=}'[target SSIM value]:float:' \
        '(-q --quality)'{-q+,--quality=}'[quality preset]:preset:(low medium high veryhigh)' \
        '(-n --min)'{-n+,--min=}'[minimum JPEG quality]:n:' \
        '(-x --max)'{-x+,--max=}'[maximum JPEG quality]:n:' \
        '(-l --loops)'{-l+,--loops=}'[binary-search iterations]:n:' \
        '(-a --accurate)'{-a,--accurate}'[favor accuracy over speed]' \
        '(-m --method)'{-m+,--method=}'[comparison metric]:metric:(ssim ms-ssim smallfry mpe)' \
        '(-s --strip)'{-s,--strip}'[strip metadata from output]' \
        '(-d --defish)'{-d+,--defish=}'[defish strength]:float:' \
        '(-z --zoom)'{-z+,--zoom=}'[defish zoom]:float:' \
        '(-r --ppm)'{-r,--ppm}'[treat input as PPM]' \
        '(-c --no-copy)'{-c,--no-copy}'[do not copy incompressible files]' \
        '(-p --no-progressive)'{-p,--no-progressive}'[disable progressive JPEG]' \
        '(-S --subsample)'{-S+,--subsample=}'[chroma subsampling]:mode:(default disable)' \
        '(-T --input-filetype)'{-T+,--input-filetype=}'[input file type]:type:(jpeg ppm auto)' \
        '(-Q --quiet)'{-Q,--quiet}'[quiet output]' \
        ':input file:_files -g "*.(jpg|jpeg|ppm)"' \
        ':output file:_files -g "*.jpg"'
}

_jpeg-recompress "$@"
