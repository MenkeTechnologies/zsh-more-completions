#compdef krtfs
# Documentation: https://github.com/freakmaxi/kertish-dos/blob/master/fs-tool/flags/command.go
# Reference accessed: 2026-05-19
# Verified: upstream fs-tool/flags/*.go. krtfs is the kertish-dos
# filesystem tool (formerly kertish-dfs).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'mkdir:create folders'
  'ls:list files and folders'
  'cp:copy file or folder'
  'mv:move file or folder'
  'rm:remove files and/or folders'
  'tree:print folders tree'
  'sh:enter shell mode of fs-tool'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[print usage documentation]' \
  '(-v --version)'{-v,--version}'[print release version]' \
  '(-t --target)'{-t,--target}'+[head node end point to work with]:address:' \
  '--head-address=[(deprecated) head node end point]:address:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'krtfs command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (ls)
        _arguments \
          '-l[long listing format]' \
          '-u[show usage information]' \
          '-h[show command usage]' \
          '*:path:_files' && ret=0
        ;;
      (rm)
        _arguments \
          '-f[force / ignore errors]' \
          '-k[keep (do not delete) source]' \
          '-h[show command usage]' \
          '*:path:_files' && ret=0
        ;;
      (cp)
        _arguments \
          '-f[overwrite existing target]' \
          '-j[join sources into target]' \
          '-r[read byte range]:range:' \
          '-h[show command usage]' \
          '*:path:_files' && ret=0
        ;;
      (mkdir|mv|tree|sh)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
