#compdef udevil
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*:arguments:->args' && ret=0

case $state in
  commands)
    local -a subcmds=(
      'mount:mount a device or directory'
      'umount:unmount a device or directory'
      'monitor:monitor device events'
      'info:show device information'
      'clean:clean mount points'
    )
    _describe -t commands 'udevil command' subcmds && ret=0
    ;;
  args)
    case ${words[2]} in
      mount)
        _arguments -s -S \
          '--mount-options[mount options]:options' \
          '--no-nosuid[do not add nosuid]' \
          '--force[force operation]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '--version[show version]' \
          '*:device or directory:_files' && ret=0
        ;;
      umount)
        _arguments -s -S \
          '--force[force unmount]' \
          '(-l --lazy)'{-l,--lazy}'[lazy unmount]' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' \
          '(-q --quiet)'{-q,--quiet}'[quiet output]' \
          '*:mount point:_files -/' && ret=0
        ;;
      monitor)
        _arguments -s -S \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0
        ;;
      info)
        _arguments -s -S \
          '*:device:_files' && ret=0
        ;;
      clean)
        ;;
    esac
    ;;
esac
return ret
