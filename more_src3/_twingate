#compdef twingate
# _twingate — Twingate Zero Trust Network Access twingate desktop client and headless service CLI for connecting devices to private resources auth login user-info status notifications resource-list service-key (Twingate team, Go); cobra
# upstream: https://github.com/Twingate

_twingate() {
    local -a sub=(
        'auth:authentication operations'
        'config:config operations'
        'log:log operations'
        'resource:resource operations'
        'service:service-key operations'
        'status:show status'
        'start:start client'
        'stop:stop client'
        'restart:restart client'
        'login:login'
        'logout:logout'
        'whoami:show current user'
        'list:list resources'
        'install:install service'
        'uninstall:uninstall service'
        'doctor:run diagnostics'
        'desktop:open desktop client'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--network=+[name]:str:' \
        '-n+[name]:str:' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--service-key=+[key]:str:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'twingate subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--browser=+[b]:b:(default chrome firefox safari edge)' \
                    '--idp=+[idp]:str:' ;;
                resource) _arguments \
                    '1:action:(list info select unselect)' \
                    '*:resource name:' ;;
                service) _arguments \
                    '1:action:(create activate deactivate list info)' \
                    '*:service id:' ;;
            esac
            ;;
    esac
}

_twingate "$@"
