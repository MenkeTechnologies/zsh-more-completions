#compdef xbcrypt
# Documentation: https://docs.percona.com/percona-xtrabackup/8.0/xbcrypt-options.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-d --decrypt)'{-d,--decrypt}'[decrypt data (default is encrypt)]' \
  '(-i --input)'{-i,--input=}'[input file (default stdin)]:file:_files' \
  '(-o --output)'{-o,--output=}'[output file (default stdout)]:file:_files' \
  '(-a --encrypt-algo)'{-a,--encrypt-algo=}'[encryption algorithm]:algo:' \
  '(-k --encrypt-key)'{-k,--encrypt-key=}'[encryption key]:key:' \
  '(-f --encrypt-key-file)'{-f,--encrypt-key-file=}'[key file]:file:_files' \
  '(-s --encrypt-chunk-size)'{-s,--encrypt-chunk-size=}'[buffer size in bytes]:bytes:' \
  '--encrypt-threads=[parallel worker threads]:n:' \
  '--read-buffer-size=[read buffer size]:bytes:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]'
