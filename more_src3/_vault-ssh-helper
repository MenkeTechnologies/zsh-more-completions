#compdef vault-ssh-helper
# Documentation: https://github.com/hashicorp/vault-ssh-helper
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

_arguments -s \
  '-config=[config file path]:file:_files -g "*.(hcl|json)"' \
  '-dev[disable TLS (development only)]' \
  '-verify-only[verify install and Vault connectivity]' \
  '-log-level=[log level]:level:(off trace debug info warn error)'
