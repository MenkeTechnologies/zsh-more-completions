#compdef havoc Havoc havoc-client havoc-server
# _havoc — C5pider havoc CLI modern Havoc Framework v0.7 v0.8 C2 multiplayer-enabled command and control framework consisting of teamserver Go-Python flexible-implant listener-management cs-like-malleable-profile-yaotl scripting tab-completion-shell for authorized red-team operations (C5pider team, Python/Go); custom argparse
# upstream: https://github.com/HavocFramework/Havoc

_havoc() {
    local -a sub=(
        'server:start the teamserver'
        'client:start the GUI client'
        'cli:start the CLI client'
        'profile:profile operations'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--profile=+[file]:file:_files -g "*.yaotl *.yaml *.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'havoc subcommand' sub ;;
        args)
            case $words[1] in
                server) _arguments \
                    '--profile=+[file]:file:_files -g "*.yaotl"' \
                    '--host=+[host]:_hosts' \
                    '--port=+[port]:n:' \
                    '--listen=+[host:port]:str:' ;;
                client) _arguments \
                    '--host=+[host]:_hosts' \
                    '--port=+[port]:n:' \
                    '--user=+[user]:str:' \
                    '--password=+[password]:str:' ;;
            esac
            ;;
    esac
}

_havoc "$@"
