#compdef wstunnel
# Documentation: https://github.com/erebe/wstunnel
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Subcommands: client, server (verified from README).
# Client flags: -L/--local-to-remote, -R/--remote-to-local,
# -H/--http-headers, --http-headers-file, -p/--http-proxy, --http-proxy-login,
# --http-proxy-password, --http-upgrade-path-prefix, --http-upgrade-credentials,
# -c/--connection-min-idle, --no-color, --log-lvl,
# --websocket-mask-frame, --websocket-ping-frequency-sec,
# --tls-sni-override, --tls-sni-disable, --tls-ech-enable,
# --tls-verify-certificate, --tls-certificate, --tls-private-key,
# --dns-resolver, --socket-so-mark, --nb-worker-threads.
# Server flags: --restrict-to, --restrict-http-upgrade-path-prefix,
# --restrict-config, --tls-certificate, --tls-private-key,
# --tls-client-ca-certs, --http-proxy, --http-proxy-login,
# --http-proxy-password, --websocket-ping-frequency-sec, --websocket-mask-frame,
# --no-color, --log-lvl, --dns-resolver, --socket-so-mark, --nb-worker-threads.
# Removed from prior file: --upgrade-credentials (correct is
# --http-upgrade-credentials), --upgrade-path-prefix (correct is
# --http-upgrade-path-prefix), --connection-retry / --connection-retry-max
# / --socks5-proxy / --no-keep-alive (not in upstream README options),
# --remote-to-local on server (it's a client flag).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'client:run as a wstunnel client'
  'server:run as a wstunnel server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'wstunnel command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (client)
        _arguments \
          '*'{-L+,--local-to-remote=}'[listen locally, forward to remote]:tunnel:' \
          '*'{-R+,--remote-to-local=}'[listen on remote, forward to local]:tunnel:' \
          '*'{-H+,--http-headers=}'[send custom header in upgrade request]:header:' \
          '--http-headers-file=[custom headers from file]:file:_files' \
          '(-p --http-proxy)'{-p+,--http-proxy=}'[HTTP proxy to reach server]:url:' \
          '--http-proxy-login=[HTTP proxy login]:user:' \
          '--http-proxy-password=[HTTP proxy password]:pass:' \
          '(-P --http-upgrade-path-prefix)'{-P+,--http-upgrade-path-prefix=}'[upgrade path prefix]:prefix:' \
          '--http-upgrade-credentials=[basic auth for upgrade]:creds:' \
          '(-c --connection-min-idle)'{-c+,--connection-min-idle=}'[min idle connection pool]:n:' \
          '--no-color[disable color output]' \
          '--log-lvl=[log level]:level:(OFF ERROR WARN INFO DEBUG TRACE)' \
          '--websocket-mask-frame[mask websocket frames]' \
          '--websocket-ping-frequency-sec=[websocket ping frequency]:secs:' \
          '--tls-sni-override=[SNI domain override]:domain:' \
          '--tls-sni-disable[disable SNI]' \
          '--tls-ech-enable[enable ECH (encrypted SNI)]' \
          '--tls-verify-certificate[verify server cert]' \
          '--tls-certificate=[client cert (pem) for mTLS]:file:_files' \
          '--tls-private-key=[client private key]:file:_files' \
          '--dns-resolver=[DNS resolver]:resolver:' \
          '--socket-so-mark=[Linux SO_MARK]:mark:' \
          '--nb-worker-threads=[number of worker threads]:n:' \
          '*: :' && ret=0 ;;
      (server)
        _arguments \
          '*--restrict-to=[restrict to tunnel info]:list:' \
          '--restrict-http-upgrade-path-prefix=[only accept this upgrade prefix]:prefix:' \
          '--restrict-config=[restriction yaml config]:file:_files' \
          '--tls-certificate=[server cert (pem)]:file:_files' \
          '--tls-private-key=[server private key]:file:_files' \
          '--tls-client-ca-certs=[client CA certs (enables mTLS)]:file:_files' \
          '--http-proxy=[HTTP proxy]:url:' \
          '--http-proxy-login=[HTTP proxy login]:user:' \
          '--http-proxy-password=[HTTP proxy password]:pass:' \
          '--websocket-ping-frequency-sec=[ping frequency]:secs:' \
          '--websocket-mask-frame[mask websocket frames]' \
          '--no-color[disable color output]' \
          '--log-lvl=[log level]:level:(OFF ERROR WARN INFO DEBUG TRACE)' \
          '--dns-resolver=[DNS resolver]:resolver:' \
          '--socket-so-mark=[Linux SO_MARK]:mark:' \
          '--nb-worker-threads=[number of worker threads]:n:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
