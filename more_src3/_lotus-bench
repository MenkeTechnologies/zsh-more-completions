#compdef lotus-bench lotus-fountain lotus-gateway lotus-health lotus-keygen lotus-pcr lotus-seed lotus-stats lotus-wallet
# Documentation: upstream cmd/lotus-*/main.go at github.com/filecoin-project/lotus
# Reference accessed: 2026-05-30 via gh api inspection of every cmd/lotus-*/main.go
# urfave/cli.Command list.
# Filecoin lotus R65 — 9-stem multi-binary harvest covering the
# auxiliary lotus binaries (excluding lotus/lotus-miner/lotus-shed/
# lotus-sim/lotus-worker, which remain deferred for future deep-dive
# rounds due to their dozens of nested subcommands).

local curcontext="$curcontext" state line ret=1

case $service in

  lotus-bench)
    # Benchmark performance of lotus on your hardware.
    local -a _subs
    _subs=(
      'sealing:benchmark seal and winning post and window post'
      'prove:benchmark a proof computation'
    )
    _arguments -C \
      '--repo=[lotus repo path]:path:_directories' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' && ret=0
    case $state in
      subcmd) _describe -t commands 'lotus-bench subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          sealing)
            _arguments -s -S \
              '--storage-dir=[path to the storage directory that will store sectors long term]:directory:_directories' \
              '--sector-size=[size of the sectors in bytes (e.g. 32GiB)]:size:' \
              '--no-gpu[disable gpu usage for the benchmark run]' \
              '--miner-addr=[pass miner address]:address:' \
              '--benchmark-existing-sectorbuilder=[directory to run post timings on an existing sectorbuilder]:directory:_directories' \
              '--json-out[output results in json format]' \
              '--skip-commit2[skip the commit2 (snark) portion of the benchmark]' \
              '--skip-unseal[skip the unseal portion of the benchmark]' \
              '--ticket-preimage=[ticket randomness preimage]:preimage:' \
              '--save-commit2-input=[file path to save commit2 input]:file:_files' \
              && ret=0
            ;;
          prove)
            _arguments '*:proof input file:_files' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  lotus-fountain)
    # Devnet token distribution utility.
    _arguments -C \
      '--repo=[lotus repo path]:path:_directories' \
      '(- *)--help[show help]' \
      '1:subcommand:(run)' \
      '*::run arg:->run_args' && ret=0
    case $state in
      run_args)
        _arguments -s -S \
          '--front=[front-end address]:address:' \
          '--from=[from address]:address:' \
          '--amount=[amount of FIL to distribute]:amount:' \
          '--data-cap=[data cap amount]:cap:' \
          '--captcha-threshold=[captcha threshold]:N:' \
          '--http-server-timeout=[HTTP server timeout]:duration:' && ret=0
        ;;
    esac
    ;;

  lotus-gateway)
    # Public API server for lotus.
    local -a _subs
    _subs=(
      'check:verify a connection can be made to a gateway'
      'run:start api server'
    )
    _arguments -C \
      '--repo=[lotus repo path]:path:_directories' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' && ret=0
    case $state in
      subcmd) _describe -t commands 'lotus-gateway subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          check) _arguments '*:apiInfo:' && ret=0 ;;
          run)
            _arguments -s -S \
              '--listen=[host address and port the api server will listen on]:host\:port:' \
              '--api-max-req-size=[maximum API request size accepted by the JSON RPC server]:bytes:' \
              '--api-max-lookback=[maximum duration allowable for tipset lookbacks]:duration:' \
              '--api-wait-lookback-limit=[max blocks to search back through for message inclusion]:N:' \
              '--rate-limit=[per-IP rate limit]:N:' \
              '--per-conn-rate-limit=[per-connection rate limit]:N:' \
              '--rate-limit-timeout=[rate limit timeout]:duration:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  lotus-health)
    # Tools for monitoring lotus daemon health.
    _arguments -C \
      '--repo=[lotus repo path]:path:_directories' \
      '(- *)--help[show help]' \
      '1:subcommand:(watch-head)' \
      '*::watch-head arg:->watch_args' && ret=0
    case $state in
      watch_args)
        _arguments -s -S \
          '--threshold=[number of times head remains unchanged before failing]:N:' \
          '--interval=[interval in seconds between chain head checks]:seconds:' \
          '--systemd-unit=[systemd unit name to restart on failure]:unit:' \
          '--api-timeout=[timeout between API retries]:duration:' \
          '--api-retries=[number of API retry attempts]:N:' && ret=0
        ;;
    esac
    ;;

  lotus-keygen)
    # Generate a lotus key.
    _arguments -s -S \
      '--type=[specify key type to generate]:type:(bls secp256k1)' \
      '--out=[specify key file name to generate]:file:_files' \
      '(- *)--help[show help]' && ret=0
    ;;

  lotus-pcr)
    # Refunds precommit initial pledge for all miners.
    local -a _subs
    _subs=(
      'version:print version'
      'find-miners:find miners with a desired minimum balance'
      'recover-miners:recover miners by refunding precommit pledge'
      'run:run the PCR'
    )
    _arguments -C \
      '--lotus-path=[lotus repo path]:path:_directories' \
      '--repo=[lotus-pcr repo path]:path:_directories' \
      '--log-level=[log level]:level:(error warn info debug)' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' && ret=0
    case $state in
      subcmd) _describe -t commands 'lotus-pcr subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          find-miners)
            _arguments -s -S \
              '--no-sync[do not wait for chain sync to complete]' \
              '--threshold=[balances below this are printed]:FIL:' \
              '--owner[include owner balance]' \
              '--worker[include worker balance]' \
              '--control[include control balance]' && ret=0
            ;;
          recover-miners|run)
            _arguments '*:miner address:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  lotus-seed)
    # Seal sectors for genesis miner.
    local -a _subs
    _subs=(
      'pre-seal:pre-seal sectors'
      'aggregate-manifests:aggregate a set of preseal manifests into a single file'
    )
    _arguments -C \
      '--sector-dir=[sector directory]:directory:_directories' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' && ret=0
    case $state in
      subcmd) _describe -t commands 'lotus-seed subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          pre-seal)
            _arguments -s -S \
              '--miner-addr=[specify the future address of your miner]:address:' \
              '--sector-size=[specify size of sectors to pre-seal]:size:' \
              '--ticket-preimage=[set the ticket preimage for sealing randomness]:preimage:' \
              '--num-sectors=[select number of sectors to pre-seal]:N:' \
              '--sector-offset=[how many sector ids to skip when starting to seal]:N:' \
              '--key=[key to use for signing / owner/worker addresses]:key:' \
              '--fake-sectors[generate fake sectors instead of sealing real ones]' \
              '--network-version=[specify network version]:version:' && ret=0
            ;;
          aggregate-manifests)
            _arguments '*:manifest file:_files' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  lotus-stats)
    # Collect basic information about a filecoin network using lotus.
    local -a _subs
    _subs=(
      'version:print version'
      'run:run lotus-stats collector'
    )
    _arguments -C \
      '--lotus-path=[lotus repo path]:path:_directories' \
      '--log-level=[log level]:level:(error warn info debug)' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' && ret=0
    case $state in
      subcmd) _describe -t commands 'lotus-stats subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          run)
            _arguments -s -S \
              '--influx-database=[influx database name]:db:' \
              '--influx-hostname=[influx hostname]:host:' \
              '--influx-username=[influx username]:user:' \
              '--influx-password=[influx password]:password:' \
              '--height=[tipset height to start processing from]:N:' \
              '--head-lag=[number of tipsets to delay processing on to smooth chain reorgs]:N:' \
              '--no-sync[do not wait for chain sync to complete]' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  lotus-wallet)
    # Basic external wallet daemon.
    local -a _subs
    _subs=(
      'get-api-key:generate API Key'
      'run:start lotus wallet'
    )
    _arguments -C \
      '--repo=[wallet repo path]:path:_directories' \
      '--wallet-repo=[wallet repo path]:path:_directories' \
      '(- *)--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' && ret=0
    case $state in
      subcmd) _describe -t commands 'lotus-wallet subcommand' _subs && ret=0 ;;
      subcmd_args)
        case $words[1] in
          run)
            _arguments -s -S \
              '--listen=[host address and port the wallet api will listen on]:host\:port:' \
              '--ledger[use a ledger device instead of an on-disk wallet]' \
              '--interactive[prompt before performing actions (do not use for miner worker address)]' \
              '--offline[do not query chain state in interactive mode]' \
              '--disable-auth[(insecure) disable api auth]' \
              '--http-server-timeout=[HTTP server timeout]:duration:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
