#compdef hledger-flow
# Documentation: https://github.com/apauley/hledger-flow
# Documentation: https://github.com/apauley/hledger-flow/blob/master/app/Main.hs
# Reference accessed: 2026-05-27
# Verified: upstream app/Main.hs (baseCommandParser, verboseParser,
# subcommandParserImport, subcommandParserReport).

# Zsh completion for hledger-flow (hledger workflow automation).

local curcontext="$curcontext" state line ret=1

local -a _hledger_flow_subcommands
_hledger_flow_subcommands=(
  'import:convert electronic statements into categorised journal files'
  'report:generate reports'
)

_arguments -s -S -C \
  '(- *)'{-V,--version}'[display version information]' \
  '*'{-v,--verbose}'[print more verbose output (repeatable)]' \
  '(-H --hledger-path)'{-H+,--hledger-path=}'[full path to an hledger executable]:path:_files' \
  '--show-options[print the options this program will run with]' \
  '--batch-size=[parallel batch size]:size:' \
  '--sequential[disable parallel processing]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'hledger-flow subcommand' _hledger_flow_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      import)
        _arguments -s -S \
          '--start-year=[import only from the specified year and onwards]:year:' \
          '--new-files-only[skip regenerating files that are at least as new as their source]' \
          '1:dir:_files -/' && ret=0
        ;;
      report)
        _arguments -s -S \
          '--ascii-reports[avoid using hledger --pretty-tables flag when generating reports]' \
          '1:basedir:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
