_skystreamer() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-R --atproto-relay)'{-R,--atproto-relay}'=[AT Protocol relay hostname (default bsky.network)]:host:' \
        '(-E --exporter)'{-E,--exporter}'=[exporter backend (default surrealdb)]:type:(jsonl csv surrealdb dry-run)' \
        '(-o --file-path)'{-o,--file-path}'=[output file (required for jsonl/csv exporters)]:path:_files' \
        '(-e --surreal-endpoint)'{-e,--surreal-endpoint}'=[SurrealDB endpoint (default ws://localhost:8000)]:url:' \
        '(-a --auth-type)'{-a,--auth-type}'=[SurrealDB auth type]:type:(token root namespace)' \
        '(-k --token)'{-k,--token}'=[token for authentication]:token:' \
        '(-u --username)'{-u,--username}'=[username for authentication]:user:' \
        '(-p --password)'{-p,--password}'=[password for authentication]:pass:' \
        '(-n --namespace)'{-n,--namespace}'=[SurrealDB namespace (default bsky.network)]:ns:' \
        '(-d --database)'{-d,--database}'=[SurrealDB database (default bsky)]:db:' \
        '(-f --fetch-user-data)'{-f,--fetch-user-data}'=[fetch user-profile data from ATProto (default true)]:bool:(true false)'
}

_skystreamer "$@"
