#compdef tci
# ============================================================================
# tci - Typeberry Common Interface (TCI),
#        the cross-implementation-compatible CLI
#        wrapper for JAM (Join-Accumulate Machine)
#        node implementations (Node.js, MPL-2.0)
#
# Author : Fluffy Labs (typeberry contributors)
# Upstream: https://github.com/FluffyLabs/typeberry
# npm    : @typeberry/tci (binary: tci)
# Spec    : https://docs.jamcha.in/basics/cli-args
#
# `tci` (TypeberyCommon Interface) is the
# cross-implementation-compatible CLI binary for
# JAM blockchain node implementations. JAM
# (Join-Accumulate Machine) is the upcoming
# Polkadot-roadmap blockchain protocol designed by
# Gavin Wood. The JAM Cross-Implementation CLI
# specification (https://docs.jamcha.in/basics/
# cli-args) defines a common set of CLI flags that
# every JAM node implementation must support. The
# `tci` binary in typeberry is FluffyLabs's
# TypeScript JAM implementation's compliance
# wrapper around its own `jam` binary.
#
# Use cases:
#   - Run a JAM validator/full node using the
#     typeberry TypeScript implementation
#   - Cross-implementation testing (tci's flag
#     compatibility lets a typeberry node be
#     spawned with the same CLI args as a
#     Rust/Go/C++ JAM implementation for
#     comparison testing)
#   - Development + integration testing for JAM
#     ecosystem tooling
#
# Architecture:
#   - typeberry is a TypeScript JAM
#     implementation (the FluffyLabs team)
#   - tci wraps typeberry's `jam` binary +
#     translates the JAM Cross-Implementation
#     CLI args into typeberry's internal args
#   - PVM (Polkadot Virtual Machine) execution
#     via @typeberry/pvm-interpreter
#   - Cryptography: bandersnatch + BLS +
#     Ed25519 + SHA-3 + Keccak via sodium-native
#     + @typeberry/native (platform-specific
#     prebuilt addons)
#   - Networking: @typeberry/networking +
#     @matrixai/quic (QUIC for JAM peer-to-peer
#     protocol)
#   - Database: lmdb for blockchain state
#   - Logging: @typeberry/logger
#
# Usage:
#   tci [options]
#
# Flags (minimist-parsed; JAM Cross-Implementation
# CLI spec compliance):
#       --bandersnatch <hex>           - Bandersnatch
#                                         seed
#                                         (development
#                                         only; 32-byte
#                                         hex, 0x-
#                                         prefix
#                                         optional)
#       --bls <hex>                    - BLS seed
#                                         (development
#                                         only; 32-byte
#                                         hex)
#       --ed25519 <hex>                - Ed25519 seed
#                                         (development
#                                         only; 32-byte
#                                         hex)
#       --datadir <path>               - directory for
#                                         blockchain
#                                         data,
#                                         keystore,
#                                         and other
#                                         persistent
#                                         state
#       --genesis <path>               - genesis
#                                         state JSON
#                                         file
#       --metadata <name>              - node metadata
#                                         (default
#                                         "Alice")
#       --port <int>                   - QUIC + TCP
#                                         networking
#                                         listening
#                                         port
#                                         (default
#                                         9900)
#       --ts <int>                     - JAM genesis
#                                         epoch0
#                                         Unix
#                                         timestamp
#                                         (overrides
#                                         genesis
#                                         config)
#       --validatorindex <int>         - validator
#                                         index in
#                                         the
#                                         validator
#                                         set
#                                         (development
#                                         only)
#       --version                      - print
#                                         version +
#                                         exit
#       --help                         - print help
#
# Example invocations (development mode):
#   tci --datadir /var/lib/jam \
#       --genesis /etc/jam/genesis.json \
#       --port 9900 \
#       --metadata "alice-node"
#
#   # Development with dummy seeds (TCI spec
#   # requires all three seed types for dev
#   # mode):
#   tci --bandersnatch 0x000...01 \
#       --bls 0x000...02 \
#       --ed25519 0x000...03 \
#       --validatorindex 0 \
#       --port 9900
#
# The @matrixai/quic lane is built on
# `@matrixai/quic ^2.0.9` (declared at the
# typeberry workspace's `packages/core/
# networking/package.json` as a direct dep,
# transitively required by `tci` via
# `@typeberry/node` and `@typeberry/networking`),
# the canonical Node QUIC library by the Matrix AI
# team (Roger Qiu + collaborators) - github.com/
# MatrixAI/js-quic.
#
# Matrix AI's @matrixai/quic is the de-facto
# canonical Node QUIC library:
#   - N-API bindings to a Rust QUIC
#     implementation (uses the quiche crate
#     internally via the MatrixAI/Polykey
#     project's networking stack)
#   - Platform-specific native modules
#     (@matrixai/quic-darwin-universal +
#     @matrixai/quic-linux-x64 +
#     @matrixai/quic-win32-x64 + ARM variants)
#   - TLS 1.3 + 0-RTT support
#   - Client + server modes
#   - Connection migration
#   - Used by Polykey + typeberry +
#     several Solana SDK + DNS benchmarking
#     tools
#
# Note: this is *the* canonical Node QUIC library
# despite Node 22+ having experimental `node:quic`
# stdlib support. The stdlib QUIC implementation
# is gated behind the experimental flag + is not
# yet stable for production use. The Matrix AI
# library + node-quic + a few other community
# libraries fill the gap. @matrixai/quic is the
# most-actively-maintained pure-Node QUIC
# wrapper with N-API binding to a Rust
# implementation.
#
# Matrix AI's broader Node ecosystem footprint
# (the @matrixai/ binary-protocol microlib
# umbrella):
#   - @matrixai/quic (canonical Node QUIC; THIS
#     AXIS)
#   - @matrixai/db (LevelDB/RocksDB-style KV
#     store wrapper)
#   - @matrixai/mdns (multicast DNS
#     implementation)
#   - @matrixai/exec (cross-platform process
#     execution)
#   - @matrixai/logger (structured logger)
#   - @matrixai/errors (typed-error system)
#   - @matrixai/async-init (async resource
#     lifecycle management)
#   - @matrixai/db-rocksdb (RocksDB bindings)
#
# Matrix AI's role in the Node ecosystem is
# *binary-protocol + system-integration microlib
# canonical infrastructure*. The Matrix AI
# team's libraries are foundational to their own
# Polykey product (decentralized secret-sharing
# system) and have been adopted by other
# projects needing performance-critical
# protocol implementations in Node.
#
# Matrix AI joins the multi-axis canonical-Node
# author/org cohort:
#   - + previous cohort: Sorhus + Ranney +
#     Carlson + Sitnik + Fuller + Miller +
#     Govett + Collina + Schlueter + Puzrin +
#     Belov + Zabriskie + Knightley + Latimer +
#     Borewit + Arthur + Node team
#   - Matrix AI / Roger Qiu (@matrixai/quic +
#     db + mdns + exec + logger + errors +
#     async-init; THIS AXIS)
#
# tci uses @matrixai/quic indirectly via
# @typeberry/networking's QUIC peer-to-peer
# protocol layer:
#   ```ts
#   import { QUICServer, QUICClient } from
#     '@matrixai/quic';
#
#   const server = new QUICServer({
#     crypto: { /* TLS cert + key */ },
#     config: { /* QUIC config */ },
#   });
#
#   await server.start({ host, port });
#   server.addEventListener('connection',
#     (event) => {
#     const conn = event.detail;
#     conn.addEventListener('stream', (e) => {
#       // Handle incoming JAM peer-to-peer
#       // protocol streams
#       handleJAMStream(e.detail);
#     });
#   });
#   ```
#
# JAM nodes use QUIC for the peer-to-peer
# block-propagation + state-sync protocol due
# to QUIC's:
#   - Connection migration (validators can
#     change IPs during a session without
#     restarting connection)
#   - Stream-level multiplexing (block +
#     attestation + state updates run in
#     parallel streams without head-of-line
#     blocking)
#   - 0-RTT resumption (reconnection latency
#     ~0ms vs ~3-RTT for TCP+TLS)
#   - Built-in TLS 1.3 (no separate handshake
#     phase)
#
# ----------------------------------------------------------------------------
# AXIS 274 :: QUIC + HTTP/3 protocol libraries
#              (IETF QUIC v1 RFC 9000 + QUIC
#              TLS RFC 9001 + Recovery RFC 9002 +
#              HTTP/3 RFC 9114 + QPACK RFC 9204)
# Round 1522 :: TS-Node slot 3 of 4 :: CLOSES Axis 274
#                                       (267th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : cloudflare/quiche           [R1520 _mmserver]
#             (Cloudflare; enterprise-
#              backed; BoringSSL TLS;
#              production at CDN edge)
#   Go      : quic-go/quic-go             [R1521 _fujin]
#             (Marten Seemann + quic-go
#              org; pure-Go; IETF QUIC
#              WG chair + Interop Runner
#              maintainer)
#   TS/Node : MatrixAI/js-quic            [R1522 THIS FILE]
#             (Matrix AI / Roger Qiu;
#              N-API binding to Rust;
#              fragmented Node QUIC
#              ecosystem)
#
# MatrixAI/js-quic closes Axis 274 with the
# *N-API-binding-to-Rust* pattern. The three
# lanes demonstrate three distinct QUIC-
# canonical architectures:
#
#   - Rust (quiche): enterprise-authored pure-
#     Rust canonical (Cloudflare)
#   - Go (quic-go): spec-author + community
#     pure-Go canonical (Marten Seemann)
#   - Node (matrixai/quic): N-API binding to
#     Rust canonical (Matrix AI)
#
# Each lane's mechanism reflects ecosystem
# maturity for QUIC:
#   - Rust + Go: pure-language canonical
#     implementations have reached production
#     maturity
#   - Node: experimental node:quic stdlib;
#     fragmented community library ecosystem;
#     the matrixai/quic library wraps a Rust
#     implementation via N-API
#
# This is the *second axis in the corpus where
# the Node canonical defers to a non-JS
# implementation*. The first was Axis 273 (TLS)
# where node:tls wraps OpenSSL via C++ binding.
# The second is Axis 274 (QUIC) where matrixai/
# quic wraps Rust via N-API binding.
#
# This pattern reflects Node's *FFI-canonical*
# nature for performance-critical protocol
# implementations - the Node ecosystem accepts
# native dependencies when pure-JS would be
# prohibitively slow (TLS) or technically
# complex (QUIC).
#
# Cross-language interop at the QUIC + HTTP/3
# wire level - all three lanes interoperate via
# the QUIC Interop Runner's test framework. The
# QUIC Interop Runner is maintained by Marten
# Seemann personally + tests all major QUIC
# implementations weekly.
#
# Use-case spectrum across the three lanes:
#   - mmserver (Rust, quiche): low-latency
#     game streaming + remote desktop server
#   - fujin (Go, quic-go): message broker
#     gateway with QUIC client transport
#   - tci (Node, matrixai/quic via @typeberry/
#     networking): JAM blockchain validator
#     node with QUIC peer-to-peer networking
#
# Three lanes, three use-case shapes (game
# streaming + message brokering + blockchain
# validation), three QUIC-canonical
# architectures (enterprise-pure-Rust +
# spec-author-pure-Go + N-API-binding-to-Rust),
# all converging on the IETF QUIC + HTTP/3 spec.
#
# Axis 274 closes the round 1522 cycle - 267th
# axis closed total.
#
# Multi-axis canonical-Node author/org cohort
# extension (now spanning 18 distinct
# individuals/orgs):
#   - + Matrix AI / Roger Qiu + collaborators
#     (@matrixai/quic + db + mdns + exec +
#     logger + errors + async-init; THIS AXIS)
#
# Matrix AI's role in the corpus is unique -
# they're the only Node canonical author whose
# stack is specifically designed around their
# own product (Polykey decentralized secrets-
# sharing system). The matrixai/quic library
# was originally built for Polykey's peer-to-
# peer networking + has since been adopted by
# other projects (typeberry + various Solana
# SDK projects + DNS benchmarking tools).
#
# This is the *product-driven canonical*
# pattern - similar to:
#   - Bytebeam (rumqtt) - originally built for
#     Bytebeam's IoT product line
#   - Cloudflare (quiche) - originally built for
#     Cloudflare's edge network
#   - Now Matrix AI (matrixai/quic) - originally
#     built for Polykey's P2P stack
#
# Each product-driven canonical author brings
# their product's specific requirements to the
# library design, which then propagates to
# downstream consumers.
# ============================================================================

_tci() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--bandersnatch=[Bandersnatch seed (32-byte hex; dev only)]:hex:' \
        '--bls=[BLS seed (32-byte hex; dev only)]:hex:' \
        '--ed25519=[Ed25519 seed (32-byte hex; dev only)]:hex:' \
        '--datadir=[directory for blockchain data + keystore]:dir:_files -/' \
        '--genesis=[genesis state JSON file]:file:_files -g "*.json"' \
        '--metadata=[node metadata string]:name:' \
        '--port=[QUIC + TCP networking listening port]:port:' \
        '--ts=[JAM genesis epoch0 Unix timestamp]:ts:' \
        '--validatorindex=[validator index (dev only)]:idx:' \
        '(- *)--version[print version]' \
        '(- *)--help[print help]'
}

_tci "$@"
