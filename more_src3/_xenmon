#compdef xenmon xenmon.py
# Documentation: https://github.com/xen-project/xen/blob/master/tools/xenmon/xenmon.py
# Reference accessed: 2026-05-21
# Verified: upstream xenmon.py optparse definition quoted from source.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-l --live)'{-l,--live}'[ncurses live monitoring frontend (default)]' \
  '(-n --notlive)'{-n,--notlive}'[write to file instead of live monitoring]' \
  '(-p --prefix)'{-p+,--prefix=}'[output file prefix (default "log")]:prefix:' \
  '(-t --time)'{-t+,--time=}'[stop after seconds; 0 = indefinite (default 10)]:secs:' \
  '(-i --interval)'{-i+,--interval=}'[logging interval ms (default 1000)]:ms:' \
  '--ms_per_sample=[ms of data per sample (default 100)]:ms:' \
  '--cpu=[CPU to display (default 0)]:cpu:' \
  '(--noallocated)--allocated[display allocated time per domain]' \
  '(--allocated)--noallocated[hide allocated time per domain]' \
  '(--noblocked)--blocked[display blocked time per domain (default)]' \
  '(--blocked)--noblocked[hide blocked time per domain]' \
  '(--nowaited)--waited[display waiting time per domain (default)]' \
  '(--waited)--nowaited[hide waiting time per domain]' \
  '(--noexcount)--excount[display execution count per domain]' \
  '(--excount)--noexcount[hide execution count per domain]' \
  '(--noiocount)--iocount[display I/O count per domain]' \
  '(--iocount)--noiocount[hide I/O count per domain]' \
  '(- *)-h[show help]' && ret=0
return ret
