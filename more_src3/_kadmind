#compdef kadmind
# _kadmind — MIT Kerberos Consortium kadmind Kerberos V5 administration server daemon (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_kadmind() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-x+[db arg]:str:' \
        '--db-args=+[db arg]:str:' \
        '-r+[realm]:str:' \
        '--realm=+[realm]:str:' \
        '-m[manual master key prompt]' \
        '-nofork[do not detach]' \
        '-port+[kadmin port]:port:_ports' \
        '-p+[kadmin port]:port:_ports' \
        '-W[allow weak crypto]' \
        '-proponly[propagate-only mode]' \
        '-k+[keytab file]:file:_files' \
        '--key-tab=+[keytab file]:file:_files' \
        '-acl+[ACL file]:file:_files' \
        '-P+[pid file]:file:_files' \
        '-d[debug mode]' \
        '--debug[debug mode]'
}

_kadmind "$@"
