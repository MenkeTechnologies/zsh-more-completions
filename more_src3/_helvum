#compdef helvum
# Documentation: https://gitlab.freedesktop.org/pipewire/helvum
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# helvum is a GTK patchbay GUI for PipeWire with no documented CLI flags
# beyond the standard GTK/GApplication --help and --version.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
