#compdef influx2 influx influx-cli-v2
# _influx2 — InfluxData influx-cli InfluxDB 2.x and InfluxDB Cloud CLI for managing organisations buckets tasks dashboards labels users tokens authentication and writing/querying line-protocol metrics with Flux (influxdata team, Go); cobra
# upstream: https://github.com/influxdata/influx-cli

_influx2() {
    local -a sub=(
        'auth:authorization operations'
        'backup:backup data'
        'bucket:bucket operations'
        'bucket-schema:bucket schema operations'
        'config:configuration operations'
        'dashboards:dashboard operations'
        'delete:delete data'
        'export:export resource'
        'init:initialize InfluxDB instance'
        'org:organization operations'
        'ping:test connection'
        'query:run Flux query'
        'restore:restore from backup'
        'secret:secret operations'
        'setup:run setup wizard'
        'stacks:stack operations'
        'task:task operations'
        'telegrafs:telegraf operations'
        'template:template operations'
        'transpile:transpile InfluxQL to Flux'
        'user:user operations'
        'v1:v1 compatibility operations'
        'write:write line protocol data'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--host=+[url]:str:' \
        '-t+[api token]:str:' \
        '--token=+[api token]:str:' \
        '--skip-verify[skip TLS verify]' \
        '--http-debug[HTTP debug]' \
        '--trace-debug-id=+[id]:str:' \
        '--configs-path=+[file]:file:_files' \
        '-c+[config name]:str:' \
        '--active-config=+[config name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'influx2 subcommand' sub ;;
        args)
            case $words[1] in
                write) _arguments \
                    '--bucket=+[name]:str:' \
                    '-b+[name]:str:' \
                    '--bucket-id=+[id]:str:' \
                    '--org=+[name]:str:' \
                    '-o+[name]:str:' \
                    '--org-id=+[id]:str:' \
                    '--precision=+[p]:p:(ns us ms s)' \
                    '-p+[p]:p:(ns us ms s)' \
                    '--format=+[fmt]:f:(lp csv)' \
                    '--header=+[csv]:str:' \
                    '--skip-header=+[N]:n:' \
                    '*:file:_files' ;;
                query) _arguments \
                    '--file=+[Flux file]:file:_files -g "*.flux"' \
                    '-f+[Flux file]:file:_files -g "*.flux"' \
                    '--org=+[name]:str:' \
                    '-o+[name]:str:' \
                    '--raw[raw output]' \
                    '--profilers=+[csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_influx2 "$@"
