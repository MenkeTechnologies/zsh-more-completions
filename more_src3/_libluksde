#compdef luksdeinfo luksdemount
# _libluksde — libluksde tools (libyal LUKS1/LUKS2 disk-encryption parser; luksdeinfo prints LUKS header / key-slot metadata, luksdemount FUSE-mounts the decrypted block device given the passphrase or key file; -h help, -V version, -v verbose, -k key file, -p passphrase, -o image offset, -X exclusive)
# upstream: https://github.com/libyal/libluksde
# Flags from libyal/libluksde luksdetools/luksdemount.c on tip.

_libluksde() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-k+[key file]:file:_files' \
        '-p+[passphrase]:passphrase:' \
        '-o+[image offset]:bytes:' \
        '-X[exclusive lock]' \
        '*:LUKS image:_files'
}

_libluksde "$@"
