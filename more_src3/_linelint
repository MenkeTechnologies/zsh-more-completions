#compdef linelint
# _linelint — newline / whitespace rule linter (fernandrone/linelint)
# upstream: https://github.com/fernandrone/linelint
# Flags from linelint.go (stdlib flag).

_linelint() {
    local -a args
    args=(
        '-a[autofix: rewrite files in place to satisfy rules]'
        '*:file or dir:_files'
    )
    _arguments -s $args
}

_linelint "$@"
