#compdef jumppad
# Documentation: https://github.com/jumppad-labs/jumppad/tree/main/cmd
# Reference accessed: 2026-05-19
# Verified: cobra Use:/Flags() definitions in cmd/*.go at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'up:create or update the resources defined in the configuration'
  'down:destroy all resources from the configuration'
  'dev:watch the configuration and re-apply on changes'
  'check:check the system for required dependencies'
  'status:show the status of resources'
  'env:show the environment variables set by the configuration'
  'logs:show the logs for resources'
  'output:show the output variables from the configuration'
  'purge:purge cached images, blueprints, and helm charts'
  'push:push a local Docker image to a cluster'
  'taint:mark a resource for recreation on the next run'
  'uninstall:remove jumppad and clean up'
  'validate:validate the configuration files'
  'fmt:format the configuration files'
  'version:show the jumppad version'
  'completion:generate shell completion scripts'
  'changelog:show the changelog'
  'generate:generate documentation from the configuration'
  'connector:run and manage the connector'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--non-interactive[run in non-interactive mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jumppad command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (up)
        _arguments \
          '--no-browser[do not open the browser]' \
          '--force-update[ignore caches and force a re-download]' \
          '--no-cache[do not use the build cache]' \
          '*--var=[set a variable key=value]:var:' \
          '--vars-file=[path to a variables file]:file:_files' \
          '*::path:_files' && ret=0 ;;
      (down)
        _arguments \
          '--force[do not prompt for confirmation]' \
          '*::path:_files' && ret=0 ;;
      (dev)
        _arguments \
          '*--var=[set a variable key=value]:var:' \
          '--vars-file=[path to a variables file]:file:_files' \
          '--interval=[interval to check for changes]:interval:' \
          '--disable-tty[disable the TTY output]' \
          '*::path:_files -/' && ret=0 ;;
      (push)
        _arguments \
          '1:image:' \
          '2:cluster:' && ret=0 ;;
      (taint|logs)
        _arguments \
          '*::resource:' && ret=0 ;;
      (env|validate|fmt)
        _arguments \
          '*::path:_files' && ret=0 ;;
      (status|output|purge|check|version|uninstall|changelog)
        _arguments \
          '*::arg:' && ret=0 ;;
      (generate)
        _arguments \
          '1:subcommand:(readme)' \
          '*::path:_files' && ret=0 ;;
      (connector)
        _arguments \
          '1:subcommand:(run stop generate-certs)' \
          '*::arg:_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
