#compdef xcresultparser
# Documentation: https://github.com/a7ex/xcresultparser
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for xcresultparser (a7ex/xcresultparser, swift-argument-parser)

_arguments -s -S \
  '--coverage-report-format[for -c output]:fmt:(totals targets classes methods)' \
  '(-o --output-format)'{-o,--output-format}'[output format]:fmt:(txt cli html md github xml junit cobertura warnings errors warnings-and-errors)' \
  '(-p --project-root)'{-p,--project-root}'[project root for relative paths]:directory:_directories' \
  '(-t --coverage-targets)'{-t,--coverage-targets}'[include coverage target (repeatable)]:target' \
  '(-e --excluded-path)'{-e,--excluded-path}'[exclude path pattern (repeatable)]:pattern' \
  '(-s --summary-fields)'{-s,--summary-fields}'[fields: errors warnings analyzerWarnings tests failed skipped duration date]' \
  '(-c --coverage)'{-c,--coverage}'[emit coverage section]' \
  '(-x --exclude-coverage-not-in-project)'{-x,--exclude-coverage-not-in-project}'[drop coverage outside project root]' \
  '(-n --no-test-result)'{-n,--no-test-result}'[omit test results]' \
  '(-f --failed-tests-only)'{-f,--failed-tests-only}'[only list failing tests]' \
  '(-q --quiet)'{-q,--quiet}'[suppress status output]' \
  '(-i --target-info)'{-i,--target-info}'[only print xcresult targets]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:xcresult bundle:_files -/' && ret=0

return ret
