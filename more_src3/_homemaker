#compdef homemaker
# _homemaker — dotfile / system bootstrap manager (FooSoft/homemaker)
# upstream: https://github.com/FooSoft/homemaker
# Flags from homemaker.go (stdlib flag).

_homemaker() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-task=[task name to execute]:task:'
        '-dest=[target directory for tasks]:dir:_files -/'
        '-force=[create parent directories at target]:bool:(true false)'
        '-clobber[delete existing files/dirs at target]'
        '-verbose[verbose output]'
        '-nocmds[do not execute commands]'
        '-nolinks[do not create symlinks]'
        '-notemplates[do not process templates]'
        '-variant=[execution variant for tasks/macros]:variant:'
        '-unlink[remove existing links instead of creating them]'
        '1:config file:_files -g "*.{toml,yaml,yml,json}"'
        '2:source dir:_files -/'
    )
    _arguments -s $args
}

_homemaker "$@"
