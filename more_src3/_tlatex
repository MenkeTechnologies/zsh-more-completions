#compdef tlatex
# Documentation: https://raw.githubusercontent.com/pmer/tla-bin/master/bin/tlatex
# Reference accessed: 2026-05-27
# Verified: upstream tla2tex.TLA.GetArguments() in tlaplus/tlaplus
#   tlatools/org.lamport.tlatools/src/tla2tex/TLA.java

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[print help and exit]' \
  '-info[print version and build info]' \
  '-grayLevel[PostScript gray level 0.0-1.0]:level:' \
  '-ps[produce PostScript output]' \
  '-nops[suppress PostScript output]' \
  '-psCommand[external PostScript command]:command:' \
  '-latexCommand[external LaTeX command]:command:' \
  '-out[LaTeX output file]:file:_files' \
  '-tlaOut[TLA output file with comments stripped]:file:_files' \
  '-alignOut[alignment output file]:file:_files' \
  '-debug[enable debug mode]' \
  '-tlaComment[treat ambiguous identifiers as TLA symbols]' \
  '-shade[enable comment shading]' \
  '-noPcalShade[disable PlusCal shading]' \
  '-noProlog[suppress LaTeX prolog]' \
  '-noEpilog[suppress LaTeX epilog]' \
  '-number[print line numbers]' \
  '-style[custom .sty style file]:file:_files -g "*.sty"' \
  '-ptSize[point size]:pt:(10 11 12)' \
  '-textwidth[text width in points (100-1000)]:points:' \
  '-textheight[text height in points (75-1500)]:points:' \
  '-hoffset[horizontal offset in points (-250 to 250)]:points:' \
  '-voffset[vertical offset in points (-250 to 250)]:points:' \
  '-metadir[metadata directory]:directory:_files -/' \
  '-latexOutputExt[LaTeX output extension]:ext:' \
  '*:spec:_files -g "*.tla"' && ret=0

return ret
