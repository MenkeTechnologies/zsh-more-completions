#compdef s6-svwait
# _s6-svwait — s6 supervision s6-svwait (block until one or more service directories reach a desired state — up/down/ready/notready/restart — across an OR or AND test)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-svwait.c on tip.

_s6-svwait() {
    _arguments \
        '(-U -u -d -D -r -R)-u[wait until service is up]' \
        '(-U -u -d -D -r -R)-U[wait until service is up AND ready]' \
        '(-U -u -d -D -r -R)-d[wait until service is down]' \
        '(-U -u -d -D -r -R)-D[wait until service is down AND not started by sv]' \
        '(-U -u -d -D -r -R)-r[wait until service is ready]' \
        '(-U -u -d -D -r -R)-R[wait until service is NOT ready]' \
        '(-a -o)-a[wait until all servicedirs reach target (AND)]' \
        '(-a -o)-o[wait until any servicedir reaches target (OR)]' \
        '-t+[max time to wait (ms)]:ms:' \
        '*:servicedir:_files -/'
}

_s6-svwait "$@"
