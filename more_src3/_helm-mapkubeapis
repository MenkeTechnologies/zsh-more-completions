#compdef helm-mapkubeapis
# Documentation: https://github.com/helm/helm-mapkubeapis
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--dry-run[simulate without making changes]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--kube-context=[kube context]:context:' \
  '--mapfile=[API mapping file location]:file:_files' \
  '--namespace=[release namespace]:namespace:' \
  '1:Helm release name:'
