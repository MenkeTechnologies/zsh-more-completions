#compdef redis-benchmark
# Documentation: redis-benchmark --help
# Source: Redis — load-generator + benchmark tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h+[server hostname]:host:_hosts' \
    '-p+[server port]:port:_ports' \
    '-s+[server socket (overrides host+port)]:socket:_files' \
    '-a+[Redis Auth password]:password:' \
    '--user=[ACL username (with -a)]:username:_users' \
    '-u+[server URI redis[s]://user\:pass@host\:port/db]:uri:' \
    '-c+[parallel connections (default 50)]:n:' \
    '-n+[total requests (default 100000)]:n:' \
    '-d+[SET/GET value size (bytes)]:bytes:' \
    '--dbnum=[SELECT db (default 0)]:n:' \
    '-3[RESP3 protocol mode]' \
    '--threads=[multi-thread mode]:num:' \
    '--cluster[cluster mode]' \
    '--enable-tracking[CLIENT TRACKING on before benchmark]' \
    '-k+[keep alive 1 / reconnect 0 (default 1)]:bool:(0 1)' \
    '-r+[random keyspace length]:keyspacelen:' \
    '-P+[pipeline requests (default 1)]:n:' \
    '-q[quiet (just query/sec)]' \
    '--precision=[decimal places in latency output]:n:' \
    '--csv[CSV output]' \
    '-l[loop forever]' \
    '-t+[comma list of tests to run]:tests:(ping_inline ping_mbulk set get incr lpush rpush lpop rpop sadd hset spop zadd zpopmin lrange_100 lrange_300 lrange_500 lrange_600 mset xadd)' \
    '-I[idle mode (open N idle conns)]' \
    '-x[read last argument from stdin]' \
    '--seed=[RNG seed]:num:' \
    '--tls[establish TLS]' \
    '--sni=[TLS SNI hostname]:host:_hosts' \
    '--cacert=[CA cert file]:file:_files' \
    '--cacertdir=[CA cert dir]:dir:_files -/' \
    '--insecure[skip cert validation]' \
    '--cert=[client cert]:file:_files' \
    '--key=[client private key]:file:_files' \
    '--tls-ciphers=[TLS 1.2 cipher list]:ciphers:' \
    '--tls-ciphersuites=[TLS 1.3 ciphersuites]:ciphers:' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*:Redis COMMAND ARGS:' \
    && ret=0

return ret
