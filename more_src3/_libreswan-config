#compdef libreswan-config ipsec-config
# _libreswan-config — Libreswan libreswan-config CLI for inspecting Libreswan IPsec build options compile-time features supported algorithms cryptohelper backend FIPS mode NSS database path configuration paths (libreswan team, C); getopt
# upstream: https://libreswan.org/

_libreswan-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--prefix[show install prefix]' \
        '--libdir[show lib dir]' \
        '--includedir[show include dir]' \
        '--datarootdir[show data root dir]' \
        '--sysconfdir[show sysconfig dir]' \
        '--ipsecdir[show ipsec dir]' \
        '--rundir[show run dir]' \
        '--vardir[show var dir]' \
        '--logdir[show log dir]' \
        '--nssdir[show NSS database dir]' \
        '--policiesdir[show policies dir]' \
        '--all[show all]' \
        '--cflags[show CFLAGS]' \
        '--libs[show LIBS]' \
        '--show-builddep[show build dep]' \
        '--fips[show FIPS]' \
        '--algorithms[show supported algorithms]' \
        '--dnssec[show DNSSEC support]' \
        '--seccomp[show seccomp support]' \
        '--lto[show LTO support]' \
        '--with-config-file=+[file]:file:_files'
}

_libreswan-config "$@"
