#compdef kani
# _kani — Kani: bit-precise model checker for Rust (model-checking/kani)
# upstream: https://github.com/model-checking/kani
# Driver: kani-driver/src/args/mod.rs (clap derive).

_kani() {
    local -a args
    args=(
        '--harness=[only check the named proof harness (substring match)]:harness:'
        '--exact[interpret --harness as an exact match instead of substring]'
        '--tests[build in test mode (cfg(test), dev-dependencies available)]'
        '--default-unwind=[default global loop-unwinding bound]:bound:'
        '--unwind=[per-harness override of the global unwinding bound]:bound:'
        '--solver=[SMT solver to use]:solver:(minisat cadical kissat z3)'
        '--output-format=[diagnostics formatting]:format:(regular terse old)'
        '--concrete-playback=[generate Rust unit test playing back a failing harness]:mode:(print inplace)'
        '--coverage[experimental coverage reporting]'
        '--enable-unstable[allow use of unstable features]'
        '--no-default-checks[disable all built-in checks]'
        '--no-overflow-checks[disable arithmetic overflow checks]'
        '--no-unwinding-checks[disable loop-unwinding-assertion checks]'
        '--no-undefined-function-checks[disable undefined-function checks]'
        '--no-assertion-reach-checks[disable assertion-reachability checks]'
        '--randomize-layout=[seed for randomized struct layout]:seed:'
        '--enable-stubbing[enable function stubbing]'
        '--workers=[number of harnesses to verify in parallel]:count:'
        '--jobs=[number of CBMC worker threads per harness]:count:'
        '--visualize[generate an HTML counterexample visualization]'
        '--gen-c[generate C source from MIR (debug)]'
        '--keep-temps[do not delete intermediate files]'
        '--target-dir=[directory for build artifacts]:dir:_files -/'
        '--quiet[suppress output]'
        '--verbose[verbose output]'
        '--debug[debug output]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '*:Rust source file:_files -g "*.rs"'
    )
    _arguments -s -S $args
}

_kani "$@"
