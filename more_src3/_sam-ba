#compdef sam-ba sam-ba.exe sam-ba_3
# _sam-ba — Microchip Atmel SAM-BA CLI for the Microchip SAM-BA in-system-programmer interfacing with Atmel SAM3 SAM4 SAM7 SAM9 SAMA5 SAMV7 and SAMD/SAML chip-built-in ROM bootloader over USB or UART for flash erase write verify (microchip team, C++); custom argparse
# upstream: https://www.microchip.com/en-us/development-tools-tools-and-software/programmers-and-debuggers/sam-ba-in-system-programmer

_sam-ba() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[level]:n:(0 1 2 3 4 5)' \
        '--verbose=+[level]:n:(0 1 2 3 4 5)' \
        '-p+[port]:p:(serial usb)' \
        '--port=+[port]:p:(serial usb)' \
        '-d+[device]:str:' \
        '--device=+[device]:str:' \
        '-b+[board]:str:' \
        '--board=+[board]:str:' \
        '-a+[applet]:a:(extram lowlevel sdmmc bootconfig spiflash nandflash dataflash qspiflash i2cflash mwflash atmel-usbi flash)' \
        '--applet=+[applet]:a:(extram lowlevel sdmmc bootconfig spiflash nandflash dataflash qspiflash i2cflash mwflash)' \
        '-i+[applet init args]:str:' \
        '--initargs=+[applet init args]:str:' \
        '-x+[script file]:file:_files -g "*.tcl *.qml *.js"' \
        '--execute=+[script file]:file:_files -g "*.tcl *.qml *.js"' \
        '-c+[command]:str:' \
        '--command=+[command]:str:' \
        '-m+[monitor]' \
        '--monitor[monitor]' \
        '-t+[traceLevel]:n:' \
        '--tracelevel=+[traceLevel]:n:' \
        '-l+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-T+[timeout]:n:' \
        '--timeout=+[timeout]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '*:script file:_files -g "*.tcl *.qml *.js"'
}

_sam-ba "$@"
