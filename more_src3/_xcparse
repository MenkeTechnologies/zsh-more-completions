#compdef xcparse
# _xcparse — xcparse Xcode result bundle parser (Swift); extracts attachments, screenshots, logs from .xcresult bundles
# upstream: https://github.com/ChargePoint/xcparse

_xcparse() {
    local -a sub=(
        'screenshots:extract screenshots from xcresult'
        'attachments:extract attachments'
        'logs:extract logs'
        'codecoverage:extract code coverage'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xcparse subcommand' sub ;;
        args)
            _arguments \
                '--test[only include test attachments]' \
                '--uti+[UTI filter]:uti:' \
                '--verbose[verbose log]' \
                '1:xcresult bundle:_files -g "*.xcresult"' \
                '2:output dir:_files -/'
            ;;
    esac
}

_xcparse "$@"
