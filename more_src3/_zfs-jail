#compdef zfs-jail zfs-unjail
# _zfs-jail — OpenZFS zfs jail / zfs unjail (FreeBSD-only: hand off control of a dataset to a non-default jail so the jail can administer ZFS properties for it; positional jail id (or jail name) followed by the dataset)
# upstream: https://github.com/openzfs/zfs
# Argument shape from openzfs cmd/zfs/zfs_main.c (zfs_do_jail) on tip.

_zfs-jail() {
    _arguments \
        '1:jail id or name:' \
        '2:dataset:'
}

_zfs-jail "$@"
