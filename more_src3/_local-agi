_local-agi() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _la_cmds=(
                'serve:start the LocalAGI web server with agent pool + web UI (default)'
                'agent:manage and run LocalAGI agents'
                'help:show help for command'
            )
            _describe -t commands 'local-agi command' _la_cmds && ret=0
            ;;
        args)
            case $words[1] in
                serve)
                    _arguments \
                        '--help[show help]' && ret=0
                    ;;
                agent)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'agent sub-command' '(run)' && ret=0
                    else
                        case $words[2] in
                            run)
                                _arguments \
                                    '1:agent name:' \
                                    '(-c --config)'{-c,--config}'=[agent JSON config file]:file:_files -g "*.json"' \
                                    '(-p --prompt)'{-p,--prompt}'=[foreground mode prompt (single-shot)]:prompt:' \
                                    '--help[show help]' && ret=0
                                ;;
                        esac
                    fi
                    ;;
                help)
                    _arguments '1:command:(serve agent)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_local-agi "$@"
