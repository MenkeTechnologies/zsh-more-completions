#compdef jack_connect jack_disconnect
# Documentation: https://jackaudio.org/
# Source: manpages.debian.org/jack_{connect,disconnect}.1 — connect / disconnect two JACK ports.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --server)'{-s+,--server=}'[JACK server to connect to]:server name:' \
    '(- *)'{-h,--help}'[display help]' \
    '*:src port then dst port:' \
    && ret=0

return ret
