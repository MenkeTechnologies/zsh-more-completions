#compdef karmada-aggregated-apiserver
# Documentation: https://karmada.io/docs/reference/components/karmada-aggregated-apiserver/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. This is an aggregated apiserver:
# removed invented --karmada-kubeconfig/--leader-elect*/--master/--logtostderr;
# real flags are kube-apiserver-style as below.

# karmada-aggregated-apiserver: Karmada aggregated API server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[path to karmada control plane kubeconfig file]:file:_files' \
  '--authentication-kubeconfig=[kubeconfig pointing at the core kubernetes server]:file:_files' \
  '--secure-port=[port to serve HTTPS with authn/authz]:port:' \
  '--bind-address=[IP address to listen for the --secure-port]:addr:' \
  '--tls-cert-file=[file containing the default x509 Certificate for HTTPS]:file:_files' \
  '--tls-private-key-file=[file containing the default x509 private key]:file:_files' \
  '--etcd-servers=[list of etcd servers to connect with]:servers:' \
  '--audit-log-path=[file to log all apiserver requests]:file:_files' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '*::karmada-aggregated-apiserver args:_files' && ret=0
return ret
