#compdef kubectl-convert
# Documentation: https://github.com/kubernetes/kubectl-convert
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  {-f,--filename}'[filename to convert]:file:_files' \
  {-o,--output}'[output format]:format:(json yaml)' \
  '--output-version[target API version to convert to]:version' \
  '--local[just convert locally, do not send to server]' \
  {-R,--recursive}'[process directory recursively]' \
  '--validate[validate input before converting]' \
  '--kubeconfig[path to kubeconfig file]:kubeconfig:_files' \
  '--context[kubeconfig context to use]:context' \
  '--cluster[kubeconfig cluster to use]:cluster' \
  {-n,--namespace}'[kubernetes namespace]:namespace' \
  '*:filename:_files'
