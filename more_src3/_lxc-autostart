#compdef lxc-autostart

# Zsh completion for lxc-autostart (auto-start LXC containers)

_arguments -s -S \
  '-k[kill/stop containers instead of starting them]' \
  '-L[list containers that would be affected]' \
  '-r[reboot containers]' \
  '-s[shutdown containers]' \
  '-a[ignore lxc.group and select all auto-started containers]' \
  '-A[also start containers not having autostart set]' \
  '(-g --groups)'{-g,--groups=}'[start only containers in specified groups]:groups (comma-separated):' \
  '(-t --timeout)'{-t,--timeout=}'[timeout in seconds for shutdown]:timeout (seconds):' \
  '(-l --logfile)'{-l,--logfile=}'[log file]:log file:_files' \
  '(-o --logpriority)'{-o,--logpriority=}'[log priority level]:priority:(FATAL CRIT ALERT ERROR WARN NOTICE INFO DEBUG TRACE)' \
  '(-n --name)'{-n,--name=}'[container name]:container name:' \
  '(-P --lxcpath)'{-P,--lxcpath=}'[path to LXC container directory]:lxc path:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[be quiet]'
