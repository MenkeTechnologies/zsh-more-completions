#compdef sfin
# Documentation: http://www.ahay.org/RSF/sfin.html
# Source: ahay/src system/main/in.c — print info about a Madagascar RSF file.
# Reference accessed: 2026-06-10
#
# Madagascar params are key=value on the command line.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'info=[(y/n) display info, n = only show data file name]: :(y n)' \
    'check=[Mb of data to check for zero values (default 2.0)]: :_default' \
    'trail=[(y/n) skip trailing dimensions of one]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
