#compdef ipptransform
# Documentation: https://manpages.debian.org/ipptransform
# Source: OpenPrinting/libcups tools/ipptransform.c — transform documents to/from PWG raster (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '-d+[output device URI]:uri:_default' \
    '-f+[output filename]:file:_files' \
    '-i+[input format]:format:(application/pdf image/jpeg image/png image/pwg-raster image/urf text/plain)' \
    '-m+[output format]:format:(application/PCLm application/pdf application/postscript image/jpeg image/pwg-raster image/urf)' \
    '*-o+[option NAME=VALUE]:name=value:_default' \
    '-r+[pwg-raster-document-resolution-supported]:resolution:_default' \
    '-s+[pwg-raster-document-sheet-back]:back:(normal flipped manual-tumble rotated)' \
    '-t+[pwg-raster-document-type-supported]:type:_default' \
    '*-v[verbose output (stackable)]' \
    '*:input file:_files' \
    && ret=0

return ret
