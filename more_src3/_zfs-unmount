#compdef zfs-unmount
# _zfs-unmount — OpenZFS zfs unmount unmount a dataset CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-unmount() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-a[unmount all]' \
        '-f[force unmount]' \
        '-u[unload key after unmount]' \
        '*:filesystem or mountpoint:'
}

_zfs-unmount "$@"
