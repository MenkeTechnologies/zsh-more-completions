#compdef smtpctl
# Documentation: https://man.openbsd.org/smtpctl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# smtpctl: control the OpenSMTPD daemon
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'discover:discover envelope or message on disk'
  'encrypt:encrypt a password string'
  'log:set log level (brief|verbose)'
  'monitor:monitor smtpd'
  'pause:pause envelope|mda|mta|smtp'
  'profile:enable profiling for subsystem'
  'remove:remove envelope or message'
  'resume:resume envelope|mda|mta|route|smtp'
  'schedule:reschedule envelope or message'
  'show:show envelope|hosts|hoststats|message|queue|relays|routes|stats|status'
  'spf:spf walk (test SPF)'
  'trace:trace subsystem'
  'unprofile:disable profiling for subsystem'
  'untrace:untrace subsystem'
  'update:update table'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'smtpctl command' commands && ret=0 ;;
  args)
    case $line[1] in
      (show)
        _values 'show subcommand' envelope hosts hoststats message queue relays routes stats status && ret=0
        ;;
      (pause)
        _values 'pause target' envelope mda mta smtp && ret=0
        ;;
      (resume)
        _values 'resume target' envelope mda mta route smtp && ret=0
        ;;
      (log)
        _values 'log level' brief verbose && ret=0
        ;;
      (spf)
        _values 'spf subcommand' walk && ret=0
        ;;
      (update)
        _values 'update subcommand' table && ret=0
        ;;
    esac
    ;;
esac
return ret
