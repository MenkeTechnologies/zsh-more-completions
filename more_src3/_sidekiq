#compdef sidekiq
# Documentation: https://github.com/sidekiq/sidekiq/blob/main/lib/sidekiq/cli.rb
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Sidekiq CLI flags taken from OptionParser block in lib/sidekiq/cli.rb.
# Removed: -d/--daemon, -L/--logfile, -P/--pidfile (not in upstream
# OptionParser; daemon/pidfile/logfile support was removed in
# Sidekiq 6.0+ — these are init-system responsibilities now).

local -a arguments

arguments=(
  '(-c --concurrency)'{-c,--concurrency}'=[number of processor threads]:threads:'
  '(-e --environment)'{-e,--environment}'=[application environment]:environment:(development test staging production)'
  '(-g --tag)'{-g,--tag}'=[process tag for procline]:tag:'
  '(-q --queue)'{-q,--queue}'=[queues to process (can be specified multiple times)]:queue:'
  '(-r --require)'{-r,--require}'=[location of Rails app or file to require]:file:_files'
  '(-t --timeout)'{-t,--timeout}'=[shutdown timeout in seconds]:seconds:'
  '(-v --verbose)'{-v,--verbose}'[verbose output]'
  '(-C --config)'{-C,--config}'=[path to YAML config file]:file:_files -g "*.yml"'
  '(-V --version)'{-V,--version}'[show version]'
  '(-h --help)'{-h,--help}'[show help message]'
)

_arguments -s -S $arguments
