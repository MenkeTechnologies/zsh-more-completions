#compdef kafka-log-dirs
# Documentation: https://kafka.apache.org/documentation/ (kafka-log-dirs.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[REQUIRED: the server(s) to use for bootstrapping]:host\:port:'
    '--broker-list[The list of brokers to be queried in the form "0,1,2"]:broker-ids:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--describe[Describe the specified log directories on the specified brokers]'
    '--help[Print usage information]'
    '--topic-list[The list of topics to be queried in the form "topic1,topic2,topic3"]:topics:'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
