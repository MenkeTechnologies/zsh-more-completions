#compdef tesla_auth
# ============================================================================
# _tesla_auth — zsh completion for adriankumpf/tesla_auth, "securely
#                generate API tokens for third-party access to your Tesla"
#                (Rust=149 leader bump OPENING Axis 94 OAuth2 /
#                ramosbugs/oauth2-rs)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/adriankumpf/tesla_auth
#   Maintainer : Adrian Kumpf
#   License    : MIT
#   Stars      : 557
#   Language   : Rust
#   Crate      : tesla_auth  (Cargo.toml [package] name =
#                              "tesla_auth", version 0.13.0)
#   Binary     : tesla_auth
#   Last push  : 2026-04-30
#
# WHAT IT IS
#   tesla_auth is "a Tesla API token generator" — a tiny Rust
#   GUI that hosts an embedded WebView (via wry / tao) pointed
#   at Tesla's identity-provider OAuth2 endpoint, captures the
#   `tesla://auth/callback` redirect URI on success, exchanges
#   the authorization code for an access + refresh token pair
#   via PKCE, and prints the tokens to stdout for use with
#   third-party Tesla integrations (TeslaMate, TeslaFi, TeslaCam
#   uploader, etc.).  The whole flow runs locally — no
#   credentials ever leave the user's machine — and uses the
#   canonical `oauth2 ^5.0` Rust crate to implement RFC 6749
#   Authorization Code + RFC 7636 PKCE.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs `struct
#                       Args` — argh-derive)
#   tesla_auth [OPTIONS]
#
#   Options:
#     -d, --debug                    Print debug output
#     -c, --clear-browsing-data      Clear browsing data at
#                                    startup (forces a fresh
#                                    Tesla login)
#
#   Standard argh auto-flags:
#     --help                         Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `oauth2 = { version = "5.0.0",
#   features = ["reqwest-blocking"] }` declared in Cargo.toml —
#   `oauth2` is THE canonical Rust OAuth2 client library
#   maintained by ramosbugs (ramosbugs/oauth2-rs, 1K+ stars,
#   used by every major Rust OAuth2 / OIDC consumer — Spot,
#   Lapdev, openidconnect-rs, byokey, BYOKEY, grok-cli, Tesla
#   Auth, etc.).  oauth2-rs is the Rust counterpart of
#   simple-oauth2 / Authlib / google-oauth2:  it implements
#   RFC 6749 (the OAuth 2.0 authorization framework), RFC 7636
#   (PKCE), RFC 8693 (token exchange), RFC 8628 (device-code
#   grant), and RFC 7009 (token revocation).  It exposes the
#   typed `BasicClient` builder configured with `ClientId` /
#   `ClientSecret` / `AuthUrl` / `TokenUrl` / `RedirectUrl` /
#   `RevocationUrl` / `IntrospectionUrl` / `DeviceAuthorization
#   Url`, the typed `AuthorizationRequest` / `TokenRequest` /
#   `DeviceCodeRequest` / `RefreshTokenRequest` /
#   `PasswordRequest` / `ClientCredentialsRequest` flow
#   builders with chainable `add_scope` / `set_pkce_challenge`
#   / `add_extra_param`, the `BasicToken Response` / `Token
#   Response` typed payload accessors (access_token,
#   refresh_token, expires_in, scopes, token_type), and the
#   pluggable HTTP transport (`reqwest::Client`,
#   `reqwest::blocking::Client`, ureq, curl).  tesla_auth's
#   `src/auth.rs` constructs an `oauth2::basic::BasicClient`
#   pointed at Tesla's identity endpoint, runs the PKCE
#   authorization-code flow inside the embedded WebView, and
#   exchanges the captured code for `BasicTokenResponse` via
#   `client.exchange_code(code).request(http_client)`.
#   Verified via:
#     gh api repos/adriankumpf/tesla_auth/contents/Cargo.toml
#       → oauth2 = { version = "5.0.0", features =
#           ["reqwest-blocking"] }
#       → [package] name = "tesla_auth"; license = "MIT"
#       → keywords = ["tesla-api", "oauth2", "webview", "cli"]
#     gh api repos/adriankumpf/tesla_auth/contents/src/main.rs
#       → use oauth2::url::Url;
#       → #[derive(argh::FromArgs)] struct Args { debug,
#                                                  clear_
#                                                  browsing_
#                                                  data }
#   This entry is the Rust=149 leader bump that OPENS Axis 94
#   (OAuth2 / ramosbugs/oauth2-rs) at 1/0/0.  Pairing Go and
#   TS-Node bumps will follow at R966 and R967 (Go=149
#   candidates golang.org/x/oauth2-based CLIs; TS-Node=149
#   candidates simple-oauth2 / openid-client users).
#
#   No completion for `tesla_auth` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_tesla_auth() {
    _arguments -s \
        '(- *)--help[show help]' \
        '(-d --debug)'{-d,--debug}'[print debug output]' \
        '(-c --clear-browsing-data)'{-c,--clear-browsing-data}'[clear browsing data at startup]'
}

_tesla_auth "$@"
