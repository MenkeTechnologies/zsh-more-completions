#compdef lasinfo
# Zsh completion for lasinfo - display info about LAS/LAZ files
# https://github.com/LAStools/LAStools

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  {-i,--input=}'[specify input LAS/LAZ file]:input file:_files' \
  '--no-check[skip checking for errors]' \
  '--no-vlrs[do not print variable length records]' \
  '--no-min-max[do not compute min/max for each field]' \
  '--repair[repair header and exit]' \
  '--repair_bb[repair bounding box in header]' \
  '--repair_counters[repair point counters in header]' \
  '--set_file_source_ID=[set file source ID]:file source ID:' \
  '--set_global_encoding=[set global encoding]:global encoding:' \
  '--set_GUID=[set project GUID]:GUID:' \
  '--set_system_identifier=[set system identifier]:system identifier:' \
  '--set_generating_software=[set generating software]:generating software:' \
  '--set_creation_day=[set file creation day of year]:day of year:' \
  '--set_creation_year=[set file creation year]:year:' \
  '--set_version=[set LAS version]:version (major.minor):' \
  '--set_header_size=[set header size]:header size:' \
  '--set_offset_to_point_data=[set offset to point data]:offset:' \
  '--set_number_of_variable_length_records=[set number of VLRs]:number:' \
  '--set_point_data_format=[set point data format]:format:' \
  '--set_point_data_record_length=[set point data record length]:length:' \
  '--set_number_of_point_records=[set number of point records]:number:' \
  '--set_scale=[set scale factors (X Y Z)]:scale X Y Z:' \
  '--set_offset=[set offset values (X Y Z)]:offset X Y Z:' \
  '--set_bounding_box=[set bounding box (minX minY minZ maxX maxY maxZ)]:bounding box:' \
  '*:file:_files'
