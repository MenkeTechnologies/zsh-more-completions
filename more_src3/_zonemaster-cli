#compdef zonemaster-cli
# Documentation: https://github.com/zonemaster/zonemaster-cli (lib/Zonemaster/CLI.pm GetOptionsFromArray)
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,--usage,-?}'[show help]' \
  '(- *)--version[show version]' \
  '*--test=[run a specific test (e.g. Connectivity/connectivity03)]:test:' \
  '--list-tests[list all available test cases]' \
  '--list_tests[list all available test cases]' \
  '--level=[minimum reporting severity]:level:(DEBUG3 DEBUG2 DEBUG INFO NOTICE WARNING ERROR CRITICAL)' \
  '--locale=[locale for output language]:locale:' \
  '--show-module[show module name in output]' \
  '--show_module[show module name in output]' \
  '--show-testcase[show test case name in output]' \
  '--show_testcase[show test case name in output]' \
  '--show-level[display severity in output]' \
  '--show_level[display severity in output]' \
  '--time[print timestamps]' \
  '--no-time[do not print timestamps]' \
  '--elapsed[show total elapsed test duration]' \
  '--count[display message counts]' \
  '--nstimes[report nameserver response metrics]' \
  '--ipv4[only test using IPv4]' \
  '--ipv6[only test using IPv6]' \
  '--no-ipv4[disable IPv4]' \
  '--no-ipv6[disable IPv6]' \
  '*--ns=[nameserver for undelegated test (name/IP)]:ns:' \
  '*--ds=[DS record for undelegated test]:ds:' \
  '--profile=[profile JSON file]:file:_files -g "*.json"' \
  '--dump-profile[output the effective profile]' \
  '--dump_profile[output the effective profile]' \
  '--save=[save session DNS data to file]:file:_files' \
  '--restore=[restore session DNS data from file]:file:_files' \
  '--hints=[load root hints from file]:file:_files' \
  '--sourceaddr4=[IPv4 source address]:address:' \
  '--sourceaddr6=[IPv6 source address]:address:' \
  '--stop-level=[halt testing at specified severity]:level:(DEBUG3 DEBUG2 DEBUG INFO NOTICE WARNING ERROR CRITICAL)' \
  '--stop_level=[halt testing at specified severity]:level:(DEBUG3 DEBUG2 DEBUG INFO NOTICE WARNING ERROR CRITICAL)' \
  '--json[structured JSON output]' \
  '--no-json[disable JSON output]' \
  '--json-stream[streaming JSON results]' \
  '--json_stream[streaming JSON results]' \
  '--raw[output untranslated message tags]' \
  '--progress[show progress activity indicator]' \
  '--no-progress[hide progress indicator]' \
  '*::domain:' && ret=0

return ret
