#compdef wx-config-3.3
# Documentation: https://github.com/wxWidgets/wxWidgets/blob/master/wx-config.in
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Configuration selection flags: --prefix[=DIR], --exec-prefix[=DIR],
# --host=HOST, --toolkit=TOOLKIT, --universal[=yes|no], --unicode[=yes|no],
# --static[=yes|no], --debug[=yes|no], --version[=VERSION], --flavour=FLAVOUR.
# Information flags: --list, --selected-config, --release, --version-full,
# --basename.
# Compilation flags: --cppflags, --cxxflags, --cflags, --cc, --cxx, --ld.
# Linking flags: --libs, --optional-libs, --linkdeps, --gl_libs, --rescomp.
# Removed --utility (not in wx-config.in upstream).
# Added --gl_libs (OpenGL link flags) per upstream.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--release[show release version]' \
  '--version-full[show full version]' \
  '--list[list available configurations]' \
  '--selected-config[show name of current config]' \
  '--host=[host triplet]:host:' \
  '--toolkit=[toolkit]:toolkit:(gtk2 gtk3 gtk4 osx_cocoa qt msw)' \
  '--universal=-[universal build]:flag:(yes no)' \
  '--unicode=-[unicode build]:flag:(yes no)' \
  '--static=-[static linkage]:flag:(yes no)' \
  '--debug=-[debug build]:flag:(yes no)' \
  '--version=-[wxWidgets version]:version:' \
  '--flavour=[build flavour]:flavour:' \
  '--basename[print library basename]' \
  '--cc[print C compiler]' \
  '--cxx[print C++ compiler]' \
  '--cppflags[print preprocessor flags]' \
  '--cxxflags[print C++ flags]' \
  '--cflags[print C compiler flags]' \
  '--rescomp[print resource compiler]' \
  '--linkdeps[print only static libraries for makefile rules]' \
  '--ld[print linker command]' \
  '--libs[print linker flags for libs]' \
  '--optional-libs[print linker flags for optional libs]' \
  '--gl_libs[print linker flags for OpenGL libs]' \
  '*:library:(xrc webview stc richtext ribbon propgrid aui gl html qa adv core xml net base std all)' && ret=0

return ret
