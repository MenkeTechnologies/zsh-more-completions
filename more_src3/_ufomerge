#compdef ufomerge
# _ufomerge — Simon Cozens ufomerge CLI for subsetting and merging UFO source fonts copying glyphs anchors components composites kerning groups OpenType feature snippets across UFO masters (simoncozens team, Python); argparse
# upstream: https://github.com/simoncozens/ufomerge

_ufomerge() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output ufo]:file:_files -g "*.ufo *.ufoz"' \
        '--output=+[output ufo]:file:_files -g "*.ufo *.ufoz"' \
        '-g+[csv glyph names]:str:' \
        '--glyphs=+[csv glyph names]:str:' \
        '-G+[file]:file:_files' \
        '--glyphs-file=+[file]:file:_files' \
        '-e+[csv glyphs to exclude]:str:' \
        '--exclude=+[csv glyphs to exclude]:str:' \
        '-k+[N kerning factor]:f:' \
        '--kern-scale=+[F]:f:' \
        '--existing-handling=+[h]:h:(skip replace combine)' \
        '--layout-handling=+[h]:h:(subset full skip)' \
        '--decompose=+[mode]:m:(none mixed all)' \
        '--ignore-aliases[ignore aliases]' \
        '--no-replace-existing[no replace existing]' \
        '--codepoints=+[csv unicode hex]:str:' \
        '--unicodes=+[csv unicode hex ranges]:str:' \
        '*:UFO masters:_files -g "*.ufo *.ufoz"'
}

_ufomerge "$@"
