#compdef tempo-query
# _tempo-query — Grafana Tempo Jaeger-storage gRPC plugin (grafana/tempo)
# upstream: https://github.com/grafana/tempo
# Flag from cmd/tempo-query/main.go on tip.

_tempo-query() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[plugin configuration YAML file]:file:_files -g "*.(yml|yaml)(-.)"'
}

_tempo-query "$@"
