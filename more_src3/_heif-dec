#compdef heif-dec
# Documentation: heif-dec --help (libheif 1.23.0)
# Source: HEIF/AVIF decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-q --quality)'{-q+,--quality=}'[JPEG output quality]:q:' \
    '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
    '(-d --decoder)'{-d+,--decoder=}'[decoder ID]:id:' \
    '--with-aux[also write auxiliary images]' \
    '--with-xmp[write XMP metadata to .xmp file]' \
    '--with-exif[write EXIF metadata to .exif file]' \
    '--skip-exif-offset[skip EXIF metadata offset bytes]' \
    '--no-colons[replace : in aux filenames with _]' \
    '--list-decoders[list available decoders]' \
    '--tiles[output all image tiles as separate images]' \
    '--quiet[suppress status messages]' \
    '(-S --sequence)'{-S,--sequence}'[decode image sequence]' \
    '--ignore-editlist[show raw sequence timeline]' \
    '(-C --chroma-upsampling)'{-C+,--chroma-upsampling=}'[chroma upsampling algo]:algo:(nn bilinear)' \
    '--png-compression-level=[PNG compression 0..9 (-1 default)]:level:' \
    '--transparency-composition-mode=[transparent-image render mode]:mode:(white black checkerboard)' \
    '--disable-limits[disable all security limits (dev only)]' \
    '--auto-correct[work around broken-input quirks]' \
    '--codec-threads=[codec plugin threads (0 default)]:n:' \
    '--tile-threads=[parallel tile decode (default 4)]:n:' \
    '--extract-mime-item=[extract MIME item by content type]:mime type:' \
    '1:input heif:_files -g "*.(heic|heif|avif)"' \
    '2:output image:_files' \
    && ret=0

return ret
