#compdef trimAl trimal
# _trimal — Salvador Capella-Gutiérrez trimAl CLI multiple sequence alignment trimming program for protein DNA RNA columns removing gappy regions ambiguously aligned positions using gappyout strict strictplus automated1 nogaps noallgaps similarity score column-overlap statistics modes (Salvador Capella-Gutierrez team, C++); getopt
# upstream: http://trimal.cgenomics.org/

_trimal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-in+[input alignment]:file:_files -g "*.fa *.fasta *.aln *.phy *.nex *.clu"' \
        '-out+[output alignment]:file:_files' \
        '-htmlout+[HTML output]:file:_files -g "*.html"' \
        '-svgout+[SVG output]:file:_files -g "*.svg"' \
        '-fasta[output FASTA]' \
        '-clustal[output CLUSTAL]' \
        '-phylip[output PHYLIP]' \
        '-phylip3.2[output PHYLIP 3.2]' \
        '-phylip_paml[output PHYLIP for PAML]' \
        '-nexus[output NEXUS]' \
        '-mega[output MEGA]' \
        '-gt+[threshold]:n:' \
        '-st+[similarity threshold]:n:' \
        '-ct+[consistency threshold]:n:' \
        '-cons+[consensus]:n:' \
        '-gappyout[gappy out mode]' \
        '-strict[strict mode]' \
        '-strictplus[strict plus mode]' \
        '-automated1[automated mode]' \
        '-nogaps[remove all gap columns]' \
        '-noallgaps[remove all-gap columns]' \
        '-keepheader[keep original header]' \
        '-keepseqs[keep all sequences]' \
        '-w+[window size]:n:' \
        '-gw+[gap window size]:n:' \
        '-sw+[similarity window]:n:' \
        '-cw+[consistency window]:n:' \
        '-resoverlap+[N]:n:' \
        '-seqoverlap+[N]:n:' \
        '-w_score+[N]:n:' \
        '-block+[N]:n:' \
        '-matrix+[file]:file:_files' \
        '-sgc[per-column gap stats]' \
        '-sgt[total gap stats]' \
        '-scc[per-column similarity stats]' \
        '-sct[total similarity stats]' \
        '-sfc[per-column score stats]' \
        '-sft[total score stats]' \
        '-sident[per-column identity stats]' \
        '*::'
}

_trimal "$@"
