#compdef tfmigrate
# Documentation: https://github.com/minamijoyo/tfmigrate
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      plan:'compute new state in temporary state'
      apply:'compute new state and push to remote state'
      list:'list migrations'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    case $line[1] in
      (plan)
        _arguments \
          '--config=[path to tfmigrate config file]:file:_files' \
          '*--backend-config=[backend configuration]:config' \
          '--out=[save plan file to path]:file:_files' \
          '*:migration file:_files' && ret=0
        ;;
      (apply)
        _arguments \
          '--config=[path to tfmigrate config file]:file:_files' \
          '*--backend-config=[backend configuration]:config' \
          '*:migration file:_files' && ret=0
        ;;
      (list)
        _arguments \
          '--config=[path to tfmigrate config file]:file:_files' \
          '--status=[filter by migration status]:status:(all unapplied)' && ret=0
        ;;
    esac
    ;;
esac

return ret
