#compdef xleak
# Documentation: https://github.com/bgreenwell/xleak
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# xleak: terminal Excel viewer (Rust + ratatui)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-i --interactive)'{-i,--interactive}'[launch interactive TUI viewer]' \
  '--sheet=[sheet name or 1-based index]:sheet:' \
  '-n+[limit displayed rows (0 = all)]:rows:' \
  '(-w --width)'{-w,--width}'+[maximum column width in chars]:chars:' \
  '-H[enable horizontal scrolling for wide files]' \
  '--formulas[display formulas by default]' \
  '--config=[path to custom config file]:file:_files' \
  '--export=[export format]:format:(csv json text)' \
  '--list-tables[list all Excel tables in the workbook]' \
  '--table=[extract specific named table]:table name:' \
  '*:spreadsheet:_files -g "*.(xlsx|xls|xlsm|xlsb|ods)"' && ret=0

return ret
