#compdef jmeter
# Documentation: https://jmeter.apache.org/usermanual/get-started.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Apache JMeter command-line options. Corrected from prior file:
# -? prints the command line options (not "show help"); -i is the
# logging config file (log4j2.xml), not jmeter.log; removed the
# duplicate invented -X[exit on error]; added -p (propfile) and
# -g (reportonly).
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show usage information]' \
  '-?[print command line options]' \
  '-v[show version information]' \
  '-n[run in CLI (non-GUI) mode]' \
  '-t+[test plan file]:file:_files -g "*.jmx"' \
  '-l+[log sample results to file]:file:_files -g "*.jtl"' \
  '-j+[JMeter run log file]:file:_files' \
  '-i+[logging configuration file (log4j2.xml)]:file:_files' \
  '-r[start remote servers from remote_hosts]' \
  '-R+[remote servers to start]:list:' \
  '-X[exit remote servers at end of test]' \
  '-H+[proxy server hostname or ip]:host:_hosts' \
  '-P+[proxy server port]:port:' \
  '-N+[non-proxy host list]:list:' \
  '-u+[proxy authentication username]:user:_users' \
  '-a+[proxy authentication password]:password:' \
  '-J+[define a JMeter property]:k=v:' \
  '-G+[define a global property]:k=v:' \
  '-D+[define a Java system property]:k=v:' \
  '-S+[additional system property file]:file:_files -g "*.properties"' \
  '-q+[additional JMeter property file]:file:_files -g "*.properties"' \
  '-p+[JMeter property file]:file:_files -g "*.properties"' \
  '-d+[JMeter home directory]:dir:_files -/' \
  '-L+[set the logging level (category=level)]:level:' \
  '-s[run the JMeter server]' \
  '-e[generate report dashboard after load test]' \
  '-o+[output folder for the report dashboard]:dir:_files -/' \
  '-g+[generate report dashboard only, from results file]:file:_files -g "*.jtl"' \
  '-f[force delete of existing results file/dir]' \
  '-Z+[server engine port]:port:' \
  '*: :_files' && ret=0

return ret
