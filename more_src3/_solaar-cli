#compdef solaar-cli
# _solaar-cli — Solaar Logitech Unifying receiver/Bolt receiver/devices manager CLI alias (pwr-Solaar, Python); argparse
# upstream: https://github.com/pwr-Solaar/Solaar

_solaar-cli() {
    local -a sub=(
        'show:show devices'
        'config:read/write device config'
        'pair:start pairing'
        'unpair:unpair device'
        'probe:probe receivers/devices'
        'cleanup:cleanup state'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--bus-id=+[hidraw bus id]:str:' \
        '--profile=+[profile]:str:' \
        '--restart-on-wake-up[restart on wake up]' \
        '--battery-icons=+[battery icons style]:s:(regular symbolic solaar)' \
        '--tray-icon-size=+[tray icon size]:n:' \
        '--window=+[window mode]:m:(show hide only)' \
        '--ipc-server[start ipc server]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'solaar subcommand' sub ;;
        args)
            case $words[1] in
                show) _arguments '*:device:' ;;
                config) _arguments \
                    '1:device:' \
                    '*:key-value:' ;;
                pair) _arguments \
                    '*:receiver:' ;;
                unpair) _arguments \
                    '1:device:' ;;
                probe) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_solaar-cli "$@"
