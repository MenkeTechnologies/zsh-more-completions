_xlsx() {
    _arguments \
        '(-f --file)'{-f+,--file=}'[use specified workbook (input)]:file:_files -g "*.(xlsx|xls|xlsb|xlsm|xlml|ods|csv|txt|dif|sylk|html|dbf)"' \
        '(-s --sheet)'{-s+,--sheet=}'[print specific sheet (name or 1-indexed)]:sheet:' \
        '(-L --listSheets --list-sheets)'{-L,--listSheets,--list-sheets}'[list sheet names in workbook]' \
        '(-t --type)'{-t+,--type=}'[output format]:type:(csv txt html json formulae)' \
        '(-b --book)'{-b+,--book=}'[output workbook format]:book:(xlsx xlsm xlsb xls xlml ods fods csv txt html dif sylk prn dbf eth)' \
        '(-o --output)'{-o+,--output=}'[write output to specified file]:file:_files' \
        '--read-only[read-only mode (skip writing)]' \
        '--all[read all sheets (default first only)]' \
        '--pretty[pretty-print JSON output]' \
        '--quiet[suppress console output except errors]' \
        '(- *)'{-h,--help}'[output usage information]' \
        '(- *)'{-v,--version}'[output version number]' \
        '*:workbook file:_files -g "*.(xlsx|xls|xlsb|xlsm|xlml|ods|csv|txt|dif|sylk|html|dbf)"'
}

_xlsx "$@"
