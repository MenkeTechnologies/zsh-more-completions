#compdef logtail
# Documentation: https://manpages.debian.org/bookworm/logcheck/logtail.8.en.html
# Reference accessed: 2026-05-17
# Verified: Debian bookworm logcheck logtail(8) manpage. This is the
# Debian logcheck logtail (offset-tracking log tail). No connection to
# Better Stack's logtail, vogo/logtail, or bingoohuang/logtail.
# Removed from prior file: bogus man.archlinux.org search URL.

# logtail: Debian logcheck offset-tracking log tail
local curcontext="$curcontext" ret=1
_arguments -C \
  '-f[logfile to read/follow]:logfile:_files' \
  '-o[offset file]:offsetfile:_files' \
  '-t[test mode (do not update offset)]' \
  '*:logfile:_files' && ret=0
return ret
