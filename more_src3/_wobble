#compdef wobble
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/wobble.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS 6.6 wobble docs at the URL above.

# EMBOSS wobble: plot third-base GC composition along a sequence
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write to stdout]' \
  '-filter[stdin/stdout]' '-options[prompt for additional qualifiers]' \
  '-debug[debug log]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[die]' '-version[version]' \
  '-outfile=[output file]:file:_files' \
  '-sequence=[DNA sequence(s)]:file:_files' \
  '-window=[window size in codons (default 30)]:size' \
  '-bases=[bases to count (default GC)]:bases' \
  '-graph=[graph output device]:fmt:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data tek tekt none)' \
  '*:DNA sequence:_files' && ret=0

return ret
