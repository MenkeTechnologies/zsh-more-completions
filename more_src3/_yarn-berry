#compdef yarn-berry
# _yarn-berry — Yarn v2+ (Berry) modern package manager (Maël Nison/Yarn team); PnP, zero-installs, workspaces, plugins
# upstream: https://github.com/yarnpkg/berry

_yarn-berry() {
    local -a sub=(
        'add:add a dependency'
        'remove:remove a dependency'
        'install:install all dependencies'
        'up:upgrade dependency'
        'dedupe:dedupe lockfile'
        'cache:cache subcommands'
        'config:get/set config'
        'create:create scaffold'
        'dlx:run a remote package'
        'exec:run a package script'
        'init:create new package'
        'info:print package info'
        'link:link package globally'
        'unlink:unlink package'
        'node:run node in PnP context'
        'npm:npm subcommands'
        'pack:create tarball'
        'patch:create patch'
        'patch-commit:commit patch'
        'rebuild:rebuild native modules'
        'remove:remove dependency'
        'run:run script'
        'set:configure'
        'stage:stage workspace'
        'unplug:unplug package'
        'version:bump version'
        'why:explain why package is installed'
        'workspace:run command in workspace'
        'workspaces:manage workspaces'
        'plugin:plugin manager'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--cwd+[cwd]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yarn-berry subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|up) _arguments \
                    '(-D --dev)'{-D,--dev}'[devDependency]' \
                    '(-P --peer)'{-P,--peer}'[peerDependency]' \
                    '(-O --optional)'{-O,--optional}'[optionalDependency]' \
                    '(-E --exact)'{-E,--exact}'[exact version]' \
                    '(-T --tilde)'{-T,--tilde}'[tilde range]' \
                    '(-C --caret)'{-C,--caret}'[caret range]' \
                    '--mode+[mode]:mode:(update-lockfile skip-build)' \
                    '*:package:' ;;
                install) _arguments \
                    '--immutable[fail on lockfile change]' \
                    '--immutable-cache[fail on cache change]' \
                    '--check-cache[redownload cache]' \
                    '--check-resolutions[verify resolutions]' \
                    '--inline-builds[print build output]' \
                    '--mode+[mode]:mode:(update-lockfile skip-build)' \
                    '--refresh-lockfile[refresh lockfile]' ;;
                workspace) _arguments \
                    '1:workspace:' \
                    '*:cmd:' ;;
                workspaces) _arguments '1:workspaces cmd:(foreach focus list)' '*:args:' ;;
                plugin) _arguments '1:plugin cmd:(import list remove runtime)' '*:args:' ;;
                config) _arguments '1:config cmd:(get set unset)' '*:args:' ;;
                cache) _arguments '1:cache cmd:(clean clear)' ;;
            esac
            ;;
    esac
}

_yarn-berry "$@"
