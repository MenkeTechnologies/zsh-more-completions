#compdef sof_ri_info
# _sof_ri_info — parse / inspect SOF .ri firmware binaries (thesofproject/sof)
# upstream: https://github.com/thesofproject/sof
# Flags from tools/sof_ri_info/sof_ri_info.py (argparse).

_sof_ri_info() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--headers[display headers only]'
        '--full_bytes[display full byte arrays]'
        '--no_colors[disable colored output]'
        '--no_cse[skip CSE manifest parsing]'
        '--no_headers[skip information about headers]'
        '--no_modules[skip information about modules]'
        '--no_memory[skip information about memory]'
        '--erase_vars=[write a constant-stripped copy to this path]:file:_files'
        '1:firmware .ri file:_files -g "*.ri"'
    )
    _arguments -s $args
}

_sof_ri_info "$@"
