#compdef s6-rc-init
# Documentation: https://skarnet.org/software/s6-rc/s6-rc-init.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c+[compiled service database]:database directory:_files -/' \
  '-l+[live state directory]:live directory:_files -/' \
  '-t+[timeout in ms for supervisor startup]:timeout' \
  '-p+[prefix prepended to symbolic link names]:prefix' \
  '-b[blocking lock]' \
  '-d[dereference bootdb path before declaring]' \
  '1:scan directory:_files -/' && ret=0

return ret
