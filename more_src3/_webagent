# Zsh completion for webagent - smolagents web browsing agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model-type[model backend]:type:(OpenAIModel LiteLLMModel TransformersModel InferenceClientModel OpenAIServerModel)' \
  '--model-id[model ID]:model:' \
  '--provider[inference provider]:provider:' \
  '--api-base[API base URL]:url:' \
  '--api-key[API key]:key:' \
  '*:prompt:' && ret=0

return ret
