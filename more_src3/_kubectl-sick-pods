#compdef kubectl-sick-pods
# kubectl-sick-pods (krew plugin): find and display unhealthy pods
# https://github.com/alecjacobs5401/kubectl-sick-pods

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[check all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector'
