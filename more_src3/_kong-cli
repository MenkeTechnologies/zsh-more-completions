#compdef kong-cli
# _kong-cli — Kong API gateway CLI alias (Kong Inc., Lua/Go); custom argparse
# upstream: https://github.com/Kong/kong

_kong-cli() {
    local -a sub=(
        'check:check Kong config'
        'config:Kong declarative config'
        'health:check Kong health'
        'hybrid:manage Kong CP/DP'
        'migrations:run migrations'
        'prepare:prepare Kong prefix'
        'quit:gracefully quit Kong'
        'reload:reload config without downtime'
        'restart:restart Kong'
        'roar:print version banner'
        'runner:run plugin development server'
        'start:start Kong'
        'stop:stop Kong'
        'vault:retrieve a vault value'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--conf=+[config file]:file:_files -g "*.conf"' \
        '-p+[prefix dir]:dir:_files -/' \
        '--prefix=+[prefix dir]:dir:_files -/' \
        '-v[verbose]' \
        '--vv[debug]' \
        '--vvv[trace]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kong subcommand' sub ;;
        args)
            case $words[1] in
                start|restart|reload|stop|quit|prepare|health|check|roar) _arguments \
                    '--nginx-conf=+[nginx conf]:file:_files' \
                    '--run-migrations[run migrations]' ;;
                migrations) _arguments \
                    '1:cmd:(bootstrap finish list off reset status up)' \
                    '--force[force]' \
                    '-f[force]' \
                    '--yes[yes]' \
                    '-y[yes]' \
                    '--db-timeout=+[db timeout]:n:' \
                    '--lock-timeout=+[lock timeout]:n:' ;;
                config) _arguments \
                    '1:cmd:(db_export db_import init parse)' \
                    '*:arg:' ;;
                hybrid) _arguments \
                    '1:cmd:(gen_cert)' \
                    '*:arg:' ;;
                vault) _arguments \
                    '1:cmd:(get)' \
                    '*:arg:' ;;
                runner) _arguments \
                    '--plugins-directory=+[plugins dir]:dir:_files -/' \
                    '--plugins-listen=+[plugins listen]:str:' ;;
            esac
            ;;
    esac
}

_kong-cli "$@"
