#compdef v4lctl
# Documentation: https://manpages.debian.org/bookworm/xawtv/v4lctl.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'show:show current state'
  'setattr:set attribute'
  'setnorm:set norm'
  'setinput:set input'
  'setfreqtab:set frequency table'
  'setchannel:set channel'
  'setstation:set station'
  'capture:turn capture on/off/overlay/grabdisplay'
  'snap:take snapshot'
  'webcam:upload snapshots to webcam'
  'movie:record movie'
  'fullscreen:toggle fullscreen mode'
  'showtime:show time'
  'msg:display message'
  'vtx:display teletext page'
  'quit:exit application'
  'keypad:numeric keypad'
  'vdr:vdr-style command'
  'volume:set volume'
  'color:set color'
  'hue:set hue'
  'bright:set brightness'
  'contrast:set contrast'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-v+[debug level 0-2]:level:(0 1 2)' \
  '-c+[video4linux device]:device:_files -g "/dev/video*"' \
  '-D+[video4linux driver]:driver:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'v4lctl command' commands && ret=0 ;;
esac

return ret
