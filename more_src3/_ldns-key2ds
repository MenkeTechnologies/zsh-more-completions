#compdef ldns-key2ds
# _ldns-key2ds — NLnet Labs ldns-key2ds (generate DS records from a DNSKEY keyfile; writes K<name>+<alg>+<id>.ds files)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-key2ds.c usage on tip.

_ldns-key2ds() {
    _arguments \
        '-f[ignore SEP flag (DS for any key)]' \
        '-n[write DS records to stdout instead of files]' \
        '(-1 -2 -g -4)-1[use SHA1 for the DS hash]' \
        '(-1 -2 -g -4)-2[use SHA256 for the DS hash]' \
        '(-1 -2 -g -4)-g[use GOST for the DS hash]' \
        '(-1 -2 -g -4)-4[use SHA384 for the DS hash]' \
        '1:keyfile:_files'
}

_ldns-key2ds "$@"
