#compdef idn2
# Documentation: idn2 --help (libidn2)
# Source: IDNA2008 lookup / decode / register CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-l --lookup -r --register)'{-d,--decode}'[decode punycode]' \
    '(-d --decode -r --register)'{-l,--lookup}'[lookup domain (default)]' \
    '(-d --decode -l --lookup)'{-r,--register}'[register label]' \
    '(-N --tr46nt --no-tr46)'{-T,--tr46t}'[TR46 transitional processing]' \
    '(-T --tr46t --no-tr46)'{-N,--tr46nt}'[TR46 non-transitional processing]' \
    '(-T --tr46t -N --tr46nt)--no-tr46[disable TR46 processing]' \
    '--usestd3asciirules[enable STD3 ASCII rules]' \
    '--no-alabelroundtrip[disable A-label roundtrip]' \
    '--debug[print debug info]' \
    '--quiet[silent operation]' \
    '*:string:' \
    && ret=0

return ret
