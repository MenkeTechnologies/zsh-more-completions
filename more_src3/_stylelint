#compdef stylelint
# Documentation: https://stylelint.io/user-guide/usage/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for stylelint - CSS/SCSS/Less linter

_arguments \
  '(-)'{-h,--help}'[display help information]' \
  '(-)'{-v,--version}'[display version information]' \
  '(-c --config)'{-c,--config}'[specify config file]:config file:_files' \
  '--config-basedir[specify config base directory]:directory:_directories' \
  {-f,--formatter}'[specify output formatter]:formatter:(compact json string tap unix verbose github)' \
  '--custom-formatter[specify custom formatter module]:module:_files' \
  '--custom-syntax[use custom syntax parser]:module:' \
  {-q,--quiet}'[only show errors]' \
  '--quiet-deprecation-warnings[ignore deprecation warnings]' \
  '(--rdd --report-descriptionless-disables)'{--rdd,--report-descriptionless-disables}'[report disables without description]' \
  '(--risd --report-invalid-scope-disables)'{--risd,--report-invalid-scope-disables}'[report invalid scope disables]' \
  '(--rd --report-needless-disables)'{--rd,--report-needless-disables}'[report needless disables]' \
  '(--rud --report-unscoped-disables)'{--rud,--report-unscoped-disables}'[report unscoped disables]' \
  '*'{-i,--ignore-path}'[specify ignore file path]:file:_files' \
  '*'{--ip,--ignore-pattern}'[specify ignore pattern]:glob pattern' \
  '(--id --ignore-disables)'{--id,--ignore-disables}'[ignore all disable comments]' \
  '(--di --disable-default-ignores)'{--di,--disable-default-ignores}'[skip automatic node_modules ignoring]' \
  '--cache[store results to process only changed files]' \
  '--cache-location[specify cache location]:path:_files' \
  '--cache-strategy[specify cache strategy]:strategy:(metadata content)' \
  '(--mw --max-warnings)'{--mw,--max-warnings}'[set maximum number of warnings]:count' \
  '--fix[automatically fix problems]' \
  '(--aei --allow-empty-input)'{--aei,--allow-empty-input}'[allow empty input]' \
  {-o,--output-file}'[specify output file]:file:_files' \
  '--stdin[accept stdin input]' \
  '--stdin-filename[specify stdin filename]:filename' \
  '--color[force colored output]' \
  '--no-color[disable colored output]' \
  '--print-config[print the config for given file]' \
  '(--go --globbyOptions)'{--go,--globbyOptions}'[pass JSON options to globby]:json' \
  '*:file or glob:_files'
