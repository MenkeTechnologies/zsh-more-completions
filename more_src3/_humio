#compdef humio humio-cli humioctl
# _humio — Falcon LogScale (Humio) humioctl CLI (CrowdStrike Falcon LogScale team, Go); spf13/cobra
# upstream: https://github.com/humio/cli

_humio() {
    local -a sub=(
        'login:authenticate'
        'logout:logout'
        'profile:manage profiles'
        'status:show server status'
        'users:manage users'
        'roles:manage roles'
        'groups:manage groups'
        'repos:manage repositories'
        'views:manage views'
        'parsers:manage parsers'
        'actions:manage actions/alerts'
        'alerts:manage alerts'
        'scheduled-searches:manage scheduled searches'
        'aggregate-alerts:manage aggregate alerts'
        'filter-alerts:manage filter alerts'
        'dashboards:manage dashboards'
        'packages:install/list/remove packages'
        'tokens:manage tokens'
        'health:show health'
        'ingest-tokens:manage ingest tokens'
        'license:manage license'
        'cluster:cluster admin'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--address=+[humio API address]:url:_urls' \
        '-a+[humio API address]:url:_urls' \
        '--token=+[humio API token]:str:' \
        '-t+[humio API token]:str:' \
        '--insecure[skip tls verify]' \
        '--profile=+[profile]:profile:' \
        '--output=+[output format]:fmt:(table json yaml)' \
        '-o+[output format]:fmt:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'humio subcommand' sub ;;
        args)
            case $words[1] in
                users|roles|groups|repos|views|parsers|actions|alerts|scheduled-searches|aggregate-alerts|filter-alerts|dashboards|ingest-tokens|tokens) _arguments \
                    '1:cmd:(list get create update delete import export)' \
                    '--repo=+[repo]:str:' \
                    '*:arg:' ;;
                packages) _arguments \
                    '1:cmd:(list install uninstall export create)' \
                    '--repo=+[repo]:str:' \
                    '*:arg:' ;;
                cluster) _arguments \
                    '1:cmd:(nodes show)' \
                    '*:arg:' ;;
                profile) _arguments \
                    '1:cmd:(create list remove use show)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_humio "$@"
