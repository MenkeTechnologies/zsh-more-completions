#compdef ipdata
# _ipdata — ipdata.co ipdata CLI client to the ipdata.co geolocation REST API enriching IP addresses with city region country ASN organization is_anonymous is_proxy is_tor is_known_attacker threat-score privacy-feed flag VPN-residential-mobile-classification streaming time-zone (ipdata team, Python); click
# upstream: https://ipdata.co/

_ipdata() {
    local -a sub=(
        'lookup:lookup an IP'
        'bulk:bulk lookup IPs'
        'reverse:reverse hostname lookup'
        'me:lookup own IP'
        'fields:list available fields'
        'usage:show API usage'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '--fields=+[fields]:str:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ipdata subcommand' sub ;;
        args)
            case $words[1] in
                lookup|reverse) _arguments '*:ip:' ;;
                bulk) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_ipdata "$@"
