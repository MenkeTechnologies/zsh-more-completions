#compdef icontopbm
# Documentation: man icontopbm (Netpbm)
# Source: convert a Sun icon file to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:icon file:_files' \
    && ret=0

return ret
