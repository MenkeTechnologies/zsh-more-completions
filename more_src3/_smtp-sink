#compdef smtp-sink
# Documentation: man smtp-sink(1)
# Source: vdukhovni/postfix smtpstone/smtp-sink.c (master) — Postfix SMTP/LMTP sink load tester (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-4[force IPv4]' \
    '-6[force IPv6]' \
    '-8[do not advertise 8BITMIME]' \
    '-a[reject ANY HELO/EHLO]' \
    '-c[show counter every second]' \
    '-C[disable command pipelining]' \
    '-e[disable ESMTP]' \
    '-E[disable ENHANCEDSTATUSCODES]' \
    '-F[disable XFORWARD]' \
    '-L[speak LMTP instead of SMTP]' \
    '-p[disable PIPELINING]' \
    '-P[reply with success after final dot]' \
    '*-v[verbose (stackable)]' \
    '-A+[delay (ms) before client abort]:ms:_default' \
    '-b+[soft bounce reply code 4yz]:code:_default' \
    '-B+[hard bounce reply code 5yz]:code:_default' \
    '-d+[dump template (per session)]:template:_default' \
    '-D+[dump template (per message)]:template:_default' \
    '-f+[reject these commands (chars)]:chars:_default' \
    '-h+[hostname]:hostname:_hosts' \
    '-m+[max concurrent sessions]:N:_default' \
    '-M+[max messages before QUIT]:N:_default' \
    '-n+[max sessions before QUIT]:N:_default' \
    '-q+[disconnect immediately after these commands]:chars:_default' \
    '-r+[reset connection mid-command]:chars:_default' \
    '-R+[chroot to root-dir]:dir:_files -/' \
    '-s+[stutter after these commands]:chars:_default' \
    '-S+[start-of-session greeting]:string:_default' \
    '-u+[run as user]:user:_users' \
    '-w+[delay before reply (sec)]:seconds:_default' \
    '1:[host]\:port:_default' \
    '2:backlog:_default' \
    && ret=0

return ret
