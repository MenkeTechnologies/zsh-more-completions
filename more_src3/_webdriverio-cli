#compdef webdriverio-cli wdio2
# _webdriverio-cli — Christian Bromann webdriverio-cli CLI command-line frontend wrapping the WebdriverIO next-gen browser and mobile automation test framework for Node.js open-source written in TypeScript Node WebdriverIO is a next-gen test framework for Node.js OpenJS Foundation Smart Selectors Web Native Auto-wait Native Support Browser-Centric Selenium W3C WebDriver Bidi Standard Mocha Jasmine Cucumber Sauce Labs BrowserStack run config install repl install reporter service framework spec wdio.conf.js sauceLabs browserstack capabilities multiremote (Christian Bromann OpenJS Foundation team, TypeScript); commander
# upstream: https://webdriver.io/

_webdriverio-cli() {
    local -a sub=(
        'config:create wdio.conf.js'
        'install:install a service or reporter'
        'repl:run a REPL'
        'run:run tests'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--watch[watch tests]' \
        '-w[watch]' \
        '--spec=+[file]:file:_files' \
        '*--spec=+[file]:file:_files' \
        '-s+[spec]:file:_files' \
        '*-s+[spec]:file:_files' \
        '--suite=+[name]:str:' \
        '*--suite=+[name]:str:' \
        '--exclude=+[file]:file:_files' \
        '*--exclude=+[file]:file:_files' \
        '--mochaOpts=+[json]:str:' \
        '--jasmineOpts=+[json]:str:' \
        '--cucumberOpts=+[json]:str:' \
        '--logLevel=+[l]:l:(trace debug info warn error silent)' \
        '-l+[log level]:l:(trace debug info warn error silent)' \
        '--bail=+[N]:n:' \
        '--baseUrl=+[url]:str:' \
        '-b+[base URL]:str:' \
        '--waitforTimeout=+[ms]:n:' \
        '-t+[timeout]:n:' \
        '--framework=+[name]:n:(mocha jasmine cucumber)' \
        '-f+[framework]:n:(mocha jasmine cucumber)' \
        '--reporters=+[name]:str:' \
        '*--reporters=+[name]:str:' \
        '*-r+[reporter]:str:' \
        '--user=+[name]:_users' \
        '-u+[user]:_users' \
        '--key=+[key]:str:' \
        '-k+[key]:str:' \
        '--region=+[name]:str:' \
        '--coverage[enable coverage]' \
        '--repeat=+[N]:n:' \
        '--multi-run=+[N]:n:' \
        '--exit-on-failure[exit on failure]' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--path=+[path]:str:' \
        '--hostname=+[host]:_hosts' \
        '--host=+[host]:_hosts' \
        '--protocol=+[p]:p:(http https)' \
        '--browserName=+[name]:n:(chrome firefox safari edge ie opera)' \
        '--connectionRetryTimeout=+[ms]:n:' \
        '--connectionRetryCount=+[N]:n:' \
        '--injectGlobals=+[v]:v:(true false)' \
        '--shard=+[N/M]:str:' \
        '--specFileRetries=+[N]:n:' \
        '--specFileRetriesDelay=+[sec]:n:' \
        '--specFileRetriesDeferred[defer retries]' \
        '--mochaOpts.timeout=+[ms]:n:' \
        '--maxInstances=+[N]:n:' \
        '--maxInstancesPerCapability=+[N]:n:' \
        '--mochaOpts.bail[mocha bail]' \
        '--mochaOpts.grep=+[pattern]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wdio subcommand' sub ;;
        args)
            case $words[1] in
                run|repl) _arguments '*:config:_files -g "wdio.conf.* *.js *.ts"' ;;
                install) _arguments '1:type:(reporter service framework)' '*:name:' ;;
                config) _arguments '*:file:_files -g "wdio.conf.* *.js *.ts"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_webdriverio-cli "$@"
