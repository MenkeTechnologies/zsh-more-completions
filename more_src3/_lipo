#compdef lipo
# Documentation: https://www.unix.com/man-page/osx/1/lipo/
# Source: Apple macOS — universal (fat) Mach-O binary creator / splitter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a archs=(x86_64 x86_64h arm64 arm64e arm64_32 armv7 armv7s armv7k i386 ppc ppc64)

_arguments -s \
    '-info[brief list of architecture types in the universal file]' \
    '-detailed_info[detailed list of architecture types]' \
    "-arch[input_file contains the specified architecture]:arch:($archs)" \
    "-arch_blank[output for arch will be an MH_DYLIB_STUB file]:arch:($archs)" \
    '-output[output file]:file:_files' \
    '(-create -thin -extract -extract_family -remove -replace -verify_arch)-create[create one universal output from inputs]' \
    "(-create -thin -extract -extract_family -remove -replace -verify_arch)-thin[create thin output of arch]:arch:($archs)" \
    "(-create -thin -extract -extract_family -remove -replace -verify_arch)-extract[extract arch into a universal output]:arch:($archs)" \
    "(-create -thin -extract -extract_family -remove -replace -verify_arch)-extract_family[extract all archs of family]:arch:($archs)" \
    "(-create -thin -extract -extract_family -remove -replace -verify_arch)-remove[remove arch from universal file]:arch:($archs)" \
    "(-create -thin -extract -extract_family -remove -replace -verify_arch)-replace[replace arch contents with given file]:arch:($archs)" \
    "(-create -thin -extract -extract_family -remove -replace -verify_arch)-verify_arch[verify arch(s) are present]:archs:($archs)" \
    "-segalign[segment alignment for arch when creating universal]:arch:($archs)" \
    '*:input file:_files' \
    && ret=0

return ret
