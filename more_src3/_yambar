#compdef yambar
# Documentation: https://codeberg.org/dnkl/yambar/raw/branch/master/doc/yambar.1.scd
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --backend)'{-b+,--backend=}'[graphics backend]:backend:(xcb wayland auto)' \
  '(-c --config)'{-c+,--config=}'[config file]:config file:_files' \
  '(-C --validate)'{-C,--validate}'[verify config and exit]' \
  '(-p --print-pid)'{-p+,--print-pid=}'[write PID to file or FD]:file or fd:_files' \
  '(-d --log-level)'{-d+,--log-level=}'[log level]:level:(info warning error none)' \
  '(-l --log-colorize)'{-l+,--log-colorize=}'[log colorize mode]:mode:(never always auto)' \
  '(-s --log-no-syslog)'{-s,--log-no-syslog}'[disable syslog]' && ret=0

return ret
