#compdef kubeless
# _kubeless — kubeless project kubeless CLI command-line frontend wrapping the kubeless Kubernetes-native serverless framework deploying Function-as-a-Service FaaS on top of Kubernetes managing functions triggers HTTP-Cron-Kafka-NATS-deployments configuration runtime topic timetrigger autoscale-replicas-cpu-target watcher (Kubeless team, Go); cobra
# upstream: https://kubeless.io/

_kubeless() {
    local -a sub=(
        'function:function operations'
        'trigger:trigger operations'
        'autoscale:autoscale management'
        'topic:topic management'
        'completion:generate shell completion'
        'install:install Kubeless'
        'uninstall:uninstall Kubeless'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubeless subcommand' sub ;;
        args)
            case $words[1] in
                function) _arguments \
                    '1:op:(deploy list describe call update delete logs top)' \
                    '--from-file=+[file]:file:_files' \
                    '--handler=+[name]:str:' \
                    '--runtime=+[r]:r:(python2.7 python3.4 python3.6 python3.7 nodejs6 nodejs8 nodejs10 nodejs12 nodejs14 dotnetcore2.0 dotnetcore2.1 dotnetcore3.1 ruby2.4 php7.2 java1.8 ballerina0.981.0 jvm1.8 go1.13)' \
                    '--dependencies=+[file]:file:_files' \
                    '--env=+[k=v]:str:' \
                    '--label=+[k=v]:str:' \
                    '--memory=+[mem]:str:' \
                    '--cpu=+[cpu]:str:' \
                    '--timeout=+[sec]:n:' \
                    '*:name:' ;;
                trigger) _arguments \
                    '1:op:(http cronjob kafka nats kinesis create delete list)' \
                    '*:name:' ;;
                autoscale) _arguments \
                    '1:op:(create list delete)' \
                    '--min=+[N]:n:' \
                    '--max=+[N]:n:' \
                    '--cpu-percentage=+[N]:n:' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_kubeless "$@"
