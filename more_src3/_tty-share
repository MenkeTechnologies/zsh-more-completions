#compdef tty-share
# Documentation: https://github.com/elisescu/tty-share
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tty-share terminal sharing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--public[create a public session]' \
  '--readonly[create a read-only session]' \
  '-L+[TCP port forwarding (local)]:spec' \
  '-A+[allow TCP port forwarding (server-side)]:spec' \
  '*::args:_message "see tty-share --help"' && ret=0

return ret
