#compdef walrusfox
# Documentation: https://github.com/LinkeTh/walrusfox
# Source: LinkeTh/walrusfox — Linux-only Pywalfox native messaging host (Rust).
# Reference accessed: 2026-06-01
# Companion binary `walrusfox-ext` is launched by Firefox automatically.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _wf_cmds
_wf_cmds=(
    'start:launch the socket server in the foreground'
    'install:install the Firefox native messaging manifest'
    'uninstall:remove the manifest and helper files'
    'update:broadcast a color refresh to connected clients'
    'dark:switch to dark theme mode'
    'light:switch to light theme mode'
    'auto:enable automatic theme mode switching'
    'health:check connectivity and status'
    'diagnose:run diagnostics'
    'print-manifest:print the native messaging manifest JSON'
    'help:show help'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'walrusfox command' _wf_cmds && ret=0
        ;;
esac

return ret
