#compdef so-elastic-reindex
# _so-elastic-reindex — Security Onion so-elastic-reindex CLI for reindexing Elasticsearch indices migrating documents to new mappings using Elasticsearch reindex API supporting concurrency batch slicing throttling and source filter scripts (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-elastic-reindex() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-s+[source index]:str:' \
        '--source=+[source index]:str:' \
        '-d+[destination index]:str:' \
        '--dest=+[destination index]:str:' \
        '--query=+[query json]:str:' \
        '--script=+[script]:str:' \
        '--slices=+[N]:n:' \
        '--batch-size=+[N]:n:' \
        '--requests-per-second=+[N]:n:' \
        '--wait-for-completion=+[b]:b:(true false)' \
        '--max-docs=+[N]:n:' \
        '--remote-host=+[host]:str:' \
        '--remote-user=+[user]:str:' \
        '--remote-password=+[password]:str:' \
        '--no-confirm[no confirm]' \
        '--dry-run[dry run]' \
        '--refresh[refresh]' \
        '--op-type=+[t]:t:(index create)' \
        '--conflicts=+[c]:c:(abort proceed)'
}

_so-elastic-reindex "$@"
