#compdef strmcmp
# Documentation: https://www.klayout.de/
# Source: KLayout/klayout src/buddies/src/bd/strmcmp.cc — layout-vs-layout structural comparator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-ta --top-a)'{-ta,--top-a=}'[top cell for first layout]:name:' \
    '(-tb --top-b)'{-tb,--top-b=}'[top cell for second layout]:name:' \
    '(-s --silent)'{-s,--silent}'[silent mode]' \
    '--with-text-orientation[compare text orientations]' \
    '--with-text-details[compare font and alignment for texts]' \
    '(-np --without-properties)'{-np,--without-properties}'[ignore properties]' \
    '(-nl --without-layer-names)'{-nl,--without-layer-names}'[ignore layer names]' \
    '(-u --terse)'{-u,--terse}'[skip too many details]' \
    '(-r --print-properties)'{-r,--print-properties}'[print shape properties too]' \
    '(-p --as-polygons)'{-p,--as-polygons}'[compare shapes as polygons]' \
    '--boxes-as-polygons[turn boxes into polygons before compare]' \
    '--paths-as-polygons[turn paths into polygons before compare]' \
    '--expand-arrays[expand array instances before compare]' \
    '(-1 --ignore-duplicates)'{-1,--ignore-duplicates}'[ignore duplicate instances and shapes]' \
    '(-l --layer-details)'{-l,--layer-details}'[print details for missing layers]' \
    '(-c --cell-mapping)'{-c,--cell-mapping}'[identify cells by their properties]' \
    '(-t --tolerance)'{-t,--tolerance=}'[geometry compare tolerance]:value:' \
    '(-m --max-count)'{-m,--max-count=}'[max number of differences to report]:value:' \
    '*:input layout files (A then B):_files' \
    && ret=0

return ret
