#compdef skillshare
# Documentation: https://github.com/runkids/skillshare
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# skillshare: sync AI CLI skills across tools (Claude Code, Codex, etc.)

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:create config, source dir, and detect targets'
  'sync:sync skills (and optionally agents/extras) to targets'
  'install:install skills from a Git repository'
  'update:update installed skills'
  'upgrade:upgrade the skillshare CLI itself'
  'audit:security audit on skills before they reach an agent'
  'target:manage per-target settings (mode etc.)'
  'completion:generate shell completion'
  'extras:manage extras (rules, commands)'
  'ui:launch the web dashboard'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'skillshare command' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '-p[set up project skills per-repo]' && ret=0
        ;;
      sync)
        _arguments \
          '--all[sync skills, agents, and extras together]' \
          '*:: :( agents )' && ret=0
        ;;
      update)
        _arguments \
          '--all[update all installed skills]' && ret=0
        ;;
      target)
        _arguments \
          '--mode=[target mode]:mode:(copy symlink)' \
          '*:name:' && ret=0
        ;;
      completion)
        _arguments \
          '--install[install completion]' \
          ':shell:(bash zsh fish)' && ret=0
        ;;
      extras)
        _values 'extras action' init collect && ret=0
        ;;
      install)
        _arguments '*:repo:' && ret=0
        ;;
    esac
    ;;
esac

return ret
