#compdef kamailio
# Documentation: https://manpages.debian.org/testing/kamailio/kamailio.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream man page at the URL above.

# Kamailio SIP server. Rewritten from prior file against the man page:
# fixed -G (pgid-file, not group ID), -K (via-host check, not serialize),
# -x/-X (mem managers, not debug levels), -e (requires -E), removed the
# duplicate boolean -S and invented -p/-A-as-setID; added the missing
# -B/-I/-L/-m/-M/-Q/-R/-t/-W documented options.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-v[show version]' \
  '-I[display internal constants and attributes]' \
  '-D[do not daemonize (run in foreground)]' \
  '-E[send log messages to stderr]' \
  '-e[log messages in terminal colors (requires -E)]' \
  '-f+[main config file]:file:_files -g "*.cfg"' \
  '-c[check config and exit]' \
  '*-l+[listen address]:addr:' \
  '-n+[child processes per interface]:n:' \
  '-N+[TCP connection handler processes]:n:' \
  '-Q+[SCTP child processes]:n:' \
  '-T[disable TCP]' \
  '-S[disable SCTP]' \
  '-w+[working/core file dir]:dir:_files -/' \
  '-Y+[runtime dir]:dir:_files -/' \
  '-t+[chroot dir]:dir:_files -/' \
  '-u+[run as user]:user:_users' \
  '-g+[run as group]:group:_groups' \
  '-P+[PID file]:file:_files' \
  '-G+[process group ID file]:file:_files' \
  '-A+[add config preprocessor define]:define:' \
  '-b+[max OS UDP receive buffer size]:n:' \
  '-B+[max OS UDP send buffer size]:n:' \
  '-m+[shared memory size in MB]:mb:' \
  '-M+[private memory size in MB]:mb:' \
  '-r[use DNS to check received= via]' \
  '-R[use reverse DNS to check via]' \
  '-x+[shared memory manager]:mgr:(fm qm tlsf)' \
  '-X+[private memory manager]:mgr:(fm qm tlsf)' \
  '-d+[increase debug level]:n:' \
  '-O+[script optimizer level]:n:' \
  '-a+[auto-aliases mode]:mode:(yes on no off)' \
  '-K[check via host for reply forwarding]' \
  '-L+[modules directory]:dir:_files -/' \
  '-W+[poll method]:method:(poll epoll kqueue select sigio_rt)' \
  '*::passthrough:' && ret=0

return ret
