#compdef linkerd-destination
# Documentation: https://github.com/linkerd/linkerd2/blob/main/controller/cmd/destination/main.go
# Reference accessed: 2026-05-17
# Verified: linkerd/linkerd2 controller/cmd/destination/main.go.
# Internal control-plane binary using Go `flag` (single-dash long names).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated GNU-style `--` long options (Go `flag` uses single-dash);
# fabricated --log-format/--log-level/--trace-collector (not in this
# binary's flag table).

# linkerd-destination: linkerd2 control plane destination service
local curcontext="$curcontext" ret=1
_arguments -C \
  '-addr=[bind address (default :8086)]:addr:' \
  '-metrics-addr=[metrics address (default :9996)]:addr:' \
  '-kubeconfig=[kubeconfig file]:file:_files' \
  '-controller-namespace=[controller namespace (default linkerd)]:ns:' \
  '-outbound-transport-mode=[outbound transport mode (default transparent)]:mode:' \
  '-enable-h2-upgrade=[enable H2 upgrade (default true)]:bool:(true false)' \
  '-enable-endpoint-slices=[enable EndpointSlices (default true)]:bool:(true false)' \
  '-enable-ipv6=[enable IPv6 (default true)]:bool:(true false)' \
  '-identity-trust-domain=[identity trust domain]:domain:' \
  '-cluster-domain=[cluster domain]:domain:' \
  '-default-opaque-ports=[default opaque ports]:list:' \
  '-enable-pprof[enable pprof endpoints]' \
  '-export-queue-metrics=[export queue metrics (default true)]:bool:(true false)' \
  '-stream-queue-capacity=[stream queue capacity]:n:' \
  '-ext-endpoint-zone-weights=[ext endpoint zone weights]:weights:' \
  '-meshed-http2-client-params=[meshed HTTP/2 client params (JSON)]:json:' && ret=0
return ret
