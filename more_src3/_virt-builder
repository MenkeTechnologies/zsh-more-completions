#compdef virt-builder
# _virt-builder — libguestfs virt-builder (build a fresh VM disk image from a template index; positional argument is the template id (e.g. fedora-39, debian-12); -o output, --size resize, --format raw|qcow2, --hostname, --root-password, --install/--uninstall, --update, --firstboot, --list, --notes <id>, --no-cache, --gpg-pubkey)
# upstream: https://github.com/libguestfs/libguestfs (builder)
# Flags from libguestfs builder/builder.ml on tip.

_virt-builder() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-x[trace libguestfs calls]' \
        '--list[list available templates]' \
        '--list-format=*[list format]:format:(short long json)' \
        '--notes+[show notes for template]:template:' \
        '--print-cache[print cache contents]' \
        '--cache+[cache dir]:dir:_files -/' \
        '--no-cache[do not cache]' \
        '--source+[index URI]:uri:' \
        '--gpg-pubkey+[pubkey file]:file:_files' \
        '--no-check-signature[skip signature check]' \
        '-o+[output disk]:file:_files' \
        '--output+[output disk]:file:_files' \
        '--format=*[output format]:fmt:(raw qcow2 vmdk vdi)' \
        '--size+[disk size]:size:' \
        '--arch+[arch]:arch:(x86_64 i686 aarch64 armv7l ppc64 ppc64le s390x riscv64)' \
        '--hostname+[hostname]:hostname:' \
        '--timezone+[timezone]:tz:' \
        '--root-password+[spec]:spec:(file: random disabled lock: password:)' \
        '*--install+[packages]:pkgs:' \
        '*--update[update packages]' \
        '*--firstboot-command+[firstboot cmd]:command:' \
        '*--firstboot+[script]:file:_files' \
        '*--ssh-inject+[USER[:KEYFILE|STR]]:spec:' \
        '*--copy-in+[src:dst]:src:dst:' \
        '*--write+[path:content]:path:content:' \
        '--selinux-relabel[relabel SELinux]' \
        '--smp+[CPU count]:n:' \
        '--memsize+[memory MiB]:mb:' \
        '1:template:'
}

_virt-builder "$@"
