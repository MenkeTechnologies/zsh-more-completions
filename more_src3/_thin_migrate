#compdef thin_migrate
# Documentation: https://man.archlinux.org/man/thin_migrate.8.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# thin_migrate: copy the contents of a thin device to another device or file
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '--source-dev=[input read-only thin device to copy]:dev:_files' \
  '--dest-dev=[output device as copy destination]:dev:_files' \
  '--dest-file=[output file as copy destination]:file:_files' \
  '-q[suppress output messages, return only exit code]' \
  '--quiet[suppress output messages, return only exit code]' \
  '--buffer-size-meg=[size of the data buffers in MiB]:n:' && ret=0
return ret
