#compdef sbuild
# Documentation: https://manpages.debian.org/sbuild
# Source: Debian/sbuild lib/Sbuild/Options.pm — Debian package builder in chroot (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-q --quiet)'{-q,--quiet}'[quiet output]' \
    '-D[debug output]' \
    '--arch=-[host architecture (== --host-arch)]:arch:_default' \
    '--build=-[build architecture]:arch:_default' \
    '--host=-[host architecture]:arch:_default' \
    '--archive=-[archive name]:archive:_default' \
    '(--no-arch-all)--arch-all[build arch-indep packages]' \
    '(--arch-all)--no-arch-all[do not build arch-indep packages]' \
    '(--no-arch-any)--arch-any[build arch-dep packages]' \
    '(--arch-any)--no-arch-any[do not build arch-dep packages]' \
    '(--no-source)--source[build source package]' \
    '(--source)--no-source[do not build source package]' \
    '(--no-apt-clean)--apt-clean[apt-clean before build]' \
    '(--apt-clean)--no-apt-clean[do not apt-clean]' \
    '(--no-apt-update)--apt-update[apt-update before build]' \
    '(--apt-update)--no-apt-update[do not apt-update]' \
    '(--no-apt-upgrade)--apt-upgrade[apt-upgrade before build]' \
    '(--apt-upgrade)--no-apt-upgrade[do not apt-upgrade]' \
    '(--no-apt-distupgrade)--apt-distupgrade[apt dist-upgrade before build]' \
    '(--apt-distupgrade)--no-apt-distupgrade[do not dist-upgrade]' \
    '(--no-run-lintian)--run-lintian[run lintian]' \
    '--no-run-lintian[do not run lintian]' \
    '(--no-run-piuparts)--run-piuparts[run piuparts]' \
    '--no-run-piuparts[do not run piuparts]' \
    '(--no-run-autopkgtest)--run-autopkgtest[run autopkgtest]' \
    '--no-run-autopkgtest[do not run autopkgtest]' \
    '(--no-source-only-changes)--source-only-changes[generate source-only .changes]' \
    '--no-source-only-changes[do not generate source-only changes]' \
    '(--no-enable-network)--enable-network[enable network in chroot]' \
    '--no-enable-network[disable network in chroot]' \
    '(--no-resolve-alternatives)--resolve-alternatives[resolve dependency alternatives]' \
    '--no-resolve-alternatives[do not resolve alternatives]' \
    '(--no-clean-source)--clean-source[clean source tree]' \
    '--no-clean-source[do not clean source tree]' \
    '--unstable[use unstable distribution]' \
    '--stable[use stable distribution]' \
    '--testing[use testing distribution]' \
    '--oldstable[use oldstable distribution]' \
    '--experimental[use experimental distribution]' \
    '--purge-extra-packages[purge extra packages after build]' \
    '--purge-build=-[purge build dir]:opt:(always successful never)' \
    '--purge-deps=-[purge installed build deps]:opt:(always successful never)' \
    '--purge-session=-[purge chroot session]:opt:(always successful never)' \
    '--build-dep-resolver=-[build-dep resolver]:resolver:(apt aptitude aspcud xapt null)' \
    '--build-dir=-[build directory]:dir:_files -/' \
    '--build-path=-[build path inside chroot]:path:_default' \
    '--chroot-mode=-[chroot mode]:mode:(schroot sudo autopkgtest unshare)' \
    '*--chroot-setup-commands=-[run command in chroot before build]:cmd:_command_names' \
    '*--chroot-cleanup-commands=-[run command in chroot after build]:cmd:_command_names' \
    '*--pre-build-commands=-[command before build]:cmd:_command_names' \
    '*--post-build-commands=-[command after build]:cmd:_command_names' \
    '*--post-build-failed-commands=-[command on build failure]:cmd:_command_names' \
    '*--extra-package=-[install extra package(s)]:pkg:_default' \
    '*--extra-repository=-[extra apt repository]:repo:_default' \
    '*--extra-repository-key=-[extra repo key file]:file:_files -g "*.{gpg,asc}"' \
    '*--add-depends=-[add build dependency]:dep:_default' \
    '*--add-depends-arch=-[add build-dep arch]:dep:_default' \
    '*--add-depends-indep=-[add build-dep indep]:dep:_default' \
    '*--add-conflicts=-[add build conflict]:dep:_default' \
    '*--add-conflicts-arch=-[add build conflict arch]:dep:_default' \
    '*--add-conflicts-indep=-[add build conflict indep]:dep:_default' \
    '--append-to-version=-[append to debian/changelog version]:string:_default' \
    '--profiles=-[build profiles (comma)]:profiles:_default' \
    '*--debbuildopt=-[option for dpkg-buildpackage]:opt:_default' \
    '*--debbuildopts=-[options string for dpkg-buildpackage]:opts:_default' \
    '*--dpkg-source-opt=-[option for dpkg-source]:opt:_default' \
    '--mail-log-to=-[mail log recipient]:email:_default' \
    '--mailfrom=-[From email for mail log]:email:_default' \
    '--stats-dir=-[stats directory]:dir:_files -/' \
    '--use-snapshot[use snapshot.debian.org]' \
    '-s[source-only build (=-S)]' \
    '-e[use experimental release]' \
    '-o[short for --oldstable]' \
    '-u[short for --unstable]' \
    '-t[short for --testing]' \
    '--force-orig-source[force using orig source]' \
    '*:dsc or source dir:_files -g "*.dsc"' \
    && ret=0

return ret
