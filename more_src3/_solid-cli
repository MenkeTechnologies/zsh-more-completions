#compdef solid-cli solid
# _solid-cli — SolidJS solid-cli CLI command-line frontend wrapping the SolidJS CLI command-line tooling for the SolidJS reactive declarative efficient performant JavaScript library for building user interfaces open-source written in TypeScript Node Solid Start framework SolidJS SolidStart CLI start init add dev build start preview deploy lint create generate test format show analyze help completion solid-start config (SolidJS team Ryan Carniato, TypeScript); commander
# upstream: https://www.solidjs.com/

_solid-cli() {
    local -a sub=(
        'init:scaffold a new project'
        'create:create a new project'
        'add:add a SolidJS feature'
        'dev:run dev server'
        'start:start prod server'
        'build:build for production'
        'preview:preview build'
        'lint:run linter'
        'format:format code'
        'test:run tests'
        'generate:generate components'
        'analyze:analyze bundle'
        'show:show info'
        'deploy:deploy app'
        'config:configure'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '-c+[config file]:file:_files -g "vite.config.* solid.config.* *.ts *.js"' \
        '--config=+[file]:file:_files' \
        '-d+[directory]:dir:_files -/' \
        '--dir=+[dir]:dir:_files -/' \
        '--cwd=+[dir]:dir:_files -/' \
        '--template=+[name]:str:' \
        '-t+[template]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--package-manager=+[m]:m:(npm pnpm yarn bun)' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--host=+[host]:_hosts' \
        '--https[use HTTPS]' \
        '--open[open browser]' \
        '--clear-screen[clear screen]' \
        '--mode=+[m]:m:(development production)' \
        '-m+[mode]:m:(development production)' \
        '--ssr[SSR build]' \
        '--client[client build]' \
        '--platform=+[p]:str:' \
        '--target=+[t]:str:' \
        '--out-dir=+[dir]:dir:_files -/' \
        '--public-dir=+[dir]:dir:_files -/' \
        '--source-maps[source maps]' \
        '--minify[minify]' \
        '--watch[watch mode]' \
        '-w[watch]' \
        '--force[force]' \
        '-f[force]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--no-banner[no banner]' \
        '--no-color[no color]' \
        '--silent[silent]' \
        '--logLevel=+[l]:l:(info warn error silent)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'solid subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments '*:feature:(router auth tailwind unocss postcss daisyui sass less stylus prettier eslint typescript vitest playwright cypress drizzle prisma vinxi pwa storybook docs trpc supabase i18n mdx)' ;;
                generate) _arguments '1:type:(component route api)' '*:name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_solid-cli "$@"
