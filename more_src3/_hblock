#compdef hblock
# hblock - Adblocker that creates a hosts file from multiple sources

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-O --output)'{-O+,--output=}'[output file path]:file:_files' \
  '(-H --header)'{-H+,--header=}'[header template file]:file:_files' \
  '(-F --footer)'{-F+,--footer=}'[footer template file]:file:_files' \
  '(-S --sources)'{-S+,--sources=}'[sources file]:file:_files' \
  '(-A --allowlist)'{-A+,--allowlist=}'[allowlist file]:file:_files' \
  '(-D --denylist)'{-D+,--denylist=}'[denylist file]:file:_files' \
  '(-R --redirection)'{-R+,--redirection=}'[redirection IP]:ip address:' \
  '(-W --wrap)'{-W+,--wrap=}'[max entries per line]:count:' \
  '(-C --comment)'{-C+,--comment=}'[comment character]:character:' \
  '(-l --lenient)'{-l,--lenient}'[match all entries from sources regardless of validity]' \
  '(-r --regex)'{-r,--regex}'[use regex patterns in allowlist]' \
  '(-c --color)'{-c+,--color=}'[colorize output]:color:(auto always never)' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  && ret=0

return ret
