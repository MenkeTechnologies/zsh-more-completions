#
# -----------------------------------------------------------------------------
# VIDEOCMS'S CLI SURFACE (verbatim from main.go)
# -----------------------------------------------------------------------------
#
# USAGE:
#   videocms [SUBCOMMAND]
#
# Subcommands (commando's colon-namespaced naming):
#   (no subcommand)     Print "try the help command" message
#   help                Show help and exit (auto-registered by commando)
#   version             Show version and exit (auto-registered)
#   serve:main          Start the main HTTP server (web UI + API)
#   config              Print the current configuration and exit
#   create:user         Create a new user account (interactive)
#   delete:user         Delete an existing user account (interactive)
#
# All subcommands take `--help` automatically (registered by commando).
#
# Configuration:
#   videocms reads its configuration from environment variables and from
#   a .env file in the working directory.  The `config` subcommand prints
#   the merged configuration after applying defaults + env vars + .env
#   file overlay.  Key env vars include DATABASE_URL, FFMPEG_PATH,
#   STORAGE_PATH, JWT_SECRET, HTTP_PORT.
#
# =============================================================================

_videocms() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands

    subcommands=(
        'help:show help and exit'
        'version:show version and exit'
        'serve\:main:start the main HTTP server'
        'config:print current configuration'
        'create\:user:create a new user account'
        'delete\:user:delete an existing user account'
    )

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' && ret=0

    case $state in
        (cmd)
            _describe -t subcommands 'videocms subcommand' subcommands && ret=0
            ;;
    esac

    return ret
}

_videocms "$@"
