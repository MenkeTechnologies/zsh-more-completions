#compdef ssrfmap
# _ssrfmap — Swisskyrepo SSRFmap ssrfmap CLI automated Server-Side Request Forgery SSRF exploitation tool reading raw HTTP request file with placeholder parameter scanning AWS-metadata GCP-metadata redis postfix DNS smtp internal-port-scan modules abusing-discovered-SSRF-vulnerabilities (Swisskyrepo team, Python); argparse
# upstream: https://github.com/swisskyrepo/SSRFmap

_ssrfmap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-r+[request file]:file:_files' \
        '--reqfile=+[file]:file:_files' \
        '-p+[parameter]:str:' \
        '--param=+[name]:str:' \
        '-m+[modules]:m:(portscan readfiles open-redirect blind-ssrf socksproxy redis github fastcgi smtp postfix axfr aws gce gcp gophertok dns memcache mongodb mysql nginx-lpe phpfpm rabbitmq rancher subnet x-fox)' \
        '--modules=+[list]:str:' \
        '-l+[listener address]:str:' \
        '--lhost=+[ip]:_hosts' \
        '-P+[lhost port]:n:' \
        '--lport=+[port]:n:' \
        '--rhost=+[ip]:_hosts' \
        '--rport=+[port]:n:' \
        '-u+[useragent]:str:' \
        '--uagent=+[ua]:str:' \
        '--ssl[use HTTPS]' \
        '--level=+[depth]:n:(1 2 3 4 5)' \
        '--proxy=+[proxy]:str:' \
        '--target=+[file]:file:_files' \
        '--handler=+[handler]:str:' \
        '--data=+[payload]:str:' \
        '--exec=+[cmd]:str:' \
        '--config=+[file]:file:_files -g "*.cfg *.ini *.yaml *.yml"' \
        '*::'
}

_ssrfmap "$@"
