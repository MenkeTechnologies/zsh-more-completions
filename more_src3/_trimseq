#compdef trimseq
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/trimseq.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS trimseq: trim ambiguous bits off the ends of sequences
# Removed prior fabricated -minlength/-mismatches/-reverse flags (those are trimest options).
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[turn off prompts]' '-stdout[write stdout]' \
  '-filter[stdin/stdout]' '-options[prompt qualifiers]' '-debug[debug log]' \
  '-verbose[verbose]' '-warning[warnings]' '-error[errors]' '-fatal[fatal]' \
  '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:file:_files' \
  '-outseq=[output sequence(s)]:file:_files' \
  '-window=[region size for ambiguity assessment (default 1)]:n:' \
  '-percent=[threshold percent ambiguity to trigger trimming (default 100.0)]:pct:' \
  '-strict[include IUPAC ambiguity codes in trimming]' \
  '-star[trim asterisks in protein sequences]' \
  '-left[trim at sequence start (default yes)]' \
  '-noleft[do not trim at sequence start]' \
  '-right[trim at sequence end (default yes)]' \
  '-noright[do not trim at sequence end]' \
  '*:sequence:_files' && ret=0

return ret
