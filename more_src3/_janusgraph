#compdef janusgraph-server.sh janusgraph.sh
# Documentation: https://github.com/JanusGraph/janusgraph/blob/master/janusgraph-dist/src/assembly/static/bin/janusgraph-server.sh
# Reference accessed: 2026-05-19
# Verified: JanusGraph upstream janusgraph-server.sh (start/stop/
# restart/status/console/config/help/usage) and janusgraph.sh
# (start/stop/status/clean, -v flag). Removed invented show/
# install/classpath subcommands; #compdef no longer claims a
# bare "janusgraph" binary (it does not exist).

local curcontext="$curcontext" state line ret=1
local -a commands

if [[ $service == janusgraph.sh ]]; then
  commands=(
    'start:fork Cassandra, ES, and Gremlin-Server processes'
    'stop:kill running Cassandra, ES, and Gremlin-Server processes'
    'status:print Cassandra, ES, and Gremlin-Server process status'
    'clean:permanently delete all graph data (run when stopped)'
  )
else
  commands=(
    'start:start the server in the background'
    'stop:stop the running server'
    'restart:stop and start the server'
    'status:check if the server is running'
    'console:start the server in the foreground'
    'config:output internal script variables for debugging'
    'help:print the help message'
    'usage:print the usage message'
  )
fi

_arguments -C \
  '-v[enable logging output to console alongside logfiles]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'janusgraph command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (start|restart|console|config)
        _arguments \
          '*:config_file:_files -g "*.{yaml,yml,properties}"' && ret=0 ;;
    esac ;;
esac

return ret
