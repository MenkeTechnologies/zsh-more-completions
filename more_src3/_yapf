#compdef yapf
# Documentation: yapf --help (Google YAPF)
# Source: Google YAPF — Python code formatter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --diff -i --in-place -q --quiet)'{-d,--diff}'[print diff for fixed source]' \
    '(-d --diff -i --in-place -q --quiet)'{-i,--in-place}'[modify files in place]' \
    '(-d --diff -i --in-place -q --quiet)'{-q,--quiet}'[no output; return value indicates need]' \
    '(-r --recursive)'{-r,--recursive}'[run recursively over directories]' \
    '(-l --lines)*'{-l,--lines=}'[1-based START-END line range to reformat]:range:' \
    '(-e --exclude)*'{-e,--exclude=}'[exclude patterns]:pattern:' \
    '--style=[style name or style file]:style:(pep8 google chromium facebook yapf)' \
    '(- *)--style-help[show style settings and exit]' \
    '--no-local-style[skip search for local style definition]' \
    '(-p --parallel)'{-p,--parallel}'[run in parallel when formatting many files]' \
    '(-m --print-modified)'{-m,--print-modified}'[print names of modified files]' \
    '(-vv --verbose)'{-vv,--verbose}'[print file names while processing]' \
    '(- *)'{-v,--version}'[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:Python file or directory:_files -g "*.py"' \
    && ret=0

return ret
