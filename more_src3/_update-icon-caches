#compdef update-icon-caches
# Documentation: https://manpages.debian.org/update-icon-caches
# Source: GTK packaging update-icon-caches.8 — wrapper to update icon caches in multiple directories (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:icon theme directory:_files -/' \
    && ret=0

return ret
