#compdef swiftgen-cli
# _swiftgen-cli — SwiftGen Swift resource code generator CLI alias (SwiftGen team, Swift); custom argparse
# upstream: https://github.com/SwiftGen/SwiftGen

_swiftgen-cli() {
    local -a sub=(
        'config:work with config files'
        'run:run a parser+template'
        'template:work with templates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'swiftgen subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments \
                    '1:cmd:(generate-xcfilelists init lint run)' \
                    '--config=+[config file]:file:_files -g "swiftgen.yml *.yml"' \
                    '-c+[config file]:file:_files -g "swiftgen.yml *.yml"' \
                    '--verbose[verbose]' \
                    '*:arg:' ;;
                run) _arguments \
                    '1:parser:(strings xcassets colors fonts ic interface-builder json plist yaml coredata files)' \
                    '--template-name=+[bundled template]:str:' \
                    '-t+[bundled template]:str:' \
                    '--template-path=+[template path]:file:_files -g "*.stencil"' \
                    '-p+[template path]:file:_files -g "*.stencil"' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--param=+[template param key=value]:list:' \
                    '--option=+[parser option key=value]:list:' \
                    '--filter=+[file filter regex]:str:' \
                    '--input-paths=+[input paths]:file:_files' \
                    '*:input:_files' ;;
                template) _arguments \
                    '1:cmd:(cat doc list show which)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_swiftgen-cli "$@"
