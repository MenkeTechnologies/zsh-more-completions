#compdef textlint
# Documentation: https://textlint.org/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '--ignore-path=[ignore file]:file:_files' \
  '--init[create config if missing]' \
  '--no-textlintrc[disable .textlintrc loading]' \
  '*--plugin=[plugin]:plugin:' \
  '*--rule=[rule]:rule:' \
  '*--preset=[preset]:preset:' \
  '--rulesdir=[rules dir]:dir:_files -/' \
  '--fix[automatically fix problems]' \
  '--dry-run[preview fixes without modifying]' \
  '(-o --output-file)'{-o,--output-file}'=[output file]:file:_files' \
  '(-f --format)'{-f,--format}'=[format]:fmt:(checkstyle compact github jslint-xml json junit pretty-error stylish table tap unix)' \
  '--no-color[disable colored output]' \
  '--quiet[errors only]' \
  '--stdin[read stdin]' \
  '--stdin-filename=[stdin filename]:name:' \
  '--cache[enable caching]' \
  '--cache-location=[cache file]:file:_files' \
  '--debug[debug]' \
  '--print-config[print configuration to stdout]' \
  '--experimental[enable experimental features]' \
  '--rules-base-directory=[base dir]:dir:_files -/' \
  '--mcp[start as Model Context Protocol server]' \
  '*:file:_files -g "*.(md|markdown|txt|rst)"'
