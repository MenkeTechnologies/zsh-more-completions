#compdef smolagent
# Documentation: https://github.com/huggingface/smolagents
# Reference accessed: 2026-05-22
# Verified: src/smolagents/cli.py argparse definitions.

# Zsh completion for smolagent - Hugging Face smolagents CodeAgent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--model-type[model backend]:type:(InferenceClientModel OpenAIModel OpenAIServerModel LiteLLMModel TransformersModel)' \
  '--model-id[model ID]:model:' \
  '--action-type[agent action type]:type:(code tool_calling)' \
  '--tools*[tools to enable]:tool:(web_search python_interpreter visit_webpage final_answer)' \
  '--imports*[authorized Python imports]:module:' \
  '--verbosity-level[verbosity 0-2]:level:(0 1 2)' \
  '--provider[inference provider]:provider:' \
  '--api-base[API base URL]:url:' \
  '--api-key[API key]:key:' \
  '*:prompt:' && ret=0

return ret
