#compdef svc
# Documentation: https://cr.yp.to/daemontools/svc.html
# Reference accessed: 2026-05-21
# Verified: upstream daemontools svc(8) docs at the URL above.
# Removed from prior file: fabricated -q (quit), -1, -2 flags; -h was
# duplicated (it means hangup/SIGHUP per the upstream docs, not "help").
# Daemontools svc has no help flag.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-u[up: start the service; restart if it stops]' \
  '-d[down: send TERM then CONT, do not restart]' \
  '-o[once: start the service; do not restart]' \
  '-p[pause: send STOP]' \
  '-c[continue: send CONT]' \
  '-h[hangup: send HUP]' \
  '-a[alarm: send ALRM]' \
  '-i[interrupt: send INT]' \
  '-t[terminate: send TERM]' \
  '-k[kill: send KILL]' \
  '-x[exit: supervise exits when service is down]' \
  '*:service dir:_files -/' && ret=0

return ret
