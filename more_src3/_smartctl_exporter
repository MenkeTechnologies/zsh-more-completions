#compdef smartctl_exporter
# Documentation: https://github.com/prometheus-community/smartctl_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--smartctl.path=[path to smartctl binary]:file:_files' \
  '--smartctl.interval=[interval between scans]:duration:' \
  '--smartctl.rescan=[rescan interval for devices]:duration:' \
  '--smartctl.device-include=[regexp of devices to include]:pattern:' \
  '--smartctl.device-exclude=[regexp of devices to exclude]:pattern:' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
