#compdef salt-pillar
# _salt-pillar — SaltStack salt-pillar CLI for fetching pillar data for a specific minion useful for debugging pillar tree rendering Jinja YAML compilation against grains gpg encrypted pillar git-pillar (saltstack team, Python); argparse
# upstream: https://github.com/saltstack/salt

_salt-pillar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[config dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '-l+[log level]:l:(quiet critical error warning info debug trace garbage)' \
        '--log-level=+[log level]:l:(quiet critical error warning info debug trace garbage)' \
        '--log-file=+[file]:file:_files' \
        '--log-file-level=+[level]:l:(quiet critical error warning info debug trace garbage)' \
        '--out=+[fmt]:f:(highstate json nested pprint raw txt yaml)' \
        '--out-indent=+[N]:n:' \
        '--out-file=+[file]:file:_files' \
        '--state-output=+[mode]:m:(full terse mixed changes filter)' \
        '--no-color[no color]' \
        '--force-color[force color]' \
        '--saltfile=+[file]:file:_files' \
        '*:minion id key:'
}

_salt-pillar "$@"
