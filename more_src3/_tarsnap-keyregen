#compdef tarsnap-keyregen
# _tarsnap-keyregen — regenerate a Tarsnap key file (Tarsnap/tarsnap)
# upstream: https://github.com/Tarsnap/tarsnap
# Flags from keyregen/keyregen.c (getopt).

_tarsnap-keyregen() {
    _arguments \
        '(- *)--version[print version]' \
        '--user=[Tarsnap account email address]:email:' \
        '--machine=[machine name]:name:' \
        '--keyfile=[new key file]:file:_files' \
        '--oldkey=[existing key file]:file:_files' \
        '--passphrase-mem=[max memory used for passphrase derivation]:bytes:' \
        '--passphrase-time=[max time used for passphrase derivation]:seconds:' \
        '--passphrased[passphrase-protect the new key]'
}

_tarsnap-keyregen "$@"
