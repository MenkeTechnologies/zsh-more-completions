#compdef wandb-cli wandb2
# _wandb-cli — Weights and Biases wandb-cli wandb CLI command-line frontend wrapping the Weights and Biases MLOps experiment-tracking model-registry hyperparameter-sweeping platform managing runs projects entities sweeps artifacts settings login logout offline sync init pull push status agent server controller restore (Weights and Biases team, Python); click
# upstream: https://wandb.ai/

_wandb-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'init:initialize a project'
        'sync:sync offline runs'
        'pull:pull artifacts'
        'push:push artifacts'
        'run:run a script with tracking'
        'launch:launch a job'
        'sweep:sweep management'
        'agent:run a sweep agent'
        'artifact:artifact operations'
        'controller:sweep controller'
        'docker:docker operations'
        'docker-run:docker run with tracking'
        'gc:run garbage collection'
        'restore:restore a previous run'
        'status:show client status'
        'service:run service'
        'server:run local server'
        'settings:show or modify settings'
        'verify:verify installation'
        'beta:beta features'
        'project:project operations'
        'entity:entity operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--anonymous=+[mode]:m:(allow must never)' \
        '--base-url=+[url]:str:' \
        '--entity=+[name]:str:' \
        '-e+[entity]:str:' \
        '--project=+[name]:str:' \
        '-p+[project]:str:' \
        '--name=+[name]:str:' \
        '-n+[name]:str:' \
        '--dir=+[dir]:dir:_files -/' \
        '--id=+[id]:str:' \
        '--sweep-id=+[id]:str:' \
        '--count=+[N]:n:' \
        '--mode=+[m]:m:(online offline disabled)' \
        '--force[force]' \
        '--no-sync[no sync]' \
        '--cloud-only[cloud only]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wandb-cli subcommand' sub ;;
        args)
            case $words[1] in
                sweep) _arguments '1:op:(create stop cancel pause resume)' '*:sweep config:_files -g "*.yaml *.yml"' ;;
                artifact) _arguments '1:op:(get put ls cache rm verify)' '*:artifact id:' ;;
                project|entity) _arguments '*:name:' ;;
            esac
            ;;
    esac
}

_wandb-cli "$@"
