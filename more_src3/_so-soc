#compdef so-soc
# _so-soc — Security Onion so-soc CLI for managing the SOC analyst web interface restarting services configuring authentication providers OIDC SAML local-users role assignments and Sigma rule cache refresh (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-soc() {
    local -a sub=(
        'restart:restart SOC interface'
        'reload:reload SOC config'
        'status:show SOC status'
        'auth:auth provider operations'
        'user:user operations'
        'role:role operations'
        'rule:Sigma rule operations'
        'tip:tip operations'
        'config:show/edit config'
        'logs:show SOC logs'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-soc subcommand' sub ;;
        args)
            case $words[1] in
                user) _arguments \
                    '1:action:(add delete update list passwd lock unlock enable disable)' \
                    '--email=+[email]:str:' \
                    '--first-name=+[name]:str:' \
                    '--last-name=+[name]:str:' \
                    '--password=+[password]:str:' \
                    '--role=+[role]:str:' \
                    '*:username:' ;;
                role) _arguments \
                    '1:action:(add delete list assign revoke info)' \
                    '*:role:' ;;
                auth) _arguments \
                    '1:action:(list configure remove)' \
                    '--provider=+[p]:p:(local oidc saml ldap)' ;;
                rule) _arguments \
                    '1:action:(list refresh import export reload)' ;;
            esac
            ;;
    esac
}

_so-soc "$@"
