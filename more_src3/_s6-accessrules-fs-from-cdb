#compdef s6-accessrules-fs-from-cdb
# _s6-accessrules-fs-from-cdb — s6 conn-tools s6-accessrules-fs-from-cdb (decompile a cdb-style accessrules database back into a filesystem tree; inverse of s6-accessrules-cdb-from-fs)
# upstream: https://github.com/skarnet/s6
# Source: src/conn-tools/s6-accessrules-fs-from-cdb.c on tip; positional only.

_s6-accessrules-fs-from-cdb() {
    _arguments \
        '1:output-dir:_files -/' \
        '2:cdb-file:_files'
}

_s6-accessrules-fs-from-cdb "$@"
