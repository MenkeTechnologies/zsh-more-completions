#compdef tetragon-operator
# _tetragon-operator — Kubernetes operator for managing Tetragon installations (cilium/tetragon)
# upstream: https://github.com/cilium/tetragon
# Subcommands from operator/cmd/ (cobra).

_tetragon-operator() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config-dir=[config directory]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                serve:'run the operator controller-manager'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                serve)
                    _arguments \
                        '--metrics-bind-address=[metrics endpoint address]:host\:port:' \
                        '--health-probe-bind-address=[probe endpoint address]:host\:port:' \
                        '--leader-election[enable leader election]' \
                        '--leader-election-namespace=[leader-election namespace]:ns:' \
                        '--leader-election-lease-duration=[lease duration]:duration:' \
                        '--leader-election-renew-deadline=[renew deadline]:duration:' \
                        '--leader-election-retry-period=[retry period]:duration:' ;;
            esac
            ;;
    esac
}

_tetragon-operator "$@"
