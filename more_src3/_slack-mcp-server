#compdef slack-mcp-server
# Documentation: https://github.com/korotovsky/slack-mcp-server
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.
# STUB: server is configured via SLACK_MCP_* environment variables; the
# binary itself does not document end-user CLI flags beyond standard
# help/version handling. See docs/03-configuration-and-usage.md upstream.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
