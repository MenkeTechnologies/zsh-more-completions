#compdef lt localtunnel
# _localhost-tunnel — defunctzombie localtunnel lt CLI (expose a local HTTP server to the internet via the public localtunnel.me proxy; --port local port, --subdomain requested subdomain, --host public localtunnel host (default https://localtunnel.me), --print-requests log incoming, --local-host bind, --local-https local server is HTTPS, --local-cert/--local-key/--local-ca for TLS, --allow-invalid-cert)
# upstream: https://github.com/localtunnel/localtunnel
# Flags from localtunnel/localtunnel bin/lt on tip.

_localhost-tunnel() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-p+[local port]:port:' \
        '--port+[local port]:port:' \
        '-s+[subdomain]:subdomain:' \
        '--subdomain+[subdomain]:subdomain:' \
        '-h+[host]:url:' \
        '--host+[host]:url:' \
        '--print-requests[log incoming]' \
        '-l+[local host]:host:_hosts' \
        '--local-host+[local host]:host:_hosts' \
        '--local-https[local is HTTPS]' \
        '--local-cert+[cert]:file:_files' \
        '--local-key+[key]:file:_files' \
        '--local-ca+[ca]:file:_files' \
        '-o[allow invalid cert]' \
        '--allow-invalid-cert[allow invalid cert]'
}

_localhost-tunnel "$@"
