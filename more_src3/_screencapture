#compdef screencapture
# Documentation: screencapture usage (macOS 26)
# Source: capture screen/window/region to file, clipboard, Mail, Preview, or video.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[force capture to the clipboard]' \
    '-b[capture Touch Bar (non-interactive only)]' \
    '-C[capture the cursor too (non-interactive only)]' \
    '-d[display errors to the user graphically]' \
    '-i[capture screen interactively (selection/window)]' \
    '-m[only capture the main monitor (no -i)]' \
    '-D+[capture from display N (1=main)]:display:(1 2 3 4)' \
    '-o[in window mode, do not capture shadow]' \
    '-p[use default capture settings; ignore files]' \
    '-M[send capture to a new Mail message]' \
    '-P[open capture in Preview or QuickTime Player]' \
    '-B+[open capture in app with bundle id]:bundleid:' \
    '-s[only allow mouse selection mode]' \
    '-S[in window mode, capture screen not window]' \
    '-J+[interactive capture starting style]:style:(selection window video)' \
    '-t+[image format]:format:(png pdf jpg tiff bmp gif)' \
    '-T+[delay seconds (default 5)]:seconds:' \
    '-w[only allow window selection mode]' \
    '-W[start interaction in window selection mode]' \
    '-x[do not play sounds]' \
    '-a[do not include attached windows]' \
    '-r[do not add dpi metadata]' \
    '-l+[capture this window id]:windowid:' \
    '-R+[capture screen rect (x,y,w,h)]:rect:' \
    '-v[capture video recording of the screen]' \
    '-V+[limit video capture to N seconds]:seconds:' \
    '-g[capture audio during video (default input)]' \
    '-G+[capture audio during video with id]:audio id:' \
    '-k[show clicks in video recording mode]' \
    '-U[show interactive toolbar in interactive mode]' \
    '-u[present UI after capture is complete]' \
    '-H[capture content in HDR]' \
    '*:output file:_files' \
    && ret=0

return ret
