#compdef vampire
# Documentation: https://github.com/vprover/vampire/blob/master/Shell/Options.cpp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '--help[show help]' \
  '--version[show version]' \
  '(-t --time_limit)'{-t+,--time_limit=}'[time limit seconds]:t:' \
  '--memory_limit+[memory limit MB]:mb:' \
  '(-m --mode)'{-m+,--mode=}'[run mode]:m:(vampire casc portfolio axiom_selection clausify model_check tclausify tpreprocess preprocess preprocess2 spider consequence_elimination output profile smtcomp)' \
  '--input_syntax+[input syntax]:s:(tptp smtlib2 auto)' \
  '--output_axiom_names[output axiom names]' \
  '--proof+[proof output]:p:(off on tptp proofcheck property smt2_proofcheck smtcheck)' \
  '--statistics+[statistics level]:l:(none brief full)' \
  '(-p --print_clausifier_premises)'{-p,--print_clausifier_premises}'[print premises]' \
  '--include+[include path]:dir:_files -/' \
  '--decode+[decode option string]:opts:' \
  '--show_options+[show options]:l:(off bad good all)' \
  '--show_experimental_options[show experimental]' \
  '--show_help+[show help on options]:on:(on off)' \
  '--saturation_algorithm+[saturation algo]:a:(discount otter lrs fmb z3)' \
  '--age_weight_ratio+[age:weight]:r:' \
  '--cores+[cores]:n:' \
  '*: :_files -g "*.p *.tptp *.smt2 *.smt *.fof"' && ret=0

return ret
