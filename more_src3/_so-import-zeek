#compdef so-import-zeek
# _so-import-zeek — Security Onion so-import-zeek CLI for ingesting precomputed Zeek tab-separated log files conn dns http ssl ssh files weird notice into Elasticsearch via Filebeat-Logstash for retrospective analysis (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-import-zeek() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-r+[replay time]:str:' \
        '--replay-time=+[replay time]:str:' \
        '-t+[delta seconds]:n:' \
        '--time-delta=+[delta seconds]:n:' \
        '-i+[index name]:str:' \
        '--index=+[index name]:str:' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-c+[count limit]:n:' \
        '--count=+[count limit]:n:' \
        '--source-type=+[t]:t:(conn dns http ssl ssh files weird notice intel known_certs known_hosts known_services x509 dhcp ftp irc kerberos mysql ntlm radius rdp sip smb_files smb_mapping smtp snmp socks software syslog tunnel)' \
        '--tag=+[csv]:str:' \
        '--no-elastic[no Elasticsearch]' \
        '--no-logstash[no Logstash]' \
        '--no-confirm[no confirm]' \
        '--keep-temp[keep temp dir]' \
        '--gz[gzipped input]' \
        '*:zeek log file:_files -g "*.log *.log.gz *.tsv *.json"'
}

_so-import-zeek "$@"
