#compdef svaba
# _svaba — Jeremiah Wala svaba CLI Structural Variation by Assembly Bayesian rearrangement caller producing breakpoint-resolution VCF from BAM/CRAM through Bayesian SGA-based assembly local realignment producing somatic germline tumor-normal pair indel SV calling subject-mode reference-aware (Jeremiah Wala team, C++); custom argparse
# upstream: https://github.com/walaj/svaba

_svaba() {
    local -a sub=(
        'run:run SvABA assembly and call SVs'
        'refilter:re-filter existing VCFs'
        'assemble:assemble reads in regions'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[tumor bam]:file:_files -g "*.bam *.cram"' \
        '--tumor-bam=+[bam]:file:_files -g "*.bam *.cram"' \
        '-n+[normal bam]:file:_files -g "*.bam *.cram"' \
        '--normal-bam=+[bam]:file:_files -g "*.bam *.cram"' \
        '-G+[reference]:file:_files -g "*.fa *.fasta"' \
        '--reference-genome=+[file]:file:_files -g "*.fa *.fasta"' \
        '-D+[dbsnp]:file:_files -g "*.vcf *.vcf.gz"' \
        '--dbsnp-vcf=+[file]:file:_files -g "*.vcf *.vcf.gz"' \
        '-a+[id prefix]:str:' \
        '--id-string=+[prefix]:str:' \
        '-k+[region bed]:file:_files -g "*.bed"' \
        '--region=+[bed]:file:_files -g "*.bed"' \
        '-p+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-c+[chunk size]:n:' \
        '--chunk-size=+[N]:n:' \
        '-z[gzip output]' \
        '--g-zip[gzip output]' \
        '--read-tracking[track reads]' \
        '--no-readtracking[no read tracking]' \
        '--germline[germline mode]' \
        '--reference-only[reference only]' \
        '--write-extracted-reads[write extracted reads]' \
        '--lod-cutoff=+[N]:str:' \
        '--lod-germ=+[N]:str:' \
        '--ml=+[N]:str:' \
        '--max-coverage=+[N]:n:' \
        '--min-overlap=+[N]:n:' \
        '--minmapq=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'svaba subcommand' sub ;;
    esac
}

_svaba "$@"
