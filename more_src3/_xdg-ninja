#compdef xdg-ninja xdg-ninja.sh
# Documentation: https://github.com/b3nj5m1n/xdg-ninja
# Reference accessed: 2026-05-21
# Verified: upstream xdg-ninja.sh case-statement parses only the flags below.
# Removed fabricated --json and --no-color (not present upstream).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --no-skip-ok)'{-v,--no-skip-ok}'[verbose: show messages for all checked files]' \
  '--skip-ok[hide output for compliant files (default)]' \
  '--skip-unsupported[hide output for files without an available fix]' && ret=0

return ret
