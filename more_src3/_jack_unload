#compdef jack_unload
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/tools/ipunload.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jack_unload: unload an internal JACK client.
# Source usage: "jack_unload client-name [ server-name ]" — positional
# args only, no option flags. Removed fabricated -h and -s flags.
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:client name:' \
  '2:server name:' && ret=0
return ret
