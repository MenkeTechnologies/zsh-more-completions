#compdef wigToBigWig
# _wigToBigWig — UCSC Kent Lab wigToBigWig convert ASCII wiggle to indexed binary bigWig format (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/bigWig.html

_wigToBigWig() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-blockSize=+[block size]:n:' \
        '-itemsPerSlot=+[items per slot]:n:' \
        '-clip[clip out-of-range positions]' \
        '-unc[do not compress]' \
        '-fixedSummaries[use only sparse-data summaries]' \
        '-keepAllChromosomes[keep all chromosomes]' \
        '-version[show version]' \
        '*:in_wig chrom_sizes out_bw:_files -g "*.wig *.bedgraph *.bw *.bigwig *.chrom.sizes *.txt"'
}

_wigToBigWig "$@"
