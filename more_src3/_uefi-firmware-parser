#compdef uefi-firmware-parser
# Documentation: https://github.com/theopolis/uefi-firmware-parser/blob/master/README.rst
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# uefi-firmware-parser: parse UEFI firmware images
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(-b --brute)'{-b,--brute}'[input blob may contain FV headers]' \
  '--superbrute[input may contain any firmware object]' \
  '(-e --extract)'{-e,--extract}'[extract all files/sections/volumes]' \
  '(-q --quiet)'{-q,--quiet}'[do not show info]' \
  '(-c --echo)'{-c,--echo}'[echo filename before parsing/extracting]' \
  '(-o --output)'{-o,--output=}'[dump objects to folder]:dir:_files -/' \
  '(-O --outputfolder)'{-O,--outputfolder}'[dump to filename-based folder]' \
  '(-g --generate)'{-g,--generate=}'[generate FDF (implies extraction)]:fdf:' \
  '--test[test file parsing — output name/success]' \
  '*:UEFI firmware image:_files -g "*.(rom|bin|cap|fd|img)"' && ret=0
return ret
