#compdef hakcheckurl
# _hakcheckurl — Luke Stephens hakcheckurl CLI for quickly probing a list of URLs reporting HTTP status code response size content-type final redirect target with concurrency control for bug-bounty reconnaissance (hakluke team, Go); flag
# upstream: https://github.com/hakluke/hakcheckurl

_hakcheckurl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[N threads]:n:' \
        '--threads=+[N threads]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-r[follow redirects]' \
        '--follow-redirects[follow redirects]' \
        '-x+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '--silent[silent]' \
        '--show-length[show response length]' \
        '--show-title[show page title]' \
        '--show-server[show server header]' \
        '--show-content-type[show content type]' \
        '--filter-status=+[csv]:str:' \
        '--match-status=+[csv]:str:' \
        '*:URL list file:_files'
}

_hakcheckurl "$@"
