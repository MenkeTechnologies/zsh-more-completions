#compdef sing-box
# Documentation: https://github.com/SagerNet/sing-box/tree/main/cmd/sing-box
# Reference accessed: 2026-05-21
# Verified: upstream cmd/sing-box/cmd*.go source (cmd.go global flags,
# cmd_run.go, cmd_check.go, cmd_format.go, cmd_merge.go,
# cmd_generate.go, cmd_rule_set*.go, cmd_tools*.go).

local -a subcommands
subcommands=(
  'run:Run the service'
  'check:Check configuration'
  'format:Format configuration'
  'merge:Merge configurations'
  'generate:Generate random data / keys'
  'geosite:Manage geosite resources'
  'geoip:Manage geoip resources'
  'rule-set:Manage rule-set resources'
  'tools:Experimental tools'
  'version:Print version'
  'completion:Generate shell completion script'
)

# Global persistent flags from cmd.go.
local -a global_flags
global_flags=(
  '(-c --config)'{-c,--config}'=[set configuration file path]:config file:_files'
  '(-C --config-directory)'{-C,--config-directory}'=[set configuration directory]:directory:_directories'
  '(-D --directory)'{-D,--directory}'=[set working directory]:directory:_directories'
  '--disable-color[disable color output]'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  $global_flags \
  '1:subcommand:->subcmd' \
  '*:: :->args'

case $state in
  subcmd)
    _describe -t subcommands 'sing-box subcommand' subcommands
    ;;
  args)
    case $words[1] in
      run|check)
        _arguments $global_flags
        ;;
      format)
        _arguments \
          $global_flags \
          '(-w --write)'{-w,--write}'[write result to source file instead of stdout]'
        ;;
      merge)
        _arguments \
          $global_flags \
          ':output path:_files'
        ;;
      generate)
        local -a gen_cmds
        gen_cmds=(
          'tls-keypair:Generate TLS keypair'
          'reality-keypair:Generate REALITY keypair'
          'wg-keypair:Generate WireGuard keypair'
          'rand:Generate random bytes'
          'uuid:Generate UUID'
          'vapid-keypair:Generate VAPID keypair'
          'ech-keypair:Generate ECH keypair'
        )
        _arguments -C \
          '1:generate subcommand:->gen_sub' \
          '*:: :->gen_args'
        case $state in
          gen_sub)
            _describe -t gen_cmds 'generate subcommand' gen_cmds
            ;;
          gen_args)
            case $words[1] in
              rand)
                _arguments \
                  '--base64[output base64-encoded]' \
                  '--hex[output hex-encoded]' \
                  ':length:'
                ;;
              tls-keypair)
                _arguments \
                  '(-m --months)'{-m,--months}'=[validity in months]:n:' \
                  ':server name:'
                ;;
            esac
            ;;
        esac
        ;;
      rule-set)
        local -a rs_cmds
        rs_cmds=(
          'compile:Compile rule-set source to binary'
          'decompile:Decompile rule-set binary to source'
          'format:Format rule-set source file'
          'match:Match rule-set against input'
          'convert:Convert rule-set between formats'
          'merge:Merge rule-set files'
          'upgrade:Upgrade rule-set format'
        )
        _arguments -C \
          '1:rule-set subcommand:->rs_sub' \
          '*:: :->rs_args'
        case $state in
          rs_sub)
            _describe -t rs_cmds 'rule-set subcommand' rs_cmds
            ;;
          rs_args)
            case $words[1] in
              compile)
                _arguments \
                  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
                  ':source path:_files'
                ;;
              match)
                _arguments \
                  '(-f --format)'{-f,--format}'=[rule-set format]:format:(source binary)' \
                  ':rule-set path:_files' \
                  ':IP address or domain:'
                ;;
              *)
                _arguments '*:file:_files'
                ;;
            esac
            ;;
        esac
        ;;
      tools)
        local -a tools_cmds
        tools_cmds=(
          'connect:Connect to a remote address'
          'fetch:Fetch a URL'
        )
        _arguments -C \
          '(-o --outbound)'{-o,--outbound}'=[use specified outbound tag]:tag:' \
          '1:tools subcommand:->tools_sub' \
          '*:: :->tools_args'
        case $state in
          tools_sub)
            _describe -t tools_cmds 'tools subcommand' tools_cmds
            ;;
        esac
        ;;
      geoip)
        local -a geoip_cmds
        geoip_cmds=(
          'list:List GeoIP codes'
          'lookup:Look up an IP address'
          'export:Export GeoIP database'
        )
        _describe -t geoip_cmds 'geoip subcommand' geoip_cmds
        ;;
      geosite)
        local -a geosite_cmds
        geosite_cmds=(
          'list:List geosite codes'
          'lookup:Look up a domain'
          'export:Export geosite database'
          'matcher:Match domains'
        )
        _describe -t geosite_cmds 'geosite subcommand' geosite_cmds
        ;;
      *)
        _arguments '*:arguments'
        ;;
    esac
    ;;
esac
