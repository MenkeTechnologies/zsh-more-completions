#compdef xlinectl
# ============================================================================
# _xlinectl — zsh completion for xline-kv/Xline's `xlinectl`, the
#              command-line client for the Xline geo-distributed KV store
#              (etcd-compatible API over tonic gRPC)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/xline-kv/Xline
#   Maintainer : DatenLord (xline-kv org)
#   License    : Apache-2.0
#   Stars      : 712
#   Language   : Rust
#   Crate      : xlinectl  (workspace member crates/xlinectl)
#   Binary     : xlinectl  (crates/xlinectl/Cargo.toml [[bin]]
#                            from src/main.rs)
#   Last push  : 2026-05-11
#
# WHAT IT IS
#   Xline is "a geo-distributed KV store for metadata management"
#   from DatenLord — a CURP-based (Curp = consensus protocol)
#   etcd-API-compatible KV store designed for cross-DC metadata.
#   `xlinectl` is its CLI client:  it speaks the etcd v3 API over
#   tonic gRPC channels and provides put/get/delete/lease/snapshot/
#   auth/user/role/txn/compaction/watch/lock/member subcommands
#   that mirror `etcdctl`.  Auth is etcd-style (`--user user:pass`
#   shorthand), output formatting is configurable (SIMPLE / FIELD
#   / JSON), and the global Curp client knobs
#   (`--wait_synced_timeout`, `--propose_timeout`,
#   `--initial_retry_timeout`, `--max_retry_timeout`,
#   `--retry_count`, `--keep_alive_interval`) tune the consensus
#   client's retry behavior.
#
# CLI ARGUMENT GRAMMAR  (verbatim from crates/xlinectl/src/main.rs
#                       `fn cli() -> Command` and per-subcommand
#                       `crates/xlinectl/src/command/<name>.rs`
#                       `fn command()` — clap 4 builder API)
#   xlinectl [GLOBAL OPTIONS] <SUBCOMMAND> [ARGS...]
#
#   Global options:
#     --endpoints <ADDR...>          Xline endpoints (repeatable)
#                                    [default: 127.0.0.1:2379]
#     --user <USERNAME[:PASSWD]>     Username (with optional inline
#                                    password)
#     --password <PASSWD>            Password (if not inlined in
#                                    --user)
#     --wait_synced_timeout <SECS>   Curp client wait-synced timeout
#                                    [default: 2]
#     --propose_timeout <SECS>       Curp client propose timeout
#                                    [default: 1]
#     --initial_retry_timeout <MS>   Initial retry interval
#                                    [default: 50]
#     --max_retry_timeout <MS>       Max retry interval
#                                    (exp-backoff)  [default: 10000]
#     --retry_count <N>              Curp client retry count
#                                    [default: 3]
#     --keep_alive_interval <MS>     Client-id keep-alive interval
#                                    [default: 1000]
#     --printer_type <FMT>           Output format
#                                    [SIMPLE|FIELD|JSON —
#                                    default: SIMPLE]
#     --ca_cert_pem_path <PATH>      CA certificate PEM file
#
#   Subcommands:
#     get <KEY> [<RANGE_END>]        Read a key or range
#       --consistency <L|S>            Linearizable or Serializable
#       --order <ORDER>                Result order
#       --sort_by <SORTBY>             Sort target
#       --limit <N>                    Maximum results
#       --prefix                       Match keys by prefix
#       --from_key                     Keys ≥ given key (byte cmp)
#       --rev <REV>                    Specific kv revision
#       --keys_only                    Return only keys
#       --count_only                   Return only count
#
#     put <KEY> <VALUE>              Write a key
#       --lease <ID>                   Lease ID to attach
#       --prev_kv                      Return previous kv
#       --ignore_value                 Update lease only
#       --ignore_lease                 Update value only
#
#     delete <KEY> [<RANGE_END>]     Delete key or range
#       --prefix                       Delete keys by prefix
#       --prev_kv                      Return deleted kvs
#       --from_key                     Delete keys ≥ given key
#
#     lease <SUBCOMMAND>             Lease management
#                                    (grant/revoke/keep_alive/
#                                     timetolive/list)
#     snapshot <SUBCOMMAND>          Snapshot management
#     auth <SUBCOMMAND>              Enable/disable auth
#     user <SUBCOMMAND>              User management
#                                    (add/delete/passwd/get/list/
#                                     grant_role/revoke_role)
#     role <SUBCOMMAND>              Role management
#                                    (add/delete/get/list/
#                                     grant_permission/
#                                     revoke_permission)
#     txn                            Run a transaction (stdin)
#     compaction <REV>               Compact kv revision history
#     watch <KEY>                    Watch a key for changes
#     lock <NAME>                    Acquire a named distributed
#                                    lock
#     member <SUBCOMMAND>            Cluster membership management
#                                    (add/remove/update/list/promote)
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `tonic = { version = "0.5.0",
#   package = "madsim-tonic" }` declared in
#   crates/xlinectl/Cargo.toml — `tonic` is the canonical Rust
#   gRPC framework maintained by the Hyper ecosystem
#   (hyperium/tonic), built on top of `hyper`, `prost`, and
#   `tower`, providing typed `Channel`, `Server`, `Code`, `Status`,
#   streaming methods, interceptor middleware, and TLS via
#   `tonic::transport`.  Xline's `xlinectl` uses `madsim-tonic` —
#   a deterministic-simulation-compatible drop-in for `tonic` from
#   the madsim project — to run the same gRPC client code under
#   real and simulated networks.  The transitive `tonic` API
#   surface is identical;  the Xline workspace pins it for both
#   simulation testing (`madsim-tonic`) and production
#   (the upstream `tonic` crate via xline-client / xlineapi).
#   Verified via:
#     gh api repos/xline-kv/Xline/contents/crates/xlinectl/
#         Cargo.toml
#       → tonic = { version = "0.5.0", package = "madsim-tonic" }
#       → xline-client = { path = "../xline-client" }
#       → clap = "4"
#     gh api repos/xline-kv/Xline/contents/crates/xlinectl/src/
#         main.rs
#       → fn cli() -> Command { Command::new("xlinectl") ...
#         .subcommand(get::command()).subcommand(put::command())
#         .subcommand(delete::command())...(13 subcommands) }
#   This entry is the Rust=139 leader bump that OPENS Axis 84
#   (gRPC Framework Library) at 1/0/0.  Pairing Go and TS-Node
#   bumps will follow at R926 and R927 (Go=139 candidates
#   `google.golang.org/grpc`, etcd-io/etcd `etcdctl`; TS-Node=139
#   candidates `@grpc/grpc-js`, `nice-grpc`).
#
#   No completion for `xlinectl` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_xlinectl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*--endpoints=[Xline endpoint addresses (repeatable)]:endpoint:' \
        '--user=[username (with optional inline password)]:user[:pass]:' \
        '--password=[password]:password:' \
        '--wait_synced_timeout=[Curp wait-synced timeout in secs]:secs:' \
        '--propose_timeout=[Curp propose timeout in secs]:secs:' \
        '--initial_retry_timeout=[initial retry interval in ms]:ms:' \
        '--max_retry_timeout=[max retry interval in ms]:ms:' \
        '--retry_count=[Curp retry count]:n:' \
        '--keep_alive_interval=[client-id keep-alive interval in ms]:ms:' \
        '--printer_type=[output format]:format:(SIMPLE FIELD JSON)' \
        '--ca_cert_pem_path=[CA certificate PEM file]:path:_files' \
        '1: :_xlinectl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                get)
                    _arguments \
                        '--consistency=[consistency level]:level:(L S)' \
                        '--order=[result order]:order:' \
                        '--sort_by=[sort target]:sort:' \
                        '--limit=[maximum results]:n:' \
                        '--prefix[match keys by prefix]' \
                        '--from_key[match keys >= given key]' \
                        '--rev=[specific kv revision]:rev:' \
                        '--keys_only[return only keys]' \
                        '--count_only[return only count]' \
                        ':key:' \
                        '::range_end:' && ret=0 ;;
                put)
                    _arguments \
                        '--lease=[lease ID to attach]:lease ID:' \
                        '--prev_kv[return previous kv]' \
                        '--ignore_value[update lease only]' \
                        '--ignore_lease[update value only]' \
                        ':key:' \
                        ':value:' && ret=0 ;;
                delete)
                    _arguments \
                        '--prefix[delete keys by prefix]' \
                        '--prev_kv[return deleted kvs]' \
                        '--from_key[delete keys >= given key]' \
                        ':key:' \
                        '::range_end:' && ret=0 ;;
                lease)
                    _arguments \
                        '1:lease subcommand:(grant revoke keep_alive timetolive list)' \
                        '*::arg:' && ret=0 ;;
                user)
                    _arguments \
                        '1:user subcommand:(add delete passwd get list grant_role revoke_role)' \
                        '*::arg:' && ret=0 ;;
                role)
                    _arguments \
                        '1:role subcommand:(add delete get list grant_permission revoke_permission)' \
                        '*::arg:' && ret=0 ;;
                member)
                    _arguments \
                        '1:member subcommand:(add remove update list promote)' \
                        '*::arg:' && ret=0 ;;
                auth|snapshot)
                    _arguments \
                        '1:subcommand:(enable disable save restore)' \
                        '*::arg:' && ret=0 ;;
                watch|lock|compaction|txn)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_xlinectl_commands] )) ||
_xlinectl_commands() {
    local -a commands
    commands=(
        'get:read a key or key range'
        'put:write a key'
        'delete:delete a key or key range'
        'lease:lease management (grant/revoke/keep_alive/timetolive/list)'
        'snapshot:snapshot management'
        'auth:enable/disable auth'
        'user:user management'
        'role:role management'
        'txn:run a transaction (stdin)'
        'compaction:compact kv revision history'
        'watch:watch a key for changes'
        'lock:acquire a named distributed lock'
        'member:cluster membership management'
    )
    _describe -t commands 'xlinectl command' commands
}

_xlinectl "$@"
