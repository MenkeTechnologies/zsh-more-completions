#compdef jarsigner
# Documentation: https://docs.oracle.com/en/java/javase/21/docs/specs/man/jarsigner.html
# Reference accessed: 2026-05-19
# Verified: jarsigner -help from OpenJDK 25.0.2 (Homebrew).

_arguments -s \
  '(- *)'{-version}'[print the program version]' \
  '(- *)'{-?,-h,--help}'[print help message]' \
  '-keystore[keystore location]:url:' \
  '-storepass[password for keystore integrity]:password:' \
  '-storetype[keystore type]:type:' \
  '-keypass[password for private key (if different)]:password:' \
  '-certchain[name of alternative certchain file]:file:_files' \
  '-sigfile[name of .SF/.DSA file]:file:_files' \
  '-signedjar[name of signed JAR file]:file:_files' \
  '-digestalg[name of digest algorithm]:algorithm:' \
  '-sigalg[name of signature algorithm]:algorithm:' \
  '-verify[verify a signed JAR file]' \
  '-verbose=-[verbose output when signing/verifying]::suboptions:(all grouped summary)' \
  '-certs[display certificates when verbose and verifying]' \
  '-revCheck[enable certificate revocation check]' \
  '-tsa[location of the Timestamping Authority]:url:' \
  '-tsacert[public key certificate for Timestamping Authority]:alias:' \
  '-tsapolicyid[TSAPolicyID for Timestamping Authority]:oid:' \
  '-tsadigestalg[algorithm of digest data in timestamping request]:algorithm:' \
  '-internalsf[include the .SF file inside the signature block]' \
  '-sectionsonly[do not compute hash of entire manifest]' \
  '-protected[keystore has protected authentication path]' \
  '-providerName[provider name]:name:' \
  '-addprovider[add security provider by name]:name:' \
  '-providerClass[add security provider by fully-qualified class name]:class:' \
  '*-providerArg[configure argument for -addprovider/-providerClass]:arg:' \
  '-providerPath[provider classpath]:list:' \
  '-strict[treat warnings as errors]' \
  '-conf[specify a pre-configured options file]:url:_files' \
  '*-J-[pass option to JVM]:option:' \
  '*:jar:_files -g "*.jar"'
