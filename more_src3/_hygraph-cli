#compdef hygraph-cli
# _hygraph-cli — Hygraph (formerly GraphCMS) headless content platform CLI alias (hygraph team, TypeScript); oclif
# upstream: https://github.com/hygraph/hygraph-cli

_hygraph-cli() {
    local -a sub=(
        'init:initialize hygraph project'
        'login:login to hygraph'
        'logout:logout'
        'config:configure cli'
        'whoami:show current user'
        'projects:list projects'
        'projects:create:create project'
        'projects:delete:delete project'
        'environments:list:list environments'
        'environments:create:create environment'
        'environments:delete:delete environment'
        'models:list:list content models'
        'models:create:create model'
        'models:delete:delete model'
        'fields:list:list fields'
        'fields:create:create field'
        'fields:delete:delete field'
        'enumerations:list:list enums'
        'enumerations:create:create enum'
        'webhooks:list:list webhooks'
        'webhooks:create:create webhook'
        'webhooks:delete:delete webhook'
        'roles:list:list roles'
        'roles:create:create role'
        'tokens:list:list tokens'
        'tokens:create:create token'
        'tokens:delete:delete token'
        'export:export schema or content'
        'import:import schema or content'
        'apply:apply schema changes'
        'diff:show diff between environments'
        'autocomplete:set up shell autocomplete'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hygraph subcommand' sub ;;
        args)
            case $words[1] in
                projects:create) _arguments \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--region=+[region]:r:(us-east-1 eu-central-1 ap-southeast-1)' \
                    '--description=+[description]:str:' \
                    '--blank[blank project]' ;;
                environments:create) _arguments \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--clone-from=+[clone from]:str:' ;;
                export) _arguments \
                    '--out=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--include=+[include]:i:(schema content all)' \
                    '--format=+[format]:f:(json yaml)' ;;
                import) _arguments \
                    '--file=+[input file]:file:_files' \
                    '-f+[input file]:file:_files' \
                    '--mode=+[mode]:m:(merge replace)' ;;
                autocomplete) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_hygraph-cli "$@"
