#compdef kedro
# Documentation: https://docs.kedro.org/en/0.18.4/development/commands_reference.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kedro: data pipeline framework CLI. Corrected from prior file: fixed
# placeholder doc URL; added documented global commands info/docs and
# short flags for kedro run (-n -r -t -lv -p -c) per the commands
# reference.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '(-e --env)'{-e,--env}'[Kedro configuration environment]:environment' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'catalog:manage the data catalog'
      'docs:open the Kedro documentation in a browser'
      'info:show installed plugins and versions'
      'ipython:open IPython session'
      'jupyter:manage Jupyter notebooks'
      'micropkg:manage micro-packages'
      'new:create a new Kedro project'
      'package:package the project'
      'pipeline:manage pipelines'
      'registry:manage the project registry'
      'run:run the project'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      run)
        _arguments -s -S \
          '--from-nodes=[start from nodes]:nodes' \
          '--to-nodes=[stop at nodes]:nodes' \
          '--from-inputs=[start from inputs]:inputs' \
          '--to-outputs=[stop at outputs]:outputs' \
          '(-n --node)'{-n,--node}'=[run specific nodes]:node' \
          '(-r --runner)'{-r,--runner}'=[runner to use]:runner' \
          '--async[run asynchronously]' \
          '(-t --tag)'{-t,--tag}'=[filter by tag]:tag' \
          '(-lv --load-version)'{-lv,--load-version}'=[load specific version]:version' \
          '(-p --pipeline)'{-p,--pipeline}'=[run specific pipeline]:pipeline' \
          '--namespace=[run specific namespace]:namespace' \
          '(-c --config)'{-c,--config}'=[path to run config file]:file:_files' \
          '--params=[set parameters]:params' \
          '(-e --env)'{-e,--env}'=[Kedro configuration environment]:environment' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      new)
        _arguments -s -S \
          '--name=[project name]:name' \
          '--tools=[tools to include]:tools' \
          '--example=[use example pipeline]:example:(y n)' \
          '--starter=[project starter]:starter' \
          '--checkout=[checkout tag/branch of starter]:ref' \
          '--directory=[directory within starter]:directory' \
          '--config=[config file]:config file:_files' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      catalog)
        _arguments -s -S \
          '1:action:(create list rank resolve)' && ret=0
        ;;
      pipeline)
        _arguments -s -S \
          '1:action:(create delete describe list package pull)' && ret=0
        ;;
      jupyter)
        _arguments -s -S \
          '1:action:(lab notebook convert)' && ret=0
        ;;
    esac
    ;;
esac

return ret
