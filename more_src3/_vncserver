#compdef vncserver tigervncserver
# _vncserver — TigerVNC vncserver (Perl wrapper that starts an Xtigervnc per-user X server with a numeric display; -kill stops one, -list shows ports, -geometry/-depth/-pixelformat configure the framebuffer, -SecurityTypes for auth)
# upstream: https://github.com/TigerVNC/tigervnc
# Flags from tigervnc unix/vncserver/vncserver.in on tip.

_vncserver() {
    _arguments \
        '-kill+[stop a display]:display:' \
        '-list[list running servers]' \
        '-name+[desktop name]:name:' \
        '-geometry+[WxH]:geom:' \
        '-depth+[bpp]:depth:(8 15 16 24 32)' \
        '-pixelformat+[pixfmt]:pixfmt:' \
        '-SecurityTypes+[security types]:types:(None VncAuth Plain TLSNone TLSVnc TLSPlain X509None X509Vnc X509Plain)' \
        '-PasswordFile+[password file]:file:_files' \
        '-localhost[bind to localhost only]' \
        '-xstartup+[xstartup script]:file:_files' \
        '-fg[foreground]' \
        '-autokill[exit when client disconnects]' \
        '-help[show help]'
}

_vncserver "$@"
