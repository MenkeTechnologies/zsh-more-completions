#compdef kubectl-crashwatch
# Documentation: https://github.com/bedirhangull/kubectl-crashwatch
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-crashwatch (bedirhangull): show logs of CrashLoopBackOff pods.
# `-d` or the `dashboard` subcommand launches the web dashboard.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d[launch the web-based dashboard]' \
  '1:command:(dashboard)' \
  '*::arg:_default'
