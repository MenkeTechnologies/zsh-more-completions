#compdef lsmod
# Documentation: https://man.archlinux.org/man/lsmod.8.en
# Reference accessed: 2026-05-30
# lsmod — list currently loaded Linux kernel modules. From kmod package.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help and exit]' \
  '(- *)'{-V,--version}'[show version of program and exit]' \
  '(-s --syslog)'{-s,--syslog}'[send errors to syslog instead of stderr]' \
  '(-v --verbose)'{-v,--verbose}'[print messages about what the program is doing]' \
  && ret=0

return ret
