#compdef wofm2opl ofm2opl
# Documentation: wofm2opl/ofm2opl --help (TeX Live 2026)
# Source: translate Omega Font Metrics (OFM) to human-readable Property List (OPL).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '-charcode-format=[character-code radix]:type:(hex ascii)' \
    '1:ofm input:_files -g "*.ofm"' \
    '2:opl output:_files -g "*.opl"' \
    && ret=0

return ret
