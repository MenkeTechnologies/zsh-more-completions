#compdef swayfx
# Documentation: https://github.com/WillPower3309/swayfx (sway.1.scd)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (fork of sway, identical CLI flags).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[specify config file]:config file:_files' \
  '(-C --validate)'{-C,--validate}'[validate config and exit]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-V --verbose)'{-V,--verbose}'[enable verbose logging]' \
  '--get-socketpath[get the IPC socket path and print it]'
