#
# WHAT IS mikaelmello/inquire AND WHY IS IT A DISTINCT 36TH RUST CLI LIBRARY?
#
# mikaelmello/inquire (https://github.com/mikaelmello/inquire, 2580+ stars)
# is **Mikael Mello's "A Rust library for building interactive prompts"** —
# **the older, more mature Rust competitor to cliclack** in the
# interactive-prompt space.  Where cliclack R510 is a 2024 Rust port of
# Nate Moore's @clack/prompts (JS), inquire is a 2021-vintage independent
# Rust prompt library with its own design lineage descending from
# Manuel Kniep's `dialoguer` and Python's `prompt_toolkit`.  inquire was
# the **dominant Rust interactive-prompt library** for years (2021-2023)
# before cliclack's modern-aesthetic challenge.  Both libraries continue
# to coexist: cliclack for projects wanting JS-Clack visual style;
# inquire for projects wanting maximally-extensible validators / custom
# prompt types / trait-driven design.
#
# inquire is DISTINCT from every documented Rust CLI library (including
# cliclack R510) on SIX specific axes:
#
#   1. TRAIT-BASED EXTENSIBILITY (Validator + Autocomplete + CustomType
#      traits) — inquire is the FIRST documented Rust interactive-prompt
#      library to expose its functionality through TRAITS for third-
#      party extensibility:
#         pub trait StringValidator: Send + Sync + 'static {
#             fn validate(&self, input: &str)
#                 -> Result<Validation, CustomUserError>;
#         }
#         pub trait Autocomplete: Send + Sync + 'static {
#             fn get_suggestions(&mut self, input: &str)
#                 -> Result<Vec<String>, CustomUserError>;
#             fn get_completion(&mut self, input: &str,
#                               highlighted: Option<String>)
#                 -> Result<Replacement, CustomUserError>;
#         }
#         pub trait CustomType<T: Clone + 'static>: ... {
#             // implement custom-type parsing + validation
#         }
#      Users define their own validator types implementing
#      `StringValidator` to plug into any prompt:
#         Password::new("Master password:")
#             .with_validator(MinLengthValidator::new(8))
#             .with_validator(MaxLengthValidator::new(64))
#             .with_validator(MinDigitsValidator::new(1))
#             .with_validator(MinSpecialCharsValidator::new(1))
#             .prompt()?;
#      Compare:
#        cliclack R510:        validator is a CLOSURE — `validate: |s| if
#                               s.len() > 0 {Ok(())} else {Err("required")}`
#                              — no trait, no third-party reuse
#        dialoguer (console-rs):simpler `with_validator(|s| ...)` closure
#        @clack/prompts (JS):   validator is a function in the options
#                               object
#        inquire:               TRAIT-BASED — third parties publish
#                               validator crates (e.g. `inquire-derive`,
#                               `inquire-validators-extra`).
#      **First documented Rust CLI library with TRAIT-BASED PROMPT
#      EXTENSIBILITY as a primary design concern.**
#
#   2. `CustomType<T>` GENERIC TYPED PROMPT — inquire's killer feature
#      is `CustomType<T>` — a generic prompt that parses any type
#      implementing the requisite traits:
#         let port: u16 = CustomType::<u16>::new("Server port:")
#             .with_default(8080)
#             .with_error_message("Must be a valid port (1-65535)")
#             .prompt()?;
#         let date: chrono::NaiveDate = CustomType::<chrono::NaiveDate>::new(
#             "Birthday:")
#             .with_formatter(&|d| d.format("%Y-%m-%d").to_string())
#             .prompt()?;
#         let uuid: Uuid = CustomType::<Uuid>::new("Token:")
#             .with_parser(&|s| Uuid::parse_str(s).map_err(|_| ()))
#             .prompt()?;
#      The user types text, inquire calls the type's `FromStr` (or a
#      custom parser closure) to parse, re-prompts on failure with the
#      error message.  Compare:
#        cliclack R510:    no generic typed prompt — text() returns
#                          String only; caller does parsing after
#        dialoguer:        Input<T> generic similar to CustomType, but
#                          inquire's design is more polished with
#                          formatter / parser / error_message triple
#        @clack/prompts:   text() returns string; caller parses
#        inquire:          GENERIC CustomType<T> with composable
#                          parser + formatter + validator —
#                          most ergonomic typed-prompt design in Rust.
#
#   3. `Autocomplete` PROMPT TYPE WITH TAB-COMPLETION CALLBACKS —
#      inquire ships first-class Autocomplete prompts with TAB-COMPLETION
#      callbacks:
#         struct FilePathCompleter;
#         impl Autocomplete for FilePathCompleter {
#             fn get_suggestions(&mut self, input: &str)
#                 -> Result<Vec<String>, CustomUserError> {
#                 // List entries in directory matching input prefix
#             }
#             fn get_completion(&mut self, input: &str,
#                               highlighted: Option<String>)
#                 -> Result<Replacement, CustomUserError> {
#                 // Tab-completion: return Some(replacement) or None
#             }
#         }
#         let path: String = Text::new("File path:")
#             .with_autocomplete(FilePathCompleter)
#             .prompt()?;
#      Compare:
#        cliclack R510:    no native autocomplete
#        dialoguer:        no native autocomplete
#        @clack/prompts:   no native autocomplete
#        inquire:          AUTOCOMPLETE TRAIT with get_suggestions +
#                          get_completion methods — UNIQUE among
#                          documented prompt libraries.
#      Used by spacedrive's `cloud` flow for path autocomplete when
#      asking the user to pick a sync directory.
#
#   4. RICH `InquireError` ERROR-TYPE HIERARCHY — inquire distinguishes
#      cancellation-modes with a typed error hierarchy:
#         pub enum InquireError {
#             OperationCanceled,         // user pressed Esc
#             OperationInterrupted,      // user pressed Ctrl-C
#             IO(io::Error),             // terminal I/O failure
#             NotTTY,                    // stdin not a terminal
#             InvalidConfiguration(String),
#             Custom(Box<dyn Error + Send + Sync>),
#         }
#      Callers can branch on these to differentiate "user gave up
#      (Esc)" vs "user killed process (Ctrl-C)" vs "stdin is a pipe,
#      no TTY".  Compare:
#        cliclack R510:    isCancel via panic — single cancel state
#        dialoguer:        Err(Error::IO) for both Ctrl-C and Esc
#        @clack/prompts:   isCancel() Symbol — single state, no Esc vs
#                           Ctrl-C distinction
#        inquire:          FIVE-VARIANT ERROR TYPE distinguishing
#                          Esc-cancel from Ctrl-C-interrupt from
#                          not-a-TTY from IO-fail.
#      Production CLI tooling needs this granularity — `spacedrive
#      cloud` handles Esc differently from Ctrl-C (Esc returns to a
#      menu, Ctrl-C aborts the entire enrollment).
#
#   5. EIGHT BUILT-IN PROMPT TYPES — inquire has a richer base set than
#      any other documented Rust prompt library:
#         Text                — single-line text input
#         Password            — masked text input
#         Confirm             — yes/no
#         Select              — single-pick from list
#         MultiSelect         — multi-pick from list
#         DateSelect          — calendar date picker (with chrono)
#         CustomType<T>       — generic typed input (see axis 2)
#         Editor              — opens $EDITOR, returns content
#      Compare:
#        cliclack R510:    text, password, confirm, select, multiselect,
#                          spinner, progress_bar — NO DateSelect, NO
#                          CustomType, NO Editor
#        dialoguer:        Input, Password, Confirm, Select, MultiSelect,
#                          FuzzySelect — NO DateSelect, NO CustomType
#        @clack/prompts:   text, password, confirm, select, multiselect,
#                          groupMultiSelect, selectKey, spinner — NO
#                          DateSelect, NO Editor, NO CustomType
#        inquire:          Text + Password + Confirm + Select +
#                          MultiSelect + DateSelect + CustomType +
#                          Editor — eight types, broader coverage.
#      The `Editor` prompt is especially distinctive — opens $EDITOR
#      ($VISUAL on macOS) on a tempfile and returns the user's edited
#      content.  Used by spacedrive for multiline configuration entry.
#
#   6. `with_render_config()` PER-PROMPT THEMING + GLOBAL `set_global
#      _render_config()` — inquire supports BOTH per-prompt theme
#      override AND global theme setting:
#         use inquire::ui::{Attributes, Color, RenderConfig, StyleSheet,
#                          Styled};
#         let mut config = RenderConfig::default();
#         config.prompt = StyleSheet::new()
#             .with_fg(Color::LightBlue)
#             .with_attr(Attributes::BOLD);
#         inquire::set_global_render_config(config);  // global default
#         let name: String = Text::new("Name:")
#             .with_render_config(config_override)  // per-prompt
#             .prompt()?;
#      RenderConfig has 30+ styled fields (prompt_prefix, answer,
#      placeholder, default_value, help_message, error_message,
#      canceled_prompt_indicator, scroll_up_prefix, scroll_down_prefix,
#      selected_option, option, selected_checkbox, unselected_checkbox,
#      ...).  Compare:
#        cliclack R510:    Theme trait + set_theme() — global only
#        dialoguer:        Theme trait — global only via ColorfulTheme/
#                          SimpleTheme
#        @clack/prompts:   no theming API
#        inquire:          PER-PROMPT + GLOBAL theming, with the finest-
#                          grained StyleSheet customization among
#                          documented prompt libraries.
#
# THE mikaelmello/inquire API SURFACE (verbatim from upstream)
#
#   use inquire::{
#       Text, Password, Confirm, Select, MultiSelect, DateSelect,
#       CustomType, Editor, InquireError,
#       PasswordDisplayMode,
#       validator::{Validation, StringValidator, MinLengthValidator,
#                   MaxLengthValidator, ValueRequiredValidator},
#       formatter::{StringFormatter, DateFormatter},
#       ui::{RenderConfig, StyleSheet, Color, Attributes, Styled},
#       Autocomplete, Replacement,
#       set_global_render_config,
#   };
#
#   // Eight prompt types, each a struct with builder methods:
#   let name = Text::new("Name:")
#       .with_default("Anonymous")
#       .with_placeholder("Your name")
#       .with_help_message("This will be displayed publicly")
#       .with_validator(ValueRequiredValidator::default())
#       .with_validator(MinLengthValidator::new(2))
#       .with_validator(MaxLengthValidator::new(50))
#       .with_formatter(&|s| s.trim().to_string())
#       .prompt()?;
#
#   let pwd = Password::new("Password:")
#       .with_display_mode(PasswordDisplayMode::Masked)
#       .with_validator(MinLengthValidator::new(8))
#       .without_confirmation()
#       .prompt()?;
#
#   let yes = Confirm::new("Continue?")
#       .with_default(true)
#       .with_help_message("y/n")
#       .prompt()?;
#
#   let pick = Select::new("Pick one", vec!["A", "B", "C"])
#       .with_page_size(7)
#       .with_starting_cursor(0)
#       .with_help_message("↑↓ to navigate, enter to select")
#       .prompt()?;
#
#   let picks = MultiSelect::new("Pick many",
#                                vec!["X", "Y", "Z", "W"])
#       .with_default(&[0, 2])
#       .with_page_size(10)
#       .with_validator(|picks: &[ListOption<&_>| ...)
#       .prompt()?;
#
#   let date = DateSelect::new("Birthday:")
#       .with_default(NaiveDate::from_ymd_opt(2000, 1, 1).unwrap())
#       .with_min_date(NaiveDate::from_ymd_opt(1900, 1, 1).unwrap())
#       .with_max_date(NaiveDate::from_ymd_opt(2030, 12, 31).unwrap())
#       .with_help_message("←→ days, PgUp/PgDn months, Home/End years")
#       .prompt()?;
#
#   let port: u16 = CustomType::<u16>::new("Server port:")
#       .with_default(8080)
#       .with_error_message("Must be 1-65535")
#       .with_help_message("Press Enter for 8080")
#       .prompt()?;
#
#   let body: String = Editor::new("Description")
#       .with_predefined_text("Default body...")
#       .with_editor_command(&std::ffi::OsStr::new("vim"))
#       .prompt()?;
#
# CONTRAST WITH OTHER RUST CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * clap / clap-derive          — proc-macro derive argv parser
#   * structopt                   — predecessor of clap-derive
#   * argh (Google)               — derive parser, code-size optimized
#   * gumdrop                     — minimalist derive parser
#   * pico-args                   — hand-rolled minimal argv parser
#   * lexopt                      — iterator-based argv parser
#   * bpaf                        — applicative-functor argv parser
#   * xflags (matklad)            — proc-macro minimal argv parser
#   * argparse (tailhook)         — Python-argparse-style argv parser
#   * seahorse                    — fluent-builder argv parser
#   * docopt.rs                   — USAGE-string-as-spec argv parser
#   * paw                         — argument-wrapping trait argv parser
#   * getopts                     — getopt(3) port argv parser
#   * argfile (R498)              — pre-parser argv preprocessor
#   * argv                        — argument iteration helpers
#   * abscissa (R502)             — application microframework + argv
#   * redox-os/arg-parser         — Redox OS native argv parser
#   * palc (R506)                 — clap-derive drop-in argv parser
#   * cliclack (R510)             — INTERACTIVE-TUI-PROMPT library
#                                    (Clack-port; modern-minimal-aesthetic)
#   * inquire (THIS)              — INTERACTIVE-TUI-PROMPT library
#                                    (TRAIT-BASED EXTENSIBILITY +
#                                    CustomType<T> + Autocomplete trait +
#                                    five-variant error type + eight
#                                    built-in prompt types + per-prompt
#                                    & global RenderConfig theming)
#
# inquire occupies a UNIQUE NICHE — the **MATURE TRAIT-EXTENSIBLE RUST
# INTERACTIVE-PROMPT library**, complementary to cliclack's aesthetic-
# minimalist position.  Where cliclack R510 brings JS-Clack-style
# beautiful prompts to Rust, inquire brings **dialoguer-style
# extensibility with broader prompt-type coverage and richer error
# semantics**.  Both are legitimate choices depending on what the host
# binary prioritizes — aesthetic coherence (cliclack) vs depth of
# prompt-type / validator / autocomplete extensibility (inquire).
#
# REAL-WORLD inquire USERS:
#
#   * spacedriveapp/spacedrive (THIS, 38156*) — open-source cross-
#       platform file explorer; uses inquire for cloud-storage pairing,
#       destructive-confirm prompts, multi-device sync setup
#   * cloudflare/quiche (11529*) — Cloudflare's QUIC/HTTP-3 toolkit;
#       h3i interactive HTTP-3 client uses inquire for prompt-driven
#       request building
#   * mufeedvh/code2prompt (7376*) — codebase-to-LLM-prompt tool; uses
#       inquire for config interactive setup
#   * postgresml/postgresml (6793*) — Postgres + GPU ML; pgml SDK uses
#       inquire for connection setup
#   * russellbanks/Komac (436*) — Community Manifest Creator for WinGet;
#       uses inquire for password input + Confirm + Select flows
#   * clawshell/clawshell (290*) — Runtime Security Layer for OpenClaw/
#       Hermes-agent; uses Confirm, Password, Select, Text plus
#       Autocomplete trait
#   * christo-auer/eilmeldung (840*) — TUI RSS reader; uses inquire
#       in TUI config flow
#   * guywaldman/magic-cli (746*) — AI-driven terminal magician
#
# inquire's adoption pattern: **production Rust CLIs that need
# DEPTH of prompt-type coverage** — Spacedrive (cloud setup wizard),
# Cloudflare quiche (HTTP-3 request building), code2prompt (config),
# postgresml (connection setup), Komac (password + select).  Where
# cliclack is the choice for "beautiful create-X aesthetic", inquire
# is the choice for "I need autocomplete + custom validators + typed
# parsing in my prompts".
#
# -----------------------------------------------------------------------------
# SPACEDRIVE'S CLI SURFACE (verbatim from apps/cli/src/main.rs)
# -----------------------------------------------------------------------------
#
# USAGE:
#   spacedrive [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
# Global options:
#   --data-dir <PATH>             Path to spacedrive data directory
#   --instance <NAME>             Daemon instance name (validated:
#                                  alphanumeric + dash + underscore,
#                                  max 64 chars; prevents path traversal)
#   --format <FORMAT>             Output format: human (default) | json
#                                  | yaml (clap value_enum)
#   -h, --help                    Show help
#       --version                 Show version
#
# Daemon lifecycle:
#   start    [--foreground]                    Start the daemon
#   stop     [--reset]                         Stop (--reset wipes v2 data)
#   restart  [--foreground] [--reset]          Restart (combine flags)
#   status                                     Core info / daemon state
#
# Domain subcommands (each with its own sub-tree — clap-derive
# subcommand structure, with inquire prompts inside for destructive
# operations and interactive flows):
#   config <SUBCOMMAND>           Configuration management
#   daemon <SUBCOMMAND>           Daemon mgmt (auto-start, etc)
#   devices <SUBCOMMAND>          Device operations (library database)
#   events <SUBCOMMAND>           Monitor event bus in real-time
#   library <SUBCOMMAND>          Libraries operations
#   file <SUBCOMMAND>             File operations
#   index <SUBCOMMAND>            Indexing operations
#   location <SUBCOMMAND>         Location operations (sync roots)
#   network <SUBCOMMAND>          Networking and pairing
#   job <SUBCOMMAND>              Job commands (thumbnail-gen, etc.)
#   logs <SUBCOMMAND>             View and follow logs
#   redundancy <SUBCOMMAND>       Cross-volume replication awareness
#   search <SUBCOMMAND>           Search operations
#   spaces <SUBCOMMAND>           Spaces operations (user-defined views)
#   sync <SUBCOMMAND>             Sync operations and metrics
#   tag <SUBCOMMAND>              Tag operations
#   volume <SUBCOMMAND>           Volume operations
#
# Interactive flows (driven by inquire):
#   cloud                         Interactive cloud-storage setup
#                                  (inquire walks user through enrollment
#                                  — region pick, credential entry,
#                                  device naming, encryption confirmation)
#   update [--force]              Update CLI and daemon to latest version
#                                  (inquire confirms destructive update)
#
# Typical usage:
#   $ spacedrive start --foreground            # start daemon w/ logs
#   $ spacedrive status                        # check daemon state
#   $ spacedrive location create /home/user/Photos
#   $ spacedrive search photos --tag holiday-2025
#   $ spacedrive cloud                         # interactive cloud setup
#   $ spacedrive job list                      # show running jobs
#   $ spacedrive sync status
#   $ spacedrive update --force
#
# =============================================================================

_spacedrive() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands formats

    subcommands=(
        'start:start the Spacedrive daemon'
        'stop:stop the Spacedrive daemon'
        'restart:restart the Spacedrive daemon'
        'status:core info / daemon state'
        'config:configuration management'
        'daemon:daemon management'
        'devices:device operations'
        'events:monitor event bus in real-time'
        'library:libraries operations'
        'file:file operations'
        'index:indexing operations'
        'location:location operations'
        'network:networking and pairing'
        'job:job commands'
        'logs:view and follow logs'
        'redundancy:cross-volume replication awareness'
        'search:search operations'
        'spaces:spaces operations'
        'sync:sync operations and metrics'
        'tag:tag operations'
        'volume:volume operations'
        'cloud:interactive cloud-storage setup'
        'update:update CLI and daemon to latest version'
        'help:show help'
    )

    formats=('human:human-readable output' 'json:JSON output' 'yaml:YAML output')

    _arguments -C \
        '--data-dir[path to spacedrive data directory]:dir:_directories' \
        '--instance[daemon instance name]:name:' \
        '--format[output format]:format:->format' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'spacedrive command' subcommands && ret=0
            ;;
        (format)
            _describe -t formats 'output format' formats && ret=0
            ;;
        (args)
            case $line[1] in
                (start|restart)
                    _arguments \
                        '--foreground[run daemon in foreground]' \
                        '--reset[reset all data before restart]' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (stop)
                    _arguments \
                        '--reset[reset all data]' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (update)
                    _arguments \
                        '--force[force update]' \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (status|cloud)
                    _arguments \
                        '(-h --help)'{-h,--help}'[show help]' && ret=0
                    ;;
                (*)
                    # All domain subcommands have their own sub-trees
                    _arguments \
                        '(-h --help)'{-h,--help}'[show help]' \
                        '*: :_default' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_spacedrive "$@"
