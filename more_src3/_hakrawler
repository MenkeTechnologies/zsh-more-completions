#compdef hakrawler
# Documentation: https://github.com/hakluke/hakrawler
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for hakrawler - web crawler for gathering URLs and endpoints.
# Note: Go-style single-dash flags.

local -a arguments

arguments=(
  '-d[crawl depth (default 2)]:depth:'
  '-t[number of threads (default 8)]:threads:'
  '-timeout[maximum seconds per URL from stdin (default -1)]:seconds:'
  '-subs[include subdomains in crawl]'
  '-i[crawl only within the specified path]'
  '-u[display only unique URLs]'
  '-proxy[proxy URL]:proxy URL:'
  '-h[add custom headers (separated by ;;)]:header:'
  '-insecure[skip TLS certificate verification]'
  '-dr[disable HTTP redirect following]'
  '-size[page size limit in KB (default -1)]:kb:'
  '-json[output results as JSON]'
  '-s[show URL origin (href, form, script, ...)]'
  '-w[display which link contains discovered URLs]'
)

_arguments -s -S $arguments
