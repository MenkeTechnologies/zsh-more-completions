#compdef xy2sky
# _xy2sky — convert FITS pixel coordinates to sky coordinates (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from xy2sky.c (single-letter getopt-style).

_xy2sky() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-a[append input line to sky position]' \
        '-b+[initial coords on command line (B1950)]:coords:' \
        '-c+[magnitude conversion coefficients]:coef:' \
        '-d[output degrees instead of HMS/DMS]' \
        '(-e -g)-e[output galactic coordinates]' \
        '(-e -g)-g[output galactic coordinates]' \
        '-f+[face for 3-D projections]:n:' \
        '-h[print column heading]' \
        '-i[first column is star ID]' \
        '-j+[center coords on command line (J2000)]:coords:' \
        '-k+[column for X (Y is next)]:n:' \
        '-l+[output mode for linear coordinates]:mode:' \
        '-m+[column for magnitude]:n:' \
        '-n+[decimal places in output]:n:' \
        '-o+[part of coordinates to output]:part:(ra dec both)' \
        '-p+[initial plate scale (arcsec/pixel)]:scale:' \
        '-q+[equinox for output]:eq:' \
        '-s+[size of image in X and Y pixels]:size:' \
        '-t[output as tab table]' \
        '1:FITS image:_files -g "*.(fits|fit|fts)"' \
        '*:X Y or pixel-list file:_files'
}

_xy2sky "$@"
