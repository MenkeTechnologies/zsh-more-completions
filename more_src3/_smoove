#compdef smoove
# _smoove — Brent Pedersen smoove CLI structural variant calling wrapper around lumpy svtyper duphold mosdepth gsort bcftools running parallel sample-by-sample SV detection then population-level genotyping merging with svtools for cohort-level VCFs annotation duplicate-marking soft-clip exclusion (Brent Pedersen team, Go); cobra
# upstream: https://github.com/brentp/smoove

_smoove() {
    local -a sub=(
        'call:call SVs from BAMs'
        'genotype:genotype SVs with svtyper'
        'merge:merge per-sample VCFs'
        'paste:paste per-sample VCFs'
        'duphold:duphold-based annotation'
        'plot-counts:plot per-sample SV counts'
        'plot-svvcf:plot SV VCF distributions'
        'annotate:annotate SV VCF'
        'cnvnator:run cnvnator integration'
        'hipstr:run HipSTR for STRs'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'smoove subcommand' sub ;;
        args)
            case $words[1] in
                call) _arguments \
                    '-x[do not exclude reads]' \
                    '-f+[fasta]:file:_files -g "*.fa *.fasta"' \
                    '-n+[name]:str:' \
                    '-o+[output dir]:dir:_files -/' \
                    '-e+[exclude bed]:file:_files -g "*.bed *.bed.gz"' \
                    '-p+[processes]:n:' \
                    '-d[duphold annotate]' \
                    '-g[genotype]' \
                    '--removepr[remove PR field]' \
                    '*:bam files:_files -g "*.bam *.cram"' ;;
                genotype) _arguments \
                    '-x[do not exclude reads]' \
                    '-v+[vcf]:file:_files -g "*.vcf *.vcf.gz"' \
                    '-f+[fasta]:file:_files' \
                    '-o+[output vcf]:file:_files' \
                    '-d[duphold]' \
                    '*:bam files:_files -g "*.bam *.cram"' ;;
            esac
            ;;
    esac
}

_smoove "$@"
