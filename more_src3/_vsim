#compdef vsim
# _vsim — Mentor Graphics Siemens ModelSim Questa vsim CLI for the Verilog VHDL SystemVerilog mixed-language simulator launching interactive GUI or batch waves loading do scripts dataset waveform PSL SVA assertion (Mentor team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/

_vsim() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c[run in command-line mode]' \
        '-batch[batch mode]' \
        '-gui[gui mode]' \
        '-quiet[quiet]' \
        '-modelsimini=+[file]:file:_files -g "*.ini modelsim.ini"' \
        '-printsimstats[print simulation stats]' \
        '-novopt[no optimization]' \
        '-vopt[optimization]' \
        '-time[print time]' \
        '-onfinish=+[m]:m:(stop quit final exit)' \
        '-do+[script]:file:_files -g "*.do *.tcl"' \
        '-wlf+[wave log file]:file:_files -g "*.wlf"' \
        '-i+[interactive]' \
        '-coverage[enable coverage]' \
        '-vcdread+[file]:file:_files -g "*.vcd"' \
        '-vcdstim+[file]:file:_files -g "*.vcd"' \
        '-vcoverage+[ucdb]:file:_files -g "*.ucdb"' \
        '-l+[log file]:file:_files' \
        '-logfile=+[log file]:file:_files' \
        '-t+[time resolution]:t:(fs ps ns us ms sec)' \
        '-time-resolution=+[time resolution]:t:(fs ps ns us ms sec)' \
        '-g+[generic mapping]:str:' \
        '-G+[generic top mapping]:str:' \
        '-suppress=+[csv]:str:' \
        '-warning=+[csv]:str:' \
        '-error=+[csv]:str:' \
        '-permit_unmatched_virtual_intf[permit unmatched virtual intf]' \
        '-fsmdebug[FSM debug]' \
        '-pli+[file]:file:_files -g "*.so *.dll"' \
        '-vlsfn=+[file]:file:_files' \
        '-foreign+[function]:str:' \
        '*:design unit:'
}

_vsim "$@"
