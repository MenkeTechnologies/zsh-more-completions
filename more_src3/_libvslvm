#compdef vslvminfo vslvmmount
# _libvslvm — libvslvm tools (libyal LVM2 volume parser; vslvminfo dumps LVM2 PV / VG / LV metadata, vslvmmount FUSE-mounts every logical volume read-only as a per-LV file; -h help, -V version, -v verbose, -o image offset, -X exclusive; positional argument is the PV (block device or image))
# upstream: https://github.com/libyal/libvslvm
# Flags from libyal/libvslvm vslvmtools/vslvminfo.c on tip.

_libvslvm() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-X[exclusive]' \
        '*:PV image:_files'
}

_libvslvm "$@"
