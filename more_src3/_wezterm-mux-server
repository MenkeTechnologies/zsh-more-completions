#compdef wezterm-mux-server
# Documentation: https://wezterm.org/multiplexing.html
# Source: https://github.com/wezterm/wezterm/blob/main/wezterm-mux-server/src/main.rs
# Reference accessed: 2026-06-02
# Multiplexer server daemon for WezTerm.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-n --skip-config)'{-n,--skip-config}'[do not load wezterm.lua]' \
    '(--skip-config)--config-file=[override standard configuration file path]:file:_files -g "*.lua"' \
    '*--config=[override a configuration setting (name=value)]:setting:_default' \
    '--daemonize[detach and run in the background]' \
    '--cwd=[initial working directory for spawned programs]:dir:_files -/' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*:program and args:_command_names -e' \
    && ret=0

return ret
