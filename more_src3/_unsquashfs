#compdef unsquashfs
# Documentation: https://man.archlinux.org/man/unsquashfs.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)'{-h,-help}'[show help summary]' \
  '-help-option[help for matching options]:regex:' \
  '-ho[help for matching options]:regex:' \
  '-help-section[help for section]:section:' \
  '-hs[help for section]:section:' \
  '-help-all[show all help]' \
  '-ha[show all help]' \
  '-no-pager[bypass pager output]' \
  '-cols[output column width]:width:' \
  '(- *)'{-v,-version}'[show version]' \
  {-d,-dest}'[destination directory]:dir:_directories' \
  '-max-depth[limit extraction depth]:levels:' \
  '-excludes[treat extract arguments as exclusions]' \
  {-ex,-exclude-list}'[files to exclude (terminate with ;)]' \
  '-extract-file[list of items to extract]:file:_files' \
  {-e,-ef}'[list of items to extract]:file:_files' \
  '-exclude-file[list of items to exclude]:file:_files' \
  {-exc,-excf}'[list of items to exclude]:file:_files' \
  '-match[abort if extract files do not match]' \
  {-L,-follow,-follow-symlinks}'[follow symlinks during extraction]' \
  {-missing,-missing-symlinks}'[abort on unresolved symlinks]' \
  {-no-wild,-no-wildcards}'[disable wildcard matching]' \
  {-r,-regex}'[POSIX regex matching]' \
  {-all,-all-time}'[set uniform timestamps]:time:' \
  '-cat[output files to stdout]' \
  {-f,-force}'[overwrite existing files]' \
  '-pf[pseudo-file output]:file:_files' \
  '-pseudo-file[pseudo-file output]:file:_files' \
  {-s,-stat}'[display superblock information]' \
  {-i,-info}'[print files during extraction]' \
  {-li,-linfo}'[print files with attributes]' \
  {-l,-ls}'[list without extracting]' \
  {-ll,-lls}'[list with attributes]' \
  {-lln,-llnumeric}'[list with numeric uid/gid]' \
  '-lc[concise listing]' \
  '-llc[concise listing with attributes]' \
  {-full,-full-precision}'[display full timestamps]' \
  '-UTC[use UTC]' \
  '-mkfs-time[show filesystem superblock time]' \
  '-fstime[alias for -mkfs-time]' \
  {-no,-no-xattrs}'[skip extended attributes]' \
  {-x,-xattrs}'[extract extended attributes]' \
  '-xattrs-exclude[exclude matching xattrs]:regex:' \
  '-xattrs-include[include matching xattrs]:regex:' \
  {-p,-processors}'[number of processors]:n:' \
  '-mem[cache memory allocation]:size:' \
  '-mem-percent[cache memory percent]:percent:' \
  {-q,-quiet}'[suppress verbose output]' \
  {-n,-no-progress}'[hide progress bar]' \
  '-percentage[show percentage instead of bar]' \
  {-ig,-ignore-errors}'[treat write errors as non-fatal]' \
  {-st,-strict-errors}'[treat all errors as fatal]' \
  {-no-exit,-no-exit-code}'[do not set exit code on errors]' \
  {-o,-offset}'[skip bytes at filesystem start]:bytes:' \
  '1:squashfs archive:_files' \
  '*:extract pattern:' \
  && ret=0

return ret
