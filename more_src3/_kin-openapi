#compdef kin-openapi
# _kin-openapi — getkin/kin-openapi Go OpenAPI 3 loader/validator/router CLI alias (getkin / Vasiliy Chibanov, Go); custom argparse
# upstream: https://github.com/getkin/kin-openapi

_kin-openapi() {
    local -a sub=(
        'validate:validate OpenAPI 3.x spec'
        'lint:lint OpenAPI 3.x spec'
        'bundle:bundle multi-file spec into one'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--circular=+[circular handling]:c:(allow disallow ignore)' \
        '--no-color[no color]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kin-openapi subcommand' sub ;;
        args)
            case $words[1] in
                validate) _arguments \
                    '--ignore-warnings[ignore warnings]' \
                    '--example-validation[validate examples]' \
                    '--default-validation[validate defaults]' \
                    '--no-pattern-validation[no pattern validation]' \
                    '--no-extra-required-validation[no extra required validation]' \
                    '*:spec:_files -g "*.yaml *.yml *.json"' ;;
                bundle) _arguments \
                    '-o+[output file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '--format=+[format]:fmt:(yaml json)' \
                    '-f+[format]:fmt:(yaml json)' \
                    '*:spec:_files' ;;
                lint) _arguments \
                    '--rules=+[rules file]:file:_files' \
                    '--severity=+[severity]:s:(error warn info)' \
                    '*:spec:_files' ;;
            esac
            ;;
    esac
}

_kin-openapi "$@"
