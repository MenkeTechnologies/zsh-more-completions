#compdef v2raya
# _v2raya — v2rayA Web GUI client for V2Ray Xray Trojan SS Tuic Hysteria Sing-box backends (v2rayA team, Go); standard flag package
# upstream: https://github.com/v2rayA/v2rayA

_v2raya() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[config dir]:dir:_files -/' \
        '--reset-password[reset admin password]' \
        '--lite[use core lite]' \
        '--passcheck[require passcheck]' \
        '--log-file=+[log file]:file:_files' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)' \
        '--log-max-days=+[N]:n:' \
        '--log-disable-color[disable color]' \
        '--log-disable-timestamp[disable timestamp]' \
        '--address=+[bind addr]:str:' \
        '-a+[bind addr]:str:' \
        '--plugin-listen-port=+[port]:port:_ports' \
        '--core-config-path=+[core config dir]:dir:_files -/' \
        '--core-version=+[version]:str:' \
        '--core-name=+[name]:n:(xray v2ray sing-box)' \
        '--enable-tls[enable tls]' \
        '--cert=+[cert file]:file:_files' \
        '--cert-key=+[key file]:file:_files' \
        '--webdir=+[web dir]:dir:_files -/' \
        '--user-agent=+[user agent]:str:' \
        '--vpn[vpn mode]' \
        '--no-update-check[no update check]' \
        '--show-active-link[print active connections]'
}

_v2raya "$@"
