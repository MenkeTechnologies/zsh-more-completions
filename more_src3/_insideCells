#compdef insideCells
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/insideCells — select cells inside a surface mesh as a cellSet (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-region+[region name]:region:_default' \
    '1:surface file:_files -g "*.{stl,obj,nas,vtk,inp}"' \
    '2:cellSet name:_default' \
    && ret=0

return ret
