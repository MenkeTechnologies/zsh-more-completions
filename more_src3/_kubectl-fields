#compdef kubectl-fields
# kubectl-fields (krew plugin): grep for Kubernetes resource fields
# https://github.com/rewanthtammana/kubectl-fields

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '1:resource type' \
  '2:field pattern'
