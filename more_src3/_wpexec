#compdef wpexec
# Documentation: https://www.freedesktop.org/software/pipewire/wireplumber/wpexec.html
# Source: PipeWire/WirePlumber src/tools/wpexec.c — execute a WirePlumber Lua script against the session manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:Lua script file:_files -g "*.lua"' \
    '*:JSON args for script:' \
    && ret=0

return ret
