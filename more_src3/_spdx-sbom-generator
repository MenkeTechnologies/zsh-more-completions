#compdef spdx-sbom-generator
# _spdx-sbom-generator — generate SPDX SBOMs from project package files (spdx/spdx-sbom-generator)
# upstream: https://github.com/spdx/spdx-sbom-generator
# Flags from cmd/generator/generator.go (cobra).

_spdx-sbom-generator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --path)'{-p+,--path=}'[path to package file or directory]:dir:_files -/' \
        '(-i --include-license-text)'{-i,--include-license-text}'[include full license text]' \
        '(-s --schema)'{-s+,--schema=}'[target SPDX schema version]:ver:(2.2 2.3)' \
        '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
        '(-f --format)'{-f+,--format=}'[output file format]:fmt:(spdx json)' \
        '(-g --global-settings)'{-g+,--global-settings=}'[Maven global settings.xml]:file:_files -g "*.xml"'
}

_spdx-sbom-generator "$@"
