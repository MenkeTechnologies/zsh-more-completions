#compdef llvm-cvtres
# _llvm-cvtres — LLVM COFF resource file converter (LLVM project, C++); convert Windows .res into COFF object
# upstream: https://github.com/llvm/llvm-project

_llvm-cvtres() {
    _arguments \
        '/?[show help]' \
        '/help[show help]' \
        '--help[show help]' \
        '/version[show version]' \
        '--version[show version]' \
        '/OUT:+[output file]:file:_files' \
        '/MACHINE:+[machine]:machine:(X64 X86 ARM ARM64 EBC)' \
        '/READONLY[read only]' \
        '/NOLOGO[no logo]' \
        '/VERBOSE[verbose]' \
        '/FOLDDUPS[fold duplicates]' \
        '*:file:_files -g "*.res"'
}

_llvm-cvtres "$@"
