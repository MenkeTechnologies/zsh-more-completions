#compdef kubectl-pgo
# Documentation: https://github.com/CrunchyData/postgres-operator-client
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[kubernetes namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '--server=[kubernetes API server address]:url:' \
  '--token=[bearer token for authentication]:token:' \
  '1:subcommand:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'backup:backup a postgrescluster'
      'create:create a postgrescluster'
      'delete:delete a postgrescluster'
      'restore:restore a postgrescluster'
      'show:show information about a postgrescluster'
      'start:start a postgrescluster'
      'stop:stop a postgrescluster'
      'support:generate a support bundle'
      'version:show pgo version'
    )
    _describe -t commands 'kubectl-pgo command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
