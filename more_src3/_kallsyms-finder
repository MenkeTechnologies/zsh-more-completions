#compdef kallsyms-finder vmlinux-to-elf vmlinuz-decompressor
# Documentation: source-direct extraction from upstream
# marin-m/vmlinux-to-elf pyproject.toml `[project.scripts]`
# entry-point mapping
# (`kallsyms-finder=vmlinux_to_elf.scripts.kallsyms_finder:main`,
# `vmlinux-to-elf=vmlinux_to_elf.scripts.vmlinux_to_elf:main`,
# `vmlinuz-decompressor=vmlinux_to_elf.scripts.vmlinuz_decompressor:main`)
# + each script's argparse `args.add_argument(...)` calls.
# Reference accessed: 2026-05-30 via gh api.
# marin-m vmlinux-to-elf R144b — 3-stem multi-binary harvest of
# the 3 CLI binaries from vmlinux-to-elf, an analysis-friendly
# extractor for Linux kernel binaries (vmlinux/vmlinuz/zImage)
# that decompresses and produces an ELF + symbol table consumable
# by Ghidra/IDA/radare2. The 4th entry-point `vmlinux-to-elf-gui`
# is a Gtk app that this completion intentionally omits since it
# takes no CLI args. Sister tool to the heavily-covered
# reverse-engineering family (ghidra/cutter/rizin/binwalk/binsider).

case $service in

  kallsyms-finder)
    # Find and decode the kallsyms symbol table embedded inside a
    # vmlinux/vmlinuz file. Smaller-surface subset of vmlinux-to-elf
    # for symbol-only extraction.
    _arguments -s -S \
      '--base-address=[force-override input kernel base address (hex; default auto)]:hex:' \
      '--bit-size=[force-override kernel bit size]:bits:(32 64)' \
      '--extra-info[print extra info while parsing]' \
      '--output=[output file for the decoded symbol table]:file:_files' \
      '--use-absolute[use absolute addresses instead of base-address relative]' \
      '1:input vmlinux/vmlinuz/zImage file:_files'
    ;;

  vmlinux-to-elf)
    # Main extractor: takes a Linux kernel image and emits an
    # analyzable ELF (with symbols) for use in disassemblers.
    _arguments -s -S \
      '--e-machine=[force-override output ELF e_machine value]:numeric:' \
      '--bit-size=[force-override input kernel bit size]:bits:(32 64)' \
      '--file-offset=[byte offset within input file where raw kernel starts]:bytes:' \
      '--base-address=[force-override output ELF base address (hex)]:hex:' \
      '--bss-size=[force-override BSS segment size]:bytes:' \
      '--extra-info[print extra info while parsing]' \
      '--use-absolute[use absolute addresses instead of base-address relative]' \
      '1:input vmlinux/vmlinuz/zImage file:_files' \
      '2:output ELF file:_files'
    ;;

  vmlinuz-decompressor)
    # Standalone decompressor for vmlinuz/zImage that emits the
    # raw vmlinux blob without ELF wrapping or symbol extraction.
    # Minimal: 2 positional args, no flags.
    _arguments -s -S \
      '1:input vmlinuz/zImage file:_files' \
      '2:output decompressed file:_files'
    ;;

esac
