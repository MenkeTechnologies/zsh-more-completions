#compdef symkeyutil
# Documentation: man symkeyutil(1)
# Source: nss-dev/nss cmd/symkeyutil/symkeyutil.c (master) — NSS symmetric key utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-L -K -D -I -E -U -W -M -H)-L[list all keys]' \
    '(-L -K -D -I -E -U -W -M -H)-K[generate a new key]' \
    '(-L -K -D -I -E -U -W -M -H)-D[delete a key]' \
    '(-L -K -D -I -E -U -W -M -H)-I[import a new key from data file]' \
    '(-L -K -D -I -E -U -W -M -H)-E[export key to data file]' \
    '(-L -K -D -I -E -U -W -M -H)-U[unwrap a key from data file]' \
    '(-L -K -D -I -E -U -W -M -H)-W[wrap a key into data file]' \
    '(-L -K -D -I -E -U -W -M -H)-M[move key to a new token]' \
    '(-L -K -D -I -E -U -W -M -H)-H[show long help]' \
    '-n+[nickname of the key]:name:_default' \
    '-i+[hex key id]:hex:_default' \
    '-j+[file with key id]:file:_files' \
    '-t+[key type]:type:(generic des cdmf des3 aes camellia camellia256 aes256 rc2 rc4 hmac)' \
    '-s+[key size in bytes]:size:_default' \
    '-k+[data file for key]:file:_files' \
    '-w+[wrap by nickname]:name:_default' \
    '-x+[wrap by id (hex)]:hex:_default' \
    '-y+[wrap id from file]:file:_files' \
    '-g+[target token for move]:token:_default' \
    '-r[output raw key material]' \
    '-d+[NSS cert database directory]:dir:_files -/' \
    '-P+[database prefix]:prefix:_default' \
    '-p+[password literal]:password:_default' \
    '-f+[password file]:file:_files' \
    '-h+[token name]:token:_default' \
    && ret=0

return ret
