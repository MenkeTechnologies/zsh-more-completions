#compdef tdf
# Documentation: https://github.com/itsjunetime/tdf (src/main.rs xflags)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tdf: terminal-based PDF viewer (also supports epub/cbz with features)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-r --r-to-l)'{-r,--r-to-l}'[display pages right-to-left]' \
  '(-m --max-wide)'{-m+,--max-wide=}'[max pages shown horizontally]:n:' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen mode]' \
  '--reload-delay=[file change debounce in ms]:ms:' \
  '(-p --prerender)'{-p+,--prerender=}'[number of pages to prerender]:n:' \
  '(-w --white-color)'{-w+,--white-color=}'[custom white color (CSS)]:color:' \
  '(-b --black-color)'{-b+,--black-color=}'[custom black color (CSS)]:color:' \
  '--version[print version and exit]' \
  '1:file:_files -g "*.(pdf|epub|cbz)"' && ret=0

return ret
