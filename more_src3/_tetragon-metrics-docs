#compdef tetragon-metrics-docs
# _tetragon-metrics-docs — generate Markdown docs for Tetragon Prometheus metrics (cilium/tetragon)
# upstream: https://github.com/cilium/tetragon
# Targets from cmd/tetragon-metrics-docs/main.go; cobra arg from isovalent/metricstool metricsmd.NewCmd.

_tetragon-metrics-docs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:target:(health resources events)'
}

_tetragon-metrics-docs "$@"
