#compdef rollup
# Documentation: https://rollupjs.org/command-line-interface/
# Source: rollup ES-module bundler CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[use a config file (rollup.config.{mjs,cjs,js})]:config:_files' \
    '-d[directory for chunks output]:dir:_directories' \
    '-e[comma-separated module IDs to exclude]:ids:' \
    '-f[output format]:fmt:(amd cjs es iife umd system)' \
    '-g[module-globals as id:Global pairs (comma-separated)]:globals:' \
    '(- *)-h[show help]' \
    '-i[input file]:file:_files' \
    '-m[generate sourcemap]' \
    '-n[UMD export name]:name:' \
    '-o[single output file]:file:_files' \
    '*-p[plugin to use]:plugin:' \
    '(- *)-v[show version]' \
    '-w[watch and rebuild on changes]' \
    '--amd.autoId[auto AMD id from chunk name]' \
    '--amd.basePath=[AMD id prefix]:prefix:' \
    '--amd.define=[use given function in place of define]:name:' \
    '--amd.forceJsExtensionForImports[use .js extension in AMD imports]' \
    '--amd.id=[AMD module id]:id:' \
    '--assetFileNames=[name pattern for emitted assets]:pattern:' \
    '--banner=[code at top of bundle (outside wrapper)]:text:' \
    '--bundleConfigAsCjs[force config to transpile to CommonJS]' \
    '--chunkFileNames=[name pattern for secondary chunks]:pattern:' \
    '--compact[minify wrapper code]' \
    '--configImportAttributesKey=[import-attributes keyword]:kw:(with assert)' \
    '--configPlugin=[plugin for config-file transpile/parse]:plugin:' \
    '--context=[top-level this value]:variable:' \
    '--entryFileNames=[name pattern for entry chunks]:pattern:' \
    '--environment=[settings passed to config via process.ENV]:values:' \
    '--exports=[export mode]:mode:(auto default named none)' \
    '--extend[extend global from --name]' \
    '--failAfterWarnings[non-zero exit on build warnings]' \
    '--filterLogs=[filter log messages]:filter:' \
    '--footer=[code at end of bundle (outside wrapper)]:text:' \
    '--forceExit[force process exit when done]' \
    '--generatedCode=[code features]:preset:(es5 es2015)' \
    '--generatedCode.arrowFunctions[emit arrow functions]' \
    '--generatedCode.constBindings[emit const bindings]' \
    '--generatedCode.objectShorthand[emit shorthand properties]' \
    '--generatedCode.symbols[emit symbols]' \
    '--hashCharacters=[hash character set]:set:' \
    '--importAttributesKey=[import-attributes keyword]:kw:' \
    '--inlineDynamicImports[single bundle with dynamic imports]' \
    '--intro=[code at top of bundle (inside wrapper)]:text:' \
    '--logLevel=[log level]:level:(silent error warn info debug)' \
    '--maxParallelFileOps=[parallel file-read count]:n:' \
    '--minifyInternalExports[force/disable internal exports minification]' \
    '--noConflict[generate noConflict for UMD globals]' \
    '--outro=[code at end of bundle (inside wrapper)]:text:' \
    '--perf[display performance timings]' \
    '--preserveModules[preserve module structure]' \
    '--preserveModulesRoot=[root for preserved modules]:path:' \
    '--preserveSymlinks[do not follow symlinks]' \
    '--shimMissingExports[shim variables for missing exports]' \
    '--silent[do not print warnings]' \
    '--sourcemapBaseUrl=[absolute sourcemap base URL]:url:' \
    '--sourcemapDebugIds[emit unique debug ids]' \
    '--sourcemapExcludeSources[no source code in source maps]' \
    '--sourcemapFile=[bundle position for sourcemap]:file:_files' \
    '--sourcemapFileNames=[sourcemap name pattern]:pattern:' \
    '--stdin=[stdin file extension]:ext:' \
    '--strictDeprecations[throw on deprecated features]' \
    '--validate[validate output]' \
    '--waitForBundleInput[wait for input files to be available]' \
    '--watch.allowInputInsideOutputPath[allow input under output]' \
    '--watch.buildDelay=[throttle watch rebuilds]:ms:' \
    '*--watch.exclude=[exclude files from watching]:glob:' \
    '*--watch.include=[limit watching to files]:glob:' \
    '--watch.onBundleEnd=[shell command on BUNDLE_END]:cmd:' \
    '--watch.onBundleStart=[shell command on BUNDLE_START]:cmd:' \
    '--watch.onEnd=[shell command on END]:cmd:' \
    '--watch.onError=[shell command on ERROR]:cmd:' \
    '--watch.onStart=[shell command on START]:cmd:' \
    '--watch.skipWrite[no disk writes when watching]' \
    '--no-treeshake[disable tree-shaking]' \
    '--no-strict[do not emit "use strict"]' \
    '--no-indent[do not indent result]' \
    '--no-interop[no interop block]' \
    '--no-esModule[no __esModule property]' \
    '--no-freeze[do not freeze namespace objects]' \
    '*:input file:_files' \
    && ret=0

return ret
