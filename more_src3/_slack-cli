#compdef slack-cli slack
# Documentation: https://docs.slack.dev/tools/slack-cli/reference/commands/slack
# Reference accessed: 2026-05-21
# Verified: upstream Slack CLI command reference at the URL above.
# Removed prior fake subcommands (chat, file, presence, reminder, snooze,
# status, init/help-only) that came from a different "slack-cli"; the
# official Slack platform CLI uses the commands below.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'app:install, uninstall, and manage team installations'
  'auth:handle local team authorizations'
  'collaborator:manage app collaborators'
  'create:generate a new Slack project'
  'datastore:interact with app data storage'
  'delete:remove the app'
  'deploy:push the app to the Slack Platform'
  'docs:access developer documentation'
  'doctor:diagnose system and app information'
  'env:manage environment variables'
  'external-auth:configure external authentication providers'
  'feedback:submit experience feedback'
  'function:administer app functions'
  'init:set up a project for CLI use'
  'install:deploy app to a team'
  'list:display authorized accounts'
  'login:authenticate to Slack'
  'logout:sign out from a team'
  'manifest:display app configuration'
  'platform:deploy and execute apps on Slack Platform'
  'project:create and maintain projects'
  'run:start local development server'
  'samples:browse sample applications'
  'sandbox:manage developer sandboxes'
  'trigger:examine trigger details'
  'uninstall:remove app from a team'
  'upgrade:check for CLI updates'
  'version:display version information'
)

_arguments -C \
  '--accessible[enable accessible prompts]' \
  '(-a --app)'{-a,--app}'[app ID or environment]:app:' \
  '--config-dir[custom config directory]:dir:_directories' \
  '(-e --experiment)'{-e,--experiment}'[enable experimental features]:feature:' \
  '(-f --force)'{-f,--force}'[bypass warnings]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-color[remove formatting from output]' \
  '(-s --skip-update)'{-s,--skip-update}'[skip version check]' \
  '(-w --team)'{-w,--team}'[workspace name or ID]:team:' \
  '--token[access token]:token:' \
  '(-v --verbose)'{-v,--verbose}'[enable debug logging]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'slack subcommand' subcommands && ret=0
    ;;
esac

return ret
