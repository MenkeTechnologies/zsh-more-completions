#compdef hexedit
# _hexedit — Pixel/hexedit (curses-based hex viewer/editor for binary files; -m fits the file to one screen, -s sector mode (read raw block device), -b BSD-style decimal addresses, -v print version + exit; positional file argument required)
# upstream: https://github.com/pixel/hexedit
# Flags from hexedit hexedit.c on tip.

_hexedit() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-m[try to fit file on one screen]' \
        '-s[treat target as raw sector device]' \
        '-b[BSD-style decimal addresses]' \
        '1:file:_files'
}

_hexedit "$@"
