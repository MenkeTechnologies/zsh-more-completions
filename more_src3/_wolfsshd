#compdef wolfsshd
# Documentation: https://github.com/wolfSSL/wolfssh/blob/master/apps/wolfsshd/wolfsshd.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# wolfsshd: SSH server daemon from wolfSSL.
# Flags verified from ShowUsage() / mygetopt() in apps/wolfsshd/wolfsshd.c.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-\?[display help and exit]' \
  '-f+[configuration file (default /etc/ssh/sshd_config)]:file:_files' \
  '-p+[port number to listen on]:port:' \
  '-d[enable debug mode]' \
  '-D[run in foreground (do not daemonize)]' \
  '-h+[host private key file]:file:_files' \
  '-E+[append to log file]:file:_files' \
  '-o[ignore unknown configuration options]' \
  '-t[test mode]' \
  '-r+[Windows-only: run command in console setup]:command:' && ret=0
return ret
