#compdef ewfacquire ewfacquirestream ewfexport ewfinfo ewfmount ewfrecover ewfverify
# _libewf — libewf tools (Joachim Metz libyal Expert-Witness Compression Format / EnCase image suite; ewfacquire creates evidence files, ewfacquirestream pipes a stream, ewfexport converts to raw/dd, ewfinfo dumps metadata, ewfmount FUSE-mounts an .e01, ewfrecover repairs broken images, ewfverify verifies integrity hashes; common flags -h help, -V version, -v verbose, -c compression (none|empty|fast|best), -C case number, -D description, -e examiner, -E evidence number, -f format (encase1..7|ftk|smart|raw|ewf|encase6+|encase7), -t target prefix, -p offset, -S segment-file size, -d digest type list (sha1|sha256|md5), -j additional jobs)
# upstream: https://github.com/libyal/libewf
# Common flags from libyal/libewf ewftools/*.c on tip.

_libewf() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[compression]:method:(none empty fast best)' \
        '-C+[case number]:case:' \
        '-D+[description]:desc:' \
        '-e+[examiner]:examiner:' \
        '-E+[evidence number]:evidence:' \
        '-f+[format]:format:(encase1 encase2 encase3 encase4 encase5 encase6 encase7 encase7-v2 ftk smart raw ewf)' \
        '-t+[target prefix]:prefix:' \
        '-p+[offset]:bytes:' \
        '-S+[segment file size]:bytes:' \
        '-d+[digest types csv]:csv:(sha1 sha256 md5)' \
        '-j+[jobs]:n:' \
        '-A+[adler32 hash]:hash:' \
        '-N+[note]:note:' \
        '*:image file:_files'
}

_libewf "$@"
