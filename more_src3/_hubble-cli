#compdef hubble-cli
# _hubble-cli — Cilium Hubble network observability CLI alias (Cilium project, Go); spf13/cobra
# upstream: https://github.com/cilium/hubble

_hubble-cli() {
    local -a sub=(
        'observe:observe events'
        'status:show hubble status'
        'config:manage hubble config'
        'list:list resources'
        'reflect:reflect grpc service'
        'watch:watch events'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files' \
        '--server=+[hubble server addr]:addr:' \
        '--port-forward[automatically port-forward]' \
        '--port-forward-port=+[port forward port]:port:' \
        '--basic-auth-username=+[basic auth user]:str:_users' \
        '--basic-auth-password=+[basic auth password]:str:' \
        '--basic-auth-password-file=+[basic auth password file]:file:_files' \
        '--debug[debug]' \
        '--tls[use TLS]' \
        '--tls-server-name=+[tls server name]:host:_hosts' \
        '--tls-allow-insecure[skip tls verify]' \
        '--tls-ca-cert-files=+[tls CA cert]:file:_files' \
        '--tls-client-cert-file=+[tls client cert]:file:_files' \
        '--tls-client-key-file=+[tls client key]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hubble subcommand' sub ;;
        args)
            case $words[1] in
                observe) _arguments \
                    '--follow[follow]' \
                    '-f[follow]' \
                    '--last=+[show last n]:n:' \
                    '--since=+[since]:dur:' \
                    '--until=+[until]:dur:' \
                    '--all[show all flows]' \
                    '--first=+[first n]:n:' \
                    '--print-raw-filters[print raw filters]' \
                    '--output=+[output format]:fmt:(table compact dict json jsonpb)' \
                    '-o+[output format]:fmt:(table compact dict json jsonpb)' \
                    '--from-fqdn=+[from fqdn]:fqdn:_hosts' \
                    '--to-fqdn=+[to fqdn]:fqdn:_hosts' \
                    '--from-ip=+[from ip]:ip:' \
                    '--to-ip=+[to ip]:ip:' \
                    '--from-pod=+[from pod]:pod:' \
                    '--to-pod=+[to pod]:pod:' \
                    '--from-namespace=+[from namespace]:ns:' \
                    '--to-namespace=+[to namespace]:ns:' \
                    '--from-service=+[from service]:svc:' \
                    '--to-service=+[to service]:svc:' \
                    '--protocol=+[protocol]:proto:(tcp udp icmp http dns)' \
                    '--port=+[port]:port:' \
                    '--verdict=+[verdict]:v:(FORWARDED DROPPED ERROR AUDIT REDIRECTED TRACED)' \
                    '--type=+[event type]:t:(drop trace l7 agent-event policy-verdict debug)' ;;
                list) _arguments \
                    '1:resource:(nodes namespaces)' ;;
                config) _arguments \
                    '1:cmd:(get set reset view)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_hubble-cli "$@"
