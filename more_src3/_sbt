#compdef sbt
# Documentation: https://github.com/sbt/sbt-launcher-package (src/universal/bin/sbt)
#                + https://www.scala-sbt.org/1.x/docs/Command-Line-Reference.html
# Reference accessed: 2026-05-29
# sbt — Scala/Java build tool (launcher script + interactive shell).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage]' \
  '(- *)'{-V,--version}'[show sbt version]' \
  '(- *)--numeric-version[print only the numeric sbt version]' \
  '(- *)--script-version[print the sbt script version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose runner output]' \
  '(-d --debug)'{-d,--debug}'[set sbt logging level to debug]' \
  '--debug-inc[extra debugging for incremental compiler]' \
  '--no-colors[disable ANSI color codes]' \
  '--color=[control ANSI colors]:mode:(auto always true false never)' \
  '--supershell=[supershell feature]:mode:(auto always true false never)' \
  '--traces[generate trace event report on shutdown]' \
  '--timings[display task timings report on shutdown]' \
  '--sbt-create[start sbt even without an sbt project]' \
  '--sbt-dir=[global settings/plugins directory]:dir:_directories' \
  '--sbt-boot=[shared boot directory]:dir:_directories' \
  '--ivy=[local Ivy repository path]:dir:_directories' \
  '--mem=[JVM memory in megabytes]:mb:' \
  '--no-share[use only local caches]' \
  '--no-global[use global caches but not ~/.sbt]' \
  '--jvm-debug=[enable JVM debugging on port]:port:' \
  '--batch[disable interactive mode]' \
  '--sbt-version=[sbt version to use]:version:' \
  '--sbt-jar=[custom sbt launcher jar]:file:_files -g "*.jar"' \
  '--java-home=[alternate JAVA_HOME]:dir:_directories' \
  '*-J+[forward option to the JVM (e.g. -J-Xmx2g)]:JVM option:' \
  '*-D+[forward system property to the JVM (e.g. -Dfoo=bar)]:key=value:' \
  '*:: :->cmd' && ret=0

case $state in
  cmd)
    local -a _cmds
    _cmds=(
      'compile:compile the project sources'
      'test:run the test suite'
      'testOnly:run only specified tests'
      'testQuick:run only previously-failing tests'
      'run:run the main class'
      'runMain:run a specific main class'
      'clean:remove all generated files'
      'console:start the Scala REPL with project classpath'
      'consoleQuick:Scala REPL without prior project compilation'
      'consoleProject:Scala REPL with sbt definition classpath'
      'package:package classes into a JAR'
      'packageBin:package main classes into a JAR'
      'packageSrc:package sources into a JAR'
      'packageDoc:package generated docs into a JAR'
      'publish:publish artifacts to repository'
      'publishLocal:publish artifacts to local Ivy cache'
      'publishM2:publish artifacts to local Maven cache'
      'doc:generate Scaladoc'
      'reload:reload the build definition'
      'update:resolve dependencies and update lock'
      'updateClassifiers:update sources/javadoc classifiers'
      'dependencyTree:show resolved dependency tree'
      'projects:list available projects'
      'project:switch project context (project <id>)'
      'inspect:show setting metadata and values'
      'show:show value of setting/task'
      'set:apply temporary setting change'
      'session:manage current session settings'
      'eval:evaluate Scala code at the prompt'
      'help:show detailed help for a command'
      'about:show sbt + Scala versions'
      'tasks:list available tasks'
      'settings:list available settings'
      'plugins:list installed plugins'
      'sbtVersion:show sbt version'
      'scalaVersion:show Scala version'
      'crossScalaVersions:list cross Scala versions'
      'exit:exit sbt'
      'quit:exit sbt'
      '+:run command across all cross Scala versions (+ <cmd>)'
      '++:temporarily switch Scala version (++ <ver> <cmd>)'
      '~:re-run command on file change (~ <cmd>)'
    )
    _describe -t commands 'sbt command' _cmds && ret=0
    ;;
esac

return ret
