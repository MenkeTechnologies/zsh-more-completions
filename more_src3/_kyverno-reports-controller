#compdef kyverno-reports-controller reports-controller
# _kyverno-reports-controller — Kyverno PolicyReport aggregator (kyverno/kyverno)
# upstream: https://github.com/kyverno/kyverno
# Flags from cmd/reports-controller/main.go + cmd/internal/flag.go on tip.

_kyverno-reports-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--backgroundScan=[enable background scan]:bool:(true false)' \
        '--admissionReports=[enable admission reports]:bool:(true false)' \
        '--aggregateReports=[enable aggregated PolicyReports]:bool:(true false)' \
        '--policyReports=[enable PolicyReports]:bool:(true false)' \
        '--validatingAdmissionPolicyReports=[enable VAP reports]:bool:(true false)' \
        '--mutatingAdmissionPolicyReports=[enable MAP reports]:bool:(true false)' \
        '--aggregationWorkers=[ephemeral report aggregation workers]:n:' \
        '--backgroundScanWorkers=[background scan workers]:n:' \
        '--backgroundScanInterval=[background scan interval]:dur:' \
        '--maxQueuedEvents=[max queued events]:n:' \
        '--omitEvents=[comma-sep event types to suppress]:list:' \
        '--skipResourceFilters=[ignore resource filters]:bool:(true false)' \
        '--apiCallTimeout=[policy HTTP API call timeout]:dur:' \
        '--maxBackgroundReports=[max ephemeral reports cap]:n:' \
        '--reportsCRDsSanityChecks=[sanity-check PolicyReport CRDs at start]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--clientRateLimitQPS=[Kubernetes client QPS]:f:' \
        '--clientRateLimitBurst=[Kubernetes client burst]:n:' \
        '--resyncPeriod=[informer resync period]:dur:' \
        '--profile[enable pprof]' \
        '--profilePort=[pprof port]:port:' \
        '--metricsHost=[Prometheus metrics bind host]:host:' \
        '--metricsPort=[Prometheus metrics bind port]:port:' \
        '--enableTracing[enable OTLP tracing]' \
        '--loggingFormat=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:'
}

_kyverno-reports-controller "$@"
