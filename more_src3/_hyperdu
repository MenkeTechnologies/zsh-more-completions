#compdef hyperdu
# Documentation: https://github.com/automationjp/HyperDiskUsage
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hyperdu — fast parallel disk-usage scanner (automationjp/HyperDiskUsage)

_arguments -s -S \
  '(-t --top)'{-t,--top}'[show top N entries]:number' \
  '(-e --exclude)'{-e,--exclude}'[comma-separated exclude patterns]:patterns' \
  '--exclude-from[read excludes from file]:file:_files' \
  '(-d --max-depth)'{-d,--max-depth}'[max recursion depth]:depth' \
  '(-m --min-file-size)'{-m,--min-file-size}'[min file size in bytes]:bytes' \
  '(-f --follow-links)'{-f,--follow-links}'[follow symlinks]' \
  '--one-file-system[stay on one filesystem]' \
  '--logical-only[logical sizes only]' \
  '--approximate[approximate sizes]' \
  '--compat=[compatibility mode]:mode:(gnu)' \
  '--apparent-size[use apparent size]' \
  '--perf=[performance profile]:mode:(turbo)' \
  '--threads=[worker thread count]:n' \
  '--time[show time]' \
  '--time-kind=[time kind]:kind' \
  '--time-style=[time style]:style' \
  '--csv=[write CSV to path]:file:_files' \
  '--json=[write JSON to path]:file:_files' \
  '--progress[show scan progress]' \
  '--progress-every=[progress update frequency]:n' \
  '--no-uring[disable io_uring]' \
  '--uring-sqpoll[enable SQPOLL]' \
  '--uring-sqpoll-idle-ms=[SQPOLL idle timeout]:ms' \
  '--uring-sqpoll-cpu=[pin SQPOLL thread to CPU]:cpu' \
  '--uring-coop[enable cooperative taskrun]' \
  '--classify=[classification]:mode:(basic deep)' \
  '--incremental-db=[snapshot database path]:file:_files' \
  '--compute-delta[compare with database]' \
  '--update-snapshot[update database state]' \
  '--watch[monitor file changes]' \
  '--tune-log[live tuning logs]' \
  '--tune-threshold=[tuning threshold]:n' \
  '--tune-only[recommendations only]' \
  '--tune-secs=[tuning duration]:seconds' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:directory:_files -/'
