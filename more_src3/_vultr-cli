#compdef vultr-cli
# _vultr-cli — Vultr Cloud CLI (Vultr, Go); manage Vultr Cloud resources
# upstream: https://github.com/vultr/vultr-cli

_vultr-cli() {
    local -a sub=(
        'account:account info'
        'application:applications'
        'backups:backups'
        'bare-metal:bare metal servers'
        'billing:billing'
        'block-storage:block storage volumes'
        'completion:print shell completion'
        'container-registry:container registry'
        'database:databases'
        'dns:DNS'
        'firewall:firewall groups'
        'iso:ISOs'
        'instance:instances'
        'kubernetes:VKE clusters'
        'load-balancer:load balancers'
        'object-storage:object storage'
        'operating-systems:OS images'
        'plans:plans'
        'plans-metal:bare metal plans'
        'regions:regions'
        'reserved-ip:reserved IPs'
        'script:startup scripts'
        'snapshot:snapshots'
        'ssh:SSH keys'
        'user:sub-users'
        'vpc:VPCs'
        'vpc2:VPC 2.0'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--config+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--output+[output format]:fmt:(json yaml)' \
        '-o+[output format]:fmt:' \
        '--persistent+[persist config]:bool:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'vultr subcommand' sub ;;
        args)
            case $words[1] in
                instance) _arguments '1:instance cmd:(create delete halt list reboot reinstall restart-recovery-mode restore start tags update update-firewall-group)' '*:id:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_vultr-cli "$@"
