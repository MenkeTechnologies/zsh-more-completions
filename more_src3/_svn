#compdef svn
# Documentation: svn help
# Source: Apache Subversion — command-line client.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'add:put files and directories under version control'
    'auth:manage cached authentication credentials'
    'blame:show authorship for each line; aliases praise/annotate/ann'
    'cat:print contents of targeted files'
    'changelist:associate or disassociate files; alias cl'
    'checkout:check out a working copy from a repository; alias co'
    'cleanup:recover state of a working copy'
    'commit:send changes to the repository; alias ci'
    'copy:duplicate something while preserving history; alias cp'
    'delete:remove files and directories; aliases del/remove/rm'
    'diff:display the differences between revisions; alias di'
    'export:create unversioned copy of a tree'
    'help:show help; aliases ?/h'
    'import:commit files into the repository'
    'info:display info about a local or remote item'
    'list:list directory entries; alias ls'
    'lock:lock working copy paths or URLs'
    'log:show log messages for a set of revisions'
    'merge:apply differences between two sources'
    'mergeinfo:display merge-related information'
    'mkdir:create a new directory under version control'
    'move:move and rename a file or directory; aliases mv/rename/ren'
    'patch:apply a patch file'
    'propdel:remove a property; aliases pdel/pd'
    'propedit:edit a property with an editor; aliases pedit/pe'
    'propget:print value of a property; aliases pget/pg'
    'proplist:list properties on files/dirs/URLs; aliases plist/pl'
    'propset:set a property on files/dirs/URLs; aliases pset/ps'
    'relocate:relocate the working copy to a new repository URL'
    'resolve:remove conflicts on working copy files'
    'resolved:remove conflicted state on working copy files (deprecated)'
    'revert:restore pristine working copy state'
    'status:show status of working copy files; alias stat/st'
    'switch:update working copy to a different URL; alias sw'
    'unlock:unlock working copy paths or URLs'
    'update:bring changes from repository into working copy; alias up'
    'upgrade:upgrade working copy to a newer format'
)

_arguments -C \
    '(- *)--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '--verbose[print extra information]' \
    '--quiet[print as little as possible]' \
    '--non-interactive[do not prompt for input]' \
    '--username=[user]:user:' \
    '--password=[password]:password:' \
    '--no-auth-cache[do not cache auth tokens]' \
    '--trust-server-cert[accept SSL server certificates from unknown CAs]' \
    '--config-dir=[runtime config directory]:dir:_files -/' \
    '*--config-option=[set a runtime config option]:section:option=value:' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd) _describe -t svn-verbs 'svn subcommand' verbs && ret=0 ;;
    args) _files && ret=0 ;;
esac

return ret
