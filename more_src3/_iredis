#compdef iredis
# Documentation: https://github.com/laixintao/iredis/blob/master/iredis/entry.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for iredis - interactive Redis client

_arguments \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-h+[server hostname]:host:_hosts' \
  '-p+[server port]:port:' \
  '(-s --socket)'{-s,--socket=}'[server socket]:file:_files' \
  '-n+[database number]:database:' \
  '(-u --username)'{-u,--username=}'[user name for authentication]:username:_users' \
  '(-a --password)'{-a,--password=}'[password for server connection]:password:' \
  '--url=[Redis URL for connection]:url:' \
  '(-d --dsn)'{-d,--dsn=}'[DSN configured in iredisrc file]:dsn:' \
  '--newbie[show command hints and helpful information]' \
  '--no-newbie[disable newbie mode]' \
  '--iredisrc=[configuration file path]:file:_files' \
  '--decode=[decode response encoding]:encoding:' \
  '--client_name=[assign a name to the connection]:name:' \
  '--raw[use raw formatting for replies]' \
  '--no-raw[disable raw formatting]' \
  '--rainbow[display colorful prompt]' \
  '--no-rainbow[disable colorful prompt]' \
  '--shell[allow shell command execution]' \
  '--no-shell[disable shell command execution]' \
  '--pager[use pager for tall output]' \
  '--no-pager[disable pager]' \
  '--greetings[enable greeting messages]' \
  '--no-greetings[disable greeting messages]' \
  '--verify-ssl=[TLS certificate verification strategy]:strategy:(none optional required)' \
  '--prompt=[custom prompt format]:format:' \
  '--natmap=[NAT map for Redis cluster behind SSH tunnels]:natmap:'
