#compdef jest-cli
# _jest-cli — Meta Jest JavaScript testing framework CLI alias (Meta / Facebook, JavaScript); custom argparse via yargs
# upstream: https://github.com/jestjs/jest

_jest-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--all[run all tests]' \
        '--automock[automock]' \
        '--bail=+[bail after N failures]:n:' \
        '-b+[bail after N failures]:n:' \
        '--cache[use cache]' \
        '--no-cache[no cache]' \
        '--cacheDirectory=+[cache directory]:dir:_files -/' \
        '--ci[CI mode]' \
        '--clearCache[clear cache]' \
        '--clearMocks[clear mocks]' \
        '--collectCoverage[collect coverage]' \
        '--collectCoverageFrom=+[collect coverage from]:list:' \
        '--colors[force colors]' \
        '--config=+[config file]:file:_files -g "jest.config.* *.json"' \
        '-c+[config file]:file:_files -g "jest.config.* *.json"' \
        '--coverage[collect coverage]' \
        '--coverageDirectory=+[coverage directory]:dir:_files -/' \
        '--coverageProvider=+[coverage provider]:p:(babel v8)' \
        '--coverageReporters=+[coverage reporters]:list:' \
        '--coverageThreshold=+[coverage threshold json]:str:' \
        '--debug[debug]' \
        '--detectLeaks[detect leaks]' \
        '--detectOpenHandles[detect open handles]' \
        '--env=+[environment]:str:' \
        '--errorOnDeprecated[error on deprecated]' \
        '--expand[expand assertion failures]' \
        '-e[expand assertion failures]' \
        '--findRelatedTests[find related tests]' \
        '--forceExit[force exit]' \
        '--globalSetup=+[global setup]:file:_files' \
        '--globalTeardown=+[global teardown]:file:_files' \
        '--globals=+[globals]:str:' \
        '--haste=+[haste config]:str:' \
        '--init[init config]' \
        '--injectGlobals[inject globals]' \
        '--json[json output]' \
        '--lastCommit[last commit tests]' \
        '--listTests[list tests]' \
        '--logHeapUsage[log heap usage]' \
        '--maxConcurrency=+[max concurrency]:n:' \
        '--maxWorkers=+[max workers]:n:' \
        '-w+[max workers]:n:' \
        '--moduleDirectories=+[module directories]:list:' \
        '--moduleFileExtensions=+[module file extensions]:list:' \
        '--moduleNameMapper=+[module name mapper]:str:' \
        '--modulePathIgnorePatterns=+[module path ignore patterns]:list:' \
        '--modulePaths=+[module paths]:list:_files -/' \
        '--noStackTrace[no stack trace]' \
        '--notify[notify]' \
        '--notifyMode=+[notify mode]:m:(always failure success change failure-change success-change)' \
        '--onlyChanged[only changed tests]' \
        '-o[only changed tests]' \
        '--onlyFailures[only failures]' \
        '-f[only failures]' \
        '--openHandlesTimeout=+[open handles timeout]:n:' \
        '--outputFile=+[output file]:file:_files' \
        '--passWithNoTests[pass with no tests]' \
        '--preset=+[preset]:str:' \
        '--prettierPath=+[prettier path]:file:_files' \
        '--projects=+[projects]:list:' \
        '--randomize[randomize]' \
        '--reporters=+[reporters]:list:' \
        '--resetMocks[reset mocks]' \
        '--resetModules[reset modules]' \
        '--resolver=+[resolver]:str:' \
        '--restoreMocks[restore mocks]' \
        '--rootDir=+[root dir]:dir:_files -/' \
        '--roots=+[roots]:list:_files -/' \
        '--runInBand[run in band]' \
        '-i[run in band]' \
        '--runTestsByPath[run tests by path]' \
        '--seed=+[seed]:n:' \
        '--selectProjects=+[select projects]:list:' \
        '--setupFiles=+[setup files]:list:' \
        '--setupFilesAfterEach=+[setup files after each]:list:' \
        '--showConfig[show config]' \
        '--silent[silent]' \
        '--skipFilter[skip filter]' \
        '--snapshotSerializers=+[snapshot serializers]:list:' \
        '--testEnvironment=+[test environment]:e:(node jsdom node-puppeteer)' \
        '--testEnvironmentOptions=+[test environment options]:str:' \
        '--testFailureExitCode=+[test failure exit code]:n:' \
        '--testLocationInResults[test location in results]' \
        '--testMatch=+[test match]:list:' \
        '--testNamePattern=+[test name pattern]:str:' \
        '-t+[test name pattern]:str:' \
        '--testPathIgnorePatterns=+[test path ignore patterns]:list:' \
        '--testPathPattern=+[test path pattern]:str:' \
        '--testRegex=+[test regex]:list:' \
        '--testResultsProcessor=+[test results processor]:str:' \
        '--testRunner=+[test runner]:str:' \
        '--testSequencer=+[test sequencer]:str:' \
        '--testTimeout=+[test timeout ms]:n:' \
        '--transform=+[transform]:str:' \
        '--transformIgnorePatterns=+[transform ignore patterns]:list:' \
        '--unmockedModulePathPatterns=+[unmocked module path patterns]:list:' \
        '--updateSnapshot[update snapshot]' \
        '-u[update snapshot]' \
        '--useStderr[use stderr]' \
        '--verbose[verbose]' \
        '--watch[watch]' \
        '--watchAll[watch all]' \
        '--watchman[use watchman]' \
        '--workerIdleMemoryLimit=+[worker idle memory limit]:str:' \
        '*:pattern:'
}

_jest-cli "$@"
