#compdef jpeg2ktopam
# Documentation: man jpeg2ktopam (Netpbm)
# Source: convert a JPEG 2000 (.jp2) image to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-debuglevel=[libjasper debug level]:number:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:jp2 file:_files -g "*.(jp2|j2k|jpf|jpx)"' \
    && ret=0

return ret
