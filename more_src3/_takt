#compdef takt
# Documentation: https://github.com/nrslib/takt
# Reference accessed: 2026-05-22
# Verified: src/app/cli/program.ts and commands.ts Commander definitions.

# Zsh completion for takt - TAKT agent workflow orchestration CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --issue)'{-i,--issue}'[GitHub issue number]:n:' \
  '--pr[PR number to fetch review comments]:n:' \
  '(-w --workflow)'{-w,--workflow}'[workflow name or path]:workflow:' \
  '(-b --branch)'{-b,--branch}'[branch name]:branch:' \
  '--auto-pr[create PR after execution]' \
  '--draft[create draft PR]' \
  '--repo[GitHub repository]:repo:' \
  '--provider[agent provider]:provider:(claude-sdk claude claude-terminal codex opencode cursor copilot mock)' \
  '--model[agent model]:model:' \
  '(-t --task)'{-t,--task}'[task content pipeline mode]:task:' \
  '--pipeline[pipeline mode non-interactive]' \
  '--skip-git[skip branch commit and push]' \
  '(-q --quiet)'{-q,--quiet}'[minimal output for CI]' \
  '(-c --continue)'{-c,--continue}'[continue last assistant session]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'takt command' \
      'run[run pending tasks]' \
      'watch[watch and auto-execute tasks]' \
      'add[add a new task]' \
      'list[list task branches]' \
      'clear[clear agent sessions]' \
      'eject[eject builtin workflow or facet]' \
      'reset[reset settings]' \
      'prompt[preview assembled prompts]' \
      'export-cc[export as Claude Code skill]' \
      'export-codex[export as Codex skill]' \
      'catalog[list available facets]' \
      'workflow[workflow authoring]' \
      'metrics[analytics metrics]' \
      'purge[purge old analytics events]' \
      'repertoire[manage repertoire packages]' && ret=0
    ;;
  args)
    case $line[1] in
      run|watch)
        _arguments '--ignore-exceed[ignore workflow max_steps]' && ret=0
        ;;
      add)
        _arguments '1:task or issue:' && ret=0
        ;;
      list)
        _arguments \
          '--non-interactive[non-interactive mode]' \
          '--action[action]:action:(diff try merge delete)' \
          '--format[output format]:format:(text json)' \
          '--yes[skip confirmations]' && ret=0
        ;;
      eject)
        _arguments '--global[eject to ~/.takt/]' '1:type or workflow:' '2:facet name:' && ret=0
        ;;
      reset)
        _values 'reset target' config categories && ret=0
        ;;
      workflow)
        case $line[2] in
          init)
            _arguments \
              '--description[workflow description]:text:' \
              '--steps[initial step count]:n:' \
              '--template[template kind]:kind:(minimal faceted)' \
              '--global[create in ~/.takt/workflows]' \
              '1:workflow name:' && ret=0
            ;;
          doctor)
            _arguments '*:targets:' && ret=0
            ;;
          *)
            _values 'workflow command' init doctor && ret=0
            ;;
        esac
        ;;
      metrics)
        case $line[2] in
          review)
            _arguments '--since[time window]:duration:' && ret=0
            ;;
          *)
            _values 'metrics command' review && ret=0
            ;;
        esac
        ;;
      repertoire)
        _values 'repertoire command' add remove list && ret=0
        ;;
      purge)
        _arguments '--retention-days[retention in days]:days:' && ret=0
        ;;
      catalog)
        _arguments '1:facet type:' && ret=0
        ;;
      prompt)
        _arguments '1:workflow:' && ret=0
        ;;
    esac
    ;;
esac

return ret
