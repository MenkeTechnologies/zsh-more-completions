#compdef halloy
# Documentation: https://github.com/squidowl/halloy
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[path to configuration file]:file:_files -g "*.{toml,yaml,yml}"'
