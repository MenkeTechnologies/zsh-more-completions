#compdef krdc
# Documentation: https://invent.kde.org/network/krdc/-/blob/master/main.cpp
# Reference accessed: 2026-05-19
# Verified: KDE krdc/main.cpp upstream. Current source registers
# only the --fullscreen option plus the `url` positional argument.
# Removed unverifiable --window/--high-quality/--medium-quality/
# --low-quality (not present in current source). --help/--version/
# --author/--license/--style/--platform come from KAboutData/Qt.

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-qt[show Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--author[show author info]' \
  '(- *)--license[show license info]' \
  '--fullscreen[start KRDC with the provided URL in fullscreen mode (one URL only)]' \
  '--style=[Qt GUI style]:style:' \
  '--platform=[Qt platform plugin]:platform:' \
  '*:URL (vnc://host[:port] or rdp://host[:port]):' && ret=0
return ret
