#compdef slocal
# Documentation: man slocal(1)
# Source: nmh uip/slocal.c (master) — special local mail delivery agent (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-addr+[delivery address]:address:_default' \
    '-user+[user name]:user:_users' \
    '-file+[input file]:file:_files' \
    '-sender+[sender address]:address:_default' \
    '-mailbox+[mailbox file]:file:_files' \
    '-home+[home directory]:dir:_files -/' \
    '-info+[extra info data]:data:_default' \
    '-maildelivery+[maildelivery rules file]:file:_files' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-suppressdup -nosuppressdup)-suppressdup[suppress duplicate delivery]' \
    '(-suppressdup -nosuppressdup)-nosuppressdup[allow duplicates]' \
    '-debug[debug output]' \
    '-version[show version]' \
    '-help[show help]' \
    && ret=0

return ret
