#compdef kubectl-openebs
# Documentation: https://github.com/openebs/openebsctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --kubeconfig)'{-c+,--kubeconfig=}'[path to kubeconfig file]:file:_files' \
  '1:subcommand:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'cluster-info:show component version, status and running components per engine'
      'completion:output shell completion code (bash or zsh)'
      'describe:detailed information about an OpenEBS resource'
      'get:fetching operations related to a volume/storage'
      'help:help about any command'
      'version:show openebs kubectl plugin version'
    )
    _describe -t commands 'kubectl-openebs command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' && ret=0
    ;;
esac

return ret
