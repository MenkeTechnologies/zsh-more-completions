#compdef hxcpp
# _hxcpp — Haxe C++ runtime build tool CLI alias (Haxe Foundation, C++); custom argparse
# upstream: https://github.com/HaxeFoundation/hxcpp

_hxcpp() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-D+[define]:list:' \
        '--define=+[define]:list:' \
        '-debug[debug build]' \
        '--debug[debug build]' \
        '-android[android target]' \
        '-iphone[iphone target]' \
        '-ios[ios target]' \
        '-mac[macos target]' \
        '-windows[windows target]' \
        '-linux[linux target]' \
        '-rpi[raspberry pi target]' \
        '-static_link[static link]' \
        '-dynamic_link[dynamic link]' \
        '-no-link[no link]' \
        '-no-strip[no strip]' \
        '-strip[strip]' \
        '-mxe[MXE cross-compile]' \
        '-emscripten[emscripten target]' \
        '-objc[Objective-C target]' \
        '-cygwin[cygwin target]' \
        '-msvc[MSVC target]' \
        '-clang[clang compiler]' \
        '-gcc[gcc compiler]' \
        '-icc[Intel compiler]' \
        '-cxx[C++ compiler override]:str:' \
        '-jobs+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '-verbose[verbose]' \
        '-v[verbose]' \
        '--clean[clean]' \
        '-clean[clean]' \
        '--profile[profile]' \
        '*:build-xml:_files -g "*.xml *.hxml"'
}

_hxcpp "$@"
