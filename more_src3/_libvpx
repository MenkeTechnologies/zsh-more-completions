#compdef vpxenc vpxdec libvpx vp8enc vp8dec vp9enc vp9dec
# _libvpx — WebM Project libvpx vpxenc and vpxdec reference VP8 VP9 video encoder and decoder (webmproject team, C); getopt
# upstream: https://github.com/webmproject/libvpx

_libvpx() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--codec=+[codec]:c:(vp8 vp9)' \
        '-c+[codec]:c:(vp8 vp9)' \
        '--passes=+[N]:n:' \
        '-p+[N]:n:' \
        '--pass=+[N]:n:' \
        '--fpf=+[stats file]:file:_files' \
        '--limit=+[N frames]:n:' \
        '--deadline=+[ms]:n:' \
        '--best[best quality]' \
        '--good[good quality]' \
        '--rt[realtime]' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '-h+[height]:n:' \
        '--height=+[height]:n:' \
        '--fps=+[num/denom]:str:' \
        '--target-bitrate=+[kbps]:n:' \
        '--cpu-used=+[N]:n:' \
        '--auto-alt-ref=+[bool]:b:(0 1)' \
        '--lag-in-frames=+[N]:n:' \
        '--threads=+[N]:n:' \
        '-t+[N]:n:' \
        '--end-usage=+[mode]:m:(vbr cbr cq q)' \
        '--cq-level=+[N]:n:' \
        '--min-q=+[N]:n:' \
        '--max-q=+[N]:n:' \
        '--profile=+[N]:n:' \
        '--tile-columns=+[N]:n:' \
        '--tile-rows=+[N]:n:' \
        '--frame-parallel=+[bool]:b:(0 1)' \
        '--row-mt=+[bool]:b:(0 1)' \
        '--aq-mode=+[mode]:m:(0 1 2 3 4)' \
        '--arnr-strength=+[N]:n:' \
        '--arnr-maxframes=+[N]:n:' \
        '--arnr-type=+[N]:n:' \
        '--tune=+[tune]:t:(psnr ssim)' \
        '--tune-content=+[content]:c:(default screen film)' \
        '--enable-tpl=+[bool]:b:(0 1)' \
        '--ivf[IVF output]' \
        '--webm[WebM output]' \
        '--obu[OBU output]' \
        '-o+[output file]:file:_files -g "*.ivf *.webm *.obu *.yuv *.y4m *.mkv"' \
        '*:input yuv:_files -g "*.yuv *.y4m"'
}

_libvpx "$@"
