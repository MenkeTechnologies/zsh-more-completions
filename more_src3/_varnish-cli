#compdef varnish-cli varnishd-cli
# _varnish-cli — Varnish HTTP Cache (varnishd) CLI alias (varnish team, C); custom argparse
# upstream: https://github.com/varnishcache/varnish-cache

_varnish-cli() {
    _arguments \
        '--help[show help]' \
        '-h+[hash type]:h:(simple_list classic critbit)' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[listen address]:str:' \
        '-b+[backend address]:str:' \
        '-C[print compiled VCL]' \
        '-d[debug mode]' \
        '-E+[storage to use]:str:' \
        '-F[do not daemonize]' \
        '-f+[VCL file]:file:_files -g "*.vcl"' \
        '-i+[identity]:str:' \
        '-I+[CLI command file]:file:_files' \
        '-j+[jail spec]:str:' \
        '-l+[shm log size]:str:' \
        '-M+[master address]:str:' \
        '-n+[working directory]:dir:_files -/' \
        '-P+[pid file]:file:_files' \
        '-p+[param=value]:str:' \
        '-r+[runtime parameters]:str:' \
        '-S+[secret file]:file:_files' \
        '-s+[storage backend]:str:' \
        '-T+[admin address]:str:' \
        '-t+[default ttl]:n:' \
        '-V[show version]' \
        '-W+[worker spec]:str:' \
        '-x+[topic]:t:(builtin cli debug parameter ref vsl vsl_glossary)' \
        '*:arg:'
}

_varnish-cli "$@"
