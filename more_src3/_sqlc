#compdef sqlc
# Documentation: https://docs.sqlc.dev/en/latest/reference/cli.html
# Reference accessed: 2026-05-21
# Verified: sqlc CLI reference (subcommands + global flags).
# Removed: --no-remote, --experimental (not in current upstream global flags).

# Zsh completion for sqlc (compile SQL to type-safe code)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'compile:statically check SQL for syntax and type errors'
  'completion:generate shell completion'
  'createdb:create an ephemeral database'
  'diff:compare generated files against existing'
  'generate:generate source code from SQL'
  'help:display command documentation'
  'init:create an empty sqlc.yaml file'
  'push:upload schema, queries, and configuration'
  'verify:validate schema, queries, and configuration'
  'version:print the sqlc version'
  'vet:examine and analyze queries'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[alternate configuration file (default sqlc.yaml)]:file:_files -g "*.(yaml|yml|json)"' \
  '--no-database[disable database connections]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sqlc command' commands && ret=0
    ;;
esac

return ret
