#compdef lapce-proxy
# _lapce-proxy — Lapce editor proxy and forwarded helper binary (lapce/lapce)
# upstream: https://github.com/lapce/lapce
# Flags from lapce-proxy/src/lib.rs (clap derive Cli).

_lapce-proxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*:path:_files'
}

_lapce-proxy "$@"
