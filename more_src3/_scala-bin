#compdef scala
# _scala-bin — Scala launcher CLI (Lightbend + Scala team, Scala); run/compile/repl Scala
# upstream: https://github.com/scala/scala

_scala-bin() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-D+[system property]:KEY=VAL:' \
        '-J+[JVM flag]:flag:' \
        '-cp+[classpath]:cp:' \
        '-classpath+[classpath]:cp:' \
        '-e+[expression]:str:' \
        '-i+[load script]:file:_files' \
        '-I+[load script]:file:_files' \
        '-encoding+[encoding]:enc:' \
        '-feature[print feature warnings]' \
        '-deprecation[print deprecation warnings]' \
        '-explaintypes[explain type errors]' \
        '-howtorun+[howtorun]:mode:(script object repl guess)' \
        '-language+[language feature]:feature:(experimental.macros higherKinds existentials implicitConversions postfixOps reflectiveCalls)' \
        '-nc[no compiler daemon]' \
        '-no-completion[no tab completion]' \
        '-nocompdaemon[no compiler daemon]' \
        '-nowarn[no warnings]' \
        '-Xlint+[lint warnings]:warnings:' \
        '-Xfatal-warnings[fatal warnings]' \
        '-Yrepl-class-based[repl class based]' \
        '-savecompiled[save compiled]' \
        '-toolcp+[tool classpath]:cp:' \
        '-unchecked[print unchecked warnings]' \
        '-uniqid[print unique ids]' \
        '-verbose[verbose]' \
        '*:script:_files -g "*.scala"'
}

_scala-bin "$@"
