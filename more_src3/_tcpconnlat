#compdef tcpconnlat tcpconnlat-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/tcpconnlat.py argparse)
# Reference accessed: 2026-05-29
# tcpconnlat — trace TCP active connection latency (connect() to SYN+SYN/ACK round-trip). BCC/eBPF.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --timestamp)'{-t,--timestamp}'[include timestamp on output]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-L --lport)'{-L,--lport}'[include LPORT on output]' \
  '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[trace IPv4 family only]' \
  '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[trace IPv6 family only]' \
  '(-v --verbose)'{-v,--verbose}'[print the BPF program for debugging]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:duration_ms (minimum duration to trace in ms, default 0):' \
  && ret=0

return ret
