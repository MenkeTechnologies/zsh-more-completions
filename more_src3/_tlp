#compdef tlp
# Documentation: https://linrunner.de/tlp/usage/tlp.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tlp - Linux Advanced Power Management

local -a commands=(
  'start:start TLP and apply profile for current power source'
  'performance:apply AC performance profile'
  'balanced:apply battery balanced profile'
  'power-saver:apply power-saving profile'
  'ac:apply AC profile and enter manual mode'
  'bat:apply battery profile and enter manual mode'
  'usb:apply autosuspend to all attached USB devices'
  'bayoff:power off optical drive in MediaBay/UltraBay'
  'diskid:show disk identifiers for configured drives'
  'setcharge:modify battery charge thresholds temporarily'
  'fullcharge:charge battery to full capacity'
  'chargeonce:charge battery to stop threshold once'
  'discharge:discharge battery to specified level'
  'recalibrate:perform battery recalibration cycle'
  'stat:show power management status'
)

_arguments \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:argument' && return 0

case $state in
  commands)
    _describe -t commands 'tlp command' commands
    ;;
esac
