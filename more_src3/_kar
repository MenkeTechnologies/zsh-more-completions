#compdef kar abi-dump sff-dump illumina-dump srapath sra-pileup sra-info kdbmeta rcexplain
# Documentation: upstream NCBI sra-tools source at
# github.com/ncbi/sra-tools
# Reference accessed: 2026-05-30 via gh api inspection of
# tools/loaders/kar/kar+args.h (OPTION_* macros) and
# tools/external/srapath/srapath.c (OPTION_* defines), plus the
# noted shared-flag set between sra-dump.c-derived dumpers
# (fastq-dump/abi-dump/sff-dump/illumina-dump all built from the
# same sra-dump source directory with format-specific prefixes).
# NCBI SRA Toolkit R106 — 9-stem multi-binary harvest completing
# the R105 deferral on remaining SRA toolkit auxiliaries.

local curcontext="$curcontext" state line ret=1

# Shared KApp common flags (same as R105 _prefetch helper).
local -a _common_kapp
_common_kapp=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '(-L --log-level)'{-L,--log-level}'=[log level]:level:(fatal sys int err warn info debug)'
  '(-v --verbose)*'{-v,--verbose}'[verbose mode (repeatable)]'
  '(-q --quiet)'{-q,--quiet}'[turn off all messages]'
  '--option-file=[read options from file]:file:_files'
)

case $service in

  kar)
    # KApp Archive (tar-like) for VDB / SRA archives.
    _arguments -s -S \
      $_common_kapp \
      '(-c --create)'{-c,--create}'=[create archive at PATH]:archive path:_files' \
      '(-x --extract)'{-x,--extract}'=[extract archive at PATH]:archive path:_files' \
      '(-t --test)'{-t,--test}'=[test archive at PATH]:archive path:_files' \
      '(-d --directory)'{-d,--directory}'=[directory to archive into / from]:dir:_directories' \
      '(-f --force)'{-f,--force}'[overwrite existing files]' \
      '(-l --long-list)'{-l,--long-list}'[long-format listing (with -t)]' \
      '(-Z --stdout)'{-Z,--stdout}'[write archive to stdout]' \
      '--md5[generate / verify MD5 checksums]' \
      '*--keep=[keep matching files (extract mode)]:pattern:' \
      '*--drop=[drop matching files (create mode)]:pattern:' \
      '--kdfile=[KAR description file]:file:_files' \
      '*:source / target file:_files' \
      && ret=0
    ;;

  abi-dump|sff-dump|illumina-dump)
    # Format-specific SRA dumpers built from tools/external/sra-dump
    # source (sra-dump.c + abi.c / sff.c / illumina.c / fastq.c
    # format modules). Share fastq-dump's spot/filter/output flags.
    _arguments -s -S \
      $_common_kapp \
      '(-A --accession)'{-A,--accession}'=[SRA accession]:accession:' \
      '(-O --outdir)'{-O,--outdir}'=[output directory]:dir:_directories' \
      '(-Z --stdout)'{-Z,--stdout}'[write to stdout]' \
      '(-N --minSpotId)'{-N,--minSpotId}'=[minimum spot ID]:row id:' \
      '(-X --maxSpotId)'{-X,--maxSpotId}'=[maximum spot ID]:row id:' \
      '--gzip[gzip compress output]' \
      '--bzip2[bzip2 compress output]' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  srapath)
    # Resolve NCBI repository paths / URLs for SRA accessions.
    _arguments -s -S \
      $_common_kapp \
      '(-a --protocol)'{-a,--protocol}'=[transport protocol]:proto:(http https fasp gs s3)' \
      '(-c --cache)'{-c,--cache}'[use the local cache repository]' \
      '--perm=[permissions/cart file]:file:_files' \
      '(-d --project)'{-d,--project}'=[project ID]:N:' \
      '(-e --vers)'{-e,--vers}'=[remote-repository version]:version:' \
      '(-f --function)'{-f,--function}'=[function]:func:(names resolve search srapath)' \
      '--location=[cloud location]:location:' \
      '--ngc=[NGC credentials file]:file:_files' \
      '(-P --path)'{-P,--path}'[print path-style location only]' \
      '(-p --param)'{-p,--param}'=[parameter to pass]:param:' \
      '(-r --raw)'{-r,--raw}'[raw output (no headers)]' \
      '(-j --json)'{-j,--json}'[JSON output]' \
      '(-t --timeout)'{-t,--timeout}'=[request timeout (seconds)]:sec:' \
      '(-u --url)'{-u,--url}'=[explicit URL]:url:' \
      '*:SRA accession:' \
      && ret=0
    ;;

  sra-pileup)
    # samtools-style pileup directly from an SRA accession.
    _arguments -s -S \
      $_common_kapp \
      '(-r --aligned-region)'{-r,--aligned-region}'=[chromosome region (chr\:from-to)]:region:' \
      '(-o --outfile)'{-o,--outfile}'=[output file]:file:_files' \
      '(-t --table)'{-t,--table}'=[table to use]:table:(p s e)' \
      '(-q --minmapq)'{-q,--minmapq}'=[minimum mapping quality]:N:' \
      '(-Q --minbasequal)'{-Q,--minbasequal}'=[minimum base quality]:N:' \
      '(-d --duplicates)'{-d,--duplicates}'=[include duplicates]:bool:(yes no)' \
      '--noskip[do not skip empty positions]' \
      '--showid[show alignment ID]' \
      '(-e --seqname)'{-e,--seqname}'[print SEQ_NAME]' \
      '(-n --noqual)'{-n,--noqual}'[omit qualities]' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  sra-info)
    # Print information about an SRA accession (schema, columns,
    # row counts, sizes).
    _arguments -s -S \
      $_common_kapp \
      '(-f --format)'{-f,--format}'=[output format]:format:(default csv xml json tab piped)' \
      '(-r --rows)'{-r,--rows}'=[row count]:N:' \
      '(-l --limit)'{-l,--limit}'=[limit on row count]:N:' \
      '--platform[show platform]' \
      '--meta[show metadata]' \
      '--schema[show schema]' \
      '--total[show totals]' \
      '*:SRA accession or file:_files' \
      && ret=0
    ;;

  kdbmeta)
    # Examine / dump VDB metadata nodes.
    _arguments -s -S \
      $_common_kapp \
      '(-T --table)'{-T,--table}'=[table name]:table:' \
      '(-X --output-format)'{-X,--output-format}'=[output format]:format:(xml json csv tab)' \
      '(-A --as-attributes)'{-A,--as-attributes}'[dump as attributes]' \
      '(-U --tree)'{-U,--tree}'[tree-style dump]' \
      '*:VDB accession or file + node path:_files' \
      && ret=0
    ;;

  rcexplain)
    # Explain ncbi-vdb / sra-tools return-code values.
    _arguments -s -S \
      $_common_kapp \
      '*:return code (decimal):' \
      && ret=0
    ;;

esac

return ret
