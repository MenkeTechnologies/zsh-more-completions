#compdef kolourpaint
# Documentation: https://invent.kde.org/graphics/kolourpaint/-/blob/master/kolourpaint.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KDE kolourpaint.cpp QCommandLineParser: --mimetypes
# and --new app-specific flags plus the standard KAboutData
# --help/--version/--author/--license flags.

# kolourpaint: KDE simple paint application
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--mimetypes[list all readable image MIME types]' \
  '--new[start with new image of WxH size]:size:' \
  '*:image file:_files' && ret=0
return ret
