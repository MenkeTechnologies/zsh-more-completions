#compdef SvtAv1EncApp svt-av1-enc
# Documentation: https://gitlab.com/AOMediaCodec/SVT-AV1/-/raw/master/Docs/Parameters.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for SVT-AV1 encoder

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-i+[input video file]:file:_files -g "*.(yuv|y4m)"' \
  '-b+[output bitstream file]:file:_files' \
  '-o+[reconstructed YUV output file]:file:_files' \
  '-c+[configuration file]:file:_files' \
  '--errlog=[error log destination]:file:_files' \
  '-w+[frame width in pixels]:width' \
  '-h+[frame height in pixels]:height' \
  '-n+[number of frames to encode]:count' \
  '--skip=[frames to skip before encoding]:count' \
  '--keyint=[keyframe interval]:frames' \
  '--preset=[encoding preset (-1 to 13)]:preset' \
  '--crf=[constant rate factor]:crf' \
  '-q+[quantization parameter]:qp' \
  '--qp=[quantization parameter]:qp' \
  '--rc=[rate control mode]:mode:(0 1 2)' \
  '--tbr=[target bitrate in kbps]:kbps' \
  '--mbr=[maximum bitrate in kbps]:kbps' \
  '--min-qp=[minimum QP]:qp' \
  '--max-qp=[maximum QP]:qp' \
  '--passes=[number of encoding passes]:passes' \
  '--pass=[current pass number]:pass' \
  '--stats=[stats file for multi-pass]:file:_files' \
  '--irefresh-type=[intra refresh type]:type:(1 2)' \
  '--hierarchical-levels=[temporal layers (2-5)]:level' \
  '--pred-struct=[prediction structure]:struct:(0 1 2)' \
  '--lp=[level of parallelism]:count' \
  '--asm=[limit instruction sets]:isa' \
  '--tune=[tuning mode]:mode:(0 1 2 3 4 5)' \
  '--enable-dlf=[deblocking filter]:value:(0 1 2)' \
  '--enable-cdef=[directional enhancement filter]:value:(0 1)' \
  '--enable-restoration=[loop restoration]:value:(0 1)' \
  '--enable-tf=[temporal filtering]:value:(0 1 2)' \
  '--film-grain=[film grain level (0-50)]:level' \
  '--svtav1-params=[colon-separated key=value pairs]:params' \
  '--progress=[verbosity level (0-2)]:level:(0 1 2)' \
  '--tile-rows=[number of tile rows]:count' \
  '--tile-columns=[number of tile columns]:count' \
  '--color-primaries=[color primaries]:value' \
  '--transfer-characteristics=[transfer characteristics]:value' \
  '--matrix-coefficients=[matrix coefficients]:value'
