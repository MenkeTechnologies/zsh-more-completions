#compdef legit
# Documentation: https://github.com/kennethreitz/legit
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'branches:display available branches'
      'switch:switch to a branch'
      'sw:switch to a branch (alias)'
      'sync:sync current branch with remote'
      'sy:sync current branch with remote (alias)'
      'publish:publish current branch to remote'
      'pub:publish current branch (alias)'
      'unpublish:remove branch from remote'
      'unp:remove branch from remote (alias)'
      'undo:undo last commit, keeping changes'
      'un:undo last commit (alias)'
    )
    _describe -t commands 'legit command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (switch|sw|unpublish|unp)
        _arguments -s -S \
          '1:branch:__legit_branches' && ret=0
        ;;
      (publish|pub|sync|sy)
        _arguments -s -S \
          '1:branch:__legit_branches' && ret=0
        ;;
      (branches|undo|un)
        ret=0
        ;;
    esac
    ;;
esac

__legit_branches() {
  local -a branches
  branches=(${${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"}})
  _describe -t branches 'branch' branches
}

return ret
