#compdef vmware
# Documentation: https://techdocs.broadcom.com/us/en/vmware-cis/desktop-hypervisors/workstation-pro/17-0/using-vmware-workstation-pro/using-the-vmware-command/run-the-vmware-command/vmware-command-options.html
# Reference accessed: 2026-05-21
# Verified: upstream Broadcom Workstation Pro 17 docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-n[open new Workstation Pro window]' \
  '-t[open VM in new tab in existing window]' \
  '-x[power on VM at startup]' \
  '-X[power on VM and switch to fullscreen]' \
  '-q[close VM tab when powered off]' \
  '-s+[set configuration variable KEY=VALUE]:key=value:' \
  '-v[show product name, version, build]' \
  '*:vmx file:_files -g "*.vmx"' && ret=0

return ret
