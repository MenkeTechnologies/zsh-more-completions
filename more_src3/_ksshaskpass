#compdef ksshaskpass
# _ksshaskpass — KDE ksshaskpass (SSH_ASKPASS implementation backed by KWallet; ssh-add and friends invoke it for passphrase prompts; positional argument is the prompt text to display)
# upstream: https://invent.kde.org/utilities/ksshaskpass
# Argument shape from ksshaskpass main.cpp on tip.

_ksshaskpass() {
    _arguments \
        '1:prompt:'
}

_ksshaskpass "$@"
