#compdef wbinfo-cli
# _wbinfo-cli — Samba wbinfo query winbindd info CLI alias (samba team, C); custom argparse
# upstream: https://github.com/samba-team/samba

_wbinfo-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[user%password]:str:' \
        '--authenticate=+[user%password]:str:' \
        '-K+[user%password]:str:' \
        '--krb5auth=+[user%password]:str:' \
        '--krb5ccname=+[name]:str:' \
        '-c+[user]:_users' \
        '--create-user=+[user]:_users' \
        '-d+[debug level]:n:' \
        '--debuglevel=+[debug level]:n:' \
        '--debug-stdout[debug to stdout]' \
        '-D+[domain]:str:' \
        '--domain-info=+[domain]:str:' \
        '-g[list groups]' \
        '--all-groups[list groups]' \
        '-G+[gid]:n:' \
        '--gid-to-sid=+[gid]:n:' \
        '-i+[user]:_users' \
        '--user-info=+[user]:_users' \
        '-I+[ip]:str:' \
        '--WINS-by-ip=+[ip]:str:' \
        '-N+[netbios name]:host:_hosts' \
        '--WINS-by-name=+[netbios name]:host:_hosts' \
        '-n+[name]:str:' \
        '--name-to-sid=+[name]:str:' \
        '-p[ping winbindd]' \
        '--ping[ping winbindd]' \
        '-P[check secret]' \
        '--check-secret[check secret]' \
        '-r+[user]:_users' \
        '--user-groups=+[user]:_users' \
        '-R+[sid]:str:' \
        '--lookup-rids=+[sid]:str:' \
        '-s+[sid]:str:' \
        '--sid-to-name=+[sid]:str:' \
        '-S+[sid]:str:' \
        '--sid-to-uid=+[sid]:str:' \
        '-t[trust account info]' \
        '--trusted-domains[trust account info]' \
        '-u[list users]' \
        '--all-users[list users]' \
        '-U+[uid]:n:' \
        '--uid-to-sid=+[uid]:n:' \
        '-Y+[sid]:str:' \
        '--sid-to-gid=+[sid]:str:' \
        '-A+[user]:_users' \
        '--set-auth-user=+[user]:_users' \
        '--getdcname=+[domain]:str:' \
        '--dsgetdcname=+[domain]:str:' \
        '--get-auth-user[get auth user]' \
        '--logoff[logoff]' \
        '--logoff-user=+[user]:_users' \
        '--logoff-uid=+[uid]:n:' \
        '--sequence[seq numbers]' \
        '--online-status[online status]' \
        '--unix-to-sid=+[id]:str:' \
        '--separator[show separator]' \
        '--verbose[verbose]' \
        '*:arg:'
}

_wbinfo-cli "$@"
