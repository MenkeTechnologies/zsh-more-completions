#compdef syz-aflow
# _syz-aflow — agentic LLM-driven syzkaller bug-investigation workflow (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-aflow/aflow.go (flag).

_syz-aflow() {
    _arguments \
        '-workflow=[workflow to execute]:flow:' \
        '-input=[input JSON file with workflow arguments]:file:_files -g "*.json"' \
        '-workdir=[directory for kernel checkout/builds/etc]:dir:_files -/' \
        '-model=[LLM model to use]:model:' \
        '-cache-size=[max cache size (e.g. 100MB 5GB 1TB)]:size:' \
        '-download-bug=[extid or id of bug to download from dashboard]:id:' \
        '-auth[use gcloud auth token for downloading bugs]' \
        '-html=[write execution trajectory into HTML file]:file:_files -g "*.html"'
}

_syz-aflow "$@"
