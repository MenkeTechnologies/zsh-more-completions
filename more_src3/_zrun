#compdef zrun
# Documentation: https://linuxcommandlibrary.com/man/zrun
# Reference accessed: 2026-05-21
# Verified: zrun(1) — transparently uncompresses compressed file
# arguments to temp files before running the command. Takes no flags
# of its own; everything after the command name is the command + args.

local -a arguments

arguments=(
    '(-):command:_command_names -e'
    '*::arguments:_normal'
)

_arguments -s -S $arguments
