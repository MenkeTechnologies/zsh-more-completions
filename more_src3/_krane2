#compdef krane2 krane
# _krane2 — appvia Krane krane2 CLI command-line frontend wrapping the Krane simple Kubernetes RBAC static analysis tool open-source written in Go identifies potential security risks in Kubernetes RBAC design and makes suggestions on how to mitigate them dashboard alert HTML-report RBAC-tree-graph rbac-cve-warning CIS Kubernetes Benchmark policies-via-rules policy-violation rule-engine dashboard report check-network-policies report-alert chart-helm-charts security-and-policy-analysis (appvia Krane team Marko Bevc Mario Casciaro, Go); cobra
# upstream: https://appvia.github.io/krane/

_krane2() {
    local -a sub=(
        'report:run RBAC report'
        'dashboard:launch dashboard'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[context]:str:' \
        '--context=+[name]:str:' \
        '-k+[kubeconfig]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '--kubeconfig=+[file]:file:_files -g "kubeconfig *.yaml *.yml"' \
        '-d+[cluster]:str:' \
        '--cluster=+[name]:str:' \
        '--listen=+[host:port]:_hosts' \
        '--port=+[port]:n:' \
        '--rules-dir=+[dir]:dir:_files -/' \
        '--rules-file=+[file]:file:_files -g "*.yaml *.yml"' \
        '--report-output-dir=+[dir]:dir:_files -/' \
        '--alert-output-dir=+[dir]:dir:_files -/' \
        '--include-rule=+[id]:str:' \
        '*--include-rule=+[id]:str:' \
        '--exclude-rule=+[id]:str:' \
        '*--exclude-rule=+[id]:str:' \
        '--slack-webhook=+[url]:str:' \
        '--slack-channel=+[name]:str:' \
        '--alert[send alert]' \
        '--report-format=+[fmt]:f:(json yaml html)' \
        '--threshold-info=+[N]:n:' \
        '--threshold-low=+[N]:n:' \
        '--threshold-medium=+[N]:n:' \
        '--threshold-high=+[N]:n:' \
        '--cluster-resource[cluster resource]' \
        '-n+[namespace]:str:' \
        '--namespace=+[ns]:str:' \
        '*--namespace=+[ns]:str:' \
        '--rbac-only[rbac only]' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krane subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_krane2 "$@"
