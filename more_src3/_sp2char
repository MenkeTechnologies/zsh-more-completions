#compdef sp2char
# _sp2char — replace spaces in string arguments with a chosen character (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from sp2char.c (single-letter getopt-style).

_sp2char() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-s+[character to substitute for spaces]:char:' \
        '-v[verbose output]' \
        '*:string:'
}

_sp2char "$@"
