#compdef wiringop wiringop-cli
# _wiringop — orangepi-xunlong wiringop gpio CLI for Orange Pi single-board computers providing GPIO access pin modes I2C SPI hardware-PWM serial-bridge utility analogue ports matching WiringPi API mapping (orangepi-xunlong team, C); getopt
# upstream: https://github.com/orangepi-xunlong/wiringOP

_wiringop() {
    local -a sub=(
        'mode:set pin mode'
        'read:read pin value'
        'write:write pin value'
        'awrite:analog write'
        'aread:analog read'
        'pwm:set PWM value'
        'pwm-bal:set PWM balanced mode'
        'pwm-ms:set PWM mark-space mode'
        'pwmc:set PWM clock'
        'pwmr:set PWM range'
        'pwmTone:play PWM tone'
        'clock:set clock'
        'unexport:unexport pin'
        'unexportall:unexport all pins'
        'export:export pin'
        'exports:list exports'
        'wfi:wait for interrupt'
        'edge:set edge'
        'readall:read all pins'
        'pins:show pinout'
        'i2cdetect:i2c detect'
        'qmode:query pin mode'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-g[use BCM_GPIO pin numbering]' \
        '-1[use physical pin numbering]' \
        '-p[use Pi 1 pinout]' \
        '-x+[extension setup]:str:' \
        '-d[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wiringop subcommand' sub ;;
        args)
            case $words[1] in
                mode) _arguments '*:pin mode:(in out pwm clock up down tri off)' ;;
                read|write|aread|awrite|edge|wfi|pwm|export|unexport|qmode) _arguments '*:pin value:' ;;
                edge) _arguments \
                    '1:pin:' \
                    '2:edge:(rising falling both)' ;;
            esac
            ;;
    esac
}

_wiringop "$@"
