#compdef unmunch
# Documentation: https://github.com/hunspell/hunspell (man/unmunch.1 source)
# Reference accessed: 2026-05-21
# Verified: hunspell project ships unmunch as `unmunch dictionary_file affix_file`; no flags accepted.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:dictionary file:_files -g "*.dic"' \
  '2:affix file:_files -g "*.aff"' && ret=0

return ret
