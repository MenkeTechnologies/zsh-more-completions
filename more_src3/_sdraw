#compdef sdraw
# _sdraw — The Document Foundation LibreOffice sdraw CLI symlink launching LibreOffice Draw the vector graphics editor opening .odg .vsd .svg .pdf .wmf .emf documents with options for headless server batch convert-to PNG JPG SVG PDF export drawing diagramming page-layout flowchart editing (LibreOffice team, C++); getopt
# upstream: https://www.libreoffice.org/

_sdraw() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--writer[start as Writer]' \
        '--calc[start as Calc]' \
        '--draw[start as Draw]' \
        '--impress[start as Impress]' \
        '--show=+[file]:file:_files' \
        '--view=+[file]:file:_files' \
        '--norestore[no restore]' \
        '--quickstart[quickstart mode]' \
        '--nologo[no logo]' \
        '--nodefault[no default doc]' \
        '--invisible[no UI window]' \
        '--minimized[start minimized]' \
        '--headless[headless mode]' \
        '--accept=+[connection string]:str:' \
        '--language=+[lang]:str:' \
        '--safe-mode[safe mode]' \
        '--convert-to+[output filter]:str:' \
        '--outdir=+[dir]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name=+[printer]:str:' \
        '--cat[print plain text to stdout]' \
        '*:drawing:_files -g "*.odg *.vsd *.vsdx *.svg *.pdf *.wmf *.emf *.fodg *.sxd"'
}

_sdraw "$@"
