#compdef shellspec
# Documentation: https://github.com/shellspec/shellspec
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-s --shell)'{-s+,--shell=}'[shell to use]:shell:_command_names' \
  '(-j --jobs)'{-j+,--jobs=}'[parallel execution count]:jobs:' \
  '(-q --quick)'{-q,--quick}'[run failed examples first]' \
  '(-r --repair)'{-r,--repair}'[execute only failures]' \
  '(-x --xtrace)'{-x,--xtrace}'[enable trace output]' \
  '--dry-run[preview without executing]' \
  '(-F --focus)'{-F,--focus}'[run focused groups only]' \
  '(-P --pattern)'{-P+,--pattern=}'[file matching pattern]:pattern:' \
  '(-E --example)'{-E+,--example=}'[filter by example name]:pattern:' \
  '(-T --tag)'{-T+,--tag=}'[filter by tag]:tag:' \
  '--random=[randomize execution order]:type[:seed]:' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(p d t j f null debug)' \
  '(-o --output)'{-o+,--output=}'[generate report formatter]:format:' \
  '--reportdir=[report output directory]:directory:_directories' \
  '(--color --no-color)--color[enable color output]' \
  '(--color --no-color)--no-color[disable color output]' \
  '(--banner --no-banner)--banner[show banner]' \
  '(--banner --no-banner)--no-banner[hide banner]' \
  '(--kcov --no-kcov)--kcov[enable kcov coverage]' \
  '(--kcov --no-kcov)--no-kcov[disable kcov coverage]' \
  '--kcov-path=[kcov executable path]:path:_command_names' \
  '--kcov-options=[additional kcov arguments]:options:' \
  '--covdir=[coverage output directory]:directory:_directories' \
  '(-O --options)'{-O+,--options=}'[additional options file]:path:_files' \
  '(-I --load-path)'{-I+,--load-path=}'[module search path]:path:_files -/' \
  '--require=[load module]:module:' \
  '--helperdir=[helper files location]:directory:_directories' \
  '--execdir=[execution directory]:location:' \
  '(-e --env)'{-e+,--env=}'[set environment variable]:name=value:' \
  '--env-from=[load env from script]:script:_files' \
  '--path=[set PATH variable]:path:' \
  '--init=[initialize project]:template:' \
  '--gen-bin=[generate support commands]:command:' \
  '--count[count examples]' \
  '--list=[list specfiles/examples]:what:(specfiles examples)' \
  '--syntax-check[validate syntax only]' \
  '--translate[output translated specfile]' \
  '--task=[run or list tasks]:task:' \
  '--docker=[run in Docker image]:image:' \
  '--fail-fast=[abort after COUNT failures]:count:' \
  '--fail-no-examples[fail if no examples are found]' \
  '--fail-low-coverage[fail on low coverage]' \
  '--failure-exit-code=[exit code on failure]:code:' \
  '--error-exit-code=[exit code on error]:code:' \
  '--profile[enable performance profiling]' \
  '--tmpdir=[temporary directory]:directory:_directories' \
  '--keep-tmpdir[preserve temp files]' \
  '--log-file=[debug log destination]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:spec file:_files' && ret=0
return ret
