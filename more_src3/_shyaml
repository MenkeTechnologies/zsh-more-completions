#compdef shyaml
# Documentation: https://github.com/0k/shyaml
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Zsh completion for shyaml YAML query helper (0k/shyaml)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version and environment info]' \
  '(-y --yaml)'{-y,--yaml}'[output strict YAML]' \
  '(-q --quiet)'{-q,--quiet}'[suppress errors for invalid paths]' \
  '(-L --line-buffer)'{-L,--line-buffer}'[process stdin line by line]' \
  '1:action:(get-type get-value get-values get-values-0 get-length keys keys-0 values values-0 key-values key-values-0)' \
  '2:key:' \
  '3:default:' && ret=0

return ret
