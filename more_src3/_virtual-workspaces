#compdef virtual-workspaces
# _virtual-workspaces — kcp virtual workspaces server (kcp-dev/kcp)
# upstream: https://github.com/kcp-dev/kcp
# Flags from cmd/virtual-workspaces/options/options.go + apiserver framework on tip.

_virtual-workspaces() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kcp kubeconfig used to drive virtual workspaces]:file:_files' \
        '--external-logical-cluster-admin-kubeconfig=[external logical-cluster admin kubeconfig]:file:_files' \
        '--context=[kubeconfig context to use]:ctx:' \
        '--profiler-address=[pprof bind address]:host\:port:' \
        '--secure-port=[HTTPS bind port (0 disables)]:port:' \
        '--bind-address=[HTTPS bind address]:ip:' \
        '--tls-cert-file=[TLS server certificate]:file:_files' \
        '--tls-private-key-file=[TLS server private key]:file:_files' \
        '--client-ca-file=[client-cert CA bundle]:file:_files' \
        '--audit-log-path=[audit log file path]:file:_files' \
        '--audit-policy-file=[audit policy YAML file]:file:_files' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:'
}

_virtual-workspaces "$@"
