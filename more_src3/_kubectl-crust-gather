#compdef kubectl-crust-gather
# Documentation: https://github.com/crust-gather/crust-gather/blob/main/src/cli.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[log verbosity]:level:' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'collect:gather cluster state into an archive'
      'serve:provide API access to collected snapshots'
      'mcp:run as an MCP server'
    )
    _describe -t commands 'kubectl-crust-gather command' cmds && ret=0
    ;;
  args)
    case $line[1] in
      collect)
        _arguments -s -S \
          '(-k --kubeconfig)'{-k+,--kubeconfig=}'[path to the kubeconfig file]:file:_files' \
          '--kubeconfig-secret-label=[kubeconfig secret label key=value]:label:' \
          '--kubeconfig-secret-name=[kubeconfig secret NAMESPACE/NAME]:name:' \
          '--insecure-skip-tls-verify[skip TLS verification]' \
          '(-f --file)'{-f+,--file=}'[output archive path]:file:_files' \
          '(-e --encoding)'{-e+,--encoding=}'[archive encoding]:encoding:' \
          '(-d --duration)'{-d+,--duration=}'[collection duration]:duration:' \
          '*'{-s+,--secret=}'[secret to redact]:secret:' \
          '--secrets-file=[file of secrets to redact]:file:_files' \
          '*--include-namespace=[include namespaces]:namespace:' \
          '*--exclude-namespace=[exclude namespaces]:namespace:' \
          '*--include-kind=[include kinds]:kind:' \
          '*--exclude-kind=[exclude kinds]:kind:' \
          '*--include-group=[include groups]:group:' \
          '*--exclude-group=[exclude groups]:group:' \
          '*--include-name=[include names]:name:' \
          '*--exclude-name=[exclude names]:name:' \
          '*--include-labels=[include by labels]:labels:' \
          '*--exclude-labels=[exclude by labels]:labels:' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-f --file)'{-f+,--file=}'[archive to serve]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
