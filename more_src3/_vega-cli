#compdef vega-cli vg vl-cli
# _vega-cli — vega + vega-lite renderer CLIs (Vega project / UW Interactive Data Lab, Node.js); commander wrappers vg2pdf / vg2png / vg2svg / vl2vg / vl2png / vl2pdf / vl2svg
# upstream: https://github.com/vega/vega

_vega-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--base=+[base directory for data loading]:dir:_files -/' \
        '-b+[base directory for data loading]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--theme=+[theme name]:theme:(excel ggplot2 quartz vox dark fivethirtyeight latimes powerbi urbaninstitute googlecharts carbonwhite carbong10 carbong90 carbong100)' \
        '-t+[theme name]:theme:(excel ggplot2 quartz vox dark fivethirtyeight latimes powerbi urbaninstitute googlecharts)' \
        '--header[include xml header (svg)]' \
        '-h[include xml header (svg)]' \
        '--scale=+[output scale]:f:' \
        '-s+[output scale]:f:' \
        '--seed=+[seed for randomness]:n:' \
        '--logLevel=+[log level]:level:(none info warn error)' \
        '-l+[log level]:level:(none info warn error)' \
        '--format=+[output format (vg2pdf only)]:f:(letter legal tabloid a4 a3 a2 a1 a0)' \
        '-f+[output format (vg2pdf only)]:f:(letter legal tabloid a4 a3 a2 a1 a0)' \
        '--orientation=+[pdf orientation]:o:(portrait landscape)' \
        '-o+[pdf orientation]:o:(portrait landscape)' \
        '--width=+[width px]:n:' \
        '-w+[width px]:n:' \
        '--height=+[height px]:n:' \
        '-H+[height px]:n:' \
        '--padding=+[padding px]:n:' \
        '-p+[padding px]:n:' \
        '--background=+[background color]:c:' \
        '-bg+[background color]:c:' \
        '--input=+[input file]:file:_files -g "*.(json|vg.json|vl.json)"' \
        '--output=+[output file]:file:_files' \
        '*:file:_files'
}

_vega-cli "$@"
