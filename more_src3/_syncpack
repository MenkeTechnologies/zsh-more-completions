#compdef syncpack
# Documentation: https://github.com/JamieMason/syncpack
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.
# Removed: stale subcommand list (fix-mismatches, list-mismatches, prompt,
# set-semver-ranges, lint-semver-ranges) - upstream marks these deprecated;
# active commands are lint, fix, format, update, list, json.

local curcontext="$curcontext" state line ret=1

local -a syncpack_commands
syncpack_commands=(
  'lint:lint dependency versions and ranges'
  'fix:resolve autofixable lint issues'
  'format:organize package.json field ordering'
  'update:upgrade dependencies to newer registry versions'
  'list:query and inspect all dependencies'
  'json:output dependency state as JSON'
)

local -a syncpack_common_flags
syncpack_common_flags=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)--version[show version]'
  '--config=[path to config file]:config file:_files'
  '--no-ansi[remove ANSI color codes]'
  '--log-levels=[logging detail]:level:(off error warn info debug)'
  '--dependencies=[glob pattern for dependency names]:glob:'
  '--dependency-types=[dependency types to include]:type:'
  '--specifier-types=[version specifier types]:type:'
  '--source=[glob pattern for package.json files]:glob:'
  '--source-mode=[source mode]:mode:(replace extend)'
  '--show=[output details]:show:(instances hints statuses all none ignored)'
  '--sort=[order results]:sort:(name count)'
  '--reporter=[output format]:reporter:(pretty json)'
)

_arguments -s -S \
  "${syncpack_common_flags[@]}" \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands command syncpack_commands && ret=0
    ;;
  args)
    case $line[1] in
      (update)
        _arguments -s -S "${syncpack_common_flags[@]}" \
          '--target=[update scope]:target:(latest minor patch)' \
          '--interactive[interactive selection]' \
          '--check[validate without modifying]' \
          '--no-cache[bypass npm registry cache]' && ret=0
        ;;
      (format)
        _arguments -s -S "${syncpack_common_flags[@]}" \
          '--check[validate without modifying]' \
          '--dry-run[simulate changes]' && ret=0
        ;;
      (fix)
        _arguments -s -S "${syncpack_common_flags[@]}" \
          '--dry-run[simulate changes]' && ret=0
        ;;
      *)
        _arguments -s -S "${syncpack_common_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
