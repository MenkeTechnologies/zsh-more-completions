#compdef udevadm-info
# _udevadm-info — systemd udevadm info subcommand CLI for querying the udev database for device attributes properties hierarchy parent attribute walks symlink resolution exported variables (systemd team, C); getopt
# upstream: https://github.com/systemd/systemd

_udevadm-info() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q+[type]:t:(name symlink path property all)' \
        '--query=+[type]:t:(name symlink path property all)' \
        '-p+[device path]:str:' \
        '--path=+[device path]:str:' \
        '-n+[device name]:str:' \
        '--name=+[device name]:str:' \
        '-r[show root]' \
        '--root[show root]' \
        '-a[show attribute walk]' \
        '--attribute-walk[show attribute walk]' \
        '-x[export as environment]' \
        '--export[export as environment]' \
        '-P+[prefix]:str:' \
        '--export-prefix=+[prefix]:str:' \
        '-e[export db]' \
        '--export-db[export db]' \
        '-d[device id of file]' \
        '--device-id-of-file=+[file]:file:_files' \
        '-c[cleanup db]' \
        '--cleanup-db[cleanup db]' \
        '--wait-for-initialization=+[seconds]:n:' \
        '--no-pager[no pager]' \
        '*:device:'
}

_udevadm-info "$@"
