#compdef tuisky
# Documentation: https://github.com/sugyan/tuisky
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tuisky - Bluesky TUI client

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[path to configuration file]:file:_files' \
  '(-n --num-columns)'{-n,--num-columns}'=[max number of columns to display]:num' && ret=0

return ret
