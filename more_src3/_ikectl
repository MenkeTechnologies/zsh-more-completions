#compdef ikectl
# _ikectl — OpenBSD ikectl (control iked(8) IKEv2 daemon + manage a simple X.509 CA for IKEv2 peers; ca certificate operations, SA management, reload, monitor, log level)
# upstream: https://github.com/openbsd/src (usr.sbin/ikectl)
# Flags + commands from usr.sbin/ikectl/ikectl.8 on tip.

_ikectl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-q[do not ask for default confirmations]' \
        '-s+[control socket]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'ikectl command' \
                '(active:set active mode passive:set passive mode couple:load running SAs into kernel decouple:unload SAs from kernel load:reload policy from file reload:reload iked config monitor:monitor messages reset:reset (all|ca|id|policy|sa|user) show:show sa ca:manage CA log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                reset) _describe -t commands 'reset target' '(all ca id policy sa user)' ;;
                show) _describe -t commands 'show target' '(sa)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
                load) _arguments '1:policy:_files' ;;
                ca)
                    _arguments \
                        '1:CA name:' \
                        '*::ca-subcommand:(create delete install certificate key request sign show export)'
                    ;;
            esac
            ;;
    esac
}

_ikectl "$@"
