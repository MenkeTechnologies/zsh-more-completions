#compdef zpool-initialize
# _zpool-initialize — OpenZFS zpool initialize (write a pattern across unallocated regions of vdevs so subsequent reads return predictable data on thin-provisioned media; -c cancel, -s suspend, -w wait, -u uninitialize cancel + clean; positional pool then optional list of vdevs)
# upstream: https://github.com/openzfs/zfs
# Flags from openzfs cmd/zpool/zpool_main.c (zpool_do_initialize) on tip.

_zpool-initialize() {
    _arguments \
        '-c[cancel]' \
        '-s[suspend]' \
        '-u[uninitialize]' \
        '-w[wait until complete]' \
        '*:pool [vdev ...]:'
}

_zpool-initialize "$@"
