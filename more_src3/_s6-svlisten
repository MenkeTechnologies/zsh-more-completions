#compdef s6-svlisten
# _s6-svlisten — s6 supervision s6-svlisten (race-free: arm event listeners on one or more services, then exec a child program; the child runs WITH the listeners armed so events between launch and check are not missed)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-svlisten.c on tip; arg list is `[opts] servicedir... "" prog...`.

_s6-svlisten() {
    _arguments \
        '(-U -u -d -D -r -R)-u[notify when service is up]' \
        '(-U -u -d -D -r -R)-U[notify when service is up AND ready]' \
        '(-U -u -d -D -r -R)-d[notify when service is down]' \
        '(-U -u -d -D -r -R)-D[notify when service is down AND not started by sv]' \
        '(-U -u -d -D -r -R)-r[notify when service is ready]' \
        '(-U -u -d -D -r -R)-R[notify when service is NOT ready]' \
        '(-a -o)-a[require all servicedirs (AND)]' \
        '(-a -o)-o[require any servicedir (OR)]' \
        '-t+[timeout (ms)]:ms:' \
        '*::servicedirs-then-prog:'
}

_s6-svlisten "$@"
