#compdef victoria-logs
# Documentation: https://docs.victoriametrics.com/victorialogs/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Subset of flags verified in upstream "List of command-line flags".
# Use `victoria-logs -help` for the full list (Go flag package, single-dash).

# victoria-logs: VictoriaMetrics logs storage and query engine
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-storageDataPath=[path to directory where to store VictoriaLogs data]:dir:_files -/' \
  '-retentionPeriod=[log retention period]:duration:' \
  '-retention.maxDiskSpaceUsageBytes=[max disk space usage bytes]:bytes:' \
  '-retention.maxDiskUsagePercent=[max disk usage percent]:percent:' \
  '-futureRetention=[reject log entries with timestamps bigger than now+futureRetention]:duration:' \
  '-maxBackfillAge=[reject log entries older than now-maxBackfillAge]:duration:' \
  '-httpListenAddr=[TCP address to listen for HTTP requests]:addr:' \
  '-httpAuth.username=[HTTP basic auth username]:user:' \
  '-httpAuth.password=[HTTP basic auth password]:password:' \
  '-http.pathPrefix=[HTTP path prefix]:prefix:' \
  '-search.maxConcurrentRequests=[max concurrent search requests]:n:' \
  '-search.maxQueryDuration=[max query duration]:duration:' \
  '-defaultParallelReaders=[default number of parallel data readers]:n:' \
  '-insert.maxFieldsPerLine=[max log fields per line]:n:' \
  '-insert.maxLineSizeBytes=[max line size readable by /insert/* handlers]:bytes:' \
  '-partitionManageAuthKey=[authKey for /internal/partition/* endpoints]:key:' \
  '-delete.enable[enable /delete/* HTTP endpoints]' && ret=0
return ret
