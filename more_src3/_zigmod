#compdef zigmod
# Documentation: https://nektro.github.io/zigmod/commands/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: fabricated 'diff', 'graph', 'update' subcommands
#   (not in upstream command list).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'version:print zigmod version'
  'init:initialize a new project'
  'fetch:fetch dependencies'
  'ci:clean install of dependencies'
  'license:manage licenses'
  'sum:hash sum operations'
  'zpm:ZPM package manager operations'
  'aq:Aquila package operations'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'zigmod command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (aq)
        _arguments '1:aq subcommand:(add showjson install update)' && ret=0
        ;;
      (zpm)
        _arguments '1:zpm subcommand:(add showjson)' && ret=0
        ;;
    esac
    ;;
esac

return ret
