#compdef lintian-brush
# _lintian-brush — auto-fix common lintian issues (Debian/lintian-brush)
# upstream: https://salsa.debian.org/jelmer/lintian-brush
# Flags from lintian-brush(1) man page.

_lintian-brush() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-d --directory)'{-d+,--directory=}'[run in DIR (default current dir)]:dir:_files -/' \
        '(--update-changelog --no-update-changelog)--update-changelog[always update changelog]' \
        '(--update-changelog --no-update-changelog)--no-update-changelog[do not update changelog]' \
        '--list-fixers[list available fixers and exit]' \
        '--list-tags[list tags with fixers and exit]' \
        '--fixers-dir=[override fixers directory]:dir:_files -/' \
        '*--exclude=[exclude a fixer]:fixer:' \
        '--diff[print unified diff of changes]' \
        '--modern[use features not in Debian stable]' \
        '--compat-release=[compatibility release]:release:' \
        '--identity[print commit identity and exit]' \
        '--disable-net-access[do not use the network]' \
        '--dry-run[run fixers without committing]' \
        '--verbose[verbose output]' \
        '--debug[debug output]' \
        '--uncertain[allow lower-certainty changes]' \
        '--allow-reformatting[allow reformatting of changed files]' \
        '--stats[print fixer performance stats]' \
        '*:tag:'
}

_lintian-brush "$@"
