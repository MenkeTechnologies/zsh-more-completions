#compdef ils
# Documentation: https://www.sleuthkit.org/sleuthkit/man/ils.html
# Source: sleuthkit/sleuthkit man/ils.1 — list inode information of a file system.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-e[list every inode in the file system]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-s[time skew of original system in seconds]:seconds:' \
    '-m[display inode details in mactime format]' \
    '-O[list only inodes of removed files still open or executing]' \
    '-p[display orphan inodes (unallocated with no file name)]' \
    '-r[list only inodes of removed files]' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-v[verbose mode to stderr]' \
    '-V[display version]' \
    '(-a -A)-a[list only allocated inodes]' \
    '(-a -A)-A[list only unallocated inodes]' \
    '(-l -L)-l[list only inodes with at least one hard link]' \
    '(-l -L)-L[list only inodes without any hard links]' \
    '(-z -Z)-z[list only inodes likely to have not been used]' \
    '(-z -Z)-Z[list only inodes likely to be used]' \
    '*:image file:_files' \
    && ret=0

return ret
