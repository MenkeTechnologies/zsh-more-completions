#compdef yubikey-checker yubikey-cli yubikey-tool
# _yubikey-checker — Yubico yubikey-checker community CLI utility for verifying connected YubiKey OTP HMAC-SHA1 challenge-response PIV OpenPGP applets firmware version capabilities and certificate slots (Yubico team, Python); argparse
# upstream: https://github.com/Yubico/yubikey-manager

_yubikey-checker() {
    local -a sub=(
        'info:show device info'
        'list:list connected YubiKeys'
        'check:run health check'
        'firmware:show firmware version'
        'applet:list installed applets'
        'reset:factory reset'
        'config:device config'
        'piv:PIV operations'
        'oath:OATH operations'
        'otp:OTP operations'
        'fido:FIDO operations'
        'openpgp:OpenPGP operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[reader name]:str:' \
        '--reader=+[reader name]:str:' \
        '-d+[device serial]:n:' \
        '--device=+[device serial]:n:' \
        '--log-level=+[level]:l:(error warn info debug trace)' \
        '--log-file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'yubikey-checker subcommand' sub ;;
        args)
            case $words[1] in
                piv) _arguments \
                    '1:action:(info reset access keys certificates objects)' \
                    '*:slot:(9a 9c 9d 9e 82 83 84 85 86 87 88 89 8a 8b 8c 8d 8e 8f 90 91 92 93 94 95)' ;;
                oath) _arguments \
                    '1:action:(info reset access accounts add list code uri delete rename)' \
                    '*:account:' ;;
                fido) _arguments \
                    '1:action:(info reset access credentials fingerprints config)' ;;
                openpgp) _arguments \
                    '1:action:(info reset access keys certificates)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_yubikey-checker "$@"
