#compdef stellar-horizon horizon
# _stellar-horizon — Stellar Development Foundation stellar-horizon API server providing JSON-over-HTTP access to Stellar ledger transactions accounts and operations backed by stellar-core (stellar team, Go); cobra
# upstream: https://github.com/stellar/go

_stellar-horizon() {
    local -a sub=(
        'db:database operations'
        'ingest:ingest operations'
        'record-metrics:record metrics'
        'serve:start API server'
        'transform:transform data'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--port=+[port]:n:' \
        '--admin-port=+[port]:n:' \
        '--db-url=+[url]:str:' \
        '--db-max-open-connections=+[N]:n:' \
        '--db-max-idle-connections=+[N]:n:' \
        '--ingest[run ingest]' \
        '--stellar-core-url=+[url]:str:' \
        '--stellar-core-db-url=+[url]:str:' \
        '--captive-core-config-path=+[path]:file:_files -g "*.cfg"' \
        '--captive-core-storage-path=+[path]:dir:_files -/' \
        '--captive-core-http-port=+[port]:n:' \
        '--captive-core-binary-path=+[path]:file:_files' \
        '--captive-core-use-db[use captive core db]' \
        '--history-archive-urls=+[csv]:str:' \
        '--network-passphrase=+[str]:str:' \
        '--per-hour-rate-limit=+[N]:n:' \
        '--rate-limit-redis-key=+[key]:str:' \
        '--redis-url=+[url]:str:' \
        '--max-db-connections=+[N]:n:' \
        '--sse-update-frequency=+[N]:n:' \
        '--connection-timeout=+[N]:n:' \
        '--max-http-request-size=+[N]:n:' \
        '--per-request-payment-channel-tx-fee-limit=+[N]:n:' \
        '--client-query-timeout=+[N]:n:' \
        '--apply-migrations[apply migrations]' \
        '--log-level=+[level]:l:(debug info warn error fatal panic)' \
        '--log-file=+[file]:file:_files' \
        '--log-format=+[fmt]:f:(text json)' \
        '--skip-cursor-update[skip cursor update]' \
        '--ingest-disable-state-verification[disable state verification]' \
        '--no-ingest-state-verification-checkpoint-frequency[no checkpoint freq]' \
        '--max-supported-protocol-version=+[N]:n:' \
        '--checkpoint-frequency=+[N]:n:' \
        '--exp-enable-ingestion-filtering[enable ingestion filtering]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'stellar-horizon subcommand' sub ;;
        args) ;;
    esac
}

_stellar-horizon "$@"
