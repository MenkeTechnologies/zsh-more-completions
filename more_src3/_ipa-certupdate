#compdef ipa-certupdate
# Documentation: https://github.com/freeipa/freeipa/blob/master/client/man/ipa-certupdate.1
# Reference accessed: 2026-05-16
# Verified: upstream client/man/ipa-certupdate.1.

# ipa-certupdate: update local IPA cert tracking and trust chain
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[print debugging info]' \
  '(-q --quiet)'{-q,--quiet}'[output only errors]' \
  '--log-file=[log to file]:file:_files' && ret=0
return ret
