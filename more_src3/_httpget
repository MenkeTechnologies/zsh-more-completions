#compdef httpget
# _httpget — minimal HTTP GET client (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Usage from httpget.c (positional URL).

_httpget() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '1:URL:_urls'
}

_httpget "$@"
