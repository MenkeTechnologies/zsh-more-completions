#compdef lp
# Documentation: https://manpages.debian.org/lp
# Source: OpenPrinting/cups systemv/lp.c — print files via CUPS (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[use encryption]' \
    '-U+[username for authentication]:user:_users' \
    '-c[copy to spool dir (always enabled)]' \
    '-d+[destination printer or class]:dest:_default' \
    '-f+[form name]:form:_default' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '-i+[change existing job]:job-id:_default' \
    '-m[send email when job is done]' \
    '-n+[number of copies]:n:_default' \
    '*-o+[print option]:name=value:_default' \
    '(-p -q)-p+[queue priority]:priority:_default' \
    '(-p -q)-q+[queue priority]:priority:_default' \
    '-s[silent mode]' \
    '-t+[job title]:title:_default' \
    '-y+[mode-list]:modes:_default' \
    '-H+[hold mode]:mode:(hold immediate restart resume HH:MM)' \
    '-P+[page list e.g. 1,3-5]:pages:_default' \
    '-S+[character set]:charset:_default' \
    '-T+[content-type]:type:_default' \
    '*:file:_files' \
    && ret=0

return ret
