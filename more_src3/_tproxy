#compdef tproxy
# Documentation: https://github.com/kevwan/tproxy
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for kevwan/tproxy transparent proxy

_arguments -s \
  '-d+[delay to relay packets]:duration' \
  '-down+[downward speed limit (bytes/second)]:bytes_per_second' \
  '-l+[local address to listen on]:host:_hosts' \
  '-p+[local port to listen on]:port' \
  '-q[quiet mode]' \
  '-r+[remote address (host:port) to connect]:host:port' \
  '-s[enable statistics]' \
  '-t+[protocol type]:protocol:(http2 grpc redis mongodb)' \
  '-up+[upward speed limit (bytes/second)]:bytes_per_second'
