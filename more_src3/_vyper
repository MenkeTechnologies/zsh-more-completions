#compdef vyper
# Documentation: https://docs.vyperlang.org/en/stable/compiling-a-contract.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# --format long form (real flag is -f only); fabricated --no-optimize
# (real form is --optimize none); fabricated -o flag (real form is -o
# only as file output redirect, not output-dir); fabricated
# --output-dir, --search-paths, --enable-decimals, --traceback-limit
# (not in upstream docs).
# Added: -Wnone, -Werror, --base64, --traceback, --venom (per docs).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-f+[output format]:format:(abi abi_python asm bytecode bytecode_runtime combined_json devdoc external_interface interface ir ir_json archive layout metadata opcodes source_map userdoc ast)' \
  '--evm-version=[target EVM version]:version:(london paris shanghai cancun prague)' \
  '--optimize=[optimization mode]:level:(none gas codesize)' \
  '-o+[redirect output to file]:file:_files' \
  '-p+[root path for interface search]:directory:_directories' \
  '--storage-layout-file=[storage layout override]:file:_files -g "*.json"' \
  '--experimental-codegen[use experimental Venom code generation]' \
  '--venom[use experimental Venom code generation]' \
  '--base64[output archive in base64]' \
  '-Wnone[suppress all warnings]' \
  '-Werror[promote warnings to errors]' \
  '--traceback[show Python traceback on errors]' \
  '*:vyper source files:_files -g "*.vy"' && ret=0

return ret
