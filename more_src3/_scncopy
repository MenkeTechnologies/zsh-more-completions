#compdef scncopy
# Documentation: dwarves scncopy
# Source: acmel/dwarves scncopy.c (master) — copy ELF sections from one file to another (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a)*-s+[copy named ELF section]:section:_default' \
    '(-s -a)-a[copy all sections]' \
    '-o+[output ELF file]:file:_files' \
    '(-? --help --usage)'{-\\?,--help,--usage}'[show usage]' \
    '1:input ELF file:_files' \
    && ret=0

return ret
