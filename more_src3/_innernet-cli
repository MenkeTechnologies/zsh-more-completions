#compdef innernet-cli innernet
# _innernet-cli — Tonari innernet WireGuard-based private mesh network CLI alias (tonarino team, Rust); clap-rs
# upstream: https://github.com/tonarino/innernet

_innernet-cli() {
    local -a sub=(
        'install:join a network'
        'show:show network'
        'up:start interface'
        'fetch:fetch updates'
        'uninstall:uninstall interface'
        'add-peer:add peer'
        'rename-peer:rename peer'
        'add-cidr:add CIDR'
        'rename-cidr:rename CIDR'
        'delete-cidr:delete CIDR'
        'list-cidrs:list CIDRs'
        'disable-peer:disable peer'
        'enable-peer:enable peer'
        'add-association:add association'
        'delete-association:delete association'
        'list-associations:list associations'
        'set-listen-port:set listen port'
        'override-endpoint:override endpoint'
        'completions:generate completions'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--no-routing[no routing]' \
        '--backend=+[backend]:b:(userspace kernel)' \
        '--mtu=+[mtu]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'innernet subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '1:invite file:_files' \
                    '--default-name[use default name]' \
                    '--name=+[name]:str:' \
                    '--delete-invite[delete invite after install]' ;;
                completions) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_innernet-cli "$@"
