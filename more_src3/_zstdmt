#compdef zstdmt zstdcat
# Documentation: zstd --help (Zstandard)
# Source: multi-threaded zstd shortcut (zstdmt = zstd -T0) and zstdcat (zstd -dc).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-H,--long-help}'[show extended help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-1,-2,-3,-4,-5,-6,-7,-8,-9}'[compression level 1-9]' \
    '--fast=[fast compression level]:level:' \
    '--ultra[allow levels beyond 19]' \
    '--long=-[long mode windowLog]::windowLog:' \
    {-d,--decompress,--uncompress}'[decompress]' \
    {-z,--compress}'[compress]' \
    {-t,--test}'[test integrity]' \
    {-l,--list}'[list information about .zst files]' \
    {-c,--stdout,--to-stdout}'[write to stdout]' \
    {-f,--force}'[overwrite/follow symlinks]' \
    {-k,--keep}'[keep input files]' \
    '--rm[remove source after success]' \
    {-r,--recursive}'[operate recursively]' \
    '--filelist=[load filenames from FILE]:file:_files' \
    {-o+,--output=}'[output file]:file:_files' \
    {-D+,--dict=}'[dictionary file]:file:_files' \
    '--patch-from=[reference file for diff]:file:_files' \
    '--train[train a dictionary from samples]' \
    '--train-cover[train using cover algorithm]' \
    '--train-fastcover[train using fastcover algorithm]' \
    '--train-legacy[train using legacy algorithm]' \
    {-T+,--threads=}'[number of threads (0=detect)]:n:' \
    '--single-thread[single-threaded mode]' \
    '--adapt=-[adaptive compression]::range:' \
    '-B+[set block size]:size:' \
    '--no-dictID[do not save dictID]' \
    '--no-check[disable integrity check]' \
    '--no-progress[do not display progress]' \
    {-q,--quiet}'[quiet mode]' \
    {-v,--verbose}'[verbose mode]' \
    '--format=[output format]:fmt:(zstd lz4 gzip xz lzma)' \
    '--sparse[sparse mode (default)]' \
    '--no-sparse[disable sparse mode]' \
    '*:file:_files' \
    && ret=0

return ret
