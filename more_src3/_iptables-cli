#compdef iptables-cli
# _iptables-cli — netfilter iptables IPv4 packet filtering CLI alias (netfilter team, C); custom argparse
# upstream: https://git.netfilter.org/iptables/

_iptables-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A+[append rule to chain]:str:' \
        '--append=+[chain]:str:' \
        '-C+[check rule]:str:' \
        '--check=+[chain]:str:' \
        '-D+[delete rule from chain]:str:' \
        '--delete=+[chain]:str:' \
        '-I+[insert rule into chain]:str:' \
        '--insert=+[chain]:str:' \
        '-R+[replace rule]:str:' \
        '--replace=+[chain]:str:' \
        '-L+[list rules]:str:' \
        '--list[list rules]' \
        '-S+[print rules in iptables-save format]:str:' \
        '--list-rules=+[chain]:str:' \
        '-F+[flush chain]:str:' \
        '--flush[flush chain]' \
        '-Z+[zero counters]:str:' \
        '--zero[zero counters]' \
        '-N+[create user-defined chain]:str:' \
        '--new=+[chain]:str:' \
        '-X+[delete user-defined chain]:str:' \
        '--delete-chain[delete chain]' \
        '-P+[set chain policy]:str:' \
        '--policy=+[chain target]:str:' \
        '-E+[rename user-defined chain]:str:' \
        '--rename-chain=+[chain]:str:' \
        '-t+[table]:t:(filter nat mangle raw security)' \
        '--table=+[table]:t:(filter nat mangle raw security)' \
        '-p+[protocol]:p:(tcp udp udplite icmp icmpv6 esp ah sctp mh all)' \
        '--protocol=+[protocol]:p:(tcp udp udplite icmp icmpv6 esp ah sctp mh all)' \
        '-s+[source]:str:' \
        '--source=+[source]:str:' \
        '--src=+[source]:str:' \
        '-d+[destination]:str:' \
        '--destination=+[destination]:str:' \
        '--dst=+[destination]:str:' \
        '-m+[match]:str:' \
        '--match=+[match]:str:' \
        '-j+[target jump]:t:(ACCEPT DROP REJECT QUEUE RETURN LOG MARK MASQUERADE SNAT DNAT REDIRECT TCPMSS TPROXY TTL ULOG CONNMARK CONNTRACK CT DSCP HMARK NFQUEUE NETMAP NOTRACK RATEEST AUDIT CHECKSUM CLUSTERIP IDLETIMER NFLOG RAWPOST SECMARK SET TEE)' \
        '--jump=+[target]:t:(ACCEPT DROP REJECT QUEUE RETURN LOG MARK MASQUERADE SNAT DNAT REDIRECT TCPMSS TPROXY)' \
        '-g+[goto chain]:str:' \
        '--goto=+[chain]:str:' \
        '-i+[in interface]:_net_interfaces' \
        '--in-interface=+[in interface]:_net_interfaces' \
        '-o+[out interface]:_net_interfaces' \
        '--out-interface=+[out interface]:_net_interfaces' \
        '-f[fragmented]' \
        '--fragment[fragmented]' \
        '-c+[set counters]:str:' \
        '--set-counters=+[counters]:str:' \
        '-n[no DNS]' \
        '--numeric[no DNS]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w+[wait seconds]:n:' \
        '--wait=+[wait seconds]:n:' \
        '-W+[wait interval us]:n:' \
        '--wait-interval=+[wait interval us]:n:' \
        '-x[exact numbers]' \
        '--exact[exact numbers]' \
        '--line-numbers[show line numbers]' \
        '--modprobe=+[command]:file:_files' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '*:arg:'
}

_iptables-cli "$@"
