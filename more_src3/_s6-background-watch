#compdef s6-background-watch
# _s6-background-watch — s6 supervision s6-background-watch (run a self-daemonizing program in the foreground for s6-supervise: tracks the PID it writes to pidfile, exits when that PID dies)
# upstream: https://github.com/skarnet/s6
# Flags from src/supervision/s6-background-watch.c on tip.

_s6-background-watch() {
    _arguments \
        '-t+[max time to wait for pidfile (ms)]:ms:' \
        '-d+[notification fd]:fd:' \
        '1:pidfile:_files' \
        '*::program:_command_names -e'
}

_s6-background-watch "$@"
