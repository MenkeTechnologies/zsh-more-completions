#compdef ifstated
# _ifstated — OpenBSD ifstated (run commands in response to network interface link-state changes or scripted tests; commonly paired with carp(4)/pf(4) for failover orchestration)
# upstream: https://github.com/openbsd/src (usr.sbin/ifstated)
# Flags from usr.sbin/ifstated/ifstated.8 on tip.

_ifstated() {
    _arguments \
        '-d[debug (foreground + verbose to stderr)]' \
        '-h[show usage]' \
        '-i[ignore initial interface state]' \
        '-n[validate config + exit]' \
        '-v[verbose log_msg]' \
        '*-D+[define macro=value]:macro=value:' \
        '-f+[config file (default /etc/ifstated.conf)]:file:_files'
}

_ifstated "$@"
