#compdef ldap-whoami
# _ldap-whoami — distro-shipped LDAP whoami wrapper (alias of ldapwhoami(1); issues the LDAP WhoAmI? extended operation against the server to print the authzid associated with the current bind; -H URI, -D bind DN, -w password, -y password file, -x simple bind, -Z TLS, -v verbose, -h help, -V version)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapwhoami)
# Flags from OpenLDAP clients/tools/ldapwhoami.c on tip.

_ldap-whoami() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-v[verbose]'
}

_ldap-whoami "$@"
