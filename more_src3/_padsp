#compdef padsp
# Documentation: https://manpages.debian.org/padsp.1
# Source: PulseAudio — LD_PRELOAD shim that wraps OSS /dev/dsp / /dev/mixer / /dev/sndstat over PA.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-s[PulseAudio server to connect to]:server:' \
    '-n[client application name passed to server]:name:' \
    '-m[stream name passed to server]:name:' \
    '-M[disable /dev/mixer emulation]' \
    '-S[disable /dev/sndstat emulation]' \
    '-D[disable /dev/dsp emulation]' \
    '-d[enable debug output]' \
    '*:command:_command_names -e' \
    && ret=0

return ret
