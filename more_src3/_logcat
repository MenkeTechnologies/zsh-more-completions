#compdef logcat
# Android logcat - View device log output

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a log_levels=(
  'V:verbose'
  'D:debug'
  'I:info'
  'W:warning'
  'E:error'
  'F:fatal'
  'S:silent'
)

local -a log_formats=(
  'brief:display priority, tag, and PID of originating process'
  'long:display all metadata fields and separate messages with blank lines'
  'process:display PID only'
  'raw:display raw log message with no metadata'
  'tag:display priority and tag only'
  'thread:legacy format showing priority, PID, and TID'
  'threadtime:display date, invocation time, priority, tag, PID, and TID'
  'time:display date, invocation time, priority, tag, and PID'
  'color:display with color-coded priority'
  'epoch:display time as seconds since epoch'
  'monotonic:display time as monotonic clock'
  'printable:ensure binary content is escaped'
  'uid:show UID or Android ID of logged process'
  'usec:display time with microsecond precision'
  'UTC:display time as UTC'
  'year:add year to displayed time'
  'zone:add local timezone to displayed time'
)

local -a log_buffers=(
  'main:main log buffer'
  'system:system log buffer'
  'radio:radio/telephony log buffer'
  'events:events log buffer'
  'crash:crash log buffer'
  'default:main, system, and crash'
  'all:all buffers'
)

_arguments -s -S \
  '(-s --silent)*'{-s,--silent}'[set default filter to silent]' \
  '(-f --file)'{-f+,--file=}'[log to file]:log file:_files' \
  '(-r --rotate-kbytes)'{-r+,--rotate-kbytes=}'[rotate log every N kbytes]:kbytes:' \
  '(-n --rotate-count)'{-n+,--rotate-count=}'[set max number of rotated logs]:count:' \
  '--id=[log to file only if signature changes]:id:' \
  '*'{-v+,--format=}'[set output format]:format:->format' \
  '-D[print dividers between each log buffer]' \
  '(-c --clear)'{-c,--clear}'[clear the entire log and exit]' \
  '(-d --dump)'{-d,--dump}'[dump the log and exit (do not block)]' \
  '(-e --regex)'{-e+,--regex=}'[only print lines matching regex]:regex:' \
  '(-m --max-count)'{-m+,--max-count=}'[quit after printing N lines]:count:' \
  '--print[with --regex, print all messages even if not matching]' \
  '(-t --tail)'{-t+,--tail=}'[print only most recent N lines]:count:' \
  '(-T --tail-time)'{-T+,--tail-time=}'[print most recent lines since time]:time:' \
  '(-g --buffer-size)'{-g,--buffer-size}'[get ring buffer size and exit]' \
  '(-G --buffer-size-set)'{-G+,--buffer-size-set=}'[set ring buffer size]:size:' \
  '-L[dump log of last reboot]' \
  '*'{-b+,--buffer=}'[request alternate ring buffer]:buffer:->buffer' \
  '(-B --binary)'{-B,--binary}'[output the log in binary]' \
  '(-S --statistics)'{-S,--statistics}'[output statistics]' \
  '(-p --prune)'{-p+,--prune=}'[set/get prune list]:prune list:' \
  '-P[print prune list]' \
  '--pid=[only print logs from given PID]:pid:' \
  '--wrap[sleep and wait for new log entries when buffer full]' \
  '--uid=[only print logs from given UID]:uid:' \
  '*:filter spec:' && ret=0

case $state in
  (format)
    _describe -t formats 'log format' log_formats && ret=0
    ;;
  (buffer)
    _describe -t buffers 'log buffer' log_buffers && ret=0
    ;;
esac

return ret
