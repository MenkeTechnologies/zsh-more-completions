#compdef ldns-revoke
# _ldns-revoke — NLnet Labs ldns-revoke (set REVOKE bit on a DNSKEY in a key file; used as part of RFC 5011 trust-anchor rollover)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-revoke.c usage on tip.

_ldns-revoke() {
    _arguments \
        '-n[print to stdout instead of writing back to file]' \
        '1:keyfile:_files'
}

_ldns-revoke "$@"
