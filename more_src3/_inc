#compdef inc
# Documentation: man inc(1)
# Source: nmh uip/inc.c (master) — incorporate new mail (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-audit+[audit file]:file:_files' \
    '-noaudit[no audit]' \
    '(-changecur -nochangecur)-changecur[change current message]' \
    '(-changecur -nochangecur)-nochangecur[do not change current]' \
    '-file+[input maildrop file]:file:_files' \
    '-form+[scan format file]:file:_files' \
    '-format+[scan format string]:string:_default' \
    '-host+[POP host]:host:_hosts' \
    '-user+[POP username]:user:_default' \
    '(-pack -nopack)-pack+[pack file]:file:_files' \
    '(-pack -nopack)-nopack[do not pack]' \
    '-port+[port number/name]:port:_default' \
    '(-silent -nosilent)-silent[silent operation]' \
    '(-silent -nosilent)-nosilent[non-silent]' \
    '(-truncate -notruncate)-truncate[truncate maildrop]' \
    '(-truncate -notruncate)-notruncate[do not truncate]' \
    '-width+[output column width]:cols:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '-snoop[show server transcript]' \
    '(-sasl -nosasl)-sasl[use SASL]' \
    '(-sasl -nosasl)-nosasl[no SASL]' \
    '-saslmech+[SASL mechanism]:mechanism:_default' \
    '-proxy+[proxy command]:command:_command_names -e' \
    '1::+folder:_default' \
    && ret=0

return ret
