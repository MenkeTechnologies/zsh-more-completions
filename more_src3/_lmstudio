#compdef lms
# Documentation: https://github.com/lmstudio-ai/lms and https://lmstudio.ai/docs/cli
# Reference accessed: 2026-05-21
# Verified: upstream README + docs at the URLs above.

# Zsh completion for lms - LM Studio CLI (local LLM management)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'lms command' \
      'status[check LM Studio status]' \
      'ls[list downloaded models]' \
      'ps[list loaded models]' \
      'load[load a model into memory]' \
      'unload[unload a model]' \
      'get[download a model from the hub]' \
      'import[add a local model file]' \
      'chat[start an interactive chat]' \
      'server[control the local inference server]' \
      'log[stream LM Studio logs]' \
      'daemon[manage headless daemon]' \
      'runtime[manage inference runtime]' \
      'create[create a new SDK project]' \
      'dev[development mode]' \
      'push[push to LM Studio hub]' \
      'clone[clone a hub artifact]' \
      'login[login to LM Studio hub]' \
      'link[manage device linking]' \
      'bootstrap[bootstrap lms onto PATH]' \
      'version[show version]' && ret=0
    ;;
  args)
    case $line[1] in
      load)
        _arguments \
          '--gpu[GPU offload amount]:level:(max auto off 0.0 0.5 1.0)' \
          '--context-length[context length to load model with]:n:' \
          '-y[load with max GPU acceleration, no prompts]' \
          '--identifier[set load identifier]:name:' && ret=0
        ;;
      unload)
        _arguments '--all[unload all loaded models]' && ret=0
        ;;
      ls|ps)
        _arguments '--json[output as JSON]' && ret=0
        ;;
      server)
        _values 'server action' \
          'start[start the local inference server]' \
          'stop[stop the local inference server]' \
          'status[show server status]' && ret=0
        ;;
      log)
        _values 'log action' 'stream[stream message traffic]' && ret=0
        ;;
      daemon)
        _values 'daemon action' \
          'up[start daemon]' \
          'down[stop daemon]' \
          'status[daemon status]' \
          'update[update daemon]' && ret=0
        ;;
    esac
    ;;
esac

return ret
