#compdef zef-j zef-js
# Documentation: https://github.com/ugexe/zef
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: upstream zef has no 'j' or 'js' subcommand. User wrapper that may
#       delegate to '_zef' if a completion for zef itself is on fpath.

local curcontext="$curcontext" state line ret=1

(( $+functions[_zef] )) || autoload -Uz _zef 2>/dev/null
if (( $+functions[_zef] )); then
  _zef "$@"
  return
fi

_arguments \
  '*::zef arg:' && ret=0

return ret
