#compdef tkdiff
# Documentation: man tkdiff(1)
# Source: tkdiff (man) — graphical Tk-based diff utility (Tcl/Tk).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-conflict[merge file with conflict markers]' \
    '-r-[compare with most recent or specified revision]:revision:_default' \
    '-rev-[(synonym for -r)]:revision:_default' \
    '*:file:_files' \
    && ret=0

return ret
