#compdef terrascan
# _terrascan-bin — Tenable Terrascan IaC static analyzer (Tenable, Go); detect compliance + security violations in IaC
# upstream: https://github.com/tenable/terrascan

_terrascan-bin() {
    local -a sub=(
        'completion:print shell completion'
        'help:show help'
        'init:initialize terrascan policy repo'
        'scan:scan IaC files for violations'
        'server:run terrascan as a server'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-c+[config file]:file:_files' \
        '--config-path+[config file]:file:_files' \
        '-l+[log level]:level:(debug info warn error panic fatal)' \
        '--log-level+[log level]:level:' \
        '-x+[log type]:type:(console json)' \
        '--log-type+[log type]:type:' \
        '-o+[output type]:fmt:(json yaml xml junit-xml sarif github-sarif human)' \
        '--output+[output type]:fmt:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'terrascan subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments \
                    '-d+[dir or repo]:dir:_files -/' \
                    '--iac-dir+[iac dir]:dir:_files -/' \
                    '-f+[file]:file:_files' \
                    '--iac-file+[file]:file:_files' \
                    '-i+[iac type]:type:(terraform k8s helm kustomize docker arm cft tfplan)' \
                    '--iac-type+[iac type]:type:' \
                    '--iac-version+[iac version]:v:' \
                    '-t+[cloud provider]:cloud:(aws azure gcp github docker k8s)' \
                    '--cloud-type+[cloud provider]:cloud:' \
                    '-p+[policy path]:path:_files -/' \
                    '--policy-path+[policy path]:path:_files -/' \
                    '--policy-type+[policy type]:type:(aws azure gcp github docker k8s)' \
                    '-r+[remote type]:type:(git s3 gcs http terraform-registry)' \
                    '--remote-type+[remote type]:type:' \
                    '--remote-url+[remote url]:url:_urls' \
                    '-s+[skip rules]:rules:' \
                    '--skip-rules+[skip rules]:rules:' \
                    '--scan-rules+[scan rules]:rules:' \
                    '--use-colors+[colors]:bool:(true false)' \
                    '--use-terraform-cache[use terraform cache]' \
                    '--verbose[verbose]' \
                    '--severity+[severity threshold]:level:(low medium high)' \
                    '--non-recursive[non-recursive scan]' \
                    '--show-passed[show passed]' \
                    '--include-passed-rules[include passed]' \
                    '--temp-dir+[temp dir]:dir:_files -/' \
                    '*:file:_files' ;;
                server) _arguments \
                    '-p+[port]:port:' \
                    '--port+[port]:port:' \
                    '--cert-path+[cert]:file:_files' \
                    '--key-path+[key]:file:_files' ;;
                init) _arguments \
                    '--config+[config]:file:_files' \
                    '--policy-repo-url+[policy repo url]:url:_urls' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_terrascan-bin "$@"
