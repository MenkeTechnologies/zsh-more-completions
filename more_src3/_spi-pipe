#compdef spi-pipe
# _spi-pipe — Christophe Blaess spi-tools spi-pipe CLI for transferring data through the Linux SPIdev character device performing simultaneous full-duplex read/write through stdin/stdout pipe block-size mode (cpb team, C); getopt
# upstream: https://github.com/cpb-/spi-tools

_spi-pipe() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:file:_files -g "/dev/spidev*"' \
        '--device=+[device]:file:_files -g "/dev/spidev*"' \
        '-s+[block size bytes]:n:' \
        '--size=+[block size bytes]:n:' \
        '-n+[number of blocks]:n:' \
        '--number=+[number of blocks]:n:' \
        '-b+[bits per word]:n:' \
        '--bits=+[bits per word]:n:' \
        '-m+[mode]:n:(0 1 2 3)' \
        '--mode=+[mode]:n:(0 1 2 3)' \
        '-l[LSB first]' \
        '--lsb[LSB first]'
}

_spi-pipe "$@"
