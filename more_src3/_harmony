#compdef harmony hmy
# _harmony — Harmony harmony node daemon and hmy CLI for the Harmony Effective Proof of Stake sharded blockchain (harmony-one team, Go); cobra
# upstream: https://github.com/harmony-one/harmony

_harmony() {
    local -a sub=(
        'config:configuration subcommands'
        'dumpconfig:dump default config'
        'keys:key subcommands'
        'rpc:JSON-RPC subcommands'
        'transfer:transfer ONE'
        'transfer-cross-shard:cross-shard transfer'
        'staking:staking subcommands'
        'governance:governance subcommands'
        'curl:curl-style raw rpc'
        'cookie:cookie subcommands'
        'failures:show node failures'
        'blockchain:blockchain subcommands'
        'utility:utility subcommands'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--node=+[node URL]:url:_urls' \
        '-n+[node URL]:url:_urls' \
        '--http=+[http URL]:url:_urls' \
        '--ws=+[ws URL]:url:_urls' \
        '--shard=+[shard id]:n:' \
        '-s+[shard id]:n:' \
        '--from=+[from address]:str:' \
        '--from-shard=+[from shard]:n:' \
        '--to=+[to address]:str:' \
        '--to-shard=+[to shard]:n:' \
        '--amount=+[amount ONE]:f:' \
        '--gas-price=+[gas price]:f:' \
        '--gas-limit=+[gas limit]:n:' \
        '--nonce=+[nonce]:n:' \
        '--passphrase=+[passphrase]:str:' \
        '--passphrase-file=+[passphrase file]:file:_files' \
        '--keystore=+[keystore]:file:_files' \
        '--ledger[use ledger]' \
        '--legacy[legacy mode]' \
        '--print-json[print json]' \
        '-j[print json]' \
        '--ips=+[bootnodes csv]:str:' \
        '--blockchain-config=+[chain config]:file:_files' \
        '--log-folder=+[log dir]:dir:_files -/' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'harmony subcommand' sub ;;
        args)
            case $words[1] in
                keys) _arguments '1:keys cmd:(add list remove import import-private-key import-ks export-private-key generate-bls-key generate-bls-keys recover-bls-key)' ;;
                staking) _arguments '1:staking cmd:(create-validator edit-validator delegate undelegate collect-rewards)' ;;
                blockchain) _arguments '1:blockchain cmd:(transaction-by-hash transaction-receipt block-by-hash block-by-number block-numbers latest-headers utility-metadata)' ;;
                utility) _arguments '1:utility cmd:(addrs metadata shard-id pad-zeros)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_harmony "$@"
