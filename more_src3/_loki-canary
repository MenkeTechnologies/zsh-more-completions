#compdef loki-canary
# _loki-canary — Grafana Loki end-to-end correctness/latency canary
# upstream: https://github.com/grafana/loki
# Flags from cmd/loki-canary/main.go on tip.

_loki-canary() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-labelname=[label name for canary log selector]:name:' \
        '-labelvalue=[label value for canary log selector]:value:' \
        '-streamname=[stream label name]:name:' \
        '-streamvalue=[stream label value]:value:' \
        '-port=[metrics port]:port:' \
        '-addr=[Loki server URL\:Port]:url:_urls' \
        '-push[push logs to Loki directly]' \
        '-tls[Loki connection uses TLS]' \
        '-cert-file=[client TLS cert]:file:_files' \
        '-key-file=[client TLS key]:file:_files' \
        '-ca-file=[client TLS CA]:file:_files' \
        '-insecure[allow insecure TLS]' \
        '-user=[Loki username]:user:' \
        '-pass=[Loki password]:pw:' \
        '-tenant-id=[X-Scope-OrgID value]:id:' \
        '-write-timeout=[write request timeout]:dur:' \
        '-write-min-backoff=[initial write retry backoff]:dur:' \
        '-write-max-backoff=[max write retry backoff]:dur:' \
        '-write-max-retries=[max write retry count]:n:' \
        '-query-timeout=[query request timeout]:dur:' \
        '-interval=[interval between log entries]:dur:' \
        '-out-of-order-percentage=[%% of entries sent out of order (0-100)]:n:' \
        '-out-of-order-min=[min OOO backshift]:dur:' \
        '-out-of-order-max=[max OOO backshift]:dur:' \
        '-size=[bytes per log line]:n:' \
        '-wait=[wait for websocket entries before query fallback]:dur:' \
        '-max-wait=[max wait before declaring entries missing]:dur:' \
        '-pruneinterval=[sent-vs-received reconcile interval]:dur:' \
        '-buckets=[response_latency histogram bucket count]:n:' \
        '-query-append=[LogQL filters to append to canary query]:expr:' \
        '-labels=[csv of labels (overrides labelname/streamname)]:csv:' \
        '-metric-test-interval=[metric test interval]:dur:' \
        '-metric-test-range=[metric test range]:dur:' \
        '-cache-test-interval=[cache test interval]:dur:' \
        '-cache-test-range=[cache test range]:dur:' \
        '-cache-test-now=[cache test "now" backshift]:dur:' \
        '-spot-check-interval=[spot-check sample interval]:dur:' \
        '-spot-check-max=[max age for spot-check entries]:dur:' \
        '-spot-check-query-rate=[spot-check query rate]:dur:' \
        '-spot-check-initial-wait=[spot-check initial wait]:dur:'
}

_loki-canary "$@"
