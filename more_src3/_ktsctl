#compdef ktsctl
# Documentation: https://sr.ht/~hadronized/kak-tree-sitter/
# Reference accessed: 2026-05-19
# Verified: kak-tree-sitter wiki "Using ktsctl" (man.sr.ht). Current
# ktsctl exposes one subcommand per action: help fetch compile install
# sync query remove prune. Usage is `ktsctl <COMMAND> <LANGS...>`.
# Removed from prior file: invented manage/info/list/completion
# subcommands and -c/--config, -v/--verbose, -q/--quiet, -V/--version,
# -l/--lang flags (current ktsctl takes languages positionally); kept
# documented -a/--all and remove's -p/--prune; replaced bogus
# man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show reference documentation'
  'fetch:download runtime resources for language(s)'
  'compile:compile runtime resources for language(s)'
  'install:install compiled resources for language(s)'
  'sync:fetch + compile + install (full workflow)'
  'query:show information about configured/installed resources'
  'remove:remove installed grammars and/or queries'
  'prune:remove all unpinned grammars and queries'
)

_arguments -C \
  '(- *)--help[show help information]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'ktsctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sync|query)
        _arguments \
          '(-a --all)'{-a,--all}'[apply to all configured languages]' \
          '--help[show help information]' \
          '*::language:' && ret=0 ;;
      (remove)
        _arguments \
          '-p[also prune unpinned resources]' \
          '--help[show help information]' \
          '*::language:' && ret=0 ;;
      (fetch|compile|install)
        _arguments \
          '--help[show help information]' \
          '*::language:' && ret=0 ;;
      (*)
        _arguments '--help[show help information]' && ret=0 ;;
    esac ;;
esac

return ret
