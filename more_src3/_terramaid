#compdef terramaid
# Documentation: https://github.com/RoseSecurity/Terramaid
# Reference accessed: 2026-05-21
# Verified: upstream README — terramaid uses cobra with a single `run`
# subcommand. Real flags: -c/--chart-type, -r/--direction,
# -h/--help, -o/--output, -s/--subgraph-name, -b/--tf-binary,
# -p/--tf-plan, -w/--working-dir, -v/--verbose.
# Previous file passed through everything to _default with no real flags.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:generate a Mermaid diagram from a terraform plan or working dir'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t cmds 'terramaid command' commands && ret=0 ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '(-c --chart-type)'{-c+,--chart-type=}'[Mermaid diagram type (default flowchart)]:type' \
          '(-r --direction)'{-r+,--direction=}'[diagram direction (default TD)]:direction:(TD LR RL BT)' \
          '(-o --output)'{-o+,--output=}'[output file (default Terramaid.md)]:file:_files' \
          '(-s --subgraph-name)'{-s+,--subgraph-name=}'[subgraph label (default Terraform)]:name' \
          '(-b --tf-binary)'{-b+,--tf-binary=}'[terraform binary path]:file:_files' \
          '(-p --tf-plan)'{-p+,--tf-plan=}'[terraform plan file]:file:_files' \
          '(-w --working-dir)'{-w+,--working-dir=}'[terraform working dir]:dir:_directories' \
          '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
