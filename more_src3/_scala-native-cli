#compdef scala-native-cli scalanative
# _scala-native-cli — Denys Shabalin Scala Native ahead-of-time Scala-to-native compiler CLI alias (scala-native team, Scala/Rust); sbt+clap hybrid
# upstream: https://github.com/scala-native/scala-native

_scala-native-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--mode=+[mode]:m:(debug release-fast release-full release-size)' \
        '--lto=+[lto]:l:(none thin full)' \
        '--gc=+[gc]:g:(none boehm immix commix)' \
        '--target=+[target triple]:str:' \
        '--clang=+[clang]:file:_files' \
        '--clangpp=+[clang++]:file:_files' \
        '--compile-options=+[compile options]:str:' \
        '--linking-options=+[linking options]:str:' \
        '--check[enable nir checking]' \
        '--check-fatal-warnings[treat warnings as errors]' \
        '--dump[dump intermediate output]' \
        '--no-optimize[disable optimizations]' \
        '--multithreading[enable multithreading]' \
        '--no-multithreading[disable multithreading]' \
        '--debug-info[include debug info]' \
        '--debug-metadata[include debug metadata]' \
        '--use-incremental-compilation[incremental]' \
        '--workdir=+[workdir]:dir:_files -/' \
        '--basedir=+[basedir]:dir:_files -/' \
        '--main=+[main class]:str:' \
        '-o+[output]:file:_files' \
        '--out=+[output]:file:_files' \
        '--cp=+[classpath]:str:' \
        '*:nir/classpath files:_files'
}

_scala-native-cli "$@"
