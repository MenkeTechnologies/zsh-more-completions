#compdef kubectl-fleet
# kubectl-fleet (krew plugin): show the status of fleet-managed clusters
# https://github.com/kubectl-fleet/kubectl-fleet

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query all namespaces]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml wide)' \
  '--no-headers[do not print headers]'
