#compdef savi
# ============================================================================
#  _savi — Savi compiler — a fast language for programmers who are passionate
#          about their craft (Pony-influenced object-capability language)
#
#  Source-direct extraction from
#    https://github.com/savi-lang/savi/blob/main/main.cr
#    https://github.com/at-grandpa/clim (the clim library itself)
#
#  Maintained by Joe Eli McIlvain (savi-lang/savi).  157 GH stars.  Savi
#  is a fast language for programmers who are passionate about their
#  craft — built on the Pony actor-model + object-capability foundation
#  but with a more modern ergonomic syntax.  Compiles via LLVM to native
#  code.  The savi compiler itself is written in Crystal.
#
#  CLI library taxonomy update: 4th Crystal CLI library — at-grandpa/clim.
#  Crystal ecosystem now has 4 documented CLI libraries (R269 stdlib
#  OptionParser + R299 Admiral + R332 commander.cr + R348 clim) joining
#  the multi-library leaders.  clim is at-grandpa's Crystal CLI framework
#  — distinct from Admiral (CLASS-INHERITANCE-WITH-MACROS via `class <
#  Admiral::Command`) and commander.cr (BLOCK-BUILDER via
#  `Commander::Command.new do |cmd| ... end`).  clim's distinguishing
#  features:
#    - CLASS-INHERITANCE-WITH-DSL via `class Cli < Clim` + `main do ...
#      end` block
#    - TYPED options via `type: T` parameter (`UInt32`/`String`/`Bool`/
#      `UInt16` etc.) leveraging Crystal's strong static type system
#    - NESTED SUBCOMMANDS via `sub "name" do ... end` blocks inside main
#    - SUBCOMMAND ALIASES via `alias_name "shortname"` inside sub blocks
#    - POSITIONAL ARGUMENTS via `argument "name", type: T, required: ...`
#  Brings cross-language CLI library taxonomy variant count to 87;
#  Crystal ecosystem now has 4 documented CLI libraries.
#
#  Surface (verbatim from main.cr):
#
#  Top-level (default action: build):
#    -h, --help                    Show help
#    -v, --version                 Show savi + llvm versions
#    -b, --backtrace               Show backtrace on error
#    -r, --release                 Compile in release mode
#        --fix                     Auto-fix compile errors where possible
#        --no-debug                Compile without debug info
#        --with-runtime-asserts    Compile with runtime asserts even in release
#        --llvm-ir                 Write generated LLVM IR to a file
#        --llvm-keep-fns           Don't allow LLVM to remove functions
#        --llvm-optimize-nothing   Don't allow LLVM to do any IR optimization
#        --print-perf              Print compiler performance info
#    -X, --cross-compile=TRIPLE    Cross compile to target triple
#    -C, --cd=DIR                  Change the working directory
#    -p NAME, --pass=NAME          Compiler pass to target
#
#  Subcommands (declared via clim `sub "name" do ... end` blocks):
#    info <kind>                   Get info: version|llvm-version|
#                                  llvm-platform|bin-path
#    server | s                    Run LSP server
#    eval | e <code>               Evaluate code inline
#    run | r [name]                Build and run code (default subcommand)
#    deps                          Dependency operations
#    add                           Add a dependency
#    fmt                           Format Savi source files
#
#  Dup-skipped neighbors during hunt (smaller surface or different lib):
#    - cocol (cocol-project/cocol 21 stars, blockchain prototyping —
#      uses clim but simpler 7-flag surface)
#    - ncal (1 star nepali calendar — DUP with existing _ncal stub)
#    - lead (spinscale 1 star, ES alerting — narrow)
#    - crystaltwin (incubaid 0 stars — too narrow)
# ============================================================================

_savi() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  local -a global_flags=(
    '(-h --help)'{-h,--help}'[show help]'
    '(-v --version)'{-v,--version}'[show savi + llvm versions]'
    '(-b --backtrace)'{-b,--backtrace}'[show backtrace on error]'
    '(-r --release)'{-r,--release}'[compile in release mode]'
    '--fix[auto-fix compile errors where possible]'
    '--no-debug[compile without debug info]'
    '--with-runtime-asserts[compile with runtime asserts even in release]'
    '--llvm-ir[write generated LLVM IR to a file]'
    '--llvm-keep-fns[don'\''t allow LLVM to remove functions]'
    '--llvm-optimize-nothing[disable all LLVM IR optimization]'
    '--print-perf[print compiler performance info]'
    '(-X --cross-compile)'{-X,--cross-compile}'=[cross compile to target triple]:triple'
    '(-C --cd)'{-C,--cd}'=[change working directory]:dir:_directories'
    '(-p --pass)'{-p,--pass}'=[compiler pass to target]:pass'
  )

  _arguments -C \
    $global_flags \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'info:get info (version/llvm-version/llvm-platform/bin-path)'
        'server:run LSP server'
        's:run LSP server (alias)'
        'eval:evaluate code inline'
        'e:evaluate code (alias)'
        'run:build and run code'
        'r:build and run (alias)'
        'deps:dependency operations'
        'add:add a dependency'
        'fmt:format Savi source files'
      )
      _describe -t commands 'savi subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        info)
          _arguments \
            '1:info kind:(version llvm-version llvm-platform bin-path)'
          ;;
        eval|e)
          _arguments -s -S \
            $global_flags \
            '1:Savi code to evaluate'
          ;;
        run|r)
          _arguments -s -S \
            $global_flags \
            '1:manifest name'
          ;;
        server|s|fmt|deps|add)
          _arguments -s -S $global_flags
          ;;
      esac
      ;;
  esac
}

_savi "$@"
