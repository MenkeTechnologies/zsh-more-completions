#compdef kmd
# _kmd — Algorand kmd Key Management Daemon serving Algorand wallet and key operations over REST API as a separate process from algod (algorand team, Go); cobra
# upstream: https://github.com/algorand/go-algorand

_kmd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d+[data dir]:dir:_files -/' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '-t+[token]:str:' \
        '--api-token=+[token]:str:' \
        '-T+[timeout]:n:' \
        '--timeout=+[timeout]:n:' \
        '-w+[wallet name]:str:' \
        '-l+[listen addr]:str:' \
        '--listen=+[listen addr]:str:' \
        '-x+[allowed origins csv]:str:' \
        '--allowed-origins=+[csv]:str:' \
        '-A+[allowed auth]:str:' \
        '-k[kill kmd]' \
        '--kill[kill kmd]' \
        '--config=+[file]:file:_files -g "*.json"' \
        '--logname=+[name]:str:' \
        '--logTag=+[tag]:str:' \
        '--logHost=+[host]:h:_hosts' \
        '--scrypt-N=+[N]:n:' \
        '--scrypt-R=+[N]:n:' \
        '--scrypt-P=+[N]:n:' \
        '--scrypt-salt-len=+[N]:n:' \
        '--session-lifetime-secs=+[N]:n:'
}

_kmd "$@"
