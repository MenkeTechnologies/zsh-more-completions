#compdef terminology
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/terminology.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-C --copyright)'{-C,--copyright}'[show copyright]' \
  '(-L --license)'{-L,--license}'[show license]' \
  '(-e --exec)'{-e+,--exec=}'[command to execute]:cmd:_command_names' \
  '(-d --current-directory)'{-d+,--current-directory=}'[current dir]:dir:_files -/' \
  '(-t --theme)'{-t+,--theme=}'[edje theme name or path]:theme:' \
  '(-b --background)'{-b+,--background=}'[background image]:file:_files' \
  '(-f --font)'{-f+,--font=}'[font (NAME/SIZE for scalable, NAME for bitmap)]:font:' \
  '(-T --title)'{-T+,--title=}'[window title]:title:' \
  '(-n --name)'{-n+,--name=}'[window name]:name:' \
  '(-i --icon-name)'{-i+,--icon-name=}'[icon name]:name:' \
  '(-r --role)'{-r+,--role=}'[window role]:role:' \
  '(-g --geometry)'{-g+,--geometry=}'[geometry CxR]:geom:' \
  '(-S --split)'{-S+,--split=}'[start with splits]:layout:(h v)' \
  '(-m --video-mute)'{-m+,--video-mute=}'[mute mode for video playback]:mode:' \
  '(-c --cursor-blink)'{-c+,--cursor-blink=}'[cursor blink behavior]:mode:' \
  '(-G --visual-bell)'{-G+,--visual-bell=}'[visual bell mode]:mode:' \
  '(-F --fullscreen)'{-F,--fullscreen}'[fullscreen]' \
  '(-I --iconic)'{-I,--iconic}'[start iconic]' \
  '(-B --borderless)'{-B,--borderless}'[borderless]' \
  '(-O --override)'{-O,--override}'[override-redirect window]' \
  '(-M --maximized)'{-M,--maximized}'[start maximized]' \
  '(-W --nowm)'{-W,--nowm}'[no window manager]' \
  '(-H --hold)'{-H,--hold}'[hold open after exit]' \
  '(-s --single)'{-s,--single}'[force single instance]' \
  '-2[xterm-256color]' \
  '--256color[xterm-256color mode]' \
  '(-l --login)'{-l,--login}'[login shell]' \
  '--active-links[toggle link highlighting]' \
  '--no-wizard[skip startup wizard]' \
  '--scale=[UI scaling factor]:scale:' \
  '--colorscheme=[named color scheme]:scheme:' \
  '*: :' && ret=0

return ret
