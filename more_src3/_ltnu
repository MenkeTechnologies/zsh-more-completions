#compdef ltnu
# Documentation: https://manpages.debian.org/ltnu
# Source: debian/devscripts scripts/ltnu.sh — "Long Time No Upload" UDD query (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '-m[query as maintainer only (not uploader)]' \
    '1::maintainer/uploader (email or alias):_default' \
    && ret=0

return ret
