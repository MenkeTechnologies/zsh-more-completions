#compdef s6-dnsname
# Documentation: https://skarnet.org/software/s6-dns/s6-dnsname.html
# Reference accessed: 2026-05-30
# s6-dnsname — reverse DNS resolver. Resolves an IP address back to a name.
# Auto-detects IPv4 vs IPv6 from input syntax unless -4/-6 forced.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-4 -6)-4[treat IP argument as IPv4]' \
  '(-4 -6)-6[treat IP argument as IPv6]' \
  '(-h -H)-H[do not use /etc/hosts (default)]' \
  '(-h -H)-h[use /etc/hosts or compiled /etc/hosts.cdb]' \
  '-r[random-permute results before printing]' \
  '-t+[resolution timeout in ms (exit 99 if exceeded)]:ms:' \
  '1:IP address:' \
  && ret=0

return ret
