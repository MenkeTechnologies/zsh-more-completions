#compdef ibtool
# Documentation: https://www.unix.com/man-page/osx/1/ibtool/
# Source: Apple Xcode — Interface Builder document compiler / strings extractor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--compile=[compile document to path]:output path:_files' \
    '--output-format=[output format]:fmt:(xml1 binary1 human-readable-text)' \
    '--import-strings-file=[replace localizable strings from file]:.strings:_files' \
    '--upgrade[upgrade input to latest document type]' \
    '--localizable-strings[include non-empty localizable strings in plist output]' \
    '--errors[include error messages in plist output]' \
    '--warnings[include warning messages in plist output]' \
    '--notices[include notice messages in plist output]' \
    '--export-strings-file=[export localizable strings to file]:.strings:_files' \
    '--export-translatable-information[include translatable strings + context]' \
    '--write=[output file path]:file:_files' \
    '--target-device=[target device]:device:(iphone ipad mac tv watch carplay)' \
    '--minimum-deployment-target=[minimum deployment target version]:version:' \
    '--module=[bundle identifier]:bundle id:' \
    '--auto-activate-custom-fonts[auto-activate custom fonts at runtime]' \
    '*:Interface Builder file:_files -g "*.(xib|storyboard|nib)"' \
    && ret=0

return ret
