#compdef knoxcli.sh knox
# _knox — Apache Knox knoxcli (CLI for the Apache Knox API gateway; subcommands: create-master, set-master, redeploy, create-cert, create-alias, list-alias, delete-alias, export-cert, list-descriptors, create-topology, delete-topology, version, deploy, validate-topology, list-topologies; --master, --gateway-url, --keystore, --alias, --value)
# upstream: https://github.com/apache/knox
# Subcommands from knox knoxcli/src/main/java/org/apache/knox/gateway/util on tip.

_knox() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--master+[master secret]:secret:' \
        '--gateway-url+[Knox gateway URL]:url:' \
        '--keystore+[keystore]:file:_files' \
        '--alias+[alias]:alias:' \
        '--value+[value]:value:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'knox command' '(create-master set-master redeploy create-cert create-alias list-alias delete-alias export-cert list-descriptors create-topology delete-topology validate-topology list-topologies deploy version)' ;;
        args) _arguments '*:argument:' ;;
    esac
}

_knox "$@"
