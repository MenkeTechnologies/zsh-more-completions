#compdef scalene
# Documentation: https://github.com/plasma-umass/scalene
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (scalene/scalene_parseargs.py).

# Zsh completion for scalene - Python CPU/memory/GPU profiler

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--help-advanced[show advanced help]' \
  '(- *)--version[show version]' \
  '(-o --outfile)'{-o,--outfile}'+[output file]:file:_files' \
  '--cpu-only[only profile CPU time]' \
  '--config=[load options from YAML config]:file:_files' \
  '--gpu[profile GPU usage]' \
  '--memory[profile memory usage]' \
  '--stacks[collect stack traces]' \
  '--no-stacks[do not collect stack traces]' \
  '--async[profile async code]' \
  '--no-async[disable async/await profiling]' \
  '--profile-all[profile all code, not just target]' \
  '--profile-only=[profile only files matching pattern]:pattern' \
  '--profile-exclude=[exclude files matching pattern]:pattern' \
  '--profile-system-libraries[include Python stdlib and packages]' \
  '--profile-interval=[profile interval]:seconds' \
  '--use-virtual-time[use virtual time only (exclude I/O)]' \
  '--cpu-percent-threshold=[CPU percent threshold]:percent' \
  '--cpu-sampling-rate=[CPU sampling interval]:seconds' \
  '--allocation-sampling-window=[allocation sampling window]:bytes' \
  '--malloc-threshold=[malloc reporting threshold]:n' \
  '--program-path=[path to program]:path:_files -/' \
  '--memory-leak-detector[experimental leak detection]' \
  '--use-legacy-tracer[use legacy tracer]' \
  '--use-python-callback[use Python callback]' \
  '--disable-jit[disable JIT]' \
  '--reduced-profile[only show lines with significant usage]' \
  '--reduced[short alias for reduced profile]' \
  '--on[start profiling enabled]' \
  '--off[start with profiling disabled]' \
  '--ipython[run inside IPython]' \
  '--html[generate HTML output]' \
  '--json[generate JSON output]' \
  '--cli[display results on the command line]' \
  '--standalone[create self-contained HTML]' \
  '--web[open browser to view results]' \
  '--no-browser[do not open browser]' \
  '--port=[server port]:port' \
  '*:script:_files -g "*.py"'
