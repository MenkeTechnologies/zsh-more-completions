#compdef tcatest
# Documentation: https://www.systutorials.com/docs/linux/man/1-tcatest/
# Reference accessed: 2026-05-21
# Verified: Tokyo Cabinet tcatest(1) — abstract DB API test utility.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'write:store records with 8-byte keys'
  'read:retrieve all records'
  'remove:remove all records'
  'rcat:concatenate-mode store with partway-duplicated keys'
  'misc:miscellaneous operations test'
  'wicked:random updating of list and map'
  'compare:schema comparison evaluation'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'tcatest subcommand' subcommands && ret=0
    ;;
  (args)
    _arguments \
      '1:database name:_files' \
      '2::record number:' && ret=0
    ;;
esac

return ret
