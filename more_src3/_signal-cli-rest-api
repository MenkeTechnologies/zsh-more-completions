#compdef signal-cli-rest-api
# _signal-cli-rest-api — REST wrapper around signal-cli (bbernhard/signal-cli-rest-api)
# upstream: https://github.com/bbernhard/signal-cli-rest-api
# Flags from src/main.go (flag).

_signal-cli-rest-api() {
    _arguments \
        '(- *)-h[show help]' \
        '-signal-cli-config=[signal-cli config directory]:dir:_files -/' \
        '-attachment-tmp-dir=[attachment temp directory]:dir:_files -/' \
        '-avatar-tmp-dir=[avatar temp directory]:dir:_files -/'
}

_signal-cli-rest-api "$@"
