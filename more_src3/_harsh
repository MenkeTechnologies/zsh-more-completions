#compdef harsh
# Documentation: https://github.com/wakatara/harsh
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for harsh - CLI habit tracker

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'ask:prompt for unrecorded habits'
  'log:show consistency graph for last 100 days'
  'todo:list todays pending habits'
  'stats:show summary statistics'
  'completion:generate shell completion scripts'
  'help:show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-C --color)'{-C,--color}'=[control output coloring]:mode:(always never auto)' \
  '(-H --hide-ended)'{-H,--hide-ended}'[exclude habits with end dates]' \
  '(-j --json)'{-j,--json}'[output JSON]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'harsh command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (completion)
        _arguments '*::shell:(bash zsh fish)' && ret=0 ;;
    esac ;;
esac

return ret
