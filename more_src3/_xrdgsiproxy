#compdef xrdgsiproxy
# Documentation: https://man.archlinux.org/man/xrdgsiproxy.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# xrdgsiproxy: manage GSI proxy certificate.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a modes=(
  'init:create proxy certificate and related proxy file'
  'info:display content of existing proxy file'
  'destroy:delete existing proxy file'
)
_arguments -C \
  '(- *)-h[display help]' \
  '-debug[enable debug mode]' \
  '-f+[non-standard location of proxy file]:file:_files' \
  '-out+[non-standard location of proxy file]:file:_files' \
  '-certdir+[non-standard location of CA info directory (init)]:dir:_directories' \
  '-cert+[non-standard certificate (init)]:file:_files' \
  '-key+[non-standard private key (init)]:file:_files' \
  '-bits+[key strength in bits (init, default 2048)]:n:' \
  '-valid+[time validity hh:mm (init, default 12:00)]:hhmm:' \
  '-path-length+[max descendant levels (init, default 0)]:n:' \
  '1: :->mode' && ret=0
case $state in
  mode) _describe -t modes 'mode' modes && ret=0 ;;
esac
return ret
