#compdef ha-manager
# _ha-manager — Proxmox Server Solutions ha-manager Proxmox VE high availability cluster resource manager CLI (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-ha-manager.git

_ha-manager() {
    local -a sub=(
        'add:add a HA resource'
        'remove:remove a HA resource'
        'set:update HA resource'
        'config:show HA configuration'
        'status:show cluster HA status'
        'crm-command:send command to CRM'
        'migrate:migrate a HA resource'
        'relocate:relocate a HA resource'
        'groupadd:add a HA group'
        'groupremove:remove a HA group'
        'groupset:update a HA group'
        'groupconfig:show HA groups'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ha-manager subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--comment=+[comment]:str:' \
                    '--group=+[ha group]:str:' \
                    '--max_relocate=+[N]:n:' \
                    '--max_restart=+[N]:n:' \
                    '--state=+[state]:s:(enabled disabled started stopped ignored)' \
                    '--type=+[resource type]:t:(vm ct)' \
                    '*:sid:' ;;
                set) _arguments \
                    '--comment=+[comment]:str:' \
                    '--digest=+[digest]:str:' \
                    '--group=+[ha group]:str:' \
                    '--max_relocate=+[N]:n:' \
                    '--max_restart=+[N]:n:' \
                    '--state=+[state]:s:(enabled disabled started stopped ignored)' \
                    '*:sid:' ;;
                remove) _arguments '*:sid:' ;;
                status) _arguments \
                    '--verbose[verbose status]' ;;
                migrate|relocate) _arguments \
                    '1:sid:' \
                    '2:node:' ;;
                crm-command) _arguments '1:cmd:(node-maintenance enable node-maintenance disable migrate relocate)' ;;
                groupadd) _arguments \
                    '--comment=+[comment]:str:' \
                    '--nodes=+[member nodes csv]:str:' \
                    '--nofailback[no failback]' \
                    '--restricted[restricted]' \
                    '*:group id:' ;;
                groupset) _arguments \
                    '--comment=+[comment]:str:' \
                    '--digest=+[digest]:str:' \
                    '--nodes=+[member nodes csv]:str:' \
                    '--nofailback=+[bool]:b:(0 1)' \
                    '--restricted=+[bool]:b:(0 1)' \
                    '*:group id:' ;;
                groupremove) _arguments '*:group id:' ;;
            esac
            ;;
    esac
}

_ha-manager "$@"
