#compdef irqbalance
# Documentation: man irqbalance(1)
# Source: Irqbalance/irqbalance irqbalance.c (master) — IRQ distribution daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --oneshot)'{-o,--oneshot}'[run once and exit]' \
    '(-d --debug)'{-d,--debug}'[debug logging]' \
    '(-f --foreground)'{-f,--foreground}'[do not daemonize]' \
    '(-j --journal)'{-j,--journal}'[log to systemd journal]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-p --powerthresh)'{-p+,--powerthresh=}'[power threshold (off|N)]:threshold:_default' \
    '*'{-i+,--banirq=}'[banned IRQ number]:irq:_default' \
    '*'{-m+,--banmod=}'[banned module name]:module:_default' \
    '(-c --deepestcache)'{-c+,--deepestcache=}'[deepest cache level to consider]:n:_default' \
    '(-l --policyscript)'{-l+,--policyscript=}'[policy script]:script:_files' \
    '(-s --pid)'{-s+,--pid=}'[PID file]:file:_files' \
    '(-t --interval)'{-t+,--interval=}'[rebalance interval (seconds)]:seconds:_default' \
    '(-e --migrateval)'{-e+,--migrateval=}'[migration value]:n:_default' \
    && ret=0

return ret
