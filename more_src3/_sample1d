#compdef sample1d
# Documentation: https://docs.generic-mapping-tools.org/latest/sample1d.html
# Source: GenericMappingTools/gmt classic-mode sample1d — resample 1-D table data (interpolation).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[track resampling method]:method:_default' \
    '-C+[color from CPT (uses z-value)]:cpt:_files -g "*.cpt(-.)"' \
    '-E[preserve trailing text from input]' \
    '-F+[interpolation method]:method:(l a c n L A C N)' \
    '-N+[column index of independent variable]:col:_default' \
    '-T+[new sampling interval / coordinates]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[weights column for smoothing spline]:col:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-j+[distance computation mode]:mode:_default' \
    '*:input table:_files' \
    && ret=0

return ret
