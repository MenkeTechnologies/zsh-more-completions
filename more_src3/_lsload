#compdef lsload
# Documentation: https://www.bsc.es/support/LSF/9.1.2/lsf_command_ref/lsload.1.html
# Reference accessed: 2026-05-19
# Verified: BSC mirror of Platform LSF 9.1.2 lsload(1) reference.
# Removed from prior file: -c (cluster) was not in upstream; the real
# cluster option is -cname.

# lsload: show LSF host load (dynamic)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage]' \
  '(- *)-V[print version]' \
  '-a[show all hosts including Dynamic Cluster VM hosts]' \
  '-cname[include cluster name for execution cluster hosts]' \
  '-l[long format]' \
  '-w[wide format (no truncation)]' \
  '(-E)-N[show normalized CPU run queue length indices]' \
  '(-N)-E[show effective CPU run queue length indices]' \
  '-R+[resource requirement expression]:expr:' \
  '-I+[load index list]:indices:' \
  '-n+[number of hosts]:n:' \
  '-s[show all dynamic resources]' \
  '*:host:_hosts' && ret=0
return ret
