#compdef ipset-save ipset-restore ipset-list
# _ipset-save — netfilter ipset save / restore / list wrappers (companions to ipset(8) for offline edit; ipset save [setname] dumps current state in restore syntax, ipset restore loads a saved dump from stdin (-f file), ipset list shows sets with -t terse, -n names only, -r resolve hostnames, -s sorted, -o output format)
# upstream: https://git.netfilter.org/ipset
# Flags from netfilter/ipset src/ipset_save + src/ipset_list on tip.

_ipset-save() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-f+[input file (restore)]:file:_files' \
        '-t[terse]' \
        '-n[names only]' \
        '-r[resolve hostnames]' \
        '-s[sorted]' \
        '-o+[output format]:format:(plain save xml json)' \
        '*:setname:'
}

_ipset-save "$@"
