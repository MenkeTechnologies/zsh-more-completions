#compdef scribe-cli
# _scribe-cli — Shalvah Adebayo knuckleswtf/scribe Laravel API doc generator CLI alias (knuckleswtf, PHP); artisan-based
# upstream: https://github.com/knuckleswtf/scribe

_scribe-cli() {
    local -a sub=(
        'scribe:install:install scribe'
        'scribe:generate:generate API docs'
        'scribe:upgrade:upgrade config file'
        'scribe:diff:diff existing docs'
        'scribe:has-incomplete-configuration:check config'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scribe subcommand' sub ;;
        args)
            case $words[1] in
                scribe:install) _arguments \
                    '--force[force overwrite]' \
                    '--type=+[type]:t:(laravel dingo)' ;;
                scribe:generate) _arguments \
                    '--force[force regenerate]' \
                    '--no-extraction[skip extraction]' \
                    '--no-upgrade-check[skip upgrade check]' \
                    '--scribe-dir=+[dir]:dir:_files -/' \
                    '--config=+[config name]:str:' \
                    '-c+[config name]:str:' \
                    '--env=+[env file]:str:' ;;
            esac
            ;;
    esac
}

_scribe-cli "$@"
