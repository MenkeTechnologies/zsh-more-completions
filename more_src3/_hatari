#compdef hatari
# Documentation: https://manpages.debian.org/bookworm/hatari/hatari.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm hatari(1) manpage. GNU long-options style; listing
# commonly-used flags - see manpage for full set.

# hatari: Atari ST/STE/TT/Falcon emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--confirm-quit[confirm quit dialog]:bool:(on off)' \
  '(-c --configfile)'{-c,--configfile=}'[config file]:file:_files' \
  '(-k --keymap)'{-k,--keymap=}'[keymap file]:file:_files' \
  '--country[country code]:code:' \
  '--layout[keyboard layout]:layout:' \
  '--language[interface language]:lang:' \
  '--fast-forward[fast-forward mode]:bool:(on off)' \
  '--auto[auto-start program]:file:_files' \
  '(-m --mono)'{-m,--mono}'[mono mode]' \
  '--monitor[monitor type]:type:(mono color vga tv)' \
  '--tos-res[TOS resolution]:res:' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen]' \
  '(-w --window)'{-w,--window}'[windowed]' \
  '--grab[grab input]:bool:(on off)' \
  '--resizable[resizable window]:bool:(on off)' \
  '--frameskips[frame skips]:n:' \
  '--statusbar[show statusbar]:bool:(on off)' \
  '(-z --zoom)'{-z,--zoom=}'[zoom factor]:n:' \
  '--bpp[bits per pixel]:n:' \
  '(-j --joystick)'{-j,--joystick=}'[joystick port]:port:' \
  '--printer[printer device]:device:_files' \
  '--midi[MIDI device]:device:_files' \
  '--rs232-in[RS-232 input]:device:_files' \
  '--rs232-out[RS-232 output]:device:_files' \
  '--drive-a[drive A image]:file:_files -g "*.(st|msa|dim|ipf|stx|zip)"' \
  '--drive-b[drive B image]:file:_files -g "*.(st|msa|dim|ipf|stx|zip)"' \
  '--disk-a[mount disk A]:file:_files -g "*.(st|msa|dim|ipf|stx|zip)"' \
  '--disk-b[mount disk B]:file:_files -g "*.(st|msa|dim|ipf|stx|zip)"' \
  '(-d --harddrive)'{-d,--harddrive=}'[hard drive directory]:dir:_files -/' \
  '--protect-hd[protect hard drive]:bool:(on off)' \
  '--acsi[ACSI hard disk image]:file:_files' \
  '--ide-master[IDE master image]:file:_files' \
  '--ide-slave[IDE slave image]:file:_files' \
  '--memstate[memory state file]:file:_files' \
  '(-s --memsize)'{-s,--memsize=}'[memory size MB]:n:' \
  '--ttram[TT-RAM size MB]:n:' \
  '(-t --tos)'{-t,--tos=}'[TOS ROM image]:file:_files' \
  '--cartridge[cartridge image]:file:_files' \
  '--cpulevel[CPU level]:n:(0 1 2 3 4)' \
  '--cpuclock[CPU clock MHz]:mhz:' \
  '--fpu[FPU type]:type:' \
  '--machine[machine type]:machine:(st megast ste megaste tt falcon)' \
  '--blitter[blitter]:bool:(on off)' \
  '--dsp[DSP type]:type:' \
  '--sound[sound]:bool:(on off)' \
  '--sound-buffer-size[sound buffer size]:n:' \
  '(-D --debug)'{-D,--debug}'[enable debug]' \
  '--trace[trace mode]:mode:' \
  '--trace-file[trace output file]:file:_files' \
  '--log-file[log file]:file:_files' \
  '--log-level[log level]:level:(fatal error warn info debug)' \
  '--saveconfig[save current config]' \
  '*:disk image:_files -g "*.(st|msa|dim|ipf|stx|zip|prg|tos|app|gtp)"' && ret=0
return ret
