#compdef slaptest
# _slaptest — OpenLDAP slaptest (validate slapd.conf or the cn=config tree without starting the server; -F config dir, -f slapd.conf, -u check user/group, -v verbose, -d debug level, -Q quiet, -V version, -h help)
# upstream: https://git.openldap.org/openldap/openldap (servers/slapd/slaptest)
# Flags from OpenLDAP servers/slapd/slapcommon.c on tip.

_slaptest() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-F+[config dir]:dir:_files -/' \
        '-f+[slapd.conf]:file:_files' \
        '-u[check user/group]' \
        '-v[verbose]' \
        '-Q[quiet]' \
        '-d+[debug level]:level:'
}

_slaptest "$@"
