#compdef hciconfig
# _hciconfig — BlueZ hciconfig (legacy CLI for configuring HCI devices: up/down power, piscan/iscan discoverable, name/class/version probes, lp/lm/auth/encrypt feature toggles; first positional is hciX device, second is the action)
# upstream: https://github.com/bluez/bluez (tools/hciconfig.c)
# Subcommands from bluez tools/hciconfig.c on tip.

_hciconfig() {
    _arguments \
        '-h[show help]' \
        '-a[print all info]' \
        '-r[reset HCI before action]' \
        '1: :_message hciX device' \
        '*:command:(up down reset rstat auth noauth encrypt noencrypt secmgr nosecmgr piscan noscan iscan pscan ptype name class voice iac inqmode inqdata inqtype inqparams pageparms pageto afhmode aclmtu scomtu features version revision commands inq cmd connections delkey oobdata mode lp lm scan delkey clkoff dataptr clkmode info)' \
        '*::arg:'
}

_hciconfig "$@"
