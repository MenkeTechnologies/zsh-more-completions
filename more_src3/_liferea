#compdef liferea
# _liferea — Linux Feed Reader (GTK news / podcast reader) (lwindolf/liferea)
# upstream: https://github.com/lwindolf/liferea
# Flags from src/liferea_application.c (GOptionEntry table).

_liferea() {
    local -a args
    args=(
        '(-v --version)'{-v,--version}'[show version information and exit]'
        '(-a --add-feed)'{-a+,--add-feed=}'[add a new subscription URI]:uri:'
        '(-w --mainwindow-state)'{-w+,--mainwindow-state=}'[main-window state]:state:(shown hidden)'
        '(-p --disable-plugins)'{-p,--disable-plugins}'[start with all plugins disabled]'
        '--debug-all[print debugging messages of all types]'
        '--debug-cache[print debugging messages for the cache handling]'
        '--debug-conf[print debugging messages for the configuration handling]'
        '--debug-db[print debugging messages of the database handling]'
        '--debug-gui[print debugging messages of all GUI functions]'
        '--debug-html[enable HTML rendering debugging (dumps to ~/.cache/liferea/output.html)]'
        '--debug-net[print debugging messages of all network activity]'
        '--debug-parsing[print debugging messages of all parsing functions]'
        '--debug-update[print debugging messages of the feed update processing]'
        '--debug-vfolder[print debugging messages of search-folder matching]'
        '(- *)'{-h,--help}'[show help]'
    )
    _arguments -s -S $args
}

_liferea "$@"
