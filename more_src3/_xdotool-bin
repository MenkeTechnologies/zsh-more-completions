#compdef xdotool
# _xdotool-bin — X11 automation tool (Jordan Sissel, C); simulate keystrokes, mouse, window manipulation
# upstream: https://github.com/jordansissel/xdotool

_xdotool-bin() {
    local -a sub=(
        'key:press a key'
        'keydown:press and hold a key'
        'keyup:release a key'
        'type:type text'
        'sleep:sleep N seconds'
        'mousemove:move mouse cursor'
        'mousemove_relative:move relative'
        'click:click a mouse button'
        'mousedown:press mouse button'
        'mouseup:release mouse button'
        'getmouselocation:print mouse location'
        'behave_screen_edge:run command when mouse hits edge'
        'getactivewindow:print active window id'
        'getwindowname:print window name'
        'getwindowpid:print window pid'
        'getwindowgeometry:print window geometry'
        'getwindowfocus:print focused window id'
        'getdisplaygeometry:print display geometry'
        'search:search for window by criteria'
        'selectwindow:click and select window'
        'help:show help'
        'version:show version'
        'behave:run command on event'
        'set_window:set window properties'
        'set_num_desktops:set N desktops'
        'set_desktop:switch desktop'
        'set_desktop_for_window:move window to desktop'
        'set_desktop_viewport:set viewport'
        'get_num_desktops:print desktop count'
        'get_desktop:print current desktop'
        'get_desktop_for_window:print window desktop'
        'get_desktop_viewport:print viewport'
        'windowactivate:activate window'
        'windowfocus:focus window'
        'windowraise:raise window'
        'windowsize:resize window'
        'windowmove:move window'
        'windowmap:map window'
        'windowunmap:unmap window'
        'windowminimize:minimize window'
        'windowkill:kill window'
        'windowclose:close window'
        'windowreparent:reparent window'
        'windowquit:quit window'
        'exec:exec a command'
    )
    _arguments -C \
        '-h[show help]' \
        '-v[verbose]' \
        '--clearmodifiers[clear modifiers]' \
        '--sync[wait for X server]' \
        '--delay+[delay ms]:n:' \
        '--window+[window id]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xdotool subcommand' sub ;;
    esac
}

_xdotool-bin "$@"
