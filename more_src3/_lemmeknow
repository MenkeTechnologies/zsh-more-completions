#compdef lemmeknow
# Documentation: https://github.com/swanandx/lemmeknow
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lemmeknow - identify mysterious text or files.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-j --json)'{-j,--json}'[output in JSON format]' \
  '(-t --text-only)'{-t,--text-only}'[only identify text, do not scan file]' \
  '(-b --boundary)'{-b,--boundary}'[disable boundaryless mode]' \
  '(-v --verbose)'{-v,--verbose}'[print output with more details]' \
  '--min=[minimum rarity]:rarity:' \
  '--max=[maximum rarity]:rarity:' \
  '(-i --include)'{-i,--include}'=[include matches with these tags (comma-separated)]:tags:' \
  '(-e --exclude)'{-e,--exclude}'=[exclude matches with these tags (comma-separated)]:tags:' \
  '*:text or filename:_files'
