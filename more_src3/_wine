#compdef wine
# Documentation: https://man.archlinux.org/man/wine.1.en
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wine - Windows application compatibility layer
# Per the wine(1) man page, only --help and --version are documented options.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '*:Windows executable:->exefiles' && ret=0

case "$state" in
  exefiles)
    _files -g '*.(exe|msi|bat|cmd|com|lnk|EXE|MSI|BAT|CMD|COM|LNK)(-.)'
    ;;
esac

return ret
