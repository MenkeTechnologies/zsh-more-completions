#compdef watcher-db-manage
# Documentation: https://docs.openstack.org/watcher/latest/ (cli/index)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above; subcommands verified in
# https://opendev.org/openstack/watcher/src/branch/master/watcher/cmd/dbmanage.py

# watcher-db-manage: DB schema management for OpenStack Watcher.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upgrade:upgrade DB schema to a specific or latest alembic revision'
  'downgrade:downgrade DB schema to the oldest alembic revision'
  'stamp:stamp DB with a given alembic revision (without running migrations)'
  'revision:create a new alembic revision'
  'version:print current revision information and exit'
  'create_schema:create the database schema'
  'purge:purge the database based on age/goal filters'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "*--config-file=[path to config file]:file:_files" \
  "*--config-dir=[path to config dir]:dir:_files -/" \
  "(-d --debug)"{-d,--debug}"[set log level to DEBUG]" \
  "--nodebug[unset --debug]" \
  "--log-config-append=[external logging config file]:file:_files" \
  "--log-date-format=[log date format]:fmt" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--rate-limit-burst=[max logged messages per rate-limit-interval]:n" \
  "--rate-limit-except-level=[log level exempt from rate limiting]:level:(CRITICAL ERROR INFO WARNING DEBUG)" \
  "--rate-limit-interval=[log rate-limit interval seconds]:n" \
  "--rpc-conn-pool-size=[RPC connection pool size]:n" \
  "--rpc-response-timeout=[RPC response timeout seconds]:n" \
  "--syslog-log-facility=[syslog facility]:facility" \
  "--transport-url=[messaging transport URL]:url" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'watcher-db-manage command' commands && ret=0 ;;
  args)
    case $line[1] in
      upgrade|downgrade|stamp)
        _arguments \
          '--revision=[alembic revision string]:revision' && ret=0 ;;
      revision)
        _arguments \
          '--message=[migration message]:message' \
          '--autogenerate[autogenerate the migration]' && ret=0 ;;
      purge)
        _arguments \
          '(-a --age-in-days)'{-a+,--age-in-days=}'[purge entries older than N days]:n' \
          '(-n --max-number)'{-n+,--max-number=}'[max number of entries to purge]:n' \
          '(-g --goal)'{-g+,--goal=}'[goal name to purge]:goal' \
          '(-t --dry-run)'{-t,--dry-run}'[show what would be purged]' && ret=0 ;;
    esac ;;
esac
return ret
