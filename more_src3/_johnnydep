#compdef johnnydep

_johnnydep() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(-v --verbose)'{-v,--verbose}'[increase output verbosity]' \
        '(-o --output-format)'{-o,--output-format}'[output format]:format:(text json yaml toml pinned human)' \
        '--fields=[fields to display]:fields:_sequence compadd - name summary version_installed version_latest version_latest_in_spec license homepage url_download url_project url_homepage extras_available extras_requested requires project_url' \
        '--no-deps[do not resolve dependencies]' \
        '--index-url=[base URL of Python Package Index]:url:_urls' \
        '--extra-index-url=[extra index URL]:url:_urls' \
        '(-r --requirement)'{-r,--requirement}'[install from a requirements file]:requirements file:_files' \
        '--python-version=[target Python version]:version:' \
        '--platform=[target platform]:platform:' \
        '--abi=[target ABI]:abi:' \
        '*:package name:' && ret=0

    return ret
}

_johnnydep "$@"
