#compdef xmlcatalog
# Documentation: https://manpages.debian.org/xmlcatalog.1
# Source: libxml2 — XML/SGML catalog editor and resolver.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--add[add entry "TYPE ORIG REPLACE" or add filename to SGML supercatalog]' \
    '--create[create a new XML catalog]' \
    '--del[remove entries matching VALUE(S)]' \
    '--noout[save output to named file rather than stdout]' \
    '--no-super-update[do not update the SGML super catalog]' \
    '--shell[interactive catalog shell]' \
    '--sgml[use SGML super catalogs for --add and --del]' \
    '(-v --verbose)'{-v,--verbose}'[output debugging information]' \
    '*:catalog file or value:_files' \
    && ret=0

return ret
