#compdef kreadconfig6
# _kreadconfig6 — KDE Plasma 6 kreadconfig6 CLI reading a value from a KConfig-style INI configuration file located under ~/.config or /etc/xdg with file group key default semantics for shell-scripted KDE Plasma settings querying (KDE team, C++); custom argparse
# upstream: https://invent.kde.org/frameworks/kconfig

_kreadconfig6() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--file=+[config file]:file:_files -g "*rc *.conf"' \
        '--group=+[group name]:str:' \
        '--key=+[key name]:str:' \
        '--default=+[default value]:str:' \
        '--type=+[type]:t:(bool int string path stringlist double)' \
        '*::'
}

_kreadconfig6 "$@"
