#compdef k8sgpt
# Documentation: https://github.com/k8sgpt-ai/k8sgpt/blob/main/cmd/analyze/analyze.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'analyze:analyze Kubernetes resources'
      'auth:authenticate with AI backends'
      'cache:manage cache'
      'customAnalyzer:manage custom analyzers'
      'dump:create a dump for debugging'
      'filters:manage filters'
      'generate:generate API keys for AI backends'
      'integration:manage integrations'
      'serve:start gRPC server'
      'version:print version'
      'completion:generate shell completion'
      'help:help about any command'
    )
    _describe -t commands 'k8sgpt command' commands && ret=0
    ;;
  args)
    case $words[1] in
      analyze)
        _arguments -s -S \
          '(-e --explain)'{-e,--explain}'[explain the problem to me]' \
          '(-b --backend)'{-b,--backend}'=[backend AI provider]:backend:' \
          '(-o --output)'{-o,--output}'=[output format]:format:(text json)' \
          '(-f --filter)'{-f,--filter}'=[filter for these analyzers]:filter:' \
          '(-n --namespace)'{-n,--namespace}'=[namespace to analyze]:namespace:' \
          '(-l --language)'{-l,--language}'=[language to use for AI]:language:' \
          '(-c --no-cache)'{-c,--no-cache}'[do not use cached data]' \
          '(-a --anonymize)'{-a,--anonymize}'[anonymize data before sending to the AI backend]' \
          '(-m --max-concurrency)'{-m,--max-concurrency}'=[max concurrent requests to the API server]:n:' \
          '(-d --with-doc)'{-d,--with-doc}'[give official documentation of the involved field]' \
          '(-i --interactive)'{-i,--interactive}'[enable interactive mode (needs --explain)]' \
          '(-z --custom-analysis)'{-z,--custom-analysis}'[enable custom analyzers]' \
          '(-r --custom-headers)'{-r,--custom-headers}'=[custom headers key:value]:headers:' \
          '(-L --selector)'{-L,--selector}'=[label selector to filter on]:selector:' \
          '(-s --with-stat)'{-s,--with-stat}'[print analysis stats]' \
          && ret=0
        ;;
      auth)
        _arguments -s -S -C \
          '1:subcommand:(add default list remove update)' \
          && ret=0
        ;;
      cache)
        _arguments -s -S -C \
          '1:subcommand:(add get list purge remove)' \
          && ret=0
        ;;
      integration)
        _arguments -s -S -C \
          '1:subcommand:(activate deactivate list)' \
          && ret=0
        ;;
      filters)
        _arguments -s -S -C \
          '1:subcommand:(add list remove)' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
