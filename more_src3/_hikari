#compdef hikari
# _hikari — Marius Orcsik hikari stacking Wayland compositor BSD-first cwm-inspired (acmewm team, C); custom argparse
# upstream: https://hikari.acmelabs.space

_hikari() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--autoconf=+[autoconf file]:file:_files' \
        '-a+[autoconf file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--xwayland[enable xwayland]' \
        '-X[enable xwayland]' \
        '--no-xwayland[disable xwayland]' \
        '--debug[debug logs]' \
        '-d[debug logs]'
}

_hikari "$@"
