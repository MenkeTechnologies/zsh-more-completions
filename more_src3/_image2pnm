#compdef image2pnm
# Documentation: https://astrometry.net/doc/build-index.html
# Source: dstndstn/astrometry.net util/image2pnm.py — convert FITS/JPEG/PNG/etc. to PNM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --infile)'{-i+,--infile=}'[input image file]:file:_files' \
    '(-u --uncompressed-outfile)'{-u+,--uncompressed-outfile=}'[temp uncompressed file]:file:_files' \
    '(-o --outfile)'{-o+,--outfile=}'[output PNM file]:file:_files -g "*.(pnm|pgm|ppm)(-.)"' \
    '(-p --ppm)'{-p,--ppm}'[output PPM (color) instead of PGM]' \
    '(-e --extension)'{-e+,--extension=}'[FITS extension index]:n:_default' \
    '--mydir=[directory containing an-fitstopnm]:dir:_directories' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    && ret=0

return ret
