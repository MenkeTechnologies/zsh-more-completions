#compdef tfautomv
# Documentation: https://github.com/busser/tfautomv
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'=[output format]:fmt:(blocks commands)' \
  '--skip-init[skip terraform init]' \
  '--skip-refresh[skip terraform refresh]' \
  '-s[skip init]' \
  '-S[skip refresh]' \
  '--preplanned[use existing plan files]' \
  '--preplanned-file=[custom plan file location]:file:_files' \
  '*--ignore=[ignore attribute differences (everything/whitespace/prefix)]:rule:' \
  '--terraform-bin=[alternative Terraform-compatible binary]:executable:_command_names -e' \
  '--no-color[disable colored output]' \
  '-v[verbose]' \
  '*:directory:_directories'
