#compdef setupcon
# _setupcon — Debian console-setup setupcon (apply /etc/default/console-setup keymap+font+codepage choices to active Linux VTs; -k only keymap, -f only font, -v verbose, --force apply even when not on a VT, --save persists current settings to config, --setup-default-keyboard fallback for early boot)
# upstream: https://salsa.debian.org/installer-team/console-setup
# Flags from console-setup setupcon (perl) on tip.

_setupcon() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-k[only keymap]' \
        '--keyboard-only[only keymap]' \
        '-f[only font + codepage]' \
        '--font-only[only font + codepage]' \
        '--force[force on non-VT]' \
        '--save[persist current settings]' \
        '--save-only[persist + exit]' \
        '--setup-default-keyboard[setup default keyboard fallback]' \
        '*:console:_files -g "/dev/tty*"'
}

_setupcon "$@"
