#compdef longhorn-manager
# _longhorn-manager — Longhorn distributed block storage controller (longhorn/longhorn-manager)
# upstream: https://github.com/longhorn/longhorn-manager
# Flags from main.go + app/daemon.go (urfave/cli v1) on tip.

_longhorn-manager() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '(-j --log-json)'{-j,--log-json}'[log in JSON format]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the manager controller daemon'
                recurring-job:'run a recurring snapshot/backup job'
                deploy-driver:'deploy the Longhorn CSI driver'
                csi:'run the Longhorn CSI plugin'
                pre-upgrade:'run pre-upgrade reconciliation'
                post-upgrade:'run post-upgrade reconciliation'
                uninstall:'uninstall Longhorn from the cluster'
                system-rollout:'roll out a system backup'
                migrate-for-pre-070-volumes:'migrate pre-v0.7.0 volumes'
            )
            _describe -t commands 'longhorn-manager command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments \
                        '--engine-image=[Longhorn engine image]:image:' \
                        '--instance-manager-image=[instance-manager image]:image:' \
                        '--share-manager-image=[share-manager image]:image:' \
                        '--backing-image-manager-image=[backing-image-manager image]:image:' \
                        '--support-bundle-manager-image=[support-bundle-manager image]:image:' \
                        '--manager-image=[Longhorn manager image]:image:' \
                        '--service-account=[manager service account]:sa:' \
                        '--kube-config=[kubeconfig path (optional)]:file:_files' \
                        '--upgrade-version-check[enforce version checking on upgrades]'
                    ;;
            esac
            ;;
    esac
}

_longhorn-manager "$@"
