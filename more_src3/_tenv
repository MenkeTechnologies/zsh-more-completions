#compdef tenv
# Documentation: https://tofuutils.github.io/tenv/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tenv - OpenTofu / Terraform / Terragrunt / Atmos version manager

local curcontext="$curcontext" state line ret=1

local -a tools=(
  'tofu:OpenTofu version management'
  'tf:Terraform version management'
  'terraform:Terraform version management'
  'tg:Terragrunt version management'
  'terragrunt:Terragrunt version management'
  'atmos:Atmos version management'
  'tofuenv:tofuenv-compatibility commands'
  'tfenv:tfenv-compatibility commands'
  'install:install a tool version'
  'use:switch default version'
  'detect:detect version for working directory'
  'reset:reset default version'
  'uninstall:uninstall version'
  'list:list installed versions'
  'list-remote:list remote versions'
  'constraint:set or read version constraint'
  'help:show help for a subcommand'
  'completion:generate shell completion script'
  'update-path:print PATH with tenv shims'
  'version:show tenv version'
)

local -a subcommands=(
  'install:install a requested version'
  'detect:detect used version'
  'use:switch the default version used'
  'reset:reset used version'
  'uninstall:uninstall a specific version'
  'list:list installed versions'
  'list-remote:list available remote versions'
  'constraint:set or read version constraint'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show tenv version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-r --root-path)'{-r,--root-path=}'[root installation path]:path:_files -/' \
  '(-a --arch)'{-a,--arch=}'[CPU architecture]:arch:(amd64 arm64 386)' \
  '(-n --no-install)'{-n,--no-install}'[disable auto-install if missing]' \
  '(-f --force-remote)'{-f,--force-remote}'[skip local version checks]' \
  '(-t --github-token)'{-t,--github-token=}'[GitHub API token]:token:' \
  '(-k --key-file)'{-k,--key-file=}'[PGP public key file]:file:_files' \
  '(-c --remote-conf)'{-c,--remote-conf=}'[remote configuration file]:file:_files' \
  '(-u --remote-url)'{-u,--remote-url=}'[remote source URL]:url:' \
  '1:tool:->tool' \
  '*::arg:->args' && ret=0

case $state in
  (tool)
    _describe -t tools 'tenv tool' tools && ret=0
    ;;
  (args)
    case $line[1] in
      (tofu|tf|terraform|tg|terragrunt|atmos)
        _arguments \
          '1:subcommand:->subcmd' \
          '*::arg:->subargs' && ret=0
        case $state in
          (subcmd)
            _describe -t subcommands 'subcommand' subcommands && ret=0
            ;;
          (subargs)
            case $line[2] in
              (install|uninstall|use)
                _arguments \
                  '(-w --working-dir)'{-w,--working-dir}'[create version file in working dir]' \
                  '1:version:(latest latest-allowed latest-pre latest-stable min-required)' && ret=0
                ;;
              (list)
                _arguments \
                  '(-d --descending)'{-d,--descending}'[display in descending order]' && ret=0
                ;;
              (list-remote)
                _arguments \
                  '(-d --descending)'{-d,--descending}'[display in descending order]' \
                  '(-s --stable)'{-s,--stable}'[only show stable versions]' && ret=0
                ;;
              (constraint)
                _arguments '1:constraint:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
