#compdef installer
# Documentation: https://www.unix.com/man-page/osx/1/installer/
# Source: Apple macOS — CLI installer for .pkg / .mpkg / product-archive payloads.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-pkg[package to install]:pkg:_files -g "*.(pkg|mpkg)"' \
    '-target[install target volume or domain]:target:(/ LocalSystem CurrentUserHomeDirectory)' \
    '-dominfo[list domains the package can be installed into]' \
    '-volinfo[list volumes the package can be installed onto]' \
    '-pkginfo[list packages installable onto target volume]' \
    '-showChoicesXML[print install choices as XML]' \
    '-showChoicesAfterApplyingChangesXML[print resulting choice state after applying XML changes]:xml:_files' \
    '-applyChoiceChangesXML[apply install-choice changes from XML]:xml:_files' \
    '-query[query a package for metadata]' \
    '-allowUntrusted[allow install of untrusted / expired-cert package]' \
    '-dumplog[write detailed log to stderr]' \
    '(- *)-help[show help]' \
    '-verbose[descriptive output]' \
    '-verboseR[parse-friendly verbose output]' \
    '(- *)-vers[show version]' \
    '-config[format args for later use]' \
    '-plist[output as XML plist]' \
    '-file[XML file of parameters]:file:_files' \
    '-lang[install language (ISO code)]:lang:' \
    '(- *)-listiso[list valid ISO language codes]' \
    '-store[install as if from Mac App Store]' \
    && ret=0

return ret
