#compdef sysinst
# Documentation: man sysinst(8)
# Source: netbsd/src usr.sbin/sysinst — menu-driven NetBSD installer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[ANSI colors bg:fg (defaults 4:7)]:bg\:fg:_default' \
    '-D[enable debugging output]' \
    '-f+[definition file for installation parameters]:definition file:_files' \
    '-m+[message catalog directory]:catalog dir:_files -/' \
    '-p[start extended partition editor]' \
    && ret=0

return ret
