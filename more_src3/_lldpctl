#compdef lldpctl
# Documentation: https://manpages.debian.org/testing/lldpd/lldpctl.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lldpctl - LLDP daemon control

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*-d[enable debugging output (repeat for more)]' \
  '-v[show version]' \
  '-u+[lldpd Unix-domain socket]:socket:_files' \
  '-f+[output format]:format:(plain keyvalue json json0 xml)' \
  '*-c+[read configuration file]:file:_files' \
  '*:interface:_net_interfaces' && ret=0

return ret
