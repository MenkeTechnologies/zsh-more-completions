#compdef splunk-otel-collector
# _splunk-otel-collector — Splunk OpenTelemetry Collector distribution (Splunk, Go); spf13/cobra wrappers
# upstream: https://github.com/signalfx/splunk-otel-collector

_splunk-otel-collector() {
    local -a sub=(
        'components:print components'
        'validate:validate config'
        'version:show version'
        'help:show help'
        'discovery:run discovery mode'
        'bundle.d:dump bundle dir'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file or URI]:str:' \
        '--set=+[set property]:str:' \
        '--feature-gates=+[feature gates]:str:' \
        '--discovery[enable discovery]' \
        '--discovery-properties=+[discovery properties file]:file:_files' \
        '--dry-run[dry run]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'splunk-otel-collector subcommand' sub ;;
        args)
            case $words[1] in
                validate) _arguments \
                    '--config=+[config file]:file:_files -g "*.yaml *.yml"' ;;
                discovery) _arguments \
                    '--config=+[config file]:file:_files' \
                    '--discovery-properties=+[properties]:file:_files' ;;
            esac
            ;;
    esac
}

_splunk-otel-collector "$@"
