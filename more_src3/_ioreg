#compdef ioreg
# Documentation: https://www.unix.com/man-page/osx/8/ioreg/
# Source: Apple macOS — show IORegistry contents.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[archive output in XML]' \
    '-b[show object name in bold]' \
    '-c[restrict to instances of C++ class]:class:(IOService IOPlatformExpert IOPCIDevice IOUSBDevice IOHIDDevice IOAudioDevice IOMedia IODisplayWrangler IODisplay IOPlatformDevice IOACPIPlatformDevice)' \
    '-d[depth limit on tree traversal]:depth:' \
    '-f[enable smart formatting]' \
    '-i[show object inheritance]' \
    '-k[show object only if it has the named key]:key:' \
    '-l[show properties for all displayed objects]' \
    '-n[show object only if it has the named name]:name:' \
    '-p[traverse over the specified plane]:plane:(IOACPIPlane IOAudio IODeviceTree IOFireWire IOPower IOService IOUSB)' \
    '-r[show subtrees rooted by matching objects]' \
    '-t[show tree location of each subtree]' \
    '-w[clip output to line width]:width:' \
    '-x[show data + numbers as hexadecimal]' \
    && ret=0

return ret
