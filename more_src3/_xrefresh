#compdef xrefresh
# _xrefresh — X11 xrefresh (refresh part or all of the X screen by mapping/unmapping a transparent window; -display picks display, -geometry WxH+X+Y limits area, -solid/-black/-white/-none pick fill, -root forces fullscreen)
# upstream: https://gitlab.freedesktop.org/xorg/app/xrefresh
# Flags from xrefresh xrefresh.c on tip.

_xrefresh() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-display+[X display]:display:' \
        '-geometry+[WxH+X+Y]:geom:' \
        '-root[refresh entire root]' \
        '-none[no fill (default)]' \
        '-solid+[fill with color]:color:' \
        '-black[fill black]' \
        '-white[fill white]' \
        '-screen+[screen number]:screen:'
}

_xrefresh "$@"
