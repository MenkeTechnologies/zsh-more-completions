#compdef ypserv
# _ypserv — OpenBSD ypserv (YP/NIS server; serves Berkeley-DB-backed YP maps from /var/yp/<domain>/; -a applies an access control list, -1 limits to NIS v1 lookups, -d enables debug, -x dumps map info)
# upstream: https://github.com/openbsd/src (usr.sbin/ypserv)
# Flags from usr.sbin/ypserv/ypserv/ypserv.8 on tip.

_ypserv() {
    _arguments \
        '-1[answer NIS v1 lookups only]' \
        '-d[debug (foreground + stderr)]' \
        '-x[print map descriptions + exit]' \
        '-a+[ACL file]:file:_files'
}

_ypserv "$@"
