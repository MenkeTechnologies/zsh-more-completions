#compdef hammer hammer-cli
# _hammer-cli — Foreman hammer (CLI for Foreman/Katello/Satellite; resource-then-action shape; resources: host, hostgroup, organization, location, content-view, repository, subscription, capsule, task, user, role, ping)
# upstream: https://github.com/theforeman/hammer-cli
# Resources from hammer help on tip.

_hammer-cli() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-u+[username]:user:' \
        '-p+[password]:password:' \
        '-c+[config file]:file:_files' \
        '-v[verbose]' \
        '--output+[output format]:format:(base table silent csv yaml json table_no_color)' \
        '--debug[debug]' \
        '--no-headers[suppress headers]' \
        '1: :->resource' \
        '*::arg:->args'
    case $state in
        resource)
            _describe -t commands 'hammer resource' \
                '(host hostgroup organization location domain subnet smart-proxy global-parameter user role report report-template task ping capsule content-view repository product subscription content-host activation-key gpg sync-plan lifecycle-environment subscription-manifest erratum environment template config-template os medium architecture model partition-table puppet-class puppet-environment compute-resource image proxy hook job-invocation job-template recurring-logic remote-execution-feature)'
            ;;
        args)
            _describe -t commands 'action' '(list info create update delete add remove set get set-parameter delete-parameter status start stop restart sync update-manifest refresh)'
            ;;
    esac
}

_hammer-cli "$@"
