#compdef src
# Documentation: https://github.com/sourcegraph/src-cli/blob/main/cmd/src/main.go
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above (Usage string).
# Removed fabricated subcommands: lsif, snapshot — these are not registered
# in src-cli main.go. Added confirmed subcommands: abc, auth, codeowners,
# gateway, search-jobs, teams.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'abc:manage agentic batch changes'
      'auth:authentication helper commands'
      'api:make Sourcegraph GraphQL API requests'
      'batch:manage batch changes'
      'code-intel:manage code intelligence data'
      'codeowners:manage code ownership information'
      'config:manage global, org, and user settings'
      'extensions:manage extensions (experimental)'
      'extsvc:manage external services'
      'gateway:interact with Cody Gateway'
      'login:authenticate with a Sourcegraph instance'
      'orgs:manage organizations'
      'teams:manage teams'
      'repos:manage repositories'
      'search:search for results on Sourcegraph'
      'search-jobs:manage search jobs'
      'serve-git:serve local git repositories over HTTP'
      'users:manage users'
      'version:display and compare src-cli version'
    )
    _describe -t commands 'src command' commands && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-json[output as JSON]' \
          '-less[pipe output through less]' \
          '-display=[max results to display]:count' \
          '-stream[stream results]' \
          '1:search query' && ret=0
        ;;
      api)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-query=[GraphQL query]:query' \
          '-vars=[query variables as JSON]:vars' \
          '-get[use HTTP GET instead of POST]' && ret=0
        ;;
      batch)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:->batch_cmds' \
          '*::arg:->batch_args' && ret=0
        case $state in
          batch_cmds)
            local -a batch_commands=(
              'preview:preview a batch change'
              'apply:apply a batch change'
              'validate:validate a batch spec'
              'new:create a new batch spec'
              'repos:list repos in a batch spec'
              'exec:execute batch change steps locally'
            )
            _describe -t commands 'batch subcommand' batch_commands && ret=0
            ;;
          batch_args)
            case $line[1] in
              preview|apply)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-f=[batch spec file]:spec file:_files -g "*.yaml"' \
                  '-namespace=[namespace]:namespace' \
                  '-n=[namespace]:namespace' && ret=0
                ;;
              validate|new)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-f=[batch spec file]:spec file:_files -g "*.yaml"' && ret=0
                ;;
              exec)
                _arguments -s -S \
                  '(- *)'{-h,--help}'[show help]' \
                  '-f=[batch spec file]:spec file:_files -g "*.yaml"' \
                  '-timeout=[step timeout]:timeout' \
                  '-keep-logs[keep logs after execution]' \
                  '-cache=[cache directory]:cache dir:_directories' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      repos)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list get delete)' && ret=0
        ;;
      users)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list get create delete)' && ret=0
        ;;
      orgs)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list get create delete members)' && ret=0
        ;;
      extensions)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(list get create update delete publish copy)' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:Sourcegraph URL' && ret=0
        ;;
    esac
    ;;
esac

return ret
