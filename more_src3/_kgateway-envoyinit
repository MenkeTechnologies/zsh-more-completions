#compdef kgateway-envoyinit envoyinit
# _kgateway-envoyinit — kgateway envoy init-container (rewrites the kgateway-generated Envoy bootstrap before exec'ing envoy)
# upstream: https://github.com/kgateway-dev/kgateway
# Source: cmd/envoyinit/main.go on tip; no CLI flags — env vars ENVOY_EXECUTABLE, INPUT_CONFIG_PATH, OUTPUT_CONFIG_PATH drive runtime behaviour.

_kgateway-envoyinit() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_kgateway-envoyinit "$@"
