#compdef jack_alias
# Documentation: https://jackaudio.org/
# Source: jackaudio/jack-example-tools tools/alias.c — assign/remove an alias name for a JACK port.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-u --unalias)'{-u,--unalias}'[remove alias for port]' \
    '(- *)'{-h,--help}'[display help]' \
    '(- *)--version[output version and exit]' \
    '*:port then alias:' \
    && ret=0

return ret
