#compdef stp
# Documentation: https://github.com/stp/stp (tools/stp/main.cpp options)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)--version[print version number]' \
  '(-a --disable-opt-inc)'{-a,--disable-opt-inc}'[disable rewriting simplifier]' \
  '(-w --switch-word)'{-w,--switch-word}'[switch off wordlevel solver]' \
  '--disable-cbitp[disable constant bit propagation]' \
  '--disable-equality[disable equality propagation]' \
  '--disable-simplifications[disable simplifications]' \
  '--size-reducing-only[size reducing simplifications only]' \
  '--unconstrained-variable-elimination[unconstrained variable elimination]' \
  '--aig-rewrite-passes=[number of AIG rewrite passes]:n:' \
  '--flattening[enable flattening]' \
  '--rewriting[enable rewriting]' \
  '--split-extracts[split extracts]' \
  '--ite-context-simplifications[ITE context simplifications]' \
  '--aig-core-simplification[AIG core simplification]' \
  '--use-intervals[use intervals]' \
  '--pure-literals[pure literals]' \
  '--always-true[always true]' \
  '--merge-same[merge same]' \
  '--bit-blast-simplification[bit-blast simplification]' \
  '--size-reducing-fixed-point-limit=[size reducing fixed-point limit]:n:' \
  '--cryptominisat[use CryptoMiniSat as SAT backend]' \
  '--minisat[use MiniSat as SAT backend]' \
  '--simplifying-minisat[use simplifying MiniSat as SAT backend]' \
  '--riss[use Riss as SAT backend]' \
  '--threads=[number of threads]:n:' \
  '(-r --ackermanize)'{-r,--ackermanize}'[ackermannize array reads]' \
  '(-b --print-stpinput)'{-b,--print-stpinput}'[print STP input back]' \
  '--print-back-CVC[print back as CVC]' \
  '--print-back-SMTLIB1[print back as SMTLIB1]' \
  '--print-back-SMTLIB2[print back as SMTLIB2]' \
  '--print-back-GDL[print back as GDL]' \
  '--print-back-dot[print back as dot]' \
  '(-p --print-counterex)'{-p,--print-counterex}'[print counter-example]' \
  '(-y --print-counterexbin)'{-y,--print-counterexbin}'[print binary counter-example]' \
  '(-q --print-arrayval)'{-q,--print-arrayval}'[print array values]' \
  '(-s --print-functionstat)'{-s,--print-functionstat}'[print function statistics]' \
  '(-t --print-quickstat)'{-t,--print-quickstat}'[print quick statistics]' \
  '(-v --print-nodes)'{-v,--print-nodes}'[print nodes]' \
  '(-n --print-output)'{-n,--print-output}'[disable returning counter-example]' \
  '--SMTLIB1[use SMT-LIB1 parser]' \
  '--SMTLIB2[use SMT-LIB2 parser]' \
  '--CVC[use CVC parser]' \
  '--output-CNF[output CNF file]' \
  '--output-bench[output bench file]' \
  '--exit-after-CNF[exit after CNF generation]' \
  '(-d --check-sanity)'{-d,--check-sanity}'[check sanity / counter-example]' \
  '*:input file:_files -g "*.(smt|smt2|cvc|stp)"' && ret=0

return ret
