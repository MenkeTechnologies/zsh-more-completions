#compdef snappyHexMesh
# Documentation: https://manpages.debian.org/testing/openfoam/snappyHexMesh.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream Debian man page at the URL above plus
# applications/utilities/mesh/generation/snappyHexMesh/snappyHexMesh.C source.

# OpenFOAM snappyHexMesh: automatic split-hex mesher
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[short help]' \
  '-help-full[full help]' \
  '-help-man[help in man-page format]' \
  '-help-notes[help notes]' \
  '-help-compat[compatibility options]' \
  '-doc[display documentation in browser]' \
  '-doc-source[display source code]' \
  '-case[case directory]:dir:_files -/' \
  '-checkGeometry[check surface geometry quality]' \
  '-decomposeParDict[decomposition dictionary]:file:_files' \
  '-dict[alternative snappyHexMeshDict]:file:_files' \
  '-dry-run[check setup using single time step]' \
  '-outFile[save simplified surface to file]:file:_files' \
  '-overwrite[overwrite existing mesh]' \
  '-parallel[run in parallel]' \
  '-patches[triangulate selected patches]:patches:' \
  '-profiling[activate profiling]' \
  '-region[mesh region]:region:' \
  '-surfaceSimplify[simplify surface from bounding box]:bbox:' \
  '-debug-switch[debug switch]:name=val:' \
  '-fileHandler[file handler]:handler:(uncollated collated masterUncollated)' \
  '-hostRoots[host roots]:hosts:' \
  '-info-switch[info switch]:name=val:' \
  '-lib[load library]:name:' \
  '-opt-switch[opt switch]:name=val:' \
  '-roots[root directories]:roots:' \
  '-noFunctionObjects[disable function objects (compat)]' \
  '*::snappyHexMesh args:_files' && ret=0
return ret
