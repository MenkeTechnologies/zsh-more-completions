#compdef symfony-cli
# _symfony-cli — SymfonyCorp Symfony CLI dev environment + cloud tooling (Symfony / SensioLabs, Go); custom argparse
# upstream: https://github.com/symfony-cli/symfony-cli

_symfony-cli() {
    local -a sub=(
        'about:show CLI info'
        'book:show Symfony Cloud book'
        'bug-report:create bug report'
        'check:check requirements'
        'cloud:cloud commands (Platform.sh)'
        'composer:run composer'
        'console:run Symfony Console'
        'doctrine-ext:Doctrine helpers'
        'fix:run analyzer fixes'
        'help:show help'
        'list:list commands'
        'local:local PHP commands'
        'new:scaffold a new Symfony project'
        'new-flex:scaffold a Symfony Flex skeleton'
        'open:open a URL/local dev'
        'php:run PHP'
        'php-version:print PHP version'
        'phpunit:run PHPUnit'
        'proxy:dev proxy'
        'run:run a command with Symfony env'
        'security:security commands'
        'server:dev server commands'
        'serve:start local web server (alias of server:start)'
        'self-update:self-update'
        'service:service helpers'
        'tunnel:SSH tunnel helpers'
        'version:show version'
        'var-dump-server:start var-dump server'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[force ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'symfony subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '--full[full]' \
                    '--demo[demo]' \
                    '--webapp[webapp]' \
                    '--api[api]' \
                    '--book[book]' \
                    '--php=+[PHP version]:str:' \
                    '--cloud[push to cloud]' \
                    '--version=+[Symfony version]:str:' \
                    '--branch=+[branch]:str:' \
                    '--no-git[no git]' \
                    '--dir=+[dir]:dir:_files -/' \
                    '*:name:' ;;
                server) _arguments \
                    '1:cmd:(start stop list status log prod ca-install ca-uninstall)' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--listen-ip=+[listen IP]:str:' \
                    '--allow-http[allow http]' \
                    '--no-tls[no tls]' \
                    '--daemon[daemon]' \
                    '-d[daemon]' \
                    '--passthru=+[passthru]:str:' \
                    '--allow-cors[allow CORS]' \
                    '--allow-all-ip[allow all IP]' \
                    '--document-root=+[document root]:dir:_files -/' \
                    '*:arg:' ;;
                cloud) _arguments \
                    '1:cmd:(login logout switch link unlink list status push pull deploy environment branch sync clone backup ssh tunnel)' \
                    '*:arg:' ;;
                proxy) _arguments \
                    '1:cmd:(start stop status domain attach detach list-domains)' \
                    '*:arg:' ;;
                local) _arguments \
                    '1:cmd:(php server console)' \
                    '*:arg:' ;;
                run|php|composer|console|phpunit) _arguments '*:cmd:_command_names -e' ;;
            esac
            ;;
    esac
}

_symfony-cli "$@"
