#compdef sndfile-waveform
# _sndfile-waveform — render an audio waveform PNG image (libsndfile/sndfile-tools)
# upstream: https://github.com/libsndfile/sndfile-tools
# Flags from src/waveform.c (getopt_long).

_sndfile-waveform() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '(-b --border)'{-b,--border}'[draw a border around the plot]'
        '(-l --logscale)'{-l,--logscale}'[logarithmic vertical scale]'
        '(-r --rectified --rectify)'{-r,--rectified,--rectify}'[rectify the signal]'
        '(-O --border-width)'{-O+,--border-width=}'[border width (px)]:px:'
        '(-g --geometry)'{-g+,--geometry=}'[image geometry WxH (px)]:WxH:'
        '(-S --separator)'{-S+,--separator=}'[per-channel separator width (px)]:px:'
        '(-W --wavesize)'{-W,--wavesize}'[scale width by sample-count instead of constant]'
        '(-s --gainscale)'{-s,--gainscale}'[scale the vertical axis by peak gain]'
        '(-c --channel)'{-c+,--channel=}'[channel(s) to plot]:channel:'
        '(-A --textcolour)'{-A+,--textcolour=}'[text color (0xRRGGBBAA)]:color:'
        '(-F --foreground)'{-F+,--foreground=}'[waveform color (0xRRGGBBAA)]:color:'
        '(-B --background)'{-B+,--background=}'[background color (0xRRGGBBAA)]:color:'
        '(-R --rmscolour)'{-R+,--rmscolour=}'[RMS color (0xRRGGBBAA)]:color:'
        '(-G --borderbg)'{-G+,--borderbg=}'[border background color (0xRRGGBBAA)]:color:'
        '(-t --timecode)'{-t+,--timecode=}'[time-axis unit]:unit:(seconds frames timecode)'
        '(-T --timeoffset)'{-T+,--timeoffset=}'[time offset to subtract]:offset:'
        '--no-peak[do not draw peak signal]'
        '--no-rms[do not draw RMS signal]'
        '1:input sound file:_files'
        '2:output PNG file:_files -g "*.png"'
    )
    _arguments -s $args
}

_sndfile-waveform "$@"
