#compdef ts
# _ts — moreutils ts (prefix each stdin line with a timestamp; -r converts existing timestamps to relative, -i shows interval since last line, -s elapsed since start, -m monotonic clock; positional arg is strftime(3) format)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils ts.pl on tip.

_ts() {
    _arguments \
        '-r[convert existing timestamps in input to relative]' \
        '-i[print interval between lines]' \
        '-s[print elapsed since start]' \
        '-m[use CLOCK_MONOTONIC]' \
        '1:format:(%H:%M:%S %Y-%m-%d\ %H:%M:%S %b\ %d\ %H:%M:%S %s)'
}

_ts "$@"
