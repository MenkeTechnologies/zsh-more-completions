#compdef hdl_checker
# Documentation: source-direct extraction from upstream
# suoto/hdl_checker setup.py `entry_points.console_scripts`
# (`hdl_checker = hdl_checker.server:main`) + hdl_checker/
# server.py argparse declarations. The installed binary uses
# underscore (`hdl_checker`) NOT hyphen (`hdl-checker`) per
# upstream entry-point name - PyPI package name vs. binary name
# disambiguation.
# Reference accessed: 2026-05-30 via gh api.
# suoto hdl_checker R155a — HDL (VHDL/Verilog/SystemVerilog)
# code-checker daemon that wraps multiple synthesis tools
# (GHDL, Riviera-Pro, ModelSim, Vivado xvhdl, msim) behind a
# common HTTP + LSP interface. Sister to the heavily-covered
# yosys/nextpnr/verilator/iverilog/vvp/gtkwave/ghdl HDL family.

_arguments -s -S \
  '--host=[HTTP server bind host]:host:_hosts' \
  '--port=[HTTP server bind port]:port:' \
  '--lsp[run as LSP (Language Server Protocol) over stdio instead of HTTP]' \
  '--attach-to-pid=[attach to a running PID and exit when that process exits]:pid:_pids' \
  '--log-level=[log verbosity for both HTTP and LSP modes]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '--log-stream=[log destination file path]:file:_files' \
  '--stdout=[redirect daemon stdout to file]:file:_files' \
  '--stderr=[redirect daemon stderr to file]:file:_files' \
  '(-V --version)'{-V,--version}'[print version and exit]'
