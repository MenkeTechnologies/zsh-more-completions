#compdef systemd-sysupdate
# Documentation: source-direct extraction from upstream
# systemd/systemd src/sysupdate/sysupdate.c —
#   verb dispatch table at lines 1287-1654 (VERB declarations
#     for list/features/update/acquire/pending/reboot)
#   parse_argv() at lines 1882-2023 (the OptionParser
#     FOREACH_OPTION_OR_RETURN dispatch + OPTION_GROUP/OPTION/
#     OPTION_LONG entries)
#   conflict validation at lines 2012-2019 (--root/--image
#     mutex, --reboot+--root/--image mutex, --definitions/
#     --component mutex)
# Reference accessed: 2026-05-30 via gh api.
#
# systemd-sysupdate is the **major A/B partition update tool**
# for systemd's atomic-update story.  Drives the systemd-
# sysupdate.service unit (and sister sysupdated D-Bus service
# at R219 updatectl).  Operates on .transfer definition files
# (typically /usr/lib/sysupdate.d/*.transfer) to download +
# verify + apply OS / boot / kernel / verity / esp partition
# updates from a configured source.  Used in immutable-distro
# update flows (Fedora Silverblue / openSUSE MicroOS / Endless
# OS / Photon OS) for safe rollback-capable updates.
#
# Continues the embedded-Linux OTA family established in
# rounds R209 genimage, R210 swupdate, R212 rauc, R213 mender.
# systemd-sysupdate is the systemd-native answer to the same
# problem space.

# Verbs decoded source-direct from sysupdate.c:1287-1654.
# `list` is VERB_DEFAULT — runs when no verb supplied.
local -a subcommands=(
  'list:list available versions (DEFAULT; optionally filter by VERSION)'
  'features:list available transfer features (optionally one FEATURE name)'
  'update:install a newer version (default: latest; optionally pin to specific VERSION)'
  'acquire:download but do NOT install the latest version (or specific VERSION)'
  'pending:report whether a pending update is staged (exit 0 = yes, 1 = no)'
  'reboot:reboot the system if an update was applied'
)

# OPTION_COMMON_JSON enum decoded source-direct from systemd's
# parse_json_argument() — the same enum is used across all
# json-emitting systemd tools: off, on, pretty, short.
local -a json_formats=(off pretty short)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show package version and exit]' \
  '(-C --component)'{-C+,--component=}'[select transfer component to update]:name:' \
  '--definitions=[find .transfer definition files in DIR]:dir:_files -/' \
  '--root=[operate on an alternate filesystem root (mutex with --image)]:path:_files -/' \
  '--image=[operate on a disk image as filesystem root (mutex with --root)]:image:_files' \
  '--image-policy=[disk image dissection policy]:policy:' \
  '--transfer-source=[directory to transfer sources from]:dir:_files -/' \
  '(-m --instances-max)'{-m+,--instances-max=}'[how many version instances to maintain]:count:' \
  '--sync=[whether to sync data to disk]:bool:(yes no true false 1 0)' \
  '--verify=[force signature verification on or off]:bool:(yes no true false 1 0)' \
  '--reboot[reboot after updating to newer version (mutex with --root/--image)]' \
  '--offline[do not fetch metadata from the network]' \
  '--no-pager[do not pipe output into a pager]' \
  '--no-legend[do not print legend in output]' \
  '--json=[output as JSON]:format:(off pretty short)' \
  '1:verb (default: list):->subcmd' \
  '*::verb-args:->args'

case $state in
  subcmd)
    _describe -t subcommands 'systemd-sysupdate verb' subcommands && return
    ;;
  args)
    case $words[1] in
      list|update|acquire)
        _message 'VERSION (optional; default: latest)' && return
        ;;
      features)
        _message 'FEATURE name (optional)' && return
        ;;
      pending|reboot)
        # No args.
        ;;
    esac
    ;;
esac
