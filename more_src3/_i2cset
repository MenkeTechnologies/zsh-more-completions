#compdef i2cset
# _i2cset — Linux i2c-tools i2cset CLI for writing a value to a register on an I2C device specifying bus address register data with byte word block I2C-block SMBus access modes interactive confirm (i2c-tools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/utils/i2c-tools/i2c-tools.git

_i2cset() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-y[disable interactive confirm]' \
        '-f[force]' \
        '-r[read after write]' \
        '-a[allow addresses 0x00-0x07 and 0x78-0x7f]' \
        '-m+[mask hex]:str:' \
        '*:i2cbus chip-address data-address value mode:'
}

_i2cset "$@"
