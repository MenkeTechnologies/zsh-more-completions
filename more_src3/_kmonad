#compdef kmonad
# Documentation: https://hackage.haskell.org/package/kmonad-0.4.2/docs/src/KMonad.Args.Cmd.html
# Reference accessed: 2026-05-19
# Verified: upstream optparse-applicative parser (KMonad.Args.Cmd).
# Added real flags: -c/--allow-cmd, -f/--fallthrough, -t/--init,
# -s/--cmp-seq, -o/--output, -i/--input, -w/--start-delay, -V/--version.

# Zsh completion for kmonad - keyboard remapping daemon

_arguments \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version and git commit]' \
  '(-d --dry-run)'{-d,--dry-run}'[parse config but do not start]' \
  '(-c --allow-cmd)'{-c,--allow-cmd}'[allow arbitrary shell-command execution]' \
  '(-f --fallthrough)'{-f,--fallthrough}'[re-emit unhandled keyboard events]' \
  '(-l --log-level)'{-l+,--log-level=}'[set log level]:level:(debug info warn error)' \
  '(-t --init)'{-t+,--init=}'[initialization string]:string:' \
  '(-s --cmp-seq)'{-s+,--cmp-seq=}'[compose-key sequence button]:button:' \
  '(-o --output)'{-o+,--output=}'[output token specification]:otoken:' \
  '(-i --input)'{-i+,--input=}'[input token specification]:itoken:' \
  '(-w --start-delay)'{-w+,--start-delay=}'[keyboard grab delay in ms]:milliseconds:' \
  '1:config file:_files -g "*.kbd"'
