#compdef wishlist
# Documentation: https://github.com/charmbracelet/wishlist
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for wishlist - Charm SSH app directory

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'serve:serve the TUI over SSH'
  'server:alias of serve'
  's:alias of serve'
)

local -a globals=(
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files'
  '--zeroconf.enabled[enable zeroconf service discovery]'
  '--zeroconf.domain=[zeroconf discovery domain]:domain:'
  '--zeroconf.timeout=[zeroconf discovery timeout]:duration:'
  '*--srv.domain=[DNS SRV discovery domain]:domain:'
  '--tailscale.net=[tailscale tailnet name]:tailnet:'
  '--tailscale.key=[tailscale API key]:key:'
  '--tailscale.client.id=[tailscale OAuth client id]:id:'
  '--tailscale.client.secret=[tailscale OAuth client secret]:secret:'
)

_arguments -C \
  $globals \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t subcommands 'wishlist subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (serve|server|s)
        _arguments -s -S \
          $globals \
          '--endpoints.refresh.interval=[endpoint refresh interval]:duration:' && ret=0
        ;;
    esac
    ;;
esac

return ret
