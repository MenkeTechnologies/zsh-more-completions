#compdef x2sys_report
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/x2sys/x2sys_report.html
# Source: GenericMappingTools/gmt supplements/x2sys — per-track crossover-statistics report.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[data column to process]:column:_default' \
    '-T+[x2sys TAG]:tag:_default' \
    '-A[redistribute crossover errors + adjustment files]' \
    '-I+[exclude tracks from file]:file:_files' \
    '-L+[apply optimal correction table]:file:_files' \
    '-N+[min crossings for inclusion]:n:_default' \
    '-Q+[external/internal crossovers only]:scope:(e i)' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[limit to crossovers with track]:track:_default' \
    '*-V[verbose (stackable)]' \
    '*:crossover database:_files' \
    && ret=0

return ret
