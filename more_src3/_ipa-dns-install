#compdef ipa-dns-install
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-dns-install.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-dns-install.1.

# ipa-dns-install: install/configure IPA DNS
local curcontext="$curcontext" ret=1
_arguments -C \
  '*--ip-address=[IPA server IP address]:ip:' \
  '*--forwarder=[DNS forwarder]:ip:' \
  '--no-forwarders[do not add DNS forwarders]' \
  '--auto-forwarders[add forwarders from /etc/resolv.conf]' \
  '--forward-policy=[DNS forwarding policy]:policy:(first only)' \
  '*--reverse-zone=[reverse DNS zone]:zone:' \
  '--no-reverse[do not create reverse DNS zone]' \
  '--auto-reverse[try to resolve reverse records]' \
  '--no-dnssec-validation[disable DNSSEC validation]' \
  '--dnssec-master[set up DNSSEC key master]' \
  '--disable-dnssec-master[disable DNSSEC master]' \
  '--kasp-db=[OpenDNSSEC kasp.db file]:file:_files' \
  '--zonemgr=[DNS zone manager email]:email:' \
  '--allow-zone-overlap[allow creating already-resolvable zones]' \
  '(-U --unattended)'{-U,--unattended}'[unattended installation]' \
  '--dns-over-tls[configure DNS over TLS]' \
  '*--dot-forwarder=[DNS-over-TLS forwarder ip#hostname]:spec:' \
  '--dns-over-tls-cert=[DoT certificate]:file:_files' \
  '--dns-over-tls-key=[DoT key]:file:_files' \
  '--dns-policy=[encrypted DNS policy]:policy:(relaxed enforced)' && ret=0
return ret
