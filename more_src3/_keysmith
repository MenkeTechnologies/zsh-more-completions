#compdef keysmith
# Documentation: https://invent.kde.org/network/keysmith
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. STUB - src/main.cpp uses
# QCommandLineParser with only addHelpOption()/addVersionOption(); all
# functionality is in the GUI.
# Removed from prior file: fabricated -h/--help/-V/--version single-dash
# variants and bogus man.archlinux.org search URL. (--help and --version
# are real and kept; the short -h/-V are not generic Qt long-form flags.)

# keysmith: KDE Plasma OTP/2FA token manager (GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' && ret=0
return ret
