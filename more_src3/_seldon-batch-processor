#compdef seldon-batch-processor
# Documentation: https://github.com/SeldonIO/seldon-core/blob/master/python/seldon_core/batch_processor.py
# Reference accessed: 2026-05-21
# Verified: upstream click decorators at the URL above.

# Seldon batch processor: run batched predictions against a Seldon deployment.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(-d --deployment-name)'{-d+,--deployment-name=}'[Seldon deployment name]:name:' \
  '(-g --gateway-type)'{-g+,--gateway-type=}'[gateway type]:type:(ambassador istio seldon)' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:ns:' \
  '(-h --host)'{-h+,--host=}'[gateway host]:host:_hosts' \
  '(-t --transport)'{-t+,--transport=}'[transport]:transport:(rest grpc)' \
  '(-a --data-type)'{-a+,--data-type=}'[payload format]:type:(data json str raw)' \
  '(-p --payload-type)'{-p+,--payload-type=}'[payload data structure]:type:(ndarray tensor tftensor)' \
  '(-w --workers)'{-w+,--workers=}'[parallel worker count]:n:' \
  '(-r --retries)'{-r+,--retries=}'[retry attempts per request]:n:' \
  '(-i --input-data-path)'{-i+,--input-data-path=}'[input file]:file:_files' \
  '(-o --output-data-path)'{-o+,--output-data-path=}'[output file]:file:_files' \
  '(-m --method)'{-m+,--method=}'[API method]:method:(predict feedback)' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(debug info warning error)' \
  '(-b --benchmark)'{-b,--benchmark}'[show elapsed processing time]' \
  '(-u --batch-id)'{-u+,--batch-id=}'[unique batch identifier]:id:' \
  '(-s --batch-size)'{-s+,--batch-size=}'[instances per request]:n:' \
  '--batch-interval=[minimum delay between predictions (seconds)]:seconds:' \
  '--use-ssl[enable HTTPS for REST transport]' \
  '--call-credentials-token=[authentication token for Seldon client]:token:' \
  '--ssl-verify=[SSL certificate verification toggle]:flag:(true false)' && ret=0
return ret
