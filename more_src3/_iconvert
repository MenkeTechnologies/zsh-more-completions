#compdef iconvert
# _iconvert — copy/convert images with format alterations (AcademySoftwareFoundation/OpenImageIO)
# upstream: https://github.com/AcademySoftwareFoundation/OpenImageIO
# Flags from src/iconvert/iconvert.cpp (ArgParse ap.options).

_iconvert() {
    _arguments \
        '(- *)--help[show help]' \
        '-v[verbose output]' \
        '-o+[output filename]:file:_files' \
        '--threads=[number of threads]:n:' \
        '-d+[output data format]:type:(uint8 sint8 uint10 uint12 uint16 sint16 half float double)' \
        '-g+[gamma correction]:float:' \
        '--tile=[output as tiled (WIDTH HEIGHT)]:w:' \
        '--scanline[force scanline output]' \
        '--compression=[compression method (name[:quality])]:method:' \
        '--quality=[deprecated; use --compression]:n:' \
        '--no-copy-image[skip ImageOutput copy_image fast path]' \
        '--adjust-time[adjust file times to DateTime metadata]' \
        '--caption=[ImageDescription text]:caption:' \
        '*--keyword=[add keyword]:keyword:' \
        '--clear-keywords[clear keywords]' \
        '*--attrib=[set NAME VALUE attribute]:name:' \
        '--orientation=[set orientation flag (1-8)]:n:(1 2 3 4 5 6 7 8)' \
        '(--rotcw --rotccw --rot180)--rotcw[rotate 90 deg clockwise]' \
        '(--rotcw --rotccw --rot180)--rotccw[rotate 90 deg counter-clockwise]' \
        '(--rotcw --rotccw --rot180)--rot180[rotate 180 deg]' \
        '--inplace[modify files in place]' \
        '--sRGB[input is in sRGB color space]' \
        '(--separate --contig)--separate[force planarconfig separate]' \
        '(--separate --contig)--contig[force planarconfig contig]' \
        '--no-clobber[skip if output exists]' \
        '*:image file:_files'
}

_iconvert "$@"
