#compdef hdparm-cli
# _hdparm-cli — Mark Lord hdparm hard disk parameter management CLI alias (Linux/hdparm team, C); custom argparse
# upstream: https://sourceforge.net/projects/hdparm/

_hdparm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[readahead sectors]:n:' \
        '-A+[read-ahead]:n:(0 1)' \
        '-b+[bus state]:n:(0 1 2)' \
        '-B+[apm level]:n:' \
        '-c+[32-bit IO]:n:(0 1 3)' \
        '-C[check power mode status]' \
        '-d+[DMA]:n:(0 1)' \
        '-D+[defect mgmt]:n:(0 1)' \
        '-E+[CD speed]:n:' \
        '-f[flush buffer]' \
        '-F[flush write cache]' \
        '-g[display geometry]' \
        '-h[show help]' \
        '-H[read hidden]' \
        '-i[get drive info]' \
        '-I[detailed info]' \
        '-J[wd_idle3]' \
        '-k+[keep settings]:n:(0 1)' \
        '-K+[keep settings on reset]:n:(0 1)' \
        '-L+[lock door]:n:(0 1)' \
        '-m+[multiblock]:n:' \
        '-M+[automatic acoustic mgmt]:n:' \
        '-n+[no IO error]:n:(0 1)' \
        '-N+[max sectors]:n:' \
        '-p+[pio mode]:n:' \
        '-P+[max sectors per req]:n:' \
        '-q[quiet]' \
        '-Q+[ncq depth]:n:' \
        '-r+[readonly]:n:(0 1)' \
        '-R+[set rw transfer]:n:' \
        '-s+[power-up]:n:(0 1)' \
        '-S+[standby timeout]:n:' \
        '-t[buffered read perf]' \
        '-T[cached read perf]' \
        '-u+[interrupts]:n:(0 1)' \
        '-U+[unregister IDE]:n:' \
        '-v[verbose]' \
        '-W+[write cache]:n:(0 1)' \
        '-y[standby]' \
        '-Y[sleep]' \
        '-Z[disable Seagate auto-spindown]' \
        '-z[reread partition table]' \
        '--security-help[security help]' \
        '--security-freeze[freeze security]' \
        '--security-unlock=+[password]:str:' \
        '--security-set-pass=+[password]:str:' \
        '--security-disable=+[password]:str:' \
        '--security-erase=+[password]:str:' \
        '--security-erase-enhanced=+[password]:str:' \
        '--security-mode=+[mode]:m:(h m)' \
        '--user-master=+[level]:u:(u m)' \
        '--read-sector=+[sector]:n:' \
        '--write-sector=+[sector]:n:' \
        '--make-bad-sector=+[sector]:n:' \
        '--repair-sector=+[sector]:n:' \
        '--trim-sector-ranges=+[ranges]:str:' \
        '--trim-sector-ranges-stdin[trim from stdin]' \
        '--Istdin[id stdin]' \
        '--Istdout[id stdout]' \
        '--dco-freeze[dco freeze]' \
        '--dco-identify[dco identify]' \
        '--dco-restore[dco restore]' \
        '--sanitize-status[sanitize status]' \
        '--sanitize-block-erase[block erase]' \
        '--sanitize-crypto-scramble[crypto scramble]' \
        '--sanitize-overwrite=+[pattern]:str:' \
        '--sanitize-freeze-lock[freeze lock]' \
        '--sanitize-antifreeze-lock[anti freeze lock]' \
        '*:device:_files -g "/dev/{sd,hd,nvme}*"'
}

_hdparm-cli "$@"
