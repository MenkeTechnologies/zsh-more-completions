#compdef hive2 hive-cli2
# _hive2 — Apache Hive hive2 CLI command-line frontend wrapping the Apache Hive data warehouse software for reading writing managing large datasets residing in distributed storage providing interactive shell-mode batch-mode hive metastore CLI-driver Beeline-replacement hiveconf hivevar service-name set variable substitution database init-files (Apache Hive team, Java); custom argparse
# upstream: https://hive.apache.org/

_hive2() {
    _arguments \
        '-h+[host]:_hosts' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-e+[query]:str:' \
        '-f+[query file]:file:_files -g "*.sql *.hql *.q"' \
        '-i+[init file]:file:_files -g "*.sql *.hql *.q"' \
        '-S[silent]' \
        '--silent[silent]' \
        '--hiveconf=+[k=v]:str:' \
        '--hivevar=+[k=v]:str:' \
        '--define=+[k=v]:str:' \
        '-d+[key=value]:str:' \
        '--database=+[name]:str:' \
        '-p+[port]:n:' \
        '--service=+[s]:s:(cli hiveserver2 hiveserver hwi jar metastore metatool orcfiledump rcfilecat schemaTool version)' \
        '--auxpath=+[paths]:str:' \
        '--config=+[dir]:dir:_files -/' \
        '*:hive script:_files -g "*.sql *.hql *.q"'
}

_hive2 "$@"
