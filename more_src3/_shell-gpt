#compdef sgpt
# Documentation: https://github.com/TheR1D/shell_gpt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--model=[LLM to use]:model:' \
  '--temperature=[sampling temperature (0.0-2.0)]:temperature:' \
  '--top-p=[top-p sampling (0.0-1.0)]:top_p:' \
  '(--md --no-md)--md[markdown output]' \
  '(--md --no-md)--no-md[plain text output]' \
  '--editor[open $EDITOR for prompt input]' \
  '(--cache --no-cache)--cache[enable caching]' \
  '(--cache --no-cache)--no-cache[disable caching]' \
  '(-s --shell)'{-s,--shell}'[shell mode - generate and execute shell commands]' \
  '(--interaction --no-interaction)--interaction[interactive shell mode]' \
  '(--interaction --no-interaction)--no-interaction[non-interactive shell mode]' \
  '(-d --describe-shell)'{-d,--describe-shell}'[describe a shell command]' \
  '(-c --code)'{-c,--code}'[code mode - generate code only]' \
  '(--functions --no-functions)--functions[enable function calls]' \
  '(--functions --no-functions)--no-functions[disable function calling]' \
  '--chat=[chat session id ("temp" for quick)]:session:' \
  '--repl=[start REPL session]:session:' \
  '--show-chat=[show previous chat]:session:' \
  '(-lc --list-chats)'{-lc,--list-chats}'[list all chats]' \
  '--role=[apply predefined role]:role:' \
  '--create-role=[create new role]:role:' \
  '--show-role=[show role definition]:role:' \
  '(-lr --list-roles)'{-lr,--list-roles}'[list all roles]' \
  '*:prompt:' && return 0
