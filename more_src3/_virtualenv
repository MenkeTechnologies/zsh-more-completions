#compdef virtualenv
# Documentation: virtualenv CLI reference (virtualenv.pypa.io)
# Source: virtualenv — create isolated Python environments.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[display version and location]' \
    '--with-traceback[show stacktrace internals on failure]' \
    '--read-only-app-data[use app data folder in read-only mode]' \
    '--app-data=[custom data folder for caching]:dir:_files -/' \
    '--reset-app-data[start with an empty app data folder]' \
    '--upgrade-embed-wheels[manually update embedded wheels]' \
    '*'{-v,--verbose}'[increase verbosity]' \
    '*'{-q,--quiet}'[decrease verbosity]' \
    '--discovery=[interpreter discovery method]:method:(builtin)' \
    '(-p --python)*'{-p,--python=}'[Python interpreter to use]:python:' \
    '*--try-first-with=[prioritize specific interpreter]:python:' \
    '--creator=[environment creation method]:creator:(builtin venv cpython3-posix cpython3-win pypy3-posix pypy3-win)' \
    '--clear[remove destination directory before creation]' \
    '--no-vcs-ignore[skip VCS ignore directive creation]' \
    '--system-site-packages[allow access to system site-packages]' \
    '(--symlinks --copies --always-copy)--symlinks[use symlinks instead of copies]' \
    '(--symlinks --copies --always-copy)'{--copies,--always-copy}'[use copies instead of symlinks]' \
    '--seeder=[seed-package method]:seeder:(app-data pip)' \
    '(--no-seed --without-pip)'{--no-seed,--without-pip}'[skip seed package installation]' \
    '(--download --no-download --never-download)--download[enable PyPI downloads]' \
    '(--download --no-download --never-download)'{--no-download,--never-download}'[disable PyPI downloads]' \
    '*--extra-search-dir=[additional wheel directory]:dir:_files -/' \
    '--pip=[pip version to install]:version:' \
    '--setuptools=[setuptools version to install]:version:' \
    '--wheel=[wheel version to install]:version:' \
    '--no-pip[skip pip installation]' \
    '--no-setuptools[skip setuptools installation]' \
    '--no-wheel[skip wheel installation]' \
    '--no-periodic-update[disable automatic wheel updates]' \
    '--symlink-app-data[symlink packages from app-data folder]' \
    '*--activators=[activation scripts to generate]:activator:(bash batch cshell fish powershell python)' \
    '--prompt=[custom prompt prefix for the environment]:prompt:' \
    '1:destination directory:_files -/' \
    && ret=0

return ret
