#compdef speexenc
# Documentation: speexenc --help (Speex)
# Source: Xiph Speex — speech-codec encoder (Ogg Speex container).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-n --narrowband -w --wideband -u --ultra-wideband)'{-n,--narrowband}'[narrowband (8 kHz) input]' \
    '(-n --narrowband -w --wideband -u --ultra-wideband)'{-w,--wideband}'[wideband (16 kHz) input]' \
    '(-n --narrowband -w --wideband -u --ultra-wideband)'{-u,--ultra-wideband}'[ultra-wideband (32 kHz) input]' \
    '--quality=[encoding quality 0..10 (default 8)]:n:' \
    '--bitrate=[encoding bit-rate cap]:n:' \
    '--vbr[enable variable bit-rate (VBR)]' \
    '--vbr-max-bitrate=[max VBR bit-rate]:bps:' \
    '--abr=[average bit-rate mode at N bps]:bps:' \
    '--vad[voice activity detection]' \
    '--dtx[file-based discontinuous transmission]' \
    '--comp=[encoding complexity 0..10 (default 3)]:n:' \
    '--nframes=[frames per Ogg packet 1..10]:n:' \
    '--no-highpass[disable built-in high-pass filter]' \
    '--skeleton[output Ogg skeleton metadata]' \
    '*--comment=[extra comment]:text:' \
    '--author=[track author]:text:' \
    '--title=[track title]:text:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '-V[verbose (show bit-rate)]' \
    '--print-rate[print per-frame bit-rate]' \
    '--rate=[sample rate for raw input]:rate:' \
    '--stereo[raw input is stereo]' \
    '--le[raw input is little-endian]' \
    '1:input WAV or raw PCM:_files' \
    '2:output Speex (.spx):_files -g "*.spx"' \
    && ret=0

return ret
