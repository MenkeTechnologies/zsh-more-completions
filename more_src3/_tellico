#compdef tellico
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/tellico.1x.html
# Reference accessed: 2026-05-21
# Verified: upstream Ubuntu tellico(1x) manpage.
# Removed from prior file: fabricated --bibtexml, --csv, --alex, --cif,
# --export-format flags (none of these are documented in tellico(1x)); the
# only documented import flags are --bibtex, --mods, --ris.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[base file name of desktop entry]:file:_files' \
  '--nofile[do not reopen the last open file]' \
  '--bibtex[import filename as a bibtex file]' \
  '--mods[import filename as a MODS file]' \
  '--ris[import filename as a RIS file]' \
  '*:collection or import file:_files' && ret=0

return ret
