#compdef hackrf_sweep
# Documentation: https://github.com/greatscottgadgets/hackrf/blob/master/host/hackrf-tools/src/hackrf_sweep.c
# Reference accessed: 2026-05-27
# Verified: upstream usage() function and getopt string in hackrf_sweep.c

# Zsh completion for hackrf_sweep (HackRF spectrum sweep mode)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show this help]' \
  '-d+[serial number of desired HackRF]:serial:' \
  '-a+[RX RF amplifier (1=enable, 0=disable)]:amp_enable:(0 1)' \
  '-f+[minimum and maximum frequencies in MHz]:freq_min\:freq_max:' \
  '-p+[antenna port power (1=enable, 0=disable)]:antenna_enable:(0 1)' \
  '-l+[RX LNA (IF) gain, 0-40dB in 8dB steps]:gain_db:' \
  '-g+[RX VGA (baseband) gain, 0-62dB in 2dB steps]:gain_db:' \
  '-w+[FFT bin width (frequency resolution) in Hz, 2445-5000000]:bin_width:' \
  '-W+[use FFTW wisdom file (created if necessary)]:wisdom_file:_files' \
  '-P+[FFTW plan type]:plan:(estimate measure patient exhaustive)' \
  '-1[one shot mode]' \
  '-N+[number of sweeps to perform]:num_sweeps:' \
  '-B[binary output]' \
  '-I[binary inverse FFT output]' \
  '-n[keep the same timestamp within a sweep]' \
  '-r+[output file]:filename:_files' && ret=0

return ret
