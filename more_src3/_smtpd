#compdef smtpd
# _smtpd — OpenSMTPD (OpenBSD project's SMTP server daemon; secure, simple alternative to sendmail/postfix; configured via smtpd.conf)
# upstream: https://github.com/OpenSMTPD/OpenSMTPD
# Flags from usr.sbin/smtpd/smtpd.c getopt + smtpd.8 on tip.

_smtpd() {
    _arguments \
        '(- *)-h[show version and usage]' \
        '*-D+[define macro=value (overrides smtpd.conf)]:macro=value:' \
        '-d[do not daemonize (log to stderr)]' \
        '-F[do not daemonize (log to syslog)]' \
        '-f+[config file]:file:_files' \
        '-n[configtest mode (validate config and exit)]' \
        '*-P+[pause subsystem at startup]:subsystem:(mda mta smtp)' \
        '*-T+[real-time trace]:trace:(imsg io smtp filters transfer bounce scheduler expand lookup stat rules mproc all)' \
        '*-v[verbose (repeat for more)]' \
        '-x+[backend-specific test path]:path:_files'
}

_smtpd "$@"
