#compdef kubearmor-controller
# _kubearmor-controller — KubeArmor admission/annotation controller (kubearmor/KubeArmor)
# upstream: https://github.com/kubearmor/KubeArmor
# Flags from pkg/KubeArmorController/cmd/main.go on tip.

_kubearmor-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind address]:host\:port:' \
        '--health-probe-bind-address=[health probe bind address]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--metrics-secure=[serve metrics over HTTPS]:bool:(true false)' \
        '--enable-http2=[enable HTTP/2 on webhook/metrics]:bool:(true false)' \
        '--annotateExisting=[annotate existing pods on startup]:bool:(true false)' \
        '--webhook-port=[webhook server port]:port:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kubearmor-controller "$@"
