#compdef salt
# _salt — SaltStack salt (issue execution-module commands from master to targeted minions; first positional is the target expression (matched per --pcre/--list/--grain/--compound/--nodegroup), second is the function name, rest are positional kwargs)
# upstream: https://github.com/saltstack/salt (salt/cli/salt.py)
# Flags from salt cli/salt.py on tip.

_salt() {
    _arguments \
        '--version[show version]' \
        '-h[show help]' \
        '--help[show help]' \
        '-c+[config dir]:dir:_files -/' \
        '-t+[timeout seconds]:seconds:' \
        '-T[show timings]' \
        '--async[fire and forget]' \
        '--summary[print result summary]' \
        '-v[verbose]' \
        '-b+[batch size]:size:' \
        '--batch-size+[batch size]:size:' \
        '-l+[log level]:level:(all garbage trace debug profile info warning error critical quiet)' \
        '--log-file+[log file]:file:_files' \
        '-E[treat target as PCRE regex]' \
        '-L[treat target as comma list]' \
        '-G[treat target as grain]' \
        '-P[treat target as grain PCRE]' \
        '-N[treat target as nodegroup]' \
        '-R[treat target as range expression]' \
        '-C[treat target as compound]' \
        '-I[treat target as pillar]' \
        '-J[treat target as pillar PCRE]' \
        '-S[treat target as ipcidr]' \
        '--output+[output format]:format:(yaml json raw nested key pprint highstate progress newline_values_only no_return overstatestage table txt virt_query)' \
        '--out-indent+[indent level]:n:' \
        '--out-file+[file]:file:_files' \
        '--no-color[disable colors]' \
        '1:target:' \
        '2:function:' \
        '*::arg:'
}

_salt "$@"
