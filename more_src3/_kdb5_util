#compdef kdb5_util
# _kdb5_util — MIT Kerberos kdb5_util Kerberos database utility CLI (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_kdb5_util() {
    local -a sub=(
        'create:create KDC database'
        'destroy:destroy KDC database'
        'stash:store master key'
        'dump:dump KDC database'
        'load:load KDC database'
        'ark:add random key'
        'add_mkey:add a master key'
        'use_mkey:use a master key'
        'list_mkeys:list master keys'
        'update_princ_encryption:update principal encryption'
        'purge_mkeys:purge old master keys'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d+[database name]:file:_files' \
        '-k+[key type]:str:' \
        '-M+[master key name]:str:' \
        '-mkey_convert[convert master key]' \
        '-new_mkey_file+[file]:file:_files' \
        '-P+[master password]:str:' \
        '-r+[realm]:str:' \
        '-sf+[stash file]:file:_files' \
        '-x+[db args]:str:' \
        '-m[read master key from kbd]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kdb5_util subcommand' sub ;;
        args)
            case $words[1] in
                dump) _arguments \
                    '-old[old format]' \
                    '-b6[krb5 1.6 format]' \
                    '-b7[krb5 1.7 format]' \
                    '-ov[ovsec format]' \
                    '-r13[recursive 1.3 format]' \
                    '-r18[recursive 1.8 format]' \
                    '-verbose[verbose]' \
                    '-mkey_convert[convert mkey]' \
                    '-new_mkey_file+[file]:file:_files' \
                    '-rev[reverse]' \
                    '-recurse[recurse]' \
                    '-svrmode+[mode]:str:' \
                    '1:file:_files' ;;
                load) _arguments \
                    '-old[old format]' \
                    '-b6[1.6 format]' \
                    '-b7[1.7 format]' \
                    '-ov[ovsec format]' \
                    '-verbose[verbose]' \
                    '-update[update]' \
                    '-hash[use hash]' \
                    '1:file:_files' ;;
                create) _arguments \
                    '-s[create stash]' \
                    '-W[wait for entropy]' ;;
            esac
            ;;
    esac
}

_kdb5_util "$@"
