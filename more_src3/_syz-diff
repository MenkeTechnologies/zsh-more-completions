#compdef syz-diff
# _syz-diff — A/B differential syzkaller fuzzing (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-diff/diff.go (flag).

_syz-diff() {
    _arguments \
        '-base=[base config]:file:_files -g "*.cfg"' \
        '-new=[new config (treated as primary)]:file:_files -g "*.cfg"' \
        '-debug[dump all VM output to console]' \
        '-patch=[git patch to apply between configs]:file:_files -g "*.(patch|diff)"'
}

_syz-diff "$@"
