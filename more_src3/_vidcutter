#compdef vidcutter
# Documentation: https://github.com/ozmartian/vidcutter
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# README documents --debug, --dev, -v/--version, -h/--help and optional
# positional argument (video or .vcp project file).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--debug[enable debug mode with verbose console output and logging]' \
  '--dev[developer mode (disable compiled resource files)]' \
  '*:video or project:_files -g "*.{mp4,m4v,mov,avi,mkv,mpg,mpeg,vob,webm,flv,wmv,3gp,ts,vcp}"' && ret=0

return ret
