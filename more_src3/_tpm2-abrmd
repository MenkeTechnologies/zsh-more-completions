#compdef tpm2-abrmd
# _tpm2-abrmd — tpm2-software tpm2-abrmd TPM2 access broker and resource manager daemon proxying TCTI device handles to multiple client applications over D-Bus with session/transient-object isolation (tpm2-software team, C); GOption
# upstream: https://github.com/tpm2-software/tpm2-abrmd

_tpm2-abrmd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-l+[logger]:l:(stdout syslog journald)' \
        '--logger=+[logger]:l:(stdout syslog journald)' \
        '-d[disable session]' \
        '--disable-dbus-stop[disable dbus stop]' \
        '-g[print gdbus addr]' \
        '--print-gdbus-address[print gdbus addr]' \
        '-t+[tcti]:t:(device mssim swtpm libtpms tabrmd)' \
        '--tcti=+[tcti]:t:(device mssim swtpm libtpms tabrmd)' \
        '--tcti-conf=+[conf]:str:' \
        '--allow-root[allow root]' \
        '--dbus-name=+[name]:str:' \
        '--dbus-bus=+[bus]:b:(session system)' \
        '--max-transients=+[N]:n:' \
        '--max-sessions=+[N]:n:' \
        '--max-connections=+[N]:n:' \
        '--flush-all[flush all on startup]' \
        '--syslog-facility=+[f]:f:(daemon authpriv user local0 local1 local2 local3 local4 local5 local6 local7)' \
        '--system[system bus]' \
        '--session[session bus]' \
        '--no-daemon[no daemonize]' \
        '-D[no daemonize]' \
        '--journal-log-level=+[N]:n:(0 1 2 3 4 5 6 7)' \
        '--prng-seed-file=+[file]:file:_files'
}

_tpm2-abrmd "$@"
