#compdef weston-info wayland-info
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/wayland-info.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. weston-info was renamed
# to wayland-info (wayland-utils package).

# wayland-info: list Wayland compositor info
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --interface)'{-i,--interface=}'[filter globals by interface substring]:interface:' && ret=0
return ret
