_hvm() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show HVM version]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'run:interpret a file (using pure Rust interpreter)'
        'run-c:interpret a file (using compiled C runtime)'
        'run-cu:interpret a file (using CUDA GPU runtime)'
        'gen-c:compile a file to standalone C source'
        'gen-cu:compile a file to standalone CUDA source'
      )
      _describe -t subcommands 'hvm subcommand' subcmds
      ;;
    args)
      case "${words[1]}" in
        run)
          _arguments -s -S \
            ':file:_files -g "*.(hvm|hvm2)"'
          ;;
        run-c|run-cu|gen-c|gen-cu)
          _arguments -s -S \
            '--io[enable IO operations (file I/O, network)]' \
            ':file:_files -g "*.(hvm|hvm2)"'
          ;;
      esac
      ;;
  esac
}

_hvm "$@"
