#compdef snapper-cleanup
# Documentation: https://manpages.debian.org/testing/snapper/snapper.8.en.html
# Reference accessed: 2026-05-21
# Verified: upstream snapper(8) man page at the URL above (cleanup subcommand).

# snapper-cleanup: periodic cleanup wrapper around `snapper cleanup` (systemd timer)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--path=[cleanup all configs affecting path (btrfs)]:dir:_files -/' \
  '--free-space=[try to make free-space available (btrfs)]:bytes:' \
  '*:cleanup algorithm:(number timeline empty-pre-post all)' && ret=0
return ret
