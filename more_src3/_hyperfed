#compdef hyperfed
# _hyperfed — KubeFed all-in-one binary that morphs into controller-manager / webhook / kubefedctl based on argv[0] or the first positional
# upstream: https://github.com/kubernetes-sigs/kubefed
# Subcommands from cmd/hyperfed/main.go on tip; each subcommand shells through to the corresponding standalone binary's cobra command.

_hyperfed() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'controller-manager':'morph into kubefed-controller-manager'
                webhook:'morph into kubefed-webhook'
                kubefedctl:'morph into kubefedctl'
            )
            _describe -t commands 'hyperfed mode' subs
            ;;
    esac
}

_hyperfed "$@"
