#compdef snpEff snpeff SnpEff SnpSift snpsift
# _snpeff — Pablo Cingolani SnpEff genetic variant annotation and effect prediction toolbox with companion SnpSift (pcingola team, Java); custom argparse
# upstream: https://github.com/pcingola/SnpEff

_snpeff() {
    local -a sub=(
        'ann:annotate variants in VCF'
        'eff:annotate variants legacy'
        'build:build database'
        'cds:show CDS sequences'
        'closest:find closest gene'
        'count:count features by region'
        'databases:list available databases'
        'download:download a database'
        'dump:dump database to text'
        'genes2bed:convert gene names to BED'
        'len:report transcript length stats'
        'pdb:annotate by PDB structures'
        'protein:check protein translation'
        'seq:print sequence'
        'show:show database info'
        'translocations:detect translocations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-debug[debug]' \
        '-c+[config file]:file:_files -g "*.config snpEff.config"' \
        '-csvStats+[csv stats file]:file:_files -g "*.csv"' \
        '-stats+[stats file]:file:_files -g "*.html"' \
        '-canon[canonical transcripts only]' \
        '-cancer[cancer mode]' \
        '-cancerSamples+[samples file]:file:_files' \
        '-fastaProt+[fasta proteins]:file:_files -g "*.fa *.fasta"' \
        '-formatEff[old effect format]' \
        '-fi+[filter intervals BED]:file:_files -g "*.bed *.bedgraph"' \
        '-fileList[input is list of VCFs]' \
        '-i+[input format]:f:(vcf bed txt)' \
        '-o+[output format]:f:(vcf gatk bed bedAnn)' \
        '-spliceSiteSize+[N]:n:' \
        '-spliceRegionExonSize+[N]:n:' \
        '-spliceRegionIntronMin+[N]:n:' \
        '-spliceRegionIntronMax+[N]:n:' \
        '-no-downstream[no downstream effects]' \
        '-no-upstream[no upstream effects]' \
        '-no-intergenic[no intergenic effects]' \
        '-no-intron[no intron effects]' \
        '-no-utr[no UTR effects]' \
        '-no+[disable effect types]:str:' \
        '-onlyReg[only regulatory effects]' \
        '-onlyTr+[transcripts file]:file:_files' \
        '-treatAllAsProteinCoding[all biotypes as protein coding]' \
        '-ud+[upstream/downstream length]:n:' \
        '-strict[strict mode]' \
        '-classic[classic format]' \
        '-formatEff[old EFF format]' \
        '-hgvs[use HGVS annotation]' \
        '-noHgvs[no HGVS]' \
        '-hgvs1LetterAa[1-letter amino acids]' \
        '-hgvsTrId[transcript IDs in HGVS]' \
        '-lof[Loss-of-Function]' \
        '-noLof[no LoF]' \
        '-motif[motif analysis]' \
        '-noMotif[no motif analysis]' \
        '-csvStats+[csv stats file]:file:_files' \
        '-nextProt[NextProt annotations]' \
        '-noNextProt[no NextProt]' \
        '-noStats[no stats]' \
        '-noLog[no log]' \
        '-interval+[bed file]:file:_files -g "*.bed"' \
        '-t+[threads]:n:' \
        '-d[debug mode]' \
        '-noShiftHgvs[no HGVS shifting]' \
        '*:database VCF:'
}

_snpeff "$@"
