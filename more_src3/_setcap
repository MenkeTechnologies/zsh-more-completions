#compdef setcap
# Documentation: man setcap(8)
# Source: kernel.org libcap progs/setcap.c — set file capabilities (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--license[display license info]' \
    '-f[force setting even when capability is invalid]' \
    '-h[show help]' \
    '-n+[user namespace rootid (!=0)]:rootid:_default' \
    '-q[quiet]' \
    '-v[validate supplied capability matches file]' \
    '-r[remove capability from file]' \
    '*:caps-or-file:_files' \
    && ret=0

return ret
