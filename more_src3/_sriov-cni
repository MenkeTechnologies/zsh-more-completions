#compdef sriov-cni
# Documentation: https://github.com/k8snetworkplumbingwg/sriov-cni
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. sriov-cni is a CNI
# plugin invoked by kubelet via stdin JSON conforming to the CNI spec;
# it has no user-facing CLI flags. All config (vlan, vlanQoS, vlanProto,
# spoofchk, trust, link_state, min_tx_rate, max_tx_rate, mac) lives in
# NetworkAttachmentDefinition JSON.
# Removed from prior file: fabricated --config-file/--multus-* flags
# (those belong to the multus plugin, not sriov-cni) and bogus
# man.archlinux.org search URL.

# sriov-cni: SR-IOV CNI plugin (stdin JSON, no CLI flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  ':no CLI flags (CNI stdin JSON plugin):' && ret=0
return ret
