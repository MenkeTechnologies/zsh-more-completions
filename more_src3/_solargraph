#compdef solargraph
# Documentation: https://github.com/castwide/solargraph/blob/master/lib/solargraph/shell.rb
# Reference accessed: 2026-05-21
# Verified: upstream lib/solargraph/shell.rb subcommand definitions.
# Removed from prior file: fabricated `bundle` subcommand (real
# command is `gems`). Added verified `gems`, `cache`, `uncache`,
# `version`, `list`, `pin`, `profile` subcommands.

# Zsh completion for solargraph (Ruby language server and linter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'version:print the version'
      'socket:run a Solargraph socket server'
      'stdio:run a Solargraph stdio server'
      'config:create or overwrite a default config file'
      'clear:delete all cached documentation'
      'cache:cache a gem'
      'uncache:delete specific cached gem documentation'
      'gems:cache documentation for installed libraries'
      'reporters:list diagnostics reporters'
      'typecheck:run the type checker'
      'scan:test the workspace for problems'
      'list:list the files in the workspace and the total count'
      'pin:describe a pin'
      'profile:profile go-to-definition performance using vernier'
      'download-core:download Ruby core documentation'
    )
    _describe -t commands 'solargraph command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (config)
        _arguments \
          '1:action:(create check)' && ret=0
        ;;
      (socket)
        _arguments \
          '--host[listen host]:host' \
          '--port[listen port]:port' && ret=0
        ;;
      (scan)
        _arguments \
          '--directory[workspace directory]:directory:_files -/' \
          '*:file:_files -g "*.rb"' && ret=0
        ;;
      (typecheck)
        _arguments \
          '--directory[workspace directory]:directory:_files -/' \
          '--level[type checking level]:level:(typed strict strong)' \
          '*:file:_files -g "*.rb"' && ret=0
        ;;
      (cache|uncache)
        _arguments \
          '*:gem name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
