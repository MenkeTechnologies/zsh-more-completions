#compdef smbutil
# Documentation: macOS man smbutil(1)
# Source: Apple macOS smbutil — SMB requester interface (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '-h[show help]' \
    '-v[verbose output]' \
    '1:command:(help lookup status view identity dfs)' \
    '*::command args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            lookup)
                _arguments '-w+[NetBIOS name server]:host:_hosts' \
                           '-t+[NetBIOS node type]:type:_default' \
                           '-e[unpercent-escape output]' \
                           '1:NetBIOS name:_default' ;;
            status)
                _arguments '-a[show all NetBIOS names]' '-e[percent-escape output]' '1:hostname:_hosts' ;;
            view|identity|dfs)
                _arguments '-N[no password prompt]' \
                           '1:URL "//user@server/share":_default' ;;
            help)
                _arguments '1:command:(lookup status view identity dfs)' ;;
        esac
        ;;
esac

return ret
