#compdef tailscaled
# Documentation: https://tailscale.com/kb/1278/tailscaled
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-cleanup[clean up system state and exit]' \
  '-debug=[run debug HTTP server on host:port]:address:' \
  '-outbound-http-proxy-listen=[run outbound HTTP proxy on host:port]:address:' \
  '-port=[UDP port for peer-to-peer traffic (0 for auto)]:port:' \
  '-socks5-server=[run SOCKS5 proxy on host:port]:address:' \
  '-state=[state backend (file, mem:, kube:, aws-ssm:, ...)]:state:' \
  '-statedir=[directory for state, keys and config]:directory:_files -/' \
  '-tun=[tunnel interface name or userspace-networking]:interface:(userspace-networking tailscale0)' \
  '-verbose=[log verbosity level]:level:(0 1 2)' \
  '-encrypt-state[encrypt state with local TPM (Linux)]' \
  '-no-logs-no-support[disable log uploads, give up support]' \
  '-version[show version and exit]' && ret=0

return ret
