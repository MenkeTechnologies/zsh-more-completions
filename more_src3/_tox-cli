#compdef tox-cli
# _tox-cli — tox automation for Python testing CLI alias (tox-dev / Holger Krekel, Python); argparse
# upstream: https://github.com/tox-dev/tox

_tox-cli() {
    local -a sub=(
        'run:run env (default)'
        'r:run env (alias)'
        'run-parallel:run envs in parallel'
        'p:run envs in parallel (alias)'
        'config:show effective configuration'
        'c:show effective configuration (alias)'
        'list:list envs'
        'l:list envs (alias)'
        'devenv:create development env'
        'd:create development env (alias)'
        'depends:show dependency graph'
        'q:quickstart wizard'
        'quickstart:quickstart wizard'
        'legacy:legacy command-line'
        'le:legacy command-line (alias)'
        'exec:run env commands'
        'e:run env commands (alias)'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "tox.ini setup.cfg pyproject.toml *.toml"' \
        '--config-file=+[config file]:file:_files -g "tox.ini setup.cfg pyproject.toml *.toml"' \
        '-e+[environment list]:list:' \
        '--env=+[environment list]:list:' \
        '-x+[override key=value]:list:' \
        '--override=+[override key=value]:list:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--colored=+[colored output]:c:(no yes always)' \
        '--workdir=+[work dir]:dir:_files -/' \
        '-w+[work dir]:dir:_files -/' \
        '--root-dir=+[root dir]:dir:_files -/' \
        '-r+[root dir]:dir:_files -/' \
        '--installpkg=+[install pkg]:file:_files' \
        '-i+[installpkg]:file:_files' \
        '--develop[install in dev mode]' \
        '--no-list-dependencies[no list dependencies]' \
        '--parallel=+[parallel envs]:n:' \
        '-p+[parallel envs]:n:' \
        '--parallel-live[live parallel output]' \
        '--parallel-no-spinner[no spinner]' \
        '--skip-pkg-install[skip package install]' \
        '--no-recreate-pkg[no recreate pkg]' \
        '--result-json=+[result json file]:file:_files' \
        '--discover=+[discover python]:list:' \
        '--list-default[list default envs]' \
        '-l[list default envs]' \
        '--list-envs[list envs]' \
        '-la[list all envs]' \
        '--list-envs-all[list all envs]' \
        '--showconfig[show effective config]' \
        '--exit-and-dump-after=+[exit and dump after seconds]:n:' \
        '--current[set current command]:' \
        '--force-dep=+[force dep]:list:' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'tox subcommand' sub ;;
        args)
            case $words[1] in
                run|r|run-parallel|p|exec|e) _arguments \
                    '--recreate[recreate env]' \
                    '--no-recreate[no recreate env]' \
                    '--skip-missing-interpreters=+[skip missing interpreters]:b:(true false)' \
                    '-s+[skip missing interpreters]:b:(true false)' \
                    '--installpkg=+[install pkg]:file:_files' \
                    '-i+[installpkg]:file:_files' \
                    '--develop[dev mode]' \
                    '*:posargs:' ;;
                devenv|d) _arguments '*:dir:_files -/' ;;
                config|c) _arguments \
                    '-k+[key]:list:' \
                    '*:arg:' ;;
                list|l) _arguments \
                    '--default[default envs]' \
                    '--no-desc[no description]' ;;
                quickstart|q) _arguments '*:dir:_files -/' ;;
                depends) _arguments '*:env:' ;;
            esac
            ;;
    esac
}

_tox-cli "$@"
