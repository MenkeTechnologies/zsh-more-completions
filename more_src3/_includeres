#compdef includeres
# Documentation: includeres (psutils Perl script)
# Source: include resources (fonts/files/procsets) referenced by %%IncludeResource comments.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:ps file:_files -g "*.ps"' \
    && ret=0

return ret
