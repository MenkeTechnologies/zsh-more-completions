#compdef testbench sof-testbench
# _testbench — Sound Open Firmware host-side topology testbench (thesofproject/sof)
# upstream: https://github.com/thesofproject/sof
# Flags from tools/testbench/testbench.c (getopt).

_testbench() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-i+[input raw audio file]:file:_files'
        '-o+[output file(s), comma-separated]:files:'
        '-t+[topology file]:file:_files -g "*.tplg"'
        '-d+[trace print level]:level:(0 1 2 3 4)'
        '-p+[pipeline IDs to run (comma-separated)]:pipelines:'
        '-C+[number of copy() iterations]:n:'
        '-P+[number of dynamic-pipeline iterations]:n:'
        '-s+[control-script file (amixer+sleep)]:file:_files'
        '-b+[input sample format]:fmt:(S16_LE S24_LE S32_LE)'
        '-c+[input channels]:n:'
        '-n+[output channels]:n:'
        '-r+[input sample rate]:rate:'
        '-R+[output sample rate]:rate:'
    )
    _arguments -s $args
}

_testbench "$@"
