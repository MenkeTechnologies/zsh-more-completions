#compdef trubudget trubudget-cli
# _trubudget — KfW Bankengruppe TruBudget aid-projects financial-coordination platform CLI on top of MultiChain (openkfw team, TypeScript/Node.js); commander
# upstream: https://github.com/openkfw/TruBudget

_trubudget() {
    local -a sub=(
        'login:authenticate against API'
        'logout:clear credentials'
        'project:project subcommands'
        'subproject:subproject subcommands'
        'workflowitem:workflow item subcommands'
        'user:user subcommands'
        'group:group subcommands'
        'permission:permission subcommands'
        'notification:notification subcommands'
        'document:document subcommands'
        'config:configuration subcommands'
        'audit:audit log subcommands'
        'backup:backup MultiChain'
        'restore:restore MultiChain'
        'global:global permissions'
        'version:show version'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--api-url=+[api url]:url:_urls' \
        '-u+[api url]:url:_urls' \
        '--user=+[user]:user:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--token=+[bearer token]:str:' \
        '--organization=+[org name]:str:' \
        '--ca=+[ca cert]:file:_files' \
        '--insecure[skip tls verify]' \
        '-k[skip tls verify]' \
        '--output=+[format]:f:(json yaml text table)' \
        '-o+[format]:f:(json yaml text table)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'trubudget subcommand' sub ;;
        args)
            case $words[1] in
                project|subproject|workflowitem) _arguments '1:cmd:(create list show update close assign permission-grant permission-revoke)' ;;
                user|group) _arguments '1:cmd:(create list show update delete)' ;;
                permission) _arguments '1:permission cmd:(grant revoke list)' ;;
                notification) _arguments '1:notification cmd:(list mark-read mark-unread count)' ;;
                document) _arguments '1:document cmd:(upload download validate delete)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_trubudget "$@"
