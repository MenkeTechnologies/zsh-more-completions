#compdef sqld
# Documentation: https://github.com/tursodatabase/libsql/tree/main/libsql-server
# Reference accessed: 2026-05-21
# Verified: libsql-server/src/main.rs (Cli clap struct).
# Removed: --http-listen, --grpc-listen, --jwt-key-file, --enable-console
# (real names: --http-listen-addr, --grpc-listen-addr, --auth-jwt-key-file,
# --enable-http-console).

_arguments -s -S \
  '(-d --db-path)'{-d+,--db-path=}'[SQLite database path (default data.sqld)]:path:_files -/' \
  '(-e --extensions-path)'{-e+,--extensions-path=}'[directory of SQLite extensions]:dir:_files -/' \
  '--http-listen-addr=[HTTP API listen addr (default 127.0.0.1:8080)]:addr:' \
  '--enable-http-console[enable interactive web console]' \
  '(-l --hrana-listen-addr)'{-l+,--hrana-listen-addr=}'[Hrana listen addr]:addr:' \
  '--admin-listen-addr=[admin API listen addr]:addr:' \
  '--auth-jwt-key-file=[file with key used to sign auth tokens]:file:_files' \
  '--http-auth=[HTTP auth string]:auth:' \
  '--http-self-url=[self URL of this server]:url:' \
  '--http-primary-url=[primary server URL (replica mode)]:url:' \
  '--grpc-listen-addr=[gRPC listen addr]:addr:' \
  '--grpc-tls[enable TLS on gRPC server]' \
  '--grpc-cert-file=[gRPC TLS cert]:file:_files' \
  '--grpc-key-file=[gRPC TLS key]:file:_files' \
  '--grpc-ca-cert-file=[gRPC TLS CA cert]:file:_files' \
  '--primary-grpc-url=[primary gRPC URL (replica mode)]:url:' \
  '--primary-grpc-tls[enable TLS on primary gRPC]' \
  '--primary-grpc-cert-file=[primary gRPC TLS cert]:file:_files' \
  '--primary-grpc-key-file=[primary gRPC TLS key]:file:_files' \
  '--primary-grpc-ca-cert-file=[primary gRPC TLS CA cert]:file:_files' \
  '--no-welcome[disable welcome message]' \
  '--enable-bottomless-replication[enable bottomless S3 replication]' \
  '--idle-shutdown-timeout-s=[shutdown after this many idle seconds]:seconds:' \
  '--initial-idle-shutdown-timeout-s=[initial idle shutdown timeout]:seconds:' \
  '--max-log-size=[max log size in MB (default 200)]:MB:' \
  '--max-log-duration=[max log duration in seconds]:seconds:' \
  '--heartbeat-url=[heartbeat endpoint URL]:url:' \
  '--heartbeat-auth=[heartbeat auth]:auth:' \
  '--heartbeat-period-s=[heartbeat period in seconds (default 30)]:seconds:' \
  '--soft-heap-limit-mb=[soft SQLite heap limit in MB]:MB:' \
  '--hard-heap-limit-mb=[hard SQLite heap limit in MB]:MB:' \
  '--max-response-size=[max response size (default 10MB)]:size:' \
  '--max-total-response-size=[max total response size (default 32MB)]:size:' \
  '--snapshot-exec=[command to run on snapshot]:command:' \
  '--checkpoint-interval-s=[checkpoint interval in seconds]:seconds:' \
  '--disable-default-namespace[disable default namespace]' \
  '--enable-namespaces[enable multi-namespace mode]' \
  '--snapshot-at-shutdown[snapshot on shutdown]' \
  '--max-active-namespaces=[max active namespaces (default 100)]:n:' \
  '--encryption-key=[encryption key for at-rest encryption]:key:' \
  '--max-concurrent-connections=[max concurrent connections (default 128)]:n:' \
  '--max-concurrent-requests=[max concurrent requests (default 128)]:n:' \
  '--disable-intelligent-throttling[disable intelligent throttling]' \
  '--connection-creation-timeout-sec=[connection creation timeout in seconds]:seconds:' \
  '--shutdown-timeout=[shutdown timeout in seconds]:seconds:' \
  '--storage-server-address=[storage server address]:addr:' \
  '--disable-metrics[disable metrics]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
