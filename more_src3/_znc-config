#compdef znc-config
# Documentation: https://wiki.znc.in/Compiling_modules
# Reference accessed: 2026-05-21
# Verified: znc-config follows the standard pkg-config-style flag set.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '--prefix[install prefix]' \
  '--bindir[bin dir]' \
  '--datadir[data dir]' \
  '--moduledir[module dir]' \
  '--includedir[include dir]' \
  '--libdir[lib dir]' \
  '--modflags[module compile flags]' \
  '--ldflags[ld flags]' \
  '--cxx[cxx compiler]' \
  '--cxxflags[cxx flags]' \
  '--version[show version]' && ret=0

return ret
