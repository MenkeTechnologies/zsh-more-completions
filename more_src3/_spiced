#compdef spiced
# Documentation: https://spiceai.org/docs
# Reference accessed: 2026-05-27
# Verified: upstream clap Args struct in bin/spiced/src/lib.rs plus flattened runtime::config::Config (crates/runtime/src/config.rs) and repl::ReplConfig (crates/repl/src/lib.rs)

# Zsh completion for spiced (Spice.ai runtime daemon)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--http=[HTTP API bind address]:bind_address:' \
  '--flight=[Arrow Flight bind address]:bind_address:' \
  '--metrics=[Prometheus metrics bind address]:bind_address:' \
  '--open_telemetry=[OpenTelemetry collector bind address]:bind_address:' \
  '--version[print version and exit]' \
  '--repl[start the SQL REPL instead of the runtime]' \
  '--tls_enabled=[enable TLS for HTTP and Flight endpoints]:bool:(true false)' \
  '--tls_certificate=[inline PEM TLS server certificate]:pem:' \
  '--tls_certificate_file=[PEM TLS server certificate file]:file:_files' \
  '--tls_key=[inline PEM TLS server private key]:pem:' \
  '--tls_key_file=[PEM TLS server private key file]:file:_files' \
  '--tls_client_auth_ca_file=[PEM CA file used to verify clients]:file:_files' \
  '--tls_client_auth_ca=[inline PEM CA used to verify clients]:pem:' \
  '--tls_client_auth_mode=[client TLS auth mode]:mode:(disabled optional required)' \
  '--telemetry_enabled[enable runtime telemetry]' \
  '--pods_watcher_enabled[enable the spicepod file watcher]' \
  '*'{-v,--verbose}'[increase log verbosity (repeatable)]' \
  '--very_verbose[enable very verbose logging]' \
  '*--set=[override a runtime config value (KEY=VALUE)]:KEY=VALUE:' \
  '--role=[cluster node role]:role:' \
  '--node-bind-address=[cluster node bind address]:bind_address:' \
  '--node-mtls-ca-certificate-file=[cluster node mTLS CA certificate file]:file:_files' \
  '--node-mtls-certificate-file=[cluster node mTLS certificate file]:file:_files' \
  '--node-mtls-key-file=[cluster node mTLS key file]:file:_files' \
  '--allow-insecure-connections[allow cluster connections without mTLS]' \
  '--scheduler-address=[cluster scheduler address]:address:' \
  '--node-advertise-address=[cluster node advertise address]:address:' \
  '--repl_flight_endpoint=[Flight endpoint used by the SQL REPL]:url:' \
  '--http_endpoint=[HTTP endpoint used by the SQL REPL]:url:' \
  '--tls_root_certificate_file=[REPL TLS root certificate file]:file:_files' \
  '--client_tls_certificate_file=[REPL client TLS certificate file]:file:_files' \
  '--client_tls_key_file=[REPL client TLS key file]:file:_files' \
  '--api_key=[REPL API key]:key:' \
  '--user_agent=[REPL HTTP user-agent]:agent:' \
  '--cache_control=[REPL cache control]:value:(cache no-cache)' \
  '*--headers=[REPL custom HTTP header]:KEY\:VALUE:' \
  '(-x --expanded)'{-x,--expanded}'[REPL expanded vertical output]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '*:spicepod path:_files -/' && ret=0

return ret
