#compdef liftbridge
# Documentation: https://github.com/liftbridge-io/liftbridge/blob/master/documentation/configuration.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# liftbridge: Liftbridge server (streaming on NATS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[load YAML config file]:file:_files' \
  '(--server-id --id)'{--server-id=,--id=}'[server id in cluster]:id:' \
  '(--namespace --ns)'{--namespace=,--ns=}'[cluster namespace]:namespace:' \
  '(-n --nats-servers)'{-n+,--nats-servers=}'[NATS server addresses]:addrs:' \
  '(-e --embedded-nats)'{-e,--embedded-nats}'[run embedded NATS server]' \
  '(--embedded-nats-config --nc)'{--embedded-nats-config=,--nc=}'[embedded NATS config file]:file:_files' \
  '(-d --data-dir)'{-d+,--data-dir=}'[data storage directory]:dir:_files -/' \
  '(-p --port)'{-p+,--port=}'[server port]:port:' \
  '--tls-cert=[server certificate file]:file:_files' \
  '--tls-key=[server private key file]:file:_files' \
  '(-l --level)'{-l+,--level=}'[log level]:level:(debug info warn error)' \
  '--raft-bootstrap-seed[bootstrap Raft cluster as self-elected leader]' \
  '--raft-bootstrap-peers=[bootstrap with specified peer IDs]:peers:' && ret=0
return ret
