#compdef slides
# Documentation: https://github.com/maaslalani/slides
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'serve:host slides over SSH'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  '1: :->cmd_or_file' \
  '*::arg:->args' && ret=0

case $state in
  (cmd_or_file)
    _alternative \
      'commands:command:_describe -t commands command commands' \
      'files:slides file:_files -g "*.md"' && ret=0
    ;;
  (args)
    case ${words[1]} in
      serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[display help]' \
          '1:slides file:_files -g "*.md"' && ret=0
        ;;
    esac
    ;;
esac

return ret
