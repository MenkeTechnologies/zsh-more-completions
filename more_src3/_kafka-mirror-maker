#compdef kafka-mirror-maker
# Documentation: https://github.com/apache/kafka/blob/3.9/core/src/main/scala/kafka/tools/MirrorMaker.scala
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# NOTE: kafka-mirror-maker.sh (MirrorMaker 1.0) was removed in Apache Kafka 4.0
# (KIP-720, apache/kafka PR #16879). It is replaced by connect-mirror-maker.sh
# (MirrorMaker 2.0). These options are the verified legacy MM1 options for
# users still on Kafka 3.x. Removed invented flags --blacklist/--exclude and
# the bogus 'kafka-mirror-maker-2' compdef alias; corrected --rebalance.listener
# to the real --consumer.rebalance.listener.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--consumer.config=[Embedded consumer config for consuming from the source cluster]:file:_files -g "*.properties"' \
  '--producer.config=[Embedded producer config]:file:_files -g "*.properties"' \
  '--num.streams=[Number of consumption streams]:n:' \
  '--whitelist=[DEPRECATED, use --include instead; list of included topics to mirror]:regex:' \
  '--include=[List of included topics to mirror]:regex:' \
  '--offset.commit.interval.ms=[Offset commit interval in ms]:ms:' \
  '--consumer.rebalance.listener=[The consumer rebalance listener to use]:class:' \
  '--rebalance.listener.args=[Arguments used by custom rebalance listener]:args:' \
  '--message.handler=[Message handler to process every record]:class:' \
  '--message.handler.args=[Arguments used by custom message handler]:args:' \
  '--abort.on.send.failure=[Configure the mirror maker to exit on a failed send]:flag:(true false)' \
  '--new.consumer[DEPRECATED Use new consumer in mirror maker (default)]' && ret=0

return ret
