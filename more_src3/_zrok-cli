#compdef zrok-cli
# _zrok-cli — OpenZiti zrok next-generation sharing platform CLI alias (openziti team, Go); cobra
# upstream: https://github.com/openziti/zrok

_zrok-cli() {
    local -a sub=(
        'access:access services'
        'access private:access private share'
        'admin:admin commands'
        'admin bootstrap:bootstrap controller'
        'admin create account:create account'
        'admin create frontend:create frontend'
        'admin delete account:delete account'
        'admin delete frontend:delete frontend'
        'admin gc:run garbage collection'
        'admin list frontends:list frontends'
        'admin list accounts:list accounts'
        'admin rotate share:rotate share'
        'config:config management'
        'config set:set config'
        'config unset:unset config'
        'config get:get config'
        'controller:start controller'
        'copy:copy from URL to local'
        'disable:disable environment'
        'enable:enable environment'
        'frontend:start frontend'
        'invite:request invite token'
        'modify:modify share'
        'modify share:modify share'
        'modify reserved:modify reserved share'
        'overview:show overview'
        'reserve:reserve share'
        'release:release reserved share'
        'share:share a service'
        'share private:share private'
        'share public:share public'
        'share reserved:share reserved'
        'status:show status'
        'test:test commands'
        'test endpoint:test endpoint'
        'test loop:test loop'
        'version:show version'
        'verify:verify control plane'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--panic[panic on error]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zrok subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                share:public|share:private) _arguments \
                    '--backend-mode=+[mode]:m:(proxy web caddy drive socks vpn)' \
                    '--basic-auth=+[user:pass]:str:' \
                    '--frontends=+[frontends]:str:' \
                    '--headless[headless]' \
                    '--insecure[insecure]' \
                    '--oauth-check-interval=+[duration]:str:' \
                    '--oauth-email-domains=+[domains]:str:' \
                    '--oauth-provider=+[provider]:p:(github google)' \
                    '*:target:' ;;
            esac
            ;;
    esac
}

_zrok-cli "$@"
