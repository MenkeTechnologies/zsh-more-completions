#compdef tidy
# Documentation: https://www.html-tidy.org/
# Source: htacg/tidy-html5 — HTML/XHTML/XML tidier (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-output -o)'{-output+,-o+}'[output file]:file:_files' \
    '-config+[configuration file]:file:_files' \
    '(-file -f)'{-file+,-f+}'[errors and warnings file]:file:_files' \
    '(-modify -m)'{-modify,-m}'[modify input file in place]' \
    '(-indent -i)'{-indent,-i}'[indent element content]' \
    '(-wrap -w)'{-wrap+,-w+}'[wrap at column]:column:_default' \
    '(-upper -u)'{-upper,-u}'[force tags to upper case]' \
    '(-clean -c)'{-clean,-c}'[replace FONT/NOBR/CENTER with CSS]' \
    '(-bare -b)'{-bare,-b}'[strip smart quotes / em dashes]' \
    '(-gdoc -g)'{-gdoc,-g}'[clean Google Docs export]' \
    '(-numeric -n)'{-numeric,-n}'[numeric entities]' \
    '(-errors -e)'{-errors,-e}'[only errors and warnings]' \
    '(-quiet -q)'{-quiet,-q}'[suppress non-essential output]' \
    '-omit[omit optional start/end tags]' \
    '-xml[input is well-formed XML]' \
    '(-asxml -asxhtml)'{-asxml,-asxhtml}'[convert HTML to XHTML]' \
    '-ashtml[force XHTML to HTML]' \
    '-access+[accessibility check level]:level:(0 1 2 3)' \
    '-raw[output values >127 without entity conversion]' \
    '-ascii[ISO-8859-1 in, US-ASCII out]' \
    '-latin0[ISO-8859-15 in, US-ASCII out]' \
    '-latin1[ISO-8859-1 in+out]' \
    '-iso2022[ISO-2022 in+out]' \
    '-utf8[UTF-8 in+out]' \
    '-mac[MacRoman in, US-ASCII out]' \
    '-win1252[Windows-1252 in, US-ASCII out]' \
    '-ibm858[IBM-858 in, US-ASCII out]' \
    '-utf16le[UTF-16LE in+out]' \
    '-utf16be[UTF-16BE in+out]' \
    '-utf16[UTF-16 in+out]' \
    '-big5[Big5 in+out]' \
    '-shiftjis[Shift_JIS in+out]' \
    '(-version -v)'{-version,-v}'[show version]' \
    '(-help -h -?)'{-help,-h,-\?}'[show help]' \
    '-help-config[list all configuration options]' \
    '-help-env[show environment information]' \
    '-show-config[show current configuration]' \
    '-export-config[export current config (file format)]' \
    '-export-default-config[export default config (file format)]' \
    '-help-option+[describe option]:option:_default' \
    '-language+[output language]:lang:_default' \
    '-xml-help[help in XML format]' \
    '-xml-config[all configs in XML format]' \
    '-xml-strings[all strings in XML]' \
    '-xml-error-strings[error strings in XML]' \
    '-xml-options-strings[option descriptions in XML]' \
    '*:HTML/XML files:_files -g "*.{html,htm,xhtml,xml}"' \
    && ret=0

return ret
