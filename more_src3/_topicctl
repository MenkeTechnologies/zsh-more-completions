#compdef topicctl
# Documentation: https://github.com/segmentio/topicctl
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a _topicctl_cmds
_topicctl_cmds=(
  'apply:apply topic configuration'
  'bootstrap:bootstrap apply configs from existing cluster topics'
  'check:validate topic configs against Kafka'
  'create:create immutable resources (acls)'
  'delete:delete topics or acls'
  'get:inspect cluster resources'
  'rebalance:rebalance partitions'
  'repl:interactive REPL'
  'reset-offsets:reset consumer group offsets'
  'tail:tail topic messages'
  'tester:test producer/consumer setup'
)

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '--no-spinner[disable progress spinners]' \
  '--cluster-config=[cluster config file]:file:_files' \
  '--zk-addr=[ZooKeeper address]:addr' \
  '--zk-prefix=[ZooKeeper prefix]:prefix' \
  '--broker-addr=[bootstrap broker address]:addr' \
  '--skip-confirm[skip confirmation prompts]' \
  '--expand-env[preprocess configs using environment variables]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'topicctl command' _topicctl_cmds && ret=0
    ;;
  args)
    case $line[1] in
      check)
        _arguments -s -S \
          '*:topic configs:_files' \
          '--path-prefix=[prefix for topic config paths]:prefix' \
          '--check-leaders[check partition leaders]' \
          '--validate-only[validate YAML only; no cluster contact]' \
          && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
