#compdef virt-create-rootfs
# _virt-create-rootfs — libguestfs virt-create-rootfs (build a guest root filesystem inside an empty directory or chroot tree to be used by libvirt LXC/Anaconda installs; -a disk, -c libvirt URI, --arch architecture, --distro alma/centos/debian/fedora/rhel/ubuntu, --suite suite, --root root prefix, --install pkgs, --mirror mirror URL)
# upstream: https://github.com/libguestfs/libguestfs (contrib)
# Flags from libguestfs contrib/virt-create-rootfs on tip.

_virt-create-rootfs() {
    _arguments \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-a+[disk image]:file:_files' \
        '-c+[libvirt URI]:uri:' \
        '--arch=*[arch]:arch:(x86_64 aarch64 ppc64le s390x armv7l)' \
        '--distro=*[distro]:distro:(centos rhel fedora debian ubuntu almalinux rocky opensuse)' \
        '--suite=*[suite]:suite:' \
        '--root+[root prefix]:dir:_files -/' \
        '*--install+[packages]:pkgs:' \
        '--mirror+[mirror URL]:url:' \
        '--update[update packages]' \
        '--debug[debug]'
}

_virt-create-rootfs "$@"
