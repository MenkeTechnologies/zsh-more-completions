#compdef sfwiggle
# Documentation: http://www.ahay.org/RSF/sfwiggle.html
# Source: ahay/src plot/main/wiggle.c — wiggle-trace seismic plot to vplot.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'xpos=[optional header file with trace positions]: :_files -g "*.rsf(-.)"' \
    'xmax=[max trace position (with xpos)]: :_default' \
    'xmin=[min trace position (with xpos)]: :_default' \
    'poly=[(y/n) draw polygons]: :(y n)' \
    'polyneg=[(y/n) polygons for negative values]: :(y n)' \
    'fatp=[polygon border thickness]: :_default' \
    'xmask=[polygon X-direction fill pattern]: :_default' \
    'ymask=[polygon Y-direction fill pattern]: :_default' \
    'pclip=[clip percentile]: :_default' \
    'zplot=[vertical separation scaling factor]: :_default' \
    'clip=[data clip (estimated from pclip by default)]: :_default' \
    'seemean=[(y/n) plot mean lines of traces]: :(y n)' \
    'verb=[(y/n) verbose]: :(y n)' \
    'transp=[(y/n) transpose axes]: :(y n)' \
    'yreverse=[(y/n) reverse vertical axis]: :(y n)' \
    'xreverse=[(y/n) reverse horizontal axis]: :(y n)' \
    '*:RSF file:_files -g "*.rsf(-.)"' \
    && ret=0

return ret
