#compdef snake
# Documentation: man snake(6)
# Source: openbsd/src games/snake/snake.c — display chase game (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-w+[playfield width]:cols:_default' \
    '-l+[playfield length]:rows:_default' \
    '-s[print top scores and exit]' \
    '-t[slow-terminal mode]' \
    && ret=0

return ret
