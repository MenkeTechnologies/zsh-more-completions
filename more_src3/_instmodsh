#compdef instmodsh
# Documentation: https://perldoc.perl.org/ExtUtils::Installed
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '-h[Show help]'
    '-m[Module name]:module:'
    '-l[List installed modules]'
    '-p[Show packlist for module]:module:'
    '-v[Validate installed module]:module:'
)

_arguments -s -S $arguments
