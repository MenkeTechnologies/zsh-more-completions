#compdef kubectl-colorize_managed_fields
# Documentation: https://github.com/tt-kuma/kubectl-colorize-managed-fields
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (pkg/cmd source).

# kubectl-colorize_managed_fields (tt-kuma/kubectl-colorize-managed-fields):
# display Kubernetes resources with fields colorized by their field manager.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(yaml json)' \
  '--no-color-description[do not print description for each field color]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '1:resource-type:_default' \
  '2:resource-name:_default'
