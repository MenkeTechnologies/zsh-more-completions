#compdef wget-cli
# _wget-cli — GNU Wget non-interactive network downloader CLI alias (GNU team, C); custom argparse
# upstream: https://www.gnu.org/software/wget/

_wget-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[run in background]' \
        '--background[run in background]' \
        '-e+[command]:str:' \
        '--execute=+[command]:str:' \
        '-o+[log file]:file:_files' \
        '--output-file=+[log file]:file:_files' \
        '-a+[append log file]:file:_files' \
        '--append-output=+[append log file]:file:_files' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-nv[non-verbose]' \
        '--no-verbose[non-verbose]' \
        '--report-speed=+[type]:t:(bits)' \
        '-i+[input file]:file:_files' \
        '--input-file=+[input file]:file:_files' \
        '-F[force HTML treatment]' \
        '--force-html[force HTML treatment]' \
        '-B+[base URL]:url:_urls' \
        '--base=+[base URL]:url:_urls' \
        '--config=+[config file]:file:_files' \
        '-t+[retry number]:n:' \
        '--tries=+[retry number]:n:' \
        '-O+[output file]:file:_files' \
        '--output-document=+[output file]:file:_files' \
        '-nc[no clobber]' \
        '--no-clobber[no clobber]' \
        '-c[continue]' \
        '--continue[continue]' \
        '--progress=+[type]:t:(bar dot)' \
        '-N[timestamping]' \
        '--timestamping[timestamping]' \
        '-S[server response]' \
        '--server-response[server response]' \
        '--spider[do not download]' \
        '-T+[seconds]:n:' \
        '--timeout=+[seconds]:n:' \
        '--dns-timeout=+[seconds]:n:' \
        '--connect-timeout=+[seconds]:n:' \
        '--read-timeout=+[seconds]:n:' \
        '-w+[wait seconds]:n:' \
        '--wait=+[wait seconds]:n:' \
        '--waitretry=+[wait seconds]:n:' \
        '--random-wait[random wait]' \
        '--no-proxy[no proxy]' \
        '-Q+[quota]:str:' \
        '--quota=+[quota]:str:' \
        '--limit-rate=+[rate]:str:' \
        '--bind-address=+[address]:str:' \
        '--no-dns-cache[no dns cache]' \
        '--restrict-file-names=+[modes]:str:' \
        '-4[ipv4]' \
        '--inet4-only[ipv4]' \
        '-6[ipv6]' \
        '--inet6-only[ipv6]' \
        '--user=+[user]:_users' \
        '--password=+[password]:str:' \
        '--ask-password[ask password]' \
        '-nd[no directories]' \
        '--no-directories[no directories]' \
        '-x[force directories]' \
        '--force-directories[force directories]' \
        '-nH[no host directories]' \
        '--no-host-directories[no host directories]' \
        '--cut-dirs=+[n]:n:' \
        '-P+[prefix]:dir:_files -/' \
        '--directory-prefix=+[prefix]:dir:_files -/' \
        '-E[adjust extension]' \
        '--adjust-extension[adjust extension]' \
        '--http-user=+[user]:_users' \
        '--http-password=+[password]:str:' \
        '--no-http-keep-alive[no http keep-alive]' \
        '--no-cache[no cache]' \
        '--no-cookies[no cookies]' \
        '--load-cookies=+[file]:file:_files' \
        '--save-cookies=+[file]:file:_files' \
        '--keep-session-cookies[keep session cookies]' \
        '--post-data=+[data]:str:' \
        '--post-file=+[file]:file:_files' \
        '--header=+[header]:str:' \
        '-U+[user-agent]:str:' \
        '--user-agent=+[user-agent]:str:' \
        '--referer=+[referer]:url:_urls' \
        '--save-headers[save headers]' \
        '--max-redirect=+[n]:n:' \
        '--method=+[method]:m:(GET POST PUT DELETE PATCH OPTIONS HEAD TRACE CONNECT)' \
        '--body-data=+[data]:str:' \
        '--body-file=+[file]:file:_files' \
        '--content-disposition[content disposition]' \
        '--content-on-error[content on error]' \
        '--trust-server-names[trust server names]' \
        '--auth-no-challenge[auth no challenge]' \
        '--secure-protocol=+[protocol]:p:(auto SSLv2 SSLv3 TLSv1 TLSv1_1 TLSv1_2 TLSv1_3 PFS)' \
        '--no-check-certificate[no check certificate]' \
        '--certificate=+[file]:file:_files' \
        '--certificate-type=+[type]:t:(PEM DER)' \
        '--private-key=+[file]:file:_files' \
        '--private-key-type=+[type]:t:(PEM DER)' \
        '--ca-certificate=+[file]:file:_files' \
        '--ca-directory=+[dir]:dir:_files -/' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-l+[depth]:n:' \
        '--level=+[depth]:n:' \
        '--delete-after[delete after]' \
        '-k[convert links]' \
        '--convert-links[convert links]' \
        '-K[backup converted]' \
        '--backup-converted[backup converted]' \
        '-m[mirror]' \
        '--mirror[mirror]' \
        '-p[page requisites]' \
        '--page-requisites[page requisites]' \
        '--strict-comments[strict comments]' \
        '-A+[accept patterns]:str:' \
        '--accept=+[accept patterns]:str:' \
        '-R+[reject patterns]:str:' \
        '--reject=+[reject patterns]:str:' \
        '--accept-regex=+[regex]:str:' \
        '--reject-regex=+[regex]:str:' \
        '--regex-type=+[type]:t:(posix pcre)' \
        '-D+[domain list]:str:' \
        '--domains=+[domain list]:str:' \
        '--exclude-domains=+[domain list]:str:' \
        '-H[span hosts]' \
        '--span-hosts[span hosts]' \
        '-I+[include directories]:str:' \
        '--include-directories=+[include directories]:str:' \
        '-X+[exclude directories]:str:' \
        '--exclude-directories=+[exclude directories]:str:' \
        '-np[no parent]' \
        '--no-parent[no parent]' \
        '--no-remove-listing[no remove listing]' \
        '--use-server-timestamps[use server timestamps]' \
        '*:url:_urls'
}

_wget-cli "$@"
