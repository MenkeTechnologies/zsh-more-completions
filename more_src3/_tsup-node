local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '(-d --out-dir)'{-d,--out-dir=}'[output directory]:dir:_directories'   '--format=[bundle format]:format:(cjs esm iife)'   '--target=[compile target]:target:'   '--dts[generate declaration files]'   '--sourcemap[emit source maps]'   '--watch[watch mode]'   '--clean[clean output directory]'   '--silent[suppress non-error logs]'   '--minify[minify bundle]'   '*:source files:_files' && ret=0

return ret
