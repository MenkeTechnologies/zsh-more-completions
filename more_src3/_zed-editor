#compdef zed-editor
# _zed-editor — Zed Industries collaborative editor CLI alias (Zed Industries, Rust); clap-rs
# upstream: https://github.com/zed-industries/zed

_zed-editor() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--new[open new window]' \
        '-n[open new window]' \
        '--add[add paths to existing window]' \
        '-a[add paths to existing window]' \
        '--foreground[run foreground]' \
        '-f[run foreground]' \
        '--zed=+[path to Zed executable]:file:_files' \
        '--dev-server-token=+[dev server token]:str:' \
        '--diff[open diff window]' \
        '-d[open diff window]' \
        '--system-specs[print system specs]' \
        '*:path:_files'
}

_zed-editor "$@"
