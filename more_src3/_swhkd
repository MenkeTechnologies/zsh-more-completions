#compdef swhkd
# Documentation: https://github.com/waycrate/swhkd/blob/master/swhkd/src/daemon.rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# swhkd - Simple Wayland Hotkey Daemon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[custom config file path]:config file:_files' \
  '(-C --cooldown)'{-C,--cooldown=}'[custom repeat cooldown duration (ms)]:milliseconds:' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '*'{-D,--device=}'[device(s) to listen on]:device:_files -W /dev/input' \
  '(-l --log)'{-l,--log=}'[custom log file path]:log file:_files' && ret=0

return ret
