#compdef kpack-controller
# _kpack-controller — kpack image-build controller
# upstream: https://github.com/buildpacks-community/kpack
# Flags from cmd/controller/main.go on tip.

_kpack-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file (out-of-cluster)]:file:_files' \
        '--master=[Kubernetes API server URL]:url:' \
        '--build-init-image=[image used to initialize a build]:image:' \
        '--rebase-image=[image used to perform rebases]:image:' \
        '--completion-image=[image used to finish a build]:image:' \
        '--build-waiter-image=[image used to wait for a build]:image:' \
        '--system-namespace=[controller namespace (signing/attestation secrets)]:ns:' \
        '--system-service-account=[controller service account]:sa:' \
        '--enable-priority-classes=[enable per-build priority classes]:bool:(true false)' \
        '--maximum-platform-api-version=[max allowed platform API version]:ver:' \
        '--insecure-ssh-trust-unknown-hosts=[auto-trust unknown SSH hosts]:bool:(true false)' \
        '--scaling-factor=[client-side rate-limit scaling factor]:n:' \
        '--injected-sidecar-support=[run builds as standard containers for injected sidecars]:bool:(true false)' \
        '--experimental-generate-slsa-attestation=[generate SLSA attestations per build]:bool:(true false)' \
        '--git-resolver-use-shallow-clone=[use shallow clone instead of ls-remote]:bool:(true false)'
}

_kpack-controller "$@"
