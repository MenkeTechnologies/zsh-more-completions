        '-output-s[output assembly]' \
        '-output-o[output object]' \
        '-of=+[file]:file:_files' \
        '-od=+[dir]:dir:_files -/' \
        '-od2=+[dir]:dir:_files -/' \
        '-op[preserve path]' \
        '-deps[print deps]' \
