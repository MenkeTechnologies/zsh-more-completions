#compdef looking-glass-client
# Documentation: https://looking-glass.io/docs

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-f,--full-screen}'[launch in full screen mode]' \
  {-F,--fps}'=[limit frame rate]:fps:' \
  {-s,--spice-host}'=[SPICE server host]:host:_hosts' \
  {-c,--spice-port}'=[SPICE server port]:port:' \
  {-j,--jit-render}'[enable JIT rendering]' \
  {-k,--shmFile}'=[shared memory file path]:file:_files' \
  '-g=[force renderer]:renderer:(auto egl opengl)' \
  {-a,--audio}'[enable audio]' \
  '--no-audio[disable audio]' \
  {-S,--minimize}'[minimize client on focus loss]' \
  '--size=[window size]:size:' \
  '--pos=[window position]:position:' \
  {-n,--no-screensaver}'[prevent screensaver activation]' \
  '--no-clipboard[disable clipboard synchronization]' \
  '--escape=[set escape key]:key:' \
  {-m,--no-minimize}'[do not minimize on focus loss]' \
  '--border[show window border]' \
  '--no-border[hide window border]' \
  '--title=[window title]:title:' \
  '-d[enable debug mode]' \
  && return 0
