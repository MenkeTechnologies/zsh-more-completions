#compdef latexpand
# Documentation: latexpand --help (CTAN/GitLab)
# Source: flatten a LaTeX file by expanding \input/\include/\usepackage and stripping comments.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show this help]' \
    '--verbose[show what is going on]' \
    '--keep-comments[do not strip comments]' \
    '--empty-comments[keep empty comments (% at end of line)]' \
    '--keep-includes[do not expand \\input/\\include directives]' \
    '--expand-usepackage[expand \\usepackage{...} if .sty found in $TEXINPUTS]' \
    '--expand-bbl=[inline FILE as bibliography]:bbl file:_files -g "*.bbl"' \
    '--biber=[include \\bibliography{} with FILE content (biber)]:biber file:_files' \
    '*'{-d+,--define=}'[define key=value macro replacement]:key=value:' \
    '(-o --output)'{-o+,--output=}'[generate output in FILE]:file:_files' \
    '--explain[generate explanatory comments in output]' \
    '--show-graphics[show included graphics]' \
    '--graphics_extensions=[colon-separated possible graphics extensions]:extensions:' \
    '--fatal[die if a file cannot be found]' \
    '--makeatletter[insert \\makeatletter in the preamble]' \
    '--in-encoding=[input encoding (PerlIO layer)]:encoding:' \
    '--out-encoding=[output encoding (PerlIO layer)]:encoding:' \
    '*:tex file:_files -g "*.tex"' \
    && ret=0

return ret
