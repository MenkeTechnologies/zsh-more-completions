#compdef lurk
# Documentation: https://github.com/JakWai01/lurk
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# Zsh completion for lurk (strace-like system call tracer in Rust)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --attach)'{-p,--attach}'=[attach to a running process]:pid:_pids' \
  '(-e --expr)'{-e,--expr}'=[qualifying expression modifying which events to trace]:expression' \
  '(-E --env)'{-E,--env}'=[add or remove environment variables]:env' \
  '(-o --file)'{-o,--file}'=[name of output file]:file:_files' \
  '(-c --summary-only)'{-c,--summary-only}'[report a summary instead of regular output]' \
  '(-C --summary)'{-C,--summary}'[report a summary in addition to regular output]' \
  '(-f --follow-forks)'{-f,--follow-forks}'[trace child processes as created]' \
  '(-s --string-limit)'{-s,--string-limit}'=[maximum string size to print]:length' \
  '(-j --json)'{-j,--json}'[display output in JSON format]' \
  '(-n --syscall-number)'{-n,--syscall-number}'[display system call numbers]' \
  '(-T --syscall-times)'{-T,--syscall-times}'[show time spent in system calls]' \
  '(-u --username)'{-u,--username}'=[run command with specified user credentials]:user:_users' \
  '(-v --no-abbrev)'{-v,--no-abbrev}'[print unabbreviated string versions]' \
  '(-z --successful-only)'{-z,--successful-only}'[print only successful syscalls]' \
  '(-Z --failed-only)'{-Z,--failed-only}'[print only failed syscalls]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '*:command:_command_names -e' && ret=0

return ret
