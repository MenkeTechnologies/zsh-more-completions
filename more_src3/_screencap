#compdef screencap
# Documentation: https://android.googlesource.com/platform/frameworks/base/+/refs/heads/main/cmds/screencap/screencap.cpp
# Source: AOSP frameworks/base — on-device screenshot grabber (run inside `adb shell screencap`).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-a[capture all active displays (appends integer postfix)]' \
    '-d[display ID to capture]:id:' \
    '(-p -j)-p[output in PNG format]' \
    '(-p -j)-j[output in JPEG format]' \
    '--hint-for-seamless[use hintForSeamless path in SurfaceFlinger]' \
    '*:output file (.png/.jpg auto-detected):_files' \
    && ret=0

return ret
