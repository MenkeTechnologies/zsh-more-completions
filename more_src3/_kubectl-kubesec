#compdef kubectl-kubesec
# kubectl-kubesec (krew plugin): security risk analysis for Kubernetes resources
# https://github.com/controlplaneio/kubectl-kubesec

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '1:command:(scan)' \
  '2:resource type:(pod deployment statefulset daemonset)' \
  '3:resource name'
