#compdef sqlite3
# Documentation: https://sqlite.org/cli.html
# Source: sqlite/sqlite src/shell.c.in — SQLite command-line shell (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-append[append database to APPEND file]' \
    '-ascii[set output mode to ascii]' \
    '-bail[stop after first error]' \
    '-batch[force batch I/O]' \
    '-box[set output mode to box]' \
    '-column[set output mode to columns]' \
    '-cmd+[run SQL or .dot command first]:command:_default' \
    '-csv[set output mode to CSV]' \
    '-deserialize[open as in-memory deserialized DB]' \
    '-echo[print commands before execution]' \
    '-errcode[print numeric error codes]' \
    '-init+[initialization file]:file:_files' \
    '(-interactive)-batch' \
    '-interactive[force interactive I/O]' \
    '-bom[add UTF-8 BOM to output]' \
    '-list[set output mode to list]' \
    '-line[set output mode to line]' \
    '-lookaside+[use N lookaside slots of SIZE bytes]:size:_default:n:_default' \
    '-markdown[set output mode to markdown]' \
    '-maxsize+[max DB file size in bytes]:bytes:_default' \
    '-memtrace[trace memory allocations]' \
    '-mmap+[default mmap size in bytes]:bytes:_default' \
    '-newline+[set output row separator]:string:_default' \
    '-nofollow[refuse to open symlinks]' \
    '-no-rowid-in-view[disable ROWID in views]' \
    '-nonce+[require nonce for unsafe ops]:nonce:_default' \
    '-nullvalue+[string for NULL values]:string:_default' \
    '-pagecache+[page cache size]:bytes:_default:n:_default' \
    '-pcachetrace[trace page cache]' \
    '-quote[set output mode to quoted]' \
    '-readonly[open DB read-only]' \
    '-safe[enable safe mode]' \
    '-separator+[set output column separator]:string:_default' \
    '-stats[print stats after each query]' \
    '-table[set output mode to table]' \
    '-tabs[set output mode to tab-separated]' \
    '-vfs+[VFS name]:vfs:_default' \
    '-zip[open as ZIP archive]' \
    '-A[same as zipfile()]' \
    '-help[show help]' \
    '-html[set output mode to HTML]' \
    '-json[set output mode to JSON]' \
    '-version[show version]' \
    '1::database file:_files -g "*.{db,sqlite,sqlite3,db3}"' \
    '2::initial SQL statement:_default' \
    && ret=0

return ret
