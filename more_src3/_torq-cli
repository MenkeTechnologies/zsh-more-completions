#compdef torq-cli torq
# _torq-cli — Torq torq-cli CLI command-line frontend wrapping the Torq Hyperautomation SOAR no-code low-code Security Automation Workflow Orchestration platform CLI providing login logout whoami workflow case integration trigger schedule alert webhook policy variable secret environment user group role insight kpi audit-log execution-log resource-tag connector designer step toolbox manifest run-execution attack-surface (Torq team Ofer Smadari, Go); cobra
# upstream: https://torq.io/

_torq-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'workflow:workflow operations'
        'case:case operations'
        'integration:integration operations'
        'trigger:trigger operations'
        'schedule:schedule operations'
        'alert:alert operations'
        'webhook:webhook operations'
        'policy:policy operations'
        'variable:variable operations'
        'secret:secret operations'
        'environment:environment operations'
        'user:user operations'
        'group:group operations'
        'role:role operations'
        'insight:insight operations'
        'kpi:KPI operations'
        'audit-log:audit log operations'
        'execution-log:execution log operations'
        'tag:resource tag operations'
        'connector:connector operations'
        'step:step operations'
        'toolbox:toolbox operations'
        'manifest:manifest operations'
        'run:run workflow execution'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--workspace=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'torq subcommand' sub ;;
        args)
            case $words[1] in
                workflow|case|integration|trigger|schedule|alert|webhook|policy|variable|secret|environment|user|group|role|insight|kpi|connector|step|toolbox|manifest) _arguments '1:op:(list get create update delete enable disable run pause resume)' '*:id:' ;;
                run) _arguments '*:workflow id:' ;;
            esac
            ;;
    esac
}

_torq-cli "$@"
