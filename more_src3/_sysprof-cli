#compdef sysprof-cli
# Documentation: https://gitlab.gnome.org/GNOME/sysprof/-/raw/master/src/sysprof-cli/sysprof-cli.c
# Reference accessed: 2026-05-21
# Verified: upstream GOptionEntry definitions in sysprof-cli source.
# Removed: --aid (no such flag), --duration (no such flag),
# --no-network/--no-memory/--no-disk/--no-cpu/--no-battery are real
# but use single-line confirmation per source.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[print version and exit]' \
  '(-c --command)'{-c,--command}'=[run command and profile the process]:command:_command_names' \
  '(-p --pid)'{-p,--pid}'=[profile specific PID (deprecated)]:pid:_pids' \
  '*'{-e,--env}'=[set environment variable (VAR=VAL)]:VAR=VALUE:' \
  '(-f --force)'{-f,--force}'[force overwrite of capture file]' \
  '--no-throttle[disable CPU throttling (deprecated for --power-profile)]' \
  '--no-battery[disable battery statistics]' \
  '--no-cpu[disable CPU statistics]' \
  '--no-disk[disable disk statistics]' \
  '--no-memory[disable memory statistics]' \
  '--no-network[disable network statistics]' \
  '--no-perf[do not record stacktraces using Linux perf]' \
  '--no-decode[do not append symbol name info from local machine]' \
  '--no-debuginfod[do not use debuginfod to resolve symbols]' \
  '--no-sysprofd[do not use Sysprofd to acquire privileges]' \
  '--use-trace-fd[set SYSPROF_TRACE_FD env for subprocess]' \
  '--scheduler[track when processes are scheduled]' \
  '--session-bus[profile D-Bus session bus]' \
  '--system-bus[profile D-Bus system bus]' \
  '--monitor-bus=[additional D-Bus address to monitor]:addr:' \
  '--gjs[set GJS_TRACE_FD env to trace GJS processes]' \
  '--gtk[set GTK_TRACE_FD env to trace GTK application]' \
  '--rapl[include RAPL energy statistics]' \
  '--memprof[profile memory allocations and frees]' \
  '--gnome-shell[connect to org.gnome.Shell for profiler stats]' \
  '--speedtrack[track performance of application main loop]' \
  '--power-profile=[use power profile during recording]:profile:' \
  '--merge[merge provided *.syscap files to stdout]' \
  '--buffer-size=[buffer size in pages (1 = 1 page)]:pages:' \
  '--stack-size=[stack size to copy for user-space unwinding]:bytes:' \
  '1:output file:_files -g "*.syscap"' && ret=0

return ret
