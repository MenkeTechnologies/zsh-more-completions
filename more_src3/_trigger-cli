#compdef trigger-cli
# Documentation: https://trigger.dev/docs/cli-introduction
# Reference accessed: 2026-05-23
# Verified: trigger.dev --help (see also _trigger).

# Zsh completion for trigger-cli - Trigger.dev background tasks CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'trigger command' \
      'login[authenticate]' \
      'init[initialize project]' \
      'dev[run tasks locally]' \
      'env[manage environment variables]' \
      'deploy[deploy to cloud]' \
      'promote[promote deployment]' \
      'whoami[show user and project]' \
      'logout[logout]' \
      'list-profiles[list profiles]' \
      'switch[switch profile]' \
      'update[update packages]' \
      'preview[preview branches]' \
      'mcp[run MCP server]' \
      'install-mcp[install MCP server config]' \
      'install-rules[install agent rules]' && ret=0
    ;;
  args)
    case $line[1] in
      env)
        if (( CURRENT == 3 )); then
          _values 'env command' list get pull && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
