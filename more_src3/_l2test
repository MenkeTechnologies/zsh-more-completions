#compdef l2test
# Documentation: https://github.com/bluez/bluez/blob/master/tools/l2test.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# l2test (BlueZ). Mode flags and value-taking options taken from the
# getopt() table in tools/l2test.c. Removed from prior file: invented `-y
# delay rate` (real `-y` is "connect, send, then dump" mode), `-x` (real
# `-x` is "listen, send, then dump"), `-c command` (real `-c` is reconnect
# mode and takes no argument).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-r[listen and receive]' \
  '-w[listen and send]' \
  '-d[listen and dump incoming data]' \
  '-x[listen, send, then dump]' \
  '-t[listen, send and receive simultaneously]' \
  '-q[connect, send and receive simultaneously]' \
  '-s[connect and send]' \
  '-u[connect and receive]' \
  '-n[connect silently]' \
  '-y[connect, send, then dump]' \
  '-c[reconnect repeatedly]' \
  '-m[multiple connects]' \
  '-p[trigger dedicated bonding]' \
  '-z[information request]' \
  '-a+[channel policy]:policy:(bredr bredr_pref amp_pref)' \
  '-b+[bytes per packet]:n:' \
  '-e+[sequence number]:n:' \
  '-g+[disconnect delay]:seconds:' \
  '-i+[HCI device]:dev:' \
  '-B+[filename]:file:_files' \
  '-C+[number of frames]:n:' \
  '-D+[send delay]:usec:' \
  '-F+[FCS mode]:fcs:' \
  '-H+[buffer size]:n:' \
  '-I+[input MTU]:n:' \
  '-J+[L2CAP CID]:cid:' \
  '-K+[receive delay]:usec:' \
  '-L+[linger timeout]:seconds:' \
  '-N+[number of frames]:n:' \
  '-O+[output MTU]:n:' \
  '-P+[PSM]:psm:' \
  '-Q+[max transmit]:n:' \
  '-V+[address type]:type:(bredr le_public le_random)' \
  '-W+[deferred setup]:seconds:' \
  '-X+[L2CAP mode]:mode:(basic ertm streaming ext-flowctl)' \
  '-Y+[socket priority]:n:' \
  '-Z+[transmission window]:n:' \
  '*:bdaddr:' && ret=0

return ret
