#compdef hydra_pmi_proxy
# Documentation: https://github.com/pmodels/mpich/blob/main/doc/wiki/how_to/Using_the_Hydra_Process_Manager.md
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# PMI proxy for MPICH Hydra process manager (internal; flags vary by build)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '--debug[enable debug output]' \
  '--control-port=[control port host:port]:hostport:' \
  '--control-code=[control code]:code:' \
  '--rmk=[resource manager kernel]:rmk:' \
  '--launcher=[bootstrap launcher]:launcher:(ssh rsh fork slurm ll lsf sge pbsdsh manual persist)' \
  '--demux=[demux engine]:engine:(poll select)' \
  '--pgid=[process group id]:id:' \
  '--retries=[retries]:n:' \
  '--usize=[universe size]:n:' \
  '--proxy-id=[proxy id]:id:' \
  '--pmi-port=[PMI port]:port:' \
  '--pmi-connect=[pmi connect mode]:mode:(cache lazy-cache alltoall)' \
  '--pmi-aggregate[aggregate pmi messages]' \
  '-s[stdin proxy]' \
  '--cleanup[cleanup processes on exit]' \
  '--enable-stdin[enable stdin]' \
  '--ckpoint-prefix=[checkpoint prefix]:path:' \
  '--ckpointlib=[checkpoint library]:lib:' \
  '--global-core-map=[core map]:map:' \
  '--global-process-count=[total process count]:n:' \
  '--auto-cleanup=[auto-cleanup]:bool:(0 1)' \
  '--pmi-process-mapping=[PMI process mapping]:map:' \
  '*::hydra_pmi_proxy args:_files' && ret=0
return ret
