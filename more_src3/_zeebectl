#compdef zeebectl zbctl
# _zeebectl — Camunda Zeebe workflow engine CLI (Camunda, Go); spf13/cobra
# upstream: https://github.com/camunda/camunda-platform

_zeebectl() {
    local -a sub=(
        'activate:activate jobs'
        'broadcast:broadcast signal'
        'cancel:cancel process instance'
        'complete:complete job'
        'create:create instance/process'
        'deploy:deploy resource'
        'evaluate:evaluate decision'
        'fail:fail job'
        'modify:modify process instance'
        'publish:publish message'
        'resolve:resolve incident'
        'set:set variables'
        'status:show cluster status'
        'throw:throw error'
        'update:update retries/element instance/timeout'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--address=+[zeebe address]:addr:' \
        '--authzUrl=+[oauth authz url]:url:_urls' \
        '--audience=+[oauth audience]:str:' \
        '--clientId=+[oauth client id]:str:' \
        '--clientSecret=+[oauth client secret]:str:' \
        '--insecure[skip tls verification]' \
        '--clientCache=+[client cache file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zeebectl subcommand' sub ;;
        args)
            case $words[1] in
                activate) _arguments \
                    '1:cmd:(jobs)' \
                    '--maxJobsToActivate=+[max jobs]:n:' \
                    '--timeout=+[timeout]:dur:' \
                    '--worker=+[worker]:str:' ;;
                create) _arguments \
                    '1:cmd:(instance)' \
                    '--processId=+[process id]:str:' \
                    '--version=+[version]:n:' \
                    '--variables=+[variables json]:str:' \
                    '--withResult[wait for result]' ;;
                deploy) _arguments \
                    '*:resource:_files -g "*.(bpmn|dmn|form)"' ;;
                publish) _arguments \
                    '1:cmd:(message)' \
                    '--correlationKey=+[correlation key]:str:' \
                    '--messageId=+[message id]:str:' \
                    '--ttl=+[ttl]:dur:' \
                    '--variables=+[variables json]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_zeebectl "$@"
