#compdef usbipd
# Documentation: man usbipd(8)
# Source: torvalds/linux tools/usb/usbip/src/usbipd.c (master) — USB/IP server daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-4 --ipv4)'{-4,--ipv4}'[bind to IPv4 only]' \
    '(-6 --ipv6)'{-6,--ipv6}'[bind to IPv6 only]' \
    '(-D --daemon)'{-D,--daemon}'[run as a daemon]' \
    '(-d --debug)'{-d,--debug}'[print debug messages]' \
    '(-e --device)'{-e,--device}'[run only in device mode]' \
    '(-P --pid)'{-P-,--pid=-}'[write pid to file]::pidfile:_files' \
    '(-t --tcp-port)'{-t+,--tcp-port=}'[TCP port to listen on]:port:_default' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    && ret=0

return ret
