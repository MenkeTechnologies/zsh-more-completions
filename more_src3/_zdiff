#compdef zdiff
# Documentation: https://man.archlinux.org/man/zdiff.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Note: zdiff is a wrapper around diff invoked on gzipped files; passes
# all diff(1) flags through. Keep positional file completion only.

local -a arguments

arguments=(
    '1:compressed file:_files -g "*.{gz,Z,tgz,bz2,xz,lzma,zst}"'
    '2:compressed file:_files -g "*.{gz,Z,tgz,bz2,xz,lzma,zst}"'
)

_arguments -s -S $arguments
