#compdef surya_ocr surya_layout surya_detect surya_table surya_latex_ocr surya_gui texify_gui
# Documentation: https://github.com/datalab-to/surya
# Reference accessed: 2026-05-27
# Verified: upstream pyproject.toml [tool.poetry.scripts] and surya/scripts/{config,ocr_text,detect_text,detect_layout,table_recognition,ocr_latex}.py.
# Deviations from spec: dropped --max_pages, --start_page, --langs (not in upstream
# click options); added --page_range, --task_name, --disable_math, --skip_table_detection
# which are the real flags. There is no surya_order binary; replaced with surya_gui,
# texify_gui from the actual scripts table.

local curcontext="$curcontext" state line ret=1

# Flags shared by every surya_* command (CLILoader.common_options in
# surya/scripts/config.py).
local -a _surya_common
_surya_common=(
  '--output_dir=[directory to save output]:dir:_files -/'
  '--page_range=[comma separated page numbers or ranges, e.g. 0,5-10,20]:range:'
  '--images[save images of detected bboxes]'
  '(-d --debug)'{-d,--debug}'[enable debug mode]'
  '(- *)--help[show help message and exit]'
  '1:input path:_files'
)

case $service in
  surya_ocr)
    _arguments -s -S \
      '--task_name=[OCR task name]:task:(ocr_with_boxes ocr_without_boxes block_without_boxes)' \
      '--disable_math[do not recognize math in OCR]' \
      $_surya_common && ret=0
    ;;
  surya_table)
    _arguments -s -S \
      '--skip_table_detection[tables already cropped; do not re-detect]' \
      $_surya_common && ret=0
    ;;
  surya_detect|surya_layout|surya_latex_ocr)
    _arguments -s -S $_surya_common && ret=0
    ;;
  surya_gui|texify_gui)
    # Streamlit launchers; forward to plain file completion.
    _arguments -s -S \
      '(- *)--help[show help message and exit]' \
      '*:file:_files' && ret=0
    ;;
  *)
    _arguments -s -S $_surya_common && ret=0
    ;;
esac

return ret
