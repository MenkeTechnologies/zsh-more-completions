#compdef stat-cli
# _stat-cli — GNU coreutils stat display file or fs status CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_stat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-L[follow symlinks]' \
        '--dereference[follow symlinks]' \
        '-f[display fs status]' \
        '--file-system[display fs status]' \
        '--cached=+[mode]:m:(always never default)' \
        '-c+[format]:str:' \
        '--format=+[format]:str:' \
        '--printf=+[format]:str:' \
        '-t[terse output]' \
        '--terse[terse output]' \
        '*:file:_files'
}

_stat-cli "$@"
