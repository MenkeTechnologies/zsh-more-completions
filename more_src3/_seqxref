#compdef seqxref
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/seqxref.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.
# Removed from prior file: fabricated -xrefoutfile (real flag is
# -outfile) and -rxformat (no such qualifier in upstream).

# EMBOSS seqxref: retrieve cross-references for a sequence
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:sequence USA:_files' \
  '-outfile=[output file (default *.seqxref)]:file:_files' \
  '-odirectory2=[output directory]:dir:_files -/' \
  '*:sequence USA:_files' && ret=0

return ret
