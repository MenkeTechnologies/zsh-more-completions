#compdef sfget
# Documentation: http://www.ahay.org/RSF/sfget.html
# Source: ahay/src system/main/get.c — output parameters from an RSF header (`sfget par1 par2 …`).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'parform=[(y/n) print "param=value" (n = value only)]: :(y n)' \
    'all=[(y/n) output all values]: :(y n)' \
    '*:parameter name:_default' \
    && ret=0

return ret
