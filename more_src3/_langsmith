#compdef langsmith langsmith-cli
# Documentation: https://github.com/langchain-ai/langsmith-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'project:list tracing projects'
  'trace:query and export traces'
  'run:query individual LLM runs'
  'thread:query conversation threads'
  'dataset:manage evaluation datasets'
  'example:manage dataset examples'
  'evaluator:manage evaluator rules'
  'experiment:query experiment results'
  'hub:manage agent and skill repos on LangSmith Hub'
  'self-update:update to the latest version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--format=[output format]:format:(json pretty)' \
  '--limit=[pagination limit]:n:' \
  '--offset=[pagination offset]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'langsmith command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (trace)
        _arguments \
          '--project=[filter by project]:project:' \
          '--limit=[max results]:n:' \
          '--last-n-minutes=[lookback minutes]:n:' \
          '--since=[earliest timestamp]:ts:' \
          '--error[errors only]' \
          '--min-latency=[minimum latency seconds]:n:' \
          '--tags=[tag filter]:tags:' \
          '--include-metadata[include metadata]' \
          '--include-io[include input/output]' \
          '--full[include all fields]' \
          '--show-hierarchy[show full run tree]' && ret=0 ;;
      (run)
        _arguments \
          '--run-type=[run type]:type:(llm chain tool retriever)' \
          '--name=[filter by name]:name:' \
          '--min-tokens=[minimum token count]:n:' \
          '--include-metadata[include metadata]' \
          '--include-feedback[include feedback]' && ret=0 ;;
      (thread)
        _arguments \
          '--project=[filter by project]:project:' \
          '--last-n-minutes=[lookback minutes]:n:' && ret=0 ;;
      (dataset)
        _arguments \
          '--name-contains=[name filter]:name:' \
          '--limit=[max results]:n:' && ret=0 ;;
      (example)
        _arguments \
          '--dataset=[dataset id or name]:dataset:' \
          '--split=[split name]:split:' \
          '--limit=[max results]:n:' \
          '--offset=[pagination offset]:n:' && ret=0 ;;
      (evaluator)
        _arguments \
          '--name=[evaluator name]:name:' \
          '--function=[evaluator function]:fn:' \
          '--dataset=[dataset name]:dataset:' \
          '--project=[project name]:project:' \
          '--sampling-rate=[sampling rate]:rate:' \
          '--replace[replace existing evaluator]' && ret=0 ;;
      (experiment)
        _arguments \
          '--dataset=[dataset name]:dataset:' \
          '--limit=[max results]:n:' && ret=0 ;;
      (hub)
        _arguments \
          '--type=[entry type]:type:' \
          '--dir=[directory]:dir:_files -/' \
          '--name=[entry name]:name:' && ret=0 ;;
      (self-update)
        _arguments \
          '--dry-run[show what would be done without doing it]' && ret=0 ;;
    esac ;;
esac

return ret
