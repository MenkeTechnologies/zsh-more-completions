#compdef xcdiff
# Documentation: https://github.com/bloomberg/xcdiff/blob/main/Documentation/CLI.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-p1+[path to first project]:project:_files -g "*.xcodeproj"' \
  '-p2+[path to second project]:project:_files -g "*.xcodeproj"' \
  '(-v --verbose)'{-v,--verbose}'[detailed report of differences]' \
  '-l[list all available comparators]' \
  '-t+[comma-separated list of targets]:targets:' \
  '-c+[Xcode configuration to compare]:config:' \
  '-g+[compare by tag]:tag:' \
  '-f+[output format]:format:(console json markdown html htmlSideBySide)' && ret=0

return ret
