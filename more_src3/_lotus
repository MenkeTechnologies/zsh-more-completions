#compdef lotus lotus-miner lotus-worker lotus-shed lotus-stats lotus-fountain lotus-keygen lotus-bench
# _lotus — Protocol Labs Filecoin Lotus reference implementation CLI for full node miner worker and shed administrative tools (filecoin-project team, Go); urfave/cli
# upstream: https://github.com/filecoin-project/lotus

_lotus() {
    local -a sub=(
        'daemon:start daemon'
        'wallet:wallet operations'
        'send:send FIL'
        'chain:chain operations'
        'state:state operations'
        'sync:sync operations'
        'net:network operations'
        'mpool:mpool operations'
        'msig:multisig operations'
        'paych:payment channel operations'
        'client:storage client operations'
        'log:logging operations'
        'auth:auth operations'
        'info:show node info'
        'version:show version'
        'evm:EVM operations'
        'eth:Ethereum compat'
        'fil-cns:Filecoin consensus'
        'wait-api:wait for API'
        'fetch-params:fetch parameters'
        'pprof:profiling'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--repo=+[dir]:dir:_files -/' \
        '--repo-suffix=+[suffix]:str:' \
        '--log-level=+[level]:l:(debug info warn error fatal)' \
        '--log-format=+[fmt]:f:(text json)' \
        '--vv[very verbose]' \
        '--color=+[mode]:m:(auto always never)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lotus subcommand' sub ;;
        args)
            case $words[1] in
                daemon) _arguments \
                    '--api=+[port]:n:' \
                    '--genesis=+[file]:file:_files -g "*.car"' \
                    '--bootstrap[bootstrap]' \
                    '--import-chain=+[file]:file:_files -g "*.car"' \
                    '--import-snapshot=+[file]:file:_files -g "*.car"' \
                    '--halt-after-import[halt after import]' \
                    '--lite[lite mode]' \
                    '--pprof=+[addr]:str:' \
                    '--profile=+[profile]:p:(bootstrapper full)' ;;
                wallet) _arguments \
                    '1:wallet action:(new list balance default set-default delete export import verify sign)' \
                    '*:key:' ;;
                send) _arguments \
                    '--source=+[addr]:str:' \
                    '--from=+[addr]:str:' \
                    '--gas-premium=+[FIL]:str:' \
                    '--gas-feecap=+[FIL]:str:' \
                    '--gas-limit=+[N]:n:' \
                    '--nonce=+[N]:n:' \
                    '*:addr amount:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_lotus "$@"
