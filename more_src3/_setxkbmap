#compdef setxkbmap
# Documentation: man setxkbmap(1)
# Source: X.Org setxkbmap.c — set XKB keyboard map (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-? -help)'{-\\?,-help}'[show help]' \
    '-compat+[compatibility map component name]:name:_default' \
    '-config+[configuration file]:file:_files' \
    '-device+[device ID]:id:_default' \
    '-display+[X display]:display:_x_display' \
    '-geometry+[geometry component name]:name:_default' \
    '-I-[add directory to XKB search path]:dir:_files -/' \
    '-keycodes+[keycodes component name]:name:_default' \
    '-keymap+[name of keymap to load]:name:_default' \
    '-layout+[keyboard layout]:layout:_default' \
    '-model+[keyboard model]:model:_default' \
    '*-option+[XKB option]:option:_default' \
    '-print[print xkb_keymap description and exit]' \
    '-rules+[rules file]:rules:_default' \
    '-symbols+[symbols component name]:name:_default' \
    '-synch[synchronize X requests]' \
    '-types+[types component name]:name:_default' \
    '-v[verbose]' \
    '-verbose+[verbosity level (1-10)]:level:_default' \
    '-variant+[layout variant]:variant:_default' \
    '1::layout:_default' \
    '2::variant:_default' \
    '*::option:_default' \
    && ret=0

return ret
