#compdef scid
# Documentation: https://scid.sourceforge.io/
# Reference accessed: 2026-05-21
# Verified: SCID (Shane's Chess Information Database) is a Tcl/Tk GUI
# accepting only positional database/PGN/EPD file arguments. No
# documented CLI flag table.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:chess database/PGN/EPD:_files -g "*.(si4|si3|pgn|pgn.gz|epd)(-.)"' && ret=0
return ret
