#compdef sev-tool sevtool
# _sev-tool — AMD SEV firmware administration utility (AMDESE/sev-tool)
# upstream: https://github.com/AMDESE/sev-tool
# Flags from src/main.cpp (getopt_long).

_sev-tool() {
    _arguments \
        '(- *)'{-H,--help}'[show help]' \
        '--verbose[verbose output]' \
        '--brief[brief output]' \
        '(-I --sys_info)'{-I,--sys_info}'[show system info]' \
        '(-O --ofolder)'{-O+,--ofolder=}'[output folder]:dir:_files -/' \
        '--factory_reset[reset SEV firmware to factory state]' \
        '--platform_status[show SEV platform status]' \
        '--pek_gen[generate a new PEK]' \
        '--pek_csr[generate a PEK CSR]' \
        '--pdh_gen[generate a new PDH]' \
        '--pdh_cert_export[export PDH cert chain]' \
        '--pek_cert_import=[import signed PEK certificate]:file:_files -g "*.(pem|crt|der)"' \
        '--get_id[get platform ID]' \
        '--set_self_owned[set platform to self-owned]' \
        '--set_externally_owned=[set platform to externally-owned (oca cert)]:file:_files' \
        '--generate_cek_ask[fetch CEK signed by ASK]' \
        '--export_cert_chain[export PEK→OCA→ASK→ARK cert chain]' \
        '--export_cert_chain_vcek[export VCEK→ASK→ARK cert chain]' \
        '--sign_pek_csr=[sign a PEK CSR with OCA key]:file:_files' \
        '--get_ask_ark[fetch ASK and ARK certs]' \
        '--calc_measurement=[calculate launch measurement (json)]:file:_files -g "*.json"' \
        '--validate_cert_chain[validate SEV cert chain]' \
        '--generate_launch_blob=[generate launch blob (json)]:file:_files -g "*.json"' \
        '--package_secret[package guest secret]' \
        '--validate_attestation[validate SEV attestation report]' \
        '--validate_guest_report[validate SNP guest attestation report]' \
        '--validate_cert_chain_vcek[validate VCEK cert chain]' \
        '--test_all[run all tests]'
}

_sev-tool "$@"
