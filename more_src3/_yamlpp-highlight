#compdef yamlpp-highlight
# Documentation: https://github.com/perlpunk/YAML-PP-p5/blob/main/bin/yamlpp-highlight
# Reference accessed: 2026-05-21
# Verified: upstream Perl source (GetOptions) at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(--expand-tabs --et --no-expand-tabs --no-et)'{--expand-tabs,--et}'[expand tabs to 8 spaces (default)]' \
  '(--expand-tabs --et --no-expand-tabs --no-et)'{--no-expand-tabs,--no-et}'[do not expand tabs]' \
  '*:YAML file:_files -g "*.(yml|yaml)"' && ret=0

return ret
