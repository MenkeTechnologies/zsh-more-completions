#compdef himalaya-cli himalaya
# _himalaya-cli — soywod himalaya command-line email client CLI alias (pimalaya team, Rust); clap-rs
# upstream: https://github.com/pimalaya/himalaya

_himalaya-cli() {
    local -a sub=(
        'account:account commands'
        'account:configure:configure account'
        'account:list:list accounts'
        'account:sync:sync account'
        'account:doctor:diagnose account'
        'folder:folder commands'
        'folder:list:list folders'
        'folder:add:add folder'
        'folder:expunge:expunge deleted'
        'folder:purge:purge folder'
        'folder:delete:delete folder'
        'envelope:envelope commands'
        'envelope:list:list envelopes'
        'envelope:thread:show thread'
        'envelope:get:get envelope'
        'envelope:watch:watch envelopes'
        'flag:flag commands'
        'flag:add:add flag'
        'flag:set:set flag'
        'flag:remove:remove flag'
        'message:message commands'
        'message:read:read message'
        'message:write:compose message'
        'message:reply:reply to message'
        'message:forward:forward message'
        'message:save:save raw message'
        'message:send:send raw message'
        'message:mailto:open mailto URL'
        'message:copy:copy message'
        'message:move:move message'
        'message:delete:delete message'
        'message:export:export message'
        'attachment:attachment commands'
        'attachment:download:download attachments'
        'template:template commands'
        'template:write:write template'
        'template:reply:reply template'
        'template:forward:forward template'
        'template:save:save template'
        'template:send:send template'
        'completion:generate completion'
        'manual:generate manual pages'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.{toml,yaml,yml}"' \
        '-c+[config file]:file:_files -g "*.{toml,yaml,yml}"' \
        '--account=+[account]:str:' \
        '-a+[account]:str:' \
        '--folder=+[folder]:str:' \
        '-f+[folder]:str:' \
        '--debug[debug]' \
        '--trace[trace]' \
        '--output=+[format]:o:(plain json)' \
        '-o+[format]:o:(plain json)' \
        '--color=+[color]:c:(auto always never)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'himalaya subcommand' sub ;;
        args)
            case $words[1] in
                envelope:list|envelope:watch) _arguments \
                    '--query=+[search query]:str:' \
                    '-q+[search query]:str:' \
                    '--page=+[page]:n:' \
                    '-p+[page]:n:' \
                    '--page-size=+[size]:n:' \
                    '-s+[size]:n:' \
                    '--folder=+[folder]:str:' \
                    '-f+[folder]:str:' ;;
                message:read|message:reply|message:forward|message:delete|message:copy|message:move|flag:add|flag:remove|flag:set|envelope:get|message:export) _arguments \
                    '*:message ids:' \
                    '--folder=+[folder]:str:' \
                    '-f+[folder]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_himalaya-cli "$@"
