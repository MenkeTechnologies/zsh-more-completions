#compdef teip
# Documentation: https://github.com/greymd/teip
# Reference accessed: 2026-05-21
# Verified: upstream README usage + clap definitions in src/main.rs.
# Removed from prior file: fabricated long forms --only-matching,
# --characters, --lines, --fields, --delimiter, --regex-delimiter,
# --solid, --invert-match (none of these long forms exist in upstream clap;
# only the short -g/-c/-l/-f/-d/-D/-s/-v forms and the long --csv/--chomp/
# --sed/--awk/--completion exist).

_arguments -s -S \
  '-g[act on lines matching regex pattern]:pattern:' \
  '-o[-g acts only on matched parts]' \
  '-G[interpret -g as Oniguruma regex]' \
  '-c[act on specified characters]:list:' \
  '-l[act on specified lines]:list:' \
  '-f[act on whitespace-separated fields]:list:' \
  '-d[field delimiter for -f]:delimiter:' \
  '-D[regex pattern for field delimiter]:regex:' \
  '--csv[interpret -f as CSV fields per RFC 4180]' \
  '-s[execute new command per actioned chunk]' \
  '--chomp[remove trailing newlines in solid mode]' \
  '-v[invert actioning range]' \
  '-z[use NUL as line delimiter]' \
  '-I[placeholder string in command, implies -s]:string:' \
  '-e[execute external command for line numbers]:command:' \
  '-A[alias: grep -n -A <n> <pattern>]:n:' \
  '-B[alias: grep -n -B <n> <pattern>]:n:' \
  '-C[alias: grep -n -C <n> <pattern>]:n:' \
  '--sed[alias: sed -n "<pattern>="]:pattern:' \
  '--awk[alias: awk "<pattern>{print NR}"]:pattern:' \
  '--completion=[generate shell completion]:shell:(bash zsh fish powershell elvish)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--:command and args:_command_names -e' && return 0
