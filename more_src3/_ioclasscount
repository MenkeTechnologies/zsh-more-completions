#compdef ioclasscount
# Documentation: https://www.unix.com/man-page/osx/8/ioclasscount/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '--track[track allocations]' \
  '--leaks[show leaks]' \
  '--reset[reset counters]' \
  '--start[start tracking]' \
  '--stop[stop tracking]' \
  '--exclude[exclude classes]' \
  '--maps=[show maps for PID]:pid:_pids' \
  '--size=[size threshold in bytes]:bytes:' \
  '--capsize=[capacity size threshold]:bytes:' \
  '--perfdata=[performance data destination]:dest:' \
  '--perfdata-name=[performance data name]:name:' \
  '--ignore=[symbol to ignore]:symbol:' \
  '--tag=[VM tag]:tag:' \
  '--zsize=[zone size threshold]:bytes:' \
  '*:class name:' && ret=0

return ret
