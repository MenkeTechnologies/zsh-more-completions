#compdef scoverage
# _scoverage — Stephen Samuel scoverage Scala code coverage CLI alias (scoverage team, Scala); sbt plugin standalone
# upstream: https://github.com/scoverage/scalac-scoverage-plugin

_scoverage() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--source-dirs=+[source dirs csv]:str:' \
        '--source-encoding=+[source encoding]:e:(utf-8 iso-8859-1)' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '-d+[data dir]:dir:_files -/' \
        '--output-cobertura-file=+[cobertura file]:file:_files' \
        '--output-xml-file=+[scoverage xml file]:file:_files' \
        '--output-html-dir=+[html dir]:dir:_files -/' \
        '--output-debug-file=+[debug file]:file:_files' \
        '--minimum-coverage=+[min pct]:n:' \
        '--minimum-coverage-stmt=+[min stmt pct]:n:' \
        '--minimum-coverage-branch=+[min branch pct]:n:' \
        '--fail-on-minimum[fail if below minimum]' \
        '--clean[clean coverage data]' \
        '--enable[enable instrumentation]' \
        '--disable[disable instrumentation]' \
        '--exclude=+[exclude packages csv]:str:' \
        '--exclude-files=+[exclude files regex]:str:' \
        '--exclude-classlikes=+[exclude classlikes]:str:' \
        '--exclude-symbols=+[exclude symbols]:str:' \
        '--highlighting[enable syntax highlighting]' \
        '--print-summary[print summary]' \
        '--report-only[report only]' \
        '*:files:_files'
}

_scoverage "$@"
