#compdef speedscope
# _speedscope — interactive flamegraph viewer (jlfwong/speedscope)
# upstream: https://github.com/jlfwong/speedscope
# Flags from bin/cli.mjs (custom argv check).

_speedscope() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1:profile file (or - for stdin):_files'
}

_speedscope "$@"
