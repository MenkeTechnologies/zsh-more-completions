#compdef libftdi1-config
# Documentation: https://manpages.debian.org/testing/libftdi1-dev/libftdi1-config.1.en.html
# Reference accessed: 2026-05-19
# Verified: `libftdi1-config --help` from installed binary.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--prefix=-[installation prefix]:dir:_files -/' \
  '--exec-prefix=-[exec prefix]:dir:_files -/' \
  '--version[show version]' \
  '--libs[print linker flags]' \
  '--cflags[print compiler flags]' \
  '*:library:' && ret=0

return ret
