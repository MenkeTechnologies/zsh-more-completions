#compdef unicode_start
# Documentation: man unicode_start(1)
# Source: legionus/kbd src/unicode_start (master) — put console in UTF-8 mode (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1::console font:_files -g "*.{psf,psfu,psf.gz}"' \
    '2::unicode map:_files -g "*.{uni,trans}"' \
    && ret=0

return ret
