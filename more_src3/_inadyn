#compdef inadyn
# Documentation: https://github.com/troglobit/inadyn/blob/master/man/inadyn.8
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# inadyn: small DDNS update client; flags per inadyn(8) manpage
_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-1 --once)'{-1,--once}'[run once and exit]' \
  '--force[force update bypassing cache]' \
  '--cache-dir=[persistent cache directory]:dir:_files -/' \
  '(-c --cmd)'{-c+,--cmd=}'[command to check IP]:cmd:' \
  '(-C --continue-on-error)'{-C,--continue-on-error}'[ignore provider errors]' \
  '(-e --exec)'{-e+,--exec=}'[script to run on IP update]:cmd:' \
  '--exec-mode=[exec script mode]:mode:(compat event)' \
  '(-f --config)'{-f+,--config=}'[config file]:file:_files' \
  '(-i --iface)'{-i+,--iface=}'[interface to monitor]:iface:' \
  '(-I --ident)'{-I+,--ident=}'[program identity for PID/syslog]:name:' \
  '(-j --json)'{-j,--json}'[output provider listing as JSON]' \
  '(-l --loglevel)'{-l+,--loglevel=}'[log level]:level:(none err warn notice info debug)' \
  '(-L --list-providers)'{-L,--list-providers}'[list supported providers]' \
  '(-n --foreground)'{-n,--foreground}'[run in foreground]' \
  '--no-pidfile[do not create PID file]' \
  '(-P --pidfile)'{-P+,--pidfile=}'[PID file location]:file:_files' \
  '(-p --drop-privs)'{-p+,--drop-privs=}'[drop privileges to user[:group]]:user:_users' \
  '(-s --syslog)'{-s,--syslog}'[log to syslog]' \
  '(-S --show-provider)'{-S+,--show-provider=}'[show provider info]:name:' \
  '(-t --startup-delay)'{-t+,--startup-delay=}'[startup delay seconds]:secs:'
