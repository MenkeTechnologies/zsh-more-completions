#compdef keepmenu
# Documentation: https://github.com/firecat53/keepmenu/blob/main/keepmenu.1.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --autotype)'{-a+,--autotype=}'[autotype sequence; overrides config default]:seq:' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '(-C --clipboard)'{-C,--clipboard}'[select to clipboard]' \
  '(-d --database)'{-d+,--database=}'[path to Keepass database]:file:_files -g "*.kdbx"' \
  '(-k --keyfile)'{-k+,--keyfile=}'[path to keyfile]:file:_files' \
  '(-n --no-prompt)'{-n,--no-prompt}'[do not prompt for database password]' \
  '(-s --show)'{-s+,--show=}'[search term(s)]:term:' \
  '(-t --totp)'{-t,--totp}'[TOTP mode]' \
  '*:: :' && ret=0

return ret
