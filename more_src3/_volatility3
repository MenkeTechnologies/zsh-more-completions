#compdef volatility3 vol3 vol.py-volatility3
# _volatility3 — Volatility Foundation Volatility 3 modern memory-forensics framework CLI for analyzing Windows Linux macOS memory using ISF symbol tables YARA scanning pslist netstat filescan windows.* linux.* mac.* plugins (volatilityfoundation team, Python); argparse
# upstream: https://github.com/volatilityfoundation/volatility3

_volatility3() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-vv[more verbose]' \
        '-vvv[very verbose]' \
        '-vvvv[trace verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-f+[memory dump]:file:_files -g "*.raw *.mem *.bin *.dmp *.vmem *.lime *.aff *.crash *.elf"' \
        '--single-location=+[memory dump]:file:_files' \
        '-o+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-r+[renderer]:r:(quick csv pretty json json-lines)' \
        '--renderer=+[renderer]:r:(quick csv pretty json json-lines)' \
        '-c+[config json]:file:_files -g "*.json"' \
        '--config=+[config json]:file:_files -g "*.json"' \
        '--save-config=+[file]:file:_files -g "*.json"' \
        '--cache-path=+[dir]:dir:_files -/' \
        '--symbol-dirs=+[csv]:str:' \
        '--plugin-dirs=+[csv]:str:' \
        '--remote-isf-url=+[url]:str:' \
        '--clear-cache[clear cache]' \
        '-l+[log file]:file:_files' \
        '--log=+[log file]:file:_files' \
        '--write-config[write config]' \
        '--single-swap-locations=+[csv]:str:' \
        '--filters=+[csv]:str:' \
        '--no-symbol-download[no symbol download]' \
        '--offline[offline mode]' \
        '--parallelism=+[N]:n:' \
        '*:plugin:(windows.pslist windows.pstree windows.psscan windows.cmdline windows.dlllist windows.handles windows.modules windows.svcscan windows.filescan windows.memmap windows.netstat windows.netscan windows.registry.hivelist windows.registry.printkey windows.registry.userassist windows.malware.malfind windows.malware.timers windows.malware.ssdt windows.malware.callbacks windows.malware.hollowprocesses windows.malware.suspicious_threads windows.virtmap windows.dlldump windows.procdump windows.moddump windows.driverscan windows.driverirp windows.driverframework linux.pslist linux.psscan linux.pstree linux.proc linux.bash linux.pscat linux.lsmod linux.netstat linux.dmesg linux.kthreads linux.tty linux.kmsg mac.pslist mac.bash mac.lsmod mac.netstat mac.proc_maps mac.psxview mac.malware.unloaded_kexts banners.banners isfinfo configwriter timeliner yarascan)'
}

_volatility3 "$@"
