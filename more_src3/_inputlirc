#compdef inputlirc inputlircd
# Documentation: https://manpages.debian.org/bookworm/inputlirc/inputlircd.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm inputlircd(8) manpage. Short flags only; no long
# forms.

# inputlircd: input-event-to-lirc daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[UNIX socket for LIRC clients]:socket:_files' \
  '-f[run in foreground]' \
  '-c[capture modifier keys as modifiers]' \
  '-r[repeat rate (ms)]:rate:' \
  '-g[grab input device(s) exclusively]' \
  '-m[minimum keycode to send]:keycode:' \
  '-n[input device name]:name:' \
  '-u[user/group id after opening devices]:user:_users' \
  '-t[key-name to LIRC command translation file]:file:_files' \
  '*:input device:_files -g "/dev/input/*"' && ret=0
return ret
