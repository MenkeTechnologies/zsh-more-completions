#compdef stern
# Documentation: https://github.com/stern/stern
# Reference accessed: 2026-05-21
# Verified: upstream stern/stern README flag table.

# Zsh completion for stern (multi-pod log tailing for Kubernetes)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  {-A,--all-namespaces}'[If present, tail across all namespaces]' \
  '--color=[Force set color output]:color:(auto always never)' \
  '--completion=[Output shell completion code]:shell:(bash zsh fish)' \
  {-c,--container}'=[Container name regex]:container:' \
  '--container-state=[Tail containers with specified status]:state:(running waiting terminated all)' \
  '--context=[The name of the kubeconfig context to use]:context:' \
  '--diff-container[Display a different color for each container]' \
  {-e,--exclude}'=[Log lines regex to exclude]:pattern:' \
  {-E,--exclude-container}'=[Container name regex to exclude]:container:' \
  '--exclude-pod=[Pod name regex to exclude]:pod:' \
  '--field-selector=[Kubernetes field selector]:selector:' \
  {-H,--highlight}'=[Highlight log lines matching regex]:pattern:' \
  {-i,--include}'=[Log lines regex to include]:pattern:' \
  '--init-containers[Include or exclude init containers]' \
  '--ephemeral-containers[Include or exclude ephemeral containers]' \
  '--kubeconfig=[Path to kubeconfig file]:file:_files' \
  '--max-log-requests=[Maximum concurrent log requests]:n:' \
  {-n,--namespace}'=[Kubernetes namespace to use]:namespace:' \
  '--no-follow[Exit when all logs have been shown]' \
  '--node=[Node name to filter on]:node:' \
  '--only-log-lines[Print only log message content]' \
  {-o,--output}'=[Specify predefined template]:format:(default raw json extjson ppextjson)' \
  {-p,--prompt}'[Toggle interactive prompt for selecting pods]' \
  '--qps=[Queries per second to the API server]:n:' \
  '--burst=[Maximum burst for throttling]:n:' \
  {-l,--selector}'=[Selector (label query) to filter on]:selector:' \
  {-s,--since}'=[Return logs newer than a relative duration]:duration:' \
  '--since-time=[Return logs after a specific date (RFC3339)]:time:' \
  '--stdin[Parse logs from stdin]' \
  '--tail=[The number of lines from the end of the logs to show]:lines:' \
  '--template=[Template to use for log lines]:template:' \
  {-T,--template-file}'=[Path to template file]:file:_files' \
  {-t,--timestamps}'[Print timestamps]' \
  '--timezone=[Set timestamps to specific timezone]:timezone:(Local UTC)' \
  '--verbosity=[Number of the log level verbosity]:level:' \
  {-v,--version}'[Print the version and exit]' \
  '1:pod query:' && ret=0

return ret
