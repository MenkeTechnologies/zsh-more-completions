#compdef lbzip2
# Documentation: https://man.archlinux.org/man/extra/lbzip2/lbzip2.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lbzip2 (parallel bzip2 compression)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-1[set block size to 100k]' \
  '-2[set block size to 200k]' \
  '-3[set block size to 300k]' \
  '-4[set block size to 400k]' \
  '-5[set block size to 500k]' \
  '-6[set block size to 600k]' \
  '-7[set block size to 700k]' \
  '-8[set block size to 800k]' \
  '-9[set block size to 900k]' \
  '--fast[alias for -1]' \
  '--best[alias for -9]' \
  '(-d --decompress)'{-d,--decompress}'[force decompression]' \
  '(-z --compress)'{-z,--compress}'[force compression]' \
  '(-t --test)'{-t,--test}'[test decompression; discard output]' \
  '(-k --keep)'{-k,--keep}'[keep input files]' \
  '(-c --stdout)'{-c,--stdout}'[write to standard output]' \
  '(-f --force)'{-f,--force}'[open non-regular input files]' \
  '-n+[number of (de)compressor threads]:wthrs' \
  '(-v --verbose)'{-v,--verbose}'[print detailed progress information]' \
  '(-s --small)'{-s,--small}'[reduce memory usage]' \
  '(-u --sequential)'{-u,--sequential}'[perform splitting sequentially]' \
  '-S[print condition variable statistics]' \
  '(-q --quiet)'{-q,--quiet}'[compatibility option]' \
  '--repetitive-fast[compatibility option]' \
  '--repetitive-best[compatibility option]' \
  '--exponential[compatibility option]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-L --license)'{-L,--license}'[display license]' \
  '(-V --version)'{-V,--version}'[display version]' \
  '*:file:_files' && ret=0

return ret
