#compdef hush
# =============================================================================
# hush — Hush is a Unix shell based on the Lua programming language.  Where
#        bash/zsh/fish use Bourne-shell-derived syntax (for/while/if/case
#        with [...] tests, $variable expansion, pipelines), Hush uses
#        LUA-DERIVED SYNTAX with shell-friendly extensions: pipeline
#        operators integrated into Lua function-call syntax, background-
#        execution operators, redirection-as-expression, and a built-in
#        REPL.  Designed as the "better shell language" — combining Lua's
#        expressiveness (closures, tables, proper data structures) with
#        shell's idioms (pipes, redirections, command-by-name).  Targets
#        shell-script-heavy ops/devops/sysadmin work where bash's quirky
#        quoting + variable-scoping rules become painful.  Single static
#        Rust binary; runs `.hsh` scripts.
#
# Author:  hush-shell organization on GitHub (primary developer: Gabriel
#          Diéguez Souza); originated as a research project demonstrating
#          how Lua's expressiveness could replace bash's idiosyncrasies
#          while retaining shell-style command-by-name execution
# Source:  https://github.com/hush-shell/hush
# CLI:     src/main.rs + src/args.rs (uses clap 2.x's `clap_app!` macro
#                                     — a DSL-style argv parser, the
#                                     macro-based predecessor to clap
#                                     3.x's builder + clap 4.x's derive)
# Library: clap's `clap_app!` MACRO (clap 2.x macro-based DSL API —
#          distinct from clap-derive R??, clap-builder R??)
# License: MIT
# Status:  Active — 691+ stars on hush-shell/hush; rust-implemented;
#          single-binary distribution.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 64TH DOCUMENTED LANGUAGE
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# its 64TH LANGUAGE (Hush, via the hush shell binary).  Hush joins the
# taxonomy as the FIRST Lua-derived-shell language documented — a niche
# occupied historically by fish-shell (Bourne-derived but heavily
# extended), nushell (data-pipeline-oriented JSON/YAML-aware shell), oil
# (an "Almost-bash, but cleaner" shell), and rc (Plan-9 shell).  Hush
# distinguishes itself by INHERITING LUA'S SYNTAX rather than extending
# Bourne — making it the only shell in the taxonomy whose script
# language IS a known programming language (Lua) rather than a shell-
# specific DSL.  New language tally: 64.  Top-language tally remains
# Rust=38 / Go=38 / TS-Node=38 (THREE-WAY TIE).  Taxonomy now spans
# 264 cross-language CLI library variants across 64 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS CLAP_APP! AND WHY IS IT THE 64TH LANGUAGE'S ENTRY?
#
# Hush's CLI is **`clap::clap_app!`** — clap 2.x's MACRO-BASED DSL for
# defining a CLI surface.  Where clap 3.x+ provides a builder API
# (`Command::new("foo").arg(Arg::new("x"))`) and clap 4.x+ provides
# derive macros (`#[derive(Parser)]`), clap 2.x SHIPPED A `clap_app!`
# MACRO that uses a Pratt-parser-style DSL inside Rust's macro_rules!
# for terse CLI definition:
#
#     clap_app!(
#         Hush =>
#             (version: crate_version!())
#             (author:  crate_authors!())
#             (about:   crate_description!())
#             (@arg check:   --check   "Perform only static analysis")
#             (@arg lex:     --lex     "Print the lexemes")
#             (@arg ast:     --ast     "Print the AST")
#             (@arg program: --program "Print the PROGRAM")
#             (@arg arguments: ... +allow_hyphen_values "Script and args")
#     )
#
# This is a THIRD distinct clap API alongside clap-derive and clap-
# builder.  Hush uses it because Hush's `args.rs` is from clap 2.x era
# (the file dates from 2020 when clap 3 was still pre-release).  The
# `clap_app!` macro is now LEGACY (deprecated in clap 4.x) but remains
# in use across many older Rust binaries.
#
# clap_app! is DISTINCT from clap-derive and clap-builder on FIVE
# specific axes:
#
#   1. MACRO-BASED DSL INSIDE macro_rules! — clap_app!'s syntax is a
#      mini-language parsed by Rust's macro_rules! system at compile
#      time:
#         clap_app!(
#             AppName =>
#                 (version: "1.0")
#                 (author: "Me")
#                 (about: "A description")
#                 (@arg flag: --flag "A flag")
#                 (@arg opt: --opt +takes_value "An option")
#                 (@subcommand sub =>
#                     (about: "A subcommand")
#                     (@arg subarg: --subarg "A subarg")
#                 )
#         )
#      The `(@kind name: properties "description")` syntax is a custom
#      DSL — `@arg`, `@subcommand`, `@group` are macro keywords.
#      Compare:
#        clap-derive:    `#[derive(Parser)] struct Args { ... }` with
#                         `#[arg(...)]` attribute macros
#        clap-builder:   `Command::new("name").arg(Arg::new("x").short('x'))`
#        clap_app!:      DSL-IN-MACRO_RULES! `(version: ...) (@arg name: ...)`
#                         — most concise of the three clap APIs but
#                         hardest to extend (limited by macro_rules!
#                         capabilities).
#      **First documented Rust CLI library variant to use Rust's
#      macro_rules! system as the option-specification DSL substrate.**
#
#   2. `+TAKES_VALUE` / `+ALLOW_HYPHEN_VALUES` / `+MULTIPLE` SIGIL-
#      QUALIFIED FLAG MODIFIERS — clap_app!'s flag-property syntax uses
#      a SIGIL-prefixed list of modifiers:
#         (@arg opt: --opt +takes_value "Option with value")
#         (@arg paths: --paths +takes_value ... "Multiple paths")
#         (@arg neg: --neg +allow_hyphen_values "Accept -1 as value")
#         (@arg req: --req +required "Required arg")
#         (@arg hidden: --hidden +hidden "Hidden from help")
#      Each `+modifier` is a positional-style flag-property toggle.
#      The `...` separator marks a multi-value argument.  Compare:
#        clap-derive:    struct-field attributes (`#[arg(required)]`,
#                         `#[arg(num_args = 1..)]`, ...)
#        clap-builder:   chained method calls (`.required(true)`,
#                         `.takes_value(true)`, ...)
#        clap_app!:      `+modifier` sigil syntax inside the macro DSL.
#      Reflects clap_app!'s DSL design heritage — sigils are the most
#      concise way to express boolean flags in a macro_rules! grammar.
#
#   3. PRATT-PARSED PARENTHESIZED SYNTAX — clap_app!'s grammar uses
#      DEEPLY NESTED PARENTHESES with Pratt-parser-style associativity:
#         clap_app!(
#             Outer =>
#                 (version: "1.0")
#                 (@subcommand inner =>
#                     (about: "...")
#                     (@arg x: --x "...")
#                     (@subcommand grandchild =>
#                         (@arg y: --y "...")
#                     )
#                 )
#         )
#      The parens nest indefinitely; macro_rules! recursively parses
#      each level.  Compare:
#        clap-derive:    flat struct definitions (no nesting beyond
#                         enum variants for subcommands)
#        clap-builder:   `Command::add_subcommand(Command::new("..."))`
#                         method chains
#        clap_app!:      EXPLICIT PARENTHESIS NESTING for command tree
#                         structure.
#      Makes deep subcommand trees readable in source but harder to
#      refactor (moving a subcommand requires reflowing parens).
#
#   4. DEPRECATED-BUT-STILL-USABLE LEGACY API — clap_app! is the
#      ONLY documented Rust CLI library variant that has been
#      EXPLICITLY DEPRECATED by its parent project but remains in use.
#      clap 3.x marked clap_app! as deprecated; clap 4.x removed it
#      entirely; users wanting clap_app! must pin to clap 2.x.
#      Compare:
#        clap-derive:    current modern (clap 4.x)
#        clap-builder:   current modern (clap 4.x)
#        clap_app!:      legacy (clap 2.x only) — Hush uses this
#                         because its codebase is older than clap 3
#      The "legacy library that won't be upgraded" pattern is rare
#      in the Rust ecosystem (Rust generally moves projects forward)
#      but happens when migration cost exceeds maintainer bandwidth.
#      Hush's args.rs is a frozen artifact from 2020.
#
#   5. `crate_version!()` / `crate_authors!()` / `crate_description!()`
#      AUTO-METADATA MACROS — clap_app! is designed to pair with three
#      compile-time macros that lift Cargo.toml metadata into the CLI:
#         (version: crate_version!())   -- reads version = "..." from
#                                          Cargo.toml at compile time
#         (author:  crate_authors!())   -- reads authors = [...]
#         (about:   crate_description!()) -- reads description = "..."
#      Compare:
#        clap-derive:    `#[command(version, author, about)]` reads
#                         same metadata via Parser-derive attribute
#                         resolution
#        clap-builder:   `Command::new(env!("CARGO_PKG_NAME"))
#                         .version(env!("CARGO_PKG_VERSION"))` —
#                         explicit env! lookups
#        clap_app!:      DEDICATED METADATA MACROS (crate_version!,
#                         crate_authors!, crate_description!,
#                         crate_name!) — terser than env!() calls but
#                         only work inside clap-aware code.
#      The `crate_*!()` macro family is one of clap_app!'s defining
#      features — and clap 4.x still ships them for derive-using code.
#
# THE clap::clap_app! API SURFACE (verbatim from clap 2.x docs)
#
#   #[macro_use]
#   extern crate clap;       // brings clap_app! into scope
#
#   use clap::{clap_app, AppSettings};
#
#   let matches = clap_app!(
#       AppName =>
#           (version: crate_version!())
#           (author:  crate_authors!())
#           (about:   crate_description!())
#           // Global args:
#           (@arg verbose: --verbose -v "Enable verbose output")
#           (@arg config: --config -c +takes_value "Config file")
#           (@arg input:  +required "Input file")
#           // Subcommands:
#           (@subcommand build =>
#               (about: "Build the project")
#               (@arg release: --release "Build in release mode")
#               (@arg target: --target +takes_value "Target triple")
#           )
#           (@subcommand test =>
#               (about: "Run tests")
#               (@arg pattern: +allow_hyphen_values "Test pattern")
#           )
#       ).setting(AppSettings::TrailingVarArg)
#        .get_matches();
#
#   // Access values:
#   if matches.is_present("verbose") { ... }
#   if let Some(cfg) = matches.value_of("config") { ... }
#
# Modifier sigils (each prefixed with `+`):
#   +takes_value          arg accepts a value (-c value)
#   +required             arg is mandatory
#   +multiple             arg can be repeated (-vvv)
#   +allow_hyphen_values  arg value may start with `-`
#   +hidden               hide from --help
#   +last                 must be the LAST positional arg
#   +use_delimiter        split value on , (e.g. -x a,b,c)
#   +case_insensitive     case-insensitive value matching
#   +empty_values         accept empty string as a valid value
#
# Special syntax:
#   ...                   variadic (multi-value) argument terminator
#   (@arg name: ...)      argument definition
#   (@subcommand cmd =>   subcommand definition
#       ...
#   )
#   (@group group =>      argument group
#       (@arg a:)
#       (@arg b:)
#   )
#
# CONTRAST WITH OTHER LANGUAGE-COMPILER / LANGUAGE-RUNTIME CLI LIBRARIES
# DOCUMENTED IN THE CORPUS:
#
#   * Wren (wren_cli)             — bare strcmp() ad-hoc parser
#   * Squirrel (sq)               — switch-on-argv[1][1] C parser
#   * Pawn (pawncc) R509          — Borland-Turbo-C-style parser
#   * Virgil (v3c) R501           — generic Option<T> in Virgil stdlib
#   * Nemerle (nemish) R505       — variant CliOption sum type
#   * Frege (fregec)              — Haskell monadic pattern matching
#   * Cone (conec) R517           — POSIX-getopt table-driven C
#   * Eta (eta) R521              — GHC CmdLineParser (12-constructor
#                                    OptKind sum type)
#   * Hush (hush, THIS)           — clap 2.x clap_app! MACRO DSL
#                                    (Rust-implemented Lua-based shell;
#                                    CLI uses clap's deprecated-but-
#                                    still-used macro_rules!-based
#                                    parenthesized DSL with sigil-
#                                    qualified modifiers and
#                                    crate_version!()/crate_authors!()/
#                                    crate_description!() auto-metadata
#                                    macros — third distinct clap API
#                                    alongside clap-derive and clap-
#                                    builder.)
#
# Hush occupies a UNIQUE NICHE — the **FIRST Lua-derived-shell language
# documented** + the **FIRST clap-2.x-`clap_app!`-macro-DSL CLI library
# variant documented**.  Two-for-one taxonomy entry: a new programming
# language (Hush) AND a new CLI library variant (clap_app! macro).
#
# REAL-WORLD hush USAGE:
#
#   * hush-shell/hush (THIS, 691*) — the shell + scripting language
#       itself; used by ops/devops folks for `.hsh` shell scripts
#   * Hush tutorials and PL-research projects
#   * Embedded in some Rust application infrastructure as the scripting
#       extension (Lua + shell idioms = expressive embedded scripting)
#
# HUSH LANGUAGE TIES TO OTHER LANGUAGES IN THE TAXONOMY:
#
#   * Lua — Hush's syntax is Lua-derived; tables, closures, function
#       definitions all follow Lua conventions
#   * fish-shell — fellow modern shell (in corpus); fish extends Bourne,
#       Hush extends Lua — DIFFERENT design choices
#   * nushell — fellow modern shell (in corpus); data-pipeline focus
#       with structured-data pipelines; complementary niche
#   * oil shell — "Almost-bash, but cleaner" (in corpus); preserves
#       bash compatibility while modernizing
#   * Rust — Hush is implemented in Rust; uses Rust ecosystem (clap,
#       crossterm, etc.); inherits Rust's static-compilation +
#       memory-safety guarantees
#
# -----------------------------------------------------------------------------
# HUSH'S CLI SURFACE (verbatim from src/args.rs)
# -----------------------------------------------------------------------------
#
# USAGE:
#   hush [OPTIONS] [SCRIPT [ARG...]]
#
# Options (from clap_app! definitions):
#   -h, --help                    Show help
#   -V, --version                 Show version
#       --check                   Perform only static analysis instead
#                                  of executing (parses + type-checks
#                                  the .hsh script without running it
#                                  — useful for IDE integration)
#       --lex                     Print the lexemes (token stream from
#                                  the lexer; debugging the hush
#                                  parser)
#       --ast                     Print the AST (parsed abstract syntax
#                                  tree; debugging the hush language
#                                  semantics)
#       --program                 Print the PROGRAM (compiled intermediate
#                                  representation; debugging codegen)
#
# Positional arguments:
#   SCRIPT                        Path to a .hsh script (omit for REPL)
#   ARG...                        Arguments passed to the script as $0..$N
#                                  (allow_hyphen_values — leading - OK)
#
# Behavior:
#   hush                          Launches interactive REPL
#   hush script.hsh               Runs script.hsh
#   hush script.hsh arg1 arg2     Runs script.hsh with arg1 arg2 as args
#   hush --check script.hsh       Type-checks script.hsh without running
#   hush --ast script.hsh         Parses + prints AST of script.hsh
#
# Exit codes (from src/main.rs):
#   0    success
#   1    invalid args (clap parse failed)
#   2    static error (--check found issues, or script has parse/type errors)
#   127  panic during script execution
#
# Hush language features (relevant context for what scripts look like):
#   - Lua-derived syntax: function f(x) ... end, tables {x = 1, y = 2}
#   - Shell idioms: pipelines via `cmd1 | cmd2`, backticks for
#     command-substitution, redirections via `>`, `<`, `>>`
#   - First-class functions + closures (Lua heritage)
#   - Proper data structures (tables, lists, dictionaries — not stringly-
#     typed like bash)
#   - Standard library inherits Lua's stdlib
#   - Async-aware (background commands via & like bash, with proper
#     waitpid semantics)
#
# Typical usage:
#   $ hush                                   # REPL
#   $ hush deploy.hsh staging                # Run deploy.hsh with arg
#   $ hush --check deploy.hsh                # Validate without running
#   $ hush --ast deploy.hsh > deploy.ast.txt  # Dump AST
#
# Companion tools:
#   None bundled — Hush is a single static Rust binary that contains
#   the lexer + parser + AST + IR + runtime + REPL all in one.
#
# =============================================================================

_hush() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--check[perform only static analysis instead of executing]' \
        '--lex[print the lexemes]' \
        '--ast[print the AST]' \
        '--program[print the PROGRAM intermediate representation]' \
        '*:hush script:_files -g "*.hsh"' && ret=0

    return ret
}

_hush "$@"
