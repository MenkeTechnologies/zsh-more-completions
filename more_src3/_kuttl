#compdef kuttl kubectl-kuttl
# Documentation: https://kuttl.dev/docs/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kuttl (kudobuilder/kuttl). Only top-level subcommands are help, version, test.
# Removed from prior file: invented `assert` and `errors` subcommands and
# several test-only flags that do not exist (--namespace, --timeout,
# --suppress-log, --report, --report-name).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'test:run kuttl test harness'
  'version:print kuttl version'
  'help:help about any command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kuttl command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (test)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--config=[path to kuttl configuration file]:file:_files -g "*.yaml *.yml"' \
          '--artifacts-dir=[output location for kind logs]:directory:_files -/' \
          '--as=[Kubernetes user to impersonate]:user:' \
          '--crd-dir=[CRDs to apply before tests]:directory:_files -/' \
          '*--manifest-dir=[directories with manifests to apply]:directory:_files -/' \
          '--start-kind[start a KIND cluster]' \
          '--start-control-plane[launch local control plane]' \
          '--kind-config=[KIND cluster config]:file:_files -g "*.yaml *.yml"' \
          '--kind-context=[KIND context name]:context:' \
          '--skip-cluster-delete[do not delete KIND/control-plane after tests]' \
          '--skip-delete[do not delete test resources]' \
          '--parallel=[maximum concurrent tests]:count:' \
          '--test=[run only named test case]:name:' \
          '--test-run-labels=[labels for test run association]:labels:' \
          '*--template-var=[variable for templated test files]:k=v:' \
          '*-v[verbosity level]' \
          '*:test directories:_files -/' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
