#compdef valac
# Documentation: valac --help (Vala)
# Source: Vala compiler (compiles to C then through cc).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(- *)--api-version[show API version]' \
    '*--vapidir=[search VAPI binding dir]:dir:_files -/' \
    '*--girdir=[search .gir dir]:dir:_files -/' \
    '*--metadatadir=[GIR metadata dir]:dir:_files -/' \
    '*--pkg=[include package binding]:package:' \
    '--vapi=[output VAPI file]:file:_files -g "*.vapi"' \
    '--library=[library name]:name:' \
    '--shared-library=[shared library name in gir]:name:' \
    '--gir=[GIR repository file (NAME-VERSION.gir)]:file:_files -g "*.gir"' \
    {-b+,--basedir=}'[base source directory]:dir:_files -/' \
    {-d+,--directory=}'[output directory]:dir:_files -/' \
    {-C,--ccode}'[output C code]' \
    {-H+,--header=}'[output C header file]:file:_files -g "*.h"' \
    '--includedir=[include path for C header]:dir:_files -/' \
    {-h+,--internal-header=}'[output internal C header]:file:_files -g "*.h"' \
    '--internal-vapi=[output internal VAPI]:file:_files -g "*.vapi"' \
    '--fast-vapi[VAPI without symbol resolution]' \
    '--use-fast-vapi[use --fast-vapi during compile]' \
    '--vapi-comments[include comments in VAPI]' \
    '--deps=[write make-style dependencies]:file:_files' \
    '--depfile=[write external dependencies for build]:file:_files' \
    '--list-sources[list source/binding files used]' \
    '--symbols=[output symbols file]:file:_files' \
    {-c,--compile}'[compile but do not link]' \
    {-o+,--output=}'[output file]:file:_files' \
    {-g,--debug}'[produce debug info]' \
    '--enable-mem-profiler[enable GLib memory profiler]' \
    '*'{-D+,--define=}'[define symbol]:symbol:' \
    '*--main=[entry point symbol]:symbol:' \
    '--nostdpkg[do not include standard packages]' \
    '--disable-assert[disable assertions]' \
    '--enable-checking[additional runtime checks]' \
    '--enable-deprecated[enable deprecated features]' \
    '--hide-internal[hide internal symbols]' \
    '--enable-experimental[enable experimental features]' \
    '--disable-warnings[disable warnings]' \
    '--fatal-warnings[treat warnings as fatal]' \
    '--disable-since-check[skip @since version check]' \
    {-k,--keep-going}'[continue after errors]' \
    '--enable-experimental-non-null[non-null type enhancements]' \
    '--enable-gobject-tracing[GObject creation tracing]' \
    '--cc=[C compiler command]:command:_command_names -e' \
    '*'{-X+,--Xcc=}'[pass option to C compiler]:option:' \
    '--pkg-config=[pkg-config command]:command:_command_names -e' \
    '--dump-tree=[write code tree]:file:_files' \
    '--save-temps[keep temporary files]' \
    '--profile=[runtime profile]:profile:(gobject posix)' \
    {-q,--quiet}'[quiet mode]' \
    {-v,--verbose}'[verbose mode]' \
    '--no-color[disable colored output]' \
    '--color=-[colored output mode]::mode:(auto always never)' \
    '--target-glib=[target GLib version]:version:' \
    '--gresources=[GResource XML file]:file:_files -g "*.xml"' \
    '--gresourcesdir=[GResource search dir]:dir:_files -/' \
    '*--enable-checking[runtime checks]' \
    '*:vala source:_files -g "*.(vala|vapi|gs|c)"' \
    && ret=0

return ret
