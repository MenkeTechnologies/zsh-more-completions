#compdef tink-controller
# _tink-controller — Tinkerbell workflow controller (tinkerbell/tink)
# upstream: https://github.com/tinkerbell/tink
# Flags from cmd/tink-controller/main.go on tip.

_tink-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--kubernetes=[apiserver URL]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--metrics-bind-address=[Prometheus metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect[enable leader election]' \
        '--log-level=[log level (0=info,1=debug)]:n:(0 1)' \
        '--namespace=[watched namespace (empty = cluster-wide)]:ns:' \
        '-v[klog verbosity level]:n:'
}

_tink-controller "$@"
