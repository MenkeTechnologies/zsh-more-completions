#compdef jack_session_notify jack_session
# _jack_session — JACK Audio Connection Kit jack_session_notify session manager notifying all JACK clients to save state for studio recall (jackaudio team, C); getopt
# upstream: https://github.com/jackaudio/jack2

_jack_session() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[save]' \
        '--save[save]' \
        '-S[save and quit]' \
        '--save-and-quit[save and quit]' \
        '-T[save template]' \
        '--save-template[save template]' \
        '-Q[quit]' \
        '--quit[quit]' \
        '-c+[client]:str:' \
        '--client=+[client]:str:' \
        '-d+[session dir]:dir:_files -/' \
        '--session-dir=+[session dir]:dir:_files -/' \
        '-n+[server name]:str:' \
        '--server-name=+[server name]:str:' \
        '*:session id or path:_files -/'
}

_jack_session "$@"
