#compdef tasklite tl
# _tasklite — CLI task manager for power users (ad-si/TaskLite)
# upstream: https://github.com/ad-si/TaskLite
# Subcommands from tasklite-core/source/Cli.hs (optparse-applicative).

_tasklite() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_tasklite_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                add|log|write|read|idea|watch|listen|buy|sell|pay|ship|query|find)
                    _arguments '*:text / query:' && ret=0 ;;
                do|doall|end|endall|wait|trash|delete|repeat|recur|duplicate|boost|hush|prioritize|info|edit|blocks|unblocks|note|deletenote|due|start|stop|tag|deletetag|get)
                    _arguments '*:task ID:' && ret=0 ;;
                waitfor|readyon|reviewin)
                    _arguments \
                        '1:duration (e.g. 1d, 2w):' \
                        '*:task ID:' && ret=0 ;;
                withtag)
                    _arguments '1:tag name:' && ret=0 ;;
                config|help|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_tasklite_commands] )) ||
_tasklite_commands() {
    local -a commands
    commands=(
        'add:add a new open task'
        'log:add an already-completed task'
        'enter:add a new task and edit it interactively'
        'readyon:set the ready-on date for a task'
        'wait:wait for a task'
        'waitfor:wait for a task with a specific duration'
        'review:open the review queue'
        'reviewin:put a task back into review in N days'
        'do:complete a single task'
        'doonly:complete one task and skip the rest of a batch'
        'doall:complete several tasks'
        'end:end a single task (mark obsolete)'
        'endall:end several tasks'
        'edit:edit a task in $EDITOR'
        'trash:move tasks to the trash'
        'delete:hard-delete tasks'
        'repeat:repeat tasks on a fixed interval'
        'recur:repeat tasks on a relative interval from completion'
        'duplicate:duplicate tasks'
        'boost:boost task priority'
        'hush:lower task priority'
        'prioritize:set explicit task priority'
        'info:show task details'
        'next:show the next task to work on'
        'random:pick a random task'
        'find:full-text search for tasks'
        'tag:add a tag to tasks'
        'deletetag:remove a tag from tasks'
        'blocks:mark tasks as blocking others'
        'unblocks:remove blocking relationships'
        'note:add a note to tasks'
        'deletenote:remove a note from tasks'
        'due:set the due date for tasks'
        'start:start tracking time on tasks'
        'stop:stop tracking time on tasks'
        'write:add a write task'
        'read:add a read task'
        'idea:add an idea task'
        'watch:add a watch task'
        'listen:add a listen task'
        'buy:add a buy task'
        'sell:add a sell task'
        'pay:add a pay task'
        'ship:add a ship task'
        'head:list the first N tasks'
        'all:list all tasks'
        'open:list open tasks'
        'modified:list recently modified tasks'
        'modifiedonly:list tasks modified after creation'
        'overdue:list overdue tasks'
        'repeating:list repeating tasks'
        'recurring:list recurring tasks'
        'new:list newly added tasks'
        'old:list old tasks'
        'ready:list tasks that are ready'
        'waiting:list waiting tasks'
        'done:list completed tasks'
        'obsolete:list obsolete (ended) tasks'
        'deletable:list deletable tasks (in trash)'
        'notag:list tasks without any tags'
        'withtag:list tasks bearing a tag'
        'get:get a specific task by id'
        'query:run a raw SQL query against the task DB'
        'config:show TaskLite configuration'
        'help:show help for a command'
        'version:print TaskLite version'
    )
    _describe -t commands 'tasklite command' commands
}

_tasklite "$@"
