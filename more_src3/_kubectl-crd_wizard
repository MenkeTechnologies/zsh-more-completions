#compdef kubectl-crd_wizard
# Documentation: https://github.com/pehlicd/crd-wizard
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--enable-ai[activate AI-powered analysis]' \
  '--ai-provider=[AI service provider]:provider:(gemini ollama)' \
  '--gemini-api-key=[Google Gemini API key]:key:' \
  '(-f --file)'{-f+,--file=}'[local CRD file path]:file:_files' \
  '--url=[Git provider URL for remote CRD source]:url:' \
  '--kind=[filter by CRD kind]:kind:' \
  '--all[export all CRDs from the cluster]' \
  '--format=[output format]:format:(md html)' \
  '--output=[destination directory]:dir:_files -/' \
  '--port=[server port]:port:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '1:command:->cmds' \
  '*::arg:_default' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'web:launch the web-based dashboard'
      'tui:start the text-based user interface'
      'generate:create documentation from CRD files or URLs'
      'export:export CRDs from the cluster as documentation'
    )
    _describe -t commands 'kubectl-crd_wizard command' cmds && ret=0
    ;;
esac

return ret
