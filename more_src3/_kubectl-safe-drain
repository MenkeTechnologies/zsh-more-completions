#compdef kubectl-safe-drain
# kubectl-safe-drain (krew plugin): safely drain a Kubernetes node
# https://github.com/suneeshkumar/kubectl-safe-drain

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--grace-period=[pod termination grace period]:seconds' \
  '--timeout=[drain timeout]:duration' \
  '--force[force drain even if there are DaemonSet-managed pods]' \
  '--ignore-daemonsets[ignore DaemonSet-managed pods]' \
  '--delete-emptydir-data[continue even if pods use emptyDir]' \
  '--dry-run[show what would happen without draining]' \
  '(-l --selector)'{-l+,--selector=}'[label selector for pods]:selector' \
  '--pod-selector=[filter pods by selector]:selector' \
  '--disable-eviction[force delete pods]' \
  '--skip-wait-for-delete-timeout=[skip waiting for pod deletion]:seconds' \
  '1:node name'
