#compdef kysely-codegen
# Documentation: https://github.com/RobinBlomberg/kysely-codegen
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kysely-codegen (RobinBlomberg/kysely-codegen). Flags taken from upstream
# README. Removed from prior file: bogus man.archlinux.org search URL;
# bun-sqlite-only dialect list. Added missing flags --config-file,
# --default-schema, --log-level, --no-domains, --numeric-parser,
# --date-parser, --partitions, --type-mapping, --type-only-imports,
# --verify.

_kysely-codegen() {
    _arguments \
        '--camel-case[apply Kysely CamelCasePlugin]' \
        '--config-file=[path to configuration file]:file:_files' \
        '--custom-imports=[custom type imports (JSON)]:json:' \
        '--date-parser=[PostgreSQL date parser]:parser:(string timestamp)' \
        '--default-schema=[default schema(s)]:schema:' \
        '--dialect=[SQL dialect]:dialect:(postgres mysql sqlite mssql libsql bun-sqlite kysely-bun-sqlite worker-bun-sqlite)' \
        '--env-file=[environment file]:file:_files' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--include-pattern=[glob pattern to include tables]:pattern:' \
        '--exclude-pattern=[glob pattern to exclude tables]:pattern:' \
        '--log-level=[terminal log level]:level:(debug info warn error silent)' \
        '--no-domains[skip PostgreSQL domain types]' \
        '--numeric-parser=[PostgreSQL numeric parser]:parser:' \
        '--overrides=[type overrides (JSON)]:json:' \
        '--out-file=[output file path]:file:_files' \
        '--partitions[include PostgreSQL table partitions]' \
        '--print[print output to terminal instead of file]' \
        '--runtime-enums[generate runtime enums]' \
        '--singularize[singularize generated type aliases]' \
        '--type-mapping=[map database types to TypeScript types]:json:' \
        '--type-only-imports[use TypeScript 3.8 import type syntax]' \
        '--url=[database connection string]:url:' \
        '--verify[verify generated types are up to date]'
}

_kysely-codegen "$@"
