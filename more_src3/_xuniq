#   * lalitshankarch/xuniq (THIS)
#   * automata-network/tee-builder — TEE binary builder
#   * Angr1st/wuerfel — dice-rolling CLI
#   * lalitshankarch/Tazdevil971/rps2-sdk — PS2 SDK
#   * Xila-Project/Core — Xila OS executables
#   * EHfive/uefi-toys (reset, loopback driver, util)
#
# -----------------------------------------------------------------------------
# XUNIQ CLI SURFACE (verbatim from src/main.rs print_help())
# -----------------------------------------------------------------------------
#
# USAGE:
#   xuniq [OPTIONS] < input > output
#
# OPTIONS:
#   -c, --capacity <N>     Expected number of UNIQUE lines (default: 1,000,000).
#                          Setting this correctly avoids HashSet rehashing
#                          mid-stream — significant performance win on
#                          large inputs.
#   -s, --safe             Use EXACT STRING MATCHING (takes more memory but
#                          no hash collisions).  Default is XxHash3_128
#                          (extremely low collision probability but
#                          theoretically possible).
#   -h, --help             Display this help and exit
#
# INPUT/OUTPUT:
#   stdin                  Input lines (UTF-8 or any byte stream)
#   stdout                 Output: unique lines in INPUT ORDER (first
#                          occurrence preserved, subsequent duplicates
#                          dropped)
#
# ALGORITHM (from xuniq source):
#   Default mode:  HashSet<u128> of XxHash3_128 hashes of trimmed lines.
#                  ~16 bytes per unique line; effectively O(1) collision
#                  probability for inputs up to 2^32 unique lines.
#   Safe mode:     HashSet<Box<[u8]>> of full trimmed line bytes.
#                  Memory ~ total bytes of unique content; zero collisions.
#
# COMPARISON TO RELATED TOOLS:
#   GNU `uniq`           Requires sorted input; xuniq works on unsorted streams
#   `sort -u`            Allocates entire input + sort buffer; xuniq is O(unique)
#   `awk '!seen[$0]++'`  Slower due to AWK interpreter overhead
#   `huniq` (Rust)       Similar tool with slightly different defaults
#
# =============================================================================

_xuniq() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '(-c --capacity)'{-c,--capacity}'[expected number of unique lines]:N (default 1000000):' \
        '(-s --safe)'{-s,--safe}'[use exact string matching (no hash collisions)]' \
        '(-h --help)'{-h,--help}'[display help and exit]' \
        && ret=0

    return ret
}

_xuniq "$@"
