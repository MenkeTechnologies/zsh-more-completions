#compdef zookeeper-shell
# Documentation: https://zookeeper.apache.org/doc/r3.9.1/zookeeperCLI.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-server+[ZooKeeper server host:port]:host\:port:_hosts' \
  '-timeout+[session timeout in ms]:ms:' \
  '-r[read-only mode]' \
  '-readonly[read-only mode]' \
  '-waitforconnection[wait for initial connection]' \
  '-client-configuration+[client configuration file]:file:_files' \
  '*:command:(connect close create delete deleteall set get getEphemerals getAcl setAcl ls stat sync printwatches addauth quit help history redo reconfig listquota setquota delquota config getAllChildrenNumber removewatches whoami version)' && ret=0

return ret
