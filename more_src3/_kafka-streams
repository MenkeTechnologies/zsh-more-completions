#compdef kafka-streams-application-reset
# _kafka-streams — Apache Kafka kafka-streams-application-reset (reset utility for Kafka Streams applications; --application-id Streams app.id, --input-topics, --intermediate-topics, --internal-topics, --bootstrap-server, --to-datetime/--to-offset/--from-file/--shift-by/--by-duration offset position, --dry-run, --execute, --force; positional argument runs after --application-id is mandatory)
# upstream: https://github.com/apache/kafka (streams)
# Flags from Apache Kafka streams bin/kafka-streams-application-reset.sh on tip.

_kafka-streams() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--application-id+[Streams app.id]:id:' \
        '--bootstrap-server+[broker]:broker:_hosts' \
        '--bootstrap-servers+[brokers]:brokers:_hosts' \
        '--input-topics+[topics csv]:topics:' \
        '--intermediate-topics+[topics csv]:topics:' \
        '--internal-topics+[topics csv]:topics:' \
        '--to-datetime+[date]:datetime:' \
        '--to-earliest[reset to earliest]' \
        '--to-latest[reset to latest]' \
        '--to-offset+[offset]:offset:' \
        '--from-file+[file]:file:_files' \
        '--shift-by+[N]:n:' \
        '--by-duration+[duration]:duration:' \
        '--command-config+[config file]:file:_files' \
        '--config-file+[config file]:file:_files' \
        '--dry-run[dry run]' \
        '--execute[execute]' \
        '--force[force]'
}

_kafka-streams "$@"
