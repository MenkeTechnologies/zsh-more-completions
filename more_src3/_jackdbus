#compdef jackdbus
# Documentation: https://github.com/jackaudio/jack2/blob/master/dbus/jackdbus.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jackdbus: JACK2 server D-Bus endpoint, activated by the session bus.
# Source main() accepts exactly one positional argument: "auto".
# Removed fabricated -h/-v/--version/-S flags (not in source).
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:mode:(auto)' && ret=0
return ret
