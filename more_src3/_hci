#compdef hci hercules-ci-cli
# _hci — Hercules CI command-line interface (hercules-ci/hercules-ci-agent)
# upstream: https://github.com/hercules-ci/hercules-ci-agent
# Subcommands from hercules-ci-cli/src/Hercules/CLI/Main.hs (optparse-applicative).

_hci() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--show-trace[print full evaluation stack traces]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'login:configure token for hercules-ci.com'
                'state:operate on state files'
                'version:print command name and version'
                'effect:run effects locally'
                'secret:manipulate locally stored secrets'
                'lock:opt-in locking for state'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_hci "$@"
