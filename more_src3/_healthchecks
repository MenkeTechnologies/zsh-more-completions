#compdef hc
# _healthchecks — Healthchecks.io CLI
# upstream: https://healthchecks.io/docs/

_healthchecks() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'ping:send a ping signal'
        'list:list checks'
        'create:create a new check'
        'pause:pause a check'
        'delete:delete a check'
    )

    _arguments -C \
        '--api-key=[Healthchecks API key]:key:' \
        '--project=[project UUID]:project:' \
        '--format=[output format]:format:(json text)' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'hc command' commands && ret=0 ;;
        args)
            case $line[1] in
                ping)
                    _arguments \
                        '1:check UUID or slug:' \
                        '--rid=[run ID]:id:' && ret=0 ;;
                create)
                    _arguments \
                        '--name=[check name]:name:' \
                        '--tags=[space-separated tags]:tags:' \
                        '--timeout=[expected period in seconds]:seconds:' \
                        '--grace=[grace period in seconds]:seconds:' && ret=0 ;;
                pause|delete)
                    _arguments '1:check UUID:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_healthchecks "$@"
