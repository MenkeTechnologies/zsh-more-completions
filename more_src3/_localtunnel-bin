#compdef lt localtunnel
# _localtunnel-bin — localtunnel client (Node.js); exposes localhost port through localtunnel.me HTTPS tunnel
# upstream: https://github.com/localtunnel/localtunnel

_localtunnel-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-p --port)'{-p,--port}'+[local port]:port:' \
        '(-h --host)'{-h,--host}'+[upstream server]:url:_urls' \
        '(-s --subdomain)'{-s,--subdomain}'+[requested subdomain]:name:' \
        '(-l --local-host)'{-l,--local-host}'+[local hostname]:host:_hosts' \
        '(--local-https)--local-https[enable when target speaks HTTPS]' \
        '(--local-cert)--local-cert+[local cert]:file:_files' \
        '(--local-key)--local-key+[local key]:file:_files' \
        '(--local-ca)--local-ca+[local CA]:file:_files' \
        '(--allow-invalid-cert)--allow-invalid-cert[skip cert verification]' \
        '(-o --open)'{-o,--open}'[open in browser]' \
        '(--print-requests)--print-requests[print requests]'
}

_localtunnel-bin "$@"
