#compdef superagent-cli
# Documentation: https://www.npmjs.com/package/superagent-cli
# Reference accessed: 2026-05-23
# Verified: npx superagent-cli --help.

# Zsh completion for superagent-cli - HTTP client CLI wrapper around superagent

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --detail)'{-d,--detail,--verbose}'[verbose response output]' \
  '(-v --verbose)'{-d,--detail,--verbose}'[verbose response output]' \
  '(-H --headers)'{-H,--headers}'[request headers key:value,...]:headers:' \
  '(-u --auth)'{-u,--auth}'[basic auth username:password]:auth:' \
  '(-t --timeout)'{-t,--timeout}'[timeout in milliseconds]:ms:' \
  '(-f --file)'{-f,--file}'[request body file]:file:_files' \
  ':url:_urls' \
  ':method:(get post put patch delete head options)' \
  '*:json body:' && ret=0

return ret
