#compdef kogito kogito-cli
# _kogito — Red Hat Kogito kogito CLI command-line frontend wrapping the Kogito cloud-native business automation platform managing services workflows decisions rule-engine DMN BPMN domain-specific OpenShift Quarkus SpringBoot Knative deploy build prometheus mongodb infinispan kafka data-index trusty-explainability (Red Hat team, Go); cobra
# upstream: https://kogito.kie.org/

_kogito() {
    local -a sub=(
        'install:install Kogito Operator'
        'uninstall:uninstall Kogito Operator'
        'project:project operations'
        'use-project:set current project'
        'deploy-service:deploy a Kogito service'
        'delete-service:delete a Kogito service'
        'build-service:build a Kogito service'
        'delete-build:delete a build'
        'get-deployments:show deployed Kogito services'
        'get-build:show build status'
        'use-knative:enable Knative integration'
        'use-keycloak:enable Keycloak integration'
        'use-trusty:enable Trusty AI integration'
        'use-process:enable Process integration'
        'use-mongodb:enable MongoDB integration'
        'install-infinispan:install Infinispan'
        'install-kafka:install Kafka'
        'install-keycloak:install Keycloak'
        'install-trusty:install Trusty'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-p+[project]:str:' \
        '--project=+[name]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--operator-image=+[image]:str:' \
        '--image-version=+[v]:str:' \
        '--runtime=+[r]:r:(quarkus springboot)' \
        '--enable-persistence[enable persistence]' \
        '--enable-events[enable events]' \
        '--build-image=+[image]:str:' \
        '--build-target=+[target]:str:' \
        '--git-source-uri=+[url]:str:' \
        '--git-source-context=+[path]:str:' \
        '--git-source-reference=+[ref]:str:' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kogito subcommand' sub ;;
        args)
            case $words[1] in
                project|deploy-service|delete-service|build-service|delete-build|use-project|get-deployments|get-build) _arguments '*:name:' ;;
            esac
            ;;
    esac
}

_kogito "$@"
