#compdef sendxbatches
# Documentation: man sendxbatches(8)
# Source: InterNetNews/inn backends/sendxbatches.in — wrap innxbatch for queued sites (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:sitename:_default' \
    '2:hostname:_hosts' \
    '*:xbatch file:_files' \
    && ret=0

return ret
