#compdef imlib2_grab
# Documentation: https://docs.enlightenment.org/api/imlib2/html/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# imlib2_grab: capture X11 drawable into image file (imlib2 demo binary).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-v[verbose]' \
  '-id+[drawable id]:id:' \
  '-width+[width]:width:' \
  '-height+[height]:height:' \
  '-noshape[do not use shape extension]' \
  '*:output file:_files' && ret=0

return ret
