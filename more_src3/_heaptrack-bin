#compdef heaptrack-bin
# _heaptrack-bin — KDAB heap memory profiler (Milian Wolff, KDE/KDAB); record allocations with stack traces
# upstream: https://github.com/KDE/heaptrack

_heaptrack-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug]' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-p --pid)'{-p,--pid}'+[attach PID]:pid:_pids' \
        '(-r --raw)'{-r,--raw}'[raw output]' \
        '(-s --stop)'{-s,--stop}'+[stop PID]:pid:_pids' \
        '(-a --analyze)'{-a,--analyze}'+[analyze file]:file:_files' \
        '--record-only[do not analyze]' \
        '*::command:_command_names -e'
}

_heaptrack-bin "$@"
