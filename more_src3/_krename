#compdef krename
# Documentation: https://invent.kde.org/utilities/krename/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KDE source (src/main.cpp QCommandLineOption
# registrations). Removed invented -c/-m/-l/--rename/--header;
# real options are -r, --template, --extension, --use-plugin,
# --copy, --move, --link, --start, --test (plus standard KDE
# --help/--version).

# KRename: KDE batch file renamer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-r[add folder recursively]' \
  '--template=[set a template]:template:' \
  '--extension=[set a template for the file extension]:template:' \
  '*--use-plugin=[enable a plugin for use]:plugin:' \
  '--copy=[copy files to folder or URL]:dest:_files -/' \
  '--move=[move files to folder or URL]:dest:_files -/' \
  '--link=[link files to folder or URL]:dest:_files -/' \
  '--start[start renaming immediately]' \
  "--test[start KRename's selftest (developers only)]" \
  '*:files:_files' && ret=0
return ret
