#compdef hcledit
# Documentation: https://github.com/minamijoyo/hcledit
# Reference accessed: 2026-05-17
# Verified: minamijoyo/hcledit upstream — non-interactive HCL editor.
# Subcommands: attribute (append/get/mv/replace/rm/set), block
# (append/get/list/mv/new/rm), body, fmt, version.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attribute:modify attributes (append/get/mv/replace/rm/set)'
  'block:manage blocks (append/get/list/mv/new/rm)'
  'body:body operations'
  'fmt:canonical format'
  'version:print version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --file)'{-f+,--file=}'[input file (stdin default)]:file:_files' \
  '(-u --update)'{-u,--update}'[in-place edit]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'hcledit command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (attribute)
        _arguments '1:operation:(append get mv replace rm set)' '*::arg:' && ret=0 ;;
      (block)
        _arguments '1:operation:(append get list mv new rm)' '*::arg:' && ret=0 ;;
    esac ;;
esac

return ret
