#compdef xsetroot
# Documentation: xsetroot -help (X.Org)
# Source: set characteristics of the X root window.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '(-def -default)'{-def,-default}'[reset unspecified attributes]' \
    '-cursor+[cursor + mask files]:cursor file:_files' \
    '-cursor_name+[cursor name from cursor font]:name:' \
    '-xcf+[Xcursor file]:file:_files' \
    '-bitmap+[bitmap file]:file:_files' \
    '-mod+[plaid grid x y pattern]:x:' \
    '(-gray -grey)'{-gray,-grey}'[gray background]' \
    '(-bg -background)'{-bg+,-background+}'[background color]:color:' \
    '(-fg -foreground)'{-fg+,-foreground+}'[foreground color]:color:' \
    '(-rv -reverse)'{-rv,-reverse}'[reverse video]' \
    '-solid+[solid background color]:color:' \
    '-name+[root window name]:string:' \
    '(-d -display)'{-d+,-display+}'[X display]:display:' \
    && ret=0

return ret
