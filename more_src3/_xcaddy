#compdef xcaddy
# Documentation: https://github.com/caddyserver/xcaddy
# Reference accessed: 2026-05-21
# Verified: cmd/commands.go (buildCommand.Flags: --with --replace --embed --output --pgo)
# and cmd/cobra.go (AddCommand: buildCommand, versionCommand). The bare
# `xcaddy <args...>` form runs Caddy in-place with module flags; controlled via
# XCADDY_* env vars rather than flags.

_xcaddy_cmds() {
    local -a commands=(
        'build:compile custom Caddy binary'
        'version:print xcaddy version'
    )
    _describe -t commands 'xcaddy command' commands
}

_xcaddy() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -C \
        '1:command:_xcaddy_cmds' \
        '*::arg:->args'

    case $state in
        args)
            case $line[1] in
                build)
                    _arguments \
                        '--output=[change the output file name]:file:_files' \
                        '*--with=[caddy module package path to include]:module-spec:' \
                        '*--replace=[Go module replacement directive]:replace-spec:' \
                        '*--embed=[embed a directory into the binary]:embed-spec:' \
                        '--pgo=[PGO profile file]:file:_files' \
                        '1:caddy-version:'
                    ;;
            esac
            ;;
    esac
}

_xcaddy "$@"
