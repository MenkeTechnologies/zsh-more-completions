#compdef undelete-blocks
# _undelete-blocks — restore deleted Mimir TSDB blocks (grafana/mimir)
# upstream: https://github.com/grafana/mimir
# Flags from tools/undelete-blocks/main.go + pkg/util/objtools BucketConfig on tip.

_undelete-blocks() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-blocks-from=[block source format]:from:(json lines listing)' \
        '-input-file=[file to read blocks from (- = stdin)]:file:_files' \
        '-allow-version-delete=[remove S3 delete-marker versions when possible]:bool:(true false)' \
        '-dry-run[log changes without writing]' \
        '-backend=[object store backend]:backend:(s3 gcs azure swift filesystem)' \
        '-s3.bucket-name=[S3 bucket name]:bucket:' \
        '-s3.endpoint=[S3 endpoint]:url:_urls' \
        '-s3.region=[S3 region]:region:' \
        '-s3.access-key-id=[S3 access key ID]:id:' \
        '-s3.secret-access-key=[S3 secret access key]:secret:' \
        '-gcs.bucket-name=[GCS bucket name]:bucket:' \
        '-azure.account-name=[Azure storage account]:name:' \
        '-azure.account-key=[Azure storage key]:key:' \
        '-azure.container-name=[Azure container name]:name:' \
        '-filesystem.dir=[local blocks directory]:dir:_files -/'
}

_undelete-blocks "$@"
