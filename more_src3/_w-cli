#compdef w-cli
# _w-cli — procps w show who is logged on and what they are doing CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_w-cli() {
    _arguments \
        '--help[show help]' \
        '-h[no header]' \
        '--no-header[no header]' \
        '--version[show version]' \
        '-V[show version]' \
        '-u[do not show user name when listing]' \
        '--no-current[do not show user name when listing]' \
        '-s[short format]' \
        '--short[short format]' \
        '-f[hide host field]' \
        '--from[hide host field]' \
        '-i[show ip instead of hostname]' \
        '--ip-addr[show ip instead of hostname]' \
        '-o[show old style output]' \
        '--old-style[show old style output]' \
        '-p[show pid file]' \
        '*:user:_users'
}

_w-cli "$@"
