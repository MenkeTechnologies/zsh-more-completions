#compdef wasp
# Documentation: https://wasp.sh/docs/general/cli
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_wasp_commands() {
  local -a commands=(
    'new:Create a new Wasp project'
    'start:Run Wasp app in development mode'
    'db:Database commands'
    'clean:Remove generated code, cached artifacts, and node_modules'
    'build:Generate production-ready web app code'
    'deploy:Deploy the app to a supported hosting provider'
    'telemetry:Show telemetry status'
    'deps:List project dependencies'
    'info:Show basic project information'
    'studio:GUI for inspecting app structure'
    'test:Execute project tests'
    'news:Display latest Wasp announcements'
    'version:Show the current CLI version'
    'waspls:Run the Wasp Language Server'
    'completion:Bash completion setup instructions'
    'uninstall:Remove Wasp from your system'
  )
  _describe -t commands 'wasp command' commands
}

_wasp_db_commands() {
  local -a sub=(
    'studio:Open the database GUI inspector'
    'migrate-dev:Synchronize the database with the schema'
    'start:Launch the development database'
  )
  _describe -t db-commands 'wasp db subcommand' sub
}

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:_wasp_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      new)
        _arguments \
          '(-t --template)'{-t+,--template=}'[project template]:template:(basic minimal saas ai-generated)' \
          '1:project name' && ret=0
        ;;
      db)
        _arguments \
          '1:db subcommand:_wasp_db_commands' \
          '--name=[migration name (migrate-dev)]:name' \
          '--create-only[create migration but do not run it (migrate-dev)]' && ret=0
        ;;
      build)
        _arguments \
          '1:build subcommand:(start)' \
          '--server-env=[server environment file (build start)]:file:_files' \
          '--client-env=[client environment file (build start)]:file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
