#compdef huntd
# Documentation: man huntd(6)
# Source: openbsd/src games/hunt/huntd/driver.c — hunt game driver (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[run in background; log to syslog]' \
    '-s[run forever (server mode)]' \
    '-p+[server port]:port:_default' \
    '-a+[bind address]:addr:_default' \
    '*-D+[config variable assignment (var=value)]:assignment:_default' \
    && ret=0

return ret
