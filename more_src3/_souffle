#compdef souffle
# Documentation: https://souffle-lang.github.io/execute
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for souffle - Datalog engine

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-F --fact-dir)'{-F,--fact-dir}'[specify fact input directory]:input directory:_files -/' \
  '(-D --output-dir)'{-D,--output-dir}'[specify output directory]:output directory:_files -/' \
  '(-o --dl-program)'{-o,--dl-program}'[generate compiled binary]:program name:_files' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:number of jobs' \
  '(-c --compile)'{-c,--compile}'[compile and execute Datalog program]' \
  '(-g --generate)'{-g,--generate}'[generate C++ source file]:C++ file:_files -g "*.cpp"' \
  '--inline-exclude=[exclude relations from inlining]:relations:' \
  '(-s --swig)'{-s+,--swig=}'[generate SWIG interface for given language]:language:(java python)' \
  '(-w --no-warn)'{-w,--no-warn}'[disable warnings]' \
  '(-m --magic-transform)'{-m+,--magic-transform=}'[enable magic set transformation for relations]:relations:' \
  '--magic-transform-exclude=[exclude relations from magic set transformation]:relations:' \
  '(-l --live-profile)'{-l,--live-profile}'[enable live profiling]' \
  '(-t --provenance)'{-t+,--provenance=}'[enable provenance mode]:mode:(explain explore)' \
  '(-p --profile)'{-p+,--profile=}'[write profile log to file]:profile log file:_files' \
  '(-u --profile-use)'{-u+,--profile-use=}'[use previously generated profile]:profile file:_files' \
  '(-r --debug-report)'{-r+,--debug-report=}'[write debug report to file]:report file:_files' \
  '(-P --pragma)'{-P+,--pragma=}'[set pragma directive]:key=value:' \
  '(-M --macro)'{-M+,--macro=}'[set macro definitions for preprocessing]:macros:' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-I --include-dir)'{-I+,--include-dir=}'[add include directory]:directory:_files -/' \
  '(-L --library-dir)'{-L+,--library-dir=}'[add library directory]:directory:_files -/' \
  '--libraries=[specify libraries to link]:libraries:' \
  '--show=[show internal representations]:representation:(parse-errors precedence-graph scc-graph transformed-datalog transformed-ram type-analysis)' \
  '1:Datalog source file:_files -g "*(#i).dl"' \
  && ret=0

return ret
