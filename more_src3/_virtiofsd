#compdef virtiofsd
# Documentation: https://gitlab.com/virtio-fs/virtiofsd/-/blob/main/README.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--print-capabilities[print vhost-user.json backend capabilities and exit]' \
  '--socket-path=[vhost-user socket path]:path:_files' \
  '--socket-group=[name of group for the vhost-user socket]:group:_groups' \
  '--fd=[file descriptor for vhost-user socket]:fd:' \
  '--shared-dir=[shared directory path]:dir:_directories' \
  '--tag=[tag the virtio device advertises]:tag:' \
  '--inode-file-handles=[use file handles instead of O_PATH FDs]:mode:(never prefer mandatory)' \
  '--xattr[enable extended attributes]' \
  '--xattrmap=[xattr translation rules]:rules:' \
  '--modcaps=[modify daemon capabilities]:caps:' \
  '--sandbox=[isolate the daemon process]:mode:(namespace chroot none)' \
  '--seccomp=[seccomp policy on disallowed syscall]:policy:(none kill log trap)' \
  '--cache=[caching policy]:policy:(auto always metadata never)' \
  '--thread-pool-size=[maximum thread pool size (0 disables)]:num:' \
  '--rlimit-nofile=[maximum number of file descriptors]:num:' \
  '--allow-direct-io[honor O_DIRECT flags from guest]' \
  '--allow-mmap[allow mmap of shared files (cache=metadata|never)]' \
  '--announce-submounts[tell the guest about submounts (default on)]' \
  '--no-announce-submounts[disable announce-submounts mode]' \
  '--posix-acl[enable POSIX ACLs (implies --xattr)]' \
  '--security-label[enable SELinux security labels (implies --xattr)]' \
  '--writeback[enable writeback cache]' \
  '--readonly[prevent write accesses from the guest]' \
  '--preserve-noatime[always preserve O_NOATIME]' \
  '--no-killpriv-v2[disable KILLPRIV V2 support]' \
  '--killpriv-v2[enable KILLPRIV V2 support]' \
  '--no-readdirplus[disable READDIRPLUS]' \
  '--log-level=[log level]:level:(error warn info debug trace off)' \
  '--syslog[log to syslog (default: stderr)]' \
  '*--uid-map=[map UID range (:ns_uid:host_uid:count:)]:map:' \
  '*--gid-map=[map GID range (:ns_gid:host_gid:count:)]:map:' \
  '*--translate-uid=[host/guest UID translation rule]:rule:' \
  '*--translate-gid=[host/guest GID translation rule]:rule:' \
  '--migration-mode=[migration scan mode]:mode:(find-paths file-handles)' && ret=0

return ret
