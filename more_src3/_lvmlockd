#compdef lvmlockd
# Documentation: https://man7.org/linux/man-pages/man8/lvmlockd.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lvmlockd: LVM lock manager daemon (sanlock/dlm backend)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-T,--test}'[test mode without calling lock manager]' \
  {-f,--foreground}'[avoid forking]' \
  {-D,--daemon-debug}'[no fork; output debugging to stdout]' \
  {-p+,--pid-file=}'[set PID file path]:file:_files' \
  {-s+,--socket-path=}'[set socket listen path]:path:_files' \
  '--adopt-file=[set adopt file path]:file:_files' \
  {-S+,--syslog-priority=}'[log level]:level:(err warning debug)' \
  {-g+,--gl-type=}'[global lock type]:type:(sanlock dlm)' \
  {-i+,--host-id=}'[set local sanlock host ID]:host_id:' \
  {-F+,--host-id-file=}'[file containing sanlock host ID]:file:_files' \
  {-o+,--sanlock-timeout=}'[override sanlock I/O timeout]:sec:' \
  {-A+,--adopt=}'[enable (1) or disable (0) lock adoption]:value:(0 1)' \
  '*::lvmlockd args:_files' && ret=0
return ret
