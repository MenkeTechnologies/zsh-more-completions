# ============================================================================
# _helmci — zsh completion for electronicarts/helmci, "a program that takes
#            a set of helm release values and automatically deploys them"
#            (Rust=153 leader bump OPENING Axis 98 Slack / slack-morphism)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/electronicarts/helmci
#   Maintainer : Electronic Arts, Inc.
#   License    : BSD-3-Clause (Apache-2.0 dual via LICENSE.txt /
#                Cargo manifest)
#   Stars      : 49
#   Language   : Rust (edition 2024, version 2.1.3)
#   Crate      : helmci  ([package] name = "helmci")
#   Binary     : helmci
#   Last push  : 2026-05-30
#
# WHAT IT IS
#   helmci is EA's deployment-automation CLI: feed it a directory
#   of `helm-values` per-cluster / per-env release definitions and
#   it walks the dependency graph, downloads the referenced charts
#   from OCI registries (`oci://`) or HTTP repos, runs `helm lint`
#   + `helm diff` + `helm upgrade` (or `helm template` / `helm
#   outdated` / `helm test`) in parallel across the discovered
#   release set, and renders progress to a Ratatui TUI, a CI-text
#   stream, or a Slack channel — pickable per-invocation via
#   repeatable `--output {text|tui|slack}`.  The Slack backend is
#   the one that drives the Axis 98 selection.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs `struct Args`
#                       + `enum Request` clap-derive declarations
#                       extracted via `gh api repos/electronicarts
#                       /helmci/contents/src/main.rs`)
#
#   helmci [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options (every subcommand):
#     --env <PATTERN>                Filter releases to use based
#                                    on env  [default: *]
#     --cluster <NAME>               Filter releases to use based
#                                    on cluster  (repeatable)
#     --vdir <DIR>                   Source directory containing
#                                    the helm-values
#     --output <FORMAT>              Output sink — repeatable;
#                                    one of {text|tui|slack}
#       text                           gitlab-compliant text +
#                                      slack output
#       tui                            full-screen ratatui TUI
#       slack                          slack-only output  (uses
#                                      slack-morphism v2.22 hyper
#                                      backend)
#     --release-filter <KEY=VAL>     Release predicate
#                                    (repeatable):
#       chart_type=<TYPE>              filter by chart type
#       chart_name=<NAME>              filter by chart name
#       release_name=<NAME>            filter by release name
#     --auto <STATE>                 Process auto=true releases
#                                    only, or all  [default: yes]
#       yes                            process auto==true only
#       all                            process every release
#                                      regardless of auto
#
#   Subcommands:
#     upgrade                        Upgrade / install releases —
#                                    runs `helm lint` → `helm diff`
#                                    → `helm upgrade --dry-run`
#                                    → `helm upgrade`
#       -b, --skip-upgrade-on-no-changes <BOOL>
#                                      Skip the upgrade step when
#                                      diff reports no changes
#                                      [default: true]
#
#     diff                           Diff releases against current
#                                    cluster state
#
#     test                           Test releases — runs `helm
#                                    outdated` → `helm lint` →
#                                    `helm template`
#       -a, --artifacts <DIR>          Directory to write
#                                      generated artifacts to
#
#     template                       Generate templates of releases
#       -a, --artifacts <DIR>          Directory to write
#                                      generated artifacts to
#
#     outdated                       Generate an outdated-releases
#                                    report
#
#     update <K=V>...                Update helm chart values
#                                    (any number of `name=value`
#                                    pairs on the command line)
#
#     rewrite-locks                  Rewrite repo lock files
#                                    (single-threaded — touches
#                                    the cache directory)
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `slack-morphism = "2.22.0"` with the
#   `hyper` feature declared in Cargo.toml — `slack-morphism` is
#   THE canonical Rust Slack SDK maintained by abdolence
#   (abdolence/slack-morphism-rust, 200+ stars; the predominant
#   typed Slack client in the Rust ecosystem, used by every major
#   Rust application that talks to Slack — helmci, hanabot,
#   universal-inbox, cokacdir, triage-bot, savoir-rs, slackline,
#   spacedriveapp/spacebot, christmas-elf-officer, etc.).  slack-
#   morphism exposes the typed `SlackClient<H>` parameterized over
#   `SlackClientHttpConnector` (with `SlackClientHyperConnector`
#   for hyper, `SlackClientHyperHttpsConnector` for hyper-rustls),
#   the typed `SlackApiToken` / `SlackApiTokenValue` /
#   `SlackApiTokenType` (bot, user, app, config-refresh, config-
#   access), every `chat.postMessage` / `chat.update` /
#   `chat.delete` / `conversations.list` / `conversations.members`
#   / `users.info` / `users.lookupByEmail` / `files.upload` /
#   `views.publish` / `views.update` / `views.open` request +
#   response model, NIP-style blocks (`SlackBlockMarkDown`,
#   `SlackBlockSection`, `SlackBlockActions`, `SlackBlockDivider`,
#   `SlackBlockHeader`, `SlackBlockContext`, `SlackBlockImage`,
#   `SlackBlockFile`, `SlackBlockVideo`) and rich text
#   (`SlackBlockRichText`, `SlackBlockRichTextElement`,
#   `SlackBlockRichTextSection`, `SlackBlockRichTextList`,
#   `SlackBlockRichTextQuote`, `SlackBlockRichTextPreformatted`,
#   `SlackBlockRichTextChannel`, `SlackBlockRichTextUser`,
#   `SlackBlockRichTextEmoji`), the typed message-edit /
#   message-thread / message-attachment / message-reaction model,
#   Slack Events API parsing (`SlackPushEvent`,
#   `SlackEventCallback`, `SlackEventCallbackBody` enum with
#   every event variant), the Socket-Mode client
#   (`SlackClientSocketModeListener`), Slack OAuth v2 token
#   exchange, signed-secret request verification, modal-view
#   submissions, slash-command callbacks, interactivity
#   callbacks, and the `SlackHyperClient` /
#   `SlackHyperListenerEnvironment` server primitives.  helmci's
#   `src/output/slack.rs` uses `SlackClient::new(SlackClient
#   HyperConnector::new(...))` to construct a typed Slack client
#   per invocation, builds typed `SlackApiChatPostMessageRequest`
#   payloads from `SlackMessageContent` + `SlackBlocks`, and
#   posts CI deploy status as rich blocks (header + section + table
#   of changed releases) to the configured channel.  Verified via:
#     gh api repos/electronicarts/helmci/contents/Cargo.toml
#       → slack-morphism = { version = "2.22.0",
#                            features = ["hyper"] }
#       → clap = { version = "4.5.60", features = ["derive"] }
#       → [package] name = "helmci", edition = "2024"
#     gh api repos/electronicarts/helmci/contents/src/main.rs
#       → #[derive(Parser)] struct Args { command: Request, env,
#                                         cluster, vdir, output,
#                                         release_filter, auto }
#       → #[derive(Subcommand)] enum Request { Upgrade, Diff,
#                                               Test, Template,
#                                               Outdated, Update,
#                                               RewriteLocks }
#       → #[derive(clap::ValueEnum)] enum OutputFormat { Text,
#                                                         Tui,
#                                                         Slack }
#       → #[derive(clap::ValueEnum)] enum AutoState { Yes, All }
#   This entry is the Rust=153 leader bump that OPENS Axis 98
#   (Slack / slack-morphism Slack protocol library) at 1/0/0.
#   Pairing Go and TS-Node bumps will follow at R982 and R983
#   (Go=153 candidates slack-go/slack-based CLIs; TS-Node=153
#   candidates @slack/web-api / @slack/bolt users).
#
#   No completion for `helmci` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_helmci() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--env=[filter releases by env pattern (default *)]:env-pattern:' \
        '*--cluster=[filter releases by cluster (repeatable)]:cluster:' \
        '--vdir=[source directory containing helm-values]:vdir:_files -/' \
        '*--output=[output sink (repeatable)]:format:(text tui slack)' \
        '*--release-filter=[release predicate (chart_type|chart_name|release_name)=VAL]:filter:->release_filter' \
        '--auto=[auto-flag handling]:state:(yes all)' \
        '1: :_helmci_commands' \
        '*::arg:->args' && ret=0

    case $state in
        release_filter)
            local -a filters
            filters=(
                'chart_type=:filter by chart type'
                'chart_name=:filter by chart name'
                'release_name=:filter by release name'
            )
            _describe -t filters 'release filter key' filters && ret=0
            ;;
        args)
            case $words[1] in
                upgrade)
                    _arguments \
                        '(-b --skip-upgrade-on-no-changes)'{-b,--skip-upgrade-on-no-changes}'=[skip upgrade when diff reports no changes (default true)]:bool:(true false)' && ret=0 ;;
                diff|outdated|rewrite-locks)
                    _arguments '*: :' && ret=0 ;;
                test|template)
                    _arguments \
                        '(-a --artifacts)'{-a,--artifacts}'=[directory to write generated artifacts to]:dir:_files -/' && ret=0 ;;
                update)
                    _arguments \
                        '*:value update (name=value):' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_helmci_commands] )) ||
_helmci_commands() {
    local -a commands
    commands=(
        'upgrade:upgrade/install releases (lint + diff + upgrade)'
        'diff:diff releases against current cluster state'
        'test:test releases (outdated + lint + template)'
        'template:generate template of releases'
        'outdated:generate outdated-releases report'
        'update:update helm chart values (name=value pairs)'
        'rewrite-locks:rewrite repo lock files'
    )
    _describe -t commands 'helmci command' commands
}

_helmci "$@"
