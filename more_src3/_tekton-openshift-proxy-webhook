#compdef tekton-openshift-proxy-webhook
# _tekton-openshift-proxy-webhook — Tekton Operator OpenShift proxy-defaulting admission webhook (injects HTTP(S)_PROXY/NO_PROXY into Tekton pods)
# upstream: https://github.com/tektoncd/operator
# Flags from cmd/openshift/proxy-webhook/main.go on tip; sharedmain webhook with no extra flags beyond knative.dev/pkg defaults.

_tekton-openshift-proxy-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_tekton-openshift-proxy-webhook "$@"
