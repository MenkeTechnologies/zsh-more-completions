#compdef kro-controller
# _kro-controller — kro.run controller (reconciles ResourceGroupDefinition + ResourceGraphInstance CRs into dynamic CRDs + a per-RGD controller chain)
# upstream: https://github.com/kro-run/kro
# Flags from cmd/controller/main.go on tip + controller-runtime zap.Options.

_kro-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--leader-elect[enable leader election]' \
        '--leader-election-namespace=[namespace for leader-election lease]:ns:' \
        '--leader-election-lease-duration=[leader-election lease duration]:duration:' \
        '--leader-election-renew-deadline=[leader-election renew deadline]:duration:' \
        '--leader-election-retry-period=[leader-election retry period]:duration:' \
        '--enable-controller-warmup[warm up dynamic controllers at startup]' \
        '--allow-crd-deletion[allow kro to delete CRDs it created]' \
        '--graceful-shutdown-timeout=[graceful shutdown timeout]:duration:' \
        '--rgd-max-collection-size=[max resources in a single collection]:n:' \
        '--rgd-max-collection-dimension-size=[max dimensions in a forEach]:n:' \
        '--rgd-max-graph-revisions=[max retained graph revisions]:n:' \
        '--rgd-progress-requeue-delay=[RGD progress requeue delay]:duration:' \
        '--feature-gates=[csv of feature gates]:gates:' \
        '--client-qps=[Kubernetes client QPS]:qps:' \
        '--client-burst=[Kubernetes client burst]:n:' \
        '--dynamic-controller-rate-limiter-min-delay=[min retry delay for dynamic controllers]:duration:' \
        '--dynamic-controller-rate-limiter-max-delay=[max retry delay for dynamic controllers]:duration:' \
        '--dynamic-controller-rate-limiter-rate-limit=[rate-limit budget (events/s)]:n:' \
        '--dynamic-controller-rate-limiter-burst-limit=[rate-limit burst budget]:n:' \
        '--dynamic-controller-default-resync-period=[default resync period (s)]:s:' \
        '--dynamic-controller-default-queue-max-retries=[max retries on the controller workqueue]:n:' \
        '--instance-requeue-interval=[ResourceGraphInstance requeue interval]:duration:' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_kro-controller "$@"
