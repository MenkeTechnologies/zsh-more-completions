#compdef tunefeed
# Documentation: man tunefeed(8)
# Source: InterNetNews/inn contrib/tunefeed.in — tune newsfeeds exclusions per traffic (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    {-d+,--days=}'[N days of traffic for active diff]:days:_default' \
    {-t+,--threshold=}'[min traffic threshold]:N:_default' \
    {-v,--version}'[show version]' \
    '1:local active file:_files' \
    '2:remote active file:_files' \
    '3::traffic file:_files' \
    && ret=0

return ret
