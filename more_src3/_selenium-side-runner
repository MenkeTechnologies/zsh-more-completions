#compdef selenium-side-runner
# _selenium-side-runner — execute Selenium IDE .side projects from CLI (SeleniumHQ/selenium-ide)
# upstream: https://github.com/SeleniumHQ/selenium-ide
# Flags from packages/side-runner/src/bin.ts (commander).

_selenium-side-runner() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--base-url=[override base URL set in IDE]:url:_urls' \
        '(-c --capabilities)'{-c+,--capabilities=}'[WebDriver capabilities]:caps:' \
        '(-j --jest-options)'{-j+,--jest-options=}'[options passed to jest]:opts:' \
        '(-s --server)'{-s+,--server=}'[WebDriver remote server URL]:url:_urls' \
        '(-r --retries)'{-r+,--retries=}'[retry tests N times on failures]:n:' \
        '(-f --filter)'{-f+,--filter=}'[only suites matching regex]:regex:' \
        '(-w --max-workers)'{-w+,--max-workers=}'[max parallel workers]:n:' \
        '(-t --timeout)'{-t+,--timeout=}'[max ms to locate an element]:ms:' \
        '(-T --jest-timeout)'{-T+,--jest-timeout=}'[max ms to wait for a test]:ms:' \
        '(-x --proxy-type)'{-x+,--proxy-type=}'[proxy type]:type:(direct manual pac socks system)' \
        '(-y --proxy-options)'{-y+,--proxy-options=}'[proxy options]:opts:' \
        '(-n --config-file)'{-n+,--config-file=}'[YAML config file]:file:_files -g "*.(yml|yaml)"' \
        '(-o --output-directory)'{-o+,--output-directory=}'[write test results JSON to dir]:dir:_files -/' \
        '(-z --screenshot-failure-directory)'{-z+,--screenshot-failure-directory=}'[write failure screenshots to dir]:dir:_files -/' \
        '(-d --debug)'{-d,--debug}'[print debug logs]' \
        '(-D --debug-startup)'{-D,--debug-startup}'[print debug startup logs]' \
        '(-X --debug-connection-mode)'{-X,--debug-connection-mode}'[debug driver connection mode]' \
        '*:side project glob:_files -g "*.side"'
}

_selenium-side-runner "$@"
