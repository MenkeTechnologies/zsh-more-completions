#compdef TileImages
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/TileImages.cxx — tile multiple images into a single output (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:outputImage:_files' \
    '3:layout (e.g. 2x2x1; trailing 0 means auto):_default' \
    '*:input images:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    && ret=0

return ret
