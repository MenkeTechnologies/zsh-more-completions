#compdef hwi hardware-wallet-interface
# _hwi — Bitcoin Core hwi hardware-wallet-interface CLI providing a unified interface to Trezor Ledger Coldcard BitBox KeepKey hardware wallets supporting xpub PSBT message-signing display-address fingerprint walletexport (bitcoin-core team, Python); argparse
# upstream: https://github.com/bitcoin-core/HWI

_hwi() {
    local -a sub=(
        'enumerate:list connected hardware wallets'
        'getmasterxpub:get master xpub'
        'getxpub:get xpub at derivation'
        'signtx:sign PSBT'
        'signmessage:sign message'
        'getkeypool:get keypool'
        'displayaddress:display address on device'
        'setup:setup device'
        'wipe:wipe device'
        'restore:restore device'
        'backup:backup device'
        'promptpin:prompt PIN'
        'sendpin:send PIN'
        'installdriver:install driver'
        'getdescriptors:get descriptors'
        'togglepassphrase:toggle passphrase'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device path]:str:' \
        '--device-path=+[device path]:str:' \
        '-t+[device type]:t:(trezor ledger coldcard keepkey digitalbitbox bitbox02 jade)' \
        '--device-type=+[device type]:t:(trezor ledger coldcard keepkey digitalbitbox bitbox02 jade)' \
        '-f+[fingerprint]:str:' \
        '--fingerprint=+[fingerprint]:str:' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--passphrase=+[passphrase]:str:' \
        '--testnet[use testnet]' \
        '--chain=+[c]:c:(main test signet regtest)' \
        '--stdinpass[read password from stdin]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--emulators[also use emulators]' \
        '--interactive[interactive mode]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hwi subcommand' sub ;;
        args)
            case $words[1] in
                getxpub|displayaddress) _arguments \
                    '--path=+[derivation]:str:' \
                    '--desc=+[descriptor]:str:' \
                    '*:path:' ;;
                signtx) _arguments '*:PSBT:' ;;
                signmessage) _arguments \
                    '--path=+[derivation]:str:' \
                    '*:message:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_hwi "$@"
