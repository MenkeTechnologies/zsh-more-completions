#compdef iceberg-cli
# _iceberg-cli — Apache Iceberg table format CLI (Apache Software Foundation, Java); picocli
# upstream: https://github.com/apache/iceberg

_iceberg-cli() {
    local -a sub=(
        'list:list tables/namespaces'
        'describe:describe table'
        'create:create table'
        'drop:drop table'
        'snapshot:manage snapshots'
        'rewrite:rewrite data files'
        'expire:expire snapshots'
        'rollback:rollback to snapshot'
        'show:show table operations'
        'history:show table history'
        'manifest:dump manifests'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--catalog=+[catalog name]:name:' \
        '--uri=+[catalog uri]:uri:' \
        '--warehouse=+[warehouse path]:path:_files -/' \
        '--namespace=+[namespace]:ns:' \
        '--table=+[table name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'iceberg-cli subcommand' sub ;;
        args)
            case $words[1] in
                list) _arguments \
                    '--namespace=+[namespace]:ns:' ;;
                describe|drop|history) _arguments \
                    '1:table:' ;;
                create) _arguments \
                    '1:table:' \
                    '--schema-file=+[schema file]:file:_files' \
                    '--partition-spec=+[partition spec]:str:' \
                    '--sort-order=+[sort order]:str:' \
                    '--location=+[location]:path:_files -/' \
                    '--properties=+[properties]:str:' ;;
                snapshot) _arguments \
                    '1:cmd:(list create-tag create-branch fast-forward cherry-pick)' \
                    '--snapshot-id=+[snapshot id]:id:' \
                    '--ref=+[ref name]:str:' ;;
                rewrite) _arguments \
                    '1:cmd:(data-files manifests)' \
                    '--target-file-size=+[target file size]:n:' \
                    '--max-concurrent-file-group-rewrites=+[concurrency]:n:' ;;
                expire) _arguments \
                    '--older-than=+[older than ms]:n:' \
                    '--retain-last=+[retain last n]:n:' ;;
                rollback) _arguments \
                    '1:table:' \
                    '--snapshot-id=+[snapshot id]:id:' ;;
                show) _arguments \
                    '1:cmd:(operations files partitions manifests refs)' \
                    '1:table:' ;;
                manifest) _arguments \
                    '1:cmd:(dump diff)' \
                    '*:file:_files' ;;
            esac
            ;;
    esac
}

_iceberg-cli "$@"
