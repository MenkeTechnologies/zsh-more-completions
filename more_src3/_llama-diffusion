#compdef llama-diffusion llama-diffusion-cli
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/examples/diffusion/diffusion-cli.cpp
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/common/arg.cpp
# Reference accessed: 2026-05-27
# Verified: upstream LLAMA_EXAMPLE_DIFFUSION-tagged args in common/arg.cpp + diffusion-cli.cpp params access

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[model path]:model:_files -g "*.gguf"' \
  '--model=[model path]:model:_files -g "*.gguf"' \
  '-p+[prompt text]:prompt' \
  '--prompt=[prompt text]:prompt' \
  '-f+[file containing the prompt]:file:_files' \
  '--file=[file containing the prompt]:file:_files' \
  '-sys+[system prompt]:prompt' \
  '--system-prompt=[system prompt]:prompt' \
  '-sysf+[file containing system prompt]:file:_files' \
  '--system-prompt-file=[file containing system prompt]:file:_files' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-b+[logical batch size]:size' \
  '--batch-size=[logical batch size]:size' \
  '-ub+[physical micro batch size]:size' \
  '--ubatch-size=[physical micro batch size]:size' \
  '-t+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '-tb+[threads for batch processing]:threads' \
  '--threads-batch=[threads for batch processing]:threads' \
  '-ngl+[number of layers to store in VRAM]:layers' \
  '--gpu-layers=[number of layers to store in VRAM]:layers' \
  '--split-mode=[how to split the model]:mode:(none layer row)' \
  '--main-gpu=[main GPU]:gpu' \
  '--tensor-split=[how to split tensors]:split' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force keep model in RAM]' \
  '-s+[RNG seed]:seed' \
  '--seed=[RNG seed]:seed' \
  '--temp=[temperature]:value' \
  '--top-k=[top-k sampling]:k' \
  '--top-p=[top-p sampling]:p' \
  '-fa[enable flash attention]' \
  '--flash-attn[enable flash attention]' \
  '--cache-type-k=[KV cache data type for K]:type:(f16 f32 q4_0 q4_1 q5_0 q5_1 q8_0)' \
  '--cache-type-v=[KV cache data type for V]:type:(f16 f32 q4_0 q4_1 q5_0 q5_1 q8_0)' \
  '--diffusion-steps=[number of diffusion steps]:n' \
  '--diffusion-visual[enable visual diffusion mode (show progressive generation)]' \
  '--diffusion-eps=[epsilon for timesteps]:f' \
  '--diffusion-algorithm=[diffusion algorithm 0..4 (origin, entropy, margin, random, confidence)]:n:(0 1 2 3 4)' \
  '--diffusion-alg-temp=[dream algorithm temperature]:f' \
  '--diffusion-block-length=[llada block length for generation]:n' \
  '--diffusion-cfg-scale=[llada classifier-free guidance scale]:f' \
  '--diffusion-add-gumbel-noise=[add gumbel noise to logits if temp > 0]:f' && ret=0

return ret
