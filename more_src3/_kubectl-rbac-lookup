#compdef kubectl-rbac-lookup
# kubectl-rbac-lookup (krew plugin): find roles and cluster roles attached to a user, group, or service account
# https://github.com/FairwindsOps/rbac-lookup

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-e --gke)'{-e,--gke}'[include GKE IAM bindings]' \
  '(-k --kind)'{-k+,--kind=}'[filter by subject kind]:kind:(User Group ServiceAccount)' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(default wide)' \
  '1:subject name pattern'
