#compdef libreoffice scalc
# _libreoffice-calc — LibreOffice scalc / soffice --calc (spreadsheet entrypoint; --headless runs without UI, --convert-to format produces a converted file, --outdir output directory, --calc forces opening in Calc, --norestore skips crash recovery, --safe-mode boots safe-mode)
# upstream: https://git.libreoffice.org/core (sfx2/source/appl/sfxhelp.cxx etc.)
# Flags from libreoffice core/desktop/source/app on tip.

_libreoffice-calc() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--headless[run without UI]' \
        '--invisible[invisible (no splash)]' \
        '--norestore[skip restoring previous session]' \
        '--nologo[no splash]' \
        '--nodefault[no default doc]' \
        '--nofirststartwizard[skip first-start wizard]' \
        '--safe-mode[start in safe mode]' \
        '--convert-to+[convert to format]:format:(pdf csv xlsx ods xls fods html)' \
        '--outdir+[output directory]:dir:_files -/' \
        '--print-to-file[print to file]' \
        '--printer-name+[printer]:printer:_printers' \
        '*-env+[env var]:key=value:' \
        '*--accept+[UNO accept-string]:accept:' \
        '*:spreadsheet:_files -g "*.(ods|xlsx|xls|csv|tsv|fods|gnumeric|123|wb2)"'
}

_libreoffice-calc "$@"
