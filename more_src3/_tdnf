#compdef tdnf
# Documentation: https://github.com/vmware/tdnf (tools/cli/lib/parseargs.c)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'autoerase:auto remove packages'
  'check:check rpm db'
  'check-update:check for updates'
  'clean:remove cached files'
  'distro-sync:synchronize to repo state'
  'downgrade:downgrade package'
  'erase:remove packages'
  'help:show help'
  'history:show transaction history'
  'info:package info'
  'install:install package'
  'list:list packages'
  'makecache:update cache'
  'mark:mark install reason'
  'provides:find packages providing'
  'reinstall:reinstall packages'
  'remove:remove packages'
  'repolist:list repositories'
  'repoquery:query packages from repos'
  'reposync:sync repository packages locally'
  'repository-packages:operate on repo packages'
  'search:search packages'
  'update:update packages'
  'updateinfo:show update advisories'
  'upgrade:upgrade packages'
  'upgrade-to:upgrade to specific version'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-y --assumeyes)'{-y,--assumeyes}'[assume yes]' \
  '--assumeno[assume no]' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-d --debuglevel)'{-d+,--debuglevel=}'[debug level]:level:' \
  '(-i --installroot)'{-i+,--installroot=}'[installroot]:dir:_files -/' \
  '--alldeps[include all deps]' \
  '--allowerasing[allow erasing for resolution]' \
  '--best[try newest only]' \
  '--builddeps[include build deps]' \
  '--cacheonly[use cache only]' \
  '--debugsolver[debug solver]' \
  '--disableexcludes[disable excludes]' \
  '--disableplugin=[disable plugin]:plugin:' \
  '--disablerepo=[disable repo]:repo:' \
  '--downloaddir=[download dir]:dir:_files -/' \
  '--downloadonly[download only]' \
  '--enableplugin=[enable plugin]:plugin:' \
  '--enablerepo=[enable repo]:repo:' \
  '--exclude=[exclude packages]:list:' \
  '--forcearch=[force architecture]:arch:' \
  '--json[JSON output]' \
  '--noautoremove[disable autoremove]' \
  '--nodeps[no dependency check]' \
  '--nogpgcheck[skip GPG check]' \
  '--nocligpgcheck[skip command line GPG check]' \
  '--noplugins[disable plugins]' \
  '--refresh[force refresh metadata]' \
  '--releasever=[release version]:ver:' \
  '--reboot-required[show if reboot needed]' \
  '--repo=[only this repo]:repo:' \
  '--repofromdir=[repo from directory]:spec:' \
  '--repofrompath=[id,baseurl path]:spec:' \
  '--repoid=[repo id]:repo:' \
  '--rpmverbosity=[rpm verbosity]:lvl:(emergency alert critical error warn notice info debug)' \
  '--rpmdefine=[rpm macro define]:def:' \
  '--sec-severity=[severity]:sev:' \
  '--security[security updates only]' \
  '--setopt=[set/override option]:opt:' \
  '--skip-broken[skip broken deps]' \
  '--skipconflicts[skip conflicts]' \
  '--skipdigest[skip digest check]' \
  '--skipobsoletes[skip obsoletes]' \
  '--skipsignature[skip signature check]' \
  '--source[operate on source packages]' \
  '--testonly[only test]' \
  '--urls[print URLs of packages]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tdnf command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list|repoquery)
        _values 'list type' 'all' 'installed' 'available' 'updates' 'upgrades' 'extras' 'obsoletes' 'recent' 'downgrades' 'userinstalled' && ret=0 ;;
      (clean)
        _values 'what' 'all' 'packages' 'metadata' 'dbcache' && ret=0 ;;
      (updateinfo)
        _values 'subcommand' 'list' 'info' 'summary' && ret=0 ;;
    esac ;;
esac

return ret
