#compdef sshd-session
# Documentation: man sshd-session(8)
# Source: openssh/openssh-portable sshd-session.c (master) — per-connection SSH server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-4[force IPv4]' \
    '-6[force IPv6]' \
    '-D[do not detach from controlling terminal]' \
    '-G[parse configuration and dump merged config]' \
    '-Q[ignored for compatibility]' \
    '-R[ignored — handled by sshd parent]' \
    '-T[test config validity and exit]' \
    '-V[show version]' \
    '-d[debug mode; do not fork (repeat for more verbosity)]' \
    '-e[write log to stderr instead of syslog]' \
    '-i[run from inetd]' \
    '-q[quiet; do not send anything to system log]' \
    '-r[ignored — handled by sshd parent]' \
    '-t[test only config and key validity]' \
    '-b+[number of SSHv1 server-key bits]:bits:_default' \
    '-C+[connection spec user:host:addr for -T]:connspec:_default' \
    '-c+[host certificate file]:certfile:_files' \
    '-E+[append log to file]:logfile:_files' \
    '-f+[alternate sshd_config]:config:_files -g "*.{conf,config}"' \
    '-g+[grace login time (seconds)]:seconds:_default' \
    '-h+[host key file (repeatable)]:keyfile:_files' \
    '-k+[server key regeneration interval (seconds)]:seconds:_default' \
    '-o+[override config option (key=value)]:option:_default' \
    '-p+[listen port]:port:_default' \
    '-u+[size of utmp host field]:size:_default' \
    && ret=0

return ret
