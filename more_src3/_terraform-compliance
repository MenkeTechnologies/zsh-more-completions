#compdef terraform-compliance
# Documentation: https://terraform-compliance.com/pages/usage/
# Reference accessed: 2026-06-04

# Zsh completion for terraform-compliance - BDD testing for Terraform

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --features)'{-f,--features}'=[BDD feature directory]:directory:_directories' \
  '(-p --planfile)'{-p,--planfile}'=[Terraform plan file]:file:_files' \
  '--cucumber-json=[cucumber JSON output file]:file:_files' \
  '--no-failure[do not return failure exit code]' \
  '--silent[suppress output]' \
  '(-S --identity)'{-S,--identity}'=[SSH identity file for remote features]:file:_files' \
  '--quit-early[quit on first failure]'
