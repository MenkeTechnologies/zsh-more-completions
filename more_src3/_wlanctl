#compdef wlanctl
# Documentation: man wlanctl(8)
# Source: netbsd/src usr.sbin/wlanctl — print 802.11 node tables (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[print only nodes without encryption]' \
    '(*)-a[print nodes for all interfaces]' \
    '*:interface:_net_interfaces' \
    && ret=0

return ret
