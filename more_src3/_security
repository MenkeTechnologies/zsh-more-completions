#compdef security
# Documentation: https://www.unix.com/man-page/osx/1/security/
# Source: Apple macOS — keychain / certificate / identity CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '-h[show command list or per-command usage]' \
    '-i[run in interactive mode]' \
    '-l[run leaks(1) on process before exit]' \
    '-p[interactive mode with custom prompt]:prompt:' \
    '-q[reduce verbosity]' \
    '-v[increase verbosity]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'list-keychains:display or modify keychain search list'
            'default-keychain:display or set default keychain'
            'login-keychain:display or set login keychain'
            'create-keychain:create new keychain'
            'delete-keychain:delete keychain from search list'
            'lock-keychain:lock specified or all keychains'
            'unlock-keychain:unlock keychain(s)'
            'set-keychain-settings:configure keychain behavior'
            'set-keychain-password:change keychain password'
            'add-generic-password:store generic password item'
            'find-generic-password:retrieve generic password'
            'delete-generic-password:remove generic password'
            'add-internet-password:store internet password'
            'find-internet-password:retrieve internet password'
            'delete-internet-password:remove internet password'
            'find-certificate:locate a certificate item'
            'find-identity:list identities (cert+key pair)'
            'add-certificates:import certificates into keychain'
            'delete-certificate:remove certificate from keychain'
            'create-keypair:generate asymmetric key pair'
            'import:import items into keychain'
            'export:export keychain items to external format'
            'add-trusted-cert:add trusted certificate'
            'remove-trusted-cert:remove trusted certificate'
            'dump-trust-settings:display trust settings'
            'verify-cert:validate certificate chain'
            'help:print help'
        )
        _describe -t subcmds 'security command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
