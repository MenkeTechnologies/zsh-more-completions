#compdef shotcut
# Documentation: https://www.shotcut.org/
# Reference accessed: 2026-05-21
# Verified: Shotcut is a Qt-based GUI video editor; no canonical CLI flag
# documentation exists upstream. App accepts file arguments and inherits
# standard Qt options (-style, -platform, etc.) from QApplication.
# STUB: file argument only; per-app CLI flags not documented upstream.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:file:_files -g "*.{mlt,xml,mp4,mkv,avi,mov,webm,flv,mpg,mpeg,wmv,ogv,wav,mp3,ogg,flac,png,jpg,jpeg,gif,svg}"' && ret=0

return ret
