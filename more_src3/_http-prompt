#compdef http-prompt
# Documentation: https://docs.http-prompt.com/en/latest/user-guide.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# http-prompt - interactive command-line HTTP client built on HTTPie and prompt_toolkit.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--spec=[OpenAPI/Swagger spec path or URL]:spec:_files' \
  '--env=[saved session file to load]:env:_files' \
  '1::URL:_urls' \
  '*::http-prompt arg:' && ret=0

return ret
