#compdef lighthouse-coredns
# _lighthouse-coredns — Submariner Lighthouse CoreDNS distribution (vanilla CoreDNS + the lighthouse plugin that resolves clusterset.local. names)
# upstream: https://github.com/submariner-io/lighthouse
# Flags from coredns/main.go on tip; reuses every CoreDNS flag (-conf, -dns.port, -dns.address, -plugins, -version).

_lighthouse-coredns() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--subm-version[show Submariner Lighthouse version]' \
        '-conf=[location of the Corefile]:file:_files' \
        '-dns.port=[override DNS UDP/TCP port]:port:' \
        '-dns.address=[override DNS bind address]:addr:' \
        '-pidfile=[write a pid file]:file:_files' \
        '-plugins[list registered plugins]' \
        '-quiet[suppress startup messages]' \
        '-version[show CoreDNS version]'
}

_lighthouse-coredns "$@"
