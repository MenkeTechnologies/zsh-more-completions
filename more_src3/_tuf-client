#compdef tuf-client
# _tuf-client — client-side CLI implementing TUF client workflow (theupdateframework/go-tuf)
# upstream: https://github.com/theupdateframework/go-tuf
# Subcommands from examples/cli/tuf-client/cmd/ (cobra).

_tuf-client() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-u --url)'{-u+,--url=}'[URL of the TUF repository]:url:_urls' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                init:'initialize client with trusted root.json metadata'
                i:'initialize client with trusted root.json metadata'
                get:'download a target from the repository'
                reset:'reset client state and delete local metadata/downloads'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                init|i)
                    _arguments \
                        '(-f --file)'{-f+,--file=}'[trusted root metadata file]:file:_files' ;;
                get)
                    _arguments \
                        '(-t --turl)'{-t+,--turl=}'[URL where target files are hosted]:url:_urls' \
                        '--nonprefixed[do not use hash-prefixed target filenames]' \
                        '1:target name:' ;;
            esac
            ;;
    esac
}

_tuf-client "$@"
