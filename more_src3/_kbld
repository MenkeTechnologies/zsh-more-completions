#compdef kbld
# Documentation: https://github.com/carvel-dev/kbld/blob/develop/pkg/kbld/cmd/kbld.go
# Reference accessed: 2026-05-19
# Verified: upstream carvel-dev/kbld cobra command tree. The root
# command IS resolve (kbld.go: NewResolveCmd then Use="kbld"), so
# bare `kbld -f ...` resolves; there is no `resolve`/`completion`
# subcommand (default completion cmd is disabled). Subcommands are
# inspect/package(pkg)/unpackage(unpkg)/version/relocate.

local curcontext="$curcontext" state line ret=1

# Persistent UI flags (KbldOptions.UIFlags.Set)
local -a global_flags=(
  '(- *)'{-h,--help}'[show help]'
  '--version[show version]'
  '--tty[force TTY-like output]'
  '--color[set color output]'
  '--json[output as JSON]'
  '(-y --yes)'{-y,--yes}'[assume yes for any prompt]'
  '*--column=[filter to show only given columns]:columns:'
)

_arguments -s -S -C \
  "${global_flags[@]}" \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'inspect:inspect images in resources'
      'package:package images into a tarball'
      'pkg:package images into a tarball'
      'unpackage:unpackage images from a tarball'
      'unpkg:unpackage images from a tarball'
      'relocate:relocate images between registries'
      'version:print version'
    )
    _describe -t commands 'kbld command' commands && ret=0
    ;;
  args)
    case $line[1] in
      (inspect|i|is|insp)
        _arguments -s -S \
          "${global_flags[@]}" \
          '*'{-f,--file}'+[set file (path, URL, or -)]:file:_files' \
          '--sort[sort by namespace, name, etc.]' && ret=0
        ;;
      (package|pkg)
        _arguments -s -S \
          "${global_flags[@]}" \
          '*'{-f,--file}'+[set file (path, URL, or -)]:file:_files' \
          '--sort[sort by namespace, name, etc.]' \
          '(-o --output)'{-o,--output}'+[output tarball path]:file:_files' \
          '--concurrency=[maximum number of concurrent imports]:count:' && ret=0
        ;;
      (unpackage|unpkg)
        _arguments -s -S \
          "${global_flags[@]}" \
          '*'{-f,--file}'+[set file (path, URL, or -)]:file:_files' \
          '--sort[sort by namespace, name, etc.]' \
          '(-i --input)'{-i,--input}'+[input tarball path]:file:_files' \
          '(-r --repository)'{-r,--repository}'+[import images into given image repository]:repo:' \
          '--lock-output=[file path to emit resolved image references]:file:_files' \
          '--concurrency=[maximum number of concurrent imports]:count:' && ret=0
        ;;
      (relocate)
        _arguments -s -S \
          "${global_flags[@]}" \
          '*'{-f,--file}'+[set file (path, URL, or -)]:file:_files' \
          '--sort[sort by namespace, name, etc.]' \
          '(-r --repository)'{-r,--repository}'+[import images into given image repository]:repo:' \
          '--lock-output=[file path to emit resolved image references]:file:_files' \
          '--concurrency=[maximum number of concurrent imports]:count:' && ret=0
        ;;
      (version)
        _arguments -s -S "${global_flags[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
