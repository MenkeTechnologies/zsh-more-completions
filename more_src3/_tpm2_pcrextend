#compdef tpm2_pcrextend
# _tpm2_pcrextend — tpm2-software tpm2_pcrextend extend a TPM2 PCR with one or more data hashes (tpm2-software team, C); custom argparse
# upstream: https://github.com/tpm2-software/tpm2-tools

_tpm2_pcrextend() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--cphash=+[cp hash file]:file:_files' \
        '*:pcr extension:'
}

_tpm2_pcrextend "$@"
