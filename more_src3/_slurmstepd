#compdef slurmstepd
# Documentation: source-direct extraction from upstream
# SchedMD/slurm src/slurmd/slurmstepd/slurmstepd.c
# `_process_cmdline(int argc, char **argv)` body — slurmstepd
# is invoked internally by slurmd over a socket with a special-
# mode positional argv pattern instead of a conventional
# getopt parse.  The 4 modes here are the only user-callable
# entry points.
# Reference accessed: 2026-05-30 via gh api.
# SchedMD slurm R162b — slurmstepd is the per-job step daemon
# spawned by slurmd to manage a single job step's namespaces,
# rlimits, SPANK plugin loading, and OOM management on a node.
# Sister daemon to slurmd + slurmctld + slurmdbd (the latter
# added in this same round).

local -a modes=(
  'getenv:print job-step rlimits + environ then exit'
  'infinity:enter -1000 OOM-adj poll loop forever'
  'ns_infinity:like infinity but inside a namespace (needs cgroup name)'
  'spank:invoke SPANK-plugin handler in given mode'
)

_arguments -C \
  '1:special mode:->mode' \
  '*:: :->modeargs'

case $state in
  mode)
    _describe -t modes 'slurmstepd special mode' modes
    ;;
  modeargs)
    case $words[1] in
      ns_infinity)
        _message 'cgroup namespace name'
        ;;
      spank)
        _message 'SPANK plugin mode token'
        ;;
    esac
    ;;
esac
