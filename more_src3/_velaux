#compdef velaux
# _velaux — KubeVela VelaUX server (kubevela/velaux)
# upstream: https://github.com/kubevela/velaux
# Flags from pkg/server/config/config.go (pflag).

_velaux() {
    _arguments \
        '--bind-addr=[HTTP API bind address]:host\:port:' \
        '--metrics-path=[metrics endpoint path]:path:' \
        '--datastore-type=[metadata storage driver]:type:(kubeapi mongodb)' \
        '--datastore-database=[mongo database name]:name:' \
        '--datastore-url=[mongo database URL]:url:_urls' \
        '--id=[leader holder identity]:id:' \
        '--lock-name=[leader lease lock resource name]:name:' \
        '--duration=[leader lease duration]:duration:' \
        '--addon-cache-duration=[addon cache interval]:duration:' \
        '--disable-statistic-cronJob[disable statistic cron job]' \
        '--kube-api-burst=[burst for kube clients]:n:' \
        '--workflow-version=[workflow controller version]:ver:' \
        '--dex-server=[Dex server URL]:url:_urls' \
        '--exit-on-lost-leader[exit when leader election lost]'
}

_velaux "$@"
