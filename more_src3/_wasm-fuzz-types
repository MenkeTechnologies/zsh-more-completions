#compdef wasm-fuzz-types
# Documentation: https://github.com/WebAssembly/binaryen/blob/main/src/tools/wasm-fuzz-types.cpp
# Documentation: https://github.com/WebAssembly/binaryen/blob/main/src/support/command-line.cpp
# Reference accessed: 2026-05-27
# Verified: upstream src/tools/wasm-fuzz-types.cpp main() uses bare Options (no ToolOptions feature flags)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--version[output version information and exit]' \
  '(-h --help)'{-h,--help}'[show help message and exit]' \
  '(-d --debug)'{-d,--debug}'[print debug information to stderr]:context (optional):' \
  '--seed=[run a single workload generated by the given seed]:seed:' \
  '(-v --verbose)'{-v,--verbose}'[print extra information]' && ret=0

return ret
