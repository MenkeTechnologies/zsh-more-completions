#compdef sample
# Documentation: man sample(1) (macOS)
# Source: macOS sample — profile a process during a time interval (call-stack sampler).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-wait[wait for target process to exist then start sampling]' \
    '-mayDie[grab symbols immediately (target may exit during sampling)]' \
    '-fullPaths[show full source paths]' \
    '-e[open output in TextEdit when done]' \
    '-file+[output file path]:file:_files' \
    '1:pid or partial-executable-name:_pids' \
    '2:duration (seconds):' \
    '3:samplingInterval (ms):' \
    && ret=0

return ret
