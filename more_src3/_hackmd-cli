#compdef hackmd-cli
# ============================================================================
#  _hackmd-cli — The HackMD Command Line Tool
#
#  Source-direct extraction from
#    https://github.com/hackmdio/hackmd-cli/tree/master/src/commands
#    https://github.com/oclif/core (the oclif framework itself)
#
#  Authored by HackMD.io.  143 GH stars.  Manages HackMD (collaborative
#  markdown editor, hackmd.io) notes, folders, teams via API.  Reads
#  ~/.config/@hackmd/hackmd-cli/config.json for API token persistence.
#
#  CLI library taxonomy update: first documented TypeScript/Node entry +
#  first documented oclif framework.  hackmd-cli uses Salesforce's
#  `@oclif/core` — `import {Flags, ux} from '@oclif/core'` brings the
#  decorator-style command framework into scope.  oclif is CLASS-INHERITANCE
#  -WITH-STATIC-FIELDS declarative API: each command is a TypeScript
#  CLASS extending a base `Command` class with STATIC FIELDS
#  (`static description = '...'`, `static flags = {...}`, `static args = {...}`,
#  `static examples = [...]`) + async `run()` method dispatched via
#  reflection at parse time.  Commands live in `src/commands/<verb>.ts`
#  with NESTED subcommand groups via `src/commands/<group>/<verb>.ts` —
#  oclif walks the FILESYSTEM HIERARCHY to discover commands.  Brings
#  cross-language CLI library taxonomy variant count to 79.
#
#  Surface (verbatim from src/commands/ filesystem hierarchy):
#    Top-level commands:
#      export       Export note content
#      history      Show user's history
#      login        Login to HackMD
#      logout       Logout from HackMD
#      whoami       Show current user information
#      teams        List user's teams
#
#    Command groups (each with sub-verbs):
#      notes          create / delete / index / update
#      folders        create / delete / index / order / update
#      team-notes     create / delete / index / update
#      team-folders   create / delete / index / order / update
#
#    Universal flags (oclif Flags.help + ux.table.flags):
#      -h, --help            Show command help
#      --columns=COLS        Only show provided columns (table output)
#      --sort=COL            Property to sort by
#      --filter=PROPERTY=V   Filter property by partial string match
#      --csv                 Output as CSV
#      --extended            Show extra columns
#      --no-truncate         Do not truncate output
#      --no-header           Hide table header
#      --output=FORMAT       Output format: csv / json / yaml
#
#    Note/folder management flags:
#      --noteId=ID                   Target note ID
#      --content=TEXT                Note content (markdown)
#      --editor                      Open $EDITOR to compose content
#      --parentFolderId=ID           Parent folder for the note
#      --readPermission=ROLE         owner / signed_in / guest
#      --writePermission=ROLE        owner / signed_in / guest
#      --commentPermission=POLICY    disabled / forbidden / owners / signed_in_users / everyone
#      --tags=CSV                    Comma-separated tags
#      --title=STRING                Note title
#
#  Dup-skipped neighbors during hunt (unfit for taxonomy delta):
#    - oclif (oclif/oclif 9535 stars, the framework generator itself —
#      would be useful but is a DUP target for oclif-framework concept;
#      hackmd-cli is a better demonstration of oclif-AS-CLIENT)
#    - shopify/cli (702 stars but is multi-tenant huge product)
#    - snipli (155 stars, code snippet sharer — narrow surface)
# ============================================================================

_hackmd-cli() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show command help]' \
    '1: :->top' \
    '*:: :->subargs'

  case $state in
    top)
      local -a verbs
      verbs=(
        'export:export note content'
        'history:show user history'
        'login:login to HackMD'
        'logout:logout from HackMD'
        'whoami:show current user information'
        'teams:list user teams'
        'notes:note management (create/delete/index/update)'
        'folders:folder management (create/delete/index/order/update)'
        'team-notes:team note management'
        'team-folders:team folder management'
      )
      _describe -t commands 'hackmd-cli command' verbs
      ;;
    subargs)
      case $line[1] in
        notes|team-notes)
          if [[ $CURRENT == 2 ]]; then
            local -a sub=(
              'create:create a note'
              'delete:delete a note'
              'index:list notes'
              'update:update a note'
            )
            _describe -t subcommands "$line[1] subcommand" sub
          else
            _hackmd-cli_note_flags
          fi
          ;;
        folders|team-folders)
          if [[ $CURRENT == 2 ]]; then
            local -a sub=(
              'create:create a folder'
              'delete:delete a folder'
              'index:list folders'
              'order:reorder folders'
              'update:update a folder'
            )
            _describe -t subcommands "$line[1] subcommand" sub
          else
            _hackmd-cli_folder_flags
          fi
          ;;
        export)
          _arguments -s -S \
            '(-h --help)'{-h,--help}'[show help]' \
            '--noteId=[note ID to export]:note id'
          ;;
        login)
          _arguments -s -S \
            '(-h --help)'{-h,--help}'[show help]' \
            '--email=[HackMD account email]:email' \
            '--password=[HackMD password]:password'
          ;;
        history|whoami|teams|logout)
          _hackmd-cli_table_flags
          ;;
      esac
      ;;
  esac
}

_hackmd-cli_table_flags() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '--columns=[columns to show]:column names' \
    '--sort=[sort by column]:column' \
    '--filter=[filter property=value]:filter' \
    '--csv[output as CSV]' \
    '--extended[show extra columns]' \
    '--no-truncate[do not truncate output]' \
    '--no-header[hide table header]' \
    '--output=[output format]:format:(csv json yaml)'
}

_hackmd-cli_note_flags() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '--noteId=[target note ID]:note id' \
    '--content=[note content (markdown)]:markdown' \
    '--editor[open EDITOR to compose content]' \
    '--parentFolderId=[parent folder ID]:folder id' \
    '--readPermission=[read permission role]:role:(owner signed_in guest)' \
    '--writePermission=[write permission role]:role:(owner signed_in guest)' \
    '--commentPermission=[comment policy]:policy:(disabled forbidden owners signed_in_users everyone)' \
    '--tags=[comma-separated tags]:tags' \
    '--title=[note title]:title' \
    '--columns=[columns to show]:columns' \
    '--output=[output format]:format:(csv json yaml)'
}

_hackmd-cli_folder_flags() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '--folderId=[folder ID]:folder id' \
    '--name=[folder name]:name' \
    '--parentFolderId=[parent folder ID]:parent folder id' \
    '--columns=[columns to show]:columns' \
    '--output=[output format]:format:(csv json yaml)'
}

_hackmd-cli "$@"
