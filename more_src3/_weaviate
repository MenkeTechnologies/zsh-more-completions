#compdef weaviate
# Documentation: https://github.com/weaviate/weaviate
# Reference accessed: 2026-05-21
# Verified: upstream uses go-openapi/flags library with standard server flags.

_arguments -s \
  '*--scheme=[listener scheme]:scheme:(http https unix)' \
  '--cleanup-timeout=[shutdown grace]:duration:' \
  '--graceful-timeout=[graceful timeout]:duration:' \
  '--max-header-size=[max header size]:bytes:' \
  '--socket-path=[unix socket]:path:_files' \
  '--host=[bind host]:host:_hosts' \
  '--port=[port]:port:' \
  '--listen-limit=[listen limit]:n:' \
  '--keep-alive=[keep-alive]:duration:' \
  '--read-timeout=[read timeout]:duration:' \
  '--write-timeout=[write timeout]:duration:' \
  '--tls-host=[TLS bind host]:host:_hosts' \
  '--tls-port=[TLS port]:port:' \
  '--tls-certificate=[TLS cert]:file:_files' \
  '--tls-key=[TLS key]:file:_files' \
  '--tls-ca=[TLS CA]:file:_files' \
  '--tls-listen-limit=[TLS listen limit]:n:' \
  '--tls-keep-alive=[TLS keep-alive]:duration:' \
  '--tls-read-timeout=[TLS read timeout]:duration:' \
  '--tls-write-timeout=[TLS write timeout]:duration:' \
  '--config-file=[config file]:file:_files -g "*.(yaml|yml|json)"' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]'
