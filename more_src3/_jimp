#                          surfaced via yargs at CLI launch from the
#                          jimp.prototype reflection)
#                 _jimp              [TS-Node=230 CLOSES Axis 175, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 jimp is the only npm image library that is COMPLETELY
#                 pure-JavaScript — sharp (the popular alternative)
#                 wraps libvips (C); gm shells out to ImageMagick;
#                 canvas wraps Cairo.  Jimp's pure-JS implementation
#                 means it runs on every JS runtime (Node, Bun, Deno,
#                 browser, Cloudflare Workers, edge functions) without
#                 native-binary distribution headaches.  Used by
#                 handwritten.js, qr-scanner-cli, node-sprite-
#                 generator, app-icon-badge, GDLauncher, yana,
#                 and every Node CLI that needs portable image
#                 manipulation without per-platform native binaries.
#
# Round-number 230 landmark fires simultaneously across all three lanes:
# Rust completion #230 (_noaa-apt) + Go completion #230 (_dotmatrix) +
# TS-Node completion #230 (_jimp) = triple-230.  Axis #168 closed in the
# lifetime of the corpus — every pure-language image processing library
# in the three big systems languages now has both a representative
# consumer completion AND a documented axis closure landmark; the lanes
# are tied together by a common design discipline (no native/CGO/system-
# C deps, single-binary or single-package distribution, in-process raster
# I/O).
# ============================================================================

_jimp() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '(-p --plugins)'{-p,--plugins=}'[Jimp plugins to load (e.g. @jimp/plugin-circle)]:plugin:'
        '(-t --types)'{-t,--types=}'[Jimp types to load (e.g. @jimp/jpeg)]:type:'
        '(-v --verbose)'{-v,--verbose}'[enable more logging]'
        '(-f --loadFont --font)'{-f,--loadFont=,--font=}'[path of font to load and use in text operations (.fnt BMFont)]:font file:_files -g "*.(fnt|FNT)"'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'--version'[print version]' \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'read:read an image into jimp (PNG/JPEG/TIFF/BMP/GIF) and apply actions'
                'create:create a new blank image with given width/height/background'
                'distance:calculate hamming distance of two images via perceptual hash'
                'diff:diff two images and optionally write the diff PNG'
                'rgbaToInt:helper — convert R,G,B,A (0-255) values to single integer'
                'intToRGBA:helper — convert integer (e.g. 0xFF0000FF) to R,G,B,A'
                'cssColorToHex:helper — convert CSS color (Hex/RGB/RGBA/HSL/HSLA/HSV/HSVA/Named) to hex number'
                'limit255:helper — clamp a number to 0..255'
                'compareHashes:helper — calculate hamming distance of two perceptual hashes'
                'colorDiff:helper — compute color difference between two {r,g,b,a} colors'
                'measureText:helper — measure how wide printing a string will be'
                'measureTextHeight:helper — measure how tall printing a string will be (args: text, width)'
            )
            _describe -t commands 'jimp command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                read)
                    _arguments \
                        $global_opts \
                        '(-o --output)'{-o,--output=}'[file to output from jimp (PNG/JPEG/TIFF/BMP)]:output file:_files' \
                        '*'{-a,--actions=}'[actions (image manipulation) to run on input — repeatable; e.g. -a greyscale -a "resize 150 -1"]:action:(greyscale invert flip mirror gaussian blur posterize sepia opacity fade convolute dither565 colour color brightness contrast quantize crop autocrop cover contain resize scale scaleToFit rotate circle displace fisheye mask composite blit print pixelate threshold shadow histogram)' \
                        '1:input image:_files -g "*.(png|PNG|jpg|JPG|jpeg|JPEG|tiff|TIFF|bmp|BMP|gif|GIF)"' && ret=0
                    ;;
                create)
                    _arguments \
                        $global_opts \
                        '(-w --width)'{-w,--width=}'[width of new image in pixels]:width:' \
                        '(--he --height)'{--he=,--height=}'[height of new image in pixels (alias `he` because -h is help)]:height:' \
                        '(-b --background)'{-b,--background=}'[background color (hex value or CSS string)]:color:' \
                        '(-o --output)'{-o,--output=}'[file to output from jimp (PNG/JPEG/TIFF/BMP)]:output file:_files' \
                        '*'{-a,--actions=}'[actions to run on the new image — repeatable]:action:' && ret=0
                    ;;
                distance|diff)
                    _arguments \
                        $global_opts \
                        '--outputDiff=[file to write diff PNG to (`diff` only)]:diff PNG:_files -g "*.(png|PNG)"' \
                        '1:image 1:_files -g "*.(png|PNG|jpg|JPG|jpeg|JPEG|tiff|TIFF|bmp|BMP|gif|GIF)"' \
                        '2:image 2:_files -g "*.(png|PNG|jpg|JPG|jpeg|JPEG|tiff|TIFF|bmp|BMP|gif|GIF)"' && ret=0
                    ;;
                rgbaToInt)
                    _arguments \
                        '1:R (0-255):' '2:G (0-255):' '3:B (0-255):' '4:A (0-255):' && ret=0
                    ;;
                intToRGBA)
                    _arguments '1:integer (e.g. 0xFF0000FF):' && ret=0
                    ;;
                cssColorToHex)
                    _arguments '1:CSS color (Hex/RGB/RGBA/HSL/HSLA/HSV/HSVA/Named):' && ret=0
                    ;;
                limit255)
                    _arguments '1:number to clamp to 0..255:' && ret=0
                    ;;
                compareHashes)
                    _arguments '1:hash 1:' '2:hash 2:' && ret=0
                    ;;
                colorDiff)
                    _arguments '1:color 1 (e.g. {r:255,g:0,b:0,a:255}):' '2:color 2:' && ret=0
                    ;;
                measureText|measureTextHeight)
                    _arguments \
                        '1:text:' \
                        '2:width (for measureTextHeight only):' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_jimp "$@"
