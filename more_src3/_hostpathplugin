#compdef hostpathplugin
# _hostpathplugin — CSI hostpath reference driver (test/development CSI driver for kubernetes-csi end-to-end testing)
# upstream: https://github.com/kubernetes-csi/csi-driver-host-path
# Flags from cmd/hostpathplugin/main.go on tip.

_hostpathplugin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--endpoint=[CSI endpoint]:uri:' \
        '--drivername=[name of the driver]:name:' \
        '--statedir=[directory for state across driver restarts]:dir:_files -/' \
        '--nodeid=[node id]:id:' \
        '--ephemeral[publish volumes in ephemeral mode]' \
        '--maxvolumespernode=[limit of volumes per node]:n:' \
        '*--capacity=[simulated capacity: <kind>=<bytes>]:spec:' \
        '--enable-attach[enable RPC_PUBLISH_UNPUBLISH_VOLUME]' \
        '--check-volume-lifecycle[downgrade volume-lifecycle violations to warnings]' \
        '--max-volume-size=[max volume size (bytes)]:n:' \
        '--enable-topology=[enable VOLUME_ACCESSIBILITY_CONSTRAINTS]:bool:(true false)' \
        '--enable-volume-expansion=[enable volume expansion]:bool:(true false)' \
        '--enable-controller-modify-volume[enable ControllerModifyVolume]' \
        '--enable-snapshot-metadata[enable Snapshot Metadata service]' \
        '--snapshot-metadata-block-type=[expected snapshot metadata block type]:type:(FIXED_LENGTH VARIABLE_LENGTH)' \
        '--accepted-mutable-parameter-names=[csv of parameter names mutable on PV]:csv:' \
        '--disable-controller-expansion[disable Controller volume expansion]' \
        '--disable-node-expansion[disable Node volume expansion]' \
        '--enable-list-snapshots=[enable RPC_LIST_SNAPSHOTS]:bool:(true false)' \
        '--max-volume-size-node=[max expanded volume size on node]:n:' \
        '--attach-limit=[max attachable volumes on a node (0 = unlimited)]:n:' \
        '--proxy-endpoint=[proxy connections from csiEndpoint to this listening socket]:socket:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_hostpathplugin "$@"
