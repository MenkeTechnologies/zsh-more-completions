#compdef jsrepo
# Documentation: https://www.jsrepo.dev/docs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (CLI command list).

# Zsh completion for jsrepo registry client (Node CLI)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:(add auth build exec info init mcp publish test tokens update)' \
  '*::args:_files' && ret=0

return ret
