#compdef semaphore sem
# _semaphore — Semaphore CI sem CLI (Render/Semaphore, Go); spf13/cobra
# upstream: https://github.com/semaphoreci/cli

_semaphore() {
    local -a sub=(
        'connect:connect CLI to organization'
        'context:manage contexts'
        'create:create resource'
        'delete:delete resource'
        'edit:edit resource'
        'get:get resource'
        'apply:apply resource yaml'
        'logs:show pipeline/job logs'
        'attach:attach to running job'
        'debug:debug job/project'
        'rebuild:rebuild workflow'
        'stop:stop workflow'
        'init:init project from current dir'
        'cancel:cancel workflow'
        'whoami:show current user'
        'change-organization:switch org'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--context=+[context]:ctx:' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sem subcommand' sub ;;
        args)
            case $words[1] in
                create|delete|edit|get|apply) _arguments \
                    '1:resource-kind:(project secret dashboard job notification self-hosted-agent-type)' \
                    '2:name:' \
                    '-f+[file]:file:_files -g "*.(yml|yaml)"' \
                    '--project-name=+[project]:str:' \
                    '*:arg:' ;;
                attach|logs|debug|rebuild|stop|cancel) _arguments \
                    '1:job-or-workflow-id:' \
                    '--project-name=+[project]:str:' ;;
                connect|change-organization) _arguments \
                    '1:organization:' ;;
                context) _arguments \
                    '1:cmd:(use list current delete)' \
                    '*:arg:' ;;
                init) _arguments \
                    '--project-name=+[project name]:str:' ;;
            esac
            ;;
    esac
}

_semaphore "$@"
