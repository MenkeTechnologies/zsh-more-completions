#compdef jsonlint
# Documentation: https://github.com/zaach/jsonlint/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jsonlint - JSON parser and validator (zaach/jsonlint)

_arguments -s -S \
  '(- *)'{-v,--version}'[print version and exit]' \
  '(-s --sort-keys)'{-s,--sort-keys}'[sort object keys]' \
  '(-i --in-place)'{-i,--in-place}'[overwrite the file]' \
  '(-t --indent)'{-t+,--indent=}'[character(s) to use for indentation]:char:' \
  '(-c --compact)'{-c,--compact}'[compact error display]' \
  '(-V --validate)'{-V+,--validate=}'[a JSON schema to use for validation]:schema file:_files' \
  '(-e --environment)'{-e+,--environment=}'[JSON Schema specification of the validation file]:env:(json-schema-draft-03 json-schema-draft-04)' \
  '(-q --quiet)'{-q,--quiet}'[do not print the parsed json to STDOUT]' \
  '(-p --pretty-print)'{-p,--pretty-print}'[force pretty printing even if invalid]' \
  '*:JSON file:_files -g "*.json"'
