#compdef kubespy
# Documentation: https://github.com/pulumi/kubespy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubespy - observe Kubernetes resources in real time.
# Subcommands derived from cmd/*.go (cobra) in the upstream repo. The tool
# uses positional arguments only; flags listed by cobra are help/version.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'status:emit changes to .status as JSON diff'
      'changes:emit changes to any field as JSON diff'
      'trace:trace changes and aggregate to a high-level summary'
      'record:emit changes to any field as a JSON array'
      'version:print kubespy version'
      'help:show help for a command'
    )
    _describe -t commands 'kubespy command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      (status|changes|record)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:apiVersion:' \
          '2:kind:' \
          '3:[namespace/]name:' && ret=0
        ;;
      (trace)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:kind:(service deployment)' \
          '2:[namespace/]name:' && ret=0
        ;;
      (version)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
