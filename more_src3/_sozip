#compdef sozip
# Documentation: https://gdal.org/en/stable/programs/sozip.html
# Source: OSGeo/gdal apps/sozip.cpp — Seek-Optimized ZIP (SOZip) archive utility.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--help-general[show generic GDAL options]' \
    '--quiet[suppress progress output]' \
    '--verbose[detailed output]' \
    '(-g --grow)'{-g,--grow}'[append files to existing zip]' \
    '--overwrite[replace target zip if present]' \
    '(-l --list)'{-l,--list}'[list files in zip with SOZip status]' \
    '(-r --recurse-paths)'{-r,--recurse-paths}'[process directories recursively]' \
    '(-j --junk-paths)'{-j,--junk-paths}'[store only filenames without paths]' \
    '--validate[verify SOZip file integrity]' \
    '--optimize-from=[convert existing zip to SOZip]:input.zip:_files -g "*.zip(-.)"' \
    '--enable-sozip=[control seek-optimization]:mode:(auto yes no)' \
    '--sozip-chunk-size=[chunk size in bytes (default 32768)]:bytes:_default' \
    '--sozip-min-file-size=[min size threshold (default 1M)]:size:_default' \
    '--content-type=[Content-Type metadata]:type:_default' \
    '1:zip file:_files -g "*.zip(-.)"' \
    '*:input files:_files' \
    && ret=0

return ret
