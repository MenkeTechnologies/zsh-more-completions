#compdef kubectl-access-matrix
# Documentation: https://github.com/corneliusweig/rakkess/blob/master/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# rakkess (kubectl access-matrix). The 'for <resource>' subcommand shows
# subject access; the root command shows the resource access matrix.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*--verbs=[show access for verbs]:verb:(create get list watch update patch delete deletecollection)' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(icon-table ascii-table)' \
  '--sa=[impersonate as service-account (namespace:sa-name)]:sa:' \
  '*--diff-with=[show diff for modified call]:key=value:' \
  '--verbosity=[log level]:level:(fatal error warning info debug)' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--as=[username to impersonate]:user:' \
  '*--as-group=[group to impersonate]:group:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context]:context:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '1:subcommand:(for resource version)' \
  '*:resource or argument:_default'
