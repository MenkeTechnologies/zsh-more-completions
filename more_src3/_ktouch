#compdef ktouch
# Documentation: https://apps.kde.org/ktouch/
# Reference accessed: 2026-05-16
# Verified: upstream KDE ktouch. Has 2 app-specific flags.
# Removed from prior file: bogus man.archlinux.org search URL.

# ktouch: KDE typing tutor
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '--resource-editor[launch course/keyboard layout editor]' \
  '(-I --import-path)'{-I+,--import-path=}'[prepend QML import path]:dir:_files -/' && ret=0
return ret
