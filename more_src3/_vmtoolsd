#compdef vmtoolsd
# _vmtoolsd — VMware open-vm-tools vmtoolsd (master VMX RPC daemon that loads guest-side plugins for clipboard, drag-and-drop, time synchronization, network info, statistics and HGFS; -b background, -c config file, -d disable plugin, -l log directory, -n plugin name match filter, -p plugin path, -h help, -V version; reads /etc/vmware-tools/tools.conf for runtime plugin configuration)
# upstream: https://github.com/vmware/open-vm-tools
# Flags from vmware/open-vm-tools open-vm-tools/services/vmtoolsd/mainCommon.c on tip.

_vmtoolsd() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-b+[background pidfile]:file:_files' \
        '-c+[config file]:file:_files' \
        '-d+[disable plugin]:plugin:' \
        '-l+[log dir]:dir:_files -/' \
        '-n+[plugin name match]:name:' \
        '-p+[plugin path]:path:_files'
}

_vmtoolsd "$@"
