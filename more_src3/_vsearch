#compdef vsearch
# _vsearch — Torbjørn Rognes vsearch CLI versatile open-source replacement for USEARCH with 64-bit memory model exact dynamic-programming alignment chimera detection cluster_fast cluster_size sortbylength derep_fulllength UCLUST-compatible centroid OTU picking large-scale 16S rRNA amplicon (Torbjørn Rognes team, C++); getopt
# upstream: https://github.com/torognes/vsearch

_vsearch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--quiet[quiet]' \
        '--threads=+[N]:n:' \
        '--cluster_fast=+[file]:file:_files -g "*.fa *.fasta"' \
        '--cluster_size=+[file]:file:_files -g "*.fa *.fasta"' \
        '--cluster_smallmem=+[file]:file:_files -g "*.fa *.fasta"' \
        '--cluster_unoise=+[file]:file:_files -g "*.fa *.fasta"' \
        '--usearch_global=+[file]:file:_files -g "*.fa *.fasta"' \
        '--usearch_local=+[file]:file:_files -g "*.fa *.fasta"' \
        '--allpairs_global=+[file]:file:_files -g "*.fa *.fasta"' \
        '--uchime_denovo=+[file]:file:_files -g "*.fa *.fasta"' \
        '--uchime_ref=+[file]:file:_files -g "*.fa *.fasta"' \
        '--uchime3_denovo=+[file]:file:_files -g "*.fa *.fasta"' \
        '--derep_fulllength=+[file]:file:_files -g "*.fa *.fasta"' \
        '--derep_prefix=+[file]:file:_files -g "*.fa *.fasta"' \
        '--derep_id=+[file]:file:_files -g "*.fa *.fasta"' \
        '--rereplicate=+[file]:file:_files -g "*.fa *.fasta"' \
        '--sortbylength=+[file]:file:_files -g "*.fa *.fasta"' \
        '--sortbysize=+[file]:file:_files -g "*.fa *.fasta"' \
        '--fastq_filter=+[file]:file:_files -g "*.fq *.fastq *.gz"' \
        '--fastq_mergepairs=+[file]:file:_files -g "*.fq *.fastq *.gz"' \
        '--fastq_eestats=+[file]:file:_files -g "*.fq *.fastq *.gz"' \
        '--fastx_subsample=+[file]:file:_files -g "*.fa *.fastq"' \
        '--makeudb_usearch=+[file]:file:_files' \
        '--udb2fasta=+[file]:file:_files -g "*.udb"' \
        '--id=+[N]:n:' \
        '--strand=+[s]:s:(plus both)' \
        '--centroids=+[file]:file:_files' \
        '--consout=+[file]:file:_files' \
        '--uc=+[file]:file:_files' \
        '--clusters=+[prefix]:str:' \
        '--db=+[file]:file:_files -g "*.fa *.fasta *.udb"' \
        '--reverse=+[file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--fastaout=+[file]:file:_files' \
        '--fastqout=+[file]:file:_files' \
        '--alnout=+[file]:file:_files' \
        '--blast6out=+[file]:file:_files' \
        '--samout=+[file]:file:_files' \
        '--matched=+[file]:file:_files' \
        '--notmatched=+[file]:file:_files' \
        '--minsize=+[N]:n:' \
        '--maxsize=+[N]:n:' \
        '--minseqlength=+[N]:n:' \
        '--maxseqlength=+[N]:n:' \
        '--maxaccepts=+[N]:n:' \
        '--maxrejects=+[N]:n:' \
        '--top_hits_only[top hits only]' \
        '--sizein[size annotation in]' \
        '--sizeout[size annotation out]' \
        '*::'
}

_vsearch "$@"
