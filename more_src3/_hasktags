#compdef hasktags

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --ctags)'{-c,--ctags}'[generate ctags file]' \
  '(-e --etags)'{-e,--etags}'[generate etags file]' \
  '(-b --both)'{-b,--both}'[generate both ctags and etags]' \
  '(-a --append)'{-a,--append}'[append to existing tags file]' \
  '--ignore-close-implementation[ignore close implementation]' \
  '--follow-symlinks[follow symbolic links]' \
  '(-S --suffixes)'{-S,--suffixes}'[file suffixes to process]:suffixes:' \
  '(-R --recurse)'{-R,--recurse}'[recurse into directories]' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '--cache[use cache file]' \
  '--help[show help message]' \
  '--version[show version]' \
  '*:file or directory:_files' && ret=0

return ret
