local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 11 flags + positional <query>.  Decoded source-
# direct from hiq/main.ha:26-39 (getopt::help array).
_arguments -s -S \
  '-1[only accept one match]' \
  '-a[add a key]' \
  '*-c+[change the value of a pair (repeatable; key/value pair)]:key/value pair:' \
  '-d[decrypt private keys]' \
  '-e[edit entries matched by the query by providing changes via stdin]' \
  '-F+[select a field for output]:field:' \
  '-l[soft lock the keyring]' \
  '-L[hard lock the keyring]' \
  '-Q[terminate the daemon (if started with -D)]' \
  '-R[remove matching keys from the key store]' \
  '-s[strict query]' \
  '(- *)'{-h,--help}'[display Hare getopt auto-generated help]' \
  '*:query expression:' && ret=0

return ret
