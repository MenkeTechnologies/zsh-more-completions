#compdef lppasswd
# Documentation: https://manpages.debian.org/lppasswd
# Source: OpenPrinting/cups systemv/lppasswd.c — manage CUPS digest password file (C, deprecated).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-a -x)-a[add a new password for user]' \
    '(-a -x)-x[delete user account]' \
    '-g+[group name]:group:_groups' \
    '1::user:_users' \
    && ret=0

return ret
