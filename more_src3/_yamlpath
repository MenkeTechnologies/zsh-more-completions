#compdef yamlpath yaml-get yaml-set yaml-merge yaml-diff yaml-paths yaml-validate eyaml-rotate-keys
# _yamlpath — wwkimball yamlpath YAML/JSON path query CLI suite alias (Bill Kimball / wwkimball, Python); argparse
# upstream: https://github.com/wwkimball/yamlpath

_yamlpath() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--query=+[YAML Path query]:str:' \
        '-q+[YAML Path query]:str:' \
        '--mustexist[fail if path missing]' \
        '-m[fail if path missing]' \
        '--value=+[set value]:str:' \
        '-v+[set value]:str:' \
        '--file=+[value file]:file:_files' \
        '-i+[value file]:file:_files' \
        '--saveto=+[save anchor]:str:' \
        '-s+[save anchor]:str:' \
        '--null[set null]' \
        '-n[set null]' \
        '--format=+[output format]:fmt:(default boolean float int string folded literal plain dquote squote)' \
        '-f+[output format]:fmt:(default boolean float int string folded literal plain dquote squote)' \
        '--mergewith=+[merge with]:file:_files' \
        '-w+[merge with]:file:_files' \
        '--config=+[config file]:file:_files -g "*.ini *.toml"' \
        '-c+[config file]:file:_files -g "*.ini *.toml"' \
        '--privatekey=+[EYAML private key]:file:_files' \
        '--publickey=+[EYAML public key]:file:_files' \
        '--eyaml=+[EYAML binary path]:file:_files' \
        '--key=+[key]:str:' \
        '-k+[key]:str:' \
        '--keynames[match key names]' \
        '-K[match key names]' \
        '--values[match values]' \
        '-Y[match values]' \
        '--expand[expand aliases]' \
        '-e[expand aliases]' \
        '--noexpand[no expand aliases]' \
        '--pathsep=+[path separator]:s:(dot fslash auto)' \
        '-t+[path separator]:s:(dot fslash auto)' \
        '--anchors-only[anchors only]' \
        '-A[anchors only]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '*:file:_files -g "*.yaml *.yml *.json"'
}

_yamlpath "$@"
