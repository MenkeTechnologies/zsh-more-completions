#compdef i3lock-fancy
# Documentation: https://github.com/meskarune/i3lock-fancy
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[display help menu]' \
  '(-d --desktop)'{-d,--desktop}'[minimize all windows before locking (requires wmctrl)]' \
  '(-g --greyscale)'{-g,--greyscale}'[use greyscale background instead of color]' \
  '(-p --pixelate)'{-p,--pixelate}'[pixelate background instead of blur (faster)]' \
  '(-f --font)'{-f+,--font=}'[custom font name]:font:' \
  '(-t --text)'{-t+,--text=}'[custom prompt text]:text:' \
  '(-l --listfonts)'{-l,--listfonts}'[list available fonts and exit]' \
  '(-n --nofork)'{-n,--nofork}'[do not fork i3lock]' \
  '*: :' && ret=0

return ret
