#compdef unshare-cli
# _unshare-cli — util-linux unshare run program with some namespaces unshared CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_unshare-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-m[mount namespace]' \
        '--mount=+[file]:file:_files' \
        '-u[uts namespace]' \
        '--uts=+[file]:file:_files' \
        '-i[ipc namespace]' \
        '--ipc=+[file]:file:_files' \
        '-n[network namespace]' \
        '--net=+[file]:file:_files' \
        '-p[pid namespace]' \
        '--pid=+[file]:file:_files' \
        '-U[user namespace]' \
        '--user=+[file]:file:_files' \
        '-C[cgroup namespace]' \
        '--cgroup=+[file]:file:_files' \
        '-T[time namespace]' \
        '--time=+[file]:file:_files' \
        '-f[fork]' \
        '--fork[fork]' \
        '--kill-child=+[signal]:str:' \
        '--mount-proc=+[mountpoint]:dir:_files -/' \
        '-r[map root user]' \
        '--map-root-user[map root user]' \
        '-c[map current user as root]' \
        '--map-current-user[map current user as root]' \
        '--map-user=+[uid]:n:' \
        '--map-group=+[gid]:n:' \
        '--map-users=+[outeruid,inneruid,count]:str:' \
        '--map-groups=+[outergid,innergid,count]:str:' \
        '--map-auto[map subuids/subgids]' \
        '--propagation=+[mode]:m:(slave shared private unchanged)' \
        '--setgroups=+[mode]:m:(allow deny)' \
        '--keep-caps[keep capabilities]' \
        '-R+[chroot dir]:dir:_files -/' \
        '--root=+[chroot dir]:dir:_files -/' \
        '-w+[work dir]:dir:_files -/' \
        '--wd=+[work dir]:dir:_files -/' \
        '-S+[uid]:n:' \
        '--setuid=+[uid]:n:' \
        '-G+[gid]:n:' \
        '--setgid=+[gid]:n:' \
        '--monotonic=+[offset]:n:' \
        '--boottime=+[offset]:n:' \
        '-l[load credentials from saved]' \
        '--load-interp[load credentials from saved]' \
        '*:command:_command_names'
}

_unshare-cli "$@"
