#compdef swift-container-sharder
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/container/sharder.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[log to console]' \
  '(-o --once)'{-o,--once}'[only run one pass of daemon]' \
  '(-d --devices)'{-d,--devices=}'[shard containers only on given devices, comma-separated; needs --once]:devices:' \
  '(-p --partitions)'{-p,--partitions=}'[shard containers only in given partitions, comma-separated; needs --once]:partitions:' \
  '--no-auto-shard[disable auto-sharding; overrides auto_shard config]' \
  '*:CONFIG file:_files -g "*.conf"' && ret=0
return ret
