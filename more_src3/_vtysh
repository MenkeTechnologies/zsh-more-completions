#compdef vtysh
# Documentation: https://github.com/FRRouting/frr/blob/master/vtysh/vtysh_main.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -u value handler (-u/--user takes no argument);
# fabricated --config_file long form (real spelling --inputfile);
# fabricated --markfile long form (real spelling --mark);
# fabricated -d daemon completion list (no upstream list — opens free).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-b --boot)'{-b,--boot}'[execute boot startup configuration]' \
  '(-c --command -e --eval)'{-c+,--command=,-e+,--eval=}'[execute command in batch mode]:command:' \
  '(-d --daemon)'{-d+,--daemon=}'[connect to specified daemon]:daemon:' \
  '(-E --echo)'{-E,--echo}'[echo prompt and command before results]' \
  '(-C --dryrun)'{-C,--dryrun}'[check configuration syntax]' \
  '(-f --inputfile)'{-f+,--inputfile=}'[input configuration file]:config file:_files' \
  '(-H --histfile)'{-H+,--histfile=}'[override history file]:history file:_files' \
  '(-m --mark)'{-m,--mark}'[mark/unmark FRR configuration]' \
  '(-n --noerror)'{-n,--noerror}'[ignore errors for return code]' \
  '(-N --pathspace)'{-N+,--pathspace=}'[namespace/VRF path]:namespace:' \
  '(-t --timestamp)'{-t,--timestamp}'[print timestamp]' \
  '(-u --user)'{-u,--user}'[restrict access (no enable)]' \
  '(-w --writeconfig)'{-w,--writeconfig}'[write integrated configuration]' \
  '--vty_socket=[VTY socket path]:path:_files' \
  '--config_dir=[configuration directory]:directory:_directories' \
  '--no-fork[do not fork (with -b)]' \
  '--exec-timeout=[exec timeout seconds]:seconds:' && ret=0

return ret
