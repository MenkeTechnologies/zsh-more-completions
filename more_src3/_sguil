#compdef sguil sguild sguil-client
# _sguil — Bamm Visscher Sguil network-security analyst console CLI for SOC investigation realtime IDS event display Snort Suricata Bro Zeek packet capture review using Tcl/Tk client and MySQL backend (sguil team, Tcl); cmd-style
# upstream: https://bammv.github.io/sguil/index.html

_sguil() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.conf sguil.conf sguil.tk"' \
        '--config=+[config file]:file:_files -g "*.conf sguil.conf sguil.tk"' \
        '-s+[server host]:h:_hosts' \
        '--server=+[server host]:h:_hosts' \
        '-p+[server port]:n:' \
        '--port=+[server port]:n:' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-P+[password]:str:' \
        '--pass=+[password]:str:' \
        '-D+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-L+[log file]:file:_files' \
        '--logfile=+[log file]:file:_files' \
        '-d[daemonize]' \
        '--daemon[daemonize]' \
        '-O+[option]:str:' \
        '--option=+[option]:str:' \
        '-T+[transcript dir]:dir:_files -/' \
        '--transcript=+[transcript dir]:dir:_files -/' \
        '-X+[X display]:str:' \
        '*:event id:'
}

_sguil "$@"
