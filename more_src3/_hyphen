#compdef hyphen example
# _hyphen — libhyphen example hyphen CLI hyphenation tool around libhyphen the Knuth-Liang TeX-pattern-based hyphenation engine that powers LibreOffice OpenOffice Firefox Hunspell-aware word break point computation per-language hyphenation dictionary .dic file UTF-8 text iteration counting (Nemeth Laszlo team, C); getopt
# upstream: https://github.com/hunspell/hyphen

_hyphen() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-l+[lhmin]:n:' \
        '-r+[rhmin]:n:' \
        '-d[skip default exception list]' \
        '-N[non-standard hyphenation]' \
        '-c+[charset]:c:(UTF-8 ISO-8859-1 ISO-8859-2 ISO-8859-9 windows-1250 windows-1252)' \
        '1:dictionary:_files -g "*.dic *.hyp"' \
        '*:text file:_files'
}

_hyphen "$@"
