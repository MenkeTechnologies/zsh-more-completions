#compdef shake
# Documentation: https://github.com/ndmitchell/shake/blob/master/src/Development/Shake/Internal/Args.hs
# Reference accessed: 2026-05-27
# Verified: upstream shakeOptsEx flag list in
# src/Development/Shake/Internal/Args.hs (ndmitchell/shake).

# Zsh completion for the shake build system. The shake binary is normally a
# user-compiled build script that links against the Shake library; the flags
# below come from shakeOptsEx and are the same set surfaced by every binary
# built with shakeArgs/shakeArgsWith.

_arguments -s -S \
  '*'{-a+,--abbrev=}'[use FULL=SHORT abbreviation in status messages]:pair:' \
  '--allow-redefine-rules[allow redefining built-in rules]' \
  '--no-allow-redefine-rules[forbid redefining built-in rules (default)]' \
  '--no-build[do not build anything]' \
  '(-C --directory)'{-C+,--directory=}'[change to DIRECTORY before doing anything]:directory:_directories' \
  '(--no-color --no-colour)'{--color,--colour}'[colorize the output]' \
  '(--color --colour)'{--no-color,--no-colour}'[do not colorize the output]' \
  '--compact=[use a compact Bazel/Buck style output]:mode:(yes no auto)' \
  '(-d --debug)'{-d-,--debug=-}'[print lots of debugging information]::file:_files' \
  '--demo[run in demo mode]' \
  '--digest[files change when digest changes]' \
  '--digest-and[files change when modtime and digest change]' \
  '--digest-and-input[files change on modtime (and digest for inputs)]' \
  '--digest-or[files change when modtime or digest change]' \
  '--digest-not[files change when modtime changes]' \
  '--exception[throw exceptions directly]' \
  '--flush=[flush metadata every N seconds]:seconds:' \
  '--never-flush[never explicitly flush metadata]' \
  '(- *)'{-h,--help}'[print this message and exit]' \
  '(-j --jobs)'{-j-,--jobs=-}'[allow N jobs/threads at once (default CPUs)]::jobs:' \
  '(-k --keep-going -S --no-keep-going --stop)'{-k,--keep-going}'[keep going when some targets cannot be made]' \
  '(-l --lint --no-lint)'{-l,--lint}'[perform limited validation after the run]' \
  '*--lint-watch=[error if any of the patterns are created (expensive)]:pattern:' \
  '--lint-fsatrace=-[use fsatrace to do validation (optionally in DIR)]::dir:_directories' \
  '*--lint-ignore=[ignore any lint errors in these patterns]:pattern:' \
  '--no-lint[turn off --lint]' \
  '--live=-[list the files that are live (optionally to FILE)]::file:_files' \
  '(-m --metadata)'{-m+,--metadata=}'[prefix for storing metadata files]:prefix:' \
  '--numeric-version[print just the version number and exit]' \
  '--skip-commands[try to avoid running external programs]' \
  '(-B --rebuild)'{-B-,--rebuild=-}'[rebuild matching files even if nothing has changed]::pattern:' \
  '--no-rebuild=-[rebuild matching files only if things have changed (default)]::pattern:' \
  '--skip=-[do not rebuild matching files this run]::pattern:' \
  '(-r --report --profile)'{-r-,--report=-,--profile=-}'[write profiling information (default report.html)]::file:_files' \
  '--no-reports[turn off --report]' \
  '--rule-version=[version of the build rules]:version:' \
  '--no-rule-version[ignore the build rules version]' \
  '--share=-[shared cache location]::directory:_directories' \
  '--share-list[list the shared cache files]' \
  '--share-sanity[sanity check the shared cache files]' \
  '--share-remove=-[remove the shared cache keys matching SUBSTRING]::substring:' \
  '--share-copy[copy files into the cache]' \
  '--share-symlink[symlink files into the cache]' \
  '(-s --silent)'{-s,--silent}'[do not print anything]' \
  '--sleep[sleep for a second before building]' \
  '(-S --no-keep-going --stop -k --keep-going)'{-S,--no-keep-going,--stop}'[turn off -k]' \
  '--storage[write a storage log]' \
  '(-p --progress --no-progress)'{-p-,--progress=-}'[show progress messages (every N secs, default 5)]::seconds:' \
  '(-p --progress)--no-progress[do not show progress messages]' \
  '(-q --quiet)'{-q,--quiet}'[print less (pass repeatedly for even less)]' \
  '--no-time[do not print build time]' \
  '--timings[print phase timings]' \
  '(-V --verbose --trace)'{-V,--verbose,--trace}'[print more (pass repeatedly for even more)]' \
  '(- *)'{-v,--version}'[print the version number and exit]' \
  '(-w --print-directory --no-print-directory)'{-w,--print-directory}'[print the current directory]' \
  '(-w --print-directory)--no-print-directory[turn off -w, even if it was turned on implicitly]' \
  '*:target:_files'
