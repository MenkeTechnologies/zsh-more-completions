#compdef hap
# Documentation: https://github.com/bmwant/hapless
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (USAGE.md).
# hap is the CLI for hapless: a Python tool that runs and manages
# background processes. Subcommands enumerated from upstream USAGE.md.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a cmds=(
      'run:execute a script in the background'
      'status:display detailed status of a hap'
      'show:alias for status'
      'logs:print process logs'
      'pause:pause a running hap (SIGSTOP)'
      'suspend:alias for pause'
      'resume:resume a paused hap (SIGCONT)'
      'signal:send a specific signal to a hap'
      'restart:stop and restart a hap'
      'kill:terminate a running hap'
      'clean:remove successfully completed haps'
      'cleanall:remove all finished haps'
      'rename:change a hap identifier'
    )
    _describe -t commands 'hap command' cmds && ret=0
    ;;
  (args)
    case $line[1] in
      (run)
        _arguments \
          '--check[fail early if startup fails]' \
          '*::command:_command_names -e' && ret=0
        ;;
      (status|show)
        _arguments \
          '(-v --verbose)'{-v,--verbose}'[extended information]' \
          '*:hap:' && ret=0
        ;;
      (logs)
        _arguments \
          '(-f --follow)'{-f,--follow}'[stream continuously]' \
          '*:hap:' && ret=0
        ;;
      (clean)
        _arguments \
          '--all[also remove failed haps]' && ret=0
        ;;
      (signal)
        _arguments \
          '1:hap:' \
          '2:signal code:' && ret=0
        ;;
      (rename)
        _arguments \
          '1:hap:' \
          '2:new name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
