#compdef hypershift
# Documentation: https://github.com/openshift/hypershift
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hypershift — OpenShift hosted control planes CLI (openshift/hypershift)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install HyperShift operator into a management cluster'
  'create:create HyperShift resources'
  'destroy:destroy HyperShift resources'
  'dump:dump cluster state for support'
  'console:open console for a hosted cluster'
  'kubeconfig:retrieve kubeconfig for a hosted cluster'
  'version:print version information'
  'help:show help for any subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '1:subcommand:->cmd' \
  '*::args:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'hypershift subcommand' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create|destroy)
        _values 'resource' 'cluster' 'infra' 'iam' 'kubeconfig' && ret=0
        ;;
    esac ;;
esac

return ret
