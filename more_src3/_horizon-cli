#compdef horizon-cli
# _horizon-cli — Taylor Otwell Laravel Horizon queue dashboard CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/horizon

_horizon-cli() {
    local -a sub=(
        'horizon:install:install horizon'
        'horizon:assets:publish assets'
        'horizon:publish:publish config'
        'horizon:clear:clear pending jobs'
        'horizon:continue:resume processing'
        'horizon:continue-supervisor:resume supervisor'
        'horizon:forget:forget pending or failed'
        'horizon:list:list supervisors'
        'horizon:pause:pause processing'
        'horizon:pause-supervisor:pause supervisor'
        'horizon:purge:purge supervisor processes'
        'horizon:snapshot:store metric snapshot'
        'horizon:status:check status'
        'horizon:supervisor:start supervisor'
        'horizon:supervisors:list supervisors'
        'horizon:terminate:terminate horizon'
        'horizon:timeout:terminate long-running'
        'horizon:work:run a horizon worker'
        'horizon:start a horizon master'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'horizon subcommand' sub ;;
        args)
            case $words[1] in
                horizon:forget) _arguments '1:job id:' ;;
                horizon:snapshot) ;;
                horizon:work) _arguments \
                    '--name=+[name]:str:' \
                    '--supervisor=+[supervisor]:str:' \
                    '--queue=+[queue]:str:' \
                    '--connection=+[connection]:str:' \
                    '--delay=+[delay]:n:' \
                    '--memory=+[memory mb]:n:' \
                    '--sleep=+[sleep s]:n:' \
                    '--timeout=+[timeout s]:n:' \
                    '--tries=+[tries]:n:' ;;
                horizon:supervisor) _arguments \
                    '1:name:' \
                    '2:connection:' \
                    '--workers-name=+[workers name]:str:' \
                    '--balance=+[balance]:b:(auto simple false)' \
                    '--queue=+[queue]:str:' \
                    '--maxProcesses=+[max processes]:n:' \
                    '--minProcesses=+[min processes]:n:' \
                    '--memory=+[memory]:n:' \
                    '--timeout=+[timeout]:n:' \
                    '--tries=+[tries]:n:' \
                    '--rest=+[rest]:n:' \
                    '--nice=+[nice]:n:' ;;
            esac
            ;;
    esac
}

_horizon-cli "$@"
