#compdef kind2
# ============================================================================
# _kind2 — zsh completion for Kind 2, the Lustre model checker
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/kind2-mc/kind2
#   Website    : https://kind.cs.uiowa.edu/
#   Maintainer : The Kind 2 development team (University of Iowa)
#   License    : Apache-2.0
#   Stars      : 124
#   Language   : OCaml (compiler) / Lustre (.lus source files)
#   Last push  : 2026-05-29
#
# WHAT IT IS
#   Kind 2 is "a multi-engine, parallel, SMT-based automatic model checker
#   for safety properties of Lustre programs" — the University of Iowa's
#   Lustre verifier.  Lustre is the synchronous dataflow language used in
#   safety-critical aerospace / defense / automotive control software
#   (SCADE Suite is the commercial descendant).  Kind 2 reads a `.lus`
#   file annotated with `--%PROPERTY` invariant requirements, then runs
#   bounded model checking (BMC), k-induction (IND / IND2), invariant
#   generation (INVGEN), IC3 with quantifier elimination (IC3QE) and
#   IC3 with implicit abstraction (IC3IA) in parallel on all properties
#   simultaneously, dispatching SMT queries to an external solver (Z3 by
#   default; also supports cvc5 / MathSAT / Bitwuzla / OpenSMT /
#   SMTInterpol / Yices / Yices2).  Output includes counter-example
#   traces for falsified properties and proof certificates for verified
#   ones, in human-readable text or machine-readable JSON / XML.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/flags.ml — 132 long flags +
#                       a handful of short ones)
#   kind2 [OPTIONS] <input.lus>
#
#   Engine selection:
#     --enable <E>           Enable model checking engine; repeatable
#                            Engines:  BMC | IND | IND2 | IC3 | IC3QE |
#                                      IC3IA | INVGEN | INVGENOS |
#                                      MCS | interpreter | CONTRACTCK |
#                                      C2I | CMonitor | BMCSKIP
#     --disable <E>          Disable specific engine; repeatable
#
#   SMT solver selection + paths:
#     --smt_solver {Z3|cvc5|MathSAT|Bitwuzla|OpenSMT|SMTInterpol|Yices|
#                   Yices2}                                  [default: Z3]
#     --smt_itp_solver       Interpolating solver
#     --smt_qe_solver        Quantifier elimination solver
#     --smt_logic <LOGIC>    SMT-LIB logic override
#     --z3_bin <FILE>        Z3 binary path
#     --cvc5_bin <FILE>      cvc5 binary path
#     --mathsat_bin <FILE>   MathSAT 5 binary path
#     --bitwuzla_bin <FILE>  Bitwuzla binary path
#     --opensmt_bin <FILE>   OpenSMT binary path
#     --smtinterpol_jar <F>  SMTInterpol JAR path
#     --yices_bin <FILE>     Yices 1 binary path (native input)
#     --yices2_bin <FILE>    Yices 2 binary path (SMT input)
#     --jkind_bin <FILE>     JKind binary path
#
#   Output:
#     -json                  Output in JSON format
#     -xml                   Output in XML format
#     -v | -vv | -vvv        Verbose output (1..3)
#     -q | -qq               Quiet output (1..2)
#     --color                Force colored output
#     --output_dir <DIR>     Output directory
#     --exit_code_mode <M>   How to derive shell exit codes
#
#   Time/resource limits:
#     --timeout <SECS>       Wall-clock seconds; 0 = none      [default: 0]
#     --timeout_wall <SECS>  Wall-clock seconds (alias)
#     --timeout_analysis <SECS>
#                            Per-analysis budget
#     --unroll_max <N>       Unrolling depth limit
#
#   IVC / MCS / Contract analysis:
#     --ivc                  Run IVC (Inductive Validity Core) extraction
#     --mcs                  Run MCS (Minimal Cut Set) computation
#     --ivc_category <C>     IVC category filter
#     --mcs_category <C>     MCS category filter
#     --contract_gen         Synthesize a contract
#     --contract_gen_depth <N>
#                            Synthesis bound
#
#   Property check controls:
#     --check_modes          Check that contract modes are exhaustive
#     --check_implem         Check the implementation
#     --check_reach          Check reachability
#     --check_nonvacuity     Check non-vacuity of assumptions
#     --check_subproperties  Verify subproperties separately
#     --compositional        Compositional analysis
#     --modular              Modular analysis
#
#   Lustre frontend:
#     --lus_main <NAME>      Main node name
#     --lus_main_type <T>    Main node type
#     --lus_strict           Strict parsing
#     --lus_push_pre         Push `pre` to leaves
#     --include_dir <DIR>    Include path  (repeatable)
#     --input_format <F>     Input format selector
#     --interpreter_input_file <F>
#                            Interpreter input file
#
#   Witness / counterexample dumps:
#     --print_cex            Print counterexamples
#     --print_witness        Print witnesses
#     --dump_cex             Dump counterexamples to disk
#     --dump_witness         Dump witnesses to disk
#     --dump_deadlock        Dump deadlocks
#     --proof                Produce a proof certificate
#
#   Standard auto-flags:
#     --help                 Show help
#     --help_of <FLAG>       Detailed help for one flag
#     --version              Show version
#     -h, -s, --debug, --debug_log, --certif, ...
#
#   (The flag set is intentionally vast — `kind2 --help` lists all 132
#    long flags.)
#
# LANGUAGE-CORPUS POSITION
#   Lustre is the 144th programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R845
#   (_sonic-pi-tool/rosc Rust=119 opens Axis 64) and continued through
#   R846 (_broscoli/hypebeast/go-osc Go=119) and R847 (_ampm/node-osc
#   TS-Node=119 CLOSES Axis 64 OSC/Open Sound Control Library at 1/1/1
#   + triple-119 landmark + 57 axes at 1/1/1).  Lustre joins the roster
#   of exotic languages already in the corpus including Ravi (R844
#   143rd), ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832 140th
#   — round-number language milestone), Imba (R828 139th), Tao (R824
#   138th), Dada (R820 137th), Acton (R816 136th), Stanza (R812 135th),
#   Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth, Lawvere/bill,
#   Cognac/Cognate, and Scrapscript.
#
#   No completion for `kind2` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_kind2() {
    local -a engines smt_solvers gateways
    engines=(BMC IND IND2 IC3 IC3QE IC3IA INVGEN INVGENOS MCS interpreter CONTRACTCK C2I CMonitor BMCSKIP)
    smt_solvers=(Z3 cvc5 MathSAT Bitwuzla OpenSMT SMTInterpol Yices Yices2)

    _arguments -s \
        '*--enable=[enable model checking engine]:engine:('"${engines[*]}"')' \
        '*--disable=[disable model checking engine]:engine:('"${engines[*]}"')' \
        '--smt_solver=[SMT solver (default Z3)]:solver:('"${smt_solvers[*]}"')' \
        '--smt_itp_solver=[interpolating solver]:solver:('"${smt_solvers[*]}"')' \
        '--smt_qe_solver=[quantifier-elimination solver]:solver:('"${smt_solvers[*]}"')' \
        '--smt_logic=[SMT-LIB logic override]:logic:' \
        '--z3_bin=[Z3 binary path]:Z3 binary:_files' \
        '--cvc5_bin=[cvc5 binary path]:cvc5 binary:_files' \
        '--mathsat_bin=[MathSAT 5 binary path]:MathSAT binary:_files' \
        '--bitwuzla_bin=[Bitwuzla binary path]:Bitwuzla binary:_files' \
        '--opensmt_bin=[OpenSMT binary path]:OpenSMT binary:_files' \
        '--smtinterpol_jar=[SMTInterpol JAR path]:JAR:_files -g "*.jar"' \
        '--yices_bin=[Yices 1 (native) path]:Yices binary:_files' \
        '--yices2_bin=[Yices 2 (SMT) path]:Yices2 binary:_files' \
        '--jkind_bin=[JKind binary path]:JKind binary:_files' \
        '--timeout=[wall-clock timeout in seconds (0 = none)]:seconds:' \
        '--timeout_wall=[wall-clock timeout in seconds]:seconds:' \
        '--timeout_analysis=[per-analysis timeout]:seconds:' \
        '--unroll_max=[unrolling depth limit]:N:' \
        '--ivc[run IVC (inductive validity core) extraction]' \
        '--mcs[run MCS (minimal cut set) computation]' \
        '--ivc_category=[IVC category filter]:category:' \
        '--mcs_category=[MCS category filter]:category:' \
        '--contract_gen[synthesize a contract]' \
        '--contract_gen_depth=[contract synthesis bound]:N:' \
        '--check_modes[check contract modes are exhaustive]' \
        '--check_implem[check the implementation]' \
        '--check_reach[check reachability]' \
        '--check_nonvacuity[check non-vacuity of assumptions]' \
        '--check_subproperties[verify subproperties separately]' \
        '--compositional[compositional analysis]' \
        '--modular[modular analysis]' \
        '--lus_main=[main Lustre node name]:node name:' \
        '--lus_main_type=[main Lustre node type]:type:' \
        '--lus_strict[strict Lustre parsing]' \
        '--lus_push_pre[push pre to leaves]' \
        '*--include_dir=[include path (repeatable)]:include dir:_files -/' \
        '--input_format=[input format selector]:format:' \
        '--interpreter_input_file=[interpreter input file]:input file:_files' \
        '--print_cex[print counterexamples]' \
        '--print_witness[print witnesses]' \
        '--dump_cex[dump counterexamples to disk]' \
        '--dump_witness[dump witnesses to disk]' \
        '--dump_deadlock[dump deadlocks]' \
        '--proof[produce a proof certificate]' \
        '--output_dir=[output directory]:output dir:_files -/' \
        '--exit_code_mode=[exit-code derivation mode]:mode:' \
        '--color[force colored output]' \
        '-json[output in JSON format]' \
        '-xml[output in XML format]' \
        '(-q -qq -v -vv -vvv)-q[quiet output]' \
        '(-q -qq -v -vv -vvv)-qq[very quiet output]' \
        '(-q -qq -v -vv -vvv)-v[verbose output]' \
        '(-q -qq -v -vv -vvv)-vv[very verbose output]' \
        '(-q -qq -v -vv -vvv)-vvv[debug-level verbose output]' \
        '--debug[debug output]' \
        '--debug_log=[debug log file]:log file:_files' \
        '--lsp[LSP/language-server-protocol mode]' \
        '--certif[generate certification artifacts]' \
        '--show_props[show property results]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--help_of=[show help for one specific flag]:flag:' \
        '(- *)--version[show version]' \
        '*:Lustre input file:_files -g "*.lus"'
}

_kind2 "$@"
