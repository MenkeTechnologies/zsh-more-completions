#compdef hostlist
# _hostlist — LLNL hostlist hostname-range expander/collapser; converts node[1-10] notation to/from flat lists, used by pdsh + powerman
# upstream: https://github.com/grondo/hostlist

_hostlist() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '(-e --expand)'{-e,--expand}'[expand to one host per line]' \
        '(-q --quoted)'{-q,--quoted}'[quote output for shell use]' \
        '(-c --count)'{-c,--count}'[print host count]' \
        '(-d --delim)'{-d,--delim}'+[output delimiter]:delim:' \
        '(-n --nth)'{-n,--nth}'+[print only Nth host]:n:' \
        '(-R --remove)'{-R,--remove}'+[remove hosts in list]:hosts:' \
        '(-i --intersect)'{-i,--intersect}'[intersect inputs]' \
        '(-x --exclude)'{-x,--exclude}'+[exclude pattern]:pattern:' \
        '(-u --union)'{-u,--union}'[union of inputs (default)]' \
        '(-m --minus)'{-m,--minus}'[set difference]' \
        '(-s --size)'{-s,--size}'+[chunk size]:n:' \
        '(-S --separator)'{-S,--separator}'+[separator]:sep:' \
        '*:hosts:'
}

_hostlist "$@"
