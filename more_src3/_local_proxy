#compdef local_proxy
# _local_proxy — Neon local Postgres proxy (in-compute HTTP/SQL-over-HTTP frontend to the local Postgres + compute_ctl; provides the SQL-over-HTTP and pg_session_jwt surface inside each compute pod)
# upstream: https://github.com/neondatabase/neon
# Flags from proxy/src/binary/local_proxy.rs on tip (clap-derive); --http is required, others have defaults.

_local_proxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '--metrics=[metrics listen address (host:port)]:hostport:' \
        '--http=[HTTP listen address (host:port, required)]:hostport:' \
        '--handshake-timeout=[TLS handshake timeout]:dur:' \
        '--connect-compute-lock=[connect-compute lock config (shards=,permits=,epoch=,timeout=)]:cfg:' \
        '*--user-rps-limit=[user RPS bucket (rps@bucket-dur, repeatable)]:bucket:' \
        '--connect-to-compute-retry=[retry config for connect-to-compute]:cfg:' \
        '--postgres=[upstream Postgres address (host:port)]:hostport:' \
        '--compute-ctl=[internal compute-ctl API base URL]:url:_urls' \
        '--config-path=[local proxy config file]:file:_files' \
        '--pid-path=[local proxy PID file path]:file:_files' \
        '--sql-over-http-pool-max-total-conns=[max pooled SQL-over-HTTP connections per endpoint]:n:' \
        '--sql-over-http-idle-timeout=[pooled connection idle timeout]:dur:' \
        '--sql-over-http-client-conn-threshold=[client connection threshold]:n:' \
        '--sql-over-http-cancel-set-shards=[cancel-set shard count]:n:' \
        '--sql-over-http-max-request-size-bytes=[max SQL-over-HTTP request bytes]:bytes:' \
        '--sql-over-http-max-response-size-bytes=[max SQL-over-HTTP response bytes]:bytes:'
}

_local_proxy "$@"
