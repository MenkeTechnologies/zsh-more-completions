#compdef lvchange
# _lvchange — change logical volume attributes (LVM2); activate/deactivate, tag, permissions, cache policy
# upstream: https://gitlab.com/lvmteam/lvm2

_lvchange() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --activate)'{-a,--activate}'+[activate]:mode:(y n ay)' \
        '(-K --ignoreactivationskip)'{-K,--ignoreactivationskip}'[ignore activation skip]' \
        '(-k --setactivationskip)'{-k,--setactivationskip}'+[set activation skip]:bool:(y n)' \
        '(-C --contiguous)'{-C,--contiguous}'+[contiguous policy]:bool:(y n)' \
        '(-p --permission)'{-p,--permission}'+[permission]:mode:(r rw)' \
        '(-r --readahead)'{-r,--readahead}'+[read-ahead]:str:(auto none NumberSectors)' \
        '(-Z --zero)'{-Z,--zero}'+[zero metadata]:bool:(y n)' \
        '--addtag+[add tag]:tag:' \
        '--deltag+[delete tag]:tag:' \
        '--alloc+[allocation policy]:policy:(contiguous cling normal anywhere inherit)' \
        '--cachemode+[cache mode]:mode:(writethrough writeback passthrough)' \
        '--cachepolicy+[cache policy]:policy:' \
        '--cachesettings+[cache settings]:str:' \
        '--monitor+[dmeventd monitor]:bool:(y n)' \
        '--rebuild+[rebuild device]:dev:_files' \
        '--refresh[refresh lv]' \
        '--resync[resync mirror]' \
        '--syncaction+[sync action]:action:(check repair)' \
        '--writebehind+[write-behind blocks]:n:' \
        '--writemostly+[write-mostly devices]:devices:' \
        '--minrecoveryrate+[min recovery rate]:rate:' \
        '--maxrecoveryrate+[max recovery rate]:rate:' \
        '--errorwhenfull+[error when full]:bool:(y n)' \
        '*:lv:'
}

_lvchange "$@"
