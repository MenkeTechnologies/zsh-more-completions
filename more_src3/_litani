#compdef litani
# Documentation: https://awslabs.github.io/aws-build-accumulator/
# Reference accessed: 2026-06-10

# Zsh completion for litani - AWS Litani build system

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:initialize a new Litani run'
  'add-job:add a build job to the current run'
  'run-build:execute the build'
  'set-jobs-status:override the status of jobs'
  'dump-run:dump the current run as JSON'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'litani command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments \
          {-h,--help}'[show help]' \
          '--project-name=[name of the project]:project name:' \
          '--output-dir=[directory for output]:output directory:_files -/' \
          '--pools=[JSON file defining job pools]:pools file:_files -g "*.json"' && ret=0 ;;
      (add-job)
        _arguments \
          {-h,--help}'[show help]' \
          '--command=[the command to run]:command:' \
          '--ci-stage=[CI stage for this job]:stage:(build test report)' \
          '--pipeline-name=[name of the pipeline]:pipeline name:' \
          '--description=[human-readable job description]:description:' \
          '--inputs=[input files for this job]:input files:_files' \
          '--outputs=[output files from this job]:output files:_files' \
          '--timeout=[timeout in seconds]:seconds:' \
          '--cwd=[working directory for the job]:directory:_files -/' \
          '--stdout-file=[file to write stdout to]:file:_files' \
          '--stderr-file=[file to write stderr to]:file:_files' \
          '--interleave-stdout-stderr[interleave stdout and stderr]' \
          '--ok-returns=[space-separated return codes treated as success]:return codes:' \
          '--ignore-returns=[space-separated return codes to ignore]:return codes:' \
          '--tags=[space-separated tags for this job]:tags:' \
          '--pool=[job pool to run this job in]:pool name:' \
          '--profile-memory[profile memory usage]' \
          '--profile-memory-interval=[memory profiling interval in seconds]:seconds:' && ret=0 ;;
      (run-build)
        _arguments \
          {-h,--help}'[show help]' \
          '--pipelines=[run only specified pipelines]:pipeline names:' \
          '--ci-stage=[run only specified CI stage]:stage:(build test report)' \
          '--fail-on-pipeline-failure[exit with error if any pipeline fails]' \
          '--jobs=[number of parallel jobs]:jobs:' \
          '--out-file=[write the run JSON to this file]:file:_files' && ret=0 ;;
      (set-jobs-status)
        _arguments \
          {-h,--help}'[show help]' \
          '--pipeline=[pipeline name]:pipeline name:' \
          '--ci-stage=[CI stage]:stage:(build test report)' \
          '--status=[status to set]:status:(fail)' && ret=0 ;;
      (dump-run)
        _arguments \
          {-h,--help}'[show help]' \
          '--out-file=[write output to this file]:file:_files' \
          '--retries=[number of retries if cache not ready]:retries:' && ret=0 ;;
    esac ;;
esac

return ret
