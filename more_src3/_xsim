#compdef xsim
# _xsim — Xilinx Vivado xsim CLI for the Vivado Simulator launching previously elaborated snapshots with GUI batch wave-dump VCD wcfg simulation script execution time control transcript log tb (Xilinx team, C++); custom argparse
# upstream: https://www.xilinx.com/products/design-tools/vivado.html

_xsim() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]:n:(0 1 2)' \
        '-quiet[quiet]' \
        '-debug+[level]:l:(line wave xmwarning sub xtb_internal)' \
        '-gui[gui mode]' \
        '-onfinish=+[m]:m:(stop quit final exit)' \
        '-tclbatch+[script]:file:_files -g "*.tcl"' \
        '-runall[run all]' \
        '-R[run all]' \
        '-wdb+[wdb file]:file:_files -g "*.wdb"' \
        '-view+[wcfg]:file:_files -g "*.wcfg"' \
        '-log+[file]:file:_files' \
        '-stats[print stats]' \
        '-vcdfile+[file]:file:_files -g "*.vcd"' \
        '-vcdunit+[unit]:str:' \
        '-maxlogsize+[N]:n:' \
        '-stack+[N]:n:' \
        '-testplusarg+[arg]:str:' \
        '-mt+[threads]:n:' \
        '-cov_db_dir+[dir]:dir:_files -/' \
        '-cov_db_name+[name]:str:' \
        '*:snapshot:'
}

_xsim "$@"
