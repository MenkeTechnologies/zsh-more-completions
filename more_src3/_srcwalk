#compdef srcwalk
# Documentation: https://github.com/sting8k/srcwalk
# Reference accessed: 2026-05-22
# Verified: src/cli.rs Clap Cli and Command subcommands.

# Zsh completion for srcwalk - Tree-sitter code intelligence for AI agents

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--scope[directory scope]:directory:_directories' \
  '--section[focus line range symbol or heading]:section:' \
  '--budget[max tokens in response]:tokens:' \
  '--no-budget[disable default budget cap]' \
  '--artifact[include JS/TS artifacts]' \
  '--expand[source context for top matches]:n:' \
  '--glob[file pattern filter]:pattern:' \
  '--filter[field:value qualifiers]:filter:' \
  '--count-by[count callers by field]:field:' \
  '--callers[show callers of symbol]' \
  '--callees[show callees of symbol]' \
  '--detailed[detailed callees with call sites]' \
  '--depth[BFS or map depth]:n:' \
  '--max-frontier[max callers per BFS hop]:n:' \
  '--max-edges[max total BFS edges]:n:' \
  '--skip-hubs[comma-separated hub symbols to skip]:symbols:' \
  '--deps[blast-radius dependencies of file]' \
  '--flow[compact caller/callee slice]' \
  '--impact[heuristic blast-radius triage]' \
  '--map[repo orientation map]' \
  '--symbols[include symbol names in map]' \
  '--limit[max results]:n:' \
  '--offset[skip first N results]:n:' \
  '--completions[generate shell completions]:shell:(bash elvish fish powershell zsh)' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'srcwalk command' \
      'guide[embedded agent guide]' \
      'version[show version]' \
      'find[find definitions usages or text]' \
      'files[find files by glob]' \
      'callers[who calls a symbol]' \
      'callees[what a symbol calls]' \
      'deps[file import dependents]' \
      'flow[compact flow slice]' \
      'impact[blast-radius triage]' \
      'map[repo map]' && ret=0
    ;;
  args)
    case $line[1] in
      version)
        _arguments '--check[check for latest release]' && ret=0
        ;;
      *)
        _arguments '*:query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
