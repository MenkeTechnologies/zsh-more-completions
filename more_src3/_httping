#compdef httping
# Documentation: https://manpages.debian.org/bookworm/httping/httping.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# httping - measure latency and throughput of a webserver.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)-V[show version]' \
  '(- *)--help[show help]' \
  '-g+[URL to ping]:url:_urls' \
  '-h+[hostname to probe]:host:_hosts' \
  '-p+[port number]:port:' \
  '-c+[number of pings]:count:' \
  '-i+[interval between pings]:seconds:' \
  '-t+[timeout in seconds]:seconds:' \
  '-G[use GET instead of HEAD]' \
  '-b[show transfer speed]' \
  '-B[request HTTP compression]' \
  '-L+[limit data transferred to bytes]:bytes:' \
  '-S[split time into connect and transfer]' \
  '-s[show HTTP status codes]' \
  '-l[use SSL]' \
  '-f[flood mode]' \
  '-a[audible ping]' \
  '-Q[use persistent connection]' \
  '-x+[use proxy host[:port]]:proxy:' \
  '-5[use SOCKS5 proxy]' \
  '-E[get proxy settings from environment]' \
  '-F[attempt TCP Fast Open]' \
  '-r[resolve hostname once]' \
  '-W[do not abort on resolve failure]' \
  '-I+[user-agent]:useragent:' \
  '-R+[referer]:referer:' \
  '-K[ncurses UI]' \
  '-D[disable graphs in ncurses mode]' \
  '-m[machine-readable output]' \
  '-q[quiet mode]' \
  '-v[verbose]' \
  '-Y[colors]' \
  '-X[show transferred bytes per ping]' \
  '-z[show X509 cert fingerprint]' \
  '-U[enable website authentication]' \
  '-T+[auth password file]:file:_files' \
  '-o+[OK status codes (comma separated)]:codes:' \
  '-e+[message when status differs from -o]:string:' \
  '-n+[Nagios plugin mode 1 warn,crit]:thresholds:' \
  '-N+[Nagios plugin mode 2]:level:' \
  '-6[IPv6]' \
  '-4[IPv4 (default)]' \
  '--abbreviate[abbreviate large values]' \
  '--adaptive-interval[ping at consistent intervals]' \
  '--ai[ping at consistent intervals]' \
  '--aggregates=[display aggregates]:intervals:' \
  '--divert-connect=[connect to alt host]:host:' \
  '--draw-phase[draw Fourier transform phase]' \
  '--graph-limit=[graph value limit]:limit:' \
  '*--header=[custom request header]:header:' \
  '--keep-cookies[keep server cookies]' \
  '--max-mtu=[max MTU]:mtu:' \
  '--no-host-header[omit Host header]' \
  '--no-tcp-nodelay[do not disable TCP delay]' \
  '--priority=[packet priority]:priority:' \
  '--proxy-password=[proxy password]:password:' \
  '--proxy-password-file=[read proxy password from file]:file:_files' \
  '--proxy-user=[proxy username]:user:' \
  '--recv-buffer=[receive buffer size]:bytes:' \
  '--slow-log=[show slow pings above ms]:ms:' \
  '--threshold-red=[red above ms]:ms:' \
  '--threshold-yellow=[yellow above ms]:ms:' \
  '--threshold-show=[show only above ms]:ms:' \
  '--timestamp[add timestamp]' \
  '--ts[add timestamp]' \
  '--tos=[type of service]:tos:' \
  '--tx-buffer=[transmit buffer size]:bytes:' && ret=0
return ret
