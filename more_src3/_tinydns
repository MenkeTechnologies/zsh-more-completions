#compdef tinydns tinydns-conf tinydns-data tinydns-edit tinydns-get
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/tinydns-edit.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# tinydns-conf: tinydns-conf acct logacct dir ip
# tinydns-edit: tinydns-edit data data.tmp add type name address (type in ns/childns/mx/host/alias)
# tinydns-data: reads ./data, no flags
# tinydns-get:  tinydns-get t fqdn [ip]

local curcontext="$curcontext" ret=1

case $service in
  (tinydns-conf)
    _arguments \
      '1:acct (user):_users' \
      '2:logacct (log user):_users' \
      '3:dir:_files -/' \
      '4:ip address:' && ret=0 ;;
  (tinydns-data)
    _arguments && ret=0 ;;
  (tinydns-edit)
    _arguments \
      '1:data file:_files' \
      '2:data.tmp file:_files' \
      '3:operation:(add)' \
      '4:record type:(ns childns mx host alias)' \
      '5:fully qualified domain name:' \
      '6:address:' && ret=0 ;;
  (tinydns-get)
    _arguments \
      '1:query type:' \
      '2:fully qualified domain name:' \
      '3:client ip:' && ret=0 ;;
  (*)
    _arguments \
      '*:file:_files' && ret=0 ;;
esac

return ret
