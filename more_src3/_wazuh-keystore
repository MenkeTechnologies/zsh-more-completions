#compdef wazuh-keystore
# _wazuh-keystore — Wazuh Inc wazuh-keystore CLI for managing the local secure key-value store backing Wazuh agent and manager credentials API keys MITRE indexer authd shared keys (wazuh team, C); getopt
# upstream: https://github.com/wazuh/wazuh

_wazuh-keystore() {
    local -a sub=(
        'get:get value for key'
        'set:set key=value'
        'remove:remove key'
        'list:list keys'
        'rotate:rotate master key'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-f+[component]:f:(agent server indexer api authd)' \
        '--family=+[component]:f:(agent server indexer api authd)' \
        '-k+[key file]:file:_files' \
        '--key=+[key file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wazuh-keystore subcommand' sub ;;
        args)
            case $words[1] in
                get|remove) _arguments '*:key name:' ;;
                set) _arguments \
                    '--value=+[value]:str:' \
                    '--from-file=+[file]:file:_files' \
                    '*:key name:' ;;
            esac
            ;;
    esac
}

_wazuh-keystore "$@"
