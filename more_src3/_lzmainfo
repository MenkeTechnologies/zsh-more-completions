#compdef lzmainfo
# Documentation: https://man7.org/linux/man-pages/man1/lzmainfo.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--help[show help]'
    '--version[show version]'
    '*:lzma file:_files -g "*.lzma"'
)

_arguments -s -S $arguments
