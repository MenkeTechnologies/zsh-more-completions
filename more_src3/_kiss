#compdef kiss
# Documentation: https://github.com/kiss-community/kiss/blob/master/kiss
# Reference accessed: 2026-05-19
# Verified: upstream kiss help() function at the URL above.
# Corrected from prior file: removed fabricated subcommands (chroot,
# depends, export, fork, link, maintainer, manifest, new, orphans,
# outdated, owns, revdepends, repo-orphans, size) and the bogus
# kiss-* binary aliases in #compdef; core kiss ships only the 13
# documented operations plus the H/help-ext extension lister.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'a:list and swap alternatives'
  'alternatives:list and swap alternatives'
  'b:build packages'
  'build:build packages'
  'c:generate checksums'
  'checksum:generate checksums'
  'd:download sources'
  'download:download sources'
  'i:install packages'
  'install:install packages'
  'l:list installed packages'
  'list:list installed packages'
  'p:list owners of files with alternatives'
  'preferred:list owners of files with alternatives'
  'r:remove packages'
  'remove:remove packages'
  's:search for packages'
  'search:search for packages'
  'u:update the repositories'
  'update:update the repositories'
  'U:update the system'
  'upgrade:update the system'
  'v:package manager version'
  'version:package manager version'
  'H:list installed kiss-* extensions'
  'help-ext:list installed kiss-* extensions'
)

_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kiss command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (b|build|c|checksum|d|download|i|install|r|remove|s|search|a|alternatives|p|preferred)
        _arguments '*:package:' && ret=0 ;;
      (l|list) _arguments '*:installed package:' && ret=0 ;;
    esac ;;
esac

return ret
