#compdef sanctum-cli
# _sanctum-cli — Taylor Otwell Laravel Sanctum lightweight SPA auth CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/sanctum

_sanctum-cli() {
    local -a sub=(
        'sanctum:install:install sanctum'
        'sanctum:prune-expired:purge expired tokens'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'sanctum subcommand' sub ;;
        args)
            case $words[1] in
                sanctum:install) _arguments \
                    '--force[force overwrite]' ;;
                sanctum:prune-expired) _arguments \
                    '--hours=+[hours]:n:' ;;
            esac
            ;;
    esac
}

_sanctum-cli "$@"
