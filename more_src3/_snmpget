#compdef snmpget snmpgetnext snmpbulkget snmpbulkwalk
# _snmpget — net-snmp snmpget / snmpgetnext / snmpbulkget / snmpbulkwalk (SNMPv1/2c/3 query helpers; -v 1|2c|3 version, -c community, -u user (v3), -l noAuthNoPriv|authNoPriv|authPriv, -a SHA|MD5 auth alg, -A auth password, -x AES|DES priv alg, -X priv password, -m MIB list, -M MIB dir, -O output flags, -T timeout, -r retries, -t agent timeout; positional argument is the SNMP agent followed by OIDs)
# upstream: https://www.net-snmp.org/
# Flags from net-snmp apps/snmpget.c on tip.

_snmpget() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v+[version]:version:(1 2c 3)' \
        '-c+[community]:community:' \
        '-u+[v3 user]:user:_users' \
        '-l+[v3 security level]:level:(noAuthNoPriv authNoPriv authPriv)' \
        '-a+[v3 auth alg]:alg:(MD5 SHA SHA-224 SHA-256 SHA-384 SHA-512)' \
        '-A+[v3 auth password]:password:' \
        '-x+[v3 priv alg]:alg:(DES AES AES-192 AES-256)' \
        '-X+[v3 priv password]:password:' \
        '-m+[MIB list]:mibs:' \
        '-M+[MIB dirs]:dir:_files -/' \
        '-O+[output flags]:flags:(n e b E X q Q s S t T u U v a)' \
        '-T+[transport]:transport:' \
        '-r+[retries]:n:' \
        '-t+[timeout]:seconds:' \
        '-d[dump packets]' \
        '-D+[debug tokens]:tokens:' \
        '1:agent:_hosts' \
        '*:OID:'
}

_snmpget "$@"
