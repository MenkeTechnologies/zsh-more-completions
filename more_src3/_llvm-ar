#compdef llvm-ar
# _llvm-ar — LLVM ar archive utility (LLVM project, C++); GNU ar-compatible
# upstream: https://github.com/llvm/llvm-project

_llvm-ar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--format=+[archive format]:format:(default gnu darwin bsd)' \
        '--plugin=+[plugin]:str:' \
        '--rsp-quoting=+[response quoting]:val:(posix windows)' \
        '--thin[create thin archive]' \
        '--output=+[output dir for extract]:dir:_files -/' \
        '*:archive or member:_files'
}

_llvm-ar "$@"
