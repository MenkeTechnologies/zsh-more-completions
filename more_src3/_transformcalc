#compdef transformcalc
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/transformcalc.html
# Source: MRtrix3/mrtrix3 cmd/transformcalc.cpp — perform calculations on linear transforms (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '-template+[reference image for some operations]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*:inputs, operation (invert|half|rigid|header|average|interpolate|decompose|align_vertices_rigid|align_vertices_rigid_scale), output:_files' \
    && ret=0

return ret
