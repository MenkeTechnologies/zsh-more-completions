#compdef ko
# _ko-bin — ko Go container image builder (Google, Go); build and push Go OCI images without Dockerfile
# upstream: https://github.com/ko-build/ko

_ko-bin() {
    local -a sub=(
        'apply:apply k8s yaml after substituting ko:// images'
        'build:build a Go image'
        'create:create a yaml after substituting ko:// images'
        'delete:delete a k8s yaml'
        'login:login to image registry'
        'publish:alias for build (build+push)'
        'resolve:resolve ko:// references in yaml'
        'run:resolve, apply, run yaml'
        'version:show version'
        'completion:print shell completion'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--platform+[target platform]:str:' \
        '--bare[use bare image name]' \
        '--base-import-paths[use base import paths]' \
        '--preserve-import-paths[preserve import paths]' \
        '--tags+[tags]:tags:' \
        '-t+[tags]:tags:' \
        '--tag-only[only tag]' \
        '--push+[push image]:bool:(true false)' \
        '--local[publish locally to daemon]' \
        '-L[publish locally]' \
        '--insecure-registry[allow HTTP registry]' \
        '--oci-layout-path+[OCI layout dir]:dir:_files -/' \
        '--tarball+[output tarball]:file:_files' \
        '--sbom+[SBOM format]:fmt:(spdx cyclonedx none)' \
        '--disable-optimizations[disable optimizations]' \
        '--debug[ko debug build]' \
        '--working-directory+[cwd]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ko subcommand' sub ;;
        args)
            case $words[1] in
                build|publish) _arguments '*:packages:_files' ;;
                apply|resolve|create|delete|run) _arguments \
                    '-f+[k8s file]:file:_files' \
                    '--filename+[k8s file]:file:_files' \
                    '-l+[label selector]:selector:' \
                    '*:resource:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ko-bin "$@"
