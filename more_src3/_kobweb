#compdef kobweb
# _kobweb — Kobweb Kotlin/JS web framework (varabyte/kobweb)
# upstream: https://github.com/varabyte/kobweb

_kobweb() {
    local curcontext="$curcontext" state line ret=1

    local -a commands=(
        'create:create a new Kobweb project'
        'export:export the site for deployment'
        'run:run the development server'
        'stop:stop the development server'
        'conf:manage Kobweb configuration'
        'list:list available templates'
        'version:show version'
    )

    _arguments -C \
        '--env=[environment]:env:(dev prod)' \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'kobweb command' commands && ret=0 ;;
        args)
            case $line[1] in
                create)
                    _arguments \
                        '1:template name:' \
                        '--repo=[template repository]:repo:' && ret=0 ;;
                run)
                    _arguments \
                        '--env=[environment]:env:(dev prod)' && ret=0 ;;
                export)
                    _arguments \
                        '--layout=[export layout]:layout:(kobweb static)' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

_kobweb "$@"
