#compdef jack_rec
# Documentation: https://man.archlinux.org/man/extra/jack-example-tools/jack_rec.1.en
# Reference accessed: 2026-05-19
# Verified: upstream man page at the URL above.
# Note: prior file invented -h; the documented SYNOPSIS is
# "jack_rec -f filename -d seconds [ -b bitdepth ] port1 [ port2 ... ]".

local curcontext="$curcontext" ret=1

_arguments -C \
  '-f+[output filename]:file:_files' \
  '-d+[recording duration in seconds]:seconds:' \
  '-b+[sample bit depth]:bits:(8 16 24 32)' \
  '*:port:' && ret=0

return ret
