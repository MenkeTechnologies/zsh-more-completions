#compdef kubectl-preflight
# kubectl-preflight (krew plugin): run preflight checks for a cluster
# https://github.com/replicatedhq/troubleshoot

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '--interactive[run in interactive mode]' \
  '--collect-without-permissions[collect what is possible without RBAC]' \
  '--format=[output format]:format:(human json)' \
  '--debug[enable debug logging]' \
  '1:spec file:_files -g "*.{yaml,yml}"'
