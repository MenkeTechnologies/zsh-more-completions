#compdef kruise-game
# _kruise-game — OpenKruise Game operator (GameServer/GameServerSet controller)
# upstream: https://github.com/openkruise/kruise-game
# Flags from main.go on tip.

_kruise-game() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--namespace=[restrict controller to this namespace]:ns:' \
        '--sync-period=[informer min resync period]:dur:' \
        '--scale-server-bind-address=[scale server bind host\:port]:host\:port:' \
        '--api-server-qps=[max sustained QPS to API server]:n:' \
        '--api-server-qps-burst=[max burst QPS to API server]:n:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kruise-game "$@"
