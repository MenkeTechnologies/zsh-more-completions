#compdef solum-deployer
# Documentation: https://opendev.org/openstack/solum
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: OpenStack Solum is retired ("no longer maintained" per upstream README);
# no canonical CLI option list is published. Falling back to generic completion.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0
return ret
