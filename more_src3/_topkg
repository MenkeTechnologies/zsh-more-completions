#compdef topkg topkg-care
# _topkg — Daniel Bünzli topkg transitory package manager for OCaml CLI alias (dbuenzli team, OCaml); cmdliner
# upstream: https://github.com/dbuenzli/topkg

_topkg() {
    local -a sub=(
        'browse:open package docs in browser'
        'build:build package'
        'clean:clean build dir'
        'distrib:create distribution archive'
        'doc:build documentation'
        'help:show help'
        'ipc:internal IPC'
        'issue:issue tracker commands'
        'lint:lint package metadata'
        'log:show release log'
        'opam:opam workflow commands'
        'publish:publish distribution'
        'run:run package binary'
        'status:show package status'
        'tag:create and sign a release tag'
        'test:run tests'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--color=+[color]:c:(auto always never)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'topkg subcommand' sub ;;
        args)
            case $words[1] in
                distrib) _arguments \
                    '--pkg-name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--build-dir=+[build dir]:dir:_files -/' \
                    '--keep-build-dir[keep build dir]' \
                    '--skip-lint[skip lint]' \
                    '--skip-tests[skip tests]' \
                    '--commit-ish=+[commit-ish]:str:' \
                    '-C+[commit-ish]:str:' ;;
                publish) _arguments \
                    '*:artefact:(distrib doc alt)' \
                    '--build-dir=+[build dir]:dir:_files -/' \
                    '--msg=+[message]:str:' \
                    '-m+[message]:str:' \
                    '--dry-run[dry run]' \
                    '-d[dry run]' ;;
                opam) _arguments \
                    '1:opam cmd:(descr field pkg submit)' \
                    '--pkg-name=+[name]:str:' \
                    '-n+[name]:str:' ;;
                tag) _arguments \
                    '1:version:' \
                    '--commit=+[commit]:str:' \
                    '--sign[sign]' \
                    '-s[sign]' \
                    '--force[force]' \
                    '-f[force]' \
                    '--delete[delete]' \
                    '-d[delete]' ;;
                lint) _arguments \
                    '*:test:(custom file-meta opam std-files)' \
                    '--list[list lint tests]' ;;
                run|test) _arguments '*:target:' ;;
            esac
            ;;
    esac
}

_topkg "$@"
