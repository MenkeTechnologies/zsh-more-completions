#compdef submariner-globalnet
# _submariner-globalnet — Submariner globalnet controller (manages GlobalCIDR + GlobalEgressIP/GlobalIngressIP for overlapping pod/service CIDRs)
# upstream: https://github.com/submariner-io/submariner
# Flags from pkg/globalnet/main.go on tip; deeper config via env vars (SUBMARINER_NAMESPACE, SUBMARINER_CLUSTERID, GLOBALNET_*).

_submariner-globalnet() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--kubeconfig=[path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--master=[Kubernetes API URL]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_submariner-globalnet "$@"
