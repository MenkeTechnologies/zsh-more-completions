#compdef llama-imatrix
# Documentation: https://github.com/ggml-org/llama.cpp/tree/master/tools/imatrix
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-m+[model path]:model file:_files -g "*.gguf"' \
  '--model=[model path]:model file:_files -g "*.gguf"' \
  '-f+[calibration data file]:input file:_files' \
  '--file=[calibration data file]:input file:_files' \
  '-o+[output file]:output file:_files' \
  '--output-file=[output file]:output file:_files' \
  '--output-format=[output file format]:format:(gguf dat)' \
  '--output-frequency=[output save frequency in chunks]:frequency' \
  '--no-ppl[do not compute perplexity]' \
  '--process-output[process output tensor]' \
  '-c+[context size]:size' \
  '--ctx-size=[context size]:size' \
  '-b+[batch size]:size' \
  '--batch-size=[batch size]:size' \
  '-t+[number of threads]:threads' \
  '--threads=[number of threads]:threads' \
  '-ngl+[number of GPU layers]:layers' \
  '--gpu-layers=[number of GPU layers]:layers' \
  '--chunks=[number of chunks to process]:chunks' \
  '--no-mmap[do not memory-map model]' \
  '--mlock[force system to keep model in RAM]' \
  '--seed=[RNG seed]:seed' \
  '-lv+[verbosity level]:level' \
  '--verbosity=[verbosity level]:level' && ret=0

return ret
