#compdef kubectl-outdated
# kubectl-outdated (krew plugin): find outdated container images in a cluster
# https://github.com/replicatedhq/outdated

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace to scan]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[scan all namespaces]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--context=[kubernetes context]:context' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
  '--ignore=[ignore images matching pattern]:pattern'
