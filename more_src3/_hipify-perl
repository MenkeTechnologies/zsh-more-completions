#compdef hipify-perl
# Documentation: https://rocm.docs.amd.com/projects/HIPIFY/en/latest/reference/hipify-perl-cmd.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hipify-perl: AMD ROCm CUDA-to-HIP translator (perl-based)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-help[show help]' \
  '-cuda-kernel-execution-syntax[keep CUDA kernel launch syntax (default)]' \
  '-hip-kernel-execution-syntax[transform CUDA kernel launch syntax to HIP function call]' \
  '-examine[combine -no-output and -print-stats]' \
  '-exclude-dirs=[directories to exclude]:dirs:' \
  '-exclude-files=[files to exclude]:files:' \
  '-experimental[HIPIFY experimentally supported APIs]' \
  '-inplace[backup input to .prehip and modify in place]' \
  '-miopen[translate cuDNN to MIOpen]' \
  '-no-output[do not write hipified output]' \
  '-o=[output filename]:file:_files' \
  '-print-stats[print conversion stats]' \
  '-print-stats-csv[print CSV stats]' \
  '-quiet-warnings[do not warn on unknown CUDA functions]' \
  '*:file:_files -g "*.(cu|cuh|c|h|cc|cpp|cxx|hpp)"' && ret=0
return ret
