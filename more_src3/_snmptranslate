#compdef snmptranslate
# _snmptranslate — net-snmp snmptranslate (translate between symbolic SNMP object names and dotted OID notation against installed MIBs; -m MIB list, -M MIB dir, -T list (a|b|d|p|s|o|t), -V version, -O output flags, -I input format, -w line width, -n recurse children, -l show MIB labels; positional argument is an OID, partial name, or MIB module name)
# upstream: https://www.net-snmp.org/
# Flags from net-snmp apps/snmptranslate.c on tip.

_snmptranslate() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-m+[MIB list]:mibs:' \
        '-M+[MIB dirs]:dir:_files -/' \
        '-T+[output]:type:(a b d p s o t l)' \
        '-O+[output flags]:flags:(n e b E X q Q s S t T u U v a)' \
        '-I+[input format]:format:(b s u t f l m n p o)' \
        '-w+[width]:n:' \
        '-n[recurse children]' \
        '-l[show MIB labels]' \
        '*:OID or name:'
}

_snmptranslate "$@"
