#compdef kyverno-json
# _kyverno-json — apply Kyverno-style policies to JSON resources (kyverno/kyverno-json)
# upstream: https://github.com/kyverno/kyverno-json
# Subcommands from pkg/commands/root.go (cobra).

_kyverno-json() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'docs:generate documentation files'
                'jp:JMESPath expression evaluation'
                'playground:start interactive playground'
                'scan:apply policies to JSON resources'
                'serve:start a JSON policy server'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                scan)
                    _arguments \
                        '--bindings=[bindings file (json/yaml)]:file:_files -g "*.(json|yml|yaml)"' \
                        '--payload=[path to payload (json/yaml)]:file:_files -g "*.(json|yml|yaml)"' \
                        '*--pre-process=[JMESPath expression for pre-processing]:expr:' \
                        '*--policy=[path to kyverno-json policies]:path:_files' \
                        '*--labels=[label selectors for policies]:selectors:' \
                        '--output=[output format]:fmt:(text json)'
                    ;;
            esac
            ;;
    esac
}

_kyverno-json "$@"
