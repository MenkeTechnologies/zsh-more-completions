#compdef llamaindex
# _llamaindex — LlamaIndex data framework for LLM applications CLI (run-llama, Python); click/typer
# upstream: https://github.com/run-llama/llama_index

_llamaindex() {
    local -a sub=(
        'new:scaffold a new project'
        'rag:start a RAG over a directory'
        'add-files:add files to a RAG index'
        'serve:serve an index over HTTP'
        'evaluate:evaluate an index'
        'chat:start an interactive chat'
        'query:run a single query'
        'install:install a llama-pack/plugin'
        'download-llamapack:download a llama-pack'
        'download-llamadataset:download a llama-dataset'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llamaindex subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:project-name:' \
                    '--template=+[template]:tmpl:' \
                    '--dir=+[directory]:dir:_files -/' ;;
                rag) _arguments \
                    '1:cmd:(create-llama)' \
                    '--files=+[files dir]:dir:_files -/' \
                    '--persist-dir=+[persist dir]:dir:_files -/' \
                    '--question=+[question]:str:' \
                    '--chat[start chat]' ;;
                add-files) _arguments \
                    '--index=+[index]:str:' \
                    '*:file:_files' ;;
                serve) _arguments \
                    '--index=+[index]:str:' \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' ;;
                evaluate) _arguments \
                    '--index=+[index]:str:' \
                    '--dataset=+[dataset]:str:' ;;
                chat|query) _arguments \
                    '--index=+[index]:str:' \
                    '--question=+[question]:str:' ;;
                install|download-llamapack|download-llamadataset) _arguments \
                    '1:name:' \
                    '--download-dir=+[download dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_llamaindex "$@"
