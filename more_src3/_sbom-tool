#compdef sbom-tool
# Documentation: https://github.com/microsoft/sbom-tool/blob/main/docs/sbom-tool-arguments.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for sbom-tool - Microsoft SBOM tool

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'generate:generate an SBOM for a given build'
  'validate:validate an SBOM document'
  'redact:redact an SBOM document'
  'aggregate:aggregate multiple SBOMs'
)

_arguments -s -S -C \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'sbom-tool command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (generate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-b --BuildDropPath)'{-b,--BuildDropPath}'+[root directory of the drop]:directory:_files -/' \
          '(-bc --BuildComponentPath)'{-bc,--BuildComponentPath}'+[directory for component detection]:directory:_files -/' \
          '(-bl --BuildListFile)'{-bl,--BuildListFile}'+[build list file]:file:_files' \
          '(-m --ManifestDirPath)'{-m,--ManifestDirPath}'+[output directory for SBOM]:directory:_files -/' \
          '(-pn --PackageName)'{-pn,--PackageName}'+[package name]:name' \
          '(-pv --PackageVersion)'{-pv,--PackageVersion}'+[package version]:version' \
          '(-ps --PackageSupplier)'{-ps,--PackageSupplier}'+[package supplier]:supplier' \
          '(-di --DockerImagesToScan)'{-di,--DockerImagesToScan}'+[docker images to scan]:images' \
          '(-cd --AdditionalComponentDetectorArgs)'{-cd,--AdditionalComponentDetectorArgs}'+[additional component-detector args]:args' \
          '(-er --ExternalDocumentReferenceListFile)'{-er,--ExternalDocumentReferenceListFile}'+[external document reference list]:file:_files' \
          '(-nsu --NamespaceUriUniquePart)'{-nsu,--NamespaceUriUniquePart}'+[unique namespace part]:part' \
          '(-nsb --NamespaceUriBase)'{-nsb,--NamespaceUriBase}'+[namespace URI base]:URI' \
          '(-gt --GenerationTimestamp)'{-gt,--GenerationTimestamp}'+[generation timestamp]:timestamp' \
          '(-D --DeleteManifestDirIfPresent)'{-D,--DeleteManifestDirIfPresent}'[delete manifest directory before generating]' \
          '(-li --FetchLicenseInformation)'{-li,--FetchLicenseInformation}'[fetch license information]' \
          '(-lto --LicenseInformationTimeoutInSeconds)'{-lto,--LicenseInformationTimeoutInSeconds}'+[license fetch timeout]:seconds' \
          '(-pm --EnablePackageMetadataParsing)'{-pm,--EnablePackageMetadataParsing}'[enable package metadata parsing]' \
          '(-P --Parallelism)'{-P,--Parallelism}'+[parallelism]:n' \
          '(-F --FollowSymlinks)'{-F,--FollowSymlinks}'[follow symlinks]' \
          '(-mi --ManifestInfo)'{-mi,--ManifestInfo}'+[manifest info / SPDX version]:info' \
          '(-C --ConfigFilePath)'{-C,--ConfigFilePath}'+[configuration file path]:file:_files' \
          '(-t --TelemetryFilePath)'{-t,--TelemetryFilePath}'+[telemetry output path]:file:_files' \
          '(-V --Verbosity)'{-V,--Verbosity}'+[verbosity level]:level:(Verbose Debug Information Warning Error Fatal)' && ret=0
        ;;
      (validate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-b --BuildDropPath)'{-b,--BuildDropPath}'+[root directory of the drop]:directory:_files -/' \
          '(-m --ManifestDirPath)'{-m,--ManifestDirPath}'+[manifest directory]:directory:_files -/' \
          '(-o --OutputPath)'{-o,--OutputPath}'+[output path for validation results]:file:_files' \
          '(-C --CatalogFilePath)'{-C,--CatalogFilePath}'+[catalog file path]:file:_files' \
          '(-s --ValidateSignature)'{-s,--ValidateSignature}'[validate signature]' \
          '(-im --IgnoreMissing)'{-im,--IgnoreMissing}'[ignore missing files]' \
          '(-n --FailIfNoPackages)'{-n,--FailIfNoPackages}'[fail if no packages found]' \
          '(-r --RootPathFilter)'{-r,--RootPathFilter}'+[root path filter]:filter' \
          '(-Ha --HashAlgorithm)'{-Ha,--HashAlgorithm}'+[hash algorithm]:algorithm' \
          '(-cs --Conformance)'{-cs,--Conformance}'+[conformance standard]:standard' \
          '(-P --Parallelism)'{-P,--Parallelism}'+[parallelism]:n' \
          '(-F --FollowSymlinks)'{-F,--FollowSymlinks}'[follow symlinks]' \
          '(-mi --ManifestInfo)'{-mi,--ManifestInfo}'+[manifest info / SPDX version]:info' \
          '(-Co --ConfigFilePath)'{-Co,--ConfigFilePath}'+[configuration file path]:file:_files' \
          '(-t --TelemetryFilePath)'{-t,--TelemetryFilePath}'+[telemetry output path]:file:_files' \
          '(-V --Verbosity)'{-V,--Verbosity}'+[verbosity level]:level:(Verbose Debug Information Warning Error Fatal)' && ret=0
        ;;
      (redact)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-sp --SbomPath)'{-sp,--SbomPath}'+[path to SBOM file]:file:_files' \
          '(-sd --SbomDir)'{-sd,--SbomDir}'+[directory containing SBOMs]:directory:_files -/' \
          '(-o --OutputPath)'{-o,--OutputPath}'+[output directory]:dir:_files -/' \
          '(-V --Verbosity)'{-V,--Verbosity}'+[verbosity level]:level:(Verbose Debug Information Warning Error Fatal)' && ret=0
        ;;
      (aggregate)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-C --ConfigFilePath)'{-C,--ConfigFilePath}'+[configuration file path]:file:_files' \
          '(-t --TelemetryFilePath)'{-t,--TelemetryFilePath}'+[telemetry output path]:file:_files' \
          '(-V --Verbosity)'{-V,--Verbosity}'+[verbosity level]:level:(Verbose Debug Information Warning Error Fatal)' && ret=0
        ;;
    esac
    ;;
esac

return ret
