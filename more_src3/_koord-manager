#compdef koord-manager
# _koord-manager — Koordinator central controller manager (koordinator-sh/koordinator)
# upstream: https://github.com/koordinator-sh/koordinator
# Flags from cmd/koord-manager/main.go on tip.

_koord-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--rest-config-qps=[Kubernetes client QPS]:n:' \
        '--rest-config-burst=[Kubernetes client burst]:n:' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--health-probe-addr=[healthz/readyz bind address]:host\:port:' \
        '--enable-leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--leader-elect-resource-lock=[leader-election lock type]:lock:(leases configmaps configmapsleases endpoints endpointsleases)' \
        '--namespace=[restrict watch to a namespace]:ns:' \
        '--enable-pprof=[enable pprof server]:bool:(true false)' \
        '--pprof-addr=[pprof bind address]:host\:port:' \
        '--sync-period=[informer min resync period]:dur:' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_koord-manager "$@"
