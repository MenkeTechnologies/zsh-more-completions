#compdef surfaceMeshImport
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/surface/surfaceMeshImport — import foreign-format surface as OpenFOAM surfaceMesh (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-noFunctionObjects[disable function objects]' \
    '-clean[clean/check surface]' \
    '-name+[name of triSurface output]:name:_default' \
    '-scaleIn+[input scaling factor]:factor:_default' \
    '-scaleOut+[output scaling factor]:factor:_default' \
    '-from+[input coordinate system]:coordinateSystem:_default' \
    '-to+[output coordinate system]:coordinateSystem:_default' \
    '1:input surface file:_files -g "*.{stl,obj,nas,vtk,off,gts,inp}"' \
    && ret=0

return ret
