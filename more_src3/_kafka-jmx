#compdef kafka-jmx
# Documentation: https://kafka.apache.org/documentation/ (kafka-jmx.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--attributes[Comma-separated list of attributes to include in the query]:attributes:'
    '--date-format[Date format (java.text.SimpleDateFormat) for the time field]:format:'
    '--help[Print usage information]'
    '--jmx-auth-prop[Pass property as username=password for remote JMX password auth]:auth-prop:'
    '--jmx-ssl-enable[Flag to enable remote JMX with SSL]:ssl-enable:(true false)'
    '--jmx-url[The url to connect to poll JMX data]:service-url:'
    '--object-name[A JMX object name to use as a query (may be given multiple times)]:name:'
    '--one-time[Flag to indicate run once only]:one-time:(true false)'
    "--report-format[Output format name]:format:(original properties csv tsv)"
    '--reporting-interval[Interval in ms with which to poll jmx stats]:ms:'
    '--version[Display Kafka version]'
    '--wait[Wait for requested JMX objects to become available before starting output]'
)

_arguments -s -S $arguments
