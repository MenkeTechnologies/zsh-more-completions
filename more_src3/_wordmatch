#compdef wordmatch
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/wordmatch.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS wordmatch: find exact word matches between two sequences.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help and exit]' \
  '-auto[turn off all prompts]' \
  '-stdout[write standard output]' \
  '-filter[read stdin/write stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug log]' \
  '-verbose[verbose output]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying messages]' \
  '-version[report version]' \
  '-asequence=[first sequence set]:file:_files' \
  '-bsequence=[second sequence(s)]:file:_files' \
  '-wordsize=[length of identical regions]:size:' \
  '-outfile=[alignment output file]:file:_files' \
  '-dumpalign[dump matches as alignments]' \
  '-logfile=[statistical log file]:file:_files' \
  '-dumpfeat[dump matches as feature files]' \
  '-aoutfeat=[feature output for a]:file:_files' \
  '-boutfeat=[feature output for b]:file:_files' \
  '*:sequence:_files' && ret=0

return ret
