#compdef servertell
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/servertell.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.
# Removed from prior file: fabricated -servername (real flag is
# -server), -html, -fields, -methods, -formats, -status (none exist in
# upstream — only -full is documented).

# EMBOSS servertell: show details of a server configured in emboss.default
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-server=[name of server defined locally for EMBOSS]:server:' \
  '-full[report full server info including database lists]' \
  '-outfile=[output file]:file:_files' \
  '-odirectory=[output directory]:dir:_files -/' \
  '*:server name:' && ret=0

return ret
