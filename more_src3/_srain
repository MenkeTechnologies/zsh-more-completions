#compdef srain
# Documentation: https://github.com/SrainApp/srain/blob/master/src/sui/sui_app.c
# Reference accessed: 2026-05-21
# Verified: upstream source at the URL above (option_entries array).
# Confirmed flags: --version/-v, --no-auto/-a, plus GLib/GTK help groups.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all help options]' \
  '(- *)--help-gapplication[show GApplication options]' \
  '(- *)--help-gtk[show GTK+ options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --no-auto)'{-a,--no-auto}'[do not auto-connect to configured servers]' \
  '*:IRC URL:_urls' && ret=0

return ret
