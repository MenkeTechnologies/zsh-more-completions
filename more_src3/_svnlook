#compdef svnlook
# Documentation: https://svnbook.red-bean.com/en/1.8/svn.ref.svnlook.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a subcommands
subcommands=(
    'author:Print the author'
    'cat:Print contents of a file'
    'changed:Print changed paths'
    'date:Print the datestamp'
    'diff:Print differences'
    'dirs-changed:Print changed directories'
    'filesize:Print file sizes'
    'help:Show help'
    'history:Print path history'
    'info:Print author, datestamp, log size, and log'
    'lock:Print lock info for a path'
    'log:Print the log message'
    'propget:Print value of a property'
    'proplist:Print all properties'
    'tree:Print the tree'
    'uuid:Print the repository UUID'
    'youngest:Print the youngest revision number'
)

_arguments -C \
    '1:subcommand:->subcmd' \
    '*:: :->args'

case $state in
    subcmd)
        _describe -t subcommands 'svnlook subcommand' subcommands
        ;;
    args)
        _arguments \
            '-r[Revision]:revision' \
            '--revision[Revision]:revision' \
            '-t[Transaction]:transaction' \
            '--transaction[Transaction]:transaction' \
            '--no-diff-deleted[Do not show diff of deleted files]' \
            '--no-diff-added[Do not show diff of added files]' \
            '--diff-cmd[Use external diff program]:cmd' \
            '--diff-copy-from[Show diff against copy source]' \
            '--show-ids[Show node IDs]' \
            '-l[Maximum number of history entries]:limit' \
            '--limit[Maximum number of history entries]:limit' \
            '-N[Operate on single directory only]' \
            '--non-recursive[Operate on single directory only]' \
            '--extensions[Diff extensions]:extensions' \
            '-x[Diff extensions]:extensions' \
            '--full-paths[Show full paths]' \
            '--copy-info[Show copy info]' \
            '--ignore-properties[Ignore properties]' \
            '--properties-only[Only show properties]' \
            '--revprop[Operate on a revision property]' \
            '--show-inherited-props[Show inherited properties]' \
            '-v[Verbose output]' \
            '--verbose[Verbose output]' \
            '--xml[Output in XML format]' \
            '*:repository path:_files'
        ;;
esac
