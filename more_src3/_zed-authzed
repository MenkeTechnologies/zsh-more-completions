#compdef zed-authzed authzed
# Documentation: https://github.com/authzed/zed
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Command tree (context/schema/permission/relationship/backup/import/
# preview/use/validate/experimental) confirmed from upstream README.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'context:manage zed contexts (set/use/list/remove)'
  'schema:schema operations (read/write/copy/diff/compile)'
  'permission:permission ops (check/lookup-resources/lookup-subjects/expand/bulk-check)'
  'relationship:relationship ops (create/touch/delete/read/bulk-delete)'
  'backup:backup or restore a SpiceDB instance'
  'import:import data from gists/pastebins/playground/file'
  'preview:preview API helpers (lookup-subjects/check-bulk)'
  'use:select active context'
  'validate:validate a schema/check'
  'experimental:experimental commands'
  'completion:generate shell completion'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--endpoint=[SpiceDB endpoint]:url:' \
  '--token=[bearer token]:token:' \
  '--api-token=[bearer token (alias)]:token:' \
  '--certificate-path=[CA cert path]:file:_files' \
  '--hostname-override=[override TLS server name]:host:' \
  '--insecure[disable TLS]' \
  '--log-format=[log format]:format:(text json console)' \
  '--log-level=[log level]:level:(trace debug info warn error)' \
  '--max-message-size=[max message size]:n:' \
  '--max-retries=[max RPC retries]:n:' \
  '--no-verify-ca[skip TLS CA verification]' \
  '--permissions-system=[permissions system slug]:slug:' \
  '--proxy=[HTTP/SOCKS proxy URL]:url:' \
  '--request-id=[X-Request-ID]:id:' \
  '--skip-version-check[skip server version check]' \
  '*--metadata=[gRPC metadata key=value]:meta:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'zed command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (context)
        _arguments '*::sub:(set use list remove current)' && ret=0 ;;
      (schema)
        _arguments '*::sub:(read write copy diff compile)' && ret=0 ;;
      (permission)
        _arguments \
          '*::sub:(check lookup-resources lookup-subjects expand bulk-check)' \
          '--explain[show check trace]' \
          '--at-revision=[zedtoken or revision]:rev:' \
          '--consistency-at-least=[at-least-as-fresh]:rev:' \
          '--consistency-fully-consistent[fully consistent]' && ret=0 ;;
      (relationship)
        _arguments \
          '*::sub:(create touch delete read bulk-delete)' \
          '--caveat=[caveat name and context]:caveat:' \
          '--json[output JSON]' \
          '--batch-size=[batch size]:n:' && ret=0 ;;
      (backup)
        _arguments \
          '*::sub:(create restore parse-revision parse-schema redact)' \
          '--conflict-strategy=[restore conflict strategy]:strategy:(skip touch fail)' \
          '--disable-retries[disable client retries]' \
          '--prefix-filter=[only resources/subjects matching prefix]:prefix:' && ret=0 ;;
      (import)
        _arguments \
          '--relationships[only import relationships]' \
          '--schema[only import schema]' \
          '*::source:' && ret=0 ;;
      (validate)
        _arguments '*::file:_files' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
