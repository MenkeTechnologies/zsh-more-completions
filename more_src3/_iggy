_iggy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[quiet mode (disabled stdout printing)]' \
        '(-d --debug)'{-d,--debug}'=[debug mode (verbose printing to file)]:path:_files' \
        '(-u --username)'{-u,--username}'=[Iggy server username]:user:' \
        '(-p --password)'{-p,--password}'=[Iggy server password]:pass:' \
        '(-t --token)'{-t,--token}'=[personal access token]:token:' \
        '(-n --token-name)'{-n,--token-name}'=[token name from secure storage]:name:' \
        '--generate=[emit shell completion]:shell:(bash zsh fish powershell elvish)' \
        '--transport=[connection transport]:transport:(TCP QUIC HTTP)' \
        '--tcp-server-address=[TCP server address]:addr:' \
        '--quic-server-address=[QUIC server address]:addr:' \
        '--http-server-address=[HTTP server address]:addr:' \
        '--encryption-key=[BASE64-encoded encryption key]:key:' \
        '--message-batch-size=[message batch size]:n:' \
        '--heartbeat-interval=[heartbeat interval]:duration:' \
        '--reconnect-interval-ms=[reconnect interval (ms)]:n:' \
        '--reconnect-max-retries=[max reconnect retries]:n:' \
        '--reconnect-replenish-interval-ms=[token bucket replenish interval (ms)]:n:' \
        '--reconnect-max-tokens=[token bucket max tokens]:n:' \
        '--consumer-name=[consumer name]:name:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _iggy_cmds=(
                'stream:stream operations'
                's:stream operations (alias)'
                'topic:topic operations'
                't:topic operations (alias)'
                'partition:partition operations'
                'p:partition operations (alias)'
                'segment:segment operations'
                'seg:segment operations (alias)'
                'ping:ping iggy server'
                'me:get current client info'
                'stats:get iggy server statistics'
                'snapshot:collect iggy server troubleshooting data'
                'pat:personal access token operations'
                'user:user operations'
                'u:user operations (alias)'
                'client:connected-client operations'
                'c:client operations (alias)'
                'cluster:cluster operations'
                'cl:cluster operations (alias)'
                'consumer-group:consumer group operations'
                'g:consumer group operations (alias)'
                'consumer-offset:consumer offset operations'
                'o:consumer offset operations (alias)'
                'message:message operations'
                'm:message operations (alias)'
                'context:context operations'
                'ctx:context operations (alias)'
                'login:login to Iggy server (login-session feature)'
                'li:login (alias)'
                'logout:logout from Iggy server'
                'lo:logout (alias)'
                'session:login session operations'
                'sess:session operations (alias)'
                'help:show help'
            )
            _describe -t commands 'iggy command' _iggy_cmds && ret=0
            ;;
        args)
            case $words[1] in
                stream|s)
                    _arguments \
                        '1:action:(create delete update get list purge)' \
                        '*: :_files' && ret=0
                    ;;
                topic|t)
                    _arguments \
                        '1:action:(create delete update get list purge)' \
                        '*: :_files' && ret=0
                    ;;
                partition|p)
                    _arguments \
                        '1:action:(create delete)' \
                        '*: :_files' && ret=0
                    ;;
                segment|seg)
                    _arguments \
                        '1:action:(delete)' \
                        '*: :_files' && ret=0
                    ;;
                message|m)
                    _arguments \
                        '1:action:(send poll flush)' \
                        '*: :_files' && ret=0
                    ;;
                user|u)
                    _arguments \
                        '1:action:(create delete update get list change-password permissions set-status)' \
                        '*: :_files' && ret=0
                    ;;
                pat)
                    _arguments \
                        '1:action:(create delete list)' \
                        '*: :_files' && ret=0
                    ;;
                client|c)
                    _arguments \
                        '1:action:(get list)' \
                        '*: :_files' && ret=0
                    ;;
                cluster|cl)
                    _arguments \
                        '1:action:(metadata)' \
                        '*: :_files' && ret=0
                    ;;
                consumer-group|g)
                    _arguments \
                        '1:action:(create delete get list)' \
                        '*: :_files' && ret=0
                    ;;
                consumer-offset|o)
                    _arguments \
                        '1:action:(get set)' \
                        '*: :_files' && ret=0
                    ;;
                context|ctx)
                    _arguments \
                        '1:action:(create delete show use list)' \
                        '*: :_files' && ret=0
                    ;;
                session|sess)
                    _arguments \
                        '1:action:(list delete)' \
                        '*: :_files' && ret=0
                    ;;
                ping|me|stats|snapshot|login|li|logout|lo)
                    _arguments '*: :_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_iggy "$@"
