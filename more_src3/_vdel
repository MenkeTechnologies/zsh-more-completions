#compdef vdel
# _vdel — Mentor Siemens EDA ModelSim/Questa vdel CLI removing compiled design units modules entities architectures packages from a Verilog/VHDL library managing library metadata _info file consistency clean orphaned entries (Siemens team, C++); custom argparse
# upstream: https://eda.sw.siemens.com/en-US/ic/questa/simulation/advanced-simulator/

_vdel() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-modelsimini=+[ini file]:file:_files -g "*.ini"' \
        '-lib=+[library]:str:' \
        '-all[delete all units]' \
        '-allsystem[delete all system units]' \
        '-quiet[quiet]' \
        '-verbose[verbose]' \
        '-relax[relax]' \
        '*:design unit:'
}

_vdel "$@"
