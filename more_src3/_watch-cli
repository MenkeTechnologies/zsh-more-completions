#compdef watch-cli
# _watch-cli — procps watch execute a program periodically CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_watch-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[beep if command exit non-zero]' \
        '--beep[beep if command exit non-zero]' \
        '-c[interpret ANSI color sequences]' \
        '--color[interpret ANSI color sequences]' \
        '-C[no color]' \
        '--no-color[no color]' \
        '-d[highlight changes]' \
        '--differences[highlight changes]' \
        '--differences=+[mode]:m:(permanent)' \
        '-e[exit on error]' \
        '--errexit[exit on error]' \
        '-g[exit when output changes]' \
        '--chgexit[exit when output changes]' \
        '-q[exit when output stable]' \
        '--equexit=+[cycles]:n:' \
        '-n+[interval seconds]:str:' \
        '--interval=+[interval seconds]:str:' \
        '-p[precise timing]' \
        '--precise[precise timing]' \
        '-r[do not run in tty mode]' \
        '--no-rerun[do not rerun program]' \
        '-t[turn off header]' \
        '--no-title[turn off header]' \
        '-w[turn off line wrap]' \
        '--no-wrap[turn off line wrap]' \
        '-x[pass command via exec]' \
        '--exec[pass command via exec]' \
        '*:command:_command_names'
}

_watch-cli "$@"
