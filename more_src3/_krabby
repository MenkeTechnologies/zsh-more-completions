#compdef krabby
# Documentation: https://github.com/yannjor/krabby
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (README + src/main.rs
# clap definitions). Completely rewritten: prior file invented a
# "yuk1ty/krabby Chromium automation CLI" with crawl/fetch/login/
# config verbs that do not exist. Real krabby is a Rust CLI that
# prints Pokemon sprites in the terminal (subcommands list/name/
# random).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'list:print list of all pokemon'
  'name:select pokemon by name'
  'random:show a random pokemon'
  'help:print help for a subcommand'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'krabby' subcmds && ret=0
    ;;
  args)
    case $line[1] in
      name)
        _arguments -s -S \
          '(-i --info)'{-i,--info}'[print pokedex entry (if it exists)]' \
          '(-s --shiny)'{-s,--shiny}'[show the shiny version of the pokemon]' \
          '--no-title[do not display pokemon name]' \
          '--padding-left=[left padding]:cols:' \
          '(-f --form)'{-f+,--form=}'[show an alternative form of the pokemon]:form:' \
          '1:pokemon name:' && ret=0
        ;;
      random)
        _arguments -s -S \
          '(-i --info)'{-i,--info}'[print pokedex entry (if it exists)]' \
          '(-s --shiny)'{-s,--shiny}'[show the shiny version of the pokemon]' \
          '--no-title[do not display pokemon name]' \
          '--padding-left=[left padding]:cols:' \
          '--no-mega[do not show mega pokemon]' \
          '--no-gmax[do not show gigantamax pokemon]' \
          '--no-regional[do not show regional pokemon]' \
          '--no-variant[do not show any variant-form pokemon]' \
          '1:generations (number or range 1-9):' && ret=0
        ;;
      list)
        _arguments '1:generations (number or range 1-9):' && ret=0
        ;;
    esac
    ;;
esac

return ret
