#compdef julia
# Documentation: https://docs.julialang.org/en/v1/manual/command-line-interface/
# Source: JuliaLang/julia src/jloptions.c — Julia language CLI (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-v,--version}'[show version]' \
    {-h,--help}'[show help]' \
    '--help-hidden[show hidden help]' \
    {-i,--interactive}'[interactive mode]' \
    {-q,--quiet}'[quiet startup]' \
    '--banner=-[startup banner]:mode:(yes no auto short)' \
    {-H+,--home=}'[set Julia home directory]:dir:_files -/' \
    '*'{-e+,--eval=}'[evaluate expression]:expr:_default' \
    {-m+,--module=}'[entry module]:mod:_default' \
    {-E+,--print=}'[evaluate and print expression]:expr:_default' \
    '*'{-L+,--load=}'[load file]:file:_files -g "*.jl"' \
    '--bug-report=-[generate bug report]:mode:(rr rr-local)' \
    {-J+,--sysimage=}'[start with system image file]:file:_files' \
    '--sysimage-native-code=-[use native code from sysimage]:mode:(yes no)' \
    '--compiled-modules=-[use cached compiled modules]:mode:(yes no existing strict)' \
    '--pkgimages=-[use precompiled pkg images]:mode:(yes no existing)' \
    {-C+,--cpu-target=}'[CPU target]:target:_default' \
    {-p+,--procs=}'[worker processes]:n:_default' \
    {-t+,--threads=}'[thread counts]:spec:_default' \
    '--gcthreads=-[GC threads]:n:_default' \
    '--machine-file=-[machine description file]:file:_files' \
    {-P-,--project=-}'[project directory]::dir:_files -/' \
    '--color=-[colorize output]:mode:(auto yes no)' \
    '--history-file=-[load/save REPL history]:mode:(yes no)' \
    '--startup-file=-[load startup.jl]:mode:(yes no)' \
    '--compile=-[compile mode]:mode:(yes no all min)' \
    '--code-coverage=-[code coverage]::mode:(none user all)' \
    '--track-allocation=-[allocation tracking]::mode:(none user all)' \
    '-O-[optimization level]::n:(0 1 2 3)' \
    '--optimize=-[optimization level]:n:(0 1 2 3)' \
    '--min-optlevel=-[min optimization]:n:(0 1 2 3)' \
    '-g-[debug info level]::n:(0 1 2)' \
    '--debug-info=-[debug info level]:n:(0 1 2)' \
    '--check-bounds=-[bounds checking]:mode:(yes no auto)' \
    '--output-bc=-[generate LLVM bitcode]:file:_files' \
    '--output-unopt-bc=-[unoptimised bitcode]:file:_files' \
    '--output-o=-[generate object file]:file:_files' \
    '--output-asm=-[generate assembly]:file:_files' \
    '--output-ji=-[generate Julia image]:file:_files' \
    '--output-incremental=-[incremental output]:mode:(yes no)' \
    '--depwarn=-[deprecation warnings]:mode:(yes no error)' \
    '--warn-overwrite=-[warn on method overwrite]:mode:(yes no)' \
    '--task-metrics=-[collect task metrics]:mode:(yes no)' \
    '--math-mode=-[math evaluation mode]:mode:(ieee user fast)' \
    '--handle-signals=-[handle signals internally]:mode:(yes no)' \
    '--experimental[enable experimental features]' \
    '--worker=-[run as worker]::cookie:_default' \
    '--bind-to=-[bind to address]:addr:_default' \
    '--lisp[start with Femtolisp REPL]' \
    '--image-codegen[force image codegen mode]' \
    '--strip-metadata[strip metadata for system image build]' \
    '--strip-ir[strip Julia IR for system image build]' \
    '--permalloc-pkgimg=-[permalloc pkg image]:mode:(yes no)' \
    '--heap-size-hint=-[GC heap size hint]:size:_default' \
    '--hard-heap-limit=-[hard heap limit]:size:_default' \
    '--heap-target-increment=-[heap target increment]:size:_default' \
    '--gc-sweep-always-full[always do full GC sweep]' \
    '--trim=-[trim sysimage]::mode:(no safe unsafe unsafe-warn)' \
    '--compress-sysimage=-[compress system image]:mode:(yes no)' \
    '--trace-eval=-[trace evaluation]::mode:_default' \
    '--target-sanitize=-[target sanitizer]:san:_default' \
    '1::script:_files -g "*.jl"' \
    '*::script args:_default' \
    && ret=0

return ret
