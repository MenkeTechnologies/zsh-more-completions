#compdef sortm
# Documentation: man sortm(1)
# Source: nmh uip/sortm.c (master) — sort nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-datefield+[date header field]:field:_default' \
    '-textfield+[text header field for sort key]:field:_default' \
    '-notextfield[disable text sort key]' \
    '-subject[sort by subject (deprecated alias)]' \
    '-limit+[limit window (days)]:days:_default' \
    '-nolimit[no limit]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-all -noall)-all[sort all messages]' \
    '(-all -noall)-noall[sort only specified]' \
    '(-check -nocheck)-check[check date parseability]' \
    '(-check -nocheck)-nocheck[no check]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
