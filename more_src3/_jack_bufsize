#compdef jack_bufsize
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/tools/bufsize.c
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above.
# Note: prior file invented -h and -s flags; real usage is
# "jack_bufsize <bufsize>" — a single positional, no options.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:buffer frames:(32 64 128 256 512 1024 2048 4096)' && ret=0

return ret
