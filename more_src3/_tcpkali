#compdef tcpkali
# Documentation: https://github.com/satori-com/tcpkali (README)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose=[verbosity level]:level:(0 1 2 3)' \
  '(--ws --websocket)'{--ws,--websocket}'[use RFC6455 WebSocket transport]' \
  '(-c --connections)'{-c+,--connections=}'[connections to keep open]:n:' \
  '--connect-rate=[max new connections per second]:rate:' \
  '--connect-timeout=[connection attempt timeout]:duration:' \
  '--channel-lifetime=[shut down each connection after T]:duration:' \
  '--channel-bandwidth=[limit single connection bandwidth]:bw:' \
  '(-l --listen-port)'{-l+,--listen-port=}'[listen on specified port]:port:' \
  '(-w --workers)'{-w+,--workers=}'[number of parallel threads]:n:' \
  '(-T --duration)'{-T+,--duration=}'[load test duration]:duration:' \
  '(-e --unescape-message-args)'{-e,--unescape-message-args}'[unescape -m/-f/--first-* args]' \
  '--first-message=[send this message first, once]:msg:' \
  '--first-message-file=[read first message from file]:file:_files' \
  '*'{-m+,--message=}'[message to repeatedly send]:msg:' \
  '*'{-f+,--message-file=}'[read message from file]:file:_files' \
  '(-r --message-rate)'{-r+,--message-rate=}'[messages per second]:rate:' \
  '--latency-marker=[measure latency using per-message marker]:str:' \
  '--statsd[enable StatsD output]' \
  '--statsd-host=[StatsD host]:host:_hosts' \
  '--statsd-port=[StatsD port]:port:' \
  '--statsd-namespace=[metric namespace]:ns:' \
  '*:host\:port:'
