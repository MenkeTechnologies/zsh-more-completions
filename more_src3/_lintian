#compdef lintian
# Documentation: https://manpages.debian.org/lintian
# Source: live-clones/lintian bin/lintian — Debian package QA checker (Perl, Getopt::Long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--print-version[print version only]' \
    '(--no-allow-root)--allow-root[allow running as root]' \
    '--no-allow-root[disallow running as root]' \
    '--cfg=-[config file]:file:_files' \
    '--no-cfg[do not read config file]' \
    '(--no-user-dirs)--user-dirs[allow per-user dirs]' \
    '--no-user-dirs[skip per-user dirs]' \
    '--ignore-lintian-env[ignore LINTIAN_* env vars]' \
    '*'{-c+,--check=}'[run named check]:check:_default' \
    '*'{-C+,--check-part=}'[run part of named check]:check:_default' \
    '*'{-X+,--dont-check-part=}'[skip part of named check]:check:_default' \
    '--color=-[colour output mode]:mode:(never always auto html)' \
    '*'{-d,--debug}'[debug output (stackable)]' \
    '--default-display-level[reset display level to default]' \
    '(--no-display-experimental -E --display-experimental)'{-E,--display-experimental}'[show experimental tags]' \
    '--no-display-experimental[hide experimental tags]' \
    '*'{-L+,--display-level=}'[display level filter]:level:_default' \
    '(-I --display-info)'{-I,--display-info}'[also display I: tags]' \
    '*--display-source=-[show only tags from named source]:source:_default' \
    '--exp-output=-[experimental output format]:fmt:_default' \
    '*--fail-on=-[exit non-zero on tag class]:class:(none error warning info pedantic experimental override)' \
    '(-F --ftp-master-rejects)'{-F,--ftp-master-rejects}'[only display tags that would cause ftp-master rejection]' \
    '--hide-overrides[hide overridden tags (deprecated; use --no-show-overrides)]' \
    '--hyperlinks=-[hyperlink mode]:mode:(on off auto)' \
    '*--include-dir=-[additional include directory]:dir:_files -/' \
    '(--no-info -i --info)'{-i,--info}'[show short description after each tag]' \
    '--no-info[do not show descriptions]' \
    '(-j --jobs)'{-j+,--jobs=}'[parallel job count]:n:_default' \
    '(-o --no-override)'{-o,--no-override}'[ignore overrides]' \
    '--no-tag-display-limit[deprecated; use --tag-display-limit=0]' \
    '--output-width=-[output width]:n:_default' \
    '--packages-from-file=-[read packages from file]:file:_files' \
    '--pedantic[show pedantic tags]' \
    '--perf-debug[performance debugging]' \
    '--profile=-[lintian profile]:profile:_default' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
    '(--no-show-overrides)--show-overrides[show overridden tags]' \
    '--no-show-overrides[hide overridden tags]' \
    '--status-log=-[per-package status log]:file:_files' \
    '*--suppress-tags=-[comma-separated tags to suppress]:tags:_default' \
    '--suppress-tags-from-file=-[file with tags to suppress]:file:_files' \
    '--tag-display-limit=-[max tag count to display]:n:_default' \
    '*'{-T+,--tags=}'[only emit named tags]:tags:_default' \
    '--tags-from-file=-[file with tag names]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '*:package or directory:_files -g "*.{deb,udeb,changes,dsc}"' \
    && ret=0

return ret
