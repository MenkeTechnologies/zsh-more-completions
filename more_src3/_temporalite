#compdef temporalite
# Documentation: https://github.com/temporalio/temporalite
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cmd/temporalite/main.go flag definitions).

# Zsh completion for temporalite - all-in-one Temporal dev server

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'start:start the Temporal server'
    )
    _describe -t commands 'temporalite command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start)
        _arguments -s -S \
          '--ephemeral[use in-memory storage]' \
          '(-f --filename)'{-f,--filename=}'[database file path]:database file:_files' \
          '*'{-n,--namespace=}'[pre-create namespace]:namespace' \
          '(-p --port)'{-p,--port=}'[frontend gRPC port]:port' \
          '--metrics-port=[metrics port]:port' \
          '--ui-port=[Web UI port]:port' \
          '--headless[disable the UI]' \
          '--ip=[IPv4 address for frontend]:ip' \
          '--ui-ip=[IPv4 address for Web UI]:ip' \
          '--ui-codec-endpoint=[UI remote codec HTTP endpoint]:url' \
          '--log-format=[log format]:format:(json pretty)' \
          '--log-level=[log level]:level:(debug info warn error fatal)' \
          '*'{-sp,--sqlite-pragma=}'[SQLite pragma statement]:pragma' \
          '(-c --config)'{-c,--config=}'[configuration directory]:dir:_directories' \
          '*--dynamic-config-value=[dynamic config value KEY=JSON]:value' && ret=0
        ;;
    esac
    ;;
esac

return ret
