#compdef tracebox
# Documentation: https://github.com/tracebox/tracebox
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '-h[show help]' \
  '-n[no DNS resolution]' \
  '-6[IPv6]' \
  '-u[UDP probe]' \
  '-d[destination port]:port:' \
  '-i[interface]:iface:_net_interfaces' \
  '-m[max hops]:n:' \
  '-M[min hops]:n:' \
  '-p[probe specification]:probe:' \
  '-l[inline Lua script]:script:' \
  '-s[Lua script file]:file:_files -g "*.lua"' \
  '-v[verbose]' \
  '-w[wait time]:s:' \
  '-f[input file]:file:_files' \
  '-j[JSON output]' \
  '-t[timeout]:s:' \
  '-S[server mode]' \
  '-c[server URL]:url:' \
  '-C[disable scamper]' \
  '*:host: _hosts'
