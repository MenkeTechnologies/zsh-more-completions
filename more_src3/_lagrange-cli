#compdef lagrange-cli lagrange
# _lagrange-cli — Jaakko Keränen Lagrange Gemini-protocol browser CLI alias (skyjake team, C); custom argparse
# upstream: https://github.com/skyjake/lagrange

_lagrange-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dump[dump rendered text]' \
        '-d[dump rendered text]' \
        '--dump-identity=+[identity name]:str:' \
        '-I+[identity name]:str:' \
        '--new-tab[open in new tab]' \
        '-n[open in new tab]' \
        '--bg=+[background mode]:bg:(0 1 minimized hidden)' \
        '-b+[background mode]:bg:(0 1 minimized hidden)' \
        '--close-tab[close tab]' \
        '-c[close tab]' \
        '--list-tab-urls[list tab urls]' \
        '--prefs-sheet[open preferences sheet]' \
        '--replace-tab[replace active tab]' \
        '-r[replace active tab]' \
        '--tab-url=+[tab url]:url:_urls' \
        '--theme=+[theme]:t:(black dark light gray sepia colorfulDark colorfulLight white)' \
        '-t+[theme]:t:(black dark light gray sepia colorfulDark colorfulLight white)' \
        '--user=+[user data dir]:dir:_files -/' \
        '-u+[user data dir]:dir:_files -/' \
        '--echo[echo to stdout]' \
        '-e[echo to stdout]' \
        '--no-tab-bar[hide tab bar]' \
        '--no-bookmarks[hide bookmarks]' \
        '--sw=+[sidebar width]:n:' \
        '--swr=+[secondary sidebar width]:n:' \
        '--font=+[font path]:file:_files' \
        '--listen=+[control socket]:str:' \
        '*:url:_urls'
}

_lagrange-cli "$@"
