#compdef xxd
# _xxd-bin — xxd hex dump tool shipped with Vim; canonical hex dump + reverse mode (text → binary)
# upstream: https://github.com/vim/vim/tree/master/src/xxd

_xxd-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-a[autoskip output]' \
        '-b[binary digit (instead of hex)]' \
        '-c+[cols per line]:n:' \
        '-C[capitalize variable names in C include]' \
        '-d[show offset in decimal]' \
        '-E[show characters in EBCDIC]' \
        '-e[little-endian dump]' \
        '-g+[group size]:n:' \
        '-i[output as C include]' \
        '-l+[length bytes]:n:' \
        '-n+[name in C include]:name:' \
        '-o+[offset]:n:' \
        '-p[plain hex dump]' \
        '-r[reverse: text to binary]' \
        '-s+[seek offset]:n:' \
        '-u[uppercase hex]' \
        '*:file:_files'
}

_xxd-bin "$@"
