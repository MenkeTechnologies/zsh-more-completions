#compdef terminator
# Documentation: https://manpages.debian.org/bookworm/terminator/terminator.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for terminator - multiple terminal emulator

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-m --maximise -M --maximize)'{-m,--maximise}'[maximise the window]' \
  '(-m --maximise -M --maximize)'{-M,--maximize}'[maximise the window]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in fullscreen mode]' \
  '(-b --borderless)'{-b,--borderless}'[start without window border]' \
  '(-H --hidden)'{-H,--hidden}'[start hidden]' \
  '(-T --title)'{-T,--title=}'[set window title]:title:' \
  '--geometry=[set window geometry]:geometry:' \
  '(-r --role)'{-r,--role=}'[set window role]:role:' \
  '--icon=[set window icon]:icon:_files' \
  '(-e --command)'{-e,--command=}'[execute command inside terminal]:command:_command_names' \
  '(-x --execute)'{-x,--execute}'[execute rest of command line]:command:_command_names' \
  '(-g --config)'{-g,--config=}'[config file]:file:_files' \
  '(-p --profile)'{-p,--profile=}'[use profile]:profile:' \
  '(-l --layout)'{-l,--layout=}'[launch with layout]:layout:' \
  '(-s --select-layout)'{-s,--select-layout=}'[show layout launcher]:layout:' \
  '(-u --no-dbus)'{-u,--no-dbus}'[disable DBus]' \
  '(-d --debug)'{-d,--debug}'[enable debugging]' \
  '--debug-classes=[debug specific classes]:classes:' \
  '--debug-methods=[debug specific methods]:methods:' \
  '--new-tab[open in a new tab]' \
  '--working-directory=[set working directory]:directory:_directories'
