#compdef innwatch
# Documentation: man innwatch(8)
# Source: InterNetNews/inn scripts/innwatch.in — monitor innd disk/load (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[innwatch control file]:file:_files' \
    '-i+[initial sleep seconds]:secs:_default' \
    '-l+[log file]:file:_files' \
    '-t+[between-checks sleep seconds]:secs:_default' \
    && ret=0

return ret
