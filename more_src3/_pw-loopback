#compdef pw-loopback
# Documentation: https://docs.pipewire.org/page_man_pw-loopback_1.html
# Source: PipeWire — virtual loopback node that mirrors capture to playback.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-r --remote)'{-r+,--remote=}'[remote instance name]:name:' \
    '(-n --name)'{-n+,--name=}'[loopback node name]:name:' \
    '(-g --group)'{-g+,--group=}'[loopback node group name]:group:' \
    '(-c --channels)'{-c+,--channels=}'[number of channels]:n:' \
    '(-m --channel-map)'{-m+,--channel-map=}'[channel map (default [FL, FR])]:map:' \
    '(-l --latency)'{-l+,--latency=}'[desired latency in ms]:ms:' \
    '(-d --delay)'{-d+,--delay=}'[added delay in seconds (float ok)]:seconds:' \
    '(-C --capture)'{-C+,--capture=}'[capture target device]:target:' \
    '(-P --playback)'{-P+,--playback=}'[playback target device]:target:' \
    '(-i --capture-props)'{-i+,--capture-props=}'[capture-node properties (JSON)]:json:' \
    '(-o --playback-props)'{-o+,--playback-props=}'[playback-node properties (JSON)]:json:' \
    && ret=0

return ret
