#compdef survive-cli
# _survive-cli — libsurvive command-line driver for HTC Vive lighthouse tracking (cnlohr/libsurvive)
# upstream: https://github.com/cnlohr/libsurvive
# Flags from src/survive.c (STATIC_CONFIG_ITEM macros).

_survive-cli() {
    _arguments \
        '--v=[verbosity level]:n:' \
        '--blacklist-devs=[devices or substrings to blacklist]:list:' \
        '--configfile=[default configuration file]:file:_files' \
        '--init-configfile=[initial configuration file]:file:_files' \
        '--disable-calibrate[disable calibration]' \
        '--force-calibrate[force calibration even if one exists]' \
        '--force-ootx[force ootx capture even if in the config file]' \
        '--lighthousecount=[how many lighthouses to look for]:n:' \
        '--lighthouse-gen=[lighthouse protocol generation]:n:(1 2)' \
        '--threaded-posers[run each poser in its own thread]' \
        '--lighthouse-0-disable[disable lighthouse at index 0]' \
        '--lighthouse-1-disable[disable lighthouse at index 1]' \
        '--lighthouse-2-disable[disable lighthouse at index 2]' \
        '--lighthouse-3-disable[disable lighthouse at index 3]' \
        '--output-callback-stats=[output callback stats interval (seconds)]:s:' \
        '--help[show help and exit]'
}

_survive-cli "$@"
