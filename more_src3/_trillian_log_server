#compdef trillian_log_server
# _trillian_log_server — Trillian append-only Merkle log RPC server
# upstream: https://github.com/google/trillian
# Flags from cmd/trillian_log_server/main.go on tip.

_trillian_log_server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-rpc_endpoint=[gRPC bind host\:port]:host\:port:' \
        '-http_endpoint=[HTTP metrics bind host\:port (empty=disabled)]:host\:port:' \
        '-healthz_timeout=[healthz check timeout]:dur:' \
        '-tls_cert_file=[TLS server cert]:file:_files' \
        '-tls_key_file=[TLS server key]:file:_files' \
        '-etcd_service=[etcd announce service name]:name:' \
        '-etcd_http_service=[etcd announce HTTP service name]:name:' \
        '-quota_system=[quota system]:name:' \
        '-quota_dry_run=[do not block on lack of quota]:bool:(true false)' \
        '-storage_system=[storage system]:name:' \
        '-tree_gc=[periodic tree GC (hard delete)]:bool:(true false)' \
        '-tree_delete_threshold=[min period before hard-delete]:dur:' \
        '-tree_delete_min_run_interval=[min interval between GC sweeps]:dur:' \
        '-tracing=[enable OpenCensus Stackdriver tracing]:bool:(true false)' \
        '-tracing_project_id=[GCP project ID for tracing]:id:' \
        '-tracing_percent=[%% of requests to trace]:n:' \
        '-config=[config file (overridable by CLI flags)]:file:_files' \
        '-cpuprofile=[write CPU profile to file]:file:_files' \
        '-memprofile=[write memory profile to file]:file:_files' \
        '-max_msg_size_bytes=[max gRPC message size]:bytes:'
}

_trillian_log_server "$@"
