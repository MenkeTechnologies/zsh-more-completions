#compdef sui-node
# _sui-node — Mysten Labs sui-node validator and full node implementation for the Sui Move-based parallel-execution Layer-1 blockchain (MystenLabs team, Rust); clap
# upstream: https://github.com/MystenLabs/sui

_sui-node() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-path=+[file]:file:_files -g "*.yaml *.yml"' \
        '-c+[file]:file:_files -g "*.yaml *.yml"' \
        '--listen-address=+[addr]:str:' \
        '--metrics-address=+[addr]:str:' \
        '--admin-interface-port=+[port]:n:' \
        '--json-rpc-address=+[addr]:str:' \
        '--websocket-address=+[addr]:str:' \
        '--p2p-listen-address=+[addr]:str:' \
        '--db-path=+[dir]:dir:_files -/' \
        '--checkpoint-executor-config=+[file]:file:_files' \
        '--end-of-epoch-broadcast-channel-capacity=+[N]:n:' \
        '--checkpoint-executor-concurrency=+[N]:n:' \
        '--state-pruning-config=+[file]:file:_files' \
        '--enable-experimental-rest-api[enable experimental REST API]' \
        '--enable-index-processing[enable indexing]' \
        '--run-with-range=+[range]:str:' \
        '--policy-config=+[file]:file:_files' \
        '--firewall-config=+[file]:file:_files' \
        '--state-debug-dump-config=+[file]:file:_files' \
        '--state-archive-write-config=+[file]:file:_files' \
        '--state-archive-read-config=+[file]:file:_files' \
        '--enable-soft-bundle[enable soft bundle]' \
        '--max-submit-position=+[N]:n:' \
        '--submit-delay-step-override-millis=+[ms]:n:' \
        '--zklogin-oauth-providers=+[csv]:str:' \
        '--checkpoint-archival-config=+[file]:file:_files'
}

_sui-node "$@"
