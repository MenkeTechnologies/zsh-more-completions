#compdef libtool-cli libtoolize-cli
# _libtool-cli — GNU libtool generic library support script CLI alias (GNU team, Shell); custom argparse
# upstream: https://www.gnu.org/software/libtool/

_libtool-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config[show config]' \
        '--debug[debug]' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--features[show features]' \
        '--finish[same as --mode=finish]' \
        '--mode=+[mode]:m:(clean compile execute finish install link uninstall)' \
        '--no-quiet[no quiet]' \
        '--no-silent[no silent]' \
        '--no-verbose[no verbose]' \
        '--no-warning[no warning]' \
        '--no-warnings[no warnings]' \
        '--preserve-dup-deps[preserve duplicate deps]' \
        '--quiet[quiet]' \
        '--silent[silent]' \
        '--verbose[verbose]' \
        '--tag=+[tag]:t:(CC CXX GCJ F77 RC LD)' \
        '*:command:_command_names'
}

_libtool-cli "$@"
