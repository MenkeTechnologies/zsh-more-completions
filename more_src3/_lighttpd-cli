#compdef lighttpd-cli
# _lighttpd-cli — Jan Kneschke lighttpd light, fast web server CLI alias (lighttpd team, C); custom argparse
# upstream: https://github.com/lighttpd/lighttpd1.4

_lighttpd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-V[show config flags and exit]' \
        '-f+[config file]:file:_files -g "lighttpd.conf"' \
        '-m+[module dir]:dir:_files -/' \
        '-i+[idle timeout seconds]:n:' \
        '-1[stay in foreground (single shot)]' \
        '-D[do not daemonize]' \
        '-p[print parsed config and exit]' \
        '-t[test config]' \
        '-tt[test config (full)]' \
        '*:arg:'
}

_lighttpd-cli "$@"
