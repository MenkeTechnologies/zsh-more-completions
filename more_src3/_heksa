#compdef heksa
# Documentation: https://github.com/raspi/heksa
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Source: main.go uses go-getoptions
_arguments -s -S \
  '(-h -? --help)'{-h,-?,--help}'[usage]' \
  '--version[build info]' \
  '(-o --offset-format)'{-o,--offset-format}'=-[left[,right] offset viewers]:formats:' \
  '(-r --print-relative-offset)'{-r,--print-relative-offset}'[extra relative column when seeking]' \
  '(-f --format)'{-f,--format}'=-[comma-separated byte viewers]:formats:' \
  '(-l --limit)'{-l,--limit}'=-[max bytes 0=∞, supports SI/IEC suffix]:size:' \
  '(-s --seek)'{-s,--seek}'=-[start offset; negative from EOF]:offset:' \
  '(-w --width)'{-w,--width}'=-[bytes per row]:width:' \
  '(-S --splitter)'{-S,--splitter}'=-[visual gap every N bytes 0=off]:n:' \
  '*:file:_files'
