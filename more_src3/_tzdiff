#compdef tzdiff
# Documentation: https://manpages.debian.org/testing/tzdiff/tzdiff.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: --help, --version long forms (manpage only
# documents short flags).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show usage]' \
  '-v[show version]' \
  '-l[display full timezone name (region/city)]' \
  '-0[round down to hour]' \
  '-n+[number of hours to display]:count:' \
  '-f+[output format of time]:format:' \
  '-t+[specify the start time]:start:' \
  '-H[scripting mode with timezone name]' \
  '-HH[scripting mode without timezone name]' \
  '-N[display without local timezone]' \
  '*:IANA zone:_time_zone' && ret=0

return ret
