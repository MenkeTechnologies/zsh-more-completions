#compdef um
# Documentation: https://github.com/sinclairtarget/um
# Reference accessed: 2026-05-21
# Verified: upstream README. Real subcommands: edit, list, rm, topic,
# help, config (and bare `um <page>` to display). No `init` or `read`
# subcommand in upstream. -h/--help and -v/--version unverified in
# README (only "um help" is documented).

local curcontext="$curcontext" ret=1 expl state line

_arguments -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'um command' compadd -- edit list rm topic help config
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
