#compdef jack_metro
# _jack_metro — JACK Audio Connection Kit jack_metro example metronome generating click sounds at a configurable BPM and frequency for testing JACK timing (jackaudio team, C); getopt
# upstream: https://github.com/jackaudio/jack2

_jack_metro() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-f+[frequency Hz]:n:' \
        '--frequency=+[frequency Hz]:n:' \
        '-A+[amplitude 0-1]:f:' \
        '--amplitude=+[amplitude 0-1]:f:' \
        '-D+[duration ms]:f:' \
        '--duration=+[duration ms]:f:' \
        '-a+[attack ms]:f:' \
        '--attack=+[attack ms]:f:' \
        '-d+[decay ms]:f:' \
        '--decay=+[decay ms]:f:' \
        '-b+[bpm]:n:' \
        '--bpm=+[bpm]:n:' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-t[transport sync]' \
        '--transport[transport sync]' \
        '-S+[server name]:str:' \
        '--server-name=+[server name]:str:'
}

_jack_metro "$@"
