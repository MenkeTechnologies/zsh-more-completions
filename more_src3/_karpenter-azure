#compdef karpenter-azure
# _karpenter-azure — Karpenter for Azure node provisioner
# upstream: https://github.com/Azure/karpenter-provider-azure
# Azure-specific flags from pkg/operator/options/options.go on tip; core Karpenter flags inherit from sigs.k8s.io/karpenter.

_karpenter-azure() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cluster-name=[AKS cluster name for resource tags]:name:' \
        '--cluster-endpoint=[external Kubernetes cluster endpoint]:url:_urls' \
        '--vm-memory-overhead-percent=[VM memory overhead %% subtracted from total]:f:' \
        '--kubelet-bootstrap-token=[bootstrap token for new nodes]:token:' \
        '--linux-admin-username=[Linux admin username for VMs]:user:' \
        '--ssh-public-key=[VM SSH public key]:key:' \
        '--network-plugin=[network plugin]:plugin:(azure kubenet none)' \
        '--dns-service-ip=[cluster DNS service IP]:ip:' \
        '--network-plugin-mode=[network plugin mode]:mode:(overlay)' \
        '--network-policy=[network policy]:policy:(azure calico cilium none)' \
        '--network-dataplane=[network dataplane]:dataplane:(cilium azure)' \
        '--vnet-guid=[vnet GUID (azure cni overlay + byo vnet)]:guid:' \
        '--vnet-subnet-id=[default subnet ARM resource ID for new nodes]:id:' \
        '--provision-mode=[provision mode]:mode:' \
        '--nodebootstrapping-server-url=[node bootstrapping provider server URL]:url:_urls' \
        '--node-resource-group=[AKS-managed node resource group]:name:' \
        '--kubelet-identity-client-id=[kubelet identity client ID]:id:' \
        '--use-sig=[use AKS shared image galleries]:bool:(true false)' \
        '--sig-access-token-server-url=[SIG access token server URL]:url:_urls' \
        '--sig-subscription-id=[SIG subscription ID]:id:' \
        '--node-osdisk-diskencryptionset-id=[ARM ID of disk encryption set]:id:' \
        '--manage-existing-aks-machines=[manage existing AKS-Machine-API machines]:bool:(true false)' \
        '--aks-machines-pool-name=[AKS agent pool for managed machines]:name:' \
        '--batch-idle-timeout-ms=[batch idle timeout (ms)]:ms:' \
        '--batch-max-timeout-ms=[batch max timeout (ms)]:ms:' \
        '--metrics-port=[metrics endpoint port]:port:' \
        '--health-probe-port=[health probe endpoint port]:port:' \
        '--leader-election-name=[leader-election lease name]:name:' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--kube-client-qps=[K8s API QPS]:n:' \
        '--kube-client-burst=[K8s API burst]:n:' \
        '--log-level=[log level]:level:(debug info error)' \
        '--feature-gates=[feature gates]:gates:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_karpenter-azure "$@"
