#compdef s6-ftrig-listen s6-ftrig-listen1 s6-ftrig-notify s6-ftrig-wait s6-ftrigrd
# Documentation: source-direct extraction from upstream skarnet/s6
# src/pipe-tools/s6-ftrig-{listen,listen1,notify,wait}.c USAGE
# strings and src/libs6/s6-ftrigrd.c main() signature.
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6 ftrig family R119 — 5-stem multi-binary harvest of the
# s6 fifodir event-trigger CLI. Sister tools to R117/R118 s6-fdholder
# and s6-envdir/setlock/fghack/mkfifodir/cleanfifodir multi-stem
# completions. The mkfifodir / cleanfifodir companions live in
# `more_src/_s6-envdir`.

case $service in

  s6-ftrig-listen)
    # Wait on multiple (fifodir, regexp) pairs; chain-load prog after
    # all (conjunction, -a, default) or any (disjunction, -o) match.
    _arguments -s -S \
      '(-a -o)-a[conjunction mode: exit only after all pairs match (default)]' \
      '(-a -o)-o[disjunction mode: exit after any single pair matches]' \
      '-t+[timeout in milliseconds; exit 1 on expiry]:ms:' \
      '*:fifodir / regexp / "" / program and args:_files'
    ;;

  s6-ftrig-listen1)
    # Wait on a single (fifodir, regexp) pair, then chain-load prog.
    _arguments -s -S \
      '-t+[timeout in milliseconds; exit 1 on expiry]:ms:' \
      '1:fifodir:_directories' \
      '2:event regexp:' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-ftrig-notify)
    # Emit each character of message as a separate event into fifodir
    # (cannot transmit the null character 0x00).
    _arguments -s -S \
      '1:fifodir:_directories' \
      '2:event message:'
    ;;

  s6-ftrig-wait)
    # Wait on a single (fifodir, regexp) pair, then exit. Differs
    # from s6-ftrig-listen1 in that it does NOT chain-load a program.
    _arguments -s -S \
      '-t+[timeout in milliseconds; exit 1 on expiry]:ms:' \
      '1:fifodir:_directories' \
      '2:event regexp:'
    ;;

  s6-ftrigrd)
    # Internal s6 fifodir-trigger server daemon spawned by libs6
    # ftrigr_start/ftrigr_startf. No CLI arguments; reads requests
    # via the SASS server protocol on stdin/stdout. Completion only
    # offers the usual zsh fallback.
    _arguments -s -S \
      '*::: :_default'
    ;;

esac
