#compdef h5cc h5fc h5pcc h5pfc h5c++ h5cpp
# _h5cc — HDF Group h5cc h5c++ h5fc h5pcc compiler wrapper scripts for the HDF5 library (HDFGroup team, C); custom argparse
# upstream: https://github.com/HDFGroup/hdf5

_h5cc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-prefix[show install prefix]' \
        '-showconfig[show install configuration]' \
        '-show[show but do not execute command]' \
        '-shlib[link with shared library]' \
        '-noshlib[link with static library]' \
        '-Wl,+[linker options]:str:' \
        '-D+[define macro]:str:' \
        '-I+[include directory]:dir:_files -/' \
        '-L+[library directory]:dir:_files -/' \
        '-l+[link library]:str:' \
        '-o+[output file]:file:_files' \
        '-c[compile only]' \
        '-S[emit asm]' \
        '-g[debug info]' \
        '-O+[opt level]:n:' \
        '-Wall[all warnings]' \
        '-Werror[warnings as errors]' \
        '*:source file:_files -g "*.c *.cpp *.cc *.cxx *.f *.f90 *.F *.F90"'
}

_h5cc "$@"
