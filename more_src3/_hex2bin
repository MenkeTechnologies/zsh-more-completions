#compdef hex2bin
# Documentation: https://hex2bin.sourceforge.net/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[enable address alignment for word-sized files]' \
  '-b[batch/script mode (exit on error)]' \
  '-c[enable checksum error reporting]' \
  '-d[display checksum types and exit]' \
  '-e[output file extension]:ext:' \
  '-E[endianness for checksum/CRC]:val:(0 1)' \
  '-f[address to write checksum/CRC]:addr:' \
  '-F[insert forced value at address]:addr=value:' \
  '-k[checksum/CRC type]:type:(0 1 2 3 4 5)' \
  '-l[maximum length (pad to length)]:n:' \
  '-m[minimum block size (power of 2)]:n:' \
  '-p[padding byte for unused locations]:byte:' \
  '-r[range for checksum/CRC computation]:start end:' \
  '-s[starting address]:addr:' \
  '-t[floor (minimum) address]:addr:' \
  '-T[ceiling (maximum) address]:addr:' \
  '-w[wordwise byte-swapping]' \
  '*:input file:_files -g "*.(hex|s19|s28|s37|srec|ihx|mot)"' && ret=0
return ret
