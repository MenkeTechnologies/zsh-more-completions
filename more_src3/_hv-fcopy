#compdef hv_fcopy_daemon hv-fcopy-daemon
# _hv-fcopy — Linux hv_fcopy_daemon (Hyper-V File Copy daemon; lets the Hyper-V host PowerShell Copy-VMFile cmdlet drop files inside the running Linux guest; -n no daemonize, -d debug)
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git (tools/hv)
# Flags from kernel tools/hv/hv_fcopy_daemon.c on tip.

_hv-fcopy() {
    _arguments \
        '-h[show help]' \
        '-n[no daemonize]' \
        '-d[debug]'
}

_hv-fcopy "$@"
