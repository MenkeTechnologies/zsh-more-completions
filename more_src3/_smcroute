#compdef smcroute
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-n[do not daemonize]' \
  '-N[run in foreground]' \
  '-s[use syslog]' \
  '-l[log level]:log level' \
  '-t[table id]:table id' \
  '-d[start daemon]' \
  '-k[kill daemon]' \
  '-e[execute script on events]:script:_files' \
  '-a[add multicast route]:interface name: :source address: :group address: :outbound interfaces' \
  '-r[remove multicast route]:interface name: :source address: :group address' \
  '-j[join multicast group]:interface name: :group address' \
  '-L[leave multicast group]:interface name: :group address' \
  '-F[configuration file]:config file:_files' \
  '-p[PID file]:PID file:_files' \
  '-h[show help]' \
  '-v[show version]' && ret=0
return ret
