#compdef hping3
# _hping3-bin — hping3 packet generator + analyzer (Salvatore Sanfilippo, C); custom TCP/UDP/ICMP/RAW packet crafting
# upstream: https://github.com/antirez/hping

_hping3-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[count]:n:' \
        '-i+[interval]:str:' \
        '--fast[alias for -i u10000]' \
        '--faster[alias for -i u1000]' \
        '--flood[flood mode]' \
        '-n[do not resolve names]' \
        '-q[quiet]' \
        '-I+[interface]:iface:_net_interfaces' \
        '-V[verbose]' \
        '-D[debug]' \
        '-Z[stop ICMP/SCTP error reporting]' \
        '-z+[bind ctrl-z to TTL]:n:' \
        '-0[raw IP mode]' \
        '-1[ICMP mode]' \
        '-2[UDP mode]' \
        '-8+[scan mode ports]:ports:' \
        '-9+[listen mode signature]:str:' \
        '-a+[spoof source]:host:_hosts' \
        '--rand-dest[random destination]' \
        '--rand-source[random source]' \
        '-t+[TTL]:n:' \
        '-N+[id]:n:' \
        '-W[winid mode]' \
        '-r[relative id]' \
        '-f[fragment]' \
        '-x[set MF flag]' \
        '-y[set DF flag]' \
        '-g+[fragoff]:n:' \
        '-m+[mtu]:n:' \
        '-o+[ToS]:str:' \
        '-G[record route]' \
        '-H+[IP protocol]:n:' \
        '-C+[icmp type]:n:' \
        '-K+[icmp code]:n:' \
        '--icmp-ipver+[icmp ipver]:n:' \
        '--icmp-iphlen+[icmp iphlen]:n:' \
        '--icmp-iplen+[icmp iplen]:n:' \
        '--icmp-ipid+[icmp ipid]:n:' \
        '--icmp-ipproto+[icmp ipproto]:n:' \
        '--icmp-ipsrc+[icmp src]:ip:' \
        '--icmp-ipdst+[icmp dst]:ip:' \
        '-s+[base src port]:port:' \
        '-p+[dst port]:port:' \
        '-k[keep src port]' \
        '-w+[winsize]:n:' \
        '-O+[set TCP offset]:n:' \
        '-M+[seq num]:n:' \
        '-L+[ack num]:n:' \
        '-Q[show TCP seq num]' \
        '--tcp-mss+[TCP MSS]:n:' \
        '-F[set FIN flag]' \
        '-S[set SYN flag]' \
        '-R[set RST flag]' \
        '-P[set PUSH flag]' \
        '-A[set ACK flag]' \
        '-U[set URG flag]' \
        '-X[set XMAS flag]' \
        '-Y[set YMAS flag]' \
        '-d+[data size]:n:' \
        '-E+[data file]:file:_files' \
        '-e+[signature]:str:' \
        '-j[hex dump packets]' \
        '-J[print as printable chars]' \
        '-B[safe protocol]' \
        '-u[stdin data tells when stop]' \
        '-T[trace route mode]' \
        '*:host:_hosts'
}

_hping3-bin "$@"
