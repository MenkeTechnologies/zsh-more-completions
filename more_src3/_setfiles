#compdef setfiles restorecon
# Documentation: man setfiles(8) / restorecon(8)
# Source: SELinuxProject/selinux policycoreutils/setfiles/setfiles.c (main) — set/restore SELinux file contexts (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[do not add associations]' \
    '-c+[file_contexts version (digest check)]:file:_files' \
    '-C[count errors]' \
    '-d[debug, log matches]' \
    '-D[use file_contexts digest in selabel_open]' \
    '-e+[exclude directory]:dir:_files -/' \
    '-E[treat conflicting specifications as errors]' \
    '-f+[input file with paths]:file:_files' \
    '-F[set specfile context (force)]' \
    '-h[show help]' \
    '-i[ignore files that do not exist]' \
    '-I[ignore directory digest (force label check)]' \
    '-l[log changes via syslog]' \
    '-m[do not read /proc/mounts]' \
    '-n[do not change any file labels]' \
    '-p[show progress]' \
    '-q[quiet (deprecated; use -v)]' \
    '(-r -R)'{-r,-R}'[recursively descend (restorecon)]' \
    '-s[read paths from stdin]' \
    '-T+[number of threads]:N:_default' \
    '-U[set user identity portion of context]' \
    '-v[verbose]' \
    '-W[warn about no-match patterns]' \
    '-x[do not cross filesystem boundaries]' \
    '*:spec or path:_files' \
    && ret=0

return ret
