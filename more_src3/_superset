#compdef superset
# Documentation: https://github.com/apache/superset (superset/cli/{main,importexport,reset,examples,test,update}.py click commands)
# Reference accessed: 2026-05-29
# Apache Superset — modern data exploration & visualization CLI.
# Flask-based CLI; dispatches to commands dynamically loaded from superset/cli/.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'init:initialize Superset (add permissions, sync roles)'
  'version:print the current version number'
  'load-examples:load Slices and Dashboards with supporting datasets'
  'load_test_users:load admin, alpha, gamma users for testing'
  'import-directory:import configuration files from a directory'
  'import_directory:import configuration files (underscore alias)'
  'export-dashboards:export all dashboards to a ZIP file'
  'export_dashboards:export dashboards (underscore alias)'
  'export-datasources:export all datasources to a ZIP file'
  'export_datasources:export datasources (underscore alias)'
  'import-dashboards:import dashboards from ZIP or JSON'
  'import_dashboards:import dashboards (underscore alias)'
  'import-datasources:import datasources from ZIP or JSON'
  'import_datasources:import datasources (underscore alias)'
  'legacy-export-dashboards:export dashboards to JSON (legacy)'
  'legacy-export-datasources:export datasources to YAML (legacy)'
  'legacy-import-dashboards:import JSON dashboards (legacy)'
  'legacy-import-datasources:import YAML datasources (legacy)'
  'legacy-export-datasource-schema:export YAML schema definition to stdout'
  'factory-reset:factory reset Superset (gated by ENABLE_FACTORY_RESET_COMMAND)'
  'set-database-uri:update a database connection URI'
  'set_database_uri:update database URI (underscore alias)'
  'sync-tags:rebuild owner/type/favorited-by tags'
  'sync_tags:rebuild tags (underscore alias)'
  'update-api-docs:regenerate openapi.json from registered base APIs'
  'update_api_docs:update openapi.json (underscore alias)'
  're-encrypt-secrets:re-encrypt secrets with previous secret key'
  're_encrypt_secrets:re-encrypt secrets (underscore alias)'
  'reset:reset operations (db tables, sessions)'
  'mcp:Model Context Protocol server'
  'thumbnails:thumbnail generation operations'
  'test:testing utilities'
  'test-db:test database connection'
  'test-loaders:test data loaders'
  'viz-migrations:visualization migration utilities'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version (with optional verbose)]' \
  '-v[verbose output for version]' \
  '--verbose[verbose output for version]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'superset subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      load-examples|load_examples)
        _arguments \
          '(-t --load-test-data)'{-t,--load-test-data}'[include supplementary test data]' \
          '(-b --load-big-data)'{-b,--load-big-data}'[include supplementary large datasets]' \
          '(-m --only-metadata)'{-m,--only-metadata}'[load schema only, no table contents]' \
          '(-f --force)'{-f,--force}'[overwrite existing tables and reload]' && ret=0
        ;;
      import-directory|import_directory)
        _arguments \
          '(-o --overwrite)'{-o,--overwrite}'[overwrite existing definitions]' \
          '(-f --force-data)'{-f,--force-data}'[force load data even if already present]' \
          ':directory:_directories' && ret=0
        ;;
      export-dashboards|export_dashboards|export-datasources|export_datasources)
        _arguments \
          '(-f --filename)'{-f,--filename=}'[output ZIP file]:file:_files -g "*.zip"' && ret=0
        ;;
      import-dashboards|import_dashboards|import-datasources|import_datasources)
        _arguments \
          '(-p --path)'{-p,--path=}'[ZIP or JSON file path]:file:_files -g "*.(zip|json|yaml|yml)"' \
          '(-u --username)'{-u,--username=}'[username to assign]:user:' && ret=0
        ;;
      legacy-export-dashboards|legacy_export_dashboards)
        _arguments \
          '(-f --print-stdout)'{-f,--print-stdout}'[print to stdout]' \
          '(-l --dashboard-file)'{-l,--dashboard-file=}'[output dashboard file]:file:_files -g "*.json"' && ret=0
        ;;
      legacy-export-datasources|legacy_export_datasources)
        _arguments \
          '(-f --print-stdout)'{-f,--print-stdout}'[print to stdout]' \
          '(-b --back-references)'{-b,--back-references}'[include parent back-references]' \
          '(-d --include-defaults)'{-d,--include-defaults}'[include default field values]' \
          '(-l --datasource-file)'{-l,--datasource-file=}'[output datasource YAML file]:file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      legacy-import-dashboards|legacy_import_dashboards)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[search directory recursively]' \
          '(-p --path)'{-p,--path=}'[JSON file or directory]:path:_files' && ret=0
        ;;
      legacy-import-datasources|legacy_import_datasources)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[search directory recursively]' \
          '(-p --path)'{-p,--path=}'[YAML file or directory]:path:_files' \
          '(-s --sync)'{-s,--sync=}'[sync metrics and columns]:sync:(metrics columns metrics,columns)' && ret=0
        ;;
      factory-reset|factory_reset)
        _arguments \
          '(-u --username)'{-u,--username=}'[admin username]:user:' \
          '(-p --password)'{-p,--password=}'[admin password]:password:' \
          '*'{-e,--exclude-users=}'[users to exclude]:user:' \
          '*'{-r,--exclude-roles=}'[roles to exclude]:role:' && ret=0
        ;;
      set-database-uri|set_database_uri)
        _arguments \
          '(-d --database-name)'{-d,--database-name=}'[database name]:name:' \
          '(-u --uri)'{-u,--uri=}'[database URI]:uri:' \
          '(-s --skip-create)'{-s,--skip-create}'[skip creating if database does not exist]' && ret=0
        ;;
    esac
    ;;
esac

return ret
