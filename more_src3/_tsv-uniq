#compdef tsv-uniq
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-uniq.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-verbose[detailed help]' \
  '(- *)--help-fields[help on field syntax]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-H --header)'{-H,--header}'[treat first line as header]' \
  '(-f --fields)'{-f,--fields}'+[fields comprising the key]:field-list' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive key comparison]' \
  '(-e --equiv)'{-e,--equiv}'[output equiv class IDs rather than uniq entries]' \
  '--equiv-header=[equiv-id field header name]:str' \
  '--equiv-start=[starting value for equiv-id numbering]:int' \
  '(-z --number)'{-z,--number}'[output equivalence class occurrence counts]' \
  '--number-header=[number field header name]:str' \
  '(-r --repeated)'{-r,--repeated}'[show only lines appearing multiple times]' \
  '(-a --at-least)'{-a,--at-least}'+[display lines repeated at least N times]:int' \
  '(-m --max)'{-m,--max}'+[restrict output to N occurrences per unique key]:int' \
  '(-d --delimiter)'{-d,--delimiter}'+[field delimiter]:char' \
  '--line-buffered[write each line to output immediately]' \
  '*:file:_files' && return 0
