#compdef loopsy
# Documentation: https://github.com/leox255/loopsy
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

_loopsy() {
    local line state
    local -a commands
    commands=(
        'init:create configuration and API key'
        'start:launch the daemon'
        'stop:shut down the daemon'
        'status:check daemon health'
        'doctor:run comprehensive diagnostics'
        'enable:set auto-start on boot'
        'disable:remove auto-start'
        'logs:view request audit trail'
        'key:manage API keys'
        'pair:initiate pairing handshake'
        'peers:manage LAN peers'
        'mobile:mobile pairing credentials'
        'phone:manage paired phones'
        'relay:configure relay endpoint'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'loopsy command' commands
            ;;
        args)
            case $line[1] in
                peers)
                    _arguments '1:subcommand:(add)' '2:ip:'
                    ;;
                phone)
                    _arguments '1:subcommand:(list revoke)' '2:id:'
                    ;;
                key)
                    _arguments '1:subcommand:(show generate)'
                    ;;
                mobile)
                    _arguments '1:subcommand:(pair)' '--ttl=[time to live in seconds]:seconds:'
                    ;;
                pair)
                    _arguments '1::peer ip:'
                    ;;
                relay)
                    _arguments '1:subcommand:(configure)' '2:url:_urls'
                    ;;
                logs)
                    _arguments '-f[follow logs]'
                    ;;
            esac
            ;;
    esac
}

_loopsy "$@"
