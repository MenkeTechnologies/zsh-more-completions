#compdef rubberband rubberband-r3
# Documentation: rubberband --help (Rubber Band library)
# Source: Particular Programs Rubber Band — audio time-stretching and pitch-shifting utility.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-t --time -T --tempo -D --duration)'{-t,--time=}'[stretch to X times original duration]:X:' \
    '(-t --time -T --tempo -D --duration)'{-T,--tempo=}'[change tempo by X or X\:Y]:X[\:Y]:' \
    '(-t --time -T --tempo -D --duration)'{-D,--duration=}'[stretch to X seconds long]:X:' \
    '(-p --pitch -f --frequency)'{-p,--pitch=}'[raise pitch by X semitones]:X:' \
    '(-p --pitch -f --frequency)'{-f,--frequency=}'[change frequency by multiple X]:X:' \
    '(-M --timemap)'{-M,--timemap=}'[time-map file]:file:_files' \
    '--pitchmap=[pitch-map file]:file:_files' \
    '--freqmap=[frequency-map file]:file:_files' \
    '(-2 --fast -3 --fine)'{-2,--fast}'[R2 (faster) engine]' \
    '(-2 --fast -3 --fine)'{-3,--fine}'[R3 (finer) engine]' \
    '(-F --formant)'{-F,--formant}'[preserve formant envelope when pitch-shifting]' \
    '--centre-focus[improve focus of centre material in stereo]' \
    '(-c --crisp)'{-c,--crisp=}'[crispness 0..6 (R2 only)]:N:(0 1 2 3 4 5 6)' \
    '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
    '(-V --version)'{-V,--version}'[print version]' \
    '(-h --help)'{-h,--help}'[print help]' \
    '(-L --loose -P --precise)'{-L,--loose}'[loose (legacy) mode]' \
    '(-L --loose -P --precise)'{-P,--precise}'[precise (default) mode]' \
    '(-R --realtime)'{-R,--realtime}'[realtime processing mode]' \
    '--no-threads[single-threaded operation]' \
    '--threads=[N worker threads]:n:' \
    '--ignore-clipping[do not auto-attenuate to avoid clipping]' \
    '*-d+[debug verbosity 0..3]:level:(0 1 2 3)' \
    '1:input WAV/audio file:_files -g "*.{wav,aif,aiff,flac,ogg,mp3}"' \
    '2:output WAV file:_files -g "*.wav"' \
    && ret=0

return ret
