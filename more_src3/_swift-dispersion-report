#compdef swift-dispersion-report
# Documentation: https://opendev.org/openstack/swift/raw/branch/master/swift/cli/dispersion_report.py
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-j --dump-json)'{-j,--dump-json}'[output dispersion report in JSON format]' \
  '(-d --debug)'{-d,--debug}'[output any 404 responses to standard error]' \
  '(-p --partitions)'{-p,--partitions}'[output the partition numbers that have any missing replicas]' \
  '--container-only[only check containers]' \
  '--object-only[only check objects]' \
  '--insecure[allow accessing insecure keystone server]' \
  '(-P --policy-name)'{-P,--policy-name=}'[storage policy name]:name:' \
  '*:dispersion config:_files -g "*.conf"' && ret=0
return ret
