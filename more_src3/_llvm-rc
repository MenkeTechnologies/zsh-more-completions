#compdef llvm-rc
# _llvm-rc — LLVM Windows resource compiler (LLVM project, C++); compile .rc resource scripts to .res files
# upstream: https://github.com/llvm/llvm-project

_llvm-rc() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-h[show help]' \
        '-?[show help]' \
        '-V[show version]' \
        '/V[show version]' \
        '/I+[include dir]:dir:_files -/' \
        '-I+[include dir]:dir:_files -/' \
        '/D+[define]:def:' \
        '-D+[define]:def:' \
        '/U+[undefine]:def:' \
        '-U+[undefine]:def:' \
        '/N[null terminate strings]' \
        '-N[null terminate strings]' \
        '/L+[default language id]:hex:' \
        '-L+[default language id]:hex:' \
        '/Y[ignore duplicate ids]' \
        '-Y[ignore duplicate ids]' \
        '/X[no default include]' \
        '-X[no default include]' \
        '-x[no default include]' \
        '/C+[input codepage]:cp:' \
        '-C+[input codepage]:cp:' \
        '-c+[input codepage]:cp:' \
        '/r[generate .rc file (no-op)]' \
        '/n[null terminate strings]' \
        '-n[null terminate strings]' \
        '-fo+[output file]:file:_files' \
        '/fo+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--codepage=+[input codepage]:cp:' \
        '--no-preprocess[no preprocess]' \
        '--target=+[target triple]:triple:' \
        '--dry-run[dry run]' \
        '*:file:_files -g "*.rc"'
}

_llvm-rc "$@"
