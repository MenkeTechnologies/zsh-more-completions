#compdef sqlboiler
# Documentation: https://github.com/volatiletech/sqlboiler
# Reference accessed: 2026-05-21
# Verified: README CLI flags and supported drivers.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '(-c --config)'{-c+,--config=}'[config file override default lookup]:config file:_files' \
  '(-o --output)'{-o+,--output=}'[output folder (default models)]:directory:_directories' \
  '(-p --pkgname)'{-p+,--pkgname=}'[generated package name (default models)]:package name:' \
  '(-t --tag)'{-t+,--tag=}'[struct tags to include (in addition to json/yaml/toml)]:tags:' \
  '--templates=[templates directory override]:template dir:_directories' \
  '*--replace=[template file to replace with custom one]:replace:' \
  '--no-tests[disable test generation]' \
  '--no-hooks[disable hooks feature]' \
  '--no-auto-timestamps[disable automatic created_at/updated_at]' \
  '--no-rows-affected[disable rows affected in update/delete]' \
  '--no-driver-templates[disable driver-specific templates]' \
  '--no-back-referencing[disable back referencing in relationship structs]' \
  '--no-context[disable context.Context usage]' \
  '--no-relation-getters[disable getters for relationship tables]' \
  '--add-global-variants[add global variant functions]' \
  '--add-panic-variants[add panic variant functions]' \
  '--add-soft-deletes[add soft delete support]' \
  '--add-enum-types[add enum types]' \
  '--enum-null-prefix=[name prefix of nullable enum types (default Null)]:prefix:' \
  '--struct-tag-casing=[struct tag casing]:casing:(camel title snake alias)' \
  '--tag-ignore=[columns to ignore for tags]:columns:' \
  '--strict-verify-mod-version[prevent code generation on version mismatch]' \
  '--wipe[delete output folder before generating]' \
  '(-d --debug)'{-d,--debug}'[debug mode prints stack traces]' \
  '1:driver:->drivers' && ret=0

case $state in
  drivers)
    local -a drivers=(
      'psql:PostgreSQL'
      'mysql:MySQL'
      'mssql:Microsoft SQL Server 2012+'
      'sqlite3:SQLite3'
      'crdb:CockroachDB (community)'
    )
    _describe -t drivers 'database driver' drivers && ret=0
    ;;
esac

return ret
