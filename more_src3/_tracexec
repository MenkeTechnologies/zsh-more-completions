#compdef tracexec
# Documentation: https://github.com/kxxt/tracexec
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for tracexec (ptrace-based exec/trace debugging tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'log:run tracexec in logging mode'
  'tui:run tracexec in TUI mode'
  'collect:collect exec events and export them'
  'ebpf:experimental eBPF mode'
  'generate-completions:generate shell completions'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--color=[control colored output]:color:(auto always never)' \
  '(-C --cwd)'{-C+,--cwd=}'[change working directory]:dir:_files -/' \
  '(-P --profile)'{-P+,--profile=}'[load profile from path]:file:_files' \
  '--no-profile[skip profile loading]' \
  '(-u --user)'{-u+,--user=}'[run as specified user (root only)]:user:_users' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'tracexec command' commands && ret=0
    ;;
  args)
    case $line[1] in
      log)
        _arguments -s -S \
          '--show-cmdline[print reconstructed command]' \
          '--show-interpreter[display script interpreter from shebang]' \
          '--show-cwd[show current working directory]' \
          '--diff-fd[diff file descriptors]' \
          '--diff-env[diff environment variables]' \
          '--show-comm[display command]' \
          '--show-argv[display argv]' \
          '--show-filename[display filename]' \
          '--show-fd[display fd]' \
          '--show-env[display env]' \
          '--decode-errno[decode errno values]' \
          '--successful-only[show only successful calls]' \
          '*::cmd:_command_names -e' && ret=0
        ;;
      tui)
        _arguments -s -S \
          '(-t --tty)'{-t,--tty}'[allocate pseudo terminal]' \
          '(-f --follow)'{-f,--follow}'[keep scrolled to bottom]' \
          '(-L --layout)'{-L+,--layout=}'[set layout]:layout:(horizontal vertical)' \
          '(-F --frame-rate)'{-F+,--frame-rate=}'[set TUI frame rate]:fps' \
          '(-m --max-events)'{-m+,--max-events=}'[maximum events to keep]:n' \
          '*'{-b+,--add-breakpoint=}'[add breakpoint pattern]:pattern' \
          '--theme=[load custom theme]:file:_files' \
          '*::cmd:_command_names -e' && ret=0
        ;;
      collect)
        _arguments -s -S \
          '(-F --format)'{-F+,--format=}'[export format]:format:(json-stream json perfetto)' \
          '(-o --output)'{-o+,--output=}'[output destination]:file:_files' \
          '(-p --pretty)'{-p,--pretty}'[prettify output]' \
          '*::cmd:_command_names -e' && ret=0
        ;;
    esac
    ;;
esac

return ret
