#compdef sherpa-onnx
# _sherpa-onnx — streaming/offline speech recognition with ONNX (k2-fsa/sherpa-onnx)
# upstream: https://github.com/k2-fsa/sherpa-onnx
# Flags from sherpa-onnx/csrc/sherpa-onnx.cc (online recognizer ParseOptions).

_sherpa-onnx() {
    _arguments \
        '--help[show help]' \
        '--tokens=[tokens file]:file:_files -g "*.txt"' \
        '--encoder=[transducer encoder ONNX model]:file:_files -g "*.onnx"' \
        '--decoder=[transducer decoder ONNX model]:file:_files -g "*.onnx"' \
        '--joiner=[transducer joiner ONNX model]:file:_files -g "*.onnx"' \
        '--zipformer2-ctc-model=[zipformer2 CTC ONNX model]:file:_files -g "*.onnx"' \
        '--paraformer-encoder=[paraformer encoder ONNX model]:file:_files -g "*.onnx"' \
        '--paraformer-decoder=[paraformer decoder ONNX model]:file:_files -g "*.onnx"' \
        '--provider=[execution provider]:provider:(cpu cuda coreml directml)' \
        '--num-threads=[number of threads]:n:' \
        '--decoding-method=[decoding method]:method:(greedy_search modified_beam_search)' \
        '--max-active-paths=[max active paths in beam search]:n:' \
        '--blank-penalty=[blank penalty]:value:' \
        '--hotwords-file=[file containing hotwords]:file:_files' \
        '--hotwords-score=[hotwords score]:value:' \
        '--temperature-scale=[temperature scaling]:value:' \
        '--rule-fsts=[contextual biasing FSTs]:files:' \
        '--rule-fars=[contextual biasing FARs]:files:' \
        '--feat-dim=[feature dimension]:n:' \
        '--sample-rate=[input sample rate]:rate:' \
        '--debug=[debug logging (0/1)]:flag:(0 1)' \
        '*:wav file:_files -g "*.wav"'
}

_sherpa-onnx "$@"
