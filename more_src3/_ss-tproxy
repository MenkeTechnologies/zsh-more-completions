#compdef ss-tproxy
# Documentation: source-direct extraction from upstream
# zfl9/ss-tproxy main script `main() {}` body — the trailing
# `case "${arg_list[0]}"` dispatch enumerates every subcommand
# (with shell-glob prefixes like `r*` for `restart` and `stat*`
# for `status` decoded back to their long forms by reading the
# function bodies invoked from each arm).
# Reference accessed: 2026-05-30 via gh api.
# zfl9 ss-tproxy R159b — bash transparent-proxy orchestrator that
# wires shadowsocks / v2ray / xray etc. through iptables TPROXY +
# REDIRECT rules with chinadns/gfwlist/chnroute mode dispatch.
# Sister to v2ray / xray / shadowsocks-libev family already in
# the corpus.

local -a subcommands=(
  'start:start the transparent proxy + DNS'
  'stop:stop the transparent proxy + DNS'
  'restart:stop then start'
  'restart-proxy:restart only the proxy process'
  'restart-dns:restart only the DNS server'
  'status:show running status'
  'show-iptables:dump the active SSTP iptables rules'
  'flush-stoprule:flush the stop-rule chain'
  'flush-dnscache:flush the local DNS cache'
  'update-gfwlist:re-fetch gfwlist domain list'
  'update-chnlist:re-fetch China-domain list'
  'update-chnroute:re-fetch China-route CIDR list'
  'set-proxy-group:assign command to the proxy cgroup'
  'set-dns-group:assign command to the DNS cgroup'
  'version:print version and exit'
  'help:print help and exit'
)

_arguments -C \
  '-x[enable shell tracing (set -x)]' \
  '-d+[base directory (default /etc/ss-tproxy)]:dir:_files -/' \
  '-c+[config file relative to base dir (default ss-tproxy.conf)]:file:_files' \
  '1: :->command' \
  '*:: :->args'

case $state in
  command)
    _describe -t commands 'ss-tproxy subcommand' subcommands
    ;;
  args)
    case $words[1] in
      set-proxy-group|set-dns-group)
        _command_names -e
        ;;
      flush-dnscache)
        _message 'optional DNS-cache name to flush'
        ;;
    esac
    ;;
esac
