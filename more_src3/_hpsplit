#compdef hpsplit
# Documentation: https://astrometry.net/
# Source: dstndstn/astrometry.net util/hpsplit.c — split a FITS star catalogue by healpix.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-o+[output filename pattern (%i = healpix id)]:pattern:_default' \
    '-r+[RA column name (default RA)]:name:_default' \
    '-d+[Dec column name (default DEC)]:name:_default' \
    '-n+[healpix Nside (default 1)]:n:_default' \
    '-R[use ring indexing (default xy)]' \
    '-m+[margin in degrees (default 0)]:deg:_default' \
    '-g[treat input as gzip-compressed]' \
    '*-c+[copy column to output files]:column:_default' \
    '*-e+[copy column as float (FITS type E)]:column:_default' \
    '-C[close output files after each input]' \
    '-t+[temp directory (default /tmp)]:dir:_directories' \
    '-b+[backref save file]:file:_files' \
    '*-v[verbose (stackable)]' \
    '*:input FITS file:_files -g "*.(fits|fit|fts|fits.gz)(-.)"' \
    && ret=0

return ret
