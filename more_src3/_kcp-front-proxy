#compdef kcp-front-proxy
# _kcp-front-proxy — kcp logical-cluster-aware front proxy (kcp-dev/kcp)
# upstream: https://github.com/kcp-dev/kcp
# Flags from cmd/kcp-front-proxy/options/options.go + apiserver framework on tip.

_kcp-front-proxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--mapping-file=[front-proxy mapping YAML file]:file:_files' \
        '--root-directory=[directory for generated certs/state]:dir:_files -/' \
        '--root-kubeconfig=[root shard kubeconfig]:file:_files' \
        '--shards-kubeconfig=[shards-aggregate kubeconfig]:file:_files' \
        '--secure-port=[HTTPS bind port (0 disables)]:port:' \
        '--bind-address=[HTTPS bind address]:ip:' \
        '--tls-cert-file=[TLS server certificate]:file:_files' \
        '--tls-private-key-file=[TLS server private key]:file:_files' \
        '--client-ca-file=[client-cert CA bundle]:file:_files' \
        '--requestheader-client-ca-file=[aggregator client CA]:file:_files' \
        '--requestheader-username-headers=[trusted username headers (comma-sep)]:list:' \
        '--requestheader-allowed-names=[allowed Common Names (comma-sep)]:list:' \
        '--audit-log-path=[audit log file path]:file:_files' \
        '--audit-policy-file=[audit policy YAML file]:file:_files' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:'
}

_kcp-front-proxy "$@"
