#compdef kubectl-accurate
# Documentation: https://cybozu-go.github.io/accurate/kubectl-accurate.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-accurate (cybozu-go/accurate). Namespace -n flag is not used;
# namespace names are positional arguments.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:list namespace trees hierarchically'
      'namespace:operate on a namespace related to Accurate'
      'template:operate on template namespaces'
      'sub:operate on SubNamespaces'
    )
    _describe -t commands 'kubectl-accurate command' commands && ret=0
    ;;
  args)
    case $line[1] in
      namespace)
        _arguments -s -S '1:subcommand:(describe set-type)' && ret=0
        ;;
      template)
        _arguments -s -S '1:subcommand:(list set unset)' && ret=0
        ;;
      sub)
        _arguments -s -S -C \
          '1:subcommand:(create delete move graft cut list)' \
          '*::arg:->sub_args' && ret=0
        case $line[1] in
          create)
            _arguments -s -S \
              '*--labels=[labels to propagate to the sub-namespace]:labels:' \
              '*--annotations=[annotations to propagate to the sub-namespace]:annotations:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
