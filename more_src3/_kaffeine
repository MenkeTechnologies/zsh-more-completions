#compdef kaffeine
# Documentation: https://manpages.debian.org/bookworm/kaffeine/kaffeine.1.en.html
# Reference accessed: 2026-05-19
# Verified: Debian bookworm kaffeine(1) manpage OPTIONS section.

# Kaffeine: KDE media player and DVB-T digital TV client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d,--debug}'[enable all debug messages]' \
  '--tempfile[opened files/URLs deleted after use]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start in full screen mode]' \
  '(-m --minimal)'{-m,--minimal}'[start in minimal mode]' \
  '(-t --alwaysontop)'{-t,--alwaysontop}'[main window always on top]' \
  '--aspectratio=[force specific aspect ratio]:ratio:(1:1 4:3 5:4 16:9 16:10 2.21:1 2.35:1 2.39:1)' \
  '--audiocd[play Audio CD]' \
  '--videocd[play Video CD]' \
  '--dvd[play DVD]' \
  '--dumpdvb[dump DVB data (debug)]' \
  '--channel=[play TV channel by name/number]:channel:' \
  '--tv=[play TV channel (deprecated)]:channel:' \
  '--lastchannel[play last tuned TV channel]' \
  '*:media file:_files' && ret=0
return ret
