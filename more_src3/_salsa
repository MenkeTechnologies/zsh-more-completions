#compdef salsa
# Documentation: https://manpages.debian.org/salsa
# Source: debian/devscripts scripts/salsa.pl — manage salsa.debian.org projects (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '--help[show help]' \
    '--version[show version]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '--token=-[Salsa private token]:token:_default' \
    '--token-file=-[file containing token]:file:_files' \
    '--group=-[Salsa group name]:group:_default' \
    '--group-id=-[Salsa group id]:id:_default' \
    '--user=-[Salsa user name]:user:_users' \
    '--user-id=-[Salsa user id]:id:_default' \
    '*--path=-[path]:path:_default' \
    '--no-cache[do not cache responses]' \
    '--verbose[verbose output]' \
    '--debug[debug output]' \
    '--api-url=-[Salsa REST API URL]:url:_default' \
    '*--desc-pattern=-[description pattern]:pattern:_default' \
    '--desc[update description]' \
    '--all[apply to all projects]' \
    '--kgb[enable KGB notification]' \
    '--disable-kgb[disable KGB notification]' \
    '--irc=-[IRC channel]:channel:_default' \
    '--tagpending[enable tag-pending hook]' \
    '1:command:(add_user delete_user del_user join list_groups list_users group search_groups search_users update_user whoami check_projects check_repo checkout co create_project create_repo delete_project del_repo fork forks push list_projects list_repos ls last_ci_status pipeline_schedule schedule pipeline_schedules schedules merge_request mr merge_requests mrs protect_branch protected_branches push_repo rename_branch rename_branches file get create edit delete create_or_edit search_projects search_repo search update_projects update_repo update_safe update_watch5 fix_repo)' \
    '*::command args:_default' \
    && ret=0

return ret
