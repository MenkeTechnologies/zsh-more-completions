#compdef jenkinsfile-runner
# Documentation: https://github.com/jenkinsci/jenkinsfile-runner
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Jenkinsfile Runner: run a Jenkinsfile without a full Jenkins server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-w --jenkins-war)'{-w,--jenkins-war}'[path to exploded Jenkins WAR directory]:file:_files' \
  '(-jv --jenkins-version)'{-jv,--jenkins-version}'[Jenkins version to use]:version:' \
  '(-p --plugins)'{-p,--plugins}'[plugins directory or plugins.txt file]:path:_files' \
  '--jenkinsHome[path to Jenkins Home directory]:dir:_files -/' \
  '--mirror[mirror site for downloading plugins]:url:' \
  '--withInitHooks[path to Groovy init hooks directory]:dir:_files -/' \
  '--skipShutdown[skip Jenkins shutdown logic]' \
  '--httpPort[port for web server and Jenkins Web UI]:port:' \
  '--httpPath[root path/prefix for web server]:path:' \
  '--openWebUI[open Jenkins Web UI in default browser]' \
  '--waitOnExit[keep running after job completion]' \
  '--agentPort[port for inbound Jenkins agents]:port:' \
  '(-f --file)'{-f,--file}'[path to Jenkinsfile]:file:_files' \
  '*'{-a,--arg}'[pipeline job parameters key=value]:param:' \
  '--runWorkspace[workspace path for node context]:dir:_files -/' \
  '(-u --keep-undefined-parameters)'{-u,--keep-undefined-parameters}'[keep undefined parameters]' \
  '(-ns --no-sandbox)'{-ns,--no-sandbox}'[run without sandbox/script security]' \
  '(-n --job-name)'{-n,--job-name}'[job name]:name:' \
  '(-b --build-number)'{-b,--build-number}'[build number]:number:' \
  '(-c --cause)'{-c,--cause}'[string describing run cause]:cause:' \
  '--scm[YAML file defining SCM and credentials]:file:_files' \
  '*::jenkinsfile-runner args:_files' && ret=0
return ret
