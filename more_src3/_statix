#compdef statix
# Documentation: https://github.com/oppiliappan/statix
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for statix - linter and suggestion tool for Nix

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'check:lint Nix files for antipatterns'
  'fix:apply suggestions to Nix files'
  'single:fix exactly one issue at a position'
  'explain:explain a lint warning'
  'dump:dump a sample config to stdout'
  'list:list all available lints'
  'help:print help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  ':subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      check|fix)
        _arguments \
          '(-i --ignore)'{-i,--ignore}'=[file patterns to skip]:glob:' \
          '(-u --unrestricted)'{-u,--unrestricted}'[do not respect .gitignore]' \
          '(-o --format)'{-o,--format}'=[output format]:format:(stderr errfmt json)' \
          '(-c --config)'{-c,--config}'=[path to statix.toml]:dir:_files -/' \
          '(-s --stdin)'{-s,--stdin}'[streaming mode: accept file on stdin]' \
          '*:file:_files -g "*.nix"' && ret=0
        ;;
      single)
        _arguments \
          '(-p --position)'{-p,--position}'=[line,col position]:pos:' \
          '(-d --dry-run)'{-d,--dry-run}'[show diff, do not write]' \
          '(-s --stdin)'{-s,--stdin}'[streaming mode]' \
          '(-c --config)'{-c,--config}'=[path to statix.toml]:dir:_files -/' \
          ':file:_files -g "*.nix"' && ret=0
        ;;
      explain)
        _arguments ':warning code:' && ret=0
        ;;
      dump|list)
        _arguments '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
