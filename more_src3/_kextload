#compdef kextload
# Documentation: https://www.unix.com/man-page/osx/8/kextload/
# Source: Apple macOS — legacy kernel-extension loader (superseded by `kmutil load` on Catalina+).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-b,-bundle-id=}'[load kext by CFBundleIdentifier]:bundle id:' \
    '*'{-d,-dependency=}'[add kext + plugins to known-kexts for dependency resolution]:kext:_files -/' \
    '(- *)'{-h,-help}'[print help]' \
    '(-q -quiet)'{-q,-quiet}'[quiet mode]' \
    '*'{-r,-repository=}'[use directory as a kext repository]:dir:_directories' \
    '*'{-v,-verbose=-}'[verbose level 0-6 or 0x####]:level:(0 1 2 3 4 5 6)' \
    '*:kext path:_files -/' \
    && ret=0

return ret
