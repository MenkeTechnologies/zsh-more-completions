#compdef klong
# Documentation: https://t3x.org/klong/
# Documentation: https://t3x.org/klong/klong20221212.tgz (klong/kg.c usage/readopts)
# Reference accessed: 2026-05-27
# Verified: upstream usage() and readopts() in klong/kg.c

# Zsh completion for Klong (kg binary; file named _klong to avoid conflict with KiroGraph kg)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h -v -\?)'{-h,-v,-\?}'[print long usage and exit]' \
  '-d[debug: print bytecode and call traces]' \
  '-e+[evaluate expression, no interactive mode]:expr:' \
  '-r+[run expression (like -e but do not print result)]:expr:' \
  '-l+[load program from file]:file:_files' \
  '-n[clean start: do not parse KLONGOPTS or load any image (must be first)]' \
  '-o+[output image to file then exit]:file:_files' \
  '-q[quiet: no banner, no prompt, exit on errors]' \
  '-s[skip first line (#!) in script files]' \
  '-t+[send transcript to file]:file:_files' \
  '-u[allocate unlimited memory]' \
  '*:script:_files' && ret=0

return ret
