#compdef kuberlr
# Documentation: https://github.com/flavio/kuberlr
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'bins:print all kubectl binaries available to the user'
  'get:download the kubectl version specified'
  'kubectl:wrap and exec a suitable kubectl version'
  'version:print the version of kuberlr'
  'help:help about any command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --v)'{-v+,--v=}'[number for the log level verbosity]:level' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kuberlr command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (get)
        _arguments \
          '*::version:' && ret=0 ;;
      (kubectl)
        _arguments \
          '*::kubectl_args:' && ret=0 ;;
    esac ;;
esac

return ret
