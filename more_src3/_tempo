#compdef tempo
# Documentation: https://grafana.com/docs/tempo/latest/configuration/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (cmd/tempo/main.go).

_arguments -s \
  '-config.file=[config file]:file:_files -g "*.(yaml|yml)"' \
  '-config.expand-env[expand env vars in config]' \
  '-config.verify[verify config and exit]' \
  '-target=[target module]:target:(all distributor querier query-frontend metrics-generator block-builder backend-scheduler backend-worker live-store)' \
  '-mem-ballast-size-mbs=[memory ballast size in MB]:mb:' \
  '-health[enable health check endpoint]' \
  '-health.url=[health check URL]:url:' \
  '-mutex-profile-fraction=[mutex profile fraction]:n:' \
  '-block-profile-threshold=[block profile threshold]:duration:' \
  '(- *)-version[show version]'
