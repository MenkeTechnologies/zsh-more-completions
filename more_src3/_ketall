#compdef ketall
# Documentation: https://github.com/corneliusweig/ketall/blob/master/doc/USAGE.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--only-scope=[Restrict scope]:scope:(cluster namespace)' \
  '(-l --selector)'{-l+,--selector=}'[Label selector]:selector:' \
  '--field-selector=[Field selector]:selector:' \
  '--exclude=[Resource names or kinds to exclude]:exclude:' \
  '--since=[Only show resources younger than duration]:duration:' \
  '--use-cache[Use cached server resources]' \
  '--allow-incomplete[Proceed even if some resources cannot be listed]' \
  '(-n --namespace)'{-n+,--namespace=}'[Namespace]:namespace:' \
  '--all-namespaces[All namespaces]' \
  '--kubeconfig=[Kubeconfig path]:file:_files' \
  '--context=[Kube context name]:context:' \
  '(-o --output)'{-o+,--output=}'[Output format]:format:' \
  '-v+[Log level]:level:(debug info warn error fatal panic)' \
  '--config=[Config file path]:file:_files' \
  '*::args: _default'
