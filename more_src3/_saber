#compdef saber
# _saber — Vue.js framework for static site / blog generation (saberland/saber)
# upstream: https://github.com/saberland/saber
# Subcommands from packages/saber/src/cli-commands.

_saber() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'build:compile and generate static HTML'
                'generate:alias of build (deprecated)'
                'serve:serve a generated site'
                'dev:run app in dev mode'
                'eject-theme:copy active theme into project'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                build|generate)
                    _arguments \
                        '--skip-compilation[skip webpack compilation]' \
                        '--inspect-webpack[inspect webpack config in editor]' \
                        '--no-cache[disable cache]' \
                        '1:app path:_files -/'
                    ;;
                serve|dev)
                    _arguments \
                        '--lazy[enable lazy page compilation]' \
                        '--port=[server port (default 3000)]:port:' \
                        '--host=[server host (default 0.0.0.0)]:host:' \
                        '--inspect-webpack[inspect webpack config in editor]' \
                        '--no-cache[disable cache]' \
                        '1:app path:_files -/'
                    ;;
                eject-theme)
                    _arguments '1:app path:_files -/'
                    ;;
            esac
            ;;
    esac
}

_saber "$@"
