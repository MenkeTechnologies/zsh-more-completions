#compdef wasm-strip
# Documentation: https://github.com/WebAssembly/wabt (src/tools/wasm-strip.cc)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o+,--output=}'[output wasm binary file]:file:_files' \
  '*'{-k+,--keep-section=}'[section name to keep]:section' \
  '*'{-R+,--remove-section=}'[section name to remove (and all sections after it)]:section' \
  '1:input wasm file:_files -g "*.wasm"' && ret=0

return ret
