#compdef lolcat
# Documentation: lolcat -h / busyloop/lolcat README + Go-port glolcat
# Source: lolcat — rainbow-colorize text output.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-p --spread)'{-p,--spread=}'[character spread (default 3.0)]:n:' \
    '(-F --freq)'{-F,--freq=}'[rainbow frequency (default 0.1)]:n:' \
    '(-S --seed)'{-S,--seed=}'[random seed (0 = random)]:n:' \
    '(-a --animate)'{-a,--animate}'[enable animation]' \
    '(-d --duration)'{-d,--duration=}'[animation duration in frames]:frames:' \
    '(-s --speed)'{-s,--speed=}'[animation speed]:n:' \
    '(-i --invert)'{-i,--invert}'[invert (colorize background)]' \
    '(-t --truecolor)'{-t,--truecolor}'[use 24-bit color output]' \
    '(-24 --24bit)'{-24,--24bit}'[24-bit color (alias)]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-f --force)'{-f,--force}'[force colors even when not on a tty]' \
    '*:file:_files' \
    && ret=0

return ret
