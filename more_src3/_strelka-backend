#compdef strelka-backend
# _strelka-backend — Target Brands Strelka backend scanner-worker daemon CLI pulling file tasks from coordinator queue executing YARA TRiD ssdeep ClamAV PE OLE PDF extraction scanners producing JSON metadata (target team, Go); flag
# upstream: https://github.com/target/strelka

_strelka-backend() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.toml"' \
        '--logfile=+[file]:file:_files' \
        '--logsystem=+[system]:s:(stdout syslog journald file)' \
        '--coordinator=+[host:port]:str:' \
        '--limits-distribution=+[d]:str:' \
        '--limits-time-to-live=+[d]:str:' \
        '--limits-max-byte-size=+[bytes]:n:' \
        '--limits-max-files=+[N]:n:' \
        '--limits-max-depth=+[N]:n:' \
        '--scanners=+[csv]:str:' \
        '--scanner-config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--cpus=+[N]:n:' \
        '--queue=+[queue name]:str:' \
        '--shutdown-timeout=+[d]:str:' \
        '--metrics=+[host:port]:str:' \
        '--prometheus-port=+[port]:n:' \
        '--no-banner[no banner]'
}

_strelka-backend "$@"
