#compdef kubectl-snap
# kubectl-snap (krew plugin): take a snapshot of Kubernetes objects
# https://github.com/mogensen/kubectl-snap

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:_guard "^-*" namespace' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[snapshot all namespaces]' \
  '--context=[kubernetes context]:context' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output directory]:dir:_directories' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(yaml json)' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector' \
  '*:resource type'
