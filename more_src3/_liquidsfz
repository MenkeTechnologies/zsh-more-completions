#compdef liquidsfz
# _liquidsfz — SFZ sampler with JACK output (swesterfeld/liquidsfz)
# upstream: https://github.com/swesterfeld/liquidsfz
# Flags from src/liquidsfz.cc.

_liquidsfz() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--debug[enable debugging output]' \
        '--quality[sample playback quality (1-3)]:n:(1 2 3)' \
        '--preload-time[sample preload time (ms)]:ms:' \
        '*:SFZ file:_files -g "*.sfz"'
}

_liquidsfz "$@"
