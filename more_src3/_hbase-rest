#compdef hbase-rest hbase-thrift hbase-thrift2 hbase-regionserver
# _hbase-rest — Apache HBase per-role daemon launchers (rest gateway, thrift / thrift2 gateways, regionserver) all share the standard daemon op (start|stop|foreground); --config alt conf dir, -D KEY=VAL set hbase property; positional argument is the action then optional per-daemon args)
# upstream: https://github.com/apache/hbase
# Subcommands from Apache HBase bin/hbase on tip.

_hbase-rest() {
    _arguments \
        '--help[show help]' \
        '--config+[config dir]:dir:_files -/' \
        '*-D+[KEY=VAL]:property:' \
        '1::action:(start stop foreground)' \
        '*::arg:_files'
}

_hbase-rest "$@"
