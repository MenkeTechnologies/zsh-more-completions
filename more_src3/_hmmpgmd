#compdef hmmpgmd
# Documentation: https://github.com/EddyRivasLab/hmmer/blob/master/src/hmmpgmd.c
# Reference accessed: 2026-05-27
# Verified: upstream src/hmmpgmd.c ESL_OPTIONS table (HMMER 3.x)

# HMMER hmmpgmd: HMMER search daemon (master/worker)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help on version and usage]' \
  '--master[run program as the master server]' \
  '--worker[run program as a worker with server at host]:host:_hosts' \
  '--cport[port to use for client/server communication]:port:' \
  '--wport[port to use for server/worker communication]:port:' \
  '--ccncts[maximum number of client side connections to accept]:n:' \
  '--wcncts[maximum number of worker side connections to accept]:n:' \
  '--pid[file to write process id to]:file:_files' \
  '--seqdb[protein database to cache for searches]:file:_files' \
  '--hmmdb[hmm database to cache for searches]:file:_files' \
  '--cpu[number of parallel CPU workers to use for multithreads]:n:' && ret=0
return ret
