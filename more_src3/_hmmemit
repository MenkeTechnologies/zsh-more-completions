#compdef hmmemit
# Documentation: https://github.com/EddyRivasLab/hmmer/blob/master/src/hmmemit.c
# Reference accessed: 2026-05-27
# Verified: upstream src/hmmemit.c ESL_OPTIONS table (HMMER 3.x)

# HMMER hmmemit: sample sequences from a profile HMM
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help on version and usage]' \
  '-o[send sequence output to file, not stdout]:file:_files' \
  '-N[number of sequences to sample]:count:' \
  '-a[emit alignment]' \
  '-c[emit simple majority-rule consensus sequence]' \
  '-C[emit fancier consensus sequence (requires --minl, --minu)]' \
  '-p[sample sequences from profile, not core model]' \
  '-L[set expected length from profile]:length:' \
  '--local[configure profile in multihit local mode]' \
  '--unilocal[configure profile in unilocal mode]' \
  '--glocal[configure profile in multihit glocal mode]' \
  '--uniglocal[configure profile in unihit glocal mode]' \
  '--minl[show consensus as any (X/N) unless at this fraction]:fraction:' \
  '--minu[show consensus as upper case if at this fraction]:fraction:' \
  '--seed[set RNG seed value]:seed:' \
  '*:HMM file:_files' && ret=0
return ret
