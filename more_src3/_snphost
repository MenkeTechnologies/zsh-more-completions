#compdef snphost
# _snphost — AMD SEV-SNP host management utility (virtee/snphost)
# upstream: https://github.com/virtee/snphost
# Subcommands from src/main.rs (clap derive).

_snphost() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-q --quiet)'{-q,--quiet}'[suppress console output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'show:show SEV-SNP platform info'
                'export:export certificate chain to a directory'
                'import:import certificate chain to a file'
                'ok:probe system for SEV-SNP support'
                'config:modify SNP configuration'
                'verify:verify a certificate chain'
                'fetch:retrieve content from AMD KDS'
                'commit:commit current firmware/TCB versions to PSP'
                'vlek-load:load a VLEK to the system'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                show|config|verify|fetch)
                    _arguments '*::subcommand:'
                    ;;
            esac
            ;;
    esac
}

_snphost "$@"
