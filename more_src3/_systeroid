#compdef systeroid
# Documentation: https://github.com/orhun/systeroid
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for systeroid (sysctl TUI)

_arguments -s -S \
  '(-a --all)'{-a,--all}'[display all variables]' \
  '(-T --tree)'{-T,--tree}'[display variables in tree-like format]' \
  '(-J --json)'{-J,--json}'[display variables in JSON format]' \
  '--deprecated[include deprecated variables]' \
  '(-e --ignore)'{-e,--ignore}'[ignore unknown variable errors]' \
  '(-N --names)'{-N,--names}'[print only variable names]' \
  '(-n --values)'{-n,--values}'[print only variable values]' \
  '(-b --binary)'{-b,--binary}'[print values without newline]' \
  '(-p --load)'{-p+,--load=}'[read values from file]:file:_files' \
  '(-S --system)'{-S,--system}'[read values from system directories]' \
  '(-r --pattern)'{-r+,--pattern=}'[use regex for matching variable names]:pattern:' \
  '(-q --quiet)'{-q,--quiet}'[suppress output after setting values]' \
  '(-w --write)'{-w,--write}'[enable writing mode only]' \
  '(-E --explain)'{-E,--explain}'[provide detailed parameter explanation]' \
  '(-D --docs)'{-D+,--docs=}'[set kernel documentation path]:path:_files -/' \
  '(-P --no-pager)'{-P,--no-pager}'[disable pager output]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '--tui[launch terminal user interface]' \
  '(-c --config)'{-c+,--config=}'[set configuration file path]:file:_files' \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-V --version)'{-V,--version}'[display version information]' \
  '*:parameter=value:' && return 0
