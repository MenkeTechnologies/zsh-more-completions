#compdef hpcviewer hpctraceviewer
# _hpcviewer — Rice University HPCToolkit hpcviewer and hpctraceviewer Eclipse RCP GUI viewers for performance experiment databases (rice-hpctoolkit team, Java); custom argparse
# upstream: https://github.com/HPCToolkit/hpcviewer.e4

_hpcviewer() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-version[show version]' \
        '-data+[workspace dir]:dir:_files -/' \
        '-name+[product name]:str:' \
        '-product+[product id]:str:' \
        '-vmargs+[VM args]:str:' \
        '-noupdate[no update]' \
        '-server[server mode]' \
        '-clean[clean workspace]' \
        '-debug[debug]' \
        '-console[show Eclipse console]' \
        '-port+[port]:port:_ports' \
        '-host+[host]:host:_hosts' \
        '*:database dir or experiment xml:_files -g "*.xml *.exp *.dbase"'
}

_hpcviewer "$@"
