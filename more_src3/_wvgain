#compdef wvgain
# Documentation: wvgain --help (WavPack 5.x)
# Source: WavPack wvgain — apply ReplayGain to WavPack files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[album mode (treat files as a single album)]' \
    '-c[clean ReplayGain values from all files (no analysis)]' \
    '-d[display calculated values only (no file modification)]' \
    '-i[ignore .wvc file (force hybrid lossy)]' \
    '-n[new files only (skip those with track / album info)]' \
    '-q[quiet (minimal console output)]' \
    '-s[show stored values only (no analysis)]' \
    '(-t -1)-t[use multiple threads for faster operation]' \
    '(-t -1)-1[do not use multiple threads]' \
    '(- *)-v[print version]' \
    '-z1[set console title to indicate progress]' \
    '*:WavPack file:_files -g "*.wv"' \
    && ret=0

return ret
