#compdef hdfs hadoop-fs
# _hadoop-fs — Apache Hadoop HDFS / hadoop fs (dfs subcommand handler used by both hadoop fs and hdfs dfs; subcommands: ls, du, df, mkdir, rm, rmdir, mv, cp, get, put, copyFromLocal, copyToLocal, cat, text, head, tail, touchz, touch, chmod, chown, chgrp, setrep, count, find, expunge, stat, getmerge, appendToFile, test, checksum, createSnapshot, deleteSnapshot, renameSnapshot)
# upstream: https://github.com/apache/hadoop
# Subcommands from Apache Hadoop hadoop-common src/main/java/org/apache/hadoop/fs/FsShell.java on tip.

_hadoop-fs() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '-fs+[Hadoop FS URI]:uri:' \
        '-conf+[config file]:file:_files' \
        '*-D+[key=value]:property:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'fs command' '(-ls -du -df -mkdir -rm -rmdir -mv -cp -get -getfacl -getfattr -put -copyFromLocal -copyToLocal -cat -text -head -tail -touchz -touch -chmod -chown -chgrp -setrep -count -find -expunge -stat -getmerge -appendToFile -test -checksum -createSnapshot -deleteSnapshot -renameSnapshot -ls -mv -setfacl -setfattr)' ;;
        args) _arguments '*:path:_files' ;;
    esac
}

_hadoop-fs "$@"
