#compdef serverpod
# Documentation: https://docs.serverpod.dev/get-started
# Source: serverpod/serverpod tools/serverpod_cli/lib/src/commands/ — server framework for Flutter/Dart (Dart, args package).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _sp_cmds
_sp_cmds=(
    'create:create a new Serverpod project'
    'create-migration:create a database migration'
    'create-repair-migration:create a repair migration'
    'generate:generate code from yaml definitions'
    'generate-pubspecs:generate pubspec files'
    'analyze-pubspecs:analyze pubspec files'
    'migrate:apply database migrations'
    'cloud:Serverpod Cloud commands'
    'start:start the development server'
    'run:run the Serverpod application'
    'language-server:run the language server'
    'mcp:run an MCP server'
    'quickstart:quickstart a new project'
    'messages:show messages'
    'version:show version'
)

_arguments -C \
    '(-q --quiet)'{-q,--quiet}'[suppress output]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'serverpod command' _sp_cmds && ret=0
        ;;
esac

return ret
