#compdef triton
# Documentation: https://github.com/TritonDataCenter/node-triton
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for the Joyent/Triton DataCenter 'triton' CloudAPI CLI.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'instance:manage compute instances (alias: inst)'
  'package:manage packages'
  'image:manage images (alias: img)'
  'network:manage networks'
  'volume:manage volumes (alias: vol)'
  'fwrule:manage firewall rules'
  'key:manage account keys'
  'profile:manage CLI profiles (CloudAPI endpoints)'
  'env:emit shell env for a profile'
  'account:show or update account info'
  'info:show account overview'
  'services:list available services'
  'datacenters:list datacenters'
  'completion:emit bash completion'
  'cloudapi:make raw CloudAPI requests'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --profile)'{-p+,--profile=}'[use named profile]:profile:' \
  '(-J --url)'{-J+,--url=}'[CloudAPI URL]:url:_urls' \
  '(-a --account)'{-a+,--account=}'[account login]:account:' \
  '(-u --user)'{-u+,--user=}'[RBAC user]:user:' \
  '(-k --keyId)'{-k+,--keyId=}'[SSH key id]:keyid:' \
  '(-i --insecure)'{-i,--insecure}'[disable TLS cert verification]' \
  '--accept-version=[accept CloudAPI version]:version:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'triton command' commands && ret=0
    ;;
esac

return ret
