#compdef krew
# _krew-bin — krew kubectl plugin manager (Kubernetes SIGs, Go); install/upgrade kubectl plugins
# upstream: https://github.com/kubernetes-sigs/krew

_krew-bin() {
    local -a sub=(
        'completion:print shell completion'
        'help:show help'
        'index:manage indexes'
        'info:print plugin info'
        'install:install kubectl plugins'
        'list:show installed plugins'
        'search:search the plugin index'
        'uninstall:uninstall plugins'
        'update:fetch latest plugin index'
        'upgrade:upgrade installed plugins'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --v)'{-v,--v}'+[log verbosity]:n:' \
        '--add-dir-header[add dir header to log]' \
        '--alsologtostderr[log to stderr too]' \
        '--log-backtrace-at+[log backtrace]:str:' \
        '--log-dir+[log dir]:dir:_files -/' \
        '--logtostderr+[log to stderr]:bool:' \
        '--stderrthreshold+[stderr threshold]:n:' \
        '--vmodule+[vmodule]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krew subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|info) _arguments '*:plugin:' ;;
                index) _arguments '1:index cmd:(add list remove)' '*:args:' ;;
                search) _arguments '*:query:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_krew-bin "$@"
