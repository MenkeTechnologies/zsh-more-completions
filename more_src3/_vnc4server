#compdef vnc4server
# Documentation: https://man.cx/vnc4server
# Reference accessed: 2026-05-21
# Verified: upstream vnc4server(1) manpage at the URL above. Unrecognised options pass through to Xvnc.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-geometry+[WxH]:geom:' \
  '-depth+[depth]:n:(8 15 16 24)' \
  '-pixelformat+[pixel format BGRnnn or RGBnnn]:fmt:' \
  '-name+[desktop name]:name:' \
  '-cc+[visual class]:class:(3 4)' \
  '-localhost[allow only same-machine connections]' \
  '-rfbport+[rfb port (Xvnc passthrough)]:port:' \
  '-rfbauth+[rfb auth file (Xvnc passthrough)]:file:_files' \
  '-fp+[font path (Xvnc passthrough)]:path:' \
  '-kill+[kill session]:display:' \
  '*:display:' && ret=0

return ret
