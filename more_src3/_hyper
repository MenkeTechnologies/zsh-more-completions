#compdef hyper
# Documentation: https://github.com/vercel/hyper (cli/index.ts)
# Reference accessed: 2026-05-29
# Hyper — Vercel terminal app CLI (plugin manager + launcher).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'install:install a plugin'
  'i:install a plugin (alias)'
  'uninstall:uninstall a plugin'
  'u:uninstall a plugin (alias)'
  'rm:uninstall a plugin (alias)'
  'remove:uninstall a plugin (alias)'
  'list:list installed plugins'
  'ls:list installed plugins (alias)'
  'search:search for plugins on npm'
  's:search for plugins on npm (alias)'
  'list-remote:list plugins available on npm'
  'lsr:list plugins available on npm (alias)'
  'ls-remote:list plugins available on npm (alias)'
  'docs:open the npm page of a plugin'
  'd:open plugin docs (alias)'
  'h:open plugin docs (alias)'
  'home:open plugin docs (alias)'
  'version:show Hyper version'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'hyper subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      install|i|uninstall|u|rm|remove|docs|d|h|home)
        _arguments '*:plugin name:' && ret=0
        ;;
      search|s)
        _arguments ':query:' && ret=0
        ;;
    esac
    ;;
esac

return ret
