#compdef twprint
# Documentation: man twprint(8)
# Source: Tripwire/tripwire-open-source src/twprint/twprintcmdline.cpp (master) — print tripwire report/database (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\\?,--help}'[show help]' \
    '(-m --mode --print-report -r --print-dbfile -d)'{-m+,--mode=}'[mode]:mode:(print-report print-dbfile)' \
    '(-m --mode --print-report -r --print-dbfile -d)--print-report[print report mode]' \
    '(-m --mode --print-report -r --print-dbfile -d)-r+[print report mode (with file)]:file:_files' \
    '(-m --mode --print-report -r --print-dbfile -d)--print-dbfile[print database mode]' \
    '(-m --mode --print-report -r --print-dbfile -d)-d+[print database mode (with file)]:file:_files' \
    '(-v --verbose -s --silent --quiet)'{-v,--verbose}'[verbose output]' \
    '(-v --verbose -s --silent --quiet)'{-s,--silent,--quiet}'[silent output]' \
    '(-c --cfgfile)'{-c+,--cfgfile=}'[config file]:file:_files' \
    '(-P --passphrase)'{-P+,--passphrase=}'[site/local key passphrase]:passphrase:_default' \
    '(-r --twrfile)'{-r+,--twrfile=}'[report file]:file:_files' \
    '*:object:_files' \
    && ret=0

return ret
