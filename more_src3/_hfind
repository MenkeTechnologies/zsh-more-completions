#compdef hfind
# Documentation: https://www.sleuthkit.org/sleuthkit/man/hfind.html
# Source: sleuthkit/sleuthkit man/hfind.1 — lookup hash values in a hash database (NSRL, HashKeeper, md5sum).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[create an index file for the database]:db_type:(nsrl-md5 nsrl-sha1 md5sum hk encase idxonly)' \
    '-f[file containing one hash value per line]:lookup file:_files' \
    '-e[extended mode (additional info besides just the name)]' \
    '-q[quick mode (display 0/1 for not-found/found instead of details)]' \
    '-V[display version]' \
    '*:hash db file or hash:_files' \
    && ret=0

return ret
