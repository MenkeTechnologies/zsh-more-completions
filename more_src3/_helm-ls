#compdef helm-ls helm_ls
# Documentation: https://github.com/mrjosh/helm-ls
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for helm-ls (Helm Language Server)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'serve:start the language server'
  'version:print version information'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (serve)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--stdio[use stdio transport]' \
          '--log-level=[log level]:level:(debug info warning error)' && ret=0
        ;;
    esac
    ;;
esac

return ret
