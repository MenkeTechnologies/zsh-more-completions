#compdef jadx-gui
# Documentation: https://github.com/skylot/jadx
# Source: skylot/jadx jadx-core JadxCLIArgs — GUI wrapper accepts the same CLI flags as `jadx`.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --output-dir)'{-d+,--output-dir=}'[output directory]:dir:_directories' \
    '(-ds --output-dir-src)'{-ds+,--output-dir-src=}'[output directory for sources]:dir:_directories' \
    '(-dr --output-dir-res)'{-dr+,--output-dir-res=}'[output directory for resources]:dir:_directories' \
    '(-r --no-res)'{-r,--no-res}'[do not decode resources]' \
    '(-s --no-src)'{-s,--no-src}'[do not decompile source code]' \
    '(-j --threads-count)'{-j+,--threads-count=}'[processing thread count (default 16)]:n:' \
    '--single-class=[decompile a single class (full name / raw / alias)]:class:' \
    '--single-class-output=[output file or dir for single class]:path:_files' \
    '--output-format=[output format]:fmt:(java json)' \
    '(-e --export-gradle)'{-e,--export-gradle}'[save as gradle project]' \
    '--export-gradle-type=[gradle project template]:type:(auto)' \
    '(-m --decompilation-mode)'{-m+,--decompilation-mode=}'[code output mode]:mode:(auto restructure simple fallback)' \
    '--show-bad-code[show inconsistent (likely incorrect) code]' \
    '--no-xml-pretty-print[do not prettify XML]' \
    '--no-imports[do not use imports; write full package name]' \
    '--no-debug-info[disable debug info parsing]' \
    '--add-debug-lines[add comments with debug line numbers]' \
    '--no-inline-anonymous[disable anonymous-class inline]' \
    '--no-inline-methods[disable method inline]' \
    '--no-move-inner-classes[disable moving inner classes into parent]' \
    '--no-inline-kotlin-lambda[disable Kotlin-lambda inline]' \
    '--no-finally[do not extract finally block]' \
    '--no-restore-switch-over-string[do not restore switch-over-string]' \
    '--no-replace-consts[do not replace constants with matching field]' \
    '--escape-unicode[escape non-latin chars in strings]' \
    '--respect-bytecode-access-modifiers[do not change original access modifiers]' \
    '--mappings-path=[deobfuscation mappings file/directory]:path:_files' \
    '--mappings-mode=[deobfuscation mapping mode]:mode:' \
    '--deobf[activate deobfuscation]' \
    '--deobf-min=[min name length to keep (default 3)]:n:' \
    '--deobf-max=[max name length to keep (default 64)]:n:' \
    '--deobf-whitelist=[space-separated classes/packages to exclude]:list:' \
    '--deobf-cfg-file=[auto-generated-name mappings file]:file:_files' \
    '--deobf-cfg-file-mode=[mode for auto-generated-name file]:mode:' \
    '--deobf-res-name-source=[better name source for resources]:source:' \
    '--use-source-name-as-class-name-alias[use source name as class-name alias]' \
    '--source-name-repeat-limit=[source-name repeat limit (default 10)]:n:' \
    '--use-kotlin-methods-for-var-names[use Kotlin intrinsics to rename vars]' \
    '--use-headers-for-detect-resource-extensions[detect resource ext from file header]' \
    '--rename-flags=[fix options]:flag:(case valid printable none all)' \
    '--integer-format=[integer display format]:fmt:(auto decimal hexadecimal)' \
    '--type-update-limit=[type-update limit per instruction (default 10)]:n:' \
    '--fs-case-sensitive[treat filesystem as case-sensitive]' \
    '--cfg[save methods CFG to .dot]' \
    '--raw-cfg[save raw-instruction CFG to .dot]' \
    '(-f --fallback)'{-f,--fallback}'[(deprecated) set decompilation mode to fallback]' \
    '--use-dx[use dx/d8 to convert Java bytecode]' \
    '--comments-level=[code comments level]:level:' \
    '--log-level=[log level]:level:(quiet progress error warn info debug)' \
    '(-v --verbose)'{-v,--verbose}'[verbose (log-level DEBUG)]' \
    '(-q --quiet)'{-q,--quiet}'[quiet (log-level QUIET)]' \
    '--disable-plugins=[plugin ids to disable (comma-separated)]:plugins:' \
    '--config=[load configuration from file]:file:_files' \
    '--save-config=[save current options to file and exit]:file:_files' \
    '--print-files[print files and dirs used by jadx]' \
    '(- *)--version[print jadx version]' \
    '(- *)'{-h,--help}'[print help]' \
    '*:input APK/dex/jar/aar/zip/class:_files' \
    && ret=0

return ret
