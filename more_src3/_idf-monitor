#compdef idf-monitor
# _idf-monitor — Espressif Systems idf_monitor.py CLI for the ESP-IDF serial monitor reading ESP32 UART log output decoding panic backtrace gdb-stub esp-tracing colour-coded log-level filter timestamps custom baud (espressif team, Python); argparse
# upstream: https://github.com/espressif/esp-idf

_idf-monitor() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-p+[serial port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '--port=+[serial port]:file:_files -g "/dev/tty* /dev/cu*"' \
        '-b+[baud]:n:(74880 115200 230400 460800 921600 1500000 2000000)' \
        '--baud=+[baud]:n:(74880 115200 230400 460800 921600 1500000 2000000)' \
        '--make=+[make]:str:' \
        '--encrypted[encrypted]' \
        '--toolchain-prefix=+[prefix]:str:' \
        '--eol=+[eol]:e:(CR LF CRLF)' \
        '--print_filter=+[filter]:str:' \
        '--decode-coredumps=+[mode]:m:(none info)' \
        '--decode-panic=+[mode]:m:(none backtrace)' \
        '--target=+[target]:t:(esp32 esp32s2 esp32s3 esp32c2 esp32c3 esp32c6 esp32h2)' \
        '--reset[reset on connect]' \
        '--no-reset[no reset on connect]' \
        '--ws=+[ws url]:str:' \
        '--rom-elf-file=+[file]:file:_files -g "*.elf"' \
        '--enable-address-decoding[enable address decoding]' \
        '--disable-address-decoding[disable address decoding]' \
        '--force-color[force color]' \
        '--no-color[no color]' \
        '--timestamps[timestamps]' \
        '--timestamp-format=+[fmt]:str:' \
        '*:elf file:_files -g "*.elf"'
}

_idf-monitor "$@"
