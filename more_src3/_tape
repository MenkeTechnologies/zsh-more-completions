#compdef tape
# Documentation: https://github.com/tape-testing/tape
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for tape - TAP-producing test harness for Node.js

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '*'{-r,--require}'=[require module before tests]:module:' \
  '(-i --ignore)'{-i,--ignore}'=[file containing ignore patterns (default .gitignore)]:file:_files' \
  '*--ignore-pattern=[exclusion glob pattern]:pattern:' \
  '--no-only[fail if any .only tests exist]' \
  '--strict[error when no test files match glob]' \
  '*:test files:_files -g "*.{js,mjs,cjs}"'
