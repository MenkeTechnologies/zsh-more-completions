#compdef systemd-bless-boot
# Documentation: source-direct extraction from upstream
# systemd/systemd src/bless-boot/bless-boot.c ŌĆö
#   lines 36-72 (help() block showing the OPTIONS + COMMANDS
#     table layout)
#   lines 76-101 (parse_argv() with the OptionParser
#     FOREACH_OPTION_OR_RETURN dispatch + OPTION_LONG entries)
#   lines 342-355 + 450-455 (the VERB_DEFAULT_NOARG and
#     VERB_FULL declarations for the 4 verbs: status (default),
#     good, bad, indeterminate)
# Reference accessed: 2026-05-30 via gh api.
#
# systemd-bless-boot manages the systemd-boot LoaderBootCount
# A/B-fallback marker: each successful boot decrements
# `tries_left` in the boot-loader-entry filename; when
# `tries_left` reaches 0 the entry is considered bad.  This
# tool transitions a boot-loader-entry filename between its
# "trying" form (with `+TRIES_LEFT-TRIES_DONE` suffix) and its
# "good" form (no counter) or "bad" form (`+0-TRIES_DONE`).
# Driven by the `systemd-bless-boot.service` unit that runs
# late in the boot to mark the boot good if userspace came up
# cleanly.
#
# Critical extraction note: bless-boot uses systemd's NEWER
# `OptionParser` + `FOREACH_OPTION_OR_RETURN` macro idiom
# (introduced in systemd v257+) ŌĆö NOT the historical
# getopt_long + static struct option pattern.  This idiom uses
# `OPTION_COMMON_HELP` / `OPTION_COMMON_VERSION` macros that
# auto-add `--help`/`-h` and `--version` with consistent
# behavior across all systemd tools.  The `OPTION_LONG` macro
# adds a long-only flag with a 3-part signature
# (name, value-placeholder, description).
#
# Critical extraction note: the verb table uses VERB_FULL /
# VERB_DEFAULT_NOARG declarations.  `status` is the DEFAULT
# verb when no arg is supplied (VERB_DEFAULT_NOARG at line
# 342).  `good`/`bad`/`indeterminate` all dispatch to the same
# verb_set() handler at line 456 but with different
# `Status data` parameters via the VERB_FULL `data` arg
# (STATUS_GOOD / STATUS_BAD / STATUS_INDETERMINATE).

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'status:show status of current boot loader entry (DEFAULT; outputs one of: clean|good|bad|indeterminate|dirty)'
  'good:mark this boot as good (removes the counter suffix from the entry filename)'
  'bad:mark this boot as bad (sets tries_left to 0 in the entry filename)'
  'indeterminate:undo any marking as good or bad (restore to the original counter state)'
  'help:print bless-boot usage and exit'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '--version[show package version and exit]' \
  \*'--path=[$BOOT partition path (may be used multiple times to specify both ESP + XBOOTLDR)]:path:_files -/' \
  '1:subcommand (default: status):->subcmd' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'bless-boot verb' subcommands && ret=0
    ;;
esac

return ret
