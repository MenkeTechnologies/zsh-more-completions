#compdef xastir
# Documentation: https://manpages.debian.org/testing/xastir/xastir.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show summary of options]' \
  '-c+[config directory (default ~/.xastir)]:dir:_directories' \
  '-f+[track callsign]:callsign:' \
  '-i[use private colormap]' \
  '-geometry+[window geometry WxH+x+y]:geom:' \
  '-l+[language code]:lang:' \
  '-m[deselect maps]' \
  '-p[disable popups]' \
  '-t[enable internal SIGSEGV handler]' \
  '-v+[debug level]:level:' && ret=0

return ret
