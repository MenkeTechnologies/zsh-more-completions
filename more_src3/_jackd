#compdef jackd
# Documentation: https://jackaudio.org/
# Source: manpages.debian.org/jackd.1 — JACK Audio Connection Kit server daemon.
# Reference accessed: 2026-06-10
# Note: -d driver opens a per-backend option set (alsa/coreaudio/dummy/net/oss/sun/portaudio/firewire);
#       this completion covers the front-end + ALSA/Dummy backend overlap which is most common on Linux.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --driver)'{-d+,--driver=}'[audio backend driver]:backend:(alsa coreaudio dummy net netone oss sun portaudio firewire)' \
    '(- *)'{-h,--help}'[print brief usage message]' \
    '(-a --autoconnect)'{-a+,--autoconnect=}'[handle self-connect requests]:modechar:' \
    '(-m --no-mlock)'{-m,--no-mlock}'[do not lock memory even with --realtime]' \
    '(-n --name)'{-n+,--name=}'[name this jackd instance]:server name:' \
    '(-p --port-max)'{-p+,--port-max=}'[maximum number of ports the server manages]:n:' \
    '--replace-registry[remove the shared memory registry used by all instances]' \
    '(-R --realtime -r --no-realtime)'{-R,--realtime}'[use realtime scheduling]' \
    '(-R --realtime -r --no-realtime)'{-r,--no-realtime}'[do not use realtime scheduling]' \
    '(-P --realtime-priority)'{-P+,--realtime-priority=}'[scheduler priority]:int:' \
    '--silent[silence any output during operation]' \
    '(-T --temporary)'{-T,--temporary}'[exit once all clients have closed]' \
    '(-t --timeout)'{-t+,--timeout=}'[client timeout limit in ms]:ms:' \
    '(-Z --nozombies)'{-Z,--nozombies}'[never kick out slow clients]' \
    '(-C --internal-session-file)'{-C+,--internal-session-file=}'[load internal clients + connections from config]:file:_files' \
    '(-u --unlock)'{-u,--unlock}'[unlock libraries (GTK+/QT/FLTK/Wine)]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-c --clocksource)'{-c+,--clocksource=}'[wall clock]:source:(h s)' \
    '(- *)'{-V,--version}'[print version and exit]' \
    && ret=0

return ret
