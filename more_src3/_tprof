#compdef tprof
# Documentation: man tprof(8)
# Source: netbsd/src usr.sbin/tprof — hardware performance counter profiler (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:operation:(list monitor count analyze top)' \
    '*::argument:_files' \
    && ret=0

return ret
