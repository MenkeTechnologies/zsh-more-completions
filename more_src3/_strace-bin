#compdef strace
# _strace-bin — strace system call tracer for Linux (Dmitry Levin); attaches to PID or runs cmd, traces syscalls
# upstream: https://github.com/strace/strace

_strace-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[count time/calls/errors]' \
        '-C[same as -c plus normal output]' \
        '-w[summarise wall-clock]' \
        '-d[debug]' \
        '-D[run tracer as detached]' \
        '-DD[run tracer in its own process group]' \
        '-DDD[run tracer in its own session]' \
        '-f[follow forks]' \
        '-ff[separate output per PID]' \
        '-h[help]' \
        '-i[print instruction pointer]' \
        '-k[print stack trace per syscall]' \
        '-q[suppress messages]' \
        '-qq[suppress exit codes too]' \
        '-r[print relative timestamp]' \
        '-t[absolute time]' \
        '-tt[time with usec]' \
        '-ttt[seconds since epoch]' \
        '-T[show syscall time]' \
        '-v[verbose (no abbreviation)]' \
        '-x[non-printable strings in hex]' \
        '-xx[all strings in hex]' \
        '-y[print fd paths]' \
        '-yy[print fd protocol]' \
        '-A[append to output]' \
        '-b+[break syscall]:syscall:' \
        '-e+[filter expr]:expr:' \
        '-o+[output file]:file:_files' \
        '-O+[overhead usec]:n:' \
        '-p+[attach PID]:pid:_pids' \
        '-P+[trace files by path]:path:_files' \
        '-s+[max string length]:n:' \
        '-S+[sort by]:by:(time calls name nothing)' \
        '-u+[run as user]:user:_users' \
        '-E+[env var]:name=val:' \
        '-I+[interrupt mode]:mode:(1 2 3 4)' \
        '-z[only successful syscalls]' \
        '-Z[only failed syscalls]' \
        '*::command:_command_names -e'
}

_strace-bin "$@"
