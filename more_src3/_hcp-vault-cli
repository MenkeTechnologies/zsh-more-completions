#compdef hcp-vault-cli hcp-vault
# _hcp-vault-cli — HashiCorp Cloud Platform hcp-vault-cli CLI command-line frontend wrapping HashiCorp Cloud Platform HCP Vault Secrets Vault-as-a-Service offering providing secrets list show create update delete-rotate-create-app-link-iam-policy-org-project-template-key-rotation-static-dynamic-rotation-tier-namespace-management for managed Vault clusters (HashiCorp team, Go); cobra
# upstream: https://www.hashicorp.com/cloud-platform/vault-secrets

_hcp-vault-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'org:organization operations'
        'project:project operations'
        'app:application operations'
        'secret:secret operations'
        'integration:integration operations'
        'sync:sync operations'
        'rotate:rotate a secret'
        'iam:IAM policy operations'
        'sa:service principal operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--access-token=+[token]:str:' \
        '--organization=+[id]:str:' \
        '--project=+[id]:str:' \
        '-a+[app]:str:' \
        '--app=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hcp-vault-cli subcommand' sub ;;
        args)
            case $words[1] in
                org|project|app|secret|integration|sync|iam|sa) _arguments '1:op:(list get create update delete enable disable)' '*:name:' ;;
                rotate) _arguments '*:secret name:' ;;
            esac
            ;;
    esac
}

_hcp-vault-cli "$@"
