#compdef udp_proxy
# Documentation: https://github.com/Mbed-TLS/mbedtls/blob/development/programs/test/udp_proxy.c
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'server_addr=:address to forward packets to'
  'server_port=:port to forward packets to'
  'listen_addr=:address for accepting client connections'
  'listen_port=:port for accepting client connections'
  'duplicate=:duplicate 1 in N packets randomly'
  'delay=:delay 1 packet in N'
  'delay_ccs=:delay ChangeCipherSpec messages'
  'delay_cli=:handshake message types from client to delay'
  'delay_srv=:handshake message types from server to delay'
  'drop=:drop 1 packet in N randomly'
  'mtu=:drop packets larger than this size'
  'bad_ad=:inject corrupted ApplicationData record'
  'bad_cid=:duplicate packets with corrupted Connection IDs'
  'pack=:merge packets into single datagram for N ms'
  'protect_hvr=:protect HelloVerifyRequest from drop/delay'
  'protect_len=:never drop/delay packets of given size'
  'inject_clihlo=:inject fake ClientHello after handshake'
  'seed=:PRNG seed for event generation'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    _describe -t params 'param' params -S '' && ret=0
    ;;
esac

return ret
