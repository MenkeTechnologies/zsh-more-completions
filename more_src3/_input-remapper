#compdef input-remapper input-remapper-control input-remapper-reader-service input-remapper-service
# Documentation: https://github.com/sezanzeb/input-remapper
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# input-remapper 2.2.x (sezanzeb/input-remapper): GTK GUI, dbus control, and systemd-style daemons.

local curcontext="$curcontext" state line ret=1
local -a ir_control_commands

if [[ $service == input-remapper-control ]]; then
  ir_control_commands=(
    'autoload:load configured presets for all devices (or one with --device)'
    'start:start injecting for --device using --preset'
    'stop:stop injecting for --device'
    'stop-all:stop injecting on every device'
    'hello:probe whether the dbus daemon replies'
    'quit:ask the daemon to shut down'
    'start-daemon:internal: background-spawn input-remapper-service'
    'start-reader-service:internal: background-spawn input-remapper-reader-service'
  )

  _arguments -s -S \
    '--command=-[send a command to the dbus daemon]:command:->ir_command' \
    '--config-dir=-[directory containing config.json]:config directory:_files -/' \
    '--preset=-[preset filename without .json suffix]:preset:' \
    '--device=-[device key from --list-devices, or a /dev/input path]:device:' \
    '--list-devices[list device keys and exit]' \
    '--symbol-names[print key names usable in presets and exit]' \
    '(-d --debug)'{-d,--debug}'[verbose logging]' \
    '(-v --version)'{-v,--version}'[print version and exit]' \
    '(-h --help)'{-h,--help}'[show help]' && ret=0

  case $state in
    (ir_command)
      _describe -t commands 'input-remapper-control --command' ir_control_commands && ret=0
      ;;
  esac
elif [[ $service == input-remapper ]]; then
  # GUI (`input_remapper_gtk.py`): debug only (argparse also supplies --help).
  _arguments -s -S \
    '(-d --debug)'{-d,--debug}'[verbose logging]' \
    '(-h --help)'{-h,--help}'[show help]' && ret=0
elif [[ $service == input-remapper-service ]]; then
  _arguments -s -S \
    '(-d --debug)'{-d,--debug}'[verbose logging]' \
    '--hide-info[suppress the version banner on startup]' \
    '(-h --help)'{-h,--help}'[show help]' && ret=0
else
  # input-remapper-reader-service
  _arguments -s -S \
    '(-d --debug)'{-d,--debug}'[verbose logging]' \
    '(-h --help)'{-h,--help}'[show help]' && ret=0
fi

return ret
