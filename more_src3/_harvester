#compdef harvester
# _harvester — Harvester HCI cluster CLI (SUSE Rancher Harvester, Go); manage Harvester Hyperconverged Infrastructure
# upstream: https://github.com/harvester/harvester

_harvester() {
    local -a sub=(
        'vm:VM commands'
        'image:image commands'
        'volume:volume commands'
        'keypair:ssh keypair commands'
        'login:login to Harvester'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug]' \
        '--config+[config file]:file:_files' \
        '--server+[server URL]:url:_urls' \
        '--namespace+[namespace]:ns:' \
        '-n+[namespace]:ns:' \
        '--token+[bearer token]:str:' \
        '-t+[bearer token]:str:' \
        '--skip-tls-verify[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'harvester subcommand' sub ;;
        args)
            case $words[1] in
                vm) _arguments '1:vm cmd:(create delete pause restart restore start stop list)' '*:vm name:' ;;
                image) _arguments '1:image cmd:(create delete list)' '*:image name:' ;;
                volume) _arguments '1:volume cmd:(create delete list)' '*:volume name:' ;;
            esac
            ;;
    esac
}

_harvester "$@"
