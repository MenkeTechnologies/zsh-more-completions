#compdef sf
# Documentation: https://github.com/salesforcecli/cli
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above (salesforcecli/cli main).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'agent:Agentforce agent commands'
  'alias:manage aliases'
  'apex:execute and manage Apex'
  'autocomplete:set up shell completion'
  'commands:list all CLI commands'
  'community:experience cloud'
  'config:configure CLI'
  'data:work with org data'
  'deploy:deploy metadata to an org'
  'env:Heroku environment integration'
  'force:legacy sfdx force commands'
  'help:show help'
  'info:show CLI info'
  'lightning:Lightning components'
  'limits:org limits'
  'logout:log out of an org'
  'org:manage Salesforce orgs'
  'package:manage packages'
  'plugins:manage CLI plugins'
  'project:work with Salesforce projects'
  'release:release management'
  'retrieve:retrieve metadata from an org'
  'schema:metadata schema'
  'sobject:standard/custom object operations'
  'static-resource:static resource management'
  'update:update the CLI'
  'user:org user management'
  'version:show CLI version'
  'visualforce:Visualforce components'
  'which:show command location'
  'whoami:show authenticated user'
)

# Global flags verified from upstream README:
#   -o/--target-org=<value>  per-command target org (most commands accept it)
#   --target-dev-hub=<value> Dev Hub override (config var name, accepted as flag)
#   --api-version=<value>    override API version
#   --flags-dir=<value>      import flag values from directory
#   --json                   format output as json
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--json[format output as JSON]' \
  '--flags-dir=[import flag values from directory]:dir:_files -/' \
  '-o+[target org username/alias]:org:' \
  '--target-org=[target org username/alias]:org:' \
  '--target-dev-hub=[Dev Hub username/alias]:hub:' \
  '--api-version=[override API version]:version:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'sf subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (autocomplete)
        _values 'shell' bash fish powershell zsh && ret=0
        ;;
      (plugins)
        _values 'plugins action' \
          install inspect link reset uninstall update trust list && ret=0
        ;;
      (config)
        _values 'config action' get list set unset && ret=0
        ;;
      (alias)
        _values 'alias action' list set unset && ret=0
        ;;
    esac
    ;;
esac

return ret
