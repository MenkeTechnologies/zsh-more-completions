#compdef kterm
# Documentation: man kterm(1)
# Source: hrs-allbsd/kterm kterm.man — Kanji-capable xterm fork (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-display+[X display]:display:_x_display' \
    '-geometry+[geometry WxH+X+Y]:geom:_default' \
    '-bg+[background color]:color:_default' \
    '-fg+[foreground color]:color:_default' \
    '-bd+[border color]:color:_default' \
    '-bw+[border width]:px:_default' \
    '-name+[application name]:name:_default' \
    '-title+[window title]:title:_default' \
    '-T+[window title]:title:_default' \
    '-iconic[start iconified]' \
    '-rv[reverse video]' \
    '-fn+[ISO 8859-1 font]:font:_default' \
    '-fr+[roman+kana font]:font:_default' \
    '-fkB+[kanji font]:font:_default' \
    '-fk@+[old-kanji font]:font:_default' \
    '-fkD+[hojo kanji font]:font:_default' \
    '-fl+[fontlist]:list:_default' \
    '-fb+[bold font]:font:_default' \
    '-frb+[roman+kana bold font]:font:_default' \
    '-fkbB+[kanji bold font]:font:_default' \
    '-cn[no cut newline]' \
    '+cn[cut newline]' \
    '-ls[login shell]' \
    '+ls[non-login shell]' \
    '-mb[margin bell]' \
    '+mb[no margin bell]' \
    '-rw[reverse wrap]' \
    '+rw[no reverse wrap]' \
    '-sb[scrollbar]' \
    '+sb[no scrollbar]' \
    '-sf[Sun function keys]' \
    '+sf[default function keys]' \
    '-sk[scroll on keypress]' \
    '+sk[no scroll on keypress]' \
    '-si[no scroll on output]' \
    '+si[scroll on output]' \
    '-cu[curses fix]' \
    '+cu[no curses fix]' \
    '-tn+[terminal type]:terminal:_default' \
    '-cr+[cursor color]:color:_default' \
    '-km+[input/output encoding]:mode:(euc sjis jis7 noconv mle)' \
    '-J[Japanese mode]' \
    '-C+[konsole mode]:mode:_default' \
    '-e+[command]:command:_command_names -e' \
    '*::command args:_default' \
    && ret=0

return ret
