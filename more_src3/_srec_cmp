#compdef srec_cmp
# Documentation: https://srecord.sourceforge.net/man/man1/srec_cmp.1.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed fabricated output-format/fill/pad/crc/Sequence/Stm32 flags
# that belong to srec_cat, not srec_cmp. srec_cmp only compares files.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-Help[show help]' \
  '(- *)-VERSion[show version]' \
  '-Verbose[verbose comparison output]' \
  '-IGnore_Checksums[disable checksum validation]' \
  '-Enable_Sequence_Warnings[enable address ordering warnings]' \
  '-Disable_Sequence_Warnings[disable address ordering warnings]' \
  '-redundant-bytes=[handle redundant memory values]:mode:(ignore warning error)' \
  '-contradictory-bytes=[handle contradictory memory values]:mode:(ignore warning error)' \
  '*:input file:_files' && ret=0
return ret
