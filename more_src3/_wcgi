#compdef wcgi-runner wcgi
# _wcgi — Wasmer wcgi WebAssembly Common Gateway Interface server for WASIX CGI (wasmerio team, Rust); clap-derive
# upstream: https://github.com/wasmerio/wasmer

_wcgi() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--addr=+[bind address]:str:' \
        '-a+[bind address]:str:' \
        '--workdir=+[work dir]:dir:_files -/' \
        '--mapdir=+[GUEST:HOST]:str:' \
        '--env=+[name=value]:str:' \
        '--forward-host-env[forward host env]' \
        '--dialect=+[dialect]:d:(wcgi rcgi)' \
        '--tls-cert=+[cert file]:file:_files' \
        '--tls-key=+[key file]:file:_files' \
        '--enable-experimental-io-devices[experimental IO]' \
        '--enable-threads[enable threads]' \
        '--allow-multiple-wasi-versions[allow multi WASI]' \
        '--deny-multiple-wasi-versions[deny multi WASI]' \
        '*:wasm or wat:_files -g "*.wasm *.wat"'
}

_wcgi "$@"
