#compdef jsonschema-cli
# jsonschema-cli - High-performance JSON Schema validator (Rust)
#
# Upstream: https://github.com/Stranger6667/jsonschema  (783+ stars, MIT)
# Author:   Dmitry Dygalo (@Stranger6667), with Schemathesis lineage
# Library:  jsonschema crate (the canonical high-perf Rust JSON Schema validator)
#
# Source-direct extraction from crates/jsonschema-cli/src/main.rs:
#   https://github.com/Stranger6667/jsonschema/blob/master/crates/jsonschema-cli/src/main.rs
#
# Drafts supported: 4 | 6 | 7 | 2019 (2019-09) | 2020 (2020-12).
# Sub-commands:     validate | bundle | dereference
# Output formats:   text | flag | list | hierarchical  (newline-delimited JSON records)

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_jsonschema_drafts() {
    local -a drafts
    drafts=(
        '4:JSON Schema Draft 4 (RFC: draft-zyp-json-schema-04)'
        '6:JSON Schema Draft 6'
        '7:JSON Schema Draft 7 (most widely deployed)'
        '2019:JSON Schema 2019-09'
        '2020:JSON Schema 2020-12 (current default for most validators)'
    )
    _describe -t drafts 'JSON Schema draft' drafts
}

_jsonschema_outputs() {
    local -a outs
    outs=(
        'text:human-readable text output (default)'
        'flag:single boolean "valid: true|false" record'
        'list:flat list of validation errors'
        'hierarchical:tree-shaped error report mirroring schema structure'
    )
    _describe -t outputs 'output style' outs
}

_jsonschema_http_args() {
    _arguments \
        '--connect-timeout=[timeout for establishing connections, in seconds]:seconds:' \
        '--timeout=[total HTTP request timeout, in seconds]:seconds:' \
        '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification (dangerous)]' \
        '--cacert=[path to a custom CA certificate (PEM format)]:cacert:_files -g "*.(pem|crt|cer|ca-bundle)"'
}

_jsonschema_cli_subcommands() {
    local -a subs
    subs=(
        'validate:validate JSON instances against a JSON Schema'
        'bundle:bundle a JSON Schema into a Compound Schema Document (2020-12)'
        'dereference:dereference a JSON Schema, inlining all $ref targets'
    )
    _describe -t subcommands 'jsonschema sub-command' subs
}

_arguments -C \
    '(- *)'{-v,--version}'[print jsonschema-cli version and exit]' \
    '(- *)'{-h,--help}'[print help and exit]' \
    '1: :_jsonschema_cli_subcommands' \
    '*::arg:->subcommand_args' \
    && ret=0

case $state in
    subcommand_args)
        case $line[1] in
            validate)
                _arguments -C \
                    '(-i --instance)'{-i,--instance}'+[path(s) to JSON instance file(s); accepts multiple values]:*:instances:_files -g "*.(json|yaml|yml)"' \
                    '(-d --draft)'{-d,--draft}'+[enforce a specific JSON Schema draft]:draft:_jsonschema_drafts' \
                    '(--assert-format --no-assert-format)--assert-format[turn ON format keyword validation]' \
                    '(--assert-format --no-assert-format)--no-assert-format[turn OFF format keyword validation]' \
                    '--output=[output style]:output style:_jsonschema_outputs' \
                    '--errors-only[only emit validation errors, suppress success records]' \
                    '--connect-timeout=[timeout for establishing connections, in seconds]:seconds:' \
                    '--timeout=[total HTTP request timeout, in seconds]:seconds:' \
                    '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification (dangerous)]' \
                    '--cacert=[path to a custom CA certificate (PEM format)]:cacert:_files -g "*.(pem|crt|cer|ca-bundle)"' \
                    '1:schema:_files -g "*.(json|yaml|yml)"' \
                    && ret=0
                ;;
            bundle)
                _arguments -C \
                    '*--resource=[register external schema resource as URI=FILE; repeatable]:URI=FILE:' \
                    '(-o --output)'{-o,--output}'+[write bundled output to FILE instead of stdout]:output file:_files' \
                    '--connect-timeout=[timeout for establishing connections, in seconds]:seconds:' \
                    '--timeout=[total HTTP request timeout, in seconds]:seconds:' \
                    '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification (dangerous)]' \
                    '--cacert=[path to a custom CA certificate (PEM format)]:cacert:_files -g "*.(pem|crt|cer|ca-bundle)"' \
                    '1:root schema:_files -g "*.(json|yaml|yml)"' \
                    && ret=0
                ;;
            dereference)
                _arguments -C \
                    '*--resource=[register external schema resource as URI=FILE; repeatable]:URI=FILE:' \
                    '(-o --output)'{-o,--output}'+[write dereferenced output to FILE instead of stdout]:output file:_files' \
                    '--connect-timeout=[timeout for establishing connections, in seconds]:seconds:' \
                    '--timeout=[total HTTP request timeout, in seconds]:seconds:' \
                    '(-k --insecure)'{-k,--insecure}'[skip TLS certificate verification (dangerous)]' \
                    '--cacert=[path to a custom CA certificate (PEM format)]:cacert:_files -g "*.(pem|crt|cer|ca-bundle)"' \
                    '1:root schema:_files -g "*.(json|yaml|yml)"' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
