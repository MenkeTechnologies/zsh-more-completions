#compdef iecset
# Documentation: https://manpages.debian.org/iecset.1
# Source: alsa-utils — IEC958 (S/PDIF) status-bit setter / inspector.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D[device name of control to open]:device:' \
    '-c[card index to open (equivalent to -Dhw:N)]:card:' \
    '-n[IEC958 control element index]:index:' \
    '-x[dump status as AESx bytes]' \
    '-i[read command sequences from stdin (one per line)]' \
    '*:setting:' \
    && ret=0

return ret
