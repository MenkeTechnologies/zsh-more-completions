#compdef stdisco
# _stdisco — print / fake Syncthing local discovery announcements (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stdisco/main.go (stdlib flag).

_stdisco() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-all[print all received announcements (not just the first)]'
        '-fake[send fake announcements]'
        '-mc=[IPv6 multicast address]:addr:'
        '-bc=[IPv4 broadcast port]:port:'
    )
    _arguments -s $args
}

_stdisco "$@"
