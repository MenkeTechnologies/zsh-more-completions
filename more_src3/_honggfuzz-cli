#compdef honggfuzz-cli honggfuzz
# _honggfuzz-cli — Robert Swiecki honggfuzz security-oriented fuzzer CLI alias (google team, C); custom argparse
# upstream: https://github.com/google/honggfuzz

_honggfuzz-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i+[input dir]:dir:_files -/' \
        '--input=+[input dir]:dir:_files -/' \
        '-x+[no instrumentation]' \
        '--noinst[no instrumentation]' \
        '-Q[QEMU mode]' \
        '--keep_output[keep output]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[low level signals]' \
        '--no_random[no random]' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[timeout sec]:n:' \
        '-n+[thread count]:n:' \
        '--threads=+[thread count]:n:' \
        '-N+[mutations per run]:n:' \
        '--iterations=+[mutations per run]:n:' \
        '-Y+[crash log file]:file:_files' \
        '--logfile=+[crash log file]:file:_files' \
        '-l+[log level]:l:(0 1 2 3 4 5)' \
        '--loglevel=+[log level]:l:(0 1 2 3 4 5)' \
        '-e+[file extension]:str:' \
        '--extension=+[file extension]:str:' \
        '-z+[mutations ratio]:n:' \
        '--mutations=+[mutations ratio]:n:' \
        '-W+[output dir]:dir:_files -/' \
        '--workspace=+[output dir]:dir:_files -/' \
        '-d+[crash dir]:dir:_files -/' \
        '--crashdir=+[crash dir]:dir:_files -/' \
        '-F+[max file size kb]:n:' \
        '--max_file_size=+[max file size kb]:n:' \
        '-w+[dictionary file]:file:_files' \
        '--dict=+[dictionary file]:file:_files' \
        '-O[save oldfile]' \
        '--save_smaller[save oldfile]' \
        '-P[persistent fuzzing mode]' \
        '--persistent[persistent fuzzing mode]' \
        '-S[sanitizers mode]' \
        '--sanitizers[sanitizers mode]' \
        '-f+[fuzz file extension]:str:' \
        '--input_file_ext=+[fuzz file extension]:str:' \
        '-u+[socket fuzzer mode]' \
        '--socket_fuzzer[socket fuzzer mode]' \
        '-c+[netdriver mode]' \
        '--netdriver[netdriver mode]' \
        '--max_mutations=+[max mutations]:n:' \
        '*:target binary args:_files'
}

_honggfuzz-cli "$@"
