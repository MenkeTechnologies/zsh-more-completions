#compdef slinktool
# Documentation: https://github.com/EarthScope/slinktool
# Source: EarthScope/slinktool src/slinktool.c — SeedLink protocol client for real-time seismic data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '(- *)-h[show help]' \
    '*-v[verbose (stackable)]' \
    '-P[ping server, report ID, exit]' \
    '*-p[print packet details (stackable)]' \
    '-u[print unpacked samples of data packets]' \
    '-nd+[network re-connect delay (s, default 30)]:seconds:_default' \
    '-nt+[network timeout (s, default 600)]:seconds:_default' \
    '-k+[keepalive interval (seconds)]:seconds:_default' \
    '-x+[save/restore stream state file]:file[:int]:_default' \
    '-d[dial-up mode]' \
    '-b[batch mode]' \
    '-s+[stream selectors]:selectors:_default' \
    '-l+[stream list file]:file:_files' \
    '-S+[multi-station stream list]:streams:_default' \
    '-tw+[time window begin:[end]]:window:_default' \
    '-o+[write all records to file]:dumpfile:_files' \
    '-A+[custom archive file structure format]:format:_default' \
    '-SDS+[SDS archive directory]:dir:_directories' \
    '-BUD+[BUD archive directory]:dir:_directories' \
    '-i+[info request type]:type:(ID CAPABILITIES STATIONS STREAMS GAPS CONNECTIONS ALL)' \
    '-I[print formatted server id and version]' \
    '-L[print formatted station list]' \
    '-Q[print formatted stream list]' \
    '-G[print formatted gap list]' \
    '-C[print formatted connection list]' \
    '1:server[:port]:_default' \
    && ret=0

return ret
