#compdef xen-livepatch
# Documentation: https://github.com/xen-project/xen/blob/master/tools/misc/xen-livepatch.c
# Reference accessed: 2026-05-21
# Verified: upstream xen-livepatch.c subcommand table quoted from source.
# Global flag --force bypasses checks; apply/load support --nodeps.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'help:display help information'
  'list:list payloads uploaded and their status'
  'upload:upload a patch file with the specified name'
  'apply:apply a checked patch'
  'revert:deactivate an applied patch'
  'replace:apply patch and revert all others'
  'unload:remove a patch from memory'
  'load:upload and apply a patch in one step'
)
_arguments -C \
  '--force[bypass some checks]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'xen-livepatch command' commands && ret=0 ;;
  args)
    case $line[1] in
      apply|load)
        _arguments \
          '--nodeps[disable inter-module buildid dependency check]' \
          '*:file:_files' && ret=0
        ;;
      *) _files && ret=0 ;;
    esac
    ;;
esac
return ret
