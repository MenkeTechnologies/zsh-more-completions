#compdef hakcc
# _hakcc — hakluke hakcc CLI fast minimal IP country-code resolution utility written in Go reading IPv4 IPv6 on stdin emitting per-host two-letter ISO 3166 country code by querying MaxMind GeoLite2 mmdb databases offline for bug-bounty recon geographic-filtering enumeration pipelines (hakluke team, Go); pflag
# upstream: https://github.com/hakluke/hakcc

_hakcc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[database]:file:_files -g "*.mmdb"' \
        '--db=+[mmdb]:file:_files -g "*.mmdb"' \
        '-c+[country filter]:str:' \
        '--country=+[code]:str:' \
        '-X+[exclude country]:str:' \
        '--exclude=+[code]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '*:input file:_files'
}

_hakcc "$@"
