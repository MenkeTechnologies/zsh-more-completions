#compdef jenkins-cli
# Documentation: https://www.jenkins.io/doc/book/managing/cli/
# Reference accessed: 2026-05-17
# Verified: Jenkins jenkins-cli.jar upstream — global flags
# (-s URL, -webSocket, -http, -ssh, -auth USER:TOKEN, -user,
# -i SSH-key, -noCertificateCheck, -noKeyAuth, -logger FINE) and
# canonical built-in subcommands (help, version, who-am-i,
# list-jobs, list-plugins, install-plugin, safe-restart,
# safe-shutdown, build, console, get-job, update-job, create-job,
# delete-job, copy-job, disable-job, enable-job, groovy, groovysh,
# reload-configuration, etc.). Subcommand set is server-defined and
# can be extended by plugins.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:show available commands'
  'version:show Jenkins version'
  'who-am-i:report current authentication'
  'login:save credentials for later commands'
  'logout:clear saved credentials'
  'build:build a job'
  'console:show console output of a build'
  'list-jobs:list jobs in a view or folder'
  'get-job:dump job XML config'
  'create-job:create a job from XML stdin'
  'update-job:update a job from XML stdin'
  'delete-job:delete a job'
  'enable-job:enable a job'
  'disable-job:disable a job'
  'copy-job:copy a job'
  'install-plugin:install a plugin'
  'list-plugins:list installed plugins'
  'install-tool:install a tool'
  'restart:restart Jenkins'
  'safe-restart:safely restart Jenkins'
  'shutdown:shut down Jenkins'
  'safe-shutdown:safely shut down Jenkins'
  'reload-configuration:reload configuration from disk'
  'get-node:dump node XML config'
  'list-nodes:list configured nodes'
  'create-node:create a node from XML stdin'
  'update-node:update a node from XML stdin'
  'delete-node:delete a node'
  'online-node:bring a node online'
  'offline-node:take a node offline'
  'wait-node-online:wait for a node to come online'
  'wait-node-offline:wait for a node to go offline'
  'list-changes:list changes in builds'
  'set-build-description:set build description'
  'set-build-display-name:set build display name'
  'mail:send mail'
  'groovy:run a Groovy script'
  'groovysh:start a Groovy shell'
  'run-cli:run a CLI command from a script'
)

_arguments -C \
  '(- *)--help[show help]' \
  '-s=[Jenkins server URL]:url:' \
  '-webSocket[use WebSocket transport]' \
  '-http[use HTTP transport]' \
  '-ssh[use SSH transport]' \
  '-auth=[username:apitoken auth]:auth:' \
  '-user=[username]:user:_users' \
  '-i=[SSH identity]:file:_files' \
  '-noCertificateCheck[skip TLS certificate check]' \
  '-noKeyAuth[disable SSH key auth]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'jenkins-cli subcommand' subcommands && ret=0
    ;;
esac

return ret
