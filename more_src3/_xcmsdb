#compdef xcmsdb
# Documentation: man xcmsdb (X.Org)
# Source: Xlib Color Management System device-profile-DB loader/query tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '(-query -remove)-query[print current screen-color-characterization data]' \
    '(-query -remove)-remove[remove SCCD properties]' \
    '-format+[data property format]:bits:(32 16 8)' \
    '1:scc file:_files' \
    && ret=0

return ret
