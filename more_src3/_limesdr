#compdef LimeSuite LimeUtil LimeQuickTest limesdr limesdr-cli LimeSDR
# _limesdr — Lime Microsystems LimeSDR LimeSuite CLI tools for the LimeSDR open SDR board family LMS7002M chipset (myriadrf team, C++); custom argparse
# upstream: https://github.com/myriadrf/LimeSuite

_limesdr() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--find[find connected devices]' \
        '--info[show device info]' \
        '--check[run device check]' \
        '--test[run loopback tests]' \
        '--update[update firmware/gateware]' \
        '--list[list devices]' \
        '--rescan[force re-enumeration]' \
        '--device=+[device handle]:str:' \
        '-d+[device handle]:str:' \
        '--fpga=+[fpga image]:file:_files -g "*.rbf *.svf"' \
        '--firmware=+[firmware image]:file:_files -g "*.upd *.img *.bin"' \
        '--frequency=+[Hz]:n:' \
        '-f+[Hz]:n:' \
        '--rate=+[Hz]:n:' \
        '--rate-rx=+[Hz]:n:' \
        '--rate-tx=+[Hz]:n:' \
        '--channel=+[N]:n:' \
        '--gain=+[dB]:f:' \
        '--gain-rx=+[dB]:f:' \
        '--gain-tx=+[dB]:f:' \
        '--bandwidth=+[Hz]:n:' \
        '--lo=+[Hz]:n:' \
        '--samples=+[N]:n:' \
        '-n+[N]:n:' \
        '--rxgain=+[dB]:f:' \
        '--txgain=+[dB]:f:' \
        '--mode=+[mode]:m:(rx tx duplex)' \
        '--ini=+[ini config]:file:_files -g "*.ini"' \
        '*:input file or command:_files'
}

_limesdr "$@"
