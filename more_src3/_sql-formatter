#compdef sql-formatter
# Documentation: https://github.com/sql-formatter-org/sql-formatter
# Reference accessed: 2026-05-21
# Verified: README CLI section (supported languages, options).

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--fix[update file in-place]' \
  '(-l --language)'{-l+,--language=}'[SQL dialect]:dialect:(bigquery clickhouse db2 db2i hive mariadb mysql n1ql plsql postgresql redshift singlestoredb snowflake spark sql sqlite tidb trino transactsql tsql)' \
  '(-c --config)'{-c+,--config=}'[config JSON file or JSON string]:config:' \
  ':input file:_files -g "*.sql"'
