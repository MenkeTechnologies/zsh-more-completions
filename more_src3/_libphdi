#compdef phdiinfo phdimount
# _libphdi — libphdi tools (libyal Parallels HDD virtual-disk parser; phdiinfo prints Parallels disk metadata + per-snapshot info, phdimount FUSE-mounts the disk read-only; -h help, -V version, -v verbose, -o image offset, -p password, -X exclusive; positional argument is the .hdd directory's DiskDescriptor.xml or HDS image)
# upstream: https://github.com/libyal/libphdi
# Flags from libyal/libphdi phditools/phdiinfo.c on tip.

_libphdi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-X[exclusive]' \
        '*:HDD image:_files'
}

_libphdi "$@"
