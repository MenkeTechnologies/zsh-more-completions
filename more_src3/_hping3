#compdef hping3 hping
# Documentation: hping3 --help
# Source: TCP/IP packet assembler/analyser (ping-like for arbitrary packets).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-c --count)'{-c+,--count=}'[packet count]:n:' \
    '(-i --interval)'{-i+,--interval=}'[interval (uX for microseconds)]:interval:' \
    '--fast[10 packets per second]' \
    '--faster[100 packets per second]' \
    '--flood[send as fast as possible (no replies)]' \
    '(-n --numeric)'{-n,--numeric}'[numeric output]' \
    '(-q --quiet)'{-q,--quiet}'[quiet output]' \
    '(-I --interface)'{-I+,--interface=}'[interface name]:iface:' \
    '(-V --verbose)'{-V,--verbose}'[verbose mode]' \
    '(-D --debug)'{-D,--debug}'[debugging info]' \
    '(-z --bind -Z --unbind)'{-z,--bind}'[bind ctrl+z to ttl]' \
    '(-z --bind -Z --unbind)'{-Z,--unbind}'[unbind ctrl+z]' \
    '--beep[beep on every matching reply]' \
    '(-0 --rawip -1 --icmp -2 --udp -8 --scan -9 --listen)'{-0,--rawip}'[raw IP mode]' \
    '(-0 --rawip -1 --icmp -2 --udp -8 --scan -9 --listen)'{-1,--icmp}'[ICMP mode]' \
    '(-0 --rawip -1 --icmp -2 --udp -8 --scan -9 --listen)'{-2,--udp}'[UDP mode]' \
    '(-0 --rawip -1 --icmp -2 --udp -8 --scan -9 --listen)'{-8,--scan}'[scan mode]' \
    '(-0 --rawip -1 --icmp -2 --udp -8 --scan -9 --listen)'{-9,--listen}'[listen mode]' \
    '(-a --spoof)'{-a+,--spoof=}'[spoof source address]:addr:' \
    '--rand-dest[random destination address]' \
    '--rand-source[random source address]' \
    '(-t --ttl)'{-t+,--ttl=}'[TTL (default 64)]:n:' \
    '(-N --id)'{-N+,--id=}'[IP id (default random)]:n:' \
    '(-W --winid)'{-W,--winid}'[use win* id byte ordering]' \
    '(-r --rel)'{-r,--rel}'[relativize id field]' \
    '(-f --frag)'{-f,--frag}'[split packets into more fragments]' \
    '(-x --morefrag)'{-x,--morefrag}'[set more-fragments flag]' \
    '(-y --dontfrag)'{-y,--dontfrag}'[set dont-fragment flag]' \
    '(-g --fragoff)'{-g+,--fragoff=}'[fragment offset]:n:' \
    '(-m --mtu)'{-m+,--mtu=}'[virtual MTU]:n:' \
    '(-o --tos)'{-o+,--tos=}'[type of service]:tos:' \
    '(-G --rroute)'{-G,--rroute}'[include RECORD_ROUTE option]' \
    '--lsrr[loose source routing and record route]' \
    '--ssrr[strict source routing and record route]' \
    '(-H --ipproto)'{-H+,--ipproto=}'[IP protocol field (raw IP)]:n:' \
    '(-C --icmptype)'{-C+,--icmptype=}'[ICMP type (default echo)]:n:' \
    '(-K --icmpcode)'{-K+,--icmpcode=}'[ICMP code]:n:' \
    '--force-icmp[send all ICMP types]' \
    '--icmp-gw=[gateway for ICMP redirect]:addr:' \
    '--icmp-ts[ICMP timestamp (type 13)]' \
    '--icmp-addr[ICMP address subnet mask (type 17)]' \
    '--icmp-help[ICMP-options help]' \
    '(-s --baseport)'{-s+,--baseport=}'[base source port]:port:' \
    '(-p --destport)'{-p+,--destport=}'[destination port]:port:' \
    '(-k --keep)'{-k,--keep}'[keep source port still]' \
    '(-w --win)'{-w+,--win=}'[TCP window size]:n:' \
    '(-O --tcpoff)'{-O+,--tcpoff=}'[fake TCP data offset]:n:' \
    '(-Q --seqnum)'{-Q,--seqnum}'[show only TCP seqnum]' \
    '(-b --badcksum)'{-b,--badcksum}'[send packets with bad IP checksum]' \
    '(-M --setseq)'{-M+,--setseq=}'[set TCP sequence number]:n:' \
    '(-L --setack)'{-L+,--setack=}'[set TCP ack]:n:' \
    '(-F --fin)'{-F,--fin}'[set FIN flag]' \
    '(-S --syn)'{-S,--syn}'[set SYN flag]' \
    '(-R --rst)'{-R,--rst}'[set RST flag]' \
    '(-P --push)'{-P,--push}'[set PUSH flag]' \
    '(-A --ack)'{-A,--ack}'[set ACK flag]' \
    '(-U --urg)'{-U,--urg}'[set URG flag]' \
    '(-X --xmas)'{-X,--xmas}'[set X unused flag (0x40)]' \
    '(-Y --ymas)'{-Y,--ymas}'[set Y unused flag (0x80)]' \
    '--tcpexitcode[use last tcp->th_flags as exit code]' \
    '--tcp-timestamp[enable TCP timestamp option]' \
    '(-d --data)'{-d+,--data=}'[data size]:bytes:' \
    '(-E --file)'{-E+,--file=}'[read data from file]:file:_files' \
    '(-e --sign)'{-e+,--sign=}'[add signature]:sig:' \
    '(-j --dump)'{-j,--dump}'[dump packets in hex]' \
    '(-J --print)'{-J,--print}'[dump printable characters]' \
    '(-B --safe)'{-B,--safe}'[enable safe protocol]' \
    '(-u --end)'{-u,--end}'[exit when file reaches EOF]' \
    '(-T --traceroute)'{-T,--traceroute}'[traceroute mode]' \
    '--tr-stop[exit on first non-ICMP in traceroute]' \
    '--tr-keep-ttl[keep TTL fixed in traceroute]' \
    '--tr-no-rtt[no RTT info in traceroute]' \
    '--apd-send[send packet described in APD]' \
    '1:host:_hosts' \
    && ret=0

return ret
