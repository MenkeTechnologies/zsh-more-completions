#compdef imhex
# Documentation: https://github.com/WerWolv/ImHex
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ImHex hex editor — subcommands registered via plugins/builtin command_line_interface.cpp.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show available subcommands]' \
  '(- *)'{-v,--version}'[show version]' \
  '--open=[open file(s) in the editor]:file:_files' \
  '--new[create a new file/window]' \
  '--select=[select address range (start[:end])]:range:' \
  '--pattern=[run pattern language code or .hexpat file]:pattern:_files -g "*.hexpat"' \
  '--calc=[evaluate mathematical expression]:expression:' \
  '--plugins[list loaded plugins or add plugin path]' \
  '--language=[set UI language]:language:' \
  '--verbose[enable debug logging]' \
  '--hash=[compute file hash]:algorithm:(md5 sha1 sha224 sha256 sha384 sha512)' \
  '--encode=[encode string]:algorithm:(base64 hex)' \
  '--decode=[decode string]:algorithm:(base64 hex)' \
  '--magic=[identify file type]:operation:(mime desc)' \
  '--hexdump=[generate hex view of file]:file:_files' \
  '--demangle=[demangle C++ identifier]:symbol:' \
  '--settings-reset[reset all settings to defaults]' \
  '--debug-mode[enable debug mode]' \
  '--validate-plugin=[validate plugin integrity]:plugin:_files' \
  '--save-editor=[load save editor from file or gist]:source:' \
  '--file-info=[display detailed file information]:file:_files' \
  '*:file:_files' && ret=0

return ret
