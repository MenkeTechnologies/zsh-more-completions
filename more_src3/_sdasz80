#compdef sdasz80
# Documentation: https://sourceforge.net/p/sdcc/code/HEAD/tree/trunk/sdcc/sdas/asxxsrc/asmain.c
# Reference accessed: 2026-05-21
# Verified: asmain.c case statements for option parsing (sdas/asxxxx assembler
# shared core used by sdasz80, sdas8051, etc.).
# Removed from prior file: -D[define symbol] (real meaning: decimal listing
# format), -x[hex octal binary listings] (only sets hex listing; binary is -b
# and octal is -q), and the implicit "include dir takes an argument" form for
# -I (real syntax accepts the path appended directly).

# sdasz80: SDCC Z80 assembler (asxxxx-derived)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-H[show help]' \
  '-l[create listing file]' \
  '-o[create object/relocatable file]' \
  '-s[create symbol table file]' \
  '-d[decimal listing]' \
  '-q[octal listing]' \
  '-x[hexadecimal listing (default)]' \
  '-b[display .define substitutions in listing]' \
  '-c[disable instruction cycle counts]' \
  '-f[flag relocatable references in listing]' \
  '-p[disable automatic pagination]' \
  '-u[disable .list/.nlist processing]' \
  '-w[wide listing format]' \
  '-a[make all symbols global]' \
  '-g[make undefined symbols global]' \
  '-N[do not resolve global assigned values]' \
  '-z[disable case sensitivity]' \
  '-v[enable out-of-range signed/unsigned errors]' \
  '-j[enable NoICE debug symbols]' \
  '-y[enable SDCC debug symbols]' \
  '-I[add directory to include search path]:dir:_files -/' \
  '-t[show diagnostic information]' \
  '*:source file:_files -g "*.(asm|s|S)"' && ret=0
return ret
