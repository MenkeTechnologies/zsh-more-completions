#compdef zathura
# Documentation: https://man.archlinux.org/man/zathura.1
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus search URL and fabricated short-flag
# mapping (-e was not "synctex-editor-command" upstream, -w is not
# "password-file", --password upstream takes value via -w).
# Added verified: --synctex-forward, --synctex-pid, -e --reparent.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  {-e,--reparent=}'[reparent to specified window]:xid:' \
  {-c,--config-dir=}'[path to config directory]:directory:_files -/' \
  {-d,--data-dir=}'[path to data directory]:directory:_files -/' \
  {-p,--plugins-dir=}'[path to plugins directory]:directory:_files -/' \
  '--fork[fork into background]' \
  {-l,--log-level=}'[set log level]:level:(debug info warning error)' \
  {-P,--page=}'[open at given page number]:page number:' \
  {-w,--password=}'[document password]:password:' \
  {-f,--find=}'[search for string upon opening]:search string:' \
  {-x,--synctex-editor-command=}'[SyncTeX editor command]:command:' \
  '--synctex-forward=[SyncTeX forward jump position]:input:' \
  '--synctex-pid=[target instance by PID]:pid:' \
  '--mode=[start in non-default mode]:mode:' \
  '*:document:_files -g "*.(#i)(pdf|ps|eps|djvu|djv|cb7|cbr|cbz|cbt)(-.)"' && ret=0

return ret
