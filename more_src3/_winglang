#compdef winglang wing-lang wingc
# _winglang — Monada Winglang wingc compiler binary form for the Wing cloud-oriented programming language (winglang team, Rust/TypeScript); custom argparse
# upstream: https://github.com/winglang/wing

_winglang() {
    local -a sub=(
        'new:scaffold a new Wing project'
        'init:initialize a new Wing project'
        'compile:compile a Wing program'
        'build:build a Wing program'
        'run:run a Wing program locally'
        'test:test a Wing program'
        'plugin:plugin subcommands'
        'lsp:run language server'
        'docs:open docs'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--target=+[target]:t:(tf-aws tf-azure tf-gcp sim awscdk-aws cdktf-aws platforms)' \
        '-t+[target]:t:(tf-aws tf-azure tf-gcp sim awscdk-aws cdktf-aws)' \
        '--platform=+[platform]:str:' \
        '-p+[platform]:str:' \
        '--plugins=+[plugins csv]:str:' \
        '--debug[debug logs]' \
        '-d[debug logs]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[disable color]' \
        '--output=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'winglang subcommand' sub ;;
        args)
            case $words[1] in
                new|init) _arguments \
                    '--template=+[template]:t:(empty hello sample chatbox app web)' \
                    '-t+[template]:t:(empty hello sample chatbox app web)' \
                    '--language=+[language]:l:(wing typescript)' \
                    '-l+[language]:l:(wing typescript)' \
                    '*:name:_files -/' ;;
                compile|build|run|test) _arguments \
                    '--target=+[target]:t:(tf-aws tf-azure tf-gcp sim awscdk-aws cdktf-aws)' \
                    '*:source:_files -g "*.w *.main.w *.test.w"' ;;
                plugin) _arguments '1:plugin cmd:(install list remove update)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_winglang "$@"
