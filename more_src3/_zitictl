#compdef zitictl
# _zitictl — NetFoundry OpenZiti zitictl tools for managing the zero-trust application networking platform (openziti team, Go); cobra
# upstream: https://github.com/openziti/ziti

_zitictl() {
    local -a sub=(
        'install:install ziti components'
        'install-controller:install controller'
        'install-router:install router'
        'install-edge-tunnel:install edge tunnel'
        'install-ziti-cli:install ziti CLI'
        'install-ziti-tunnel:install ziti-tunnel'
        'install-ziti-prox-c:install ziti-prox-c'
        'install-ziti-edge-tunnel:install edge tunnel'
        'create-controller-config:scaffold controller config'
        'create-router-config:scaffold router config'
        'init-controller:initialize controller PKI'
        'pki:pki subcommands'
        'identity:identity subcommands'
        'config:config subcommands'
        'service:service subcommands'
        'router:router subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--log-format=+[format]:f:(text json pfxlog)' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zitictl subcommand' sub ;;
        args)
            case $words[1] in
                pki) _arguments '1:pki cmd:(create init bundle list)' ;;
                identity) _arguments '1:identity cmd:(list create delete update show enroll)' ;;
                service) _arguments '1:service cmd:(list create delete update show)' ;;
                router) _arguments '1:router cmd:(list create delete update show enroll)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_zitictl "$@"
