#compdef updvitomp
# Documentation: updvitomp --help (3.00-0.04-u2.02 TeX Live 2026)
# Source: convert a TeX DVI file to a MetaPost MPX file (uplatex kanji-aware variant).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-progname=[set program name to STRING]:name:' \
    '-kanji=[kanji encoding]:encoding:(euc jis sjis utf8 uptex)' \
    '-kpathsea-debug=[set path searching debugging flags]:number:' \
    '1:dvi file:_files -g "*.dvi"' \
    '2:mpx output:_files -g "*.mpx"' \
    && ret=0

return ret
