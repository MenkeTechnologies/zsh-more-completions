#compdef iqtree2
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/iqtree2.1.html
# Reference accessed: 2026-05-19
# Verified: Ubuntu noble iqtree2(1) manpage.

# IQ-TREE 2: ML phylogenetic inference (long flags)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '-s[alignment file]:file:_files' \
  '--seqtype[sequence type]:type:(DNA AA BIN MORPH CODON NT2AA)' \
  '-p[edge-proportional partition file]:file:_files' \
  '-q[proportional partition file]:file:_files' \
  '-Q[separate edge-length partition file]:file:_files' \
  '-m[substitution model]:model:(JC HKY GTR WAG LG JTT MFP)' \
  '--mset[model selection set]:set:' \
  '--mrate[rate heterogeneity]:set:(E I G R)' \
  '--cmin[min rate categories]:n:' \
  '--cmax[max rate categories]:n:' \
  '--merit[model selection criterion]:crit:(AIC AICc BIC)' \
  '-B[ultrafast bootstrap replicates]:n:' \
  '--alrt[SH-aLRT replicates]:n:' \
  '--abayes[approximate Bayes test]' \
  '--lbp[local bootstrap]:n:' \
  '-b[non-parametric bootstrap replicates]:n:' \
  '--prefix[output prefix]:prefix:' \
  '--redo[redo all stages]' \
  '-T[CPU threads (AUTO)]:n:' \
  '--threads-max[max CPU threads]:n:' \
  '--seed[random seed]:n:' \
  '-z[user trees for topology tests]:file:_files' \
  '--zb[topology test bootstrap]:n:' \
  '--au[AU test]' \
  '-g[constraint tree]:file:_files' \
  '--ancestral[ancestral sequence reconstruction]' \
  '-t[starting tree]:file:_files' \
  '--tree-fix[fix tree for parameter estimation]:file:_files' \
  '-o[outgroup taxon]:taxon:' \
  '--keep-ident[keep identical sequences]' \
  '--symtest[symmetry tests]' \
  '*::files and options:_files' && ret=0
return ret
