#compdef sdc
# ============================================================================
#  _sdc — sdc: the Snazzy D Compiler — alternative D programming
#         language compiler with focus on faster build times +
#         improved error messages vs upstream DMD/LDC/GDC
#         (Amaury "deadalnix" Sechet — snazzy-d/sdc)
#
#  Source-direct extraction from
#    https://github.com/snazzy-d/sdc/blob/master/src/driver/sdc.d
#    https://dlang.org/phobos/std_getopt.html (D's stdlib
#    `std.getopt` module — D's official getopt-style arg parser)
#
#  Maintained by Amaury "deadalnix" Sechet (D Language Foundation
#  fellow, ex-Facebook compiler engineer, BCH/eCash Bitcoin Cash
#  protocol contributor).  270 GH stars.  SDC is the "Snazzy D
#  Compiler" — an INDEPENDENT implementation of D2 written FROM
#  SCRATCH in D itself (bootstrapped via DMD/LDC).  Focus: faster
#  compilation than mainline DMD, better error messages, and a
#  cleaner internal architecture (the front-end is reused by SDC's
#  own formatter `sdfmt` and unit-test runner `sdunit` shipped
#  alongside).  SDC uses LLVM as its code-generation backend (like
#  LDC but with a different front-end).  Not currently a drop-in
#  replacement for DMD/LDC for production D code — SDC is an
#  ongoing research/experimental compiler — but a working
#  alternative for the D2 language subset it implements.  Sister
#  tools: dmd (the reference D compiler — IN CORPUS via _dmd
#  + STOCK on some Linux distros), ldc2 (LLVM D compiler — IN
#  CORPUS via _ldc2), gdc (GCC D compiler — IN CORPUS via _gdc),
#  dub (D package manager — IN CORPUS via _dub), sdfmt (Snazzy D
#  Formatter — IN CORPUS via _sdfmt; sister tool to sdc), sdunit
#  (Snazzy D unit-test runner — shipped alongside sdc), dlang/
#  tools (ddemangle, etc. — IN CORPUS via _ddemangle).
#
#  CLI library taxonomy update: 1st D LANGUAGE CLI library —
#  D's STDLIB **std.getopt** (Phobos library).  D language now
#  has 1 documented CLI library — joins the cross-language
#  taxonomy as the 33rd documented language.  🎉 NEW LANGUAGE
#  entry — D joins alongside Rust, Go, TypeScript-Node, Python,
#  Ruby, Perl, Haskell, OCaml, Elixir, R, Bash, Deno, Lua, Scheme,
#  Clojure, Common Lisp, Racket, Crystal, Nim, Zig, Odin, V,
#  Mojo, Roc, Hare, Standard ML, Erlang, Pony, Prolog, Pike, F#,
#  Janet.
#
#  std.getopt (D Phobos) is D's OFFICIAL standard-library argv
#  parser, shipped in Phobos (D's stdlib).  Distinctive philosophy:
#  REFERENCE-BASED with PAIRS of (flag-spec, target-pointer) — the
#  caller passes a flat list of alternating SHORT+LONG flag spec
#  string AND POINTER to the target variable to bind the parsed
#  value into.  Used by every D CLI tool that doesn't reach for
#  a third-party library — including abraunegg/onedrive (OneDrive
#  Client for Linux 12,479 stars — IN CORPUS via _onedrive),
#  eBay/tsv-utils (eBay's TSV Utilities 1,479 stars — IN CORPUS
#  via _tsv-filter/_tsv-select/_tsv-summarize/etc.), snazzy-d/sdc
#  (270 stars), dlang/phobos (D's own stdlib unittests use it),
#  dlang/tools (ddemangle 207 stars — IN CORPUS via _ddemangle),
#  ldc-developers/ldc (LDC tools like timetrace2txt), funkwerk/
#  depend (D dependency tool 19 stars), CyberShadow/cirun, gdtk-uq/
#  gdtk (Gas Dynamics Toolkit — University of Queensland CFD
#  research code), and ESSENTIALLY EVERY D BINARY.  Like Go's
#  stdlib `flag`, Python's `argparse`, and Rust's `rust-lang/
#  getopts`, std.getopt is THE de-facto starting point for D CLI
#  development.
#
#  std.getopt API:
#    import std.getopt;
#
#    int main(string[] args) {
#      bool dbg = false;
#      bool inPlace = false;
#      string outputFile;
#      string[] includePaths;
#      int optLevel = 2;
#
#      // getopt() takes ARGS (string[]) and an interleaved list of
#      // (FLAG-SPEC, HELP-TEXT, TARGET-POINTER) triples.
#      // It MUTATES `args` to remove parsed flags; remaining items
#      // are positional arguments.
#      auto helpInfo = getopt(
#        args,
#        std.getopt.config.caseSensitive,    // Modifier: case-sensitive flag matching
#        "I",         "Include path",        &includePaths,    // string[] → repeatable
#        "L",         "Library path",        &linkerPaths,
#        "O",         "Optimization level",  &optLevel,        // int → typed conversion
#        "c",         "Stop before linking", &dontLink,        // bool → flag presence
#        "o",         "Output file",         &outputFile,
#        "g",         "Generate source-level debug info", &debugBuild,
#        "emit-llvm", "Output LLVM bitcode",  &outputLLVM,
#        "main",      "Generate the main function", &generateMain,
#      );
#
#      if (helpInfo.helpWanted) {
#        defaultGetoptPrinter("My tool description.",
#                             helpInfo.options);
#        return 0;
#      }
#
#      // After getopt: `args` array now contains positional args
#      // (program name in args[0], remaining positionals in args[1..])
#      auto files = args[1 .. $];
#    }
#
#  std.getopt distinctive features:
#    - REFERENCE-BASED (pointer-driven) binding — `&variable`
#      pointers passed inline tell getopt where to STORE each
#      parsed value; no Optional<T> wrappers, no return-struct
#      indirection (caller provides variables of correct types
#      upfront)
#    - INTERLEAVED ARGUMENT LIST — pass alternating `(flag-spec,
#      help-text, target-pointer)` triples in ONE flat argument
#      list to getopt(); D's variadic templates make this safe
#      and type-checked at compile time
#    - FLAG-SPEC SYNTAX (compile-time string analysis):
#      * `"name"` — single-form flag; getopt auto-derives:
#        single-char → short flag `-x`, multi-char → long
#        `--name`; PLUS auto-allows --no-name for booleans
#      * `"n|name"` — explicit short+long pair
#      * `"name|n"` — same (order doesn't matter)
#      * Note: each non-bool flag also accepts `=VALUE` and
#        space-separated VALUE forms
#    - TYPED CONVERSION — the type of the TARGET variable
#      determines parsing: `bool` (flag presence), `int`/`uint`/
#      `long` (integer parse), `double`/`float` (float parse),
#      `string` (raw value), `T[]` (REPEATABLE — each occurrence
#      appends), `T[string]` (KEY=VALUE pairs into associative
#      array)
#    - CONFIG MODIFIERS interleaved as `std.getopt.config.X`
#      constants:
#      * `config.caseSensitive` — case-sensitive flag matching
#      * `config.caseInsensitive` — DEFAULT (D historically prefers
#        case-insensitive but most tools opt into caseSensitive)
#      * `config.bundling` — POSIX short-flag clustering (`-abc`
#        → `-a -b -c`); off by default
#      * `config.noBundling` — explicit disable
#      * `config.passThrough` — don't error on unrecognized flags
#      * `config.noPassThrough` — DEFAULT
#      * `config.required` — make subsequent flags required
#      * `config.optional` — DEFAULT
#      * `config.stopOnFirstNonOption` — POSIXLY_CORRECT mode
#    - `defaultGetoptPrinter(description, helpInfo.options)` —
#      auto-renders POSIX-style usage from the parsed options
#      struct (caller controls when to print)
#    - `helpInfo.helpWanted: bool` — true if -h/--help was seen
#      (getopt registers --help/-h automatically)
#    - `GetOptException` — thrown on parse failure (unrecognized
#      flag, value-conversion error, missing required value)
#    - MUTATES `args` IN PLACE — flags consumed are removed; what
#      remains is positionals (program name preserved in args[0])
#    - INSPIRED BY GNU getopt_long(3) — std.getopt brings the
#      same long/short flag duality but enriches with D's
#      type-system features (typed binding, variadic templates,
#      associative-array flags)
#  Distinct from other languages' stdlib argparse-style libraries:
#  Python argparse (Python), stdlib flag (Go), rust-lang/getopts
#  (Rust), Phobos std.getopt (D — this round), OCaml Arg, Haskell
#  System.Console.GetOpt, Ruby OptionParser, Perl Getopt::Long,
#  Java getopt-java, Janet spork/argparse, Janet spork/argparse,
#  Pike Getopt, Erlang argparse, Pony cli, etc.  D's std.getopt's
#  distinguishing feature vs other-language stdlibs: D's variadic
#  templates make it the ONLY stdlib argparse that uses INLINE
#  FLAG-SPEC + HELP-STRING + TARGET-POINTER TRIPLES in one
#  function call — Python's argparse uses sequential
#  `add_argument()` calls, Go's flag uses separate
#  `flag.StringVar`/`BoolVar` calls, Rust's getopts uses
#  `opts.optflag/optopt` chained calls, etc.  D collapses all of
#  these into a single typed variadic call to `getopt()`.  std.
#  getopt's approach: REFERENCE-BASED INTERLEAVED-TRIPLES with
#  `getopt(args, config, "spec1", "help1", &var1, "spec2",
#  "help2", &var2, ...)` variadic-template entry + COMPILE-TIME-
#  TYPED binding via target pointer type (bool/int/string/T[]/
#  T[string]) + `"name|n"` flag-spec syntax for short+long pairs
#  + `std.getopt.config.X` constants for case-sensitivity/
#  bundling/passThrough/required modifiers + AUTO --help/-h
#  registration + `defaultGetoptPrinter(description, helpInfo.
#  options)` auto-help renderer + `GetOptException` for parse
#  errors + MUTATES args IN PLACE (positionals remain) +
#  INSPIRED BY GNU getopt_long(3) enhanced with D's type system —
#  corpus's **first documented D CLI library**.  Brings cross-
#  language CLI library taxonomy variant count to 162; D joins as
#  the 33rd documented language alongside Rust, Go, TypeScript-
#  Node, Python, Ruby, Perl, Haskell, OCaml, Elixir, R, Bash,
#  Deno, Lua, Scheme, Clojure, Common Lisp, Racket, Crystal,
#  Nim, Zig, Odin, V, Mojo, Roc, Hare, Standard ML, Erlang,
#  Pony, Prolog, Pike, F#, Janet.
#
#  Surface (verbatim from `src/driver/sdc.d` std.getopt
#  registrations):
#
#  Usage:
#    sdc [options] <file.d>
#
#  Options:
#    -I <PATH>                      Include path (repeatable —
#                                   each -I appends; std.getopt
#                                   target type is string[])
#    -L <PATH>                      Library path (repeatable)
#    -O <LEVEL>                     Optimization level (int; e.g.
#                                   -O0, -O1, -O2, -O3)
#    -c                             Stop before linking (compile-
#                                   only, output object file)
#    -o <FILE>                      Output file
#    -g                             Generate source-level debug
#                                   information
#    -S                             Stop before assembling and
#                                   output assembly file
#        --emit-llvm                Output LLVM bitcode (when
#                                   combined with -c) or LLVM
#                                   assembly (when combined with -S)
#    --main                         Generate the main function
#                                   automatically (useful for
#                                   single-file programs without
#                                   explicit main)
#    -h, --help                     Show help (auto from std.getopt
#                                   via helpInfo.helpWanted +
#                                   defaultGetoptPrinter)
#
#  Positional:
#    <file.d>                       D source file(s) to compile
#                                   (multiple files allowed)
#
#  Examples:
#    sdc hello.d                                    # Compile to a.out
#    sdc -o myprog hello.d                          # Custom output name
#    sdc -c hello.d                                 # Compile-only (object file)
#    sdc -S hello.d                                 # Output assembly
#    sdc -c --emit-llvm hello.d                     # Output LLVM bitcode
#    sdc -S --emit-llvm hello.d                     # Output LLVM assembly text
#    sdc -O2 -g hello.d                             # Optimized + debug info
#    sdc -I./include -I/usr/include/d hello.d       # Multiple include paths
#    sdc -L./lib --main hello.d                     # Library path + auto main
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also std.getopt users):
#    - onedrive (IN CORPUS via _onedrive — abraunegg/onedrive
#      OneDrive Client for Linux 12,479 stars; uses std.getopt
#      in src/main.d; previously documented but std.getopt library
#      not formally entered into taxonomy)
#    - tsv-filter / tsv-select / tsv-summarize / tsv-utils-bench
#      (IN CORPUS — eBay's TSV Utilities 1,479 stars; multiple
#      binaries; uses std.getopt; previously documented)
#    - ddemangle (IN CORPUS via _ddemangle — dlang/tools demangler
#      207 stars; uses std.getopt)
#    - sdfmt (IN CORPUS via _sdfmt — Snazzy D Formatter sister tool
#      to sdc; uses std.getopt; previously documented)
#    - depend (funkwerk/depend 19 stars D dependency tool —
#      FUTURE candidate)
#    - cirun (CyberShadow/cirun 3 stars — too niche)
# ============================================================================

_sdc() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '*-I+[include path (repeatable)]:path:_directories' \
    '*-L+[library path (repeatable)]:path:_directories' \
    '-O+[optimization level]:level:(0 1 2 3)' \
    '-c[stop before linking (compile-only)]' \
    '-o+[output file]:file:_files' \
    '-g[generate source-level debug information]' \
    '-S[stop before assembling and output assembly file]' \
    '--emit-llvm[output LLVM bitcode (-c) or LLVM assembly (-S)]' \
    '--main[generate the main function automatically]' \
    '*:file:_files -g "*.d"'
}

_sdc "$@"
