#compdef wrap-and-sort
# Documentation: https://manpages.debian.org/wrap-and-sort
# Source: debian/devscripts scripts/wrap-and-sort — wrap/sort Debian control fields (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-a --wrap-always)'{-a,--wrap-always}'[always wrap lists]' \
    '(-s --short-indent)'{-s,--short-indent}'[indent wrapped lines by one space]' \
    '(-b --sort-binary-packages)'{-b,--sort-binary-packages}'[sort binary package paragraphs by name]' \
    '(-k --keep-first)'{-k,--keep-first}'[keep first binary package at top when sorting]' \
    '(-n --no-cleanup)'{-n,--no-cleanup}'[do not remove trailing whitespace]' \
    '(-t --trailing-comma)'{-t,--trailing-comma}'[add trailing comma]' \
    '(-d --debian-directory)'{-d+,--debian-directory=}'[debian directory location]:dir:_files -/' \
    '*'{-f+,--file=}'[wrap and sort only specified file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[print all files touched]' \
    '--max-line-length=-[max line length before wrapping]:n:_default' \
    '(-N --dry-run)'{-N,--dry-run}'[do not modify files; print would-modify list]' \
    && ret=0

return ret
