#compdef helm-dashboard
# helm-dashboard: Helm plugin for a GUI dashboard
# https://github.com/komodorio/helm-dashboard

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--port=[port to listen on]:port' \
  '--bind=[address to bind to]:address' \
  '--namespace=[Kubernetes namespace]:namespace:_guard "^-*" namespace' \
  '--no-browser[do not open browser automatically]' \
  '--verbose[enable verbose logging]' \
  '--devel[include development versions]' \
  '--local-chart=[path to local chart directory]:dir:_directories'
