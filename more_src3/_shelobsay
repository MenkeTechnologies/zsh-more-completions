#compdef shelobsay
# Documentation: https://github.com/ntucker/shelobsay
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--maxLength=[maximum line length]:n:' \
  '--help[show help]' \
  '--version[show version]' \
  '*:string:' && ret=0

return ret
