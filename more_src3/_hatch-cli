#compdef hatch-cli
# _hatch-cli — Hatch modern Python project manager CLI alias (PyPA, Python); click
# upstream: https://github.com/pypa/hatch

_hatch-cli() {
    local -a sub=(
        'build:build distributions'
        'clean:clean dist artifacts'
        'config:manage config'
        'dep:manage deps'
        'env:manage environments'
        'fmt:format code'
        'new:scaffold new project'
        'project:manage project metadata'
        'publish:publish to index'
        'python:manage python installations'
        'run:run command in env'
        'self:manage hatch itself'
        'shell:open shell in env'
        'status:show env status'
        'test:run tests'
        'version:show/bump version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--env=+[environment]:str:' \
        '-e+[environment]:str:' \
        '--project=+[project name]:str:' \
        '-p+[project name]:str:' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--color[force color]' \
        '--no-color[no color]' \
        '--interactive[interactive]' \
        '--no-interactive[no interactive]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hatch subcommand' sub ;;
        args)
            case $words[1] in
                env) _arguments \
                    '1:cmd:(create find prune remove run show)' \
                    '*:arg:' ;;
                version) _arguments \
                    '1:bump-type:(release dev rc minor major micro patch)' ;;
                run) _arguments \
                    '*:cmd:_command_names -e' ;;
                build) _arguments \
                    '--target=+[target]:t:(sdist wheel)' \
                    '-t+[target]:t:(sdist wheel)' \
                    '--clean[clean]' \
                    '-c[clean]' \
                    '--clean-hooks-after[clean hooks after]' \
                    '--hooks-only[hooks only]' \
                    '--no-hooks[no hooks]' ;;
                publish) _arguments \
                    '--repo=+[repo]:r:(main test)' \
                    '-r+[repo]:r:(main test)' \
                    '--user=+[user]:str:_users' \
                    '-u+[user]:str:_users' \
                    '--auth=+[auth token]:str:' \
                    '-a+[auth token]:str:' \
                    '*:file:_files' ;;
                python) _arguments \
                    '1:cmd:(install list show find remove update)' \
                    '*:arg:' ;;
                project) _arguments \
                    '1:cmd:(metadata)' \
                    '*:arg:' ;;
                shell) _arguments \
                    '1:env:' \
                    '2:cmd:_command_names -e' ;;
                new) _arguments \
                    '1:name:' \
                    '--init[in current dir]' \
                    '-i[in current dir]' \
                    '--cli[include cli]' ;;
                fmt) _arguments \
                    '--check[check format]' \
                    '--linter[only linter]' \
                    '--formatter[only formatter]' \
                    '--sync[sync config]' ;;
                test) _arguments \
                    '--all[all envs]' \
                    '-a[all envs]' \
                    '--cover[coverage]' \
                    '--show[show]' ;;
            esac
            ;;
    esac
}

_hatch-cli "$@"
