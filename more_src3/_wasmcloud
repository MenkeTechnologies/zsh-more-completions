#compdef wash
# Documentation: https://github.com/wasmCloud/wasmCloud (crates/wash/src/bin/wash.rs, release-1.9.x)
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_wash_commands() {
  local -a commands=(
    'app:Manage declarative applications and deployments (wadm)'
    'build:Build (and sign) a wasmCloud component or capability provider'
    'call:Invoke a component operation'
    'capture:Capture and replay invocations (experimental)'
    'claims:Generate and manage JWTs for wasmCloud components and capability providers'
    'config:Create configuration for components, capability providers and links'
    'ctx:Manage wasmCloud host configuration contexts'
    'completions:Generate shell completions'
    'dev:Start a developer loop'
    'down:Tear down a wasmCloud environment'
    'drain:Manage contents of local wasmCloud caches'
    'get:Get information about a running wasmCloud environment'
    'inspect:Inspect a wasmCloud component or capability provider for signing claims and interfaces'
    'keys:Generate and manage signing keys'
    'label:Label (or unlabel) a host'
    'link:Link one component to another on a set of interfaces'
    'new:Create a new project from a template'
    'par:Create, inspect, and modify capability provider archive files'
    'plugin:Manage wash plugins'
    'pull:Pull a wasmCloud artifact from an OCI registry'
    'push:Push a wasmCloud artifact to an OCI registry'
    'scale:Scale a component running in a host'
    'secrets:Manage secret references for components, capability providers and links'
    'spy:Spy on all invocations a component sends and receives'
    'start:Start a component or capability provider'
    'stop:Stop a component, capability provider, or host'
    'ui:Serve a web UI for wasmCloud'
    'up:Bootstrap a wasmCloud environment'
    'update:Update a component on a wasmCloud host'
    'wit:Manage WIT dependencies'
  )
  _describe -t commands 'wash command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(text json)' \
  '--experimental[enable experimental features]' \
  '--help-markdown[print help in markdown format]' \
  '1:command:_wash_commands' \
  '*::arg:->args' && ret=0

case "$state" in
  args)
    case "$words[1]" in
      up)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--detached[run in detached mode]' \
          '--host-seed=[host seed key]:seed' \
          '--rpc-host=[RPC host]:host' \
          '--rpc-port=[RPC port]:port' \
          '--rpc-timeout-ms=[RPC timeout in ms]:ms' \
          '--ctl-host=[control interface host]:host' \
          '--ctl-port=[control interface port]:port' \
          '--lattice=[lattice prefix]:lattice' \
          '--wasmcloud-version=[wasmCloud host version]:version' \
          '--nats-port=[NATS port]:port' \
          '--nats-websocket-port=[NATS WebSocket port]:port' \
          '--wadm-version=[wadm version]:version' \
          '--allowed-insecure=[comma-separated insecure registries]:list' \
          '--enable-structured-logging[enable structured logging]' \
          && ret=0
        ;;
      down)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all[stop all hosts]' \
          '--host-id=[host id to stop]:id' \
          '--lattice=[lattice prefix]:lattice' \
          && ret=0
        ;;
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--config-path=[path to wasmcloud.toml]:config:_files' \
          '--build-only[only build, do not sign]' \
          '--no-sign[do not sign]' \
          '--sign-only[only sign the artifact]' \
          '--skip-fetch[skip fetching dependencies]' \
          && ret=0
        ;;
      dev)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--host-seed=[host seed key]:seed' \
          '--nats-port=[NATS port]:port' \
          '--leave-host-running[leave the host running on exit]' \
          && ret=0
        ;;
      new)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--template-name=[template name]:template' \
          '--path=[output path]:path:_directories' \
          '1:subcommand:(component provider)' \
          '*:name' \
          && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--jwt-only[only show the JWT]' \
          '--wit[print the WIT interface]' \
          '*:file:_files' \
          && ret=0
        ;;
      completions)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell elvish)' \
          && ret=0
        ;;
      spy)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--ctl-host=[control interface host]:host' \
          '--ctl-port=[control interface port]:port' \
          '--lattice=[lattice prefix]:lattice' \
          '*:component-id' \
          && ret=0
        ;;
      ui)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port to serve on]:port' \
          && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
