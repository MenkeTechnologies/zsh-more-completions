#compdef hyperfetch
# _hyperfetch — hyperfetch system-info CLI in Rust producing colourful ASCII art system stats CPU GPU RAM disk uptime OS kernel desktop environment terminal shell similar to neofetch fastfetch with config TOML (hyperfetch team, Rust); clap
# upstream: https://github.com/hyperfetch/hyperfetch

_hyperfetch() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.toml *.yaml *.yml *.jsonc"' \
        '--config=+[config file]:file:_files -g "*.toml *.yaml *.yml *.jsonc"' \
        '-l+[logo file]:file:_files -g "*.txt *.ascii *.png *.svg"' \
        '--logo=+[logo file]:file:_files -g "*.txt *.ascii *.png *.svg"' \
        '-d+[distro]:d:(arch ubuntu debian fedora gentoo nixos alpine void manjaro endeavour rocky almalinux opensuse centos rhel pop_os mint elementary kali parrot crux slackware lfs windows macos freebsd openbsd netbsd dragonfly hyperbsd haiku android termux)' \
        '--distro=+[distro]:d:(arch ubuntu debian fedora gentoo nixos alpine void manjaro endeavour rocky almalinux opensuse centos rhel pop_os mint elementary kali parrot crux slackware lfs windows macos freebsd openbsd netbsd dragonfly hyperbsd haiku android termux)' \
        '-s+[structure]:str:' \
        '--structure=+[structure]:str:' \
        '--no-color[no color]' \
        '--no-logo[no logo]' \
        '--no-bar[no bar]' \
        '--no-shell[no shell]' \
        '--no-color-bar[no color bar]' \
        '--format=+[fmt]:f:(default compact full json yaml ascii)' \
        '--theme=+[theme]:str:' \
        '--config-create[create default config]' \
        '--config-print[print config path]' \
        '--list-modules[list modules]' \
        '--bench[benchmark]'
}

_hyperfetch "$@"
