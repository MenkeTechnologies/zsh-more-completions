#compdef kubectl-cnpg
# Documentation: https://cloudnative-pg.io/documentation/current/kubectl-plugin/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; subcommand list from
# cmd/kubectl-cnpg/main.go (cloudnative-pg/cloudnative-pg).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'backup:request an on-demand backup'
  'certificate:generate a TLS client certificate'
  'destroy:destroy an instance and its PVCs'
  'fence:fence/unfence an instance or cluster'
  'fio:run a fio storage benchmark'
  'hibernate:hibernate (suspend) a cluster'
  'install:generate the operator install manifest'
  'logs:collect/aggregate cluster pod logs'
  'maintenance:set or unset maintenance mode'
  'pgadmin:deploy pgAdmin (demo)'
  'pgbench:run pgbench against a cluster'
  'promote:promote a replica to primary'
  'psql:start an interactive psql session'
  'publication:manage logical replication publications'
  'reload:trigger a reconciliation/reload'
  'report:bundle a troubleshooting report'
  'restart:rollout restart a cluster or instance'
  'snapshot:take a consistent volume snapshot backup'
  'status:cluster health/replication overview'
  'subscription:manage logical replication subscriptions'
  'versions:print plugin and operator versions'
)

_arguments -C \
  '--color=[colorize output]:when:(always never auto)' \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kubectl-cnpg subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (status)
        _arguments \
          '*'{-v,--verbose}'[increase verbosity]' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(yaml json)' && ret=0
        ;;
      (certificate)
        _arguments \
          '--cnpg-cluster=[cluster]:cluster:' \
          '--cnpg-user=[user]:user:' && ret=0
        ;;
      (maintenance)
        _values 'maintenance action' 'set' 'unset' && ret=0
        ;;
      (report)
        _arguments -C \
          '1:report action:(operator cluster)' \
          '(-f --file)'{-f+,--file=}'[output file]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-S --stopRedaction)'{-S,--stopRedaction}'[disable redaction]' \
          '--logs[include logs]' && ret=0
        ;;
      (logs)
        _values 'logs action' 'cluster' 'pretty' && ret=0
        ;;
      (destroy)
        _arguments '--keep-pvc[keep PVCs]' && ret=0
        ;;
      (hibernate)
        _values 'hibernate action' 'on' 'off' 'status' && ret=0
        ;;
      (fence)
        _values 'fence action' 'on' 'off' && ret=0
        ;;
      (backup)
        _arguments \
          '(-m --method)'{-m+,--method=}'[backup method]:method:(volumeSnapshot barmanObjectStore plugin)' \
          '--backup-target=[backup target]:target:(primary prefer-standby)' \
          '--online[request an online (hot) backup]' \
          '--immediate-checkpoint[trigger an immediate checkpoint]' \
          '--wait-for-archive[wait for WAL archiving to complete]' && ret=0
        ;;
      (psql)
        _arguments '--replica[connect to a replica]' && ret=0
        ;;
      (pgadmin)
        _arguments \
          '--mode=[deployment mode]:mode:(desktop server)' \
          '--dry-run[print manifest without applying]' && ret=0
        ;;
      (publication)
        _values 'publication action' 'create' 'drop' && ret=0
        ;;
      (subscription)
        _values 'subscription action' 'create' 'drop' 'sync-sequences' && ret=0
        ;;
    esac
    ;;
esac

return ret
