#compdef lone lone-embed
# ============================================================================
# _lone — zsh completion for lone-lang/lone, "the standalone Linux Lisp",
#          a freestanding Lisp interpreter that runs directly on top of the
#          Linux kernel with full system-call support and ZERO dependencies
#          (not even the C standard library) — 181st programming language
#          entry, R999 TRIPLE-9 commit landmark.
#          Covers both binaries:
#            lone        — the interpreter (reads Lisp from stdin)
#            lone-embed  — the ELF segment embedder for shipping
#                          self-contained executable Lisp programs
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/lone-lang/lone
#   Maintainer : lone-lang  (matheusmoreira + contributors)
#   License    : AGPL-3.0
#   Stars      : 393
#   Language   : C  (freestanding — no libc, no dynamic linker;
#                   speaks raw Linux syscalls via per-architecture
#                   assembly entry points under source/lone/
#                   architecture/linux/)
#   Module     : lone  (the interpreter binary, built from
#                source/lone.c)
#   Binaries   : lone        (the interpreter)
#                lone-embed  (the ELF segment embedder, built
#                             from source/tools/lone-embed.c)
#   Module path: . :
#                ~/.lone/modules :
#                ~/.local/lib/lone/modules :
#                /usr/lib/lone/modules
#                (loaded in order in source/lone.c entry point;
#                 plus modules baked into the binary as embedded
#                 ELF PT_LONE segments via lone-embed)
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   lone is a freestanding Linux Lisp interpreter — it speaks the
#   raw Linux system-call ABI directly, with no libc, no dynamic
#   loader, and no link-time deps:
#
#     (import (lone) (linux system-call))
#     (system-call 'write 1 "Hello, world!" 13)
#
#   Data types: 56-bit signed integers, UTF-8 texts, byte buffers,
#   interned symbols, linked lists, contiguous vectors, hash
#   tables with prototypal inheritance, nil / true / false (no
#   floats yet).  Functions: lambdas + closures, variadic args,
#   FEXPR (un-evaluated arguments — pre-macro form), primitive
#   C-side builtins, generators with `yield`, and delimited
#   continuations.  Modules:  intrinsic modules `lone`, `math`,
#   `list`, `text`, `bytes`, `table`, `vector`, `linux`;
#   file-system module loading; ELF PT_LONE embedded segment
#   modules (so a single binary can ship its full module graph
#   pre-loaded — invoke `lone-embed` to bake them in).
#
#   The interpreter reads source from stdin; `lone < script.ln`
#   is the typical invocation pattern.  Self-contained executables
#   are built by appending the `null` module (the bootstrap entry
#   point) plus the rest of the program's modules into PT_LONE
#   ELF segments via `lone-embed`, after which the resulting
#   binary runs its baked-in Lisp on launch without reading
#   stdin.
#
# CLI ARGUMENT GRAMMAR  (verbatim from source/lone.c entry-point
#                       + source/tools/lone-embed.c argument
#                       parser; extracted via `gh api repos/lone-
#                       lang/lone/contents/source/...`)
#
#   lone < <SCRIPT>                  Interpret Lisp from stdin.
#                                    Module path roots searched
#                                    in order:
#                                      .
#                                      ~/.lone/modules
#                                      ~/.local/lib/lone/modules
#                                      /usr/lib/lone/modules
#                                    plus any modules pre-baked
#                                    into the binary as PT_LONE
#                                    embedded ELF segments via
#                                    lone-embed.
#
#                                    (no command-line flags
#                                    proper — environment is
#                                    consumed via the standard
#                                    Linux auxv / environ /
#                                    argv mechanism that lisp
#                                    code reads through the
#                                    `(linux)` intrinsic module's
#                                    `auxiliary-vector`,
#                                    `arguments`, and `environment`
#                                    builtins)
#
#   lone-embed <ELF-PATH> <SEGMENT-DATA-PATH>
#                                    Embed a binary blob of
#                                    pre-loaded lisp module
#                                    data into an existing ELF
#                                    executable as a PT_LONE
#                                    segment.  Exits with one of
#                                    the documented status codes
#                                    on malformed input
#                                    (`lone_tools_embed_exit_*`
#                                    constants in source/tools/
#                                    lone-embed.c):
#                                      8   invalid ELF
#                                      9   missing required
#                                          PT_NULL entry
#                                      10  multiple PT_PHDR
#                                          entries
#                                      11  load address
#                                          unaligned
#                                      12  incorrect load bias
#                                      250 overflow during
#                                          program-header-table
#                                          expansion
#
# LANGUAGE-CORPUS POSITION
#   Lone is the 181st programming language entry in this
#   completion corpus and the R999 TRIPLE-9 commit landmark.
#   It joins daslang (R992 180th — round-number 180th-language
#   milestone), Blaise (R988 179th), Fusion (R984 178th), Aver
#   (R980 177th — R980 round-number commit landmark), Raven
#   (R976 176th), HydraScript (R972 175th), Lazurite (R968
#   174th), duck-lang (R964 173rd), Rascal (R960 172nd — R960
#   round-number commit landmark), Ixion (R956 171st),
#   KernelScript (R952 170th — round-number 170th-language
#   milestone), Prog8 (R948 169th), Objeck (R944 168th), Feral
#   (R940 167th — R940 round-number commit landmark), Biscuit/
#   BL (R936 166th), Rux (R932 165th), Jule (R928 164th),
#   Nevalang (R924 163rd), Corvid (R920 162nd — round-number
#   R920 commit landmark), Soppo (R916 161st), Cyrus (R912
#   160th — round-number language milestone), Lumina (R908
#   159th), Penne (R904 158th), EndBASIC (R900 157th — R900
#   prior TRIPLE-9 commit landmark), goboscript (R896 156th),
#   Alan (R892 155th), Mech (R888 154th — triple-8 landmark),
#   Lisette (R884 153rd), Bril (R880 152nd), Vyxal (R876
#   151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th),
#   Mochi (R860 147th), Oden (R856 146th), Hop (R852 145th),
#   Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th),
#   Acton (R816 136th), and Stanza (R812 135th).
#
#   Verified via:
#     gh api repos/lone-lang/lone/contents/README.md
#       → "Lone is a freestanding Lisp interpreter designed to
#          run directly on top of the Linux kernel with full
#          support for Linux system calls."
#       → "It has zero dependencies, not even the C standard
#          library."
#       → intrinsic modules: lone, math, list, text, bytes,
#                              table, vector, linux
#       → embedded ELF segment module loading
#     gh api repos/lone-lang/lone/contents/source/lone.c
#       → entry point: long lone(int argc, char **argv, char
#                                 **envp, struct lone_auxiliary_
#                                 vector *auxv)
#       → module path: . / ~/.lone/modules / ~/.local/lib/lone/
#                       modules / /usr/lib/lone/modules
#       → lone_lisp_module_load_null_from_standard_input(&lone)
#     gh api repos/lone-lang/lone/contents/source/tools/lone-
#         embed.c
#       → if (argc <= 2) { linux_exit(1); }
#       → open_files(&elf, argv[1], argv[2])
#       → exit-code constants 8, 9, 10, 11, 12, 250
#
#   No completion for `lone` or `lone-embed` ships with Apple
#   zsh (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_lone() {
    case "${service:-${words[1]}}" in
        lone-embed)
            _arguments \
                '1:target ELF executable:_files' \
                '2:segment data path (lisp module blob):_files' ;;
        lone|*)
            _arguments \
                '*:Lone Lisp script (typically piped to stdin):_files' ;;
    esac
}

_lone "$@"
