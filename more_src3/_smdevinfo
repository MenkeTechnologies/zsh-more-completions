#compdef smdevinfo
# Documentation: https://github.com/libyal/libsmdev
# Source: libyal/libsmdev manuals/smdevinfo.1 — display info about Storage Media Devices (raw disk / device files).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-i[ignore data file(s)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:device or image:_files' \
    && ret=0

return ret
