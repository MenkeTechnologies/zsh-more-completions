#compdef liquidwar
# Documentation: https://manpages.debian.org/bookworm/liquidwar/liquidwar.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm liquidwar(6) manpage OPTIONS sections
# Note: classic Liquid War 5 uses single-dash flags (not GNU long form). The
# prior version of this file used "--fullscreen", "--windowed", "--width",
# "--height", "--no-sound", "--debug" — none of those exist; replaced with
# the real flag set below.

# Liquid War 5: 2D real-time fluid combat
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[print version and exit]' \
  '-h[print copyright info and exit]' \
  '-cfg[config file path]:file:_files' \
  '-dat[data path]:dir:_files -/' \
  '-map[map path]:path:_files' \
  '-tex[texture path]:path:_files' \
  '-mid[music path]:path:_files' \
  '-server[server config]:path:_files' \
  '-mapgen[map generator path]:path:_files' \
  '-vga[force VGA mode (320x200)]' \
  '-no400300[do not use 400x300 mode]' \
  '-silent[no audio output]' \
  '-nowater[disable water rendering]' \
  '-nosfx[disable sound effects]' \
  '-nomusic[disable music]' \
  '-mem[print memory diagnostics]' \
  '-nojoy[disable joystick]' \
  '-noback[disable background]' \
  '-notex[disable textures]' \
  '-auto[autotest mode]' \
  '-safe[safe-graphic-mode]' \
  '-nice[run niced]' \
  '-check[run a self check]' \
  '-stop[stop on completion]' \
  '-c[(short option from troubleshooting set)]' \
  '-netlog[enable network log]' \
  '-n[number of players in server (2-6)]:n:(2 3 4 5 6)' \
  '-lag[network lag setting]:ms:' \
  '-port[server port]:port:' \
  '-log[server log file]:file:_files' \
  '-public[make server public on metaserver]' \
  '-private[hide server from metaserver]' \
  '-comment[server comment]:text:' \
  '-password[server password]:pass:' \
  '-callback[callback option]:value:' \
  '-metaserver[metaserver URL]:url:' \
  '-nobeep[no console beep]' \
  '-capture[screen capture]' \
  '-tombola[tombola mode]' \
  '*::extra args:_files' && ret=0
return ret
