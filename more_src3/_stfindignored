#compdef stfindignored
# _stfindignored — find files ignored by Syncthing patterns (syncthing/syncthing)
# upstream: https://github.com/syncthing/syncthing
# Flags from cmd/dev/stfindignored/main.go (stdlib flag).

_stfindignored() {
    _arguments \
        '(- *)-h[show help]' \
        '1:root directory:_files -/'
}

_stfindignored "$@"
