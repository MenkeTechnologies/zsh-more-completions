#compdef kernel-install
# Documentation: https://man7.org/linux/man-pages/man8/kernel-install.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kernel-install (add/remove kernels to/from the boot loader)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'add:Add a new kernel to the boot loader'
  'add-all:Add all installed kernels to the boot loader'
  'remove:Remove a kernel from the boot loader'
  'inspect:Print details about the kernel-install setup'
  'list:List installed kernels'
)

_arguments -s -S -C \
  '--esp-path=[Set the EFI System Partition path]:path:_files -/' \
  '--boot-path=[Set the Extended Boot Loader partition path]:path:_files -/' \
  '--make-entry-directory=[Create the entry directory]:option:(yes no auto)' \
  '--entry-type=[Boot entry type]:type:(type1 type2 all)' \
  '--entry-token=[Specify the entry token]:token:' \
  '(-v --verbose)'{-v,--verbose}'[Increase verbosity]' \
  '--root=[Set the root directory]:root:_files -/' \
  '--image=[Operate on disk image or block device]:image:_files' \
  '--image-policy=[Disk image policy]:policy:' \
  '--json=[JSON output mode]:mode:(short pretty off)' \
  '--no-pager[Do not pipe output into a pager]' \
  '--no-legend[Do not print column headers or footers]' \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)--version[Show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'kernel-install command' commands && ret=0
    ;;
  args)
    case $words[1] in
      add)
        _arguments \
          '1:kernel version' \
          '2:kernel image:_files' \
          '*:initrd:_files' && ret=0
        ;;
      remove)
        _arguments \
          '1:kernel version' && ret=0
        ;;
    esac
    ;;
esac

return ret
