#compdef kallisto
# Documentation: https://pachterlab.github.io/kallisto/manual
# Reference accessed: 2026-05-19
# Verified: upstream manual at the URL above.

# kallisto RNA-seq quantification. Corrected from prior file against the
# official manual: removed pseudo/merge (not in current subcommand list),
# added quant-tcc/cite/version; index gained -d/-t/-m/-e; bus gained the
# documented -l/-B/-b/-n/-N/-T and strand flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'index:build a kallisto index'
      'quant:quantify abundances'
      'quant-tcc:quantify transcript-compatibility counts'
      'bus:generate BUS files for single-cell'
      'h5dump:convert HDF5 to text'
      'inspect:inspect a kallisto index'
      'version:print version information'
      'cite:print citation information'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      index)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'[output index file]:file:_files' \
          '(-k --kmer-size)'{-k,--kmer-size}'[k-mer size]:size' \
          '(-d --d-list)'{-d,--d-list}'[FASTA of sequences to mask]:file:_files' \
          '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
          '(-m --min-size)'{-m,--min-size}'[minimizer length]:size' \
          '(-e --ec-max-size)'{-e,--ec-max-size}'[max targets in an equivalence class]:size' \
          '--make-unique[make duplicate sequences unique]' \
          '--aa[index amino acid sequences]' \
          '--distinguish[distinguish sequences by name]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:FASTA files:_files -g "*.{fa,fasta,fa.gz,fasta.gz}"' && ret=0
        ;;
      quant)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'[index file]:file:_files' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_files' \
          '(-b --bootstrap-samples)'{-b,--bootstrap-samples}'[number of bootstrap samples]:number' \
          '--seed=[bootstrap seed]:seed' \
          '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
          '--plaintext[output plaintext instead of HDF5]' \
          '--single[single-end reads]' \
          '--single-overhang[include reads with unobserved fragment portions]' \
          '(-l --fragment-length)'{-l,--fragment-length}'[estimated average fragment length]:length' \
          '(-s --sd)'{-s,--sd}'[estimated standard deviation]:sd' \
          '--fr-stranded[strand specific reads, first read forward]' \
          '--rf-stranded[strand specific reads, first read reverse]' \
          '--bias[perform sequence-specific bias correction]' \
          '--genomebam[project pseudoalignments to genome]' \
          '--gtf=[GTF file for genome bam]:file:_files -g "*.gtf"' \
          '--chromosomes=[chromosome file]:file:_files' \
          '(- *)'{-h,--help}'[show help]' \
          '*:FASTQ files:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' && ret=0
        ;;
      bus)
        _arguments -s -S \
          '(-i --index)'{-i,--index}'[index file]:file:_files' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory]:directory:_files' \
          '(-x --technology)'{-x,--technology}'[single-cell technology]:technology:' \
          '(-l --list)'{-l,--list}'[list supported technologies]' \
          '(-B --batch)'{-B,--batch}'[process files listed in file]:file:_files' \
          '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
          '(-b --bam)'{-b,--bam}'[input is a BAM file]' \
          '(-n --num)'{-n,--num}'[output read number in flag column]' \
          '(-N --numReads)'{-N,--numReads}'[maximum reads to process]:num' \
          '(-T --tag)'{-T,--tag}'[5 prime tag sequence for UMI]:tag' \
          '--fr-stranded[first read forward (UMI-tagged)]' \
          '--rf-stranded[first read reverse (UMI-tagged)]' \
          '--unstranded[non-strand-specific reads]' \
          '--paired[treat as paired reads]' \
          '--aa[align to amino acid index]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:FASTQ files:_files -g "*.{fq,fastq,fq.gz,fastq.gz}"' && ret=0
        ;;
      inspect)
        _arguments -s -S \
          '1:index file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
