#compdef hyprpicker
# Documentation: https://wiki.hypr.land/Hypr-Ecosystem/hyprpicker/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# hyprpicker — Hyprland wlroots color picker

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --autocopy)'{-a,--autocopy}'[copy color to clipboard (needs wl-clipboard)]' \
  '(-f --format)'{-f+,--format=}'[output color format]:format:(cmyk hex rgb hsl hsv)' \
  '(-o --output-format)'{-o+,--output-format=}'[custom output template]:template' \
  '(-n --notify)'{-n,--notify}'[send desktop notification on pick]' \
  '(-b --no-fancy)'{-b,--no-fancy}'[disable colored output formatting]' \
  '(-r --render-inactive)'{-r,--render-inactive}'[freeze inactive displays]' \
  '(-z --no-zoom)'{-z,--no-zoom}'[disable zoom lens]' \
  '(-t --no-fractional)'{-t,--no-fractional}'[disable fractional scaling support]' \
  '(-d --disable-hex-preview)'{-d,--disable-hex-preview}'[turn off live hex code preview]' \
  '(-l --lowercase-hex)'{-l,--lowercase-hex}'[render hex values in lowercase]' \
  '(-s --scale)'{-s+,--scale=}'[zoom magnification 1.0-10.0]:scale' \
  '(-u --radius)'{-u+,--radius=}'[selection circle size 1-1000]:radius' \
  '(-q --quiet)'{-q,--quiet}'[suppress most logging]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' && ret=0

return ret
