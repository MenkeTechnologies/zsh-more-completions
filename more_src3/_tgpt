#compdef tgpt
# Documentation: https://github.com/aandrew-me/tgpt/blob/main/md/usage.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--provider=[specify AI provider]:provider:(deepseek gemini groq isou koboldai ollama openai pollinations phind)'
  '--model=[set model name]:model:'
  '--key=[API key for provider]:key:'
  '--temperature=[temperature for response]:temperature:'
  '--top_p=[top_p value]:value:'
  '--url=[custom API URL]:url:'
  '--log=[log conversation to file]:file:_files'
  '--preprompt=[system prompt]:text:'
  '--out=[image output filename]:file:_files'
  '--height=[image height]:height:'
  '--width=[image width]:width:'
  '--img_count=[number of images]:count:'
  '--img_negative=[negative prompt]:text:'
  '--img_ratio=[image ratio]:ratio:'
  {-s,--shell}'[generate and execute shell commands]'
  {-c,--code}'[generate code]'
  {-q,--quiet}'[quiet output]'
  {-w,--whole}'[whole response at once]'
  {-img,--image}'[generate image from prompt]'
  '-y[execute shell commands without confirmation]'
  {-v,--version}'[show version]'
  {-h,--help}'[show help]'
  {-i,--interactive}'[start interactive mode]'
  {-m,--multiline}'[multi-line input mode]'
  {-is,--interactive-shell}'[start interactive shell mode]'
  {-cl,--changelog}'[view changelog]'
  '*:prompt text'
)

_arguments -s -S $arguments
