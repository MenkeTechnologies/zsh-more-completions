#compdef wheel
# _wheel — PyPA wheel command-line utility (pypa/wheel)
# upstream: https://github.com/pypa/wheel
# Subcommands from src/wheel/_commands/__init__.py (argparse subparsers).

_wheel() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'unpack:unpack a wheel'
                'pack:repack an unpacked wheel directory'
                'convert:convert an .egg or .whl to a wheel'
                'tags:retag an existing wheel'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                unpack)
                    _arguments \
                        '(-d --dest)'{-d+,--dest=}'[destination directory]:dir:_files -/' \
                        '1:wheel file:_files -g "*.whl"'
                    ;;
                pack)
                    _arguments \
                        '(-d --dest-dir)'{-d+,--dest-dir=}'[destination directory]:dir:_files -/' \
                        '--build-number=[build number to add to filename]:n:' \
                        '1:unpacked wheel directory:_files -/'
                    ;;
                convert)
                    _arguments \
                        '(-d --dest-dir)'{-d+,--dest-dir=}'[destination directory]:dir:_files -/' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                        '*:egg or wheel file:_files -g "*.(egg|whl)"'
                    ;;
                tags)
                    _arguments \
                        '--python-tag=[python tag (e.g. py3, +py3, -py2)]:tag:' \
                        '--abi-tag=[ABI tag]:tag:' \
                        '--platform-tag=[platform tag]:tag:' \
                        '--build=[build tag]:tag:' \
                        '--remove[remove the original file]' \
                        '*:wheel file:_files -g "*.whl"'
                    ;;
            esac
            ;;
    esac
}

_wheel "$@"
