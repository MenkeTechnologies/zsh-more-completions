#compdef signify signify-openbsd
# Documentation: man signify(1)
# Source: aperezdc/signify signify.c (master) — OpenBSD-style signing/verification tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-C -G -S -V)-C[verify checksum (multi-file)]' \
    '(-C -G -S -V)-G[generate new key pair]' \
    '(-C -G -S -V)-S[sign a message]' \
    '(-C -G -S -V)-V[verify a signature]' \
    '-c+[comment for new key]:comment:_default' \
    '-e[embed message in signature (sign/verify)]' \
    '-m+[message file]:file:_files' \
    '-n[do not prompt for passphrase]' \
    '-p+[public key file]:pubkey:_files -g "*.pub"' \
    '-q[quiet]' \
    '-s+[secret key file]:seckey:_files -g "*.sec"' \
    '-t+[key type]:type:_default' \
    '-x+[signature file]:sigfile:_files -g "*.sig"' \
    '-z[gzip mode (embed in gzip)]' \
    '*:file:_files' \
    && ret=0

return ret
