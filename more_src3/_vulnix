#compdef vulnix
# Documentation: https://github.com/flyingcircusio/vulnix
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# system/derive/help subcommand split (vulnix is not a subcommand-style
# CLI — it takes paths/derivations as positional args and flags).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--system[scan current system closure]' \
  '-R[process derivations without determining requisites]' \
  '--json[output JSON]' \
  '-w+[whitelist file or URL]:whitelist:_files' \
  '*:nix store path or derivation:_files' && ret=0

return ret
