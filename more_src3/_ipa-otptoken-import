#compdef ipa-otptoken-import
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-otptoken-import.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-otptoken-import.1.

# ipa-otptoken-import: import OATH OTP tokens from PSKC file
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-k --keyfile)'{-k,--keyfile=}'[key file for decrypting token data]:file:_files' \
  '1:input file:_files -g "*.xml"' \
  '2:output file:_files' && ret=0
return ret
