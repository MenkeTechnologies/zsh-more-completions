#compdef tab
# Documentation: https://github.com/austinjones/tab-rs
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# tab: terminal multiplexer (austinjones/tab-rs)
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-l[list all available tabs]' \
  '*-w+[close named tab]:tab:' \
  '--install=[install completions or starship integration]:target:(all bash fish zsh starship)' \
  '--shutdown[restart the daemon]' \
  '*:tab name:' && ret=0

return ret
