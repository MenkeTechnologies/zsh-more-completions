#compdef terragrunt-cli
# Documentation: https://docs.terragrunt.com/docs/reference/cli-options/
# Reference accessed: 2026-05-21
# Verified: upstream docs.terragrunt.com (modern CLI).
# terragrunt-cli is the alternate binary name for terragrunt — same command
# surface. This file mirrors _terragrunt with the alternate compdef.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'run:execute OpenTofu/Terraform commands through terragrunt'
  'run-all:run terragrunt across a stack of modules (legacy)'
  'exec:execute arbitrary commands wrapped by terragrunt'
  'backend:manage backend state (bootstrap/migrate/delete)'
  'stack:manage terragrunt stacks (run/generate/clean/output)'
  'catalog:browse modules in a terminal UI'
  'scaffold:generate terragrunt config from a template'
  'find:locate terragrunt configurations'
  'list:list terragrunt configurations'
  'hcl:HCL helpers (fmt/validate)'
  'dag:DAG helpers (graph)'
  'render:render the resolved terragrunt config'
  'info:print terragrunt context info (print/strict)'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--working-dir=[terragrunt working dir]:dir:_files -/' \
  '--config=[terragrunt config file]:file:_files -g "*.hcl *.json"' \
  '--tf-path=[OpenTofu/Terraform binary path]:file:_files' \
  '--log-level=[log verbosity]:level:(trace debug info warn error fatal panic disabled)' \
  '--log-format=[log format]:format:(pretty json bare key-value)' \
  '--no-color[disable color output]' \
  '--non-interactive[assume yes for prompts]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t cmds 'terragrunt-cli command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac

return ret
