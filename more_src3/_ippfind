#compdef ippfind
# Documentation: ippfind --help (CUPS 26)
# Source: discover IPP printers via DNS-SD with a find(1)-style expression.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-6)-4[connect using IPv4]' \
    '(-4)-6[connect using IPv6]' \
    '-T+[browse timeout in seconds]:seconds:' \
    '-V+[default IPP version]:version:(1.0 1.1 2.0 2.1 2.2)' \
    '-P+[match port to number/range]:port:' \
    '(-d --domain)'{-d+,--domain=}'[match domain regex]:regex:' \
    '(-h --host)'{-h+,--host=}'[match hostname regex]:regex:' \
    '(-l --ls)-l[list attributes]' \
    '(-l --ls)--ls[list attributes]' \
    '(-n --name)'{-n+,--name=}'[match service-name regex]:regex:' \
    '--path=[match resource path regex]:regex:' \
    '--port=[match port to number/range]:port:' \
    '(-p --print)-p[print URI if true]' \
    '(-p --print)--print[print URI if true]' \
    '--print-name[print service name if true]' \
    '(-q --quiet)-q[quietly report match via exit code]' \
    '(-q --quiet)--quiet[quietly report match via exit code]' \
    '(-r --remote)-r[true if service is remote]' \
    '(-r --remote)--remote[true if service is remote]' \
    '--local[true if service is local]' \
    '(-s)-s[print service name if true]' \
    '(-t --txt)'{-t+,--txt=}'[true if TXT contains key]:key:' \
    '(-u --uri)'{-u+,--uri=}'[match URI regex]:regex:' \
    '(-x --exec)'{-x+,--exec=}'[execute utility if true; terminate with \;]:utility:_command_names -e' \
    '(--not)\![unary NOT of expression]' \
    '--not[unary NOT of expression]' \
    '--false[always false]' \
    '--true[always true]' \
    '--and[logical AND]' \
    '--or[logical OR]' \
    '*:regtype, name, or expression:' \
    && ret=0

return ret
