#compdef taxgetdown
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/taxgetdown.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# EMBOSS taxgetdown: get taxonomy entries downwards through hierarchy
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help]' \
  '-auto[turn off prompts]' \
  '-stdout[write output to standard output]' \
  '-filter[read stdin / write stdout]' \
  '-options[prompt for standard and additional values]' \
  '-debug[write debug output]' \
  '-verbose[report command line options]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report version number]' \
  '-taxons=[taxon filename, format, or reference]:USA:' \
  '-iformat1=[input taxonomy format]:format:' \
  '-iquery1=[input query fields or ID list]:query:' \
  '-ioffset1=[input start position offset]:offset:' \
  '-idbname1=[user-provided database name]:dbname:' \
  '-outfile=[output taxon file]:file:_files' \
  '-odirectory2=[output directory]:dir:_directories' \
  '-oformat2=[output format]:fmt:(ncbi ebi tax excel)' \
  '*:taxonomy query:' && ret=0

return ret
