#compdef wiggletools
# _wiggletools — Daniel Zerbino Ensembl WiggleTools genomic signal track summary and combinatorics on wiggle bigWig bedGraph (Ensembl team, C); custom argparse
# upstream: https://github.com/Ensembl/WiggleTools

_wiggletools() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '*:operation files:(scale exp ln log mult div add abs sub sum mean median stdev variance pearson correlation gt lt gte lte sel skip extend shift trim filter chroms profile profiles strict apply applyPaste smooth seek seqs strict toBg toBw write writeBg histogram nbins fill clip overlap distance count_chr unit AUC isZero anySample firstSample default dropZero)'
}

_wiggletools "$@"
