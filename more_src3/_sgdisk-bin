#compdef sgdisk
# _sgdisk-bin — gdisk script-friendly GPT partition table editor (Rod Smith); scriptable counterpart to gdisk
# upstream: https://www.rodsbooks.com/gdisk

_sgdisk-bin() {
    _arguments \
        '(-a --set-alignment)'{-a,--set-alignment}'+[align sectors]:n:' \
        '(-A --attributes)'{-A,--attributes}'+[set attribute]:list:' \
        '(-b --backup)'{-b,--backup}'+[backup table to file]:file:_files' \
        '(-B --rebuild-second-header)'{-B,--rebuild-second-header}'[rebuild backup header]' \
        '(-c --change-name)'{-c,--change-name}'+[change part name]:partnum:name:' \
        '(-C --recompute-chs)'{-C,--recompute-chs}'[recompute CHS values]' \
        '(-d --delete)'{-d,--delete}'+[delete partition]:partnum:' \
        '(-D --display-alignment)'{-D,--display-alignment}'[show current alignment]' \
        '(-e --move-second-header)'{-e,--move-second-header}'[move backup header to end]' \
        '(-E --end-of-largest)'{-E,--end-of-largest}'[end of largest free block]' \
        '(-f --first-in-largest)'{-f,--first-in-largest}'[first sector of largest free block]' \
        '(-F --first-aligned-in-largest)'{-F,--first-aligned-in-largest}'[first aligned sector in largest free block]' \
        '(-g --mbrtogpt)'{-g,--mbrtogpt}'[convert MBR to GPT]' \
        '(-G --randomize-guids)'{-G,--randomize-guids}'[randomize all GUIDs]' \
        '(-h --hybrid)'{-h,--hybrid}'+[hybrid MBR boot list]:list:' \
        '(-i --info)'{-i,--info}'+[show partition info]:partnum:' \
        '(-l --load-backup)'{-l,--load-backup}'+[load backup from file]:file:_files' \
        '(-L --list-types)'{-L,--list-types}'[list known partition types]' \
        '(-m --gpttombr)'{-m,--gpttombr}'+[GPT->MBR convert list]:list:' \
        '(-n --new)'{-n,--new}'+[new partition]:partnum:start:end:' \
        '(-N --largest-new)'{-N,--largest-new}'+[new in largest free block]:partnum:' \
        '(-o --clear)'{-o,--clear}'[zap all partitions]' \
        '(-O --options)'{-O,--options}'[show diagnostic info]' \
        '(-p --print)'{-p,--print}'[print partition table]' \
        '(-P --pretend)'{-P,--pretend}'[dry run]' \
        '(-Q --transform-bsd)'{-Q,--transform-bsd}'+[BSD disk label to GPT]:list:' \
        '(-r --transpose)'{-r,--transpose}'+[transpose two part numbers]:p1:p2:' \
        '(-R --replicate)'{-R,--replicate}'+[copy to other disk]:device:_files' \
        '(-s --sort)'{-s,--sort}'[sort partition table by start]' \
        '(-S --resize-table)'{-S,--resize-table}'+[resize partition table]:n:' \
        '(-t --typecode)'{-t,--typecode}'+[type code]:partnum:type:' \
        '(-T --transform-mbr)'{-T,--transform-mbr}'[MBR to GPT in place]' \
        '(-u --partition-guid)'{-u,--partition-guid}'+[set part GUID]:partnum:guid:' \
        '(-U --disk-guid)'{-U,--disk-guid}'+[set disk GUID]:guid:' \
        '(-v --verify)'{-v,--verify}'[verify table]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-z --zap)'{-z,--zap}'[zap GPT but leave MBR]' \
        '(-Z --zap-all)'{-Z,--zap-all}'[zap GPT and MBR]' \
        '*:device:_files'
}

_sgdisk-bin "$@"
