#compdef xvinfo
# _xvinfo — X11 xvinfo (probe the Xv (X-Video) extension: lists every Xv adaptor + the formats, attributes, image formats and encodings it advertises; -display picks an X display, -short condenses output)
# upstream: https://gitlab.freedesktop.org/xorg/app/xvinfo
# Flags from xvinfo xvinfo.c on tip.

_xvinfo() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-display+[X display]:display:' \
        '-short[condensed output]'
}

_xvinfo "$@"
