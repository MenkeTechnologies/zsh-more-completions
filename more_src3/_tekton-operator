#compdef tekton-operator
# _tekton-operator — Tekton Operator (Kubernetes platform) — reconciles TektonConfig/TektonPipeline/TektonTrigger/TektonDashboard/TektonChains/TektonResult/TektonHub
# upstream: https://github.com/tektoncd/operator
# Flags from cmd/kubernetes/operator/main.go via pkg/reconciler/platform/config.go on tip; rest via knative.dev/pkg sharedmain.

_tekton-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--controllers=[csv of controllers to enable (empty = all)]:csv:' \
        '--unique-process-name=[name of the sharedMain process used in leader election]:name:' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_tekton-operator "$@"
