#compdef tinyssh tinysshd
# Documentation: https://man.archlinux.org/man/tinysshd.8
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-q[suppress error messages]' \
  '-Q[print error messages (default)]' \
  '-v[display extra information]' \
  '-s[enable state-of-the-art cryptography (default)]' \
  '-S[disable state-of-the-art cryptography]' \
  '-p[enable post-quantum cryptography (default)]' \
  '-P[disable post-quantum cryptography]' \
  '-l[use syslog]' \
  '-L[use standard error output (default)]' \
  '-x+[add subsystem command]:subsystem:' \
  '-e+[execute specified command instead of shell]:command:' \
  '*:keydir:_files -/' && ret=0

return ret
