#compdef whisper-bench
# Documentation: https://github.com/ggml-org/whisper.cpp/blob/master/examples/bench/bench.cpp
# Reference accessed: 2026-05-27
# Verified: upstream whisper_params_parse() in examples/bench/bench.cpp (ggml-org/whisper.cpp).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-m --model)'{-m+,--model=}'[model file path]:file:_files' \
  '(-w --what)'{-w+,--what=}'[what to benchmark: 0=encode, 1=decode, 2=ggml mul_mat, 3=memcpy]:n:((0\:encode 1\:decode 2\:ggml-mul-mat 3\:memcpy))' \
  '(-ng --no-gpu)'{-ng,--no-gpu}'[disable GPU]' \
  '(-fa --flash-attn)'{-fa,--flash-attn}'[enable flash attention]' \
  '(-nfa --no-flash-attn)'{-nfa,--no-flash-attn}'[disable flash attention]' && ret=0

return ret
