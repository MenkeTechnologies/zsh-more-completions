#compdef zoekt-mirror-gitiles
# _zoekt-mirror-gitiles — Zoekt Gitiles/cgit repository mirror
# upstream: https://github.com/sourcegraph/zoekt
# Flags from cmd/zoekt-mirror-gitiles/main.go on tip.

_zoekt-mirror-gitiles() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-dest=[destination directory]:dir:_files -/' \
        '-name=[regex of repo names to clone]:regex:' \
        '-exclude=[regex of repo names to skip]:regex:' \
        '-type=[webserver type to crawl]:type:(gitiles cgit)' \
        '*:url:_urls'
}

_zoekt-mirror-gitiles "$@"
