#compdef SurfaceCurvature
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/SurfaceCurvature.cxx — compute mean/Gaussian curvature on a binary surface (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:input image:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '2:output curvature image:_files' \
    '3:sigma (neighbourhood radius):_default' \
    '4:option (curvature type integer):_default' \
    && ret=0

return ret
