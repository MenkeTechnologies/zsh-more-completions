#compdef kubectl-clusterpedia
# Documentation: https://clusterpedia.io/docs/usage/access-clusterpedia/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# STUB: clusterpedia (clusterpedia-io/clusterpedia) is NOT a krew plugin/binary.
# It is accessed via `kubectl --cluster clusterpedia get ...` using
# search.clusterpedia.io/* label selectors. This completion mirrors the
# kubectl get flags used against a clusterpedia cluster.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[all namespaces]' \
  '--chunk-size=[list chunk size]:size:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '(-l --selector)'{-l+,--selector=}'[label selector (search.clusterpedia.io/* keys)]:selector:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(wide yaml json jsonpath name)' \
  '1:resource:_default' \
  '*:name or selector:_default'
