#compdef kcharselect
# Documentation: https://github.com/KDE/kcharselect/blob/master/main.cc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. kcharselect only calls
# KAboutData::setupCommandLine — no app-specific options.
# STUB: standard KAboutData options only.

# kcharselect: KDE character chooser (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt-specific options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[the base file name of the desktop entry]:file:_files' && ret=0
return ret
