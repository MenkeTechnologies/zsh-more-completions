#compdef thefuck
# Documentation: thefuck --help on The Fuck 3.32
# Source: nvbn/thefuck — magnificent app that corrects your previous console command.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-v,--version}'[show version and exit]' \
    '(-a --alias)'{-a,--alias=}'[print shell alias (optional custom name)]::custom-alias-name:' \
    '(-l --shell-logger)'{-l,--shell-logger=}'[log shell output to file]:file:_files' \
    '--enable-experimental-instant-mode[enable experimental instant mode]' \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(-y --yes --yeah --hard -r --repeat)'{-y,--yes,--yeah,--hard}'[execute fixed command without confirmation]' \
    '(-y --yes --yeah --hard -r --repeat)'{-r,--repeat}'[repeat on failure]' \
    '(-d --debug)'{-d,--debug}'[enable debug output]' \
    '*:command:_command_names -e' \
    && ret=0

return ret
