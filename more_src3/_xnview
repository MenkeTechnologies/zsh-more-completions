#compdef xnview xnviewmp
# _xnview — XnView / XnView MP (Pierre-e Gougelet's closed-source image viewer + converter supporting 500+ formats; -ipv8 path / -i indexed view, --convert from src to dst, --rotate angle, --filter list, --quality (1-100), --crop x y w h, --resize WxH; positional list opens in viewer)
# upstream: https://www.xnview.com/ (closed source)
# Flags from XnView MP help on tip.

_xnview() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--convert+[output format]:format:(png jpg jpeg gif tiff tif webp bmp pdf heif heic avif tga ico ppm)' \
        '--quality+[quality 1-100]:quality:' \
        '--resize=*[WxH]:size:' \
        '--rotate=*[angle]:angle:(90 180 270 -90 -180 -270)' \
        '--crop=*[x y w h]:crop:' \
        '--filter=*[apply filter]:filter:' \
        '--out=*[output path]:file:_files' \
        '*:image:_files'
}

_xnview "$@"
