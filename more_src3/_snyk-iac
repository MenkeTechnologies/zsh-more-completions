#compdef snyk-iac
# _snyk-iac — Snyk Infrastructure-as-Code scanner subcommand alias (Snyk, TypeScript); commander
# upstream: https://github.com/snyk/cli

_snyk-iac() {
    local -a sub=(
        'test:scan IaC files'
        'capture:capture cloud snapshot'
        'describe:describe drift'
        'update-exclude-policy:update exclude policy'
        'rules:manage custom rules'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '--json-file-output=+[json file output]:file:_files' \
        '--sarif[sarif output]' \
        '--sarif-file-output=+[sarif file output]:file:_files' \
        '--severity-threshold=+[severity threshold]:t:(low medium high critical)' \
        '--report[report to platform]' \
        '--target-name=+[target name]:str:' \
        '--target-reference=+[target reference]:str:' \
        '--remote-repo-url=+[remote repo url]:url:_urls' \
        '--org=+[organization]:org:' \
        '--rules=+[rules file]:file:_files' \
        '--policy-path=+[policy path]:file:_files' \
        '--ignore-policy[ignore policy]' \
        '--trust-policies[trust policies]' \
        '--exclude=+[exclude patterns]:list:' \
        '--var-file=+[terraform vars file]:file:_files -g "*.tfvars"' \
        '--scan=+[scan target]:t:(resource-changes planned-values)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'snyk iac subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '*:path:_files' ;;
                describe|capture) _arguments \
                    '--all[all]' \
                    '--only-managed[only managed]' \
                    '--only-unmanaged[only unmanaged]' \
                    '--drift[drift]' \
                    '--filter=+[filter]:str:' \
                    '--from=+[snapshot from]:list:' \
                    '--to=+[snapshot to]:list:' ;;
                update-exclude-policy) _arguments '*:arg:' ;;
                rules) _arguments \
                    '1:cmd:(push pull test init)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_snyk-iac "$@"
