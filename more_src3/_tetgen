#compdef tetgen
# Documentation: https://wias-berlin.de/software/tetgen/1.5/doc/manual/
# Source: TetGen 1.5 manual section 4.2 (Hang Si, WIAS-Berlin) — 3-D Delaunay tetrahedral mesh generator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[tetrahedralize a piecewise linear complex (PLC)]' \
    '-Y[preserve input surface mesh (do not modify it)]' \
    '-r[reconstruct previously generated mesh]' \
    '-q[refine mesh to improve quality]' \
    '-R[mesh coarsening (reduce element count)]' \
    '-A[assign attributes to tetrahedra in different regions]' \
    '-a[apply maximum tetrahedron volume constraint]' \
    '-m[apply mesh sizing function]' \
    '-i[insert list of additional points]' \
    '-O[mesh optimization level]' \
    '-S[max number of added Steiner points]' \
    '-T[tolerance for coplanar test (default 1e-8)]' \
    '-X[suppress use of exact arithmetic]' \
    '-M[no merge of coplanar facets or very close vertices]' \
    '-w[generate weighted Delaunay (regular) triangulation]' \
    '-c[retain the convex hull of the PLC]' \
    '-d[detect self-intersections of facets of the PLC]' \
    '-z[number all output items starting from zero]' \
    '-f[output all faces to .face file]' \
    '-e[output all edges to .edge file]' \
    '-n[output tetrahedra neighbors to .neigh file]' \
    '-v[output Voronoi diagram to files]' \
    '-g[output mesh to .mesh (Medit) file]' \
    '-k[output mesh to .vtk (Paraview) file]' \
    '-J[no jettison of unused vertices from output .node]' \
    '-B[suppress output of boundary information]' \
    '-N[suppress output of .node file]' \
    '-E[suppress output of .ele file]' \
    '-F[suppress output of .face and .edge file]' \
    '-I[suppress mesh iteration numbers]' \
    '-C[check consistency of final mesh]' \
    '-Q[quiet (no terminal output except errors)]' \
    '-V[verbose (detailed terminal output)]' \
    '-h[help / brief instruction]' \
    '*:input .poly/.smesh/.mesh:_files' \
    && ret=0

return ret
