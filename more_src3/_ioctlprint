#compdef ioctlprint
# Documentation: man ioctlprint(1)
# Source: netbsd/src usr.bin/kdump (ioctlprint) — describe ioctl requests (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-l[list all recognized ioctl requests]' \
    '-e+[emulation for syscall maps (default netbsd)]:emulation:_default' \
    '-f+[printf-style output format (%E %e %n %x %o %d %i)]:format:_default' \
    '*:ioctl name or numeric value:_default' \
    && ret=0

return ret
