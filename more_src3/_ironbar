#compdef ironbar
# Documentation: https://github.com/JakeStanger/ironbar/blob/master/src/cli.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[display version information]' \
  '--print-schema[output config JSON schema and exit]' \
  '--print-completions=[output shell completions and exit]:shell:(bash elvish zsh fish powershell)' \
  '--debug[enable debug output to stderr]' \
  '(-c --config)'{-c,--config=}'[config file path]:config file:_files' \
  '(-t --theme)'{-t,--theme=}'[theme/CSS file path]:css file:_files' \
  '(-v --validate-config)'{-v,--validate-config}'[validate config and CSS then exit]' \
  '(-f --format)'{-f,--format=}'[output response format]:format:(plain json)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'ping:test connection to the IPC server'
      'inspect:show how to address an element'
      'reload:reload configuration'
      'var:manage runtime variables'
      'bar:control bars'
      'style:manage CSS styling'
    )
    _describe -t commands 'ironbar command' commands && ret=0
    ;;
  args)
    case $line[1] in
      var)
        local -a v=('set:set a variable' 'get:get a variable value' 'list:list variables')
        _describe -t v 'var command' v && ret=0
        ;;
      bar)
        local -a b=(
          'show:show a bar' 'hide:hide a bar'
          'set_visible:set bar visibility' 'toggle_visible:toggle bar visibility'
          'get_visible:get bar visibility' 'show_popup:show a popup'
          'hide_popup:hide a popup' 'set_popup_visible:set popup visibility'
          'toggle_popup:toggle popup visibility' 'get_popup_visible:get popup visibility'
          'set_exclusive:set exclusive zone'
        )
        _describe -t b 'bar command' b && ret=0
        ;;
      style)
        local -a s=(
          'load_css:load a CSS stylesheet' 'add_class:add a CSS class'
          'remove_class:remove a CSS class' 'toggle_class:toggle a CSS class'
        )
        _describe -t s 'style command' s && ret=0
        ;;
    esac
    ;;
esac

return ret
