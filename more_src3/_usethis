#compdef usethis
# _usethis — Hadley Wickham Jenny Bryan usethis R package automating package setup CI tests vignettes licenses GitHub releases CRAN submission and tidyverse workflow tasks (rstudio team, R); R argparse
# upstream: https://github.com/r-lib/usethis

_usethis() {
    local -a sub=(
        'create-package:create new R package'
        'create-project:create new R project'
        'use-git:initialize git repo'
        'use-github:set up GitHub remote'
        'use-github-actions:add GitHub Actions CI'
        'use-r:create new R file'
        'use-test:create test file'
        'use-testthat:set up testthat'
        'use-vignette:create vignette'
        'use-readme-md:add README.md'
        'use-readme-rmd:add README.Rmd'
        'use-news-md:add NEWS.md'
        'use-license:add license'
        'use-mit-license:add MIT license'
        'use-apache-license:add Apache license'
        'use-gpl-license:add GPL license'
        'use-cc0-license:add CC0 license'
        'use-package:add Imports dependency'
        'use-dev-package:add dev dependency'
        'use-pipe:re-export %>%'
        'use-tidy-eval:re-export tidy eval'
        'use-tibble:re-export tibble'
        'use-rstudio:configure RStudio'
        'use-data:save data into package'
        'use-data-raw:create data-raw dir'
        'use-pkgdown:setup pkgdown site'
        'use-pkgdown-github-pages:deploy pkgdown to gh-pages'
        'use-cran-comments:create cran-comments.md'
        'use-release-issue:create release checklist'
        'use-version:bump version'
        'use-dev-version:bump dev version'
        'use-revdep:setup revdep'
        'create-from-github:fork and clone github repo'
        'pr-init:start a PR'
        'pr-resume:resume a PR'
        'pr-finish:finish a PR'
        'pr-merge-main:merge main into PR branch'
        'pr-pull:pull latest from PR branch'
        'pr-push:push to PR branch'
        'pr-sync:sync PR with main'
        'pr-fetch:fetch PR'
        'pr-view:open PR in browser'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'usethis subcommand' sub ;;
        args) ;;
    esac
}

_usethis "$@"
