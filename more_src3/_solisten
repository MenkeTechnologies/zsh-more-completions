#compdef solisten solisten-bpfcc
# _solisten — trace TCP/IPv4/IPv6 socket listen events (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/solisten.py (argparse).

_solisten() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--show-netns[also show the network namespace]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '(-n --netns)'{-n+,--netns=}'[trace this network namespace only]:netns:'
    )
    _arguments $args
}

_solisten "$@"
