#compdef thanos2
# _thanos2 — Thanos thanos2 CLI command-line frontend wrapping the Thanos open-source highly available Prometheus setup with long-term storage providing sidecar query query-frontend receive rule store compact downsample tools bucket inspect ls verify cleanup repair label-relabel rewrite cors retention block global-deduplication scaling-Prometheus-multi-cluster (Thanos CNCF team Bartek Plotka, Go); kingpin
# upstream: https://thanos.io/

_thanos2() {
    local -a sub=(
        'sidecar:run sidecar'
        'query:run querier'
        'query-frontend:run query frontend'
        'receive:run receiver'
        'rule:run ruler'
        'store:run store gateway'
        'compact:run compactor'
        'downsample:run downsampler'
        'tools:tools'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--log.level=+[level]:l:(debug info warn error)' \
        '--log.format=+[fmt]:f:(logfmt json)' \
        '--tracing.config-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--tracing.config=+[yaml]:str:' \
        '--http-address=+[host:port]:_hosts' \
        '--http-grace-period=+[d]:str:' \
        '--grpc-address=+[host:port]:_hosts' \
        '--grpc-server-tls-cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--grpc-server-tls-key=+[file]:file:_files -g "*.pem *.key"' \
        '--grpc-server-tls-client-ca=+[file]:file:_files -g "*.pem *.crt"' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--prometheus.url=+[url]:str:' \
        '--prometheus.http-client-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--query.replica-label=+[name]:str:' \
        '--query.timeout=+[d]:str:' \
        '--query.max-concurrent=+[N]:n:' \
        '--store=+[host:port]:_hosts' \
        '--rule-file=+[glob]:str:' \
        '--objstore.config-file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--objstore.config=+[yaml]:str:' \
        '--retention.resolution-raw=+[d]:str:' \
        '--retention.resolution-5m=+[d]:str:' \
        '--retention.resolution-1h=+[d]:str:' \
        '--shipper.upload-compacted[upload compacted]' \
        '--web.external-prefix=+[path]:str:' \
        '--web.prefix-header=+[name]:str:' \
        '--web.route-prefix=+[path]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'thanos subcommand' sub ;;
        args)
            case $words[1] in
                tools) _arguments '1:tool:(bucket rules-check)' '2:op:(verify ls inspect web replicate cleanup mark rewrite retention downsample)' '*:arg:' ;;
            esac
            ;;
    esac
}

_thanos2 "$@"
