#compdef tracepath6
# Documentation: man tracepath6(8)
# Source: dgibson/iputils tracepath6.c (master) — discover MTU along path to dest (IPv6, C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-n[do not resolve hop hostnames]' \
    '-b[show both IP and hostname]' \
    '-l+[initial packet length]:bytes:_default' \
    '-m+[max hops (TTL)]:hops:_default' \
    '-p+[destination port]:port:_default' \
    '(-h -?)'{-h,-\\?}'[show help]' \
    '1:destination:_hosts' \
    && ret=0

return ret
