#compdef syz-prog2c
# _syz-prog2c — convert syzkaller programs into C reproducers (google/syzkaller)
# upstream: https://github.com/google/syzkaller
# Flags from tools/syz-prog2c/prog2c.go (flag).

_syz-prog2c() {
    _arguments \
        '-os=[target OS]:os:(linux freebsd netbsd openbsd darwin windows fuchsia trusty test)' \
        '-arch=[target architecture]:arch:(amd64 386 arm64 arm mips64le ppc64le riscv64 s390x)' \
        '-build[also build the generated program]' \
        '-threaded[create threaded program]' \
        '-repeat=[repeat program N times (<=0=infinite)]:n:' \
        '-procs=[number of parallel processes]:n:' \
        '-slowdown=[execution slowdown]:n:' \
        '-sandbox=[sandbox to use]:sandbox:(none setuid namespace android)' \
        '-sandbox_arg=[executor sandbox argument]:n:' \
        '-prog=[program file to convert]:file:_files' \
        '-segv[catch and ignore SIGSEGV]' \
        '-tmpdir[create temp dir and execute inside it]' \
        '-trace[trace syscall results]' \
        '-strict[parse input program in strict mode]' \
        '-leak[do leak checking]'
}

_syz-prog2c "$@"
