#compdef vegeta-cli
# Documentation: https://github.com/tsenart/vegeta
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'attack:run an attack'
  'encode:encode results to other formats'
  'plot:generate HTML plot'
  'report:generate report'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-cpus=[number of CPUs to use]:n:' \
  '-profile=[enable profiling]:m:(cpu heap)' \
  '-version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vegeta command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (attack)
        _arguments \
          '-targets=[targets file]:file:_files' \
          '-format=[targets format]:f:(http json)' \
          '-rate=[req per time unit]:rate:' \
          '-duration=[attack duration]:t:' \
          '-workers=[initial workers]:n:' \
          '-max-workers=[max workers]:n:' \
          '-connections=[max open idle conns per host]:n:' \
          '-max-connections=[max conns per host]:n:' \
          '-h2c[send HTTP/2 over TCP without TLS]' \
          '-http2[enable HTTP/2 when supported]' \
          '-keepalive[use persistent connections]' \
          '-laddr=[local IP address]:a:' \
          '-output=[output file]:file:_files' \
          '-redirects=[max redirects]:n:' \
          '-resolvers=[DNS resolvers csv]:list:' \
          '-proxy-header=[proxy CONNECT header]:h:' \
          '-prometheus-addr=[Prometheus listen addr]:a:' \
          '-cert=[client TLS cert PEM]:file:_files' \
          '-key=[client TLS key PEM]:file:_files' \
          '-root-certs=[CA certs csv]:list:_files' \
          '-insecure[ignore invalid TLS certs]' \
          '-name=[attack name]:n:' \
          '-timeout=[request timeout]:t:' \
          '-chunked[chunked transfer encoding]' \
          '-body=[request body file]:file:_files' \
          '*-header=[request header]:h:' \
          '-session-tickets[enable TLS session tickets]' \
          '-dns-ttl=[DNS TTL]:t:' \
          '-lazy[read targets lazily]' \
          '-max-body=[maximum body bytes to capture]:bytes:' \
          '-unix-socket=[connect via Unix socket]:socket:_files' \
          '-connect-to=[map ip:port to destination]:mapping:' \
          && ret=0 ;;
      (report)
        _arguments \
          '-type=[report type]:t:(text json hist hdrplot)' \
          '-buckets=[histogram buckets]:b:' \
          '-output=[output file]:file:_files' \
          '-every=[report interval]:t:' \
          '*:result file:_files' && ret=0 ;;
      (plot)
        _arguments \
          '-output=[output HTML]:file:_files' \
          '-threshold=[threshold]:n:' \
          '-title=[title]:t:' \
          '*:result file:_files' && ret=0 ;;
      (encode)
        _arguments \
          '-output=[output file]:file:_files' \
          '-to=[target format]:f:(csv json gob)' \
          '*:result file:_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
