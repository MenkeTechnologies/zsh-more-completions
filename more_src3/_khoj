#compdef khoj khoj-cli
# _khoj — Khoj AI khoj private personal AI assistant CLI for searching chatting with your knowledge corpus (khoj-ai team, Python); argparse
# upstream: https://github.com/khoj-ai/khoj

_khoj() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--config-file=+[config file]:file:_files -g "*.yml *.yaml"' \
        '--regenerate[regenerate index]' \
        '-r[regenerate index]' \
        '--port=+[port]:port:_ports' \
        '-p+[port]:port:_ports' \
        '--host=+[host]:host:_hosts' \
        '--socket=+[socket]:file:_files' \
        '--anonymous-mode[anonymous mode]' \
        '--no-gui[no GUI]' \
        '--no-tray[no tray icon]' \
        '--gpu=+[bool]:b:(true false)' \
        '--verbose=+[level]:n:' \
        '--disable-chat-on-gpu[disable chat on GPU]' \
        '--enable-chat-on-gpu[enable chat on GPU]' \
        '--non-interactive[non-interactive]' \
        '--sandbox[sandbox mode]' \
        '--demo[demo mode]'
}

_khoj "$@"
