#compdef xk6
# Documentation: upstream README at github.com/grafana/xk6
# Reference accessed: 2026-05-30
# Grafana xk6 R53 — CLI for developing k6 extensions. Sister-binary to
# existing _k6-cli coverage.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'new:scaffold a new extension project from a template'
  'build:compile a custom k6 binary with extensions'
  'run:execute a k6 test script with a freshly-built custom binary'
  'lint:validate extension source code against quality/security/compatibility standards'
  'test:run integration tests (supports glob + TAP/JSON reporting)'
  'x:execute subcommands provided by extensions'
  'sync:synchronize Go module dependencies with k6 versions'
)

local -a _new_templates
_new_templates=(javascript output subcommand)

local -a _lint_presets
_lint_presets=(loose strict private community official)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'xk6 subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      new)
        _arguments \
          '--template=[extension template]:template:($_new_templates)' \
          '1:extension name:' && ret=0
        ;;
      build)
        _arguments \
          '--with=[include extension (path/repo URL)]:extension:' \
          '--replace=[Go-module replace directive]:module:' \
          '--output=[output binary path]:file:_files' \
          '1:k6 version:' && ret=0
        ;;
      run)
        _arguments \
          '*:k6 args (test script + flags):_files' && ret=0
        ;;
      lint)
        _arguments \
          '--preset=[compliance preset]:preset:($_lint_presets)' \
          '*:extension path:_directories' && ret=0
        ;;
      test)
        _arguments \
          '--format=[reporting format]:format:(tap json)' \
          '*:test glob:' && ret=0
        ;;
      sync)
        _arguments \
          '1:extension path:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
