#compdef signoz-cli signoz
# _signoz-cli — SigNoz signoz-cli CLI command-line frontend wrapping the SigNoz open-source full-stack APM observability platform alternative to Datadog NewRelic providing install upgrade restart status logs ports collect query alert dashboard service-map flamegraph trace exception metrics ingest OTLP-Jaeger-Zipkin ClickHouse-backed traces-metrics-logs (SigNoz team Pranay Prateek, Go/TypeScript); cobra
# upstream: https://signoz.io/

_signoz-cli() {
    local -a sub=(
        'install:install SigNoz'
        'upgrade:upgrade SigNoz'
        'start:start SigNoz'
        'stop:stop SigNoz'
        'restart:restart SigNoz'
        'status:status'
        'logs:tail logs'
        'ports:show ports'
        'config:configuration'
        'query:run a query'
        'alert:alert operations'
        'dashboard:dashboard operations'
        'trace:trace operations'
        'service:service operations'
        'metric:metric operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-token=+[token]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--tenant=+[name]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "signoz.yml *.yml *.yaml"' \
        '--config=+[file]:file:_files -g "signoz.yml *.yml *.yaml"' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'signoz subcommand' sub ;;
        args)
            case $words[1] in
                install|upgrade) _arguments '1:platform:(docker docker-swarm kubernetes helm)' '*:arg:' ;;
                alert|dashboard|trace|service|metric) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_signoz-cli "$@"
