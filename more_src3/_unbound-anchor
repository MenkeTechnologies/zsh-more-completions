#compdef unbound-anchor
# _unbound-anchor — NLnet Labs unbound-anchor (DNSSEC root trust anchor bootstrap/updater; RFC 5011 tracking + RFC 7958 HTTPS fallback fetch of root-anchors.xml/p7s)
# upstream: https://github.com/NLnetLabs/unbound
# Flags from smallapp/unbound-anchor.c + doc/unbound-anchor.8.in on tip.

_unbound-anchor() {
    _arguments \
        '(- *)-h[show help + version]' \
        '-a+[root anchor key file]:file:_files' \
        '-c+[root update certificate file]:file:_files' \
        '-l[list builtin root key + cert to stdout]' \
        '-u+[server hostname to fetch from (default data.iana.org)]:host:_hosts' \
        '-S[do not use SNI for HTTPS]' \
        '-b+[source bind address]:ip:' \
        '-x+[server path to root-anchors.xml]:path:' \
        '-s+[server path to root-anchors.p7s]:path:' \
        '-n+[expected signer emailAddress (use "" to disable check)]:email:' \
        '-4[force IPv4]' \
        '-6[force IPv6]' \
        '-f+[resolv.conf to use]:file:_files' \
        '-r+[root.hints file]:file:_files' \
        '-R[allow fallback to direct root query when -f resolver fails]' \
        '*-v[verbose (repeat for more)]' \
        '-C+[debug: read unbound.conf into the resolver]:file:_files' \
        '-P+[HTTPS port]:port:' \
        '-F[force HTTPS xml/p7s update path]'
}

_unbound-anchor "$@"
