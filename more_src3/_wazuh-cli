#compdef wazuh-cli wazuhcli
# _wazuh-cli — Wazuh Inc wazuh-cli CLI command-line frontend to the Wazuh Open Source XDR SIEM unified Threat Detection and Response platform fork of OSSEC managing agents alerts rules decoders configuration manager-cluster api groups syscheck rootcheck logcollector reports security-events FIM SCA MITRE-ATT&CK (Wazuh team, Python); click
# upstream: https://wazuh.com/

_wazuh-cli() {
    local -a sub=(
        'agents:agent operations'
        'manager:manager operations'
        'cluster:cluster operations'
        'rules:rule operations'
        'decoders:decoder operations'
        'groups:group operations'
        'lists:list operations'
        'alerts:alert operations'
        'events:event operations'
        'mitre:MITRE ATT&CK mapping'
        'security:security operations'
        'sca:SCA security configuration assessment'
        'syscheck:syscheck operations'
        'rootcheck:rootcheck operations'
        'syscollector:syscollector operations'
        'vulnerability:vulnerability scanner'
        'api:API status'
        'auth:authentication'
        'config:configuration'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--cluster-node=+[name]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.conf"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.conf"' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wazuh-cli subcommand' sub ;;
        args)
            case $words[1] in
                agents|manager|cluster|rules|decoders|groups|lists) _arguments '1:op:(list get add update delete restart status info)' '*:id-or-name:' ;;
                alerts|events|mitre|sca|syscheck|rootcheck|syscollector|vulnerability) _arguments '1:op:(list search query stats)' '*:agent id:' ;;
            esac
            ;;
    esac
}

_wazuh-cli "$@"
