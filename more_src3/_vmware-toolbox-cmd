#compdef vmware-toolbox-cmd
# Documentation: https://github.com/vmware/open-vm-tools/blob/master/open-vm-tools/toolbox/toolbox-cmd.c
# Reference accessed: 2026-05-21
# Verified: upstream open-vm-tools source code at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'config:control configuration options'
  'device:device management'
  'disk:disk management (shrink, wipe)'
  'gueststore:guest store access'
  'help:show help'
  'info:show info (uptime, etc)'
  'logging:control logging'
  'script:control suspend/resume scripts'
  'stat:show statistics'
  'timesync:control time synchronisation'
  'upgrade:VMware Tools upgrade control'
  'globalconf:global config management'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'vmware-toolbox-cmd command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (timesync)
        _values 'op' enable disable status && ret=0 ;;
      (disk)
        _values 'op' list shrink shrinkonly wipe && ret=0 ;;
      (info)
        _values 'op' update uptime hosttime build deviceconfig logiosize logiopath logging guestid guestinfo && ret=0 ;;
      (logging)
        _values 'op' level && ret=0 ;;
      (stat)
        _values 'op' balloon cpures cpulimit hostmem memlimit memres memswap memused raw sessionid speed && ret=0 ;;
      (upgrade)
        _values 'op' status start && ret=0 ;;
      (device)
        _values 'op' list status enable disable && ret=0 ;;
      (config)
        _arguments \
          '1:op:(get set remove)' \
          '*:section_key_value:' && ret=0 ;;
    esac ;;
esac

return ret
