#compdef kubectl-ingress-nginx
# kubectl-ingress-nginx (krew plugin): inspect and manage ingress-nginx
# https://github.com/kubernetes/ingress-nginx

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    local -a commands=(
      'backends:inspect dynamic backends'
      'certs:output the certificate data in an ingress-nginx pod'
      'conf:inspect the nginx.conf'
      'exec:execute a command inside an ingress-nginx pod'
      'general:inspect the general dynamic config'
      'info:show cluster info about ingress-nginx'
      'ingresses:display list of ingresses with backends'
      'lint:inspect nginx configuration for errors'
      'logs:get logs of the ingress-nginx controller'
      'ssh:open a SSH session to an ingress-nginx pod'
    )
    _describe -t commands 'kubectl ingress-nginx command' commands && ret=0
    ;;
  args)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--deployment=[ingress-nginx deployment name]:name' \
      '--namespace=[namespace of ingress-nginx]:namespace:_guard "^-*" namespace' \
      '--pod=[specific ingress-nginx pod name]:pod' \
      '--context=[kubernetes context]:context' \
      '--kubeconfig=[path to kubeconfig]:file:_files' \
      '--host=[host to filter on]:host' \
      '*:args' && ret=0
    ;;
esac

return ret
