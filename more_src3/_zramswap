#compdef zramswap
# _zramswap — Debian Linux zramswap CLI service-wrapper around /sys/block/zram* compressed RAM block devices configuring lzo lz4 zstd lz4hc compression streams swap priority percent-of-physical-RAM allocation start stop status restart subcommands for the systemd-managed zramswap.service (Debian team, shell); custom argparse
# upstream: https://github.com/highvoltage/zram-tools

_zramswap() {
    local -a sub=(
        'start:start zram-managed swap devices'
        'stop:stop zram-managed swap devices'
        'restart:restart zram-managed swap'
        'status:show zram swap status'
        'config:show effective config'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'zramswap subcommand' sub ;;
    esac
}

_zramswap "$@"
