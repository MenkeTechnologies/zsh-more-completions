#compdef stathist
# Documentation: man stathist(8)
# Source: InterNetNews/inn contrib/stathist.in — parse innd history profiler logs (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '1::logfile:_files' \
    && ret=0

return ret
