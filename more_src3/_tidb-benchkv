#compdef tidb-benchkv
# _tidb-benchkv — TiDB transactional KV benchmark (txnkv)
# upstream: https://github.com/pingcap/tidb
# Flags from cmd/benchkv/main.go on tip.

_tidb-benchkv() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-N=[data row count]:n:' \
        '-C=[concurrent workers]:n:' \
        '-pd=[PD address]:host\:port:' \
        '-V=[value byte size]:n:'
}

_tidb-benchkv "$@"
