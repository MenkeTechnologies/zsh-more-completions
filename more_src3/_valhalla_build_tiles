#compdef valhalla_build_tiles
# Documentation: https://github.com/valhalla/valhalla
# Source: valhalla/valhalla src/mjolnir/valhalla_build_tiles.cc — build the routing graph tile hierarchy from .osm.pbf.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-c --config)'{-c+,--config=}'[path to JSON config file]:file:_files -g "*.json(-.)"' \
    '(-i --inline-config)'{-i+,--inline-config=}'[inline JSON config]:json:_default' \
    '(-s --start)'{-s+,--start=}'[start stage of build pipeline]:stage:(initialize parsing constructedges build enhance filter hierarchy shortcuts restrictions validate elevation cleanup)' \
    '(-e --end)'{-e+,--end=}'[end stage of build pipeline]:stage:(initialize parsing constructedges build enhance filter hierarchy shortcuts restrictions validate elevation cleanup)' \
    '(-j --concurrency)'{-j+,--concurrency=}'[number of threads (default all)]:n:_default' \
    '*:OSM PBF file:_files -g "*.osm.pbf(-.)"' \
    && ret=0

return ret
