#compdef i2cdump
# _i2cdump — Linux i2c-tools i2cdump CLI for examining the registers visible to an I2C device printing register dump in hexadecimal supporting byte word SMBus block I2C-block consecutive byte mode (i2c-tools team, C); getopt
# upstream: https://git.kernel.org/pub/scm/utils/i2c-tools/i2c-tools.git

_i2cdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-y[disable interactive confirm]' \
        '-f[force]' \
        '-r+[register range]:str:' \
        '-c[consecutive byte mode]' \
        '-a[allow addresses 0x00-0x07 and 0x78-0x7f]' \
        '*:i2cbus chip-address mode bank bankreg:'
}

_i2cdump "$@"
