#compdef sqlfmt
# Documentation: https://github.com/tconbeer/sqlfmt
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--check[verify files are properly formatted without modifying]' \
  '--diff[show differences between current and formatted versions]' \
  '(-l --line-length)'{-l+,--line-length=}'[desired line length]:length:' \
  '--quiet[suppress output messages]' \
  '--verbose[enable detailed output]' \
  '--no-jinjafmt[disable Jinja template formatting]' \
  '--reset-cache[clear formatting cache]' \
  '--dialect=[SQL dialect]:dialect:(polyglot clickhouse)' \
  '*--exclude=[exclude directories or patterns]:pattern:' \
  '*:file:_files' && ret=0

return ret
