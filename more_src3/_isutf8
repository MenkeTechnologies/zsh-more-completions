#compdef isutf8
# Documentation: isutf8 --help (moreutils)
# Source: check whether input files are valid UTF-8.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    {-q,--quiet}'[suppress normal output]' \
    {-l,--list}'[only print invalid file names]' \
    {-i,--invert}'[list valid UTF-8 files instead]' \
    {-v,--verbose}'[print detailed error]' \
    '*:file:_files' \
    && ret=0

return ret
