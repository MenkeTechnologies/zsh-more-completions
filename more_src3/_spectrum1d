#compdef spectrum1d
# Documentation: https://docs.generic-mapping-tools.org/latest/spectrum1d.html
# Source: GenericMappingTools/gmt src/spectrum1d.c — compute auto- and cross-spectra via Welch's method (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-S+[segment size for Welch averaging]:size:_default' \
    '-C+[output options (xycnpago combo)]:opts:_default' \
    '-D+[sampling interval]:dt:_default' \
    '-L+[detrend mode]:mode:(h m)' \
    '-N+[output filename stem]:stem:_default' \
    '-T[disable single-table stdout output]' \
    '-W[output wavelength in column 1 (not freq)]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[segment gaps]:gap:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-qi+[record selection]:cols:_default' \
    '-s+[skip records with NaN]:cols:_default' \
    '*:input table:_files' \
    && ret=0

return ret
