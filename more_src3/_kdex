#compdef kdex
# Documentation: https://github.com/urbanisierung/kdex
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Source: clap-generated completion (kdex completions zsh); upstream
# README confirms index/search/add/list/remove/sync/update/mcp/watch.

autoload -U is-at-least

_kdex() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--json[Output as JSON]' \
'--quiet[Suppress non-error output]' \
'--no-color[Disable colored output]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'--debug[Enable debug output with backtraces]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_kdex_commands" \
"*::: :->kdex" \
&& ret=0
    case $state in
    (kdex)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:kdex-command-$line[1]:"
        case $line[1] in
            (index)
_arguments "${_arguments_options[@]}" : \
'--name=[Custom name for the repository]:NAME:_default' \
'--json[Output as JSON]' \
'--quiet[Suppress non-error output]' \
'--no-color[Disable colored output]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'--debug[Enable debug output with backtraces]' \
'-h[Print help]' \
'--help[Print help]' \
'::path -- Directory to index (defaults to current directory):_files' \
&& ret=0
;;
(add)
_arguments "${_arguments_options[@]}" : \
'-r+[Add a remote GitHub repository]:REMOTE:_default' \
'--remote=[Add a remote GitHub repository]:REMOTE:_default' \
'--branch=[Branch to clone (for remote repos)]:BRANCH:_default' \
'--name=[Custom name for the repository]:NAME:_default' \
'--shallow[Use shallow clone (faster, less disk space)]' \
'--json[Output as JSON]' \
'--quiet[Suppress non-error output]' \
'--no-color[Disable colored output]' \
'-v[Enable verbose output]' \
'--verbose[Enable verbose output]' \
'--debug[Enable debug output with backtraces]' \
'-h[Print help]' \
'--help[Print help]' \
