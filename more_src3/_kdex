&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-r+[Filter by repository name]:REPO:_default' \
'--repo=[Filter by repository name]:REPO:_default' \
'-t+[Filter by file type (code, markdown, config)]:FILE_TYPE:_default' \
'--file-type=[Filter by file type (code, markdown, config)]:FILE_TYPE:_default' \
'--tag=[Filter by tag (from frontmatter)]:TAG:_default' \
'-l+[Maximum number of results]:LIMIT:_default' \
'--limit=[Maximum number of results]:LIMIT:_default' \
'-g[Group results by repository]' \
'--group-by-repo[Group results by repository]' \
'(-H --hybrid --lexical --fuzzy --regex)-s[Use semantic (vector) search]' \
'(-H --hybrid --lexical --fuzzy --regex)--semantic[Use semantic (vector) search]' \
'(-s --semantic --lexical --fuzzy --regex)-H[Use hybrid search (combines lexical + semantic)]' \
