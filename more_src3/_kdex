(( $+functions[_kdex_commands] )) ||
_kdex_commands() {
    local commands; commands=(
'index:Index a directory (code repository or knowledge base)' \
'add:Add a repository (local or remote GitHub)' \
'search:Search indexed content' \
'update:Update an existing index' \
'sync:Sync remote repositories with their origins' \
'list:List all indexed repositories' \
'remove:Remove a repository from the index' \
'config:Show or edit configuration' \
'mcp:Start MCP server for AI tool integration' \
'watch:Watch for file changes and re-index automatically' \
'rebuild-embeddings:Rebuild embeddings for semantic search' \
'completions:Generate shell completions' \
'backlinks:Find files that link to a target file (backlinks)' \
'tags:List all tags from indexed files' \
'context:Build AI context from search results' \
'stats:Show knowledge index statistics' \
'graph:Export knowledge graph visualization' \
'health:Check knowledge index health' \
'add-mcp:Configure MCP integration for AI tools' \
'self-update:Update kdex to the latest version' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'kdex commands' commands "$@"
}
