#compdef impacket-findDelegation
# Documentation: https://github.com/fortra/impacket/blob/master/examples/findDelegation.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-findDelegation: find Kerberos delegation rights in AD.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-target-domain[domain to query if different from user domain]:domain:' \
  '-user[request data for specific user]:user:' \
  '-disabled[include disabled users in query]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-dc-host[domain controller hostname]:host:_hosts' \
  '*::positional:_files' && ret=0
return ret
