#compdef tsc
# Documentation: https://www.typescriptlang.org/docs/handbook/compiler-options.html
# Source: microsoft/TypeScript — `tsc` CLI commands + build/watch options.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--all[show all compiler options]' \
    '(- *)--help[help on the CLI]' \
    '--ignoreConfig[ignore tsconfig and use CLI options only]' \
    '(- *)--init[create a new tsconfig.json]' \
    '(- *)--listFilesOnly[print files in compilation and stop]' \
    '--locale=[language of TypeScript messages]:locale:' \
    '(-p --project)'{-p+,--project=}'[path to tsconfig.json or project dir]:project:_files' \
    '(- *)--showConfig[print final config instead of building]' \
    '(- *)--version[print version]' \
    '--build[build one or more projects + dependencies]' \
    '--clean[delete outputs of all projects]' \
    '--dry[show what would be built or deleted]' \
    '--force[build all projects even if up to date]' \
    '--verbose[verbose logging]' \
    '(-w --watch)'{-w,--watch}'[watch input files]' \
    '*--excludeDirectories=[directories to skip in watch]:dir:_directories' \
    '*--excludeFiles=[files to skip in watch]:file:_files' \
    '--fallbackPolling=[watcher fallback approach]:mode:(fixedInterval priorityInterval dynamicPriority fixedChunkSize)' \
    '--synchronousWatchDirectory[synchronous directory-watcher callbacks]' \
    '--watchDirectory=[directory watcher mode]:mode:(useFsEvents fixedPollingInterval dynamicPriorityPolling fixedChunkSizePolling)' \
    '--watchFile=[file watcher mode]:mode:(fixedPollingInterval priorityPollingInterval dynamicPriorityPolling fixedChunkSizePolling useFsEvents useFsEventsOnParentDirectory)' \
    '*:source file:_files -g "*.(ts|tsx|mts|cts|d.ts)"' \
    && ret=0

return ret
