#compdef so-elastic-fleet
# _so-elastic-fleet — Security Onion so-elastic-fleet CLI for managing Elastic Fleet server and Elastic Agents enrolling unenrolling reassigning policies syncing artifacts across Security Onion deployment (security-onion team, Bash); getopt
# upstream: https://github.com/Security-Onion-Solutions/securityonion

_so-elastic-fleet() {
    local -a sub=(
        'enroll:enroll new agent'
        'unenroll:unenroll agent'
        'list:list agents'
        'reassign:reassign agent policy'
        'upgrade:upgrade agent'
        'policy:policy operations'
        'integration:integration operations'
        'package:package operations'
        'sync:sync artifacts'
        'status:show fleet status'
        'reset:reset fleet'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[node]:str:' \
        '--node=+[node]:str:' \
        '-f[force]' \
        '--force[force]' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'so-elastic-fleet subcommand' sub ;;
        args)
            case $words[1] in
                enroll) _arguments \
                    '--policy=+[policy id or name]:str:' \
                    '--api-key=+[key]:str:' \
                    '--server=+[url]:str:' \
                    '--cert=+[file]:file:_files' \
                    '*:host:_hosts' ;;
                unenroll|reassign|upgrade) _arguments \
                    '--agent-id=+[id]:str:' \
                    '--policy=+[policy id or name]:str:' ;;
                policy|integration|package) _arguments \
                    '1:action:(list create delete update info)' \
                    '*:name:' ;;
            esac
            ;;
    esac
}

_so-elastic-fleet "$@"
