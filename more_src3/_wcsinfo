#compdef wcsinfo
# Documentation: https://astrometry.net/
# Source: dstndstn/astrometry.net util/wcsinfo.c — print WCS info from a FITS WCS header.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-e+[FITS HDU number (default 0)]:n:_default' \
    '-W+[set/override IMAGEW]:width:_default' \
    '-H+[set/override IMAGEH]:height:_default' \
    '1:wcs file:_files -g "*.(wcs|fits|fit|fts)(-.)"' \
    && ret=0

return ret
