#compdef hazelcast-cli hz-cli
# _hazelcast-cli — Hazelcast hazelcast-cli CLI command-line frontend wrapping the Hazelcast Platform open-source in-memory distributed computing platform unifying IMDG and Jet streaming providing start stop list cluster-state version member-list management-center submit jet-job snapshot save restore cancel resume suspend export-data-link import sql-output mc-cmd jet-job-cluster-management (Hazelcast Inc team, Java); picocli
# upstream: https://hazelcast.com/

_hazelcast-cli() {
    local -a sub=(
        'start:start a member'
        'stop:stop a member'
        'list:list members'
        'cluster:cluster commands'
        'submit:submit a Jet job'
        'cancel:cancel a Jet job'
        'snapshot:snapshot commands'
        'save-snapshot:save snapshot'
        'restore:restore from snapshot'
        'resume:resume a job'
        'suspend:suspend a job'
        'list-jobs:list Jet jobs'
        'sql:open SQL prompt'
        'mc:Management Center commands'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--targets=+[host:port]:_hosts' \
        '-t+[host:port]:_hosts' \
        '--config=+[file]:file:_files -g "hazelcast-client.yml *.yaml *.xml"' \
        '-f+[file]:file:_files -g "hazelcast-client.yml *.yaml *.xml"' \
        '--cluster-name=+[name]:str:' \
        '-n+[name]:str:' \
        '--credentials=+[user:password]:str:' \
        '--token=+[token]:str:' \
        '--jet-config=+[file]:file:_files -g "hazelcast-jet.yml"' \
        '--max-snapshots=+[N]:n:' \
        '--snapshot-interval=+[ms]:n:' \
        '--processing-guarantee=+[g]:g:(none at-least-once exactly-once)' \
        '--name=+[job name]:str:' \
        '--class=+[class]:str:' \
        '--main-class=+[class]:str:' \
        '--snapshot=+[name]:str:' \
        '--retry-strategy=+[s]:s:(none custom-retry)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'hazelcast subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments '*:jar:_files -g "*.jar"' ;;
                cluster) _arguments '1:op:(get-state change-state shutdown version)' '*:arg:' ;;
            esac
            ;;
    esac
}

_hazelcast-cli "$@"
