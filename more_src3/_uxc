#compdef uxc
# ============================================================================
# _uxc — zsh completion for holon-run/uxc, "a unified CLI for discovering
#         and invoking tools across OpenAPI, MCP, GraphQL, gRPC, and JSON-
#         RPC" — Rust=148 leader bump OPENING Axis 93 (OpenAPI / openapiv3
#         schema library)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/holon-run/uxc
#   Maintainer : Holon Run
#   License    : MIT
#   Stars      : 110
#   Language   : Rust
#   Crate      : uxc  (Cargo.toml [package] name = "uxc";
#                       [[bin]] name = "uxc")
#   Binary     : uxc  (Universal X-Protocol CLI)
#   Last push  : 2026-05-26
#
# WHAT IT IS
#   uxc is "the universal X-protocol CLI" — a single command-line
#   tool that auto-detects whether a target endpoint speaks
#   OpenAPI, Model Context Protocol (MCP), GraphQL, gRPC, or
#   JSON-RPC, downloads + caches the schema, and invokes any
#   operation with typed argument coercion (`key=value` for
#   primitives, `key:=value` for raw JSON, nested-path syntax
#   `parent.child[0]=value`).  Companion features include a
#   `daemon` for warm subprocess sessions (used heavily by MCP
#   stdio servers), a `link` command that creates host-bound
#   shortcuts under `~/.local/bin`, a `source` + `stream`
#   subsystem for managed long-running subscriptions
#   (WebSocket / Discord Gateway / Slack Socket Mode / Feishu /
#   GraphQL subscriptions / JSON-RPC subscriptions / polling),
#   a `cache` manager, and an `auth` credential-store + binding
#   system that resolves credentials per-host with optional
#   `--inject-env` for stdio child processes.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs `Cli` /
#                       `Commands` clap-derive enum — clap 4
#                       with derive feature)
#   uxc [GLOBAL OPTIONS] [<URL>] [<OPERATION_ID> [args...]]
#   uxc <SUBCOMMAND> [args...]
#
#   Global options (apply to every subcommand):
#     -h, --help                     Show help
#     --daemon-exclusive <KEY>       Exclusive daemon state key
#                                    for MCP stdio session
#                                    eviction (repeatable)
#     --daemon-idle-ttl <SECS>       Idle TTL for reused MCP
#                                    stdio daemon sessions
#                                    (0 disables idle reaping)
#     --auth <CREDENTIAL_ID>         Override endpoint binding
#                                    auto-match
#     --inject-env <NAME={{secret}}> Inject resolved credential
#                                    into stdio child env
#                                    (repeatable)
#     --no-cache                     Disable cache for this op
#     --cache-ttl <SECS>             Cache TTL
#     --timeout-ms <MS>              Per-request timeout
#     --refresh-schema               Force online schema
#                                    discovery + refresh cache
#                                    (conflicts with --no-cache)
#     --schema-url <URL>             Explicit OpenAPI schema URL
#     --codegen-schema               Export runtime codegen
#                                    schema input
#     --format <FORMAT>              Output format (json|text)
#                                    (conflicts with --text)
#     --text                         Use human-readable text
#                                    output
#
#   Subcommands:
#     config import mcp              Import an MCP client/editor
#                                    config into a uxc link /
#                                    auth / binding plan
#       --from <SOURCE>                Source path or preset
#                                      (default: auto)
#
#     cache <SUBCMD>                 Manage schema cache
#                                    (list / show / clear /
#                                     refresh)
#
#     auth <SUBCMD>                  Manage credentials +
#                                    bindings
#                                    (credential / binding /
#                                     oauth / login / list /
#                                     show / set / delete)
#
#     link <NAME> <HOST>             Create a host-bound
#                                    shortcut command
#       --dir <DIR>                    Install directory
#                                      (default: ~/.local/bin
#                                       on Unix, ~/.uxc/bin on
#                                       Windows)
#       --schema-url <URL>             Persisted OpenAPI URL
#       --credential <ID>              Persisted --auth value
#       --skill <NAME>                 Persisted skill name
#       --skill-doc <URL>              Skill docs URL
#       --skill-path <PATH>            Skill local path
#       --force                        Overwrite existing
#                                      shortcut
#
#     daemon <SUBCMD>                Manage local runtime daemon
#                                    (start / stop / status /
#                                     log / list)
#
#     source <SUBCMD>                Manage daemon-backed
#                                    managed sources
#                                    (add / remove / list /
#                                     start / stop / restart)
#
#     stream <SUBCMD>                Read managed source streams
#                                    (read / tail / clear)
#
#   Dynamic operation form (no recognized subcommand):
#     <URL>                          Remote endpoint URL
#     <OPERATION_ID>                 Auto-detected operation
#                                    from the endpoint's schema
#     <KEY=VALUE>...                 Primitive argument
#                                    assignments
#     <KEY:=JSON_VALUE>...           Typed JSON argument
#                                    assignments
#     <PARENT.CHILD[N]=VALUE>        Nested-path argument
#                                    assignments
#     '{...}'                        Single JSON payload
#                                    (overrides per-key args)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `openapiv3 = "1.0"` declared in
#   Cargo.toml — `openapiv3` is THE canonical Rust OpenAPI v3
#   schema library maintained by the glade-rs / kurtbuilds
#   ecosystem (kurtbuilds/openapiv3, the predominant Rust
#   typed deserializer for OpenAPI 3.0.x / 3.1.x JSON / YAML
#   schemas).  openapiv3 exposes `openapiv3::OpenAPI` with
#   `Info`, `Server`, `Paths`, `PathItem`, `Operation` —
#   typed `RequestBody`, `Response`, `Parameter`, `Components`,
#   `Schema` with `SchemaKind::Type(Type::Object|Array|String|
#   Number|Integer|Boolean)`, `ReferenceOr<T>` for `$ref`
#   resolution, `MediaType`, `Encoding`, `Header`, `Link`,
#   `Callback`, `SecurityScheme` (HTTP / API key / OAuth2 /
#   OpenID Connect), and full Discriminator + AllOf/OneOf/AnyOf
#   composition.  uxc's `src/adapters/openapi/` constructs a
#   typed `openapiv3::OpenAPI` from the schema URL, walks every
#   `Paths.iter()` entry, coerces user args against the
#   `Schema` for the operation's `RequestBody`, then issues a
#   typed `reqwest` call.  Verified via:
#     gh api repos/holon-run/uxc/contents/Cargo.toml
#       → openapiv3 = "1.0"
#       → [package] name = "uxc"; license = "MIT"
#       → [[bin]] name = "uxc"; path = "src/main.rs"
#     gh api repos/holon-run/uxc/contents/src/main.rs
#       → #[derive(Parser)] struct Cli { url, command, --auth,
#                                          --no-cache, --cache-
#                                          ttl, --timeout-ms,
#                                          --refresh-schema,
#                                          --schema-url, ... }
#       → enum Commands { Config{...}, Cache{...}, Auth{...},
#                          Link{...}, Daemon{...}, Source{...},
#                          Stream{...}, External(Vec<String>) }
#   This entry is the Rust=148 leader bump that OPENS Axis 93
#   (OpenAPI / openapiv3 schema library) at 1/0/0.  Pairing
#   Go and TS-Node bumps will follow at R962 and R963 (Go=148
#   candidates getkin/kin-openapi-based CLIs; TS-Node=148
#   candidates openapi-typescript / @apidevtools/swagger-parser
#   users).
#
#   No completion for `uxc` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_uxc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '*--daemon-exclusive=[exclusive daemon state key (repeatable)]:key:' \
        '--daemon-idle-ttl=[idle TTL in seconds (0 disables idle reaping)]:secs:' \
        '--auth=[explicit credential ID]:id:' \
        '*--inject-env=[inject resolved credential into stdio child env]:name\=secret:' \
        '--no-cache[disable cache for this operation]' \
        '--cache-ttl=[cache TTL in seconds]:secs:' \
        '--timeout-ms=[per-request timeout in ms]:ms:' \
        '--refresh-schema[force online schema discovery]' \
        '--schema-url=[explicit OpenAPI schema URL]:url:' \
        '--codegen-schema[export runtime codegen schema input]' \
        '--format=[output format]:format:(json text)' \
        '--text[use human-readable text output]' \
        '1: :_uxc_commands_or_url' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                config)
                    _arguments \
                        '1:config subcommand:(import)' \
                        '*::arg:->config_args' && ret=0
                    case $state in
                        config_args)
                            case $words[1] in
                                import)
                                    _arguments \
                                        '1:import target:(mcp)' \
                                        '--from=[source path or preset]:source:' && ret=0 ;;
                            esac
                            ;;
                    esac
                    ;;
                cache)
                    _arguments \
                        '1:cache subcommand:(list show clear refresh)' \
                        '*::arg:' && ret=0 ;;
                auth)
                    _arguments \
                        '1:auth subcommand:(credential binding oauth login list show set delete)' \
                        '*::arg:' && ret=0 ;;
                link)
                    _arguments \
                        '--dir=[install directory]:dir:_files -/' \
                        '--schema-url=[persisted OpenAPI URL]:url:' \
                        '--credential=[persisted credential ID]:id:' \
                        '--skill=[persisted skill name]:skill:' \
                        '--skill-doc=[skill docs URL]:url:' \
                        '--skill-path=[skill local path]:path:_files' \
                        '--force[overwrite existing shortcut]' \
                        ':shortcut name:' \
                        ':host:' && ret=0 ;;
                daemon)
                    _arguments \
                        '1:daemon subcommand:(start stop status log list)' \
                        '*::arg:' && ret=0 ;;
                source)
                    _arguments \
                        '1:source subcommand:(add remove list start stop restart)' \
                        '*::arg:' && ret=0 ;;
                stream)
                    _arguments \
                        '1:stream subcommand:(read tail clear)' \
                        '*::arg:' && ret=0 ;;
                *)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_uxc_commands_or_url] )) ||
_uxc_commands_or_url() {
    local -a commands
    commands=(
        'config:import and normalize external runtime configs'
        'cache:manage schema cache'
        'auth:manage authentication credentials and bindings'
        'link:create a host-bound shortcut command'
        'daemon:manage local runtime daemon'
        'source:manage daemon-backed managed sources'
        'stream:read managed source streams'
    )
    _describe -t commands 'uxc command (or endpoint URL)' commands
}

_uxc "$@"
