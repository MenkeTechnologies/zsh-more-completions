#compdef hostapd-cli
# _hostapd-cli — Jouni Malinen hostapd_cli interactive client for hostapd CLI alias (jmalinen team, C); custom argparse
# upstream: https://w1.fi/hostapd/

_hostapd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-i+[interface]:_net_interfaces' \
        '-p+[control socket path]:dir:_files -/' \
        '-P+[pid file]:file:_files' \
        '-a+[action script]:file:_files' \
        '-r+[reconnect attempt seconds]:n:' \
        '-G+[grouping]:n:' \
        '-B[run in background]' \
        '-s+[server]:host:_hosts' \
        '*:command:(ping mib relog status sta all_sta new_sta deauthenticate disassociate signature poll_sta stop_ap reload wps_pin wps_pbc wps_check_pin wps_cancel wps_nfc_tag_read wps_nfc_config_token wps_nfc_token wps_get_status nfc_get_handover_sel nfc_get_handover_req nfc_report_handover wps_ap_pin wps_config get_config license interface chan_switch req_lci req_range driver_flags vendor erp_flush log_level set get hs20_wnm_notif hs20_deauth_req disassoc_imminent ess_disassoc bss_tm_req coloc_intf_req mesh_pmksa_add mesh_pmksa_del set_neighbor remove_neighbor req_beacon dpp_qr_code dpp_nfc_uri dpp_nfc_handover_req dpp_nfc_handover_sel dpp_bootstrap_gen dpp_bootstrap_remove dpp_bootstrap_get_uri dpp_bootstrap_info dpp_bootstrap_set dpp_auth_init dpp_listen dpp_stop_listen dpp_configurator_add dpp_configurator_remove dpp_configurator_get_key dpp_configurator_sign dpp_pkex_add dpp_pkex_remove dpp_chirp dpp_stop_chirp dpp_relay_add_controller dpp_relay_remove_controller dpp_controller_start dpp_controller_stop dpp_push_button accept_acl deny_acl quiet interactive help quit)'
}

_hostapd-cli "$@"
