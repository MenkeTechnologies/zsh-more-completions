#compdef sqawk
# _sqawk — Danyil Bohdan sqawk awk-like SQL query tool for plain text CLI alias (dbohdan team, Tcl); custom argparse
# upstream: https://github.com/dbohdan/sqawk

_sqawk() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--FS=+[input field separator]:str:' \
        '-FS+[input field separator]:str:' \
        '--RS=+[input record separator]:str:' \
        '-RS+[input record separator]:str:' \
        '--OFS=+[output field separator]:str:' \
        '-OFS+[output field separator]:str:' \
        '--ORS=+[output record separator]:str:' \
        '-ORS+[output record separator]:str:' \
        '--FX=+[field expansion]:str:' \
        '--MNF=+[max NF]:n:' \
        '--header=+[header line]:b:(0 1)' \
        '--prefix=+[column prefix]:str:' \
        '--table=+[table name]:str:' \
        '--format=+[input format]:f:(awk csv tsv json)' \
        '-format+[input format]:f:(awk csv tsv json)' \
        '--output=+[output format]:f:(awk csv tsv json table tcl)' \
        '-output+[output format]:f:(awk csv tsv json table tcl)' \
        '--database=+[sqlite db file]:file:_files -g "*.{db,sqlite,sqlite3}"' \
        '-database+[sqlite db file]:file:_files -g "*.{db,sqlite,sqlite3}"' \
        '--dbfile=+[sqlite db file]:file:_files' \
        '--noinput[no input from stdin]' \
        '-noinput[no input from stdin]' \
        '--query=+[SQL query]:str:' \
        '-1[interpret first arg as query]' \
        '*:query and files:_files'
}

_sqawk "$@"
