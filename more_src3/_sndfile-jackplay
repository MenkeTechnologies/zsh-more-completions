#compdef sndfile-jackplay
# Documentation: https://github.com/libsndfile/sndfile-tools/blob/master/man/sndfile-jackplay.1
# Reference accessed: 2026-05-16
# Verified: upstream libsndfile/sndfile-tools sndfile-jackplay(1)
# manpage.
# Removed from prior file: fabricated -V/--version flag and bogus
# man.archlinux.org search URL.

# sndfile-jackplay: JACK-based libsndfile audio player
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --wait)'{-w-,--wait=-}'[wait for input; optional auto-connect port]:port:' \
  '(-a --autoconnect)'{-a-,--autoconnect=-}'[auto-connect to JACK port]:port:' \
  '(-l --loop)'{-l-,--loop=-}'[loop file count times (0 = infinite)]:count:' \
  '*:audio file:_files' && ret=0
return ret
