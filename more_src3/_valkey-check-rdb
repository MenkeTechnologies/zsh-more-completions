#compdef valkey-check-rdb
# Documentation: https://valkey.io/topics/persistence/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# valkey-check-rdb: check Valkey RDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '*:RDB file:_files -g "*.rdb"' && ret=0
return ret
