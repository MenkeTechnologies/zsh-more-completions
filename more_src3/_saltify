#compdef saltify
# _saltify — SaltStack saltify CLI for the salt-cloud Saltify driver bootstrapping SaltStack masterless or master-managed minions on existing machines via SSH bootstrap salt-minion installer (saltstack team, Python); argparse
# upstream: https://github.com/saltstack/salt

_saltify() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-c+[config dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '-l+[log level]:l:(quiet critical error warning info debug trace garbage)' \
        '--log-level=+[log level]:l:(quiet critical error warning info debug trace garbage)' \
        '--log-file=+[file]:file:_files' \
        '--out=+[fmt]:f:(json nested pprint raw txt yaml)' \
        '--out-indent=+[N]:n:' \
        '-p+[profile]:str:' \
        '--profile=+[profile]:str:' \
        '-d[destroy]' \
        '--destroy[destroy]' \
        '-a+[action]:str:' \
        '--action=+[action]:str:' \
        '-f+[function]:str:' \
        '--function=+[function]:str:' \
        '-Q[query]' \
        '--query[query]' \
        '-F[full query]' \
        '--full-query[full query]' \
        '-S[select query]' \
        '--select-query[select query]' \
        '-L[show only key info]' \
        '--list-images[list images]' \
        '--list-sizes[list sizes]' \
        '--list-locations[list locations]' \
        '--list-providers[list providers]' \
        '-y[yes]' \
        '--assume-yes[yes]' \
        '--map=+[file]:file:_files -g "*.map *.sls"' \
        '--no-deploy[no deploy]' \
        '*:minion id:'
}

_saltify "$@"
