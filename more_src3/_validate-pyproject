#compdef validate-pyproject
# Documentation: https://validate-pyproject.readthedocs.io/en/latest/
# Reference accessed: 2026-06-04

# Zsh completion for validate-pyproject (validate pyproject.toml files)
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '--dump-json[dump the JSON Schema to stdout and exit]'
  '*--enable-plugins[enable additional validation plugins]:plugin name:'
  '*--disable-plugins[disable validation plugins]:plugin name:'
  '*--tool[specify tool sub-tables to validate]:tool name:'
  '*:pyproject.toml file:_files -g "*.toml"'
)

_arguments -s -S $arguments
