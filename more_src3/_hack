#compdef hack
# Documentation: man hack(6)
# Source: openbsd/src games/hack/hack.main.c — exploring dungeons (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[HACK directory]:dir:_files -/' \
    '-s[print score and exit]' \
    '-D[wizard mode (if compiled)]' \
    '-n[suppress news at startup]' \
    '-u+[player name]:name:_default' \
    '1::locknum:_default' \
    && ret=0

return ret
