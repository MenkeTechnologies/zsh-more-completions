#compdef lemminx
# Documentation: https://github.com/eclipse-lemminx/lemminx
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# STUB: LemMinX is an XML Language Server invoked by IDE/editor clients
# over LSP, not a user-facing CLI. The only documented runtime argument is
# `--port` for the XMLServerSocketLauncher debug launcher.

local ret=1

_arguments -s -S \
  '--port=[socket port for XMLServerSocketLauncher debug mode]:port:' \
  '*:file:_files' && ret=0

return ret
