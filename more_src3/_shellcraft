#compdef shellcraft
# Documentation: https://docs.pwntools.com/en/stable/commandline.html
# Reference accessed: 2026-05-30
# shellcraft — pwntools shellcode generator. Catalog of pre-built shellcodes
# (hierarchical names like `amd64.linux.sh`, `i386.linux.read`) with per-name
# argument lists. Encoding/output transformations applied after generation.

local curcontext="$curcontext" state line ret=1

# A few common shellcode names. The real catalog is much larger; this set
# covers the everyday-CTF picks. Users can still tab through arbitrary names.
local -a _names
_names=(
  'amd64.linux.sh:execve("/bin/sh") for x86-64 Linux'
  'amd64.linux.execve:explicit execve syscall on x86-64 Linux'
  'amd64.linux.cat:cat a file to stdout (amd64)'
  'amd64.linux.dupsh:dup stdio onto fd then exec shell'
  'amd64.linux.read:read syscall'
  'amd64.linux.write:write syscall'
  'amd64.linux.open:open syscall'
  'amd64.linux.connect:TCP connect-back'
  'amd64.linux.listen:bind+listen+accept'
  'i386.linux.sh:execve("/bin/sh") for i386 Linux'
  'i386.linux.execve:explicit execve syscall on i386 Linux'
  'i386.linux.dupsh:dup stdio onto fd then exec shell (i386)'
  'i386.linux.read:read syscall (i386)'
  'arm.linux.sh:execve("/bin/sh") for ARM Linux'
  'arm.linux.execve:explicit execve syscall on ARM Linux'
  'aarch64.linux.sh:execve("/bin/sh") for AArch64 Linux'
  'mips.linux.sh:execve("/bin/sh") for MIPS Linux'
  'thumb.linux.sh:execve("/bin/sh") for ARM Thumb mode'
  'common.nop:single nop instruction'
  'common.infloop:infinite loop'
  'common.debugbreak:trigger a debugger trap'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-\?,--show}'[show documentation for the selected shellcode]' \
  '(- *)'{-l,--list}'[list available shellcodes (optional filter)]' \
  '(--syscalls)--syscalls[list syscalls and exit]' \
  '(-o --out)'{-o,--out=}'[output file (default stdout)]:file:_files' \
  '(-f --format)'{-f,--format=}'[output format]:format:(r raw s str string c h hex a asm assembly p i hexii e elf d escaped default)' \
  '(-d --debug)'{-d,--debug}'[debug the shellcode with GDB]' \
  '--delim=[delimiter between multiple shellcodes]:delim:' \
  '(-b --before)'{-b,--before}'[insert debug trap before code]' \
  '(-a --after)'{-a,--after}'[insert debug trap after code]' \
  '(-v --avoid)'{-v,--avoid=}'[encode to avoid these hex bytes]:hex:' \
  '(-n --newline)'{-n,--newline}'[encode to avoid newline bytes]' \
  '(-z --zero)'{-z,--zero}'[encode to avoid NULL bytes]' \
  '(-r --run)'{-r,--run}'[execute the generated shellcode]' \
  '(--color --no-color)--color[colorize output]' \
  '(--color --no-color)--no-color[disable color output]' \
  '--address=[load address]:hex-address:' \
  '(-s --shared)'{-s,--shared}'[emit shared library ELF]' \
  '--arch=[override target architecture]:arch:(i386 amd64 arm aarch64 thumb mips mipsel mips64 mips64el powerpc sparc)' \
  '--os=[override target OS]:os:(linux freebsd windows baremetal android)' \
  '1:shellcode name:->name' \
  '*:shellcode argument:' \
  && ret=0

case $state in
  name)
    _describe -t shellcodes 'pwntools shellcode' _names && ret=0
    ;;
esac

return ret
