#compdef tz
# Documentation: https://github.com/oz/tz
# Reference accessed: 2026-05-21
# Verified: upstream main.go flag definitions.
# Removed from prior file: --help, --version, --list, --no-header
# (Go flag pkg uses single-dash, and -q is "exit immediately", not
# "no-header").

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-q[exit immediately]' \
  '-v[show version]' \
  '-when=[time in seconds since unix epoch (disables -w)]:epoch:' \
  '-list=[list or search zones by name]:filter:' \
  '-m[use 24-hour time]' \
  '-w[watch live, set time to now every minute]' \
  '*:timezone:_time_zone' && ret=0

return ret
