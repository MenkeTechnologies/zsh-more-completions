#compdef sendmail mailq newaliases
# _sendmail — Postfix sendmail-compatible interface (Sendmail-style CLI for mail submission + queue listing; binary is also installed as mailq and newaliases)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/sendmail.1 on tip; many Sendmail-only flags are accepted but silently ignored for compat.

_sendmail() {
    _arguments \
        '-Ac[(ignored) initial-submission config]' \
        '-Am[(ignored) MTA-submission config]' \
        '-B+[message body MIME type]:type:(7BIT 8BITMIME)' \
        '-bd[daemon mode (runs `postfix start`)]' \
        '-bh[(ignored) print persistent host status]' \
        '-bH[(ignored) purge persistent host status]' \
        '-bi[initialize alias database (alias for newaliases)]' \
        '-bl[daemon mode (use inet_interfaces=loopback in main.cf for local-only)]' \
        '-bm[deliver mail (default mode)]' \
        '-bp[list mail queue (alias for mailq)]' \
        '-bs[stand-alone SMTP server mode]' \
        '-bv[verify recipient addresses, do not deliver]' \
        '-C+[path to main.cf or its parent dir]:file:_files' \
        '-F+[set sender full name]:name:' \
        '-f+[envelope sender address]:sender:_email_addresses' \
        '-G[gateway/relay submission]' \
        '-h+[hop count limit]:n:' \
        '-I[initialize alias database (alias for newaliases)]' \
        '-i[do not treat dot as end-of-input]' \
        '-L+[syslog tag]:tag:' \
        '-m[do not send to self when expanding alias]' \
        '-N+[delivery status notification conditions]:dsn:(never failure delay success)' \
        '-n[(ignored) do not use aliases]' \
        '-O+[set main.cf parameter]:param=value:' \
        '-o7[force 7-bit transport]' \
        '-o8[allow 8-bit MIME]' \
        '-oi[do not treat dot as end-of-input]' \
        '-om[send to self when expanding alias]' \
        '-oA+[alias source file]:file:_files' \
        '-q[try to deliver queued mail (with -qIqueue-id or -qSsite or -qRrecipient)]' \
        '-R+[delivery mode]:mode:(hdrs full)' \
        '-t[read recipients from headers]' \
        '-U[(ignored) initial user submission]' \
        '-V+[envelope identifier]:envid:' \
        '-XV+[set envelope identifier with verp_delimiters]:envid:' \
        '-v[verbose mode]' \
        '*:recipient:_email_addresses'
}

_sendmail "$@"
