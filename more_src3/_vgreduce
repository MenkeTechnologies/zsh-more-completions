#compdef vgreduce
# _vgreduce — remove physical volume(s) from a volume group (LVM2)
# upstream: https://gitlab.com/lvmteam/lvm2

_vgreduce() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --all)'{-a,--all}'[reduce all missing pvs]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-f --force)'{-f,--force}'[force]' \
        '--removemissing[remove missing pvs]' \
        '--mirrorsonly[only mirror legs]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:vg or pv:_files'
}

_vgreduce "$@"
