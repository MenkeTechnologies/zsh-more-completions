#compdef tomcat-init
# Documentation: https://refspecs.linuxbase.org/LSB_3.0.0/LSB-Core-generic/LSB-Core-generic/iniscrptact.html
# Reference accessed: 2026-05-21
# Verified: LSB Core init-script action arguments. tomcat-init is a standard
# LSB-style System V init script for Apache Tomcat; the action arguments are
# those defined by the LSB Core spec (start/stop/restart/try-restart/
# reload/force-reload/status). `condrestart` is a RedHat/SysV extension
# accepted by most Tomcat init script packages.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start tomcat'
  'stop:stop tomcat'
  'restart:stop and restart tomcat'
  'reload:reload configuration'
  'status:show service status'
  'condrestart:restart only if currently running (RH/SysV)'
  'try-restart:restart only if currently running (LSB)'
  'force-reload:reload config or restart if running'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'tomcat-init command' commands && ret=0 ;;
esac

return ret
