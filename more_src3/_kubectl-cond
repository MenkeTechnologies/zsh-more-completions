#compdef kubectl-cond
# Documentation: https://github.com/ahmetb/kubectl-cond
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --filename)'{-f+,--filename=}'[query conditions from a manifest file]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[query across all namespaces]' \
  '*:args:_default'
