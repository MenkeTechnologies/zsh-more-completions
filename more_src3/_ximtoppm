#compdef ximtoppm
# Documentation: man ximtoppm (Netpbm)
# Source: convert an Xim (X image) file to PPM, with optional alpha mask.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--alphaout=[alpha output file (- for stdout)]:file:_files' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:xim file:_files' \
    && ret=0

return ret
