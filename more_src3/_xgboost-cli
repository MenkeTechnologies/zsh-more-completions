#compdef xgboost-cli xgboost2
# _xgboost-cli — DMLC XGBoost xgboost-cli CLI command-line frontend wrapping the XGBoost extreme gradient boosting library binary launcher for training and prediction with config-driven parameter management providing booster gbtree gblinear dart objective reg:squarederror binary:logistic multi:softmax rank:pairwise eval-metric (XGBoost team, C++); custom argparse
# upstream: https://xgboost.ai/

_xgboost-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--task=+[t]:t:(train pred eval dump)' \
        '--booster=+[b]:b:(gbtree gblinear dart)' \
        '--objective=+[o]:o:(reg:squarederror reg:squaredlogerror reg:logistic reg:pseudohubererror binary:logistic binary:logitraw binary:hinge count:poisson multi:softmax multi:softprob rank:pairwise rank:ndcg rank:map survival:cox survival:aft)' \
        '--eval-metric=+[m]:m:(rmse rmsle mae mape logloss error merror mlogloss auc aucpr ndcg map cox-nloglik aft-nloglik gamma-nloglik tweedie-nloglik gamma-deviance)' \
        '--data=+[file]:file:_files' \
        '--test-data=+[file]:file:_files' \
        '--eval-train[evaluate on training data]' \
        '--model-in=+[file]:file:_files -g "*.model *.bin *.json"' \
        '--model-out=+[file]:file:_files -g "*.model *.bin *.json"' \
        '--model-dir=+[dir]:dir:_files -/' \
        '--name-pred=+[file]:file:_files' \
        '--name-dump=+[file]:file:_files' \
        '--dump-format=+[f]:f:(json text)' \
        '--num-round=+[N]:n:' \
        '--max-depth=+[N]:n:' \
        '--eta=+[N]:str:' \
        '--gamma=+[N]:str:' \
        '--min-child-weight=+[N]:str:' \
        '--max-delta-step=+[N]:str:' \
        '--subsample=+[N]:str:' \
        '--colsample-bytree=+[N]:str:' \
        '--colsample-bylevel=+[N]:str:' \
        '--colsample-bynode=+[N]:str:' \
        '--lambda=+[N]:str:' \
        '--alpha=+[N]:str:' \
        '--tree-method=+[m]:m:(auto exact approx hist gpu_hist)' \
        '--device=+[d]:d:(cpu cuda gpu)' \
        '--predictor=+[p]:p:(auto cpu_predictor gpu_predictor)' \
        '--nthread=+[N]:n:' \
        '--seed=+[N]:n:' \
        '--save-period=+[N]:n:' \
        '*:config file:_files -g "*.conf *.cfg"'
}

_xgboost-cli "$@"
