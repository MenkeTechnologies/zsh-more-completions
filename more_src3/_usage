#compdef usage
# Documentation: https://usage.jdx.dev/cli/
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for usage - CLI usage specification tool

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bash:Generate bash completions'
      'fish:Generate fish shell completions'
      'zsh:Generate zsh completions'
      'powershell:Generate PowerShell completions'
      'generate:Generate completions, manpages, fig, json, markdown'
      'lint:Validate usage specifications'
      'exec:Execute a command using a usage spec'
      'complete-word:Handle word completion'
    )
    _describe -t commands 'usage command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      generate)
        local -a gen_cmds=(
          'completion:output shell completions'
          'completion-init:initialize completion setup'
          'fig:create Fig specifications'
          'json:export as JSON'
          'manpage:create man pages'
          'markdown:generate markdown documentation'
        )
        _describe -t commands 'generate subcommand' gen_cmds && ret=0
        ;;
      bash|fish|zsh|powershell)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[specify usage spec file]:file:_files' && ret=0
        ;;
      lint|exec|complete-word)
        _arguments -s -S \
          '(-f --file)'{-f,--file}'[specify usage spec file]:file:_files' \
          '*:args' && ret=0
        ;;
    esac
    ;;
esac

return ret
