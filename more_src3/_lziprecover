#compdef lziprecover
# Documentation: https://manpages.debian.org/bookworm/lziprecover/lziprecover.1.en.html
# Reference accessed: 2026-05-30
# lziprecover — Antonio Diaz Diaz's data-recovery tool for the lzip format.
# Repairs single-byte errors, splits multi-member archives, dumps/strips/
# removes corrupt members, and reproduces zeroed sectors using a known-good
# reference copy.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-a --trailing-error)'{-a,--trailing-error}'[exit non-zero on trailing data]' \
  '(-A --alone-to-lz)'{-A,--alone-to-lz}'[convert lzma-alone files to lzip format]' \
  '(-c --stdout)'{-c,--stdout}'[write to stdout, keep input files]' \
  '(-d --decompress)'{-d,--decompress}'[decompress files]' \
  '(-D --range-decompress)'{-D,--range-decompress=}'[decompress a byte range to stdout]:range (N-M):' \
  '(-e --reproduce)'{-e,--reproduce}'[try to reproduce a zeroed sector]' \
  '--lzip-level=[reproduce one level, all, or match length]:level (N|a|m[N]):' \
  '--lzip-name=[lzip executable to drive --reproduce]:name:_command_names -e' \
  '--reference-file=[known-good reference for --reproduce]:file:_files -g "*.lz"' \
  '(-f --force)'{-f,--force}'[overwrite existing output files]' \
  '(-i --ignore-errors)'{-i,--ignore-errors}'[ignore some errors in -d/-D/-l/-t/--dump]' \
  '(-k --keep)'{-k,--keep}'[keep (do not delete) input files]' \
  '(-l --list)'{-l,--list}'[print compressed and uncompressed sizes]' \
  '(-m --merge)'{-m,--merge}'[correct errors using several copies of the file]' \
  '(-o --output)'{-o,--output=}'[place output into FILE]:file:_files' \
  '(-q --quiet -v --verbose)'{-q,--quiet}'[suppress all messages]' \
  '(-R --repair)'{-R,--repair}'[try to repair a small error in file]' \
  '(-s --split)'{-s,--split}'[split multi-member file into single-member files]' \
  '(-t --test)'{-t,--test}'[test compressed file integrity]' \
  '(-q --quiet -v --verbose)*'{-v,--verbose}'[verbose (repeat for more)]' \
  '--loose-trailing[allow trailing data that looks like a corrupt header]' \
  '--dump=[dump listed/damaged members + tdata to stdout]:spec ([list]:d:t):' \
  '--remove=[remove members + tdata from files in place]:spec ([list]:d:t):' \
  '--strip=[copy files to stdout stripping members]:spec ([list]:d:t):' \
  '*:lzip file:_files -g "*.(lz|tlz|lzma)"' \
  && ret=0

return ret
