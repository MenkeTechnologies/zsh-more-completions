#compdef heroic
# Documentation: https://github.com/Heroic-Games-Launcher/HeroicGamesLauncher
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for heroic - Heroic Games Launcher (Electron-based GUI).
# Heroic accepts standard Electron/Chromium runtime flags rather than a
# documented CLI; entries below are the commonly used Electron flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-gui[run without GUI]' \
  '--no-sandbox[disable sandbox]' \
  '--disable-gpu[disable GPU acceleration]' \
  '--enable-logging[enable logging]' \
  '--log-level[set log level]:level:(verbose info warning error)' \
  '*:URI:' && ret=0

return ret
