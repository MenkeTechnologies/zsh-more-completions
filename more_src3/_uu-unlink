#compdef uu-unlink
# Documentation: https://uutils.github.io/coreutils/docs/utils/unlink.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

autoload -U is-at-least

_uu-unlink() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':FILE:_files' \
&& ret=0
}

(( $+functions[_uu-unlink_commands] )) ||
_uu-unlink_commands() {
    local commands; commands=()
    _describe -t commands 'uu-unlink commands' commands "$@"
}

if [ "$funcstack[1]" = "_uu-unlink" ]; then
    _uu-unlink "$@"
else
    compdef _uu-unlink uu-unlink
fi
