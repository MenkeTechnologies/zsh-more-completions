#compdef lightgbm
# Documentation: https://lightgbm.readthedocs.io/en/latest/Parameters.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# LightGBM: Microsoft gradient boosting CLI. Args are passed as key=value
# pairs (e.g. `lightgbm task=train config=train.conf data=data.txt`).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-version[show version]' \
  '*:lightgbm key=value:' && ret=0
return ret
