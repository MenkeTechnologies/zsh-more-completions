#compdef logz-cli logzio-cli logzio
# _logz-cli — Logz.io logz-cli CLI command-line frontend wrapping the Logz.io cloud observability platform managed ELK stack open-source-as-a-service log management infrastructure monitoring cloud SIEM platform CLI providing login deploy notify search export bulk-import alert subaccount user role token endpoint account region archive sub-accounts Kibana Grafana OpenSearch retention sub-region (Logz.io team Tomer Levy, Go); cobra
# upstream: https://logz.io/

_logz-cli() {
    local -a sub=(
        'login:authenticate'
        'whoami:show identity'
        'search:search logs'
        'export:export logs'
        'bulk-import:bulk import logs'
        'alert:alert operations'
        'subaccount:subaccount operations'
        'user:user operations'
        'role:role operations'
        'token:token operations'
        'endpoint:endpoint operations'
        'account:account operations'
        'archive:archive operations'
        'kibana-object:Kibana object operations'
        'restore:restore operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--shipping-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--region=+[r]:r:(us eu ca au nl au asia uk)' \
        '--account-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'logz subcommand' sub ;;
        args)
            case $words[1] in
                alert|subaccount|user|role|token|endpoint|account|archive|kibana-object) _arguments '1:op:(list get create update delete enable disable)' '*:id:' ;;
                search|export|bulk-import) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_logz-cli "$@"
