#compdef tidb-ctl
# _tidb-ctl — TiDB Controller (pingcap/tidb-ctl)
# upstream: https://github.com/pingcap/tidb-ctl
# Flags & subcommands from cmd/root.go and per-file Use:/Short: declarations.

_tidb-ctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--host=[TiDB server host]:host:_hosts' \
        '--port=[TiDB server port]:port:' \
        '--pdhost=[PD server host]:host:_hosts' \
        '--pdport=[PD server port]:port:' \
        '--ca=[TLS CA path]:file:_files -g "*.(pem|crt)"' \
        '--ssl-key=[TLS key path]:file:_files -g "*.(pem|key)"' \
        '--ssl-cert=[TLS cert path]:file:_files -g "*.(pem|crt)"' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'schema:schema information'
                'mvcc:MVCC information'
                'table:table information'
                'region:region information'
                'etcd:control etcd via grpc_gateway'
                'decoder:decode key'
                'base64decode:decode base64 value'
                'keyrange:show key ranges'
                'log:convert single-line log to multi-line form'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                schema) _arguments '1:subcommand:(in tid)' ;;
                mvcc)   _arguments '1:subcommand:(key txn hex index)' ;;
                table)  _arguments '1:subcommand:(region disk-usage)' ;;
                etcd)   _arguments '1:subcommand:(ddlinfo delkey putkey)' ;;
            esac
            ;;
    esac
}

_tidb-ctl "$@"
