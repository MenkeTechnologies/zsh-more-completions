#compdef scanpy
# _scanpy — Theis Lab scverse scanpy CLI single-cell analysis toolkit in Python for preprocessing visualization clustering trajectory inference differential expression on AnnData objects integrating with Scrublet Harmony BBKNN scVI deepest-of-deep scientific Python sklearn-compatible pipeline (Theis Lab team, Python); argparse
# upstream: https://scanpy.readthedocs.io/

_scanpy() {
    local -a sub=(
        'read:read a dataset'
        'write:write to disk'
        'pp:preprocessing functions'
        'tl:tools (PCA UMAP leiden)'
        'pl:plotting functions'
        'queries:gene metadata queries'
        'external:external integrations'
        'datasets:built-in datasets'
        'logging:logging utilities'
        'settings:settings management'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[n_jobs]:n:' \
        '--n-jobs=+[N]:n:' \
        '--n-pcs=+[N]:n:' \
        '--n-neighbors=+[N]:n:' \
        '--resolution=+[N]:n:' \
        '--random-state=+[N]:n:' \
        '--figdir=+[dir]:dir:_files -/' \
        '--writedir=+[dir]:dir:_files -/' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--cachedir=+[dir]:dir:_files -/' \
        '--max-memory=+[GB]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'scanpy subcommand' sub ;;
        args)
            case $words[1] in
                pp) _arguments '1:method:(normalize_total log1p filter_cells filter_genes scale neighbors highly_variable_genes regress_out combat downsample_counts subsample recipe_seurat recipe_zheng17 recipe_weinreb17 calculate_qc_metrics)' ;;
                tl) _arguments '1:method:(pca tsne umap leiden louvain diffmap dpt paga rank_genes_groups embedding_density score_genes ingest dendrogram draw_graph)' ;;
                pl) _arguments '1:method:(scatter heatmap dotplot tracksplot violin stacked_violin matrixplot umap tsne paga rank_genes_groups dendrogram embedding_density)' ;;
            esac
            ;;
    esac
}

_scanpy "$@"
