#compdef kbxutil
# Documentation: kbxutil --help on kbxutil (GnuPG) 2.5.20
# Source: GnuPG kbxutil — list / export / import Keybox (kbx) data files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--stats --import-openpgp --find-dups --cut)--stats[show key statistics]' \
    '(--stats --import-openpgp --find-dups --cut)--import-openpgp[import OpenPGP keyblocks]' \
    '(--stats --import-openpgp --find-dups --cut)--find-dups[find duplicates]' \
    '(--stats --import-openpgp --find-dups --cut)--cut[export records]' \
    '--from=[first record to export]:N:' \
    '--to=[last record to export]:N:' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[quiet]' \
    '(-n --dry-run)'{-n,--dry-run}'[no changes]' \
    '--debug=[set debugging flags]:flags:' \
    '--debug-all[enable full debugging]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:kbx file:_files -g "*.kbx"' \
    && ret=0

return ret
