#compdef xcparser
# _xcparser — xcparser Xcode test/result extraction (Swift); parse .xcresult bundles into JSON + raw logs
# upstream: https://github.com/sersoft-gmbh/xcparser

_xcparser() {
    local -a sub=(
        'summary:print test summary'
        'logs:extract activity logs'
        'screenshots:extract screenshots'
        'attachments:extract attachments'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'xcparser subcommand' sub ;;
        args)
            _arguments \
                '(-i --input)'{-i,--input}'+[xcresult bundle]:bundle:_files -g "*.xcresult"' \
                '(-o --output)'{-o,--output}'+[output dir or file]:path:_files' \
                '(-f --format)'{-f,--format}'+[output format]:fmt:(json text)' \
                '(-v --verbose)'{-v,--verbose}'[verbose log]'
            ;;
    esac
}

_xcparser "$@"
