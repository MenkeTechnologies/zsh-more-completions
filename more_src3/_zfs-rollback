#compdef zfs-rollback
# _zfs-rollback — OpenZFS zfs rollback rollback to snapshot CLI alias (openzfs team, C); custom argparse
# upstream: https://github.com/openzfs/zfs

_zfs-rollback() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-r[destroy newer snapshots]' \
        '-R[destroy newer snapshots and clones]' \
        '-f[force unmount]' \
        '*:snapshot:'
}

_zfs-rollback "$@"
