#compdef sfspike
# Documentation: http://www.ahay.org/RSF/sfspike.html
# Source: ahay/src system/main/spike.c — generate a sparse spike RSF dataset.
# Reference accessed: 2026-06-10
#
# Per-axis (1..dim) params: n#, o#, d#, label#, unit#, k#, l#, p#.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    'nsp=[number of spikes]: :_default' \
    'mag=[spike magnitudes (vector of nsp)]: :_default' \
    'title=[plot title]: :_default' \
    'n1=[size of 1st axis]: :_default' \
    'o1=[origin, 1st axis]: :_default' \
    'd1=[sampling, 1st axis]: :_default' \
    'label1=[label, 1st axis]: :_default' \
    'unit1=[unit, 1st axis]: :_default' \
    'k1=[spike start positions on 1st axis (nsp vector)]: :_default' \
    'l1=[spike end positions on 1st axis (nsp vector)]: :_default' \
    'p1=[spike inclinations on 1st axis (samples, nsp vector)]: :_default' \
    'n2=[size of 2nd axis]: :_default' \
    'o2=[origin, 2nd axis]: :_default' \
    'd2=[sampling, 2nd axis]: :_default' \
    'k2=[spike start positions on 2nd axis]: :_default' \
    'l2=[spike end positions on 2nd axis]: :_default' \
    'p2=[spike inclinations on 2nd axis]: :_default' \
    'n3=[size of 3rd axis]: :_default' \
    'k3=[spike start positions on 3rd axis]: :_default' \
    'l3=[spike end positions on 3rd axis]: :_default' \
    && ret=0

return ret
