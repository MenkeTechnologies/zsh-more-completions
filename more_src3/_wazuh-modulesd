#compdef wazuh-modulesd
# Documentation: https://documentation.wazuh.com/current/user-manual/reference/daemons/wazuh-modulesd.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. Upstream lists only
# -d/-dd/-f/-h/-t; -c/-D/-g/-u/-V not documented for this daemon.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[basic debug mode]' \
  '-dd[verbose debug mode]' \
  '-f[run in foreground]' \
  '-t[test configuration]' && ret=0
return ret
