_hunk() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a review_opts
    review_opts=(
        '--mode=[layout mode]:mode:(auto split stack)'
        '--watch[auto-reload when the current diff input changes (re-run the loader on file/git events)]'
        '--agent-context=[path to JSON sidecar with agent rationale (inline notes shown beside changed lines)]:file:_files -g "*.json"'
        '--pager[use pager-style chrome and controls (less-like keybindings instead of full TUI)]'
        '--line-numbers[show line numbers in the diff view]'
        '--no-line-numbers[hide line numbers in the diff view]'
        '--wrap[wrap long diff lines instead of truncating]'
        '--no-wrap[truncate long diff lines instead of wrapping]'
        '--hunk-headers[show hunk metadata rows (file path + @@ line)]'
        '--no-hunk-headers[hide hunk metadata rows]'
        '--agent-notes[show agent notes by default (toggle in-app with the configured key)]'
        '--no-agent-notes[hide agent notes by default]'
        '--theme=[named theme override (matches a key in ~/.config/hunk/themes/)]:theme:'
    )

    local -a git_opts
    git_opts=(
        '(--staged --cached)--staged[review staged changes]'
        '(--staged --cached)--cached[review staged changes (alias for --staged)]'
        '--exclude-untracked[hide untracked files in working-tree reviews]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show CLI help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'diff:review working-tree changes (or compare against a target ref/revset, or diff two files directly)'
                'show:review the last commit or a given commit/revset target'
                'stash:git-only — review a stash entry (`hunk stash show [ref]`)'
                'patch:review a patch file or stdin (`hunk patch -` reads stdin)'
                'pager:general Git-pager wrapper with automatic diff detection (drop into GIT_PAGER env var)'
                'difftool:review Git difftool file pairs (drop into git config diff.tool / git difftool flow)'
                'session:inspect or control a live Hunk session (subcommands: info / wait / accept / reject / etc)'
                'skill:print the bundled Hunk review skill path (load in your coding agent for session coordination)'
                'daemon:run the local Hunk session daemon (`hunk daemon serve` starts the broker socket)'
                'help:show CLI help (or help for a specific subcommand)'
            )
            _describe -t commands 'hunk command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                diff)
                    _arguments \
                        '(- *)'{-h,--help}'[show diff subcommand help]' \
                        $review_opts \
                        $git_opts \
                        '*::diff-arg:->diffargs' && ret=0
                    # diff takes either [target] [-- <pathspec...>] or <left> <right>
                    case $state in
                        diffargs)
                            _arguments \
                                '*:file or git revset:_files' && ret=0
                            ;;
                    esac
                    ;;
                show)
                    _arguments \
                        '(- *)'{-h,--help}'[show show-subcommand help]' \
                        $review_opts \
                        '*:git commit / jj revset (default: HEAD):' && ret=0
                    ;;
                stash)
                    _arguments \
                        '(- *)'{-h,--help}'[show stash-subcommand help]' \
                        '1:stash subcommand:(show)' \
                        '*:stash ref (default: stash@{0}):' && ret=0
                    ;;
                patch)
                    _arguments \
                        '(- *)'{-h,--help}'[show patch-subcommand help]' \
                        $review_opts \
                        '1:patch file (use `-` for stdin):_files -g "*.(patch|diff)"' && ret=0
                    ;;
                pager)
                    _arguments \
                        '(- *)'{-h,--help}'[show pager-subcommand help]' \
                        $review_opts && ret=0
                    ;;
                difftool)
                    _arguments \
                        '(- *)'{-h,--help}'[show difftool-subcommand help]' \
                        $review_opts \
                        '1:left file:_files' \
                        '2:right file:_files' \
                        '3::path hint:_files' && ret=0
                    ;;
                session)
                    _arguments \
                        '(- *)'{-h,--help}'[show session-subcommand help]' \
                        '1:session subcommand:(info wait accept reject list current)' && ret=0
                    ;;
                skill)
                    _arguments \
                        '(- *)'{-h,--help}'[show skill-subcommand help]' \
                        '1:skill subcommand:(path)' && ret=0
                    ;;
                daemon)
                    _arguments \
                        '(- *)'{-h,--help}'[show daemon-subcommand help]' \
                        '1:daemon subcommand:(serve stop status)' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(diff show stash patch pager difftool session skill daemon)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_hunk "$@"
