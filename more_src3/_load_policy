#compdef load_policy
# Documentation: man load_policy(8)
# Source: SELinuxProject/selinux policycoreutils/load_policy/load_policy.c (main) — load the SELinux policy (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-q[quiet (no error messages)]' \
    '-i[initialization mode]' \
    '-b[(deprecated; booleans always preserved)]' \
    && ret=0

return ret
