#compdef zabbix-proxy zabbix_proxy
# Documentation: https://www.zabbix.com/documentation/current/en/manpages/zabbix_proxy
# Reference accessed: 2026-05-21
# Verified: upstream Zabbix zabbix_proxy manpage at the URL above.

# zabbix-proxy: Zabbix monitoring proxy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[alternate config file]:file:_files' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground]' \
  '(-R --runtime-control)'{-R,--runtime-control=}'[runtime option]:opt:(config_cache_reload snmp_cache_reload housekeeper_execute diaginfo prof_enable prof_disable log_level_increase log_level_decrease)' && ret=0
return ret
