#compdef tiffcrop
# Documentation: tiffcrop -h (libtiff)
# Source: copy / crop / convert / extract / process TIFF files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-v[show version]' \
    '-a[append to output instead of overwriting]' \
    '(-L)-B[force Big-Endian output]' \
    '(-B)-L[force Little-Endian output]' \
    '-M[suppress memory-mapped reads]' \
    '-C[suppress strip chopping]' \
    '-d+[initial directory offset (1-based)]:offset:' \
    '-p+[sample packing]:packing:(contig separate)' \
    '(-t)-s[write output in strips]' \
    '(-s)-t[write output in tiles]' \
    '-i[ignore read errors]' \
    '-k+[memory allocation limit MiB (0=none)]:mib:' \
    '-r+[max rows per strip]:n:' \
    '-w+[output tile width pixels]:px:' \
    '-l+[output tile length pixels]:px:' \
    '-f+[fill order]:order:(lsb2msb msb2lsb)' \
    '-c+[compression scheme]:scheme:(lzw zip jpeg packbits g3 g4 none)' \
    '-e+[export mode]:mode:(combined separated multiple image)' \
    '-N+[image numbers (1,3-5,7)]:list:' \
    '-Z+[zones spec]:list:' \
    '-X+[crop width inches]:width:' \
    '-Y+[crop length inches]:length:' \
    '-O+[orientation operations]:list:' \
    '-R+[rotation degrees]:degrees:(90 180 270)' \
    '-F+[mirror flip]:axis:(horiz vert both)' \
    '-I+[invert/negate]:mode:(black white both data)' \
    '-S+[output rows x columns layout]:layout:' \
    '-U+[units]:unit:(in cm px)' \
    '-H+[horizontal resolution dpi]:dpi:' \
    '-V+[vertical resolution dpi]:dpi:' \
    '-J+[horizontal margin]:value:' \
    '-K+[vertical margin]:value:' \
    '-D+[debug printout]:flags:' \
    '*:tiff:_files -g "*.(tif|tiff|TIF|TIFF)"' \
    && ret=0

return ret
