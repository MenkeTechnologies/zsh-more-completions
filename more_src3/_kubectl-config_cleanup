#compdef kubectl-config_cleanup
# Documentation: https://github.com/TorchAIKC/kubectl-config-cleanup/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--raw[output the cleaned kubeconfig in raw format]' \
  '--print-removed[print the configurations that were removed]' \
  '--connect-timeout=[connection timeout for each apiserver]:duration:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(json yaml jsonpath)' \
  '*:args:_default'
