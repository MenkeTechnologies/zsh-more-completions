#compdef langwatch
# Documentation: https://github.com/langwatch/langwatch
# Reference accessed: 2026-05-22
# Verified: langwatch npm package --help.

# Zsh completion for langwatch - LangWatch prompts datasets and observability CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'langwatch command' \
      'login[login and save API key]' \
      'status[show project resource counts]' \
      'docs[fetch LangWatch documentation]' \
      'scenario-docs[fetch Scenario documentation]' \
      'prompt[manage prompt dependencies]' \
      'evaluator[manage evaluator definitions]' \
      'experiment[run and inspect experiments]' \
      'workflow[manage workflows]' \
      'agent[manage agent definitions]' \
      'dashboard[manage analytics dashboards]' \
      'model-provider[manage LLM model providers]' \
      'model-default[manage default models]' \
      'virtual-keys[manage AI Gateway virtual keys]' \
      'vk[alias for virtual-keys]' \
      'gateway-budgets[manage gateway spend budgets]' \
      'gateway-providers[manage gateway provider bindings]' \
      'annotation[manage trace annotations]' \
      'analytics[query analytics and metrics]' \
      'trace[search and inspect traces]' \
      'scenario[manage scenarios]' && ret=0
    ;;
esac

return ret
