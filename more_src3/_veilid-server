#compdef veilid-server
# Documentation: https://gitlab.com/veilid/veilid/-/tree/main/veilid-server
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for Veilid P2P server node

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode in the background]' \
  '(-c --config-file)'{-c,--config-file=}'[configuration file]:file:_files' \
  '(-s --set-config)'{-s,--set-config=}'[set config value (key in dot format, value in json)]:kv:' \
  '(-p --password)'{-p,--password=}'[password to protect device encryption key]:password:' \
  '--new-password=[change device encryption key password]:password:' \
  '--no-attach[prevent automatic network attachment]' \
  '--debug[turn on debug logging]' \
  '--trace[turn on trace logging]' \
  '--otlp=[enable OpenTelemetry (GRPC) endpoint]:endpoint:' \
  '--flame=[enable flamegraph tracing]:path:_files' \
  '--perfetto=[enable perfetto tracing]:path:_files' \
  '(-n --subnode-index)'{-n,--subnode-index=}'[subnode index for testing]:n:' \
  '--subnode-count=[number of subnodes]:n:' \
  '--virtual-router=[connect to virtual router URL]:url:' \
  '--generate-key-pairs=[generate keypairs and print]:crypto_kinds:' \
  '--set-key-pairs[set public and secret keys interactively]' \
  '--delete-protected-store[delete protected store contents]' \
  '--delete-table-store[delete table store contents]' \
  '--delete-block-store[delete block store contents]' \
  '--dump-config[print configuration to console]' \
  '--dump-txt-record[print bootstrap TXT record]' \
  '--emit-schema=[emit JSON-Schema for named type]:schema:' \
  '--bootstrap=[bootstrap hostnames]:list:' \
  '--bootstrap-keys=[bootstrap signing keys]:list:' \
  '--panic[panic on ctrl-c instead of graceful shutdown]' \
  '--network-key=[network isolation password override]:key:' \
  '--wait-for-debug[wait for debugger (debug builds only)]' \
  '--console[enable tokio console]' \
  '--ignore-log-targets=[targets to ignore for logging]:targets:' \
  '--port=[override all listen addresses with :port]:port:' \
  '*::file:_files' && ret=0

return ret
