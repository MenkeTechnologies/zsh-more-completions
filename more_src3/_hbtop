#compdef hbtop
# Documentation: https://hbase.apache.org/book.html#hbtop
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Apache HBase hbtop - real-time monitoring tool modeled after top(1)
# Per upstream: only -d/--delay, -h/--help, -m/--mode are documented options

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --delay)'{-d,--delay=}'[refresh delay in seconds (default 3)]:secs:' \
  '(-m --mode)'{-m,--mode=}'[mode: n=Namespace, t=Table, r=Region, s=RegionServer]:mode:(n t r s)' \
  '*-D-[set Hadoop/HBase property key=value]:property:'
