#compdef kalzium
# Documentation: https://apps.kde.org/kalzium/
# Reference accessed: 2026-05-16
# Verified: upstream KDE kalzium. -m flag requires OpenBabel/Eigen/
# Avogadro build.
# Removed from prior file: bogus man.archlinux.org search URL.

# kalzium: KDE periodic table
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '(-m --molecule)'{-m+,--molecule=}'[open molecule (requires Avogadro build)]:file:_files' && ret=0
return ret
