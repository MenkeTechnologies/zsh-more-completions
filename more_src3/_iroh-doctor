#compdef iroh-doctor
# _iroh-doctor — diagnose network issues with iroh-net (n0-computer/iroh-doctor)
# upstream: https://github.com/n0-computer/iroh-doctor
# Subcommands from src/doctor.rs (clap).

_iroh-doctor() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--config=[config file]:file:_files' \
        '--metrics-addr=[address to serve metrics on]:addr:' \
        '--metrics-dump-path=[CSV metrics dump path]:file:_files' \
        '--service-node=[iroh service node endpoint id]:endpoint:' \
        '--ssh-key=[SSH key for service node auth]:file:_files' \
        '1: :->cmd'

    case $state in
        cmd)
            local -a cmds=(
                'report:run a network connectivity report'
                'accept:accept incoming connections for testing'
                'connect:connect to an accepting peer'
                'port-map:test port mapping (UPnP/NAT-PMP/PCP)'
                'port-map-probe:probe port mapping support'
                'relay-urls:probe relay URLs'
                'swarm-client:join a swarm of testers'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_iroh-doctor "$@"
