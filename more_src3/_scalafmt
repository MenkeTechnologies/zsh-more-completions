#compdef scalafmt
# Documentation: https://scalameta.org/scalafmt/docs/installation.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for scalafmt - Scala code formatter

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'+[path to .scalafmt.conf]:config file:_files -g "*.conf"' \
  '--config-str=[configuration as command-line string]:config string' \
  '--exclude=[exclude specific files or directories]:pattern' \
  '--respect-project-filters[apply project filters with explicit targets]' \
  '--check[check formatting, exit on first failure]' \
  '--test[check formatting; exit with status 1 on failure]' \
  '--reportError[exit with status 1 if misformatted code is found]' \
  '--mode=[file-fetching mode]:mode:(diff diff-ref changed any anygit)' \
  '--stdin[read from stdin]' \
  '--stdout[write formatted output to stdout]' \
  '--assume-filename=[filename hint for stdin]:filename' \
  '--list[list files that differ from formatted output]' \
  '--quiet[suppress console output]' \
  '--debug[enable diagnostic output]' \
  '--non-interactive[disable progress bar]' \
  '*:files:_files -g "*.{scala,sbt,sc}"' && ret=0

return ret
