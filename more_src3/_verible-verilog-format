#compdef verible-verilog-format
# Documentation: https://github.com/chipsalliance/verible/blob/master/verible/verilog/tools/formatter/verilog-format.cc
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--helpfull[show all options]' \
  '--inplace[overwrite the input file on successful conditions]' \
  '--verify[only checks if formatting would be done; exit 0=no changes, 1=would reformat]' \
  '--stdin_name=[name of stdin file for diagnostic purposes]:name:' \
  '--lines=[specific lines to format, 1-based comma-separated inclusive N-M ranges]:ranges:' \
  '--failsafe_success[always exit 0, even on input or internal errors]' \
  '--verify_convergence[verify re-formatting yields no further changes]' \
  '--verbose[be more verbose]' \
  '--show_largest_token_partitions=[print token partitioning then exit]:n:' \
  '--show_token_partition_tree[print token partitioning diagnostics then exit]' \
  '--show_inter_token_info[with show_token_partition_tree, include inter-token info]' \
  '--show_equally_optimal_wrappings[print when multiple optimal solutions exist]' \
  '--max_search_states=[limit search states for line wrap optimization]:n:' \
  '*:file:_files -g "*.{v,sv,vh,svh}"' && ret=0

return ret
