#compdef silence
# _silence — Silence SMS/MMS encryption Android-line CLI (TextSecure protocol); send encrypted SMS sessions
# upstream: https://git.silence.dev/Silence/Silence

_silence() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--init+[init session with peer]:peer phone:' \
        '--send+[send to peer]:peer phone:' \
        '--list-sessions[list active sessions]' \
        '--export+[export session to file]:file:_files' \
        '--import+[import session from file]:file:_files' \
        '*:message text:'
}

_silence "$@"
