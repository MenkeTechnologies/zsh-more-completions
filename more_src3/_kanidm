#compdef kanidm
# Documentation: https://github.com/kanidm/kanidm/blob/master/tools/cli/src/opt/kanidm.rs
# Reference accessed: 2026-05-19
# Verified: upstream tools/cli/src/opt/kanidm.rs clap enums at the URL.

# Kanidm identity management CLI. Corrected from prior file: global
# flag is --output (-l) not --output-mode; oauth2/domain are nested
# under `system`, not top-level; added real reauth/session/graph and
# -I/--instance/--debug; removed the fake top-level help command.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-H --url)'{-H,--url}'[server URL]:URL' \
  '(-D --name)'{-D,--name}'[authenticate as name]:name' \
  '(-C --ca)'{-C,--ca}'[CA certificate path]:ca cert:_files' \
  '(-I --instance)'{-I,--instance}'[instance name to connect to]:instance' \
  '(-l --output)'{-l,--output}'[output/log format]:mode:(text json)' \
  '--debug[enable debugging output]' \
  '--skip-hostname-verification[bypass hostname verification]' \
  '--accept-invalid-certs[disable CA verification]' \
  '--token-cache-path=[token cache file path]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'login:authenticate to the server'
      'reauth:re-authenticate for privileged access'
      'logout:destroy current session'
      'session:manage active CLI sessions'
      'self:operations on the current account'
      'person:manage person accounts'
      'group:manage groups'
      'service-account:manage service accounts'
      'graph:generate graphviz dot of group hierarchy'
      'system:system configuration (incl. oauth2, domain)'
      'recycle-bin:manage recycle bin'
      'raw:raw low-level database queries'
      'version:show version'
    )
    _describe -t commands 'kanidm subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      person|group|service-account)
        local -a entity_subcmds=(
          'create:create a new entry'
          'delete:delete an entry'
          'get:get entry details'
          'list:list entries'
          'update:update an entry'
        )
        _describe -t commands 'subcommand' entity_subcmds && ret=0
        ;;
      system)
        local -a sys_subcmds=(
          'oauth2:manage OAuth2 resource servers'
          'domain:manage domain settings'
        )
        _describe -t commands 'system subcommand' sys_subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
