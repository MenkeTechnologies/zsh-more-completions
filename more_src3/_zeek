#compdef zeek bro
# _zeek — Zeek (Bro) network security monitor (passive packet inspector that turns traffic into typed event streams + scripts; -i live interface, -r read pcap, -w write pcap, -e expr inline script, -f BPF filter, -p script-prefix, -s signatures file, -C ignore checksum errors, -N print loaded plugins, -O optimize-script, -j json-logs, --bare-mode skip base scripts; positional script names follow)
# upstream: https://github.com/zeek/zeek
# Flags from Zeek src/main.cc on tip.

_zeek() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[live interface]:interface:_net_interfaces' \
        '-r+[pcap to read]:file:_files -g "*.(pcap|pcapng|cap)"' \
        '-w+[pcap to write]:file:_files -g "*.(pcap|pcapng)"' \
        '-e+[inline script]:expr:' \
        '-f+[BPF filter]:filter:' \
        '*-p+[script prefix]:prefix:' \
        '-s+[signatures]:file:_files -g "*.sig"' \
        '-C[ignore checksum errors]' \
        '-N[print plugins + exit]' \
        '-O[optimize script]' \
        '-j[JSON logs]' \
        '--bare-mode[skip base scripts]' \
        '-G+[load plugins dir]:dir:_files -/' \
        '-x+[debug execution]:expr:' \
        '*::script:_files'
}

_zeek "$@"
