#compdef insanely-fast-whisper
# Documentation: upstream README at github.com/Vaibhavs10/insanely-fast-whisper
# Reference accessed: 2026-05-30
# Whisper-family R33 — Flash Attention 2 optimized transcription CLI.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--file-name=[audio file path or URL (required)]:file:_files' \
  '--device-id=[GPU id (CUDA) or "mps" (Mac)]:device:(0 1 2 3 mps)' \
  '--transcript-path=[output location for transcription]:file:_files' \
  '--model-name=[ASR model checkpoint (default openai/whisper-large-v3)]:model:' \
  '--task=[operation type]:task:(transcribe translate)' \
  '--language=[input audio language (auto-detect if omitted)]:lang:' \
  '--batch-size=[parallel batches (default 24)]:N:' \
  '--flash[enable Flash Attention 2]' \
  '--timestamp=[timestamp granularity]:granularity:(chunk word)' \
  '--hf-token=[Hugging Face token for speaker diarization]:token:' \
  '--diarization_model=[diarization model (default pyannote/speaker-diarization)]:model:' \
  '--num-speakers=[exact speaker count]:N:' \
  '--min-speakers=[minimum speaker threshold]:N:' \
  '--max-speakers=[maximum speaker threshold]:N:' \
  && ret=0

return ret
