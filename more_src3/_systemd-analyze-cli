#compdef systemd-analyze-cli
# _systemd-analyze-cli — systemd systemd-analyze analyze and debug systemd CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_systemd-analyze-cli() {
    local -a sub=(
        'time:show boot time'
        'blame:show what slowed boot'
        'critical-chain:show critical chain'
        'plot:plot boot timeline'
        'dot:show dependency graph'
        'dump:dump server state'
        'unit-files:show installed units'
        'unit-paths:show search paths'
        'exit-status:show exit status table'
        'syscall-filter:show syscall filters'
        'condition:eval conditions'
        'verify:verify unit files'
        'security:analyze security'
        'inspect-elf:inspect ELF'
        'malloc:malloc statistics'
        'fdstore:filedescriptor store'
        'image-policy:check image policy'
        'pcrs:show TPM PCRs'
        'srk:show SRK'
        'capability:show capabilities'
        'filesystems:show filesystem table'
        'architectures:show architectures'
        'compare-versions:compare versions'
        'log-level:show/set log level'
        'log-target:show/set log target'
        'service-watchdogs:show watchdogs'
        'timespan:show timespan'
        'timestamp:parse timestamp'
        'calendar:parse calendar expression'
        'cat-config:show config'
        'has-tpm2:check TPM2 support'
        'pcr-prediction:predict PCR values'
        'pcr-policy:show PCR policy'
        'plot-fdoc:show plot fdoc'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--system[talk to system manager]' \
        '--user[talk to user manager]' \
        '--global[global config]' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '--from-pattern=+[pattern]:str:' \
        '--to-pattern=+[pattern]:str:' \
        '--root=+[root]:dir:_files -/' \
        '--image=+[image]:file:_files' \
        '--man=+[bool]:b:(yes no)' \
        '--generators=+[bool]:b:(yes no)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--security-policy=+[json]:file:_files' \
        '--threshold=+[n]:n:' \
        '--offline=+[bool]:b:(yes no)' \
        '--root-owner=+[uid]:n:' \
        '--profile=+[profile]:str:' \
        '--instance=+[instance]:str:' \
        '--unit=+[unit]:str:' \
        '--no-ask-password[no ask password]' \
        '--json=+[mode]:m:(short pretty off)' \
        '-j[json short]' \
        '--table[table output]' \
        '--detailed[detailed]' \
        '--iterations=+[n]:n:' \
        '--base-time=+[time]:str:' \
        '--pcr=+[pcr]:n:' \
        '--tpm2-device=+[dev]:str:' \
        '--tpm2-pcrs=+[pcrs]:str:' \
        '--tpm2-public-key=+[file]:file:_files' \
        '--tpm2-public-key-pcrs=+[pcrs]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'systemd-analyze subcommand' sub ;;
    esac
}

_systemd-analyze-cli "$@"
