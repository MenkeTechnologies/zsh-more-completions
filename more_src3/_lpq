#compdef lpq
# Documentation: https://manpages.debian.org/lpq
# Source: OpenPrinting/cups berkeley/lpq.c — BSD-style print queue lister (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[use encryption]' \
    '-U+[username for authentication]:user:_users' \
    '-P+[destination printer or class]:printer:_default' \
    '-a[show queues for all printers]' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '-l[long status]' \
    '*:user or job ID:_default' \
    && ret=0

return ret
