#compdef stterm st
# _stterm — suckless st (simple terminal; -a override class for WM, -f font, -g geometry, -i ignore tty utmp, -n name, -o save dump to file, -T/-t title, -w window id to embed in, -l line program file, -e exec command)
# upstream: https://git.suckless.org/st
# Flags from st x.c on tip.

_stterm() {
    _arguments \
        '-v[show version]' \
        '-a+[override class]:class:' \
        '-c+[class hint]:class:' \
        '-f+[font]:font:' \
        '-g+[geometry]:geom:' \
        '-i[fixed geometry]' \
        '-n+[window name]:name:' \
        '-o+[dump io to file]:file:_files' \
        '-T+[window title]:title:' \
        '-t+[window title]:title:' \
        '-w+[parent window id]:windowid:' \
        '-l+[line program file]:file:_files' \
        '-e[execute remaining args as command]' \
        '*::command:_command_names -e'
}

_stterm "$@"
