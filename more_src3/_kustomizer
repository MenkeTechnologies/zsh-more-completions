#compdef kustomizer
# Documentation: https://github.com/stefanprodan/kustomizer/tree/main/cmd/kustomizer
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kustomizer (stefanprodan/kustomizer). Cobra-based. Top-level commands
# are taken from the files under cmd/kustomizer/*.go.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'apply:apply inventory to cluster'
  'build:build inventory from manifests'
  'completion:generate shell completion script'
  'config:manage kustomizer configuration'
  'delete:delete inventory from cluster'
  'diff:diff inventory against cluster or artifact'
  'get:list inventories'
  'inspect:inspect artifact or inventory'
  'list:list OCI artifacts'
  'pull:pull artifact from registry'
  'push:push artifact to registry'
  'tag:tag OCI artifact'
  'help:help about any command'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--timeout=[operation timeout]:duration:' \
  '(-n --namespace)'{-n+,--namespace=}'[inventory namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  (cmds)
    _describe -t commands 'kustomizer command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      apply|build|delete|diff|get|inspect)
        _arguments '1:subcommand:(inventory artifact inventories)' && ret=0
        ;;
      pull|push|tag|list)
        _arguments '1:subcommand:(artifact artifacts)' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
