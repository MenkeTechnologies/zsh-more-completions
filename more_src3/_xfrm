#compdef ip-xfrm xfrm
# _xfrm — iproute2 ip-xfrm (sub-object of ip(8) managing the kernel IPsec XFRM database; subcommands: state {list|add|update|delete|deleteall|get|count|flush|allocspi|monitor}, policy {list|add|update|delete|deleteall|get|count|flush|monitor|default}, monitor; common flags -s stats, -f family, -j JSON; positional argument is the subobject followed by per-subobject keys (src, dst, proto, reqid, spi, mode, mark))
# upstream: https://git.kernel.org/pub/scm/network/iproute2/iproute2.git (ip/ipxfrm.c)
# Subcommands from iproute2 ip/ipxfrm.c on tip.

_xfrm() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '-V[show version]' \
        '-s[stats]' \
        '-f+[family]:family:(inet inet6)' \
        '-j[json output]' \
        '-p[pretty json]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'xfrm subobject' '(state policy monitor)' ;;
        args)
            case $line[1] in
                state) _describe -t commands 'state action' '(list show add update delete deleteall get count flush allocspi monitor)' ;;
                policy) _describe -t commands 'policy action' '(list show add update delete deleteall get count flush monitor default)' ;;
                monitor) _arguments '*::filter:' ;;
            esac
            ;;
    esac
}

_xfrm "$@"
