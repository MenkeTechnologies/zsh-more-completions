#compdef httpx
# Documentation: httpx CLI source (encode/httpx httpx/_main.py)
# Source: encode/httpx — Python HTTP client (CLI mode).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-m --method)'{-m,--method=}'[request method]:method:(GET POST PUT PATCH DELETE OPTIONS HEAD CONNECT TRACE)' \
    '*'{-p,--params=}'[query parameter (NAME VALUE)]:name value:' \
    '(-c --content)'{-c,--content=}'[byte content for request body]:text:' \
    '*'{-d,--data=}'[form data (NAME VALUE)]:name value:' \
    '*'{-f,--files=}'[form file (NAME FILENAME)]:name filename:' \
    '(-j --json)'{-j,--json=}'[JSON data for body]:json:' \
    '*'{-h,--headers=}'[header (NAME VALUE)]:name value:' \
    '*--cookies=[cookie (NAME VALUE)]:name value:' \
    '--auth=[user password (- for prompt)]:user password:' \
    '--proxy=[proxy URL]:url:' \
    '--timeout=[network timeout (seconds)]:float:' \
    '--follow-redirects[automatically follow redirects]' \
    '--no-verify[disable SSL verification]' \
    '--http2[use HTTP/2 if supported]' \
    '--download=[save response to file]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[show request and response details]' \
    '(- *)--help[show help]' \
    '1:URL:_urls' \
    && ret=0

return ret
