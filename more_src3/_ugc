#compdef ugc ugc-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/lib/ugc.py argparse)
# Reference accessed: 2026-05-29
# ugc — trace garbage collection events in high-level language runtimes via USDT (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --language)'{-l,--language=}'[language to trace]:lang:(java node python ruby)' \
  '(-v --verbose)'{-v,--verbose}'[verbose: print the BPF program (for debugging)]' \
  '(-m --milliseconds)'{-m,--milliseconds}'[report times in milliseconds (default microseconds)]' \
  '(-M --minimum)'{-M,--minimum=}'[display only GCs longer than N ms (default 0)]:ms:' \
  '(-F --filter)'{-F,--filter=}'[display only GCs whose description contains this text]:text:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pid (process id to attach to):_pids' \
  && ret=0

return ret
