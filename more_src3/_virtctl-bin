#compdef virtctl
# _virtctl-bin — KubeVirt virtctl CLI (KubeVirt + CNCF, Go); manage KubeVirt VMs/instances on k8s
# upstream: https://github.com/kubevirt/kubevirt

_virtctl-bin() {
    local -a sub=(
        'addvolume:add volume to VM'
        'completion:print shell completion'
        'console:open VM serial console'
        'create:create resources'
        'credentials:set/clear VM credentials'
        'delete:delete VM'
        'expose:expose VM port'
        'fslist:list VM filesystems'
        'guestfs:open guestfs shell'
        'guestosinfo:get VM guest OS info'
        'help:show help'
        'image-upload:upload disk image'
        'memory-dump:get/clear memory dump'
        'migrate:live-migrate VM'
        'migrate-cancel:cancel a migration'
        'pause:pause VM'
        'permitted-devices:show permitted devices'
        'port-forward:port forward to VM'
        'powerstate:get VM power state'
        'restart:restart VM'
        'restore:restore VM'
        'scp:scp to VM'
        'softreboot:soft reboot VM'
        'ssh:ssh into VM'
        'start:start VM'
        'stop:stop VM'
        'unpause:unpause VM'
        'usbredir:USB redirect'
        'userlist:list logged-in users'
        'version:show version'
        'vnc:open VM VNC'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--add_dir_header[add dir header]' \
        '--alsologtostderr[also log to stderr]' \
        '--as+[impersonate user]:user:' \
        '--as-group+[impersonate group]:group:' \
        '--cache-dir+[cache dir]:dir:_files -/' \
        '--certificate-authority+[CA cert]:file:_files' \
        '--client-certificate+[client cert]:file:_files' \
        '--client-key+[client key]:file:_files' \
        '--cluster+[k8s cluster]:cluster:' \
        '--context+[kube context]:context:' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '-n+[namespace]:ns:' \
        '--namespace+[namespace]:ns:' \
        '--request-timeout+[request timeout]:duration:' \
        '--server+[k8s API server]:host:_hosts' \
        '--token+[bearer token]:str:' \
        '--user+[kubeconfig user]:user:' \
        '-v+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'virtctl subcommand' sub ;;
        args)
            case $words[1] in
                console|vnc|start|stop|restart|pause|unpause|migrate|softreboot|memory-dump|powerstate|guestosinfo|userlist|fslist) _arguments '*:VM name:' ;;
                ssh|scp) _arguments '*:user@vmi:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_virtctl-bin "$@"
