#compdef fsbtrfsinfo fsbtrfsmount
# _libfsbtrfs — libfsbtrfs tools (libyal Linux btrfs parser; fsbtrfsinfo dumps tree-of-trees + chunks + extents metadata, fsbtrfsmount FUSE-mounts the filesystem read-only with each subvolume as a directory; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E inode filter, -F path filter, -X exclusive; positional argument is the btrfs image)
# upstream: https://github.com/libyal/libfsbtrfs
# Flags from libyal/libfsbtrfs fsbtrfstools/fsbtrfsinfo.c on tip.

_libfsbtrfs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[inode filter]:inode:' \
        '-F+[path filter]:path:' \
        '-X[exclusive]' \
        '*:btrfs image:_files'
}

_libfsbtrfs "$@"
