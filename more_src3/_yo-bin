#compdef yo
# _yo-bin — Yeoman generator runner (Sindre Sorhus); scaffold projects via npm-published generator-* packages
# upstream: https://github.com/yeoman/yo

_yo-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--no-color[disable color]' \
        '--no-insight[disable insight tracking]' \
        '--insight[enable insight tracking]' \
        '--generators[list installed generators]' \
        '--local-only[only local generators]' \
        '--force[overwrite without prompt]' \
        '--skip-cache[skip cache update]' \
        '--skip-install[skip install]' \
        '*:generator:'
}

_yo-bin "$@"
