#compdef smbmount mount.smbfs
# _smbmount — Samba smbmount / mount.smbfs (legacy CIFS/SMB share mount helper; positional service = //server/share, second is mountpoint, then -o options (username,password,uid,gid,credentials,domain,iocharset,sec,mfsymlinks); -h help, -V version)
# upstream: https://gitlab.com/samba-team/samba (client/smbmount.c)
# Flags from samba client/smbmount.c on tip.

_smbmount() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-r[read only]' \
        '-w[read-write]' \
        '-n[no mtab update]' \
        '-v[verbose]' \
        '-o+[mount options]:options:(username password credentials domain workgroup uid gid file_mode dir_mode iocharset codepage sec ro rw guest forceuid forcegid nounix mfsymlinks vers mapchars cache acl noacl rsize wsize)' \
        '1:service //server/share:' \
        '2:mountpoint:_files -/'
}

_smbmount "$@"
