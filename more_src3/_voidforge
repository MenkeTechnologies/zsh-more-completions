#compdef voidforge
# Documentation: https://github.com/tmcleod3/voidforge
# Reference accessed: 2026-05-22
# Verified: packages/voidforge/scripts/voidforge.ts CLI commands.

# Zsh completion for voidforge - VoidForge AI methodology and project wizard CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'voidforge command' \
      'init[create or configure a project]' \
      'update[update methodology or wizard]' \
      'install[add extension to project]' \
      'uninstall[remove extension from project]' \
      'deploy[deploy project]' \
      'doctor[check versions and health]' \
      'migrate[migrate project to new version]' \
      'version[show wizard and methodology versions]' \
      'templates[list project templates]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--browser[open browser wizard]' \
          '--headless[CLI-only init without browser]' \
          '--name[project name for headless init]:name:' \
          '--core[minimal methodology only]' && ret=0
        ;;
      update)
        _arguments \
          '--self[update the wizard itself]' \
          '--extensions[update all installed extensions]' && ret=0
        ;;
      install|uninstall)
        _arguments '1:extension:' && ret=0
        ;;
      migrate)
        _arguments '1:target:(treasury)' && ret=0
        ;;
      deploy|doctor|version|templates)
        ret=0
        ;;
    esac
    ;;
esac

return ret
