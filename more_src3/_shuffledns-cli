#compdef shuffledns-cli shuffledns
# _shuffledns-cli — ProjectDiscovery ShuffleDNS shuffledns-cli CLI command-line frontend wrapping the ShuffleDNS massdns wrapper for fast subdomain enumeration with public resolver bruteforce open-source written in Go MassDNS-wrapper wildcard-detection-and-removal multiple-resolvers wordlist-based-bruteforce mode-bruteforce-resolve-massdns resolvers-file output-file silent JSON-output stats stream-output verbose retry rate-limit (ProjectDiscovery team, Go); goflags
# upstream: https://github.com/projectdiscovery/shuffledns

_shuffledns-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[domain]:str:' \
        '-domain=+[name]:str:' \
        '-l+[input list]:file:_files' \
        '-list=+[file]:file:_files' \
        '-w+[wordlist]:file:_files' \
        '-wordlist=+[file]:file:_files' \
        '-r+[resolvers file]:file:_files' \
        '-resolver=+[file]:file:_files' \
        '-tr+[trusted resolvers]:file:_files' \
        '-tcp[use TCP]' \
        '-mode+[m]:m:(bruteforce resolve filter)' \
        '-massdns+[path]:file:_files' \
        '-mcp+[massdns conf]:file:_files' \
        '-wt+[wildcard threshold]:n:' \
        '-wd+[wildcard domain]:str:' \
        '-t+[threads]:n:' \
        '-c+[concurrency]:n:' \
        '-retries+[N]:n:' \
        '-strict-wildcard[strict wildcard]' \
        '-massdns-flags+[flags]:str:' \
        '-o+[output file]:file:_files' \
        '-output=+[file]:file:_files' \
        '-no-color[no color]' \
        '-nc[no color]' \
        '-silent[silent]' \
        '-stats[stats]' \
        '-stream[stream]' \
        '-no-bar[no progress bar]' \
        '-raw-output+[file]:file:_files' \
        '-json[JSON output]' \
        '-up[update]' \
        '-duc[disable update check]' \
        '*:domain:'
}

_shuffledns-cli "$@"
