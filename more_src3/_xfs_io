#compdef xfs_io
# _xfs_io — xfsprogs xfs_io (interactive low-level access to a single XFS file's pages, extents, mappings; subcommands include open/close, pread/pwrite, mmap, falloc, mwrite, sync_range, fsync, fadvise, fiemap, lsattr/chattr, copy_range; -c runs one-shot command, -f read+write open, -x expert mode)
# upstream: https://git.kernel.org/pub/scm/fs/xfs/xfsprogs-dev.git
# Flags from xfsprogs io/init.c on tip.

_xfs_io() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[run command (repeatable)]:command:' \
        '-C+[run command in file context]:command:' \
        '-f[read+write open]' \
        '-r[read-only open]' \
        '-i[skip initial seek]' \
        '-n[no fnctl access]' \
        '-p+[set program name]:name:' \
        '-T[open with O_TMPFILE]' \
        '-t[open with O_TRUNC]' \
        '-x[expert mode]' \
        '-d[allow direct I/O]' \
        '-F[use fopen-style mode bits]' \
        '*:file:_files'
}

_xfs_io "$@"
