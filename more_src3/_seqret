#compdef seqret
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/seqret.html
# Reference accessed: 2026-05-21
# Verified: upstream EMBOSS docs at the URL above.
# Removed from prior file: fabricated -osquery= (no such qualifier);
# trimmed -osformat value list to ones explicitly enumerated in upstream
# docs; removed bogus -sask (not a top-level qualifier — sequence-side
# variant is -sask1).

# EMBOSS seqret: read and write sequence(s) - workhorse format converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence(s)]:USA:_files' \
  '-firstonly[only output the first sequence]' \
  '-feature[carry feature tables into output]' \
  '-outseq=[output sequence file]:file:_files' \
  '-osformat=[output sequence format]:format:(embl genbank gff pir swiss dasgff debug listfile fasta)' \
  '-osextension=[output file extension]:ext:' \
  '-osname=[output file base name]:name:' \
  '-osdirectory=[output directory]:dir:_files -/' \
  '-osdbname=[output database name for index files]:name:' \
  '-ossingle[write each sequence to its own file]' \
  '-oufo=[UFO features for output]:ufo:' \
  '-offormat=[output feature format]:format:' \
  '-ofname=[output feature filename]:file:_files' \
  '-ofdirectory=[output feature directory]:dir:_files -/' \
  '-sbegin=[start position of subsequence]:n:' \
  '-send=[end position of subsequence]:n:' \
  '-sreverse[reverse the sequence (DNA only)]' \
  '-supper[uppercase the sequence]' \
  '-slower[lowercase the sequence]' \
  '-snucleotide[mark input as nucleotide]' \
  '-sprotein[mark input as protein]' \
  '-sformat=[input format]:format:' \
  '*:sequence USA:_files' && ret=0
return ret
