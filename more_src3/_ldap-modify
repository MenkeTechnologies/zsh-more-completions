#compdef ldap-modify
# _ldap-modify — distro-shipped LDAP modify wrapper (small helper around OpenLDAP ldapmodify(1) tuned for the local SLAPD; -H URI, -D bind DN, -w password, -y password file, -f LDIF file, -a treat as add, -c continue on error, -x simple bind, -Z TLS, -n dry run, -v verbose, -h help, -V version)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapmodify)
# Flags from OpenLDAP clients/tools/ldapmodify.c on tip.

_ldap-modify() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-f+[LDIF file]:file:_files -g "*.ldif"' \
        '-a[treat as add]' \
        '-c[continue on error]' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-n[dry run]' \
        '-v[verbose]' \
        '*-o+[option=value]:opt:'
}

_ldap-modify "$@"
