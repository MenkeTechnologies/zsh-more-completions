#compdef tsv-filter
# Documentation: https://github.com/eBay/tsv-utils/blob/master/docs/tool_reference/tsv-filter.md
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# All filter operations take a "field-list:value" or "field-list" pattern.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-verbose[detailed help content]' \
  '(- *)--help-options[list options only]' \
  '(- *)--help-fields[help on field syntax]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-H --header)'{-H,--header}'[treat first line as header]' \
  '(-d --delimiter)'{-d,--delimiter}'+[field delimiter]:char' \
  '--or[use OR logic instead of AND]' \
  '(-v --invert)'{-v,--invert}'[invert filter results]' \
  '(-c --count)'{-c,--count}'[output matched line count only]' \
  '--label=[add field indicating filter match]:str' \
  '--label-values=[customize label values]:STR1:STR2' \
  '--line-buffered[immediate output mode]' \
  '*--empty=[field contains no characters]:field-list' \
  '*--not-empty=[field has content]:field-list' \
  '*--blank=[field is empty or whitespace only]:field-list' \
  '*--not-blank=[field contains non-whitespace]:field-list' \
  '*--is-numeric=[value interpretable as number]:field-list' \
  '*--is-finite=[valid number, not NaN/infinity]:field-list' \
  '*--is-nan=[NaN detection]:field-list' \
  '*--is-infinity=[infinity detection]:field-list' \
  '*--le=[numeric less or equal]:FIELD\:VALUE' \
  '*--lt=[numeric less than]:FIELD\:VALUE' \
  '*--ge=[numeric greater or equal]:FIELD\:VALUE' \
  '*--gt=[numeric greater than]:FIELD\:VALUE' \
  '*--eq=[numeric equals]:FIELD\:VALUE' \
  '*--ne=[numeric not equals]:FIELD\:VALUE' \
  '*--str-le=[string less or equal]:FIELD\:VALUE' \
  '*--str-lt=[string less than]:FIELD\:VALUE' \
  '*--str-ge=[string greater or equal]:FIELD\:VALUE' \
  '*--str-gt=[string greater than]:FIELD\:VALUE' \
  '*--str-eq=[string equals]:FIELD\:VALUE' \
  '*--str-ne=[string not equals]:FIELD\:VALUE' \
  '*--istr-eq=[case-insensitive string equals]:FIELD\:VALUE' \
  '*--istr-ne=[case-insensitive string not equals]:FIELD\:VALUE' \
  '*--str-in-fld=[substring match]:FIELD\:VALUE' \
  '*--istr-in-fld=[case-insensitive substring match]:FIELD\:VALUE' \
  '*--str-not-in-fld=[negative substring match]:FIELD\:VALUE' \
  '*--istr-not-in-fld=[case-insensitive negative substring match]:FIELD\:VALUE' \
  '*--regex=[regex match]:FIELD\:REGEX' \
  '*--iregex=[case-insensitive regex match]:FIELD\:REGEX' \
  '*--not-regex=[negative regex match]:FIELD\:REGEX' \
  '*--not-iregex=[case-insensitive negative regex match]:FIELD\:REGEX' \
  '*--char-len-le=[character length less or equal]:FIELD\:VALUE' \
  '*--char-len-lt=[character length less than]:FIELD\:VALUE' \
  '*--char-len-ge=[character length greater or equal]:FIELD\:VALUE' \
  '*--char-len-gt=[character length greater than]:FIELD\:VALUE' \
  '*--char-len-eq=[character length equals]:FIELD\:VALUE' \
  '*--char-len-ne=[character length not equals]:FIELD\:VALUE' \
  '*--byte-len-le=[byte length less or equal]:FIELD\:VALUE' \
  '*--byte-len-lt=[byte length less than]:FIELD\:VALUE' \
  '*--byte-len-ge=[byte length greater or equal]:FIELD\:VALUE' \
  '*--byte-len-gt=[byte length greater than]:FIELD\:VALUE' \
  '*--byte-len-eq=[byte length equals]:FIELD\:VALUE' \
  '*--byte-len-ne=[byte length not equals]:FIELD\:VALUE' \
  '*--ff-le=[field-to-field numeric less or equal]:F1\:F2' \
  '*--ff-lt=[field-to-field numeric less than]:F1\:F2' \
  '*--ff-ge=[field-to-field numeric greater or equal]:F1\:F2' \
  '*--ff-gt=[field-to-field numeric greater than]:F1\:F2' \
  '*--ff-eq=[field-to-field numeric equals]:F1\:F2' \
  '*--ff-ne=[field-to-field numeric not equals]:F1\:F2' \
  '*--ff-str-eq=[field-to-field string equals]:F1\:F2' \
  '*--ff-istr-eq=[field-to-field case-insensitive string equals]:F1\:F2' \
  '*--ff-str-ne=[field-to-field string not equals]:F1\:F2' \
  '*--ff-istr-ne=[field-to-field case-insensitive string not equals]:F1\:F2' \
  '*--ff-absdiff-le=[field-to-field absolute difference less or equal]:F1\:F2\:V' \
  '*--ff-absdiff-gt=[field-to-field absolute difference greater than]:F1\:F2\:V' \
  '*--ff-reldiff-le=[field-to-field relative difference less or equal]:F1\:F2\:V' \
  '*--ff-reldiff-gt=[field-to-field relative difference greater than]:F1\:F2\:V' \
  '*:file:_files' && return 0
