#compdef krill krillc
# _krill — NLnet Labs Krill RPKI Certificate Authority and publication server with krillc admin client (NLnetLabs team, Rust); clap-derive
# upstream: https://github.com/NLnetLabs/krill

_krill() {
    local -a sub=(
        'config:configuration subcommands'
        'health:show daemon health'
        'info:show server info'
        'metrics:show metrics'
        'stats:show stats'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "*.conf *.toml"' \
        '--config=+[config file]:file:_files -g "*.conf *.toml"' \
        '-d[run in foreground with logs to stderr]' \
        '--debug[run in foreground with logs to stderr]' \
        '--log-level=+[level]:l:(off error warn info debug trace)' \
        '--log-file=+[log file]:file:_files' \
        '--log-syslog[log via syslog]' \
        '-f[format check config and exit]' \
        '--format-check[format check config and exit]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krill subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:config cmd:(user repo init)' ;;
                stats) _arguments '1:stats cmd:(repo-objects repo-stats)' ;;
            esac
            ;;
    esac
}

_krill "$@"
