#compdef heimdalld heimdallcli
# Documentation: upstream cmd/heimdalld/service/*.go and
# cmd/heimdallcli/main.go at github.com/MaticNetwork/heimdall
# Reference accessed: 2026-05-30 via gh api inspection of every
# cobra.Command Use:/AddCommand call.
# Polygon Heimdall R79 — Heimdall is Polygon PoS validator/bridge
# layer (Cosmos SDK fork). Two binaries:
# - heimdalld: validator daemon
# - heimdallcli: light-client tool
# Both Cosmos-SDK-derived but with Heimdall-specific extensions
# (Polygon bridge, heimdall-specific genesis, etc.) so kept as a
# separate completion from the standard _gaiad multi-stem.

local curcontext="$curcontext" state line ret=1

case $service in

  heimdalld)
    # Heimdall validator daemon.
    local -a _d_cmds
    _d_cmds=(
      'start:run the full node'
      'tendermint:Tendermint subcommands (show-node-id/show-validator/show-address)'
      'export:export application state to JSON'
      'version:show version'
      'show-account:print account address and public key'
      'show-privatekey:print account private key (DANGEROUS)'
      'rest-server:start a REST server (legacy)'
      'bridge:start the Polygon Heimdall bridge'
      'verify-genesis:verify the genesis file matches expected hash'
      'init:initialize genesis config, priv-validator and p2p-node files'
      'create-testnet:initialize files for a Heimdall testnet'
      'rollback:rollback cosmos-sdk and tendermint state by one height'
      'unsafe-reset-all:reset blockchain database, replays of all consensus state'
      'help:show help'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--home=[node home directory]:dir:_files -/' \
      '--chain-id=[chain ID]:id:' \
      '--log_level=[log level]:level:(debug info warn error)' \
      '--log_format=[log format]:fmt:(plain json)' \
      '--trace[print stack traces on errors]' \
      '(-): :->dcmd' \
      '(-)*:: :->dcmd_args' && ret=0
    case $state in
      dcmd) _describe -t commands 'heimdalld subcommand' _d_cmds && ret=0 ;;
      dcmd_args)
        case $words[1] in
          init)
            _arguments \
              '--home=[node home directory]:dir:_files -/' \
              '--home-client=[client home directory]:dir:_files -/' \
              '--chain-id=[chain ID]:id:' \
              '--id=[validator ID (default 1)]:N:' \
              '--overwrite-genesis[overwrite genesis.json if it exists]' \
              && ret=0
            ;;
          create-testnet)
            _arguments \
              '-o=[output directory (default ./mytestnet)]:dir:_directories' \
              '--output-dir=[output directory]:dir:_directories' \
              '--v=[number of validators (default 4)]:N:' \
              '--n=[number of non-validators (default 8)]:N:' \
              '--node-dir-prefix=[node directory prefix (default node)]:prefix:' \
              '--node-daemon-home=[daemon home name (default heimdalld)]:name:' \
              '--node-cli-home=[CLI home name (default heimdallcli)]:name:' \
              '--node-host-prefix=[node host prefix (default node)]:prefix:' \
              '--chain-id=[chain ID]:id:' \
              '--signer-dump[dump signer info to JSON (default true)]' \
              && ret=0
            ;;
          rollback)
            _arguments \
              '--force[force rollback]' \
              '--home=[node home directory]:dir:_files -/' \
              '--home-client=[client home directory]:dir:_files -/' \
              '--chain-id=[chain ID]:id:' \
              '--id=[validator ID]:N:' \
              && ret=0
            ;;
          start)
            _arguments \
              '--moniker=[node name]:name:' \
              '--p2p.laddr=[P2P listen address]:addr:' \
              '--rpc.laddr=[RPC listen address]:addr:' \
              '--minimum-gas-prices=[minimum gas prices]:prices:' \
              '--pruning=[pruning strategy]:strategy:(syncable nothing everything)' \
              '--halt-height=[halt at height]:N:' \
              '--halt-time=[halt at unix time]:N:' \
              '--bridge[also start the bridge process]' \
              '--all[start with all sidechain bridges]' \
              '--rest-server[also start the REST server]' \
              && ret=0
            ;;
          tendermint)
            _arguments '1:tendermint subcommand:(show-node-id show-validator show-address)' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  heimdallcli)
    # Heimdall light-client.
    local -a _c_cmds
    _c_cmds=(
      'status:query remote node status'
      'query:querying subcommands (validator/block/txs/tx + modules)'
      'tx:transactions subcommands (sign/broadcast/encode + modules)'
      'keys:keyring management'
      'export-heimdall:export genesis file with state dump (requires --home and --chain-id)'
      'address-to-hex:convert address to hex'
      'hex-to-address:convert hex to address'
      'generate-keystore:generate keystore file using private key'
      'generate-validatorkey:generate validator key file using private key'
      'version:show version'
      'help:show help'
    )
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--home=[CLI home directory]:dir:_files -/' \
      '--chain-id=[chain ID of tendermint node]:id:' \
      '--node=[<host>:<port> to tendermint RPC]:url:' \
      '--keyring-backend=[keyring backend]:b:(os file kwallet pass test memory)' \
      '--output=[output format]:fmt:(text json)' \
      '--trust-node[do not verify proofs for queries]' \
      '(-): :->ccmd' \
      '(-)*:: :->ccmd_args' && ret=0
    case $state in
      ccmd) _describe -t commands 'heimdallcli subcommand' _c_cmds && ret=0 ;;
      ccmd_args)
        case $words[1] in
          query|q)
            _arguments \
              '1:query subcommand:(validator block txs tx auth bank staking slashing gov supply distribution clerk topup checkpoint bor chainmanager borvalidator account)' \
              '*::arg:' && ret=0
            ;;
          tx)
            _arguments \
              '1:tx subcommand:(sign broadcast encode auth bank staking slashing gov supply distribution clerk topup checkpoint bor chainmanager borvalidator)' \
              '*::arg:' && ret=0
            ;;
          keys)
            _arguments \
              '1:keys subcommand:(add delete export import list mnemonic parse show update)' \
              '*::arg:' && ret=0
            ;;
          address-to-hex)
            _arguments '1:address:' && ret=0
            ;;
          hex-to-address)
            _arguments '1:hex:' && ret=0
            ;;
          generate-keystore|generate-validatorkey)
            _arguments '1:private key:' && ret=0
            ;;
          export-heimdall)
            _arguments \
              '--home=[home directory]:dir:_files -/' \
              '--chain-id=[chain ID]:id:' \
              && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
