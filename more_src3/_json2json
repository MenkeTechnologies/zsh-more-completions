#compdef json2json jsonstats
# Documentation: source-direct extraction from upstream
# simdjson/simdjson tools/{json2json,jsonstats}.cpp `cxxopts::
# Options(...)`.add_options()(...) chains. Per upstream
# tools/CMakeLists.txt:
#   foreach(tool IN ITEMS json2json jsonstats jsonpointer minify)
#       add_executable("${tool}" "${tool}.cpp")
# the 4 tools share an upstream binary-name registration loop -
# the 2 binaries jsonpointer + minify from this same loop are
# already covered in the corpus.
# Reference accessed: 2026-05-30 via gh api.
# simdjson R157c — 2-stem multi-binary harvest of the 2 simdjson
# example tools not previously covered (jsonpointer + minify
# already in corpus). Sister tools to the heavily-covered JSON
# CLIs (jq/yq/jaq/gron/gomplate/dasel) in the corpus.

case $service in

  json2json)
    # Re-emit a JSON file (round-trip parse + serialize) via the
    # simdjson parser. Useful as a parsing-correctness smoke test.
    _arguments -s -S \
      '(-z --ondemand)'{-z,--ondemand}'[use the On-Demand front-end (default off)]' \
      '(-d --rawdump)'{-d,--rawdump}'[dump the raw content of the parser tape]' \
      '(-f --file)'{-f+,--file=}'[input JSON file]:file:_files -g "*.json"' \
      '(-h --help)'{-h,--help}'[print usage]' \
      '1:input JSON file (positional alternative to -f):_files -g "*.json"'
    ;;

  jsonstats)
    # Print statistics (string/integer/object/array counts, byte
    # counts, escape-character counts) for a JSON file.
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print usage]' \
      '(-f --file)'{-f+,--file=}'[input JSON file]:file:_files -g "*.json"' \
      '1:input JSON file (positional alternative to -f):_files -g "*.json"'
    ;;

esac
