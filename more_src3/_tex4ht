#compdef tex4ht
# Documentation: none found
# Reference accessed: 2026-05-21
# Verified: upstream tug.org tex4ht docs blocked (403); manpages 404.
# STUB: tex4ht uses non-standard option syntax embedded in the input
# filename argument (e.g. `tex4ht file.dvi "-cmozhtf,charset=utf-8"`);
# safe completion is just file arguments.

local curcontext="$curcontext" state line ret=1
_arguments -s -S '*:file:_files -g "*.{tex,dvi}"' && ret=0
return ret
