#compdef ipcrm-cli
# _ipcrm-cli — util-linux ipcrm remove IPC resources CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_ipcrm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[remove all]' \
        '--all[remove all]' \
        '-q+[msqid]:n:' \
        '--queue-id=+[msqid]:n:' \
        '-Q+[msgkey]:str:' \
        '--queue-key=+[msgkey]:str:' \
        '-m+[shmid]:n:' \
        '--shmem-id=+[shmid]:n:' \
        '-M+[shmkey]:str:' \
        '--shmem-key=+[shmkey]:str:' \
        '-s+[semid]:n:' \
        '--semaphore-id=+[semid]:n:' \
        '-S+[semkey]:str:' \
        '--semaphore-key=+[semkey]:str:' \
        '*:type id:'
}

_ipcrm-cli "$@"
