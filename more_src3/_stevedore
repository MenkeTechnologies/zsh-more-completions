#compdef stevedore
# Documentation: https://github.com/gostevedore/stevedore
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local -a _stevedore_commands
_stevedore_commands=(
  'build:Constructs Docker images from defined specifications'
  'create:Establishes new resources'
  'get:Retrieves configuration, builders, images, credentials'
  'initialize:Set up Stevedore with configuration files'
  'promote:Move built images to registries'
  'completion:Generate shell completion scripts'
  'version:Display current version'
  'help:Show help'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'stevedore commands' _stevedore_commands
    ;;
  args)
    case "$words[1]" in
      build)
        _arguments \
          '--builders-path[builders path]:dir:_directories' \
          '--tree[display hierarchical image relationships]' \
          '*:image name'
        ;;
      get)
        _arguments \
          '1:resource:(builders configuration credentials images)'
        ;;
      initialize)
        _arguments \
          '--builders-path[builders path]:dir:_directories' \
          '--credentials-storage-type[credentials storage type]:type:' \
          '--generate-credentials-encryption-key[generate encryption key]' \
          '--images-path[images path]:dir:_directories' \
          '--log-path-file[log path file]:file:_files'
        ;;
      promote)
        _arguments \
          '--promote-image-registry-namespace[target namespace]:namespace:' \
          '*:image name'
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish)'
        ;;
    esac
    ;;
esac
