#compdef source2c
# Documentation: https://github.com/FFmpeg/FFmpeg/blob/master/tools/source2c
# Reference accessed: 2026-05-21
# Verified: source2c shell script at the URL above (FFmpeg tools).
# Takes exactly two positional arguments: input file and output C file.

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files' \
  '2:output C file:_files -g "*.c"' && ret=0

return ret
