#compdef hadoop
# Documentation: https://hadoop.apache.org/docs/stable/hadoop-project-dist/hadoop-common/CommandsManual.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'archive:create a hadoop archive'
  'checknative:check native code availability'
  'classpath:print class path'
  'conftest:validate config XML files'
  'credential:manage credentials and secrets'
  'distch:change ownership and permissions on many files'
  'distcp:copy files or directories recursively'
  'dtutil:fetch and manage delegation tokens'
  'fs:filesystem shell (alias of hdfs dfs)'
  'gridmix:cluster benchmark tool'
  'jar:run a jar file'
  'jnipath:print computed java.library.path'
  'kerbname:convert principals to Hadoop usernames'
  'kdiag:diagnose Kerberos problems'
  'key:manage keys via KeyProvider'
  'kms:run Key Management Server'
  'trace:view and modify tracing settings'
  'version:print version'
  'CLASSNAME:run a specified Java class'
  'envvars:show computed Hadoop env vars'
  'daemonlog:get/set log level for a running daemon'
)

_arguments -C \
  '--buildpaths[enable developer jar versions in classpath]' \
  '--config=[override config directory]:dir:_files -/' \
  '--daemon=[daemon mode]:mode:(start stop status)' \
  '--debug[enable shell debug output]' \
  '(- *)--help[show help]' \
  '--hostnames=[override workers file with hostnames]:list:' \
  '--hosts=[override workers file]:file:_files' \
  '--loglevel=[override log level]:level:(FATAL ERROR WARN INFO DEBUG TRACE)' \
  '--workers[execute on all hosts in workers file]' \
  '*-archives=[archives to unarchive on compute nodes]:list:' \
  '-conf=[application config file]:file:_files -g "*.xml"' \
  '*-D[set property value]:prop=value:' \
  '*-files=[files to copy to cluster]:list:' \
  '-fs=[default FS URL]:uri:' \
  '-jt=[ResourceManager]:jt:' \
  '*-libjars=[jar files for classpath]:list:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'hadoop subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (jar)
        _arguments \
          ':jarfile:_files -g "*.jar"' \
          ':main class:' \
          '*:args:' && ret=0
        ;;
      (key)
        _values 'key action' 'create' 'roll' 'delete' 'list' 'check' && ret=0
        ;;
      (credential)
        _values 'credential action' 'create' 'delete' 'list' 'check' && ret=0
        ;;
      (daemonlog)
        _arguments \
          '-getlevel[get log level]:host\:port:' \
          '-setlevel[set log level]:host\:port:' \
          '-protocol=[protocol]:proto:(http https)' && ret=0
        ;;
    esac
    ;;
esac

return ret
