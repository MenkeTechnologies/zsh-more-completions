#compdef tiff2bw
# Documentation: tiff2bw (libtiff)
# Source: convert a color TIFF to greyscale.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[red channel percent]:pct:' \
    '-G+[green channel percent]:pct:' \
    '-B+[blue channel percent]:pct:' \
    '-r+[rows per strip]:n:' \
    '-c+[compression scheme]:scheme:(lzw zip packbits none)' \
    ':input.tif:_files -g "*.(tif|tiff|TIF|TIFF)"' \
    ':output.tif:_files -g "*.(tif|tiff)"' \
    && ret=0

return ret
