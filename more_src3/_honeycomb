#compdef honeycomb hcm
# Documentation: https://github.com/bendrucker/honeycomb-cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a resources

resources=(
  'api:Honeycomb API helpers'
  'auth:authentication helpers (login/logout/whoami)'
  'board:Honeycomb boards'
  'column:dataset columns'
  'dataset:datasets'
  'environment:Honeycomb environments'
  'key:API keys'
  'marker:dataset markers'
  'mcp:MCP server helpers'
  'query:saved queries / run queries'
  'recipient:notification recipients'
  'slo:service level objectives'
  'trigger:triggers (alerts)'
  'completion:generate shell completion'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[config profile]:profile:' \
  '--format=[output format]:format:(json table)' \
  '--no-interactive[disable interactive prompts]' \
  '--api-url=[override Honeycomb API URL]:url:' \
  '--api-key=[Honeycomb API key]:key:' \
  '--environment=[target environment]:env:' \
  '1: :->res' \
  '*::arg:->args' && ret=0

local -a crud_actions=(
  'list:list resources'
  'get:get a single resource'
  'create:create a resource'
  'update:update a resource'
  'delete:delete a resource'
)

case $state in
  (res) _describe -t res 'honeycomb resource' resources && ret=0 ;;
  (args)
    case $line[1] in
      (board|column|dataset|environment|key|recipient|slo|trigger)
        _describe -t actions 'action' crud_actions && ret=0 ;;
      (auth)
        _arguments '*::sub:(login logout whoami)' && ret=0 ;;
      (marker)
        local -a marker_subs=(
          'list:list markers'
          'add:add a marker'
          'update:update a marker'
          'delete:delete a marker'
        )
        _describe -t mcmds 'marker subcommand' marker_subs && ret=0
        _arguments \
          '--dataset=[dataset (use __all__ for env-wide)]:dataset:' \
          '--type=[marker type]:type:' \
          '--message=[marker message]:msg:' \
          '--url=[marker URL]:url:' \
          '--start_time=[unix start time]:n:' \
          '--end_time=[unix end time]:n:' && ret=0 ;;
      (query)
        _arguments \
          '*::sub:(run get list)' \
          '--dataset=[dataset]:dataset:' \
          '--query-json=[query JSON]:json:' \
          '--query-file=[query JSON file]:file:_files -g "*.json"' \
          '--time-range=[time range in seconds]:n:' && ret=0 ;;
      (api)
        _arguments \
          '*::sub:(get post put patch delete)' \
          '*--header=[HTTP header]:header:' \
          '--data=[request body]:json:' && ret=0 ;;
      (mcp)
        _arguments '*::sub:(serve test)' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
