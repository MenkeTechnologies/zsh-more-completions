#compdef wrangler1
# Documentation: https://www.npmjs.com/package/@cloudflare/wrangler
# Reference accessed: 2026-05-23
# Verified: npm view @cloudflare/wrangler bin (Wrangler v1 legacy).

# Zsh completion for wrangler1 - Cloudflare Wrangler v1 legacy CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'generate:scaffold a Cloudflare Workers project'
  'publish:publish worker to Cloudflare'
  'dev:run worker locally'
  'preview:preview worker'
  'tail:stream worker logs'
  'secret:manage worker secrets'
  'route:manage worker routes'
  'kv:manage Workers KV namespaces'
  'config:manage wrangler configuration'
  'login:authenticate with Cloudflare'
  'whoami:show current Cloudflare account'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'wrangler1 command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
