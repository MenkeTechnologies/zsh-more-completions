#compdef uglifyjs
# Documentation: https://github.com/mishoo/UglifyJS
# Source: mishoo/UglifyJS — JavaScript parser, mangler, compressor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print usage]' \
    '(- *)'{-V,--version}'[print version]' \
    '(-p --parse)'{-p+,--parse=}'[parser options]:opts:' \
    '(-c --compress)'{-c+,--compress=}'[compressor options]:opts:' \
    '(-m --mangle)'{-m+,--mangle=}'[mangle name options]:opts:' \
    '--mangle-props=[mangle properties options]:opts:' \
    '(-b --beautify)'{-b+,--beautify=}'[beautify output options]:opts:' \
    '(-O --output-opts)'{-O+,--output-opts=}'[output options (beautify off)]:opts:' \
    '(-o --output)'{-o+,--output=}'[output file (default STDOUT)]:file:_files' \
    '(--annotations --no-annotations)--annotations[process and preserve comment annotations]' \
    '(--annotations --no-annotations)--no-annotations[ignore and discard comment annotations]' \
    '--comments=[preserve copyright comments]:filter:' \
    '--config-file=[read minify() options from JSON]:file:_files' \
    '*'{-d,--define=}'[global definitions (name=value)]:def:' \
    '(-e --enclose)'{-e+,--enclose=}'[embed everything in a big function]:args:' \
    '--expression[parse a single expression, not a program]' \
    '(--ie --v8 --webkit --no-module)--ie[support non-standard Internet Explorer]' \
    '(--ie --v8 --webkit --no-module)--v8[support non-standard Chrome / Node.js]' \
    '(--ie --v8 --webkit --no-module)--webkit[support non-standard Safari / WebKit]' \
    '--keep-fargs[do not mangle/drop function arguments]' \
    '--keep-fnames[do not mangle/drop function names]' \
    '--module[process input as ES module (implies --toplevel)]' \
    '(--ie --v8 --webkit --no-module)--no-module[avoid runtime-altering optimizations]' \
    '--name-cache=[file to hold mangled-name mappings]:file:_files' \
    '--self[build UglifyJS as library (implies --wrap UglifyJS)]' \
    '--source-map=[source map options]:opts:' \
    '--timings[display operation timings on stderr]' \
    '--toplevel[compress/mangle top-level variables]' \
    '--verbose[diagnostic messages]' \
    '--warn[warning messages]' \
    '--wrap=[wrap everything in a function with given name]:name:' \
    '*:input .js:_files -g "*.(js|mjs|cjs)"' \
    && ret=0

return ret
