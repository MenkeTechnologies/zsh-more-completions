#compdef stowsh
# Documentation: https://github.com/mikepqr/stowsh
# Source: mikepqr/stowsh — Bash GNU-Stow-style dotfile manager.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-D[uninstall package(s)]' \
    '-n[dry-run (preview without changes)]' \
    '-s[skip errors rather than abort on failure]' \
    '-v[verbose output]' \
    '-vv[even more verbose output]' \
    '-g[ignore files not tracked by git]' \
    '-t+[target directory (default cwd)]:dir:_files -/' \
    '(- *)'{-h,--help}'[show help]' \
    '*:package path:_files -/' \
    && ret=0

return ret
