#compdef lwconfig
# Documentation: BeyondTrust lwconfig
# Source: josephholsten/pbis lwconfig/src/main.c (master) — read/write Likewise registry settings (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--file+[apply settings from file]:file:_files' \
    '--list[list known settings]' \
    '--dump[dump current settings as a config]' \
    '--show+[show value of setting]:name:_default' \
    '--detail[show details]' \
    '--details[show details]' \
    '--verbose[verbose output]' \
    '*:setting name=value:_default' \
    && ret=0

return ret
