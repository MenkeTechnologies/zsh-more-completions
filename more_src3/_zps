#compdef zps
# Documentation: https://github.com/orhun/zps
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# Removed from prior file: -t (scan process tree), -s (states),
# and the wrong -n (was "show only zombies"); -p was incorrectly
# typed to accept a PID — upstream -p/--prompt takes no argument.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[list all user-space processes]' \
  '(-r --reap)'{-r,--reap}'[reap zombie processes]' \
  '(-s --signal)'{-s,--signal}'+[signal to use on zombie parents]:signal:_signals' \
  '(-p --prompt)'{-p,--prompt}'[show prompt for selecting processes]' \
  '(-q --quiet)'{-q,--quiet}'[reap in quiet mode]' \
  '(-n --no-color)'{-n,--no-color}'[disable color output]' && ret=0

return ret
