#compdef tagpending
# Documentation: https://manpages.debian.org/tagpending
# Source: debian/devscripts scripts/tagpending.pl — tag Debian bugs as pending (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-v --verbose --no-verbose)'{-v,--verbose}'[verbose output]' \
    '--no-verbose[disable verbose]' \
    '(-n --noact)'{-n,--noact}'[do not actually send messages]' \
    '(--no-comments)--comments[include comments from changelog]' \
    '--no-comments[do not include comments]' \
    '(-s --silent)'{-s,--silent}'[do not show output]' \
    '(-f --force)'{-f,--force}'[force; offline mode]' \
    '(-c --confirm)'{-c,--confirm}'[confirm before sending]' \
    '(-t --to)'{-t+,--to=}'[only consider entries since version]:version:_default' \
    '(-w --wnpp)'{-w,--wnpp}'[consider WNPP bugs as well]' \
    '(-i --interactive)'{-i,--interactive}'[interactive mode]' \
    && ret=0

return ret
