#compdef kn-quickstart
# Documentation: https://github.com/knative-extensions/kn-plugin-quickstart/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream knative-extensions/kn-plugin-quickstart README.
# Removed invented flags --config, --install-eventing,
# --install-serving, --registry-port, --cluster-name, --kubeconfig,
# --version (option). Real flags: --extraMountHostPath,
# --extraMountContainerPath, --registry (kind), -h/--help.

# kn-quickstart: Knative quickstart plugin (one-command local install)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'kind:quickstart with Kind'
  'minikube:quickstart with Minikube'
  'completion:generate autocompletion script for the specified shell'
  'version:print the plugin version'
  'help:help about any command'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--extraMountHostPath=[host path for mounting (kind)]:path:_files -/' \
  '--extraMountContainerPath=[container path for mounting (kind)]:path:' \
  '--registry[configure local container image registry (kind)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kn-quickstart command' commands && ret=0 ;;
esac
return ret
