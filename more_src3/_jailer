#compdef jailer
# Documentation: https://github.com/firecracker-microvm/firecracker/blob/main/docs/jailer.md
# Reference accessed: 2026-05-19
# Verified: upstream docs + src/jailer/src/main.rs Argument list.
# Removed fabricated --node and -V short flag (source defines only the
# long --version; no --node argument exists).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print the binary version number]' \
  '--id=[microVM unique id]:id:' \
  '--exec-file=[path to the Firecracker binary to exec]:file:_files' \
  '--uid=[user id to switch to inside the jail]:uid:' \
  '--gid=[group id to switch to inside the jail]:gid:' \
  '--chroot-base-dir=[chroot base directory]:dir:_files -/' \
  '--netns=[network namespace path to join]:path:' \
  '--cgroup=[cgroup file=value (repeatable)]:kv:' \
  '--cgroup-version=[cgroup version]:ver:(1 2)' \
  '--parent-cgroup=[parent cgroup for nested hierarchies]:cgroup:' \
  '--resource-limit=[resource=value process limit (repeatable)]:kv:' \
  '--daemonize[setsid and redirect stdio to /dev/null]' \
  '--new-pid-ns[spawn into a new PID namespace]' \
  '*::firecracker args:_files' && ret=0
return ret
