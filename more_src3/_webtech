#compdef webtech
# Documentation: https://github.com/ShielderSec/webtech
# Reference accessed: 2026-05-21
# Verified: upstream README option list.

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[show help message]'
  '(-u --urls)'{-u+,--urls=}'[URL(s) to scan]:url:'
  '(--ul --urls-file)'{--ul=,--urls-file=}'[file containing URL list]:file:_files'
  '(--ua --user-agent)'{--ua=,--user-agent=}'[custom user agent]:user-agent:'
  '(--rua --random-user-agent)'{--rua,--random-user-agent}'[use random user agent]'
  '(--db --database-file)'{--db=,--database-file=}'[custom database file]:file:_files'
  '(--oj --json)'{--oj,--json}'[output JSON report]'
  '(--og --grep)'{--og,--grep}'[output grepable report]'
  '(--udb --update-db)'{--udb,--update-db}'[force update of remote database files]'
)

_arguments -s -S $arguments
