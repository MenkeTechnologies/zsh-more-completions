#compdef jalv_console jalv.console jalv-console
# _jalv_console — David Robillard Jalv jalv_console headless LV2 plugin host running plugins without a GUI for batch processing and scripting (drobilla team, C); getopt
# upstream: https://gitlab.com/drobilla/jalv

_jalv_console() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[dump events]' \
        '--dump[dump events]' \
        '-t[trace]' \
        '--trace[trace]' \
        '-n+[client name]:str:' \
        '--name=+[client name]:str:' \
        '-l+[load state]:file:_files -g "*.ttl *.lv2"' \
        '--load=+[load state]:file:_files -g "*.ttl *.lv2"' \
        '-p+[preset uri]:str:' \
        '--preset=+[preset uri]:str:' \
        '-c+[control symbol=value]:str:' \
        '--control=+[control symbol=value]:str:' \
        '-b+[buffer-size]:n:' \
        '--buffer-size=+[buffer-size]:n:' \
        '-U+[ui uri]:str:' \
        '--ui-uri=+[ui uri]:str:' \
        '-x[exact]' \
        '--exact[exact]' \
        '-X+[exclusive]:b:(0 1)' \
        '-N[no menu]' \
        '-s+[update rate Hz]:f:' \
        '--update-rate=+[update rate Hz]:f:' \
        '--no-menu[no menu]' \
        '*:LV2 plugin URI:'
}

_jalv_console "$@"
