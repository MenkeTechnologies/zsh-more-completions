#compdef linkerd-proxy linkerd2-proxy
# Documentation: https://github.com/linkerd/linkerd2-proxy/blob/main/linkerd/app/src/env.rs
# Reference accessed: 2026-05-19
# Verified: linkerd/linkerd2-proxy linkerd/app/src/env.rs.
# STUB: linkerd2-proxy is configured exclusively through environment variables
# (LINKERD2_PROXY_* / ENV_* keys parsed in linkerd/app/src/env.rs); it does
# not accept CLI flags. Provide a no-op file completion so the command itself
# is recognized.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*::linkerd-proxy args:_files' && ret=0
return ret
