#compdef windows_exporter
# _windows_exporter — Prometheus exporter for Windows machines (prometheus-community/windows_exporter)
# upstream: https://github.com/prometheus-community/windows_exporter
# Flags from cmd/windows_exporter/main.go (kingpin).

_windows_exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--config.file=[YAML configuration file]:file:_files -g "*.(yml|yaml)"' \
        '--telemetry.path=[URL path for metrics]:path:' \
        '--web.disable-exporter-metrics[exclude exporter-self metrics]' \
        '--collectors.enabled=[comma-separated collectors to enable]:collectors:' \
        '--collectors.disabled=[comma-separated collectors to disable]:collectors:' \
        '--scrape.timeout-margin=[seconds to subtract from client timeout]:secs:' \
        '--debug.enabled[expose /debug/pprof endpoints]' \
        '--process.priority=[exporter process priority]:level:(realtime high abovenormal normal belownormal low)' \
        '--process.memory-limit=[soft memory limit in bytes]:bytes:' \
        '--web.listen-address=[bind address(es)]:addr:' \
        '--web.config.file=[exporter-toolkit web config]:file:_files' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)'
}

_windows_exporter "$@"
