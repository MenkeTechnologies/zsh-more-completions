#compdef wokwi wokwi-cli
# _wokwi — Wokwi wokwi-cli command-line interface for the Wokwi online embedded simulator Arduino ESP32 Pi Pico (wokwi team, Rust); clap-derive
# upstream: https://github.com/wokwi/wokwi-cli

_wokwi() {
    local -a sub=(
        'run:run simulation locally'
        'test:run test scenarios'
        'login:log into Wokwi account'
        'logout:remove credentials'
        'doctor:run diagnostic checks'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[disable color]' \
        '--token=+[Wokwi token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'wokwi subcommand' sub ;;
        args)
            case $words[1] in
                run|test) _arguments \
                    '--diagram=+[diagram.json]:file:_files -g "*.json"' \
                    '--elf=+[elf binary]:file:_files -g "*.elf *.bin *.hex"' \
                    '--firmware=+[firmware binary]:file:_files -g "*.bin *.hex *.elf *.uf2"' \
                    '--gdb=+[port]:port:_ports' \
                    '--gdb-listen=+[host:port]:str:' \
                    '--gdb-no-load[no load via gdb]' \
                    '--timeout=+[seconds]:n:' \
                    '--timeout-exit-code=+[N]:n:' \
                    '--interactive[interactive]' \
                    '--serial-log-file=+[file]:file:_files' \
                    '--scenario=+[scenario yaml]:file:_files -g "*.yml *.yaml"' \
                    '--screenshot-part=+[part id]:str:' \
                    '--screenshot-time=+[ms]:n:' \
                    '--screenshot-file=+[file]:file:_files -g "*.png"' \
                    '--expect-text=+[text]:str:' \
                    '--fail-text=+[text]:str:' \
                    '*:project dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_wokwi "$@"
