#compdef yace
# Documentation: https://github.com/nerdswords/yet-another-cloudwatch-exporter
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above (YACE README + flags).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '--config.file=[Exporter config file]:file:_files -g "*.{yaml,yml}"' \
  '--cloudwatch-concurrency=[concurrent CloudWatch metric requests]:n:' \
  '--tag-concurrency=[concurrent tag requests]:n:' \
  '--scraping-interval=[seconds between background scrapes]:seconds:' \
  '--decoupled-scraping[scrape metrics in background at fixed intervals]' \
  '*::args: _default'
