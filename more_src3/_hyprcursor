#compdef hyprcursor-util
# _hyprcursor-util — Vaxry Hyprwm hyprcursor cursor theme format CLI converter and extractor (hyprwm team, C++); custom argparse
# upstream: https://github.com/hyprwm/hyprcursor

_hyprcursor-util() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--create=+[xcursor theme dir]:dir:_files -/' \
        '-c+[xcursor theme dir]:dir:_files -/' \
        '--extract=+[hyprcursor theme]:dir:_files -/' \
        '-x+[hyprcursor theme]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--name=+[theme name]:str:' \
        '-n+[theme name]:str:' \
        '--description=+[description]:str:' \
        '-d+[description]:str:' \
        '*:dir:_files -/'
}

_hyprcursor-util "$@"
