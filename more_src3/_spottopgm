#compdef spottopgm
# Documentation: man spottopgm (Netpbm)
# Source: convert a SPOT satellite image to PGM (with optional crop rectangle).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-1 -2 -3)-1[band 1]' \
    '(-1 -2 -3)-2[band 2]' \
    '(-1 -2 -3)-3[band 3]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:first-col first-line last-col last-line input:_files' \
    && ret=0

return ret
