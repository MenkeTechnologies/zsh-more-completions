#compdef tuist
# Documentation: https://github.com/tuist/tuist
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: tuist has many subcommands but the project ships its own shell
# completions; per-subcommand flag detail not verifiable in WebFetch.
# Providing top-level commands only; arguments delegated to file completion.

local curcontext="$curcontext" state line ret=1
local -a _tuist_cmds

_tuist_cmds=(
  'build:build the project'
  'cache:cache frameworks'
  'clean:clean project artifacts'
  'edit:edit the project manifest'
  'generate:generate the Xcode project'
  'graph:export dependency graph'
  'init:initialize a new project'
  'install:install project dependencies'
  'inspect:inspect bundle / project'
  'migration:utilities for migrating to Tuist'
  'plugin:manage Tuist plugins'
  'run:run a scheme'
  'scaffold:scaffold files from a template'
  'test:test the project'
  'version:print the current version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:_files' && ret=0

case $state in
  cmd) _describe -t commands 'tuist command' _tuist_cmds && ret=0 ;;
esac

return ret
