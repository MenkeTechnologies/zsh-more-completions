#compdef sqlitestudio
# Documentation: https://github.com/pawelsalawa/sqlitestudio
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# STUB: Qt GUI app; only generic --help/--version/database-file invocation documented.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '*:database:_files -g "*.(db|sqlite|sqlite3)"' && ret=0
return ret
