#compdef markdown-pp markdownpp
# _markdown-pp — preprocessor for Markdown files (jreese/markdown-pp)
# upstream: https://github.com/jreese/markdown-pp
# Flags from MarkdownPP/main.py (argparse).

_markdown-pp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-w --watch)'{-w,--watch}'[watch for file changes and recompile]' \
        '(-o --output)'{-o+,--output=}'[output file name]:file:_files' \
        '(-e --exclude)'{-e+,--exclude=}'[comma-separated modules to exclude]:modules:' \
        '*:input file or directory:_files -g "*.mdpp"'
}

_markdown-pp "$@"
