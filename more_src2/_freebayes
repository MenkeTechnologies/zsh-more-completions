#compdef freebayes
# Documentation: https://github.com/freebayes/freebayes
# Documentation: https://github.com/freebayes/freebayes/blob/master/src/Parameters.cpp
# Reference accessed: 2026-05-27
# Verified: upstream src/Parameters.cpp long_options[] and usage() (freebayes/freebayes)

# Zsh completion for freebayes (Bayesian genetic variant caller)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help dialog]' \
  '--version[print release number and git commit id]' \
  '(-b --bam)'{-b+,--bam=}'[add BAM file to the set to be analyzed]:bam file:_files -g "*.(bam|BAM)"' \
  '(-L --bam-list)'{-L+,--bam-list=}'[file containing list of BAM files]:bam list:_files' \
  '(-c --stdin)'{-c,--stdin}'[read BAM input on stdin]' \
  '(-f --fasta-reference)'{-f+,--fasta-reference=}'[reference FASTA file]:fasta:_files -g "*.(fa|fasta|fna)"' \
  '(-t --targets)'{-t+,--targets=}'[limit analysis to targets in BED file]:bed:_files -g "*.bed"' \
  '(-r --region)'{-r+,--region=}'[limit analysis to region (chr\:start-end)]:region:' \
  '(-s --samples)'{-s+,--samples=}'[limit analysis to samples listed in file]:samples file:_files' \
  '--populations=[file mapping samples to populations]:populations file:_files' \
  '(-A --cnv-map)'{-A+,--cnv-map=}'[copy number map BED file]:cnv bed:_files -g "*.bed"' \
  '(-v --vcf)'{-v+,--vcf=}'[output VCF results to FILE]:vcf out:_files' \
  '--gvcf[write gVCF output indicating coverage in uncalled regions]' \
  '--gvcf-chunk=[emit gVCF record every NUM bases]:num:' \
  '--gvcf-dont-use-chunk=[disable gvcf chunking with boolean]:bool:(true false)' \
  '--variant-input=[use variants in VCF as input]:vcf:_files -g "*.vcf*"' \
  '-@+[use variants in VCF as input]:vcf:_files -g "*.vcf*"' \
  '(-l --only-use-input-alleles)'{-l,--only-use-input-alleles}'[only provide calls for alleles in input VCF]' \
  '--haplotype-basis-alleles=[VCF defining haplotype basis alleles]:vcf:_files -g "*.vcf*"' \
  '--report-all-haplotype-alleles[report all alleles at haplotype sites]' \
  '--report-monomorphic[report monomorphic loci and all considered alleles]' \
  '(-P --pvar)'{-P+,--pvar=}'[report sites with polymorphism probability >= N]:n:' \
  '--strict-vcf[generate strict VCF format]' \
  '(-T --theta)'{-T+,--theta=}'[expected mutation rate / nucleotide diversity]:theta:' \
  '(-p --ploidy)'{-p+,--ploidy=}'[default ploidy for analysis]:n:' \
  '(-J --pooled-discrete)'{-J,--pooled-discrete}'[model pooled samples with discrete genotypes]' \
  '(-K --pooled-continuous)'{-K,--pooled-continuous}'[output all alleles passing input filters]' \
  '(-Z --use-reference-allele)'{-Z,--use-reference-allele}'[include reference allele as observation from same population]' \
  '--reference-quality=[mapping/base quality for reference allele observations]:mq,bq:' \
  '(-n --use-best-n-alleles)'{-n+,--use-best-n-alleles=}'[evaluate only best N SNP alleles]:n:' \
  '(-E --max-complex-gap --haplotype-length)'{-E+,--max-complex-gap=,--haplotype-length=}'[max gap length for complex haplotype calls]:n:' \
  '--min-repeat-size=[minimum total repeat length in bp]:n:' \
  '--min-repeat-entropy=[minimum entropy threshold for tandem-repeat region]:bits:' \
  '--no-partial-observations[exclude observations not fully spanning haplotype window]' \
  '--throw-away-indel-obs[remove indel observations from input]' \
  '--throw-away-mnps-obs[remove MNP observations from input]' \
  '--throw-away-complex-obs[remove complex allele observations from input]' \
  '--throw-away-snp-obs[remove SNP observations from input]' \
  '--dont-left-align-indels[disable indel left-alignment]' \
  '(-m --min-mapping-quality)'{-m+,--min-mapping-quality=}'[min mapping quality (Q)]:q:' \
  '(-q --min-base-quality)'{-q+,--min-base-quality=}'[min base quality (Q)]:q:' \
  '(-R --min-supporting-allele-qsum)'{-R+,--min-supporting-allele-qsum=}'[min sum of allele observation qualities]:q:' \
  '(-Y --min-supporting-mapping-qsum)'{-Y+,--min-supporting-mapping-qsum=}'[min sum of mapping qualities supporting allele]:q:' \
  '(-Q --mismatch-base-quality-threshold)'{-Q+,--mismatch-base-quality-threshold=}'[count base mismatches with quality >= Q]:q:' \
  '(-U --read-mismatch-limit)'{-U+,--read-mismatch-limit=}'[exclude reads with >N mismatches]:n:' \
  '(-z --read-max-mismatch-fraction)'{-z+,--read-max-mismatch-fraction=}'[exclude reads with >fraction mismatches]:fraction:' \
  '--read-snp-limit=[exclude reads with >N SNPs]:n:' \
  '(-e --read-indel-limit)'{-e+,--read-indel-limit=}'[exclude reads with >N indels]:n:' \
  '--indel-exclusion-window=[exclude observations within N bp of indels]:n:' \
  '(-0 --standard-filters)'{-0,--standard-filters}'[use stringent input filters (-m 30 -q 20)]' \
  '(-4 --use-duplicate-reads)'{-4,--use-duplicate-reads}'[include duplicate-marked alignments]' \
  '(-F --min-alternate-fraction)'{-F+,--min-alternate-fraction=}'[require this fraction of reads supporting alternate]:fraction:' \
  '(-C --min-alternate-count)'{-C+,--min-alternate-count=}'[require N reads supporting alternate in one sample]:n:' \
  '(-3 --min-alternate-qsum)'{-3+,--min-alternate-qsum=}'[require qual sum N supporting alternate]:q:' \
  '(-G --min-alternate-total)'{-G+,--min-alternate-total=}'[require N reads across population for alternate]:n:' \
  '--min-coverage=[require minimum coverage N at site]:n:' \
  '--limit-coverage=[downsample read coverage to N at high-depth sites]:n:' \
  '(-g --skip-coverage)'{-g+,--skip-coverage=}'[skip positions with coverage >N]:n:' \
  '--trim-complex-tail[trim complex tails of haplotype observations]' \
  '(-w --hwe-priors-off)'{-w,--hwe-priors-off}'[disable HWE prior probability estimation]' \
  '(-V --binomial-obs-priors-off)'{-V,--binomial-obs-priors-off}'[disable binomial observation priors]' \
  '(-a --allele-balance-priors-off)'{-a,--allele-balance-priors-off}'[disable allele balance priors]' \
  '--observation-bias=[file with length-dependent allele observation biases]:file:_files' \
  '--base-quality-cap=[cap base quality at Q]:q:' \
  '--prob-contamination=[contamination estimate for all samples]:fraction:' \
  '--legacy-gls[use legacy genotype likelihood calculations]' \
  '--contamination-estimates=[per-sample contamination estimates file]:file:_files' \
  '(-D --read-dependence-factor)'{-D+,--read-dependence-factor=}'[scale successive observations by factor]:factor:' \
  '(-j --use-mapping-quality)'{-j,--use-mapping-quality}'[use mapping quality in data likelihoods]' \
  '(-H --harmonic-indel-quality)'{-H,--harmonic-indel-quality}'[weight indel base qualities harmonically]' \
  '(-B --genotyping-max-iterations)'{-B+,--genotyping-max-iterations=}'[max EM iterations during genotyping]:n:' \
  '--genotyping-max-banddepth=[max band depth for genotyping]:n:' \
  '(-W --posterior-integration-limits)'{-W+,--posterior-integration-limits=}'[posterior integration bandwidth,depth]:n,m:' \
  '(-N --exclude-unobserved-genotypes)'{-N,--exclude-unobserved-genotypes}'[skip sample genotypings with no supporting reads]' \
  '(-S --genotype-variant-threshold)'{-S+,--genotype-variant-threshold=}'[posterior threshold for genotype variant calls]:n:' \
  '--site-selection-max-iterations=[max iterations for site selection]:n:' \
  '--report-genotype-likelihood-max[report genotype with max likelihood instead of MAP]' \
  '--genotype-qualities[compute and report genotype qualities (GQ)]' \
  '(-d --debug)'{-d,--debug}'[print debugging output]' \
  '*:bam file:_files -g "*.(bam|BAM)"' && ret=0

return ret
