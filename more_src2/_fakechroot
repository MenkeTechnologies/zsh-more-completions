#compdef fakechroot
# Documentation: https://github.com/dex4er/fakechroot/blob/master/scripts/fakechroot.sh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-v,--version}'[show version]' \
  {-l+,--lib=}'[path to replacement libfakechroot.so]:library path:_files' \
  {-d+,--elfloader=}'[ELF loader (ld.so)]:loader:_files' \
  {-e+,--environment=}'[load environment configuration type]:type:' \
  {-s,--use-system-libs}'[use system libraries before fakechroot libraries]' \
  {-c+,--config-dir=}'[override config directory]:config directory:_directories' \
  {-b+,--bindir=}'[bin directory]:bin directory:_directories' \
  '--[end of options, command follows]' \
  '*::command:_normal' \
  && ret=0

return ret
