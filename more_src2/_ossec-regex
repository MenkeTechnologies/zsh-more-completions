#compdef ossec-regex
# Documentation: https://www.ossec.net/docs/docs/programs/ossec-regex.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ossec-regex: validate a regex pattern; reads test strings from stdin.
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:regex pattern:' && ret=0
return ret
