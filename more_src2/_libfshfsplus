#compdef fshfsplusinfo fshfsplusmount
# _libfshfsplus — libfshfsplus tools (libyal Apple HFS+ / HFSX parser; fshfsplusinfo dumps volume header + catalog + extents B-trees, fshfsplusmount FUSE-mounts the volume read-only; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E entry filter, -F path filter, -X exclusive; positional argument is the HFS+ image)
# upstream: https://github.com/libyal/libfshfs
# Common flag shape from libyal/libfshfs fshfstools/* on tip.

_libfshfsplus() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[entry filter]:entry:' \
        '-F+[path filter]:path:' \
        '-X[exclusive]' \
        '*:HFS+ image:_files'
}

_libfshfsplus "$@"
