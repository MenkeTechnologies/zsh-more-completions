#compdef gbox
# Documentation: https://docs.gbox.ai/cli/gbox-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gbox: CLI and MCP for gbox; AI-agent automation for Android/Browser/Desktop (babelcloud/gbox).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :_default' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'login:Login using GitHub OAuth'
      'box:Manage box resources'
      'device-connect:Manage remote connections for local Android devices'
      'port-forward:Forward ports from a remote box to your local machine'
      'mcp:Manage MCP configuration operations'
      'profile:Manage configuration profiles'
      'version:Print the client version information'
      'completion:Generate the autocompletion script for the specified shell'
    )
    _describe -t commands 'gbox command' cmds && ret=0
    ;;
esac

return ret
