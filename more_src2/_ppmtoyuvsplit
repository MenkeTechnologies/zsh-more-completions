#compdef ppmtoyuvsplit
# Documentation: man ppmtoyuvsplit (Netpbm)
# Source: convert a PPM to a triplet of YUV planes (basename.Y, .U, .V).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:basename:' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
