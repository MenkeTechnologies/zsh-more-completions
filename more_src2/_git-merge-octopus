#compdef git-merge-octopus
# Documentation: https://git-scm.com/docs/git-merge
# Source: git/git git-merge-octopus.sh — octopus merge strategy (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:merge bases -- heads:_default' \
    && ret=0

return ret
