#compdef pamunlookup
# Documentation: man pamunlookup (Netpbm)
# Source: reverse pamlookup — produce an index image from a color image and lookup table.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-lookupfile=[lookup color PAM file]:file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
