#compdef psrose
# Documentation: https://docs.generic-mapping-tools.org/latest/psrose.html
# Source: GenericMappingTools/gmt classic-mode psrose — rose / wind / sector diagrams of directional data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[sector width (degrees)]:degrees:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT for sector coloring]:cpt:_files -g "*.cpt(-.)"' \
    '-D[center sectors on bin intervals]' \
    '-E+[principal/mean direction vectors]:opts:_default' \
    '-F[omit scale-length bar]' \
    '-G+[sector fill]:color:_default' \
    '-I[compute stats, no plot]' \
    '-J+[projection (X diameter form only)]:proj:_default' \
    '-L+[cardinal-direction labels]:labels:_default' \
    '-M+[vector params]:opts:_default' \
    '-N+[overlay von Mises curve]:opts:_default' \
    '-Q+[confidence level for significance test]:pct:_default' \
    '-R+[region (radius, azimuth)]:region:_default' \
    '-S[normalize radii to 0..1]' \
    '-T[input is orientation data (180° ambiguity)]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z+[scale input radii]:factor:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-t+[transparency percent]:pct:_default' \
    '*:input table:_files' \
    && ret=0

return ret
