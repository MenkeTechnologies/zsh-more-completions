#compdef rnaeval
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAeval.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNAeval: evaluate free energy of given RNA structure
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output (per-loop energies)]' \
  '(-T --temp)'{-T,--temp=}'[temperature in C]:temp:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[circular RNA]' \
  '(-g --gquad)'{-g,--gquad}'[G-quadruplex formation]' \
  '(-i --infile)'{-i,--infile=}'[input file]:file:_files' \
  '(-a --msa)'{-a,--msa}'[input is Stockholm MSA]' \
  '(-P --paramFile)'{-P,--paramFile=}'[parameter file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--salt=[salt concentration in molar]:val:' \
  '--logML[use log model for multiloop energies]' \
  '--nsp=[non-standard base pair list]:pairs:' \
  '--energyModel=[energy model]:em:' \
  '--shape=[SHAPE reactivity data]:file:_files' \
  '--shapeMethod=[SHAPE conversion strategy]:method:' \
  '--shapeConversion=[SHAPE conversion method]:method:' \
  '--cfactor=[covariance term weight]:val:' \
  '--nfactor=[non-compatible penalty]:val:' \
  '(-r --ribosum_scoring)'{-r,--ribosum_scoring}'[apply RIBOSUM scoring]' \
  '(-R --ribosum_file)'{-R,--ribosum_file=}'[RIBOSUM matrix file]:file:_files' \
  '*:RNA sequence/structure file:_files' && ret=0
return ret
