#compdef domainjoin-cli
# Documentation: man domainjoin-cli(8)
# Source: josephholsten/pbis domainjoin/domainjoin-cli/src/main.c (master) — PBIS AD domain-join CLI (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'query:show current domain-join status'
    'setname:set computer name'
    'join:join an Active Directory domain'
    'leave:leave the current AD domain'
    'fixfqdn:repair computer FQDN'
    'configure:enable/disable PAM/nsswitch/ssh/krb5 modules'
    'get_os_type:show detected OS type'
    'get_arch:show CPU architecture'
    'get_distro:show distro name'
    'get_distro_version:show distro version'
    'raise_error:raise a debug error code'
)

_arguments -s -C \
    '--help[show help]' \
    '--help-internal[show debug command help]' \
    '--logfile=[log file path or "." for console]:file:_files' \
    '--loglevel=[log level]:level:(error warning info verbose)' \
    '1:command:->cmd' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmd) _describe -t commands 'domainjoin-cli command' cmds && ret=0 ;;
    cmdargs)
        case $line[1] in
            join)
                _arguments \
                    '--notimesync[do not synchronize time with DC]' \
                    '*--enable+[enable module]:module:(pam nsswitch ssh krb5)' \
                    '*--disable+[disable module]:module:(pam nsswitch ssh krb5)' \
                    '--ou+[organizational unit]:OU:_default' \
                    '--multiple[allow multiple-domain join]' \
                    '--preview[preview join steps]' \
                    '--advanced[show advanced details]' \
                    '--details+[show details for module]:module:(pam nsswitch ssh krb5)' \
                    '--assumeDefaultDomain=[assume default domain]:yes_no:(yes no)' \
                    '--userDomainPrefix=[short domain name]:name:_default' \
                    '--trustEnumerationWaitSeconds=[trust enumeration wait]:seconds:_default' \
                    '*:positional:_default' ;;
            leave)
                _arguments \
                    '*--enable+[enable module]:module:(pam nsswitch ssh krb5)' \
                    '*--disable+[disable module]:module:(pam nsswitch ssh krb5)' \
                    '--multiple+[domain name to leave]:domain:_default' \
                    '--keepLicense[keep license after leaving]' \
                    '--deleteAccount+[delete account]:user:_users' \
                    '--preview[preview leave steps]' \
                    '--advanced[show advanced details]' \
                    '--details+[show details for module]:module:(pam nsswitch ssh krb5)' \
                    '*:positional:_default' ;;
            configure)
                _arguments \
                    '(--enable --disable)--enable[enable module]' \
                    '(--enable --disable)--disable[disable module]' \
                    '--testprefix+[test root prefix]:dir:_files -/' \
                    '--long+[long domain name]:domain:_default' \
                    '--short+[short domain name]:domain:_default' \
                    '1:module:(pam nsswitch ssh krb5 eventfwdd reapsysld)' ;;
            setname) _arguments '1:computer name:_default' ;;
            raise_error) _arguments '1:error code/name:_default' ;;
        esac
        ;;
esac

return ret
