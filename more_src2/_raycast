#compdef raycast raycast-cli ray
# _raycast — Raycast macOS productivity launcher Ray CLI alias (Raycast Inc., TypeScript); commander
# upstream: https://github.com/raycast/extensions

_raycast() {
    local -a sub=(
        'login:login to Raycast account'
        'logout:logout'
        'whoami:show current user'
        'init:scaffold extension'
        'create-extension:scaffold extension'
        'develop:start dev mode'
        'build:build extension'
        'lint:lint extension'
        'fix-lint:auto-fix lint issues'
        'pull-contributions:pull contributions'
        'publish:publish extension'
        'evals:run AI evals'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'raycast subcommand' sub ;;
        args)
            case $words[1] in
                init|create-extension) _arguments \
                    '--template=+[template]:t:(typescript javascript)' \
                    '--no-install[no install]' \
                    '--non-interactive[non-interactive]' ;;
                develop) _arguments \
                    '--watch[watch]' \
                    '--target=+[target]:t:(extension)' \
                    '--port=+[dev server port]:port:' ;;
                build) _arguments \
                    '--target=+[target]:t:(extension)' \
                    '--out-dir=+[output dir]:dir:_files -/' \
                    '--source-maps[source maps]' \
                    '--no-minify[no minify]' \
                    '--skip-types[skip types]' ;;
                lint|fix-lint) _arguments \
                    '--target=+[target]:t:(extension)' ;;
                publish) _arguments \
                    '--non-interactive[non-interactive]' \
                    '--skip-build[skip build]' \
                    '--target=+[target]:t:(extension)' ;;
                evals) _arguments \
                    '1:cmd:(run pull)' \
                    '--config=+[config file]:file:_files' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_raycast "$@"
