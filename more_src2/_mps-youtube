#compdef mpsyt mps-youtube
# _mps-youtube — mpsyt YouTube terminal player (Python); search + stream YouTube audio via mpv/mplayer with playlist management
# upstream: https://github.com/mps-youtube/yewtube

_mps-youtube() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug log]' \
        '--logging[enable logging]' \
        '--no-textart[disable text art]' \
        '--no-autosize[disable auto-size]' \
        '--no-preload[disable preload]' \
        '--no-update[skip update check]' \
        '*:mpsyt cmd:'
}

_mps-youtube "$@"
