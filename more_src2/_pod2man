#compdef pod2man
# Documentation: pod2man --help
# Source: Perl POD pod2man — convert POD to nroff (man pages).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-c --center)'{-c,--center=}'[centered header string]:string:' \
    '(-d --date)'{-d,--date=}'[left-hand footer date]:string:' \
    '(-e --encoding)'{-e,--encoding=}'[output encoding]:enc:(UTF-8 ASCII iso-8859-1 roff groff)' \
    '--errors=[error handling style]:style:(die warn pod none)' \
    '--fixed=[fixed-width font]:font:' \
    '--fixedbold=[fixed-width bold font]:font:' \
    '--fixeditalic=[fixed-width italic font]:font:' \
    '--fixedbolditalic=[fixed-width bold-italic font]:font:' \
    '--guesswork=[heuristic rules]:rules:' \
    '(-n --name)'{-n,--name=}'[page name]:name:' \
    '--nourls[no URL formatting]' \
    '--official[mark as official Perl distro]' \
    '(-r --release)'{-r,--release=}'[release version footer]:version:' \
    '(-s --section)'{-s,--section=}'[manual section]:section:(1 2 3 4 5 6 7 8 9 1p 3pm 3perl)' \
    '(-q --quotes)'{-q,--quotes=}'[quote style for C<>]:quotes:' \
    '--lquote=[opening C<> quote]:char:' \
    '--rquote=[closing C<> quote]:char:' \
    '--stderr[error output to stderr]' \
    '(-u --utf8)'{-u,--utf8}'[shortcut for --encoding=UTF-8]' \
    '--verbose[verbose]' \
    '1:input POD:_files -g "*.{pod,pm,pl}"' \
    '2:output file:_files' \
    && ret=0

return ret
