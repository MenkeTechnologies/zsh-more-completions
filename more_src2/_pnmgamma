#compdef pnmgamma
# Documentation: man pnmgamma (Netpbm)
# Source: apply a gamma transformation to a Netpbm image (per channel optionally).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-bt709tolinear -lineartobt709 -bt709tosrgb -srgbtobt709 -bt709ramp -srgbramp)-bt709tolinear[Rec.709 -> linear]' \
    '(-bt709tolinear -lineartobt709 -bt709tosrgb -srgbtobt709 -bt709ramp -srgbramp)-lineartobt709[linear -> Rec.709]' \
    '(-bt709tolinear -lineartobt709 -bt709tosrgb -srgbtobt709 -bt709ramp -srgbramp)-bt709tosrgb[Rec.709 -> sRGB]' \
    '(-bt709tolinear -lineartobt709 -bt709tosrgb -srgbtobt709 -bt709ramp -srgbramp)-srgbtobt709[sRGB -> Rec.709]' \
    '(-bt709tolinear -lineartobt709 -bt709tosrgb -srgbtobt709 -bt709ramp -srgbramp)-bt709ramp[apply Rec.709 ramp]' \
    '(-bt709tolinear -lineartobt709 -bt709tosrgb -srgbtobt709 -bt709ramp -srgbramp)-srgbramp[apply sRGB ramp]' \
    '-gamma=[gamma exponent]:float:' \
    '-rgamma=[red gamma]:float:' \
    '-ggamma=[green gamma]:float:' \
    '-bgamma=[blue gamma]:float:' \
    '-ungamma[invert gamma]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:gamma or pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
