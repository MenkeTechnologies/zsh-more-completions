#compdef pepdigest
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pepdigest.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pepdigest: in-silico digest of protein with chemical/proteolytic agent
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-seqall=[protein sequence(s)]:protein USA:_files' \
  '-menu=[cleavage agent menu choice]:menu:((1\:Trypsin 2\:Lys-C 3\:Arg-C 4\:Asp-N 5\:V8-bicarb 6\:V8-phosph 7\:Chymotrypsin 8\:CNBr))' \
  '-unfavoured[allow unfavoured cleavage sites]' \
  '-ragging[allow semi/non-specific digestion]' \
  '-termini=[which termini to retain]:termini:' \
  '-overlap[show partial digestion results]' \
  '-allpartials[show all possible partial digest products]' \
  '-mono[use monoisotopic masses]' \
  '-mwdata=[molecular weight data file]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:protein USA:_files' && ret=0
return ret
