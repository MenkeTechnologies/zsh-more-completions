#compdef lxqt-config-input
# Documentation: https://github.com/lxqt/lxqt-config/blob/master/lxqt-config-input/lxqt-config-input.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--load-touchpad[load last touchpad settings]' && ret=0

return ret
