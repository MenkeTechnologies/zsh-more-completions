#compdef db-to-sqlite

_db-to-sqlite() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '--all[import all tables]' \
        '*--table=[specific table to import]:table name:' \
        '--sql=[custom SQL query to execute]:sql query:' \
        '*--pk=[column to use as primary key]:column name:' \
        '--output=[conflict handling strategy]:strategy:(append replace)' \
        '--no-detect-types[disable automatic type detection]' \
        '--progress[show progress bar during import]' \
        '*--redact=[column values to redact]:column name:' \
        '1:connection string:' \
        '2:SQLite database file:_files' && ret=0

    return ret
}

_db-to-sqlite "$@"
