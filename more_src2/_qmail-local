#compdef qmail-local
# _qmail-local — qmail's local-delivery agent (delivers one envelope to a user account via the dot-qmail mechanism; spawned by qmail-lspawn with full envelope context as positional args)
# upstream: https://github.com/notqmail/notqmail
# Flags + positional args from qmail-local.8 on tip.

_qmail-local() {
    _arguments \
        '-n[no-op (do everything but actually deliver)]' \
        '-N[dry-run + report]' \
        '1:user:_users' \
        '2:homedir:_files -/' \
        '3:local:' \
        '4:dash:' \
        '5:ext:' \
        '6:domain:' \
        '7:sender:_email_addresses' \
        '8:defaultdelivery:'
}

_qmail-local "$@"
