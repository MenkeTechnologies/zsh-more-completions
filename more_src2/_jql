#compdef jql
# Documentation: https://github.com/yamafaktory/jql
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jql (yamafaktory/jql) — JSON Query Language

_arguments -s -S \
  '(-i --inline)'{-i,--inline}'[output JSON on a single line (disable pretty print)]' \
  '(-q --query)'{-q,--query}'[read the query from a file instead of stdin]:query file:_files' \
  '(-r --raw-string)'{-r,--raw-string}'[write string primitives without JSON double-quotes]' \
  '(-s --stream)'{-s,--stream}'[process JSON output streamed line by line]' \
  '(-v --validate)'{-v,--validate}'[return exit code based on JSON validity]' \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-V,--version}'[print version information]' \
  '1:query:' \
  '2:json file:_files -g "*.json"' && return 0
