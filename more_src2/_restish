#compdef restish
# Documentation: https://github.com/rest-sh/restish/blob/main/docs/configuration.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for restish - REST API client.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'api:manage API configurations'
  'head:make a HEAD request'
  'get:make a GET request'
  'post:make a POST request'
  'put:make a PUT request'
  'patch:make a PATCH request'
  'delete:make a DELETE request'
  'edit:edit a resource'
  'links:list resource links'
  'help:show help for a command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--rsh-filter=[filter response via shorthand query]:query:' \
  '*--rsh-header=[set HTTP header]:header:' \
  '--rsh-insecure[disable TLS certificate validation]' \
  '--rsh-client-cert=[PEM client certificate]:file:_files' \
  '--rsh-client-key=[PEM client private key]:file:_files' \
  '--rsh-ca-cert=[PEM CA certificate]:file:_files' \
  '--rsh-no-paginate[disable automatic pagination]' \
  '--rsh-output-format=[output format]:format:(auto json yaml)' \
  '--rsh-profile=[use specified profile]:profile:' \
  '*--rsh-query=[add query parameter]:param=value:' \
  '--rsh-raw[raw output for shell processing]' \
  '--rsh-server=[override API base URL]:url:' \
  '--rsh-verbose[verbose logging]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'restish command' commands && ret=0
    ;;
  args)
    case $line[1] in
      api)
        local -a apicmds=(
          'configure:create or modify API configuration'
          'show:show API configuration'
          'sync:refresh API description cache'
          'edit:edit all APIs in default editor'
        )
        _describe -t apicmds 'api subcommand' apicmds && ret=0
        ;;
    esac
    ;;
esac

return ret
