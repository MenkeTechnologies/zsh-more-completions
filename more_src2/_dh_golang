#compdef dh_golang
# _dh_golang — debhelper for Go programs (Debian/dh-golang)
# upstream: https://salsa.debian.org/go-team/packages/dh-golang
# Only debhelper standard options; dh_golang has no script-specific flags.

_dh_golang() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '*-a[arch-dependent packages only]' \
        '*-i[arch-independent packages only]' \
        '*-p+[act on this package]:package:' \
        '*-N+[skip this package]:package:' \
        '-O+[option passed to the helper]:opt:'
}

_dh_golang "$@"
