#compdef ppmdmkfont ppmddumpfont
# Documentation: man ppmdmkfont (Netpbm)
# Source: make / dump a font file for the ppmdraw scripting language.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:font file:_files' \
    && ret=0

return ret
