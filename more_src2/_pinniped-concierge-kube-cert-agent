#compdef pinniped-concierge-kube-cert-agent
# _pinniped-concierge-kube-cert-agent — Pinniped concierge kube-cert-agent helper (runs as a pod alongside the kube-apiserver controller-manager to expose the cluster signing keypair)
# upstream: https://github.com/vmware-tanzu/pinniped
# Source: cmd/pinniped-concierge-kube-cert-agent/main.go on tip; subcommand dispatcher — runtime config via CERT_PATH/KEY_PATH env vars.

_pinniped-concierge-kube-cert-agent() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'sleep:run an infinite sleep (used as a long-lived pod entrypoint)'
                'print:read CERT_PATH and KEY_PATH and emit a base64-encoded {tls.crt, tls.key} JSON object'
            )
            _describe -t commands 'kube-cert-agent command' subs
            ;;
    esac
}

_pinniped-concierge-kube-cert-agent "$@"
