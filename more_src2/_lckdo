#compdef lckdo
# _lckdo — moreutils lckdo (run a command with a fcntl(2)/lockf(3) file lock held on lockfile; -w timeout in seconds (0 fails immediately if already locked))
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils lckdo.c on tip.

_lckdo() {
    _arguments \
        '-w+[wait timeout (seconds; 0 fail-fast)]:seconds:' \
        '1:lockfile:_files' \
        '*::command:_command_names -e'
}

_lckdo "$@"
