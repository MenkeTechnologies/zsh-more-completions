#compdef reduce redcsl redpsl
# Documentation: https://reduce-algebra.sourceforge.io/lisp-docs/cslse2.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. CSL REDUCE command-line options.

# REDUCE: general-purpose computer algebra system
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--my-path[show fully rooted directory and exit]' \
  '--gui[run in its own window]' \
  '--guimin[run in window mode, start minimized]' \
  '--nogui[force console-style mode]' \
  '--texmacs[set texmacs flag (when launched from TeXmacs)]' \
  '-a[invert the batchp() behavior]' \
  '-b[disable prompt and text recoloring]' \
  '-c[show authorship notice]' \
  '-d[set Lisp variables to string values]:name=value:' \
  '-e[enable experimental features]' \
  '-g[debugging mode with backtraces]' \
  '-i[read-only image file]:image:_files' \
  '-K[heap size (and optional stack size)]:size:' \
  '-l[send output to named log file]:log file:_files' \
  '-n[bypass startup function]' \
  '-o[output image file for faslout]:image:_files' \
  '-q[suppress echo and GC messages]' \
  '-r[random number generator seed]:seed:' \
  '-v[increase verbosity, enable GC messages]' \
  '-w[force console mode (-w+ forces windowed mode)]' \
  '*:REDUCE source:_files -g "*.red"' && ret=0
return ret
