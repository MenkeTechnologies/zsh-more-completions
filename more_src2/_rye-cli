#compdef rye-cli
# _rye-cli — Armin Ronacher Rye Python project & toolchain manager (astral-sh / Rye, Rust); clap-rs
# upstream: https://github.com/astral-sh/rye

_rye-cli() {
    local -a sub=(
        'add:add dependencies'
        'build:build distributions'
        'config:manage config'
        'fetch:fetch python toolchain'
        'fmt:format code'
        'init:scaffold a new project'
        'install:install standalone tool'
        'list:list installed packages'
        'lock:update lockfile'
        'lint:run lints'
        'make-req:make requirement'
        'pin:pin python version'
        'publish:publish to registry'
        'remove:remove dependencies'
        'run:run script'
        'self:manage rye itself'
        'show:show project info'
        'shell:open shell'
        'sync:sync env with lockfile'
        'test:run tests'
        'tools:manage tools'
        'toolchain:manage toolchains'
        'uninstall:uninstall tool'
        'version:show/bump version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--env-file=+[env file]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rye subcommand' sub ;;
        args)
            case $words[1] in
                add|remove) _arguments \
                    '--dev[dev dep]' \
                    '--optional=+[optional group]:str:' \
                    '-O+[optional group]:str:' \
                    '--git=+[git url]:url:_urls' \
                    '--url=+[url]:url:_urls' \
                    '--path=+[path]:dir:_files -/' \
                    '--absolute[absolute path]' \
                    '--tag=+[git tag]:str:' \
                    '--rev=+[git rev]:str:' \
                    '--branch=+[git branch]:str:' \
                    '--features=+[features]:list:' \
                    '-F+[features]:list:' \
                    '--pin=+[pin policy]:p:(==equal ~equal >=greater-equal)' \
                    '--pre[allow pre-release]' \
                    '*:package:' ;;
                sync) _arguments \
                    '--no-dev[no dev deps]' \
                    '--no-lock[no lock]' \
                    '--features=+[features]:list:' \
                    '-f+[features]:list:' \
                    '--all-features[all features]' \
                    '--pyproject=+[pyproject path]:file:_files' \
                    '--force[force]' \
                    '--update-all[update all]' \
                    '--reset[reset]' \
                    '--with-sources[with sources]' \
                    '--keep-workspace-venv[keep workspace venv]' \
                    '--all[all packages]' \
                    '--no-create-venv[no create venv]' ;;
                lock) _arguments \
                    '--features=+[features]:list:' \
                    '-f+[features]:list:' \
                    '--all-features[all features]' \
                    '--pyproject=+[pyproject path]:file:_files' \
                    '--update-all[update all]' \
                    '--pre[allow pre-release]' \
                    '--with-sources[with sources]' \
                    '--reset[reset]' ;;
                run) _arguments \
                    '--list[list scripts]' \
                    '-l[list scripts]' \
                    '--pyproject=+[pyproject path]:file:_files' \
                    '*:cmd:_command_names -e' ;;
                config) _arguments \
                    '--get=+[get key]:str:' \
                    '--set=+[set key=value]:str:' \
                    '--unset=+[unset key]:str:' \
                    '--show-path[show config path]' \
                    '--format=+[format]:fmt:(table json yaml)' ;;
                init) _arguments \
                    '--script[init script]' \
                    '--lib[init lib]' \
                    '--py=+[python version]:str:' \
                    '-p+[python version]:str:' \
                    '--build-system=+[build system]:s:(hatchling setuptools flit pdm maturin)' \
                    '-b+[build system]:s:(hatchling setuptools flit pdm maturin)' \
                    '--license=+[license]:str:' \
                    '--name=+[name]:str:' \
                    '--virtual[virtual env]' \
                    '--vcs=+[vcs]:vcs:(git hg none)' \
                    '--from-readme[init from README]' \
                    '--no-readme[no README]' \
                    '*:path:_files -/' ;;
                fetch|pin) _arguments \
                    '1:python-version:' ;;
                toolchain|tools) _arguments \
                    '1:cmd:(list register remove fetch)' \
                    '*:arg:' ;;
                self) _arguments \
                    '1:cmd:(update install uninstall completion)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_rye-cli "$@"
