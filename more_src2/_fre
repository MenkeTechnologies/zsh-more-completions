#compdef fre
# Documentation: https://github.com/camdencheek/fre
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fre — frecency tracker designed for fzf integration.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--stat[show frecency statistics]' \
  '--sorted[output sorted directory list]' \
  '--sort_method=[sort method]:method:(frequent recent frecency)' \
  '--add=[record directory visit]:directory:_files -/' \
  '--delete=[remove path from store]:path:_files -/' \
  '--decrease=[decrease weight by visits]:count' \
  '--store_name=[name of the store]:name' \
  '--purge[purge non-existent paths]' \
  '*::paths:_files -/'
