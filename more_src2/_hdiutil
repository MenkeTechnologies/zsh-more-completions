#compdef hdiutil
# Documentation: https://www.unix.com/man-page/osx/1/hdiutil/
# Source: Apple macOS — DiskImages.framework CLI (DMG / sparseimage / sparsebundle / IMG).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'attach:attach a disk image as a device'
            'detach:detach a disk image and terminate processes'
            'eject:detach a disk image (synonym)'
            'verify:verify the checksum of a read-only/compressed image'
            'create:create a new disk image'
            'convert:convert image format'
            'burn:burn an image to optical media'
            'makehybrid:generate a (potentially hybrid) read-only disk image'
            'compact:remove unused bands from sparse HFS image'
            'resize:resize disk image / container'
            'segment:divide NDIF/UDIF image into smaller parts'
            'info:DiskImages.framework + attached-image info'
            'imageinfo:metadata about a disk image'
            'fsid:filesystem id of an image'
            'isencrypted:is the image encrypted?'
            'chpass:change passphrase on encrypted image'
            'unmount:dismount volume without detaching image'
            'pmap:show partition-map details'
            'plist:show as XML plist'
        )
        _describe -t subcmds 'hdiutil command' subcmds && ret=0
        ;;
    args)
        case $words[1] in
            attach|detach|eject|verify|imageinfo|fsid|isencrypted|chpass|unmount|pmap|plist|compact|resize|convert)
                _files -g "*.(dmg|sparseimage|sparsebundle|img|iso|cdr|toast)" && ret=0
                ;;
            *)
                _files && ret=0
                ;;
        esac
        ;;
esac

return ret
