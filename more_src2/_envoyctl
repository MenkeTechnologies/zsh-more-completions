#compdef envoyctl envoy-cli
# _envoyctl — Envoy Proxy admin alias CLI for /healthcheck etc. (Envoy Proxy, C++); custom argparse (binary itself)
# upstream: https://github.com/envoyproxy/envoy

_envoyctl() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-path=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config-yaml=+[inline yaml config]:str:' \
        '--validate-yaml[validate yaml]' \
        '--mode=+[mode]:m:(serve validate init-only)' \
        '--service-cluster=+[service cluster]:str:' \
        '--service-node=+[service node]:str:' \
        '--service-zone=+[service zone]:str:' \
        '--admin-address-path=+[admin address path]:file:_files' \
        '--log-level=+[log level]:level:(trace debug info warning error critical off)' \
        '-l+[log level]:level:(trace debug info warning error critical off)' \
        '--component-log-level=+[component log level]:str:' \
        '--log-format=+[log format]:str:' \
        '--log-format-escaped[escape log format]' \
        '--log-path=+[log path]:file:_files' \
        '--restart-epoch=+[restart epoch]:n:' \
        '--hot-restart-version[show hot restart version]' \
        '--drain-time-s=+[drain time seconds]:n:' \
        '--drain-strategy=+[drain strategy]:s:(gradual immediate)' \
        '--parent-shutdown-time-s=+[parent shutdown time seconds]:n:' \
        '--enable-mutex-tracing[enable mutex tracing]' \
        '--cpuset-threads[use cpuset threads]' \
        '--disable-extensions=+[disable extensions]:list:' \
        '--reject-unknown-dynamic-fields[reject unknown dynamic fields]' \
        '--ignore-unknown-dynamic-fields[ignore unknown dynamic fields]' \
        '--max-stats=+[max stats]:n:' \
        '--max-obj-name-len=+[max obj name length]:n:' \
        '--concurrency=+[concurrency]:n:' \
        '--use-dynamic-base-id[use dynamic base id]' \
        '--base-id=+[base id]:n:' \
        '--base-id-path=+[base id path]:file:_files' \
        '--config-yaml=+[inline yaml]:str:' \
        '--bootstrap-version=+[bootstrap version]:n:' \
        '--enable-fine-grain-logging[enable fine-grain logging]' \
        '*:arg:'
}

_envoyctl "$@"
