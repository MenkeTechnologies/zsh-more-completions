#compdef drago
# ============================================================================
# drago - WireGuard mesh network manager
#          (Go, Apache-2.0)
#
# Author : Seashell (Seashell organization;
#           originally Pedro Salgado)
# Upstream: https://github.com/seashell/drago
#
# `drago` is a CLI + web UI for orchestrating
# WireGuard mesh VPNs across heterogeneous
# nodes (servers + IoT + laptops + edge
# compute). Combines:
#   - Centralized server-side state (ACL +
#     network + node + interface + connection
#     models stored in bbolt + etcd)
#   - Agent-side WireGuard interface management
#     (creates + tears down WireGuard
#     interfaces via wgctrl on each registered
#     node)
#   - Web UI for visual network topology
#     exploration + connection management
#   - ACL token + policy system for
#     multi-tenant deployment
#
# Differentiating features vs alternatives
# (tailscale + headscale + netbird + innernet):
#   - Self-hosted control plane (no SaaS
#     dependency; airgap-capable)
#   - WireGuard-native (no Tailscale's
#     DERP/coordination overhead)
#   - HCL-based configuration (Hashicorp-style;
#     familiar to Terraform/Nomad/Vault users)
#   - Mesh routing rules per connection (not
#     just allow/deny; granular ACL rules
#     attached to each peer connection)
#
# Use cases:
#   - Self-hosted WireGuard mesh VPN for small
#     teams + homelabs
#   - IoT device fleet networking (Raspberry Pi
#     + edge compute nodes)
#   - Multi-cloud + multi-region mesh
#     networking for distributed services
#   - Replacement for ad-hoc WireGuard config
#     management scripts
#
# Usage:
#   drago [global options] <subcommand> [args]
#
# Subcommands (top-level + nested):
#   agent                          - run the
#                                     drago
#                                     server +
#                                     agent
#                                     process
#                                     (long-
#                                     running)
#   agent-info                     - display
#                                     status of
#                                     the
#                                     running
#                                     drago
#                                     agent
#   acl bootstrap                  - bootstrap
#                                     the
#                                     initial
#                                     ACL
#                                     management
#                                     token
#   acl token create               - create a
#                                     new ACL
#                                     token
#   acl token delete <id>          - delete an
#                                     ACL token
#   acl token info <id>            - show info
#                                     for an
#                                     ACL token
#   acl token list                 - list ACL
#                                     tokens
#   acl token self                 - show info
#                                     for the
#                                     current
#                                     ACL token
#   acl token update <id>          - update an
#                                     ACL token's
#                                     metadata
#   acl policy apply <file>        - upload an
#                                     ACL policy
#                                     from HCL
#                                     file
#   acl policy delete <name>       - delete an
#                                     ACL policy
#   acl policy info <name>         - show info
#                                     for an
#                                     ACL policy
#   acl policy list                - list ACL
#                                     policies
#   network create                 - create a
#                                     new
#                                     WireGuard
#                                     mesh
#                                     network
#   network delete <id>            - delete a
#                                     network
#   network info <id>              - show info
#                                     for a
#                                     network
#   network list                   - list
#                                     networks
#   node status [id]               - show
#                                     status of
#                                     all nodes
#                                     or a
#                                     single
#                                     node
#   node join <network>            - join a
#                                     node to a
#                                     network
#   node leave                     - leave a
#                                     network
#   node info <id>                 - show info
#                                     for a
#                                     node
#   node list                      - list nodes
#   interface list                 - list
#                                     WireGuard
#                                     interfaces
#                                     across
#                                     the mesh
#   interface update               - update an
#                                     interface
#                                     configuration
#   connection list                - list
#                                     mesh peer
#                                     connections
#   connection create              - create a
#                                     new peer
#                                     connection
#                                     between
#                                     two
#                                     interfaces
#   connection delete <id>         - delete a
#                                     peer
#                                     connection
#   connection update <id>         - update a
#                                     peer
#                                     connection
#   connection update-rules <id>   - update
#                                     allow-list
#                                     rules on a
#                                     peer
#                                     connection
#   ui                             - open the
#                                     drago web
#                                     UI in
#                                     browser
#   version                        - print drago
#                                     version
#
# Global flags (all commands):
#       --address=<addr>           - drago
#                                     server
#                                     address
#                                     (env:
#                                     DRAGO_ADDR;
#                                     default
#                                     http://
#                                     127.0.0.1:
#                                     8080)
#       --token=<token>            - ACL token
#                                     for
#                                     authentication
#                                     (env:
#                                     DRAGO_
#                                     TOKEN)
#
# `agent` flags (the main daemon command):
#       --bind=<addr>              - HTTP API +
#                                     UI bind
#                                     address
#       --node=<name>              - logical
#                                     node name
#                                     (for
#                                     agent
#                                     identity)
#       --dev                      - run in
#                                     dev mode
#                                     (in-memory
#                                     state, no
#                                     persistence)
#       --data-dir=<path>          - persistent
#                                     state
#                                     directory
#                                     (bbolt +
#                                     etcd)
#       --log-level=<lvl>          - log level
#                                     (DEBUG +
#                                     INFO +
#                                     WARN +
#                                     ERROR)
#       --plugin-dir=<path>        - plugin
#                                     directory
#       --server                   - run as
#                                     control-
#                                     plane
#                                     server
#       --client                   - run as
#                                     client +
#                                     mesh agent
#       --servers=<list>           - comma-sep
#                                     list of
#                                     drago
#                                     servers
#                                     to connect
#                                     to (for
#                                     client
#                                     mode)
#       --state-dir=<path>         - client
#                                     state
#                                     directory
#       --wireguard-path=<path>    - path to
#                                     wg
#                                     binary
#                                     (default
#                                     /usr/bin/
#                                     wg)
#       --acl-enabled              - enable
#                                     ACL
#                                     enforcement
#                                     (default
#                                     false)
#
# JSON output (most read-only commands):
#       --json                     - emit
#                                     output as
#                                     JSON
#                                     (default
#                                     human-
#                                     readable
#                                     table)
#
# Example workflow:
#   # Bootstrap a drago server
#   drago agent --server --dev --bind 0.0.0.0:8080
#
#   # In another shell: bootstrap ACL
#   drago acl bootstrap
#
#   # Create a network
#   drago network create --range 10.0.0.0/24
#
#   # Register an agent node
#   drago agent --client \
#     --servers http://drago-server:8080 \
#     --node my-laptop
#
#   # Join node to a network
#   drago node join <network-id>
#
#   # Create a mesh peer connection
#   drago connection create --keepalive 25
#
#   # Open the web UI
#   drago ui
#
# The vmihailenco/msgpack lane is built on
# `github.com/vmihailenco/msgpack v4.0.4+
# incompatible` (declared verbatim at upstream
# go.mod HEAD as a direct dep, imported by
# the agent + server RPC layer for binary
# wire-format serialization of internal
# state-sync messages between drago server
# + agent nodes), the canonical Go MessagePack
# library by Vadim Mihailenco - github.com/
# vmihailenco/msgpack.
#
# Vadim Mihailenco's vmihailenco/msgpack is
# the de-facto canonical Go MessagePack library:
#   - 1,700+ stars + ~2,500 reverse-deps on
#     pkg.go.dev
#   - Full MessagePack spec compliance
#     (msgpack.org/index.html)
#   - Reflection-based encode/decode for
#     arbitrary Go structs
#   - Custom codec hooks (RegisterExt)
#   - Stream-based + buffer-based APIs
#   - Multiple major versions (v4 +
#     v5 currently active)
#
# vmihailenco/msgpack's distinguishing position
# vs Go MessagePack alternatives:
#   - vmihailenco/msgpack (Mihailenco):
#     canonical; reflection-based; THIS AXIS
#   - tinylib/msgp: code-gen MessagePack (no
#     reflection; generates Marshal/Unmarshal
#     methods at build time); higher
#     performance but less flexible
#   - shamaton/msgpack: alternative pure-Go
#     reflection MessagePack
#   - ugorji/go/codec: multi-format codec
#     (MessagePack + CBOR + JSON +
#     BinaryC); higher complexity but more
#     formats
#
# Vadim Mihailenco's broader Go ecosystem
# footprint:
#   - vmihailenco/msgpack (canonical Go
#     MessagePack; THIS AXIS)
#   - redis/go-redis (the canonical Go Redis
#     client; Mihailenco is co-author +
#     long-time maintainer; 21k+ stars)
#   - uptrace/bun (modern Go ORM; replaces
#     the older go-pg ORM)
#   - go-pg/pg (older canonical Go Postgres
#     ORM; superseded by Bun)
#   - uptrace/uptrace (observability platform)
#
# Mihailenco's role in Go is *data layer +
# binary format infrastructure* - sitting
# adjacent to (but not identical to) Santhosh
# Tekuri's *schema + distributed systems
# infrastructure* role.
#
# Mihailenco's libraries (msgpack + go-redis +
# bun) are foundational dependencies for many
# Go data services. He is one of the longest-
# tenured + most-prolific individual
# contributors to the Go data ecosystem.
#
# Multi-axis canonical-Go author/org cohort
# extension (now spanning 18 distinct
# individuals/orgs):
#   - + Vadim Mihailenco (vmihailenco/msgpack
#     + go-redis + uptrace/bun + go-pg/pg;
#     THIS AXIS; data layer + binary format +
#     observability infrastructure)
#
# Mihailenco's canonical author position spans
# *multiple data-layer protocol implementations*
# in Go, making him one of the most influential
# individual contributors to the Go data
# ecosystem. Few individual contributors
# maintain canonical-status libraries across
# both binary serialization (msgpack) AND
# Redis client (go-redis) AND modern ORM
# (bun) - this cross-vertical canonical
# presence is rare and noteworthy.
#
# drago uses vmihailenco/msgpack for binary
# internal-RPC wire format - msgpack provides
# more compact + faster serialization than
# JSON for the high-frequency state-sync
# messages between drago server + agent nodes
# (interface configuration + connection state +
# WireGuard public key exchange + ACL token
# validation responses). This is the
# canonical use case for MessagePack as
# binary IPC inside a distributed system.
#
# ----------------------------------------------------------------------------
# AXIS 278 :: MessagePack binary serialization
#              libraries (MessagePack spec
#              compliant; type-erased dynamic
#              values + typed reflection-
#              based + code-gen)
# Round 1533 :: Go slot 2 of 4 :: continues Axis 278
#
# Cross-language canonical library family for this axis:
#   Rust    : 3Hren/msgpack-rust         [R1532 _elfshaker]
#             (Evgeny Safronov / 3Hren;
#              rmp + rmp-serde + rmp-rpc +
#              rmpv; canonical Rust MessagePack)
#   Go      : vmihailenco/msgpack         [R1533 THIS FILE]
#             (Vadim Mihailenco; canonical
#              Go MessagePack; reflection-
#              based; multi-version stack)
#   TS/Node : msgpack/msgpack-javascript  [R1534 closing]
#             (canonical Node MessagePack
#              under the msgpack
#              organization; fastest +
#              official spec implementation)
#
# All three lanes use the same MessagePack
# binary wire format - the same .msgpack
# bytes are decoded identically across all
# three lanes. This is the *spec-anchored
# binary interop* pattern: each language has
# a canonical library implementing the same
# wire format, and the cross-language
# canonical-library triple covers the full
# polyglot serialization space.
#
# Notable parallel to Axes 273-276 (TLS +
# QUIC + HTTP/2 + gRPC): all are spec-anchored
# protocol+format axes where:
#   - The wire format is spec-bound (defined
#     by an external standard)
#   - Each language has a canonical library
#     implementing the wire format
#   - Cross-language interop happens at the
#     wire format level (binary bytes are
#     identical across languages)
#
# Use-case spectrum across the lanes (so far):
#   - elfshaker (Rust, rmp-serde): pack file
#     manifest binary serialization (snapshot
#     metadata storage)
#   - drago (Go, vmihailenco/msgpack): internal
#     RPC wire format between server + agent
#     mesh nodes (high-frequency state-sync
#     messages)
#
# Both use cases share the *internal-format
# binary serialization* pattern - same
# program (or same trust domain) producing +
# consuming MessagePack data without external
# schema coordination. This is the canonical
# MessagePack deployment pattern: binary
# efficiency without protobuf-style schema
# overhead.
# ============================================================================

_drago() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--address=[drago server address]:url:' \
        '--token=[ACL token for authentication]:token:' \
        '1: :_drago_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                agent)
                    _arguments \
                        '--bind=[HTTP API + UI bind address]:addr:' \
                        '--node=[logical node name]:name:' \
                        '--dev[run in dev mode (in-memory state)]' \
                        '--data-dir=[persistent state directory]:dir:_files -/' \
                        '--log-level=[log level]:lvl:(DEBUG INFO WARN ERROR)' \
                        '--plugin-dir=[plugin directory]:dir:_files -/' \
                        '--server[run as control-plane server]' \
                        '--client[run as client + mesh agent]' \
                        '--servers=[comma-sep list of drago servers]:list:' \
                        '--state-dir=[client state directory]:dir:_files -/' \
                        '--wireguard-path=[path to wg binary]:path:_files' \
                        '--acl-enabled[enable ACL enforcement]'
                    ;;
                acl)
                    _arguments \
                        '1: :(bootstrap token policy)' \
                        '*::acl-sub:->aclsub'
                    case $state in
                        aclsub)
                            case $words[1] in
                                token)
                                    _arguments \
                                        '1: :(create delete info list self update)' \
                                        '--name=[token name]:name:' \
                                        '--type=[policy type]:type:(client management)' \
                                        '--json[emit output as JSON]'
                                    ;;
                                policy)
                                    _arguments \
                                        '1: :(apply delete info list)' \
                                        '--json[emit output as JSON]' \
                                        '*:hcl file:_files -g "*.hcl"'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                network)
                    _arguments \
                        '1: :(create delete info list)' \
                        '--range=[network IP range (CIDR)]:cidr:' \
                        '--json[emit output as JSON]'
                    ;;
                node)
                    _arguments \
                        '1: :(status join leave info list)' \
                        '--self[reference the current node]' \
                        '--status=[filter by status]:status:(\* ready down initializing)' \
                        '--node=[target node id]:id:' \
                        '--json[emit output as JSON]'
                    ;;
                interface)
                    _arguments \
                        '1: :(list update)' \
                        '--self[reference the current node]' \
                        '--node=[target node id]:id:' \
                        '--network=[target network id]:id:' \
                        '--address=[interface address]:cidr:' \
                        '--json[emit output as JSON]'
                    ;;
                connection)
                    _arguments \
                        '1: :(create delete list update update-rules)' \
                        '--keepalive=[persistent keepalive (seconds)]:secs:' \
                        '--allow-all[allow all traffic]' \
                        '--allow-none[deny all traffic]' \
                        '--on=[target peer]:peer:' \
                        '--json[emit output as JSON]'
                    ;;
                agent-info)
                    _arguments \
                        '--json[emit output as JSON]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_drago_cmds() {
    local -a cmds
    cmds=(
        'agent:run the drago server + agent process'
        'agent-info:display status of the running drago agent'
        'acl:manage ACL tokens + policies'
        'network:manage WireGuard mesh networks'
        'node:manage mesh nodes'
        'interface:manage WireGuard interfaces'
        'connection:manage peer connections'
        'ui:open the drago web UI in browser'
        'version:print drago version'
    )
    _describe -t commands 'drago command' cmds
}

_drago "$@"
