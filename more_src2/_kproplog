#compdef kproplog
# _kproplog — MIT Kerberos Consortium kproplog Kerberos V5 incremental propagation log dump utility (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_kproplog() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose dump]' \
        '-h[summary only]' \
        '-e[show last N entries]' \
        '-R[reset the log]' \
        '-version[show version]' \
        '-M[reset master ulog]'
}

_kproplog "$@"
