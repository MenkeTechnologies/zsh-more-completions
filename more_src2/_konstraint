#compdef konstraint
# _konstraint — generate Gatekeeper CRDs from Rego policies (plexsystems/konstraint)
# upstream: https://github.com/plexsystems/konstraint
# Subcommands & flags from internal/commands/{default,create,document}.go (cobra).

_konstraint() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'create:create Gatekeeper constraints from Rego policies'
                'doc:generate documentation from Rego policies'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                create)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output directory for resources]:dir:_files -/' \
                        '(-d --dryrun)'{-d,--dryrun}'[set constraint enforcement to dryrun]' \
                        '--skip-constraints[skip generation of constraints]' \
                        '--constraint-template-version=[ConstraintTemplate version]:ver:(v1 v1beta1)' \
                        '--partial-constraints[generate partial constraints for policies w/ parameters]' \
                        '--constraint-template-custom-template-file=[custom ConstraintTemplate template]:file:_files' \
                        '--constraint-custom-template-file=[custom Constraint template]:file:_files' \
                        '--log-level=[log level]:level:(error info debug trace)' \
                        '1:source dir:_files -/'
                    ;;
                doc)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[doc output filename]:file:_files' \
                        '--template-file=[doc template file]:file:_files' \
                        '--url=[URL where policy files are hosted]:url:' \
                        '--no-rego[do not include Rego in documentation]' \
                        '--include-comments[include rego comments in documentation]' \
                        '1:source dir:_files -/'
                    ;;
            esac
            ;;
    esac
}

_konstraint "$@"
