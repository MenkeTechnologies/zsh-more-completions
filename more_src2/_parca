#compdef parca
# Documentation: https://github.com/parca-dev/parca (pkg/parca/parca.go Flags struct)
# Reference accessed: 2026-05-29
# parca — continuous profiling backend (Polar Signals). Accepts pprof profiles from agents/clients.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show application version]' \
  '--config-path=[config file path (default parca.yaml)]:file:_files -g "*.(yaml|yml)"' \
  '--mode=[operating mode (default all)]:mode:(all scraper-only forwarder)' \
  '--http-address=[HTTP listen address (default :7070)]:addr:' \
  '--http-read-timeout=[HTTP read timeout (default 5s)]:duration:' \
  '--http-write-timeout=[HTTP write timeout (default 1m)]:duration:' \
  '--port=[(DEPRECATED) use --http-address instead]:port:' \
  '*--cors-allowed-origins=[allowed CORS origins (repeatable)]:origin:' \
  '--path-prefix=[path prefix for the UI]:prefix:' \
  '--mutex-profile-fraction=[mutex profile sample fraction (default 0)]:N:' \
  '--block-profile-rate=[block profile sample rate (default 0)]:N:' \
  '--enable-persistence[turn on persistent storage for metastore + profile storage]' \
  '--profile-share-server=[gRPC address for sharing profiles (default api.pprof.me\:443)]:addr:' \
  '--store-address=[gRPC address to send profiles + symbols to (forwarder/scraper-only mode)]:addr:' \
  '--bearer-token=[bearer token to authenticate with store ($PARCA_BEARER_TOKEN)]:token:' \
  '--bearer-token-file=[file to read bearer token from]:file:_files' \
  '--insecure[send gRPC via plaintext (no TLS)]' \
  '--insecure-skip-verify[skip TLS certificate verification]' \
  '*--external-label=[label to attach to all profiles in scraper-only mode (key=value, repeatable)]:label:' \
  '*--grpc-headers=[additional gRPC headers to send to remote store (key=value, repeatable)]:header:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-format=[log format]:format:(logfmt json)' \
  && ret=0

return ret
