#compdef onnxruntime-cli ort-cli
# _onnxruntime-cli — Microsoft ONNX Runtime perf/test CLI alias (Microsoft, C++); custom argparse
# upstream: https://github.com/microsoft/onnxruntime

_onnxruntime-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--model=+[model file]:file:_files -g "*.onnx"' \
        '-m+[model file]:file:_files -g "*.onnx"' \
        '--provider=+[execution provider]:p:(cpu cuda dnnl tensorrt openvino dml coreml rocm acl armnn cann webgpu xnnpack qnn rknn snpe migraphx vsinpu)' \
        '-p+[execution provider]:p:(cpu cuda dnnl tensorrt openvino dml coreml rocm acl armnn cann webgpu xnnpack qnn rknn snpe migraphx vsinpu)' \
        '--threads=+[intra op threads]:n:' \
        '-t+[intra op threads]:n:' \
        '--inter-threads=+[inter op threads]:n:' \
        '--optimization-level=+[graph optimization level]:l:(0 1 2 3 99)' \
        '-O+[graph optimization level]:l:(0 1 2 3 99)' \
        '--execution-mode=+[execution mode]:m:(sequential parallel)' \
        '--enable-profiling[enable profiling]' \
        '--profile-output=+[profile output]:file:_files' \
        '--log-level=+[log level]:level:(verbose info warning error fatal)' \
        '--log-id=+[log id]:str:' \
        '--input-names=+[input names csv]:list:' \
        '--input-shapes=+[input shapes]:list:' \
        '--input-data=+[input data files]:list:_files' \
        '--output-names=+[output names csv]:list:' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--iterations=+[iterations]:n:' \
        '-i+[iterations]:n:' \
        '--warmup-iterations=+[warmup iterations]:n:' \
        '--concurrency=+[concurrency]:n:' \
        '--repeat=+[repeat count]:n:' \
        '--seed=+[random seed]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '*:arg:'
}

_onnxruntime-cli "$@"
