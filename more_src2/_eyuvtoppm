#compdef eyuvtoppm
# Documentation: man eyuvtoppm (Netpbm)
# Source: convert Berkeley encoder YUV bytes to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--width=[image width]:width:' \
    '--height=[image height]:height:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:eyuv file:_files' \
    && ret=0

return ret
