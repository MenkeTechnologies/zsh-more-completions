#compdef jwt_tool
# Documentation: https://github.com/ticarpi/jwt_tool/blob/master/jwt_tool.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jwt_tool (ticarpi/jwt_tool).
# Corrected from prior file: -I is --injectclaims (not --inject);
# private key is -pr/--privkey (not -pk); -pk is --pubkey; JWKS URL is
# -ju/--jwksurl; -jw is --jwksfile (a file); claim flags are
# --headerclaim/--payloadclaim/--headervalue/--payloadvalue (no hyphen);
# removed fabricated -hp/--header-path; -M modes are pb/er/cc/at (no
# fuzz); -X exploits a/n/b/p/s/k/i; added real -b/--bare, -r/--request,
# -rt/--rate, -i/--insecure, -v/--verbose.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(-b --bare)'{-b,--bare}'[return tokens only, suitable for scripting]' \
  '(-t --targeturl)'{-t,--targeturl}'=[URL to send HTTP request to with new JWT]:url:' \
  '(-r --request)'{-r,--request}'=[URL request file to base the request on]:file:_files' \
  '(-rt --rate)'{-rt,--rate}'=[maximum number of requests per minute]:rate:' \
  '(-i --insecure)'{-i,--insecure}'[use HTTP instead of HTTPS for requests]' \
  '(-rc --cookies)'{-rc,--cookies}'=[request cookies to send]:cookies:' \
  '*'{-rh,--headers}'=[request headers to send (can repeat)]:headers:' \
  '(-pd --postdata)'{-pd,--postdata}'=[POST data to send]:data:' \
  '(-cv --canaryvalue)'{-cv,--canaryvalue}'=[text indicating a valid response]:value:' \
  '(-np --noproxy)'{-np,--noproxy}'[disable proxy for requests]' \
  '(-nr --noredir)'{-nr,--noredir}'[disable redirects]' \
  '(-M --mode)'{-M,--mode}'=[scanning mode]:mode:((pb\:"playbook audit" er\:"fuzz existing claims to force errors" cc\:"fuzz common claims" at\:"All Tests"))' \
  '(-X --exploit)'{-X,--exploit}'=[exploit known vulnerabilities]:exploit:((a\:"alg\:none" n\:"null signature" b\:"blank password" p\:"psychic signature (ECDSA)" s\:"spoof JWKS" k\:"key confusion" i\:"inject inline JWKS"))' \
  '(-ju --jwksurl)'{-ju,--jwksurl}'=[URL location for spoofed JWKS]:url:' \
  '(-S --sign)'{-S,--sign}'=[sign the resulting token]:algorithm:(hs256 hs384 hs512 rs256 rs384 rs512 es256 es384 es512 ps256 ps384 ps512)' \
  '(-pr --privkey)'{-pr,--privkey}'=[private key for asymmetric crypto]:file:_files' \
  '(-T --tamper)'{-T,--tamper}'[tamper with the JWT contents]' \
  '(-I --injectclaims)'{-I,--injectclaims}'[inject or update claims in the token]' \
  '*'{-hc,--headerclaim}'=[header claim to tamper (can repeat)]:claim:' \
  '*'{-pc,--payloadclaim}'=[payload claim to tamper (can repeat)]:claim:' \
  '*'{-hv,--headervalue}'=[header value to inject (can repeat)]:value:' \
  '*'{-pv,--payloadvalue}'=[payload value to inject (can repeat)]:value:' \
  '(-C --crack)'{-C,--crack}'[crack the HMAC-SHA key]' \
  '(-d --dict)'{-d,--dict}'=[dictionary file for cracking]:file:_files' \
  '(-p --password)'{-p,--password}'=[password for cracking/signing]:password:' \
  '(-kf --keyfile)'{-kf,--keyfile}'=[keyfile for kid attacks]:file:_files' \
  '(-V --verify)'{-V,--verify}'[verify the RSA signature]' \
  '(-pk --pubkey)'{-pk,--pubkey}'=[public key for asymmetric crypto]:file:_files' \
  '(-jw --jwksfile)'{-jw,--jwksfile}'=[JSON Web Key Store file]:file:_files' \
  '(-Q --query)'{-Q,--query}'=[query a token ID from the logfile]:query:' \
  '(-v --verbose)'{-v,--verbose}'[produce verbose output]' \
  '1:JWT token:' \
  && ret=0

return ret
