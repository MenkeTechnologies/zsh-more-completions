#
# THE frink CLI — manpage-equivalent options from frinklang.org
#
# frink is conventionally invoked via the frink.jar JAR file:
#   java -cp frink.jar frink.parser.Frink [options] [files] [params]
#
# OR via a wrapper script (`frink`) that sets up the JAR
# classpath.  Common wrapper script:
#   #!/bin/sh
#   exec java -cp "$FRINK_HOME/frink.jar" frink.parser.Frink "$@"
#
# Command-line options (from
# https://frinklang.org/#CommandLineOptions):
#
#   -e EXPR              evaluate Frink expression and exit
#                        (multiple -e are concatenated)
#   -f FILE              load Frink source file (multiple)
#   -k                   remain in interactive mode after
#                        script execution
#   -u FILE              use specified units file instead of
#                        default
#   --nounits, -nu       do not load any units file
#   -I PATH              append path to source search path
#   --encoding STR       character encoding of subsequent files
#                        (UTF-8 / ISO-8859-1 / etc.)
#   -v, --version        print version and exit
#   --sandbox            enable sandbox mode (restricted file
#                        + network access)
#   --ignore-errors      ignore syntax errors during parsing
#
# GUI mode options (via frink.gui.FrinkStarter class):
#   --swing              start Swing GUI mode
#   --gui                start Swing GUI mode (alias for --swing)
#   --awt                start AWT GUI mode
#   --fullscreen         start fullscreen GUI
#   --prog               start in programming mode (blank program)
#   -open FILE           open specified file in GUI
#   -1                   Swing one-line input mode
#   -3                   Swing multi-line input mode
#
# File extensions:
#   .frink               Frink source file
#   .units               Custom units definition file
#
# Environment / classpath:
#   CLASSPATH=path/to/frink.jar    Set in shell or wrapper
#   FRINK_HOME=path/to/dir         Common wrapper convention
#
# Default invocation patterns:
#   frink                          REPL mode (interactive)
#   frink script.frink             execute script
#   frink -e "1 mile -> km"        one-shot expression
#   frink --swing                  Swing GUI
#   frink --nounits compute.frink  no units file for speed
#   frink -u my_units.frink        custom units
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://frinklang.org/ — Frink Web Site, Command-Line Options
# section.  Frink source code is closed; the website is the
# canonical reference for command-line invocation.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '*-e+[evaluate Frink expression and exit (repeatable)]:expression:_default' \
    '*-f+[load Frink source file (repeatable)]:file:_files -g "*.frink"' \
    '-k[remain in interactive mode after script execution]' \
    '-u+[use specified units file instead of default]:file:_files -g "*.(frink|units)"' \
    '(--nounits -nu)'{--nounits,-nu}'[do not load any units file]' \
    '*-I+[append path to source search path]:path:_files -/' \
    '--encoding=[character encoding of subsequent files]:encoding:(UTF-8 UTF-16 ISO-8859-1 US-ASCII)' \
    '(-v --version)'{-v,--version}'[print version and exit]' \
    '--sandbox[enable sandbox mode (restricted file + network access)]' \
    '--ignore-errors[ignore syntax errors during parsing]' \
    '(--swing --gui)'{--swing,--gui}'[start Swing GUI mode]' \
    '--awt[start AWT GUI mode]' \
    '--fullscreen[start fullscreen GUI]' \
    '--prog[start in programming mode (blank program)]' \
    '-open+[open specified file in GUI]:file:_files -g "*.frink"' \
    '-1[Swing one-line input mode]' \
    '-3[Swing multi-line input mode]' \
    '*:Frink source file:_files -g "*.frink"' \
    && ret=0

return ret
