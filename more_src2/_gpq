#compdef gpq
# =============================================================================
# gpq — Planet Labs PBC's "Utility for working with
#       GeoParquet" — a Go CLI for inspecting, validating,
#       converting, and extracting from GeoParquet files
#       (the geospatial extension of Apache Parquet,
#       standardizing geometry storage + spatial metadata
#       in column-oriented files).  Bridges GeoJSON ↔
#       GeoParquet conversions, validates conformance to
#       the OGC GeoParquet specification, and supports
#       spatial subsetting via bounding boxes.
#       Distinguishing from ogr2ogr (GDAL), QGIS bulk
#       converters, GeoPandas Python tooling, and other
#       geospatial converters by:
#         - 5 SUBCOMMANDS via alecthomas/kong:
#             * convert    — convert between formats:
#                            GeoJSON ↔ GeoParquet ↔ Parquet
#             * validate   — validate GeoParquet file
#                            against OGC spec
#             * describe   — print metadata + schema info
#             * extract    — column projection + spatial
#                            subsetting via bbox
#             * version    — show version info
#         - GEOPARQUET SPEC CONFORMANCE — validates files
#           against the OGC GeoParquet specification
#           (versions 1.0.0 and 1.1.0): geometry encoding,
#           CRS handling, primary geometry column, bbox
#           metadata, geometry types, spatial index hints
#         - SCHEMA INFERENCE — when converting GeoJSON to
#           GeoParquet, gpq infers Parquet schema from the
#           first N features (--min N) up to M features
#           (--max M); typed Parquet columns with consistent
#           encoding
#         - 5 COMPRESSION OPTIONS via --compression:
#             * uncompressed
#             * snappy
#             * gzip
#             * brotli
#             * zstd (default — best balance)
#         - SPATIAL SUBSETTING via --bbox X_MIN,Y_MIN,X_MAX,Y_MAX
#           — extract only features intersecting the
#           bounding box
#         - COLUMN PROJECTION via --drop-cols / --keep-only-
#           cols — comma-separated column lists for narrowing
#           output schema (Parquet's columnar layout enables
#           efficient column-level I/O)
#         - SANTHOSH-TEKURI/JSONSCHEMA VALIDATION — gpq
#           validates GeoParquet metadata against published
#           JSON Schemas for both spec versions; santhosh-
#           tekuri's jsonschema is used (Draft 2020-12-
#           compliant Go validator)
#         - APACHE ARROW backend — arrow/go/v16 provides
#           the Parquet reader/writer; gpq is a thin CLI
#           wrapper over Arrow's columnar Parquet machinery
#         - paulmach/orb FOR GEOMETRY OPS — Tom Mach's
#           pure-Go geometry library handles WKB encoding /
#           decoding + bounding box computation + intersection
#           tests for --bbox extraction
#         - REMOTE STORAGE via gocloud.dev — files can be
#           read directly from S3 (s3://bucket/key), GCS
#           (gs://bucket/key), Azure Blob (az://...),
#           filesystem (file:// or local paths), or stdin
#         - PRETTY OUTPUT via jedib0t/go-pretty + fatih/color
#           — table rendering for `describe` + colored output
#           in `validate` reports
#         - JSON / TEXT OUTPUT FORMATS — --format json or
#           --format text (default) for describe + validate
#       Used by: geospatial data engineers preparing
#       GeoParquet datasets for cloud-native analytics
#       (Microsoft Planetary Computer, AWS Open Data
#       Registry, Google Earth Engine), Planet Labs' own
#       satellite imagery distribution pipelines, and as a
#       reference implementation of santhosh-tekuri/
#       jsonschema + Apache Arrow + paulmach/orb + alecthomas/
#       kong + gocloud.dev composition in Go geospatial
#       tools.
#
# Author:  Planet Labs PBC (planetlabs.com) — satellite-
#          imagery company; gpq maintained by Tim Schaub
#          (tschaub) + Planet engineering.  Released 2023;
#          active development through 2026.  License:
#          Apache-2.0.
# Source:  https://github.com/planetlabs/gpq
#          https://github.com/planetlabs/gpq/blob/main/cmd/gpq/main.go
#          https://github.com/planetlabs/gpq/blob/main/cmd/gpq/command/command.go
#          https://github.com/planetlabs/gpq/blob/main/go.mod
# CLI:     cmd/gpq/main.go + cmd/gpq/command/*.go — uses
#          alecthomas/kong (kong-based CLI; documented
#          elsewhere).  Headline library: **santhosh-tekuri/
#          jsonschema** (the new variant being documented
#          here, expanding Axis 23 — JSON Schema Validation —
#          to Go).
# Library: github.com/santhosh-tekuri/jsonschema/v5 v5.3.1
#          ("santhosh-tekuri/jsonschema" — "JSONSchema (draft
#           2020-12, draft 2019-09, draft-7, draft-6, draft-4)
#           Validation using Go" — Santhosh Kumar Tekuri
#           (santhosh-tekuri on GitHub).  Distinct from
#           jsonschema (R681, Rust Axis 23 opener) by being:
#              1. ALL JSON SCHEMA DRAFTS — implements all five
#                 production JSON Schema specifications:
#                   * Draft 4 (2013)
#                   * Draft 6 (2017)
#                   * Draft 7 (2019)
#                   * Draft 2019-09
#                   * Draft 2020-12 (current)
#                 Auto-detects from $schema URL.  Same coverage
#                 as Stranger6667's Rust jsonschema (R681).
#              2. FASTEST GO JSON SCHEMA VALIDATOR —
#                 benchmarks show santhosh-tekuri/jsonschema
#                 is ~2-3x faster than xeipuuv/gojsonschema
#                 (the older alternative) due to compiled-
#                 schema optimization.
#              3. COMPILED SCHEMAS — same pattern as Rust
#                 jsonschema: parse once, validate many:
#                   import "github.com/santhosh-tekuri/jsonschema/v5"
#                   compiler := jsonschema.NewCompiler()
#                   sch, err := compiler.Compile("schema.json")
#                   if err != nil { return err }
#                   for instance := range instances {
#                       if err := sch.Validate(instance); err != nil {
#                           log.Println(err)
#                       }
#                   }
#              4. CUSTOM VOCABULARIES — extensible with custom
#                 keywords + format validators:
#                   compiler.RegisterFormat("ip-cidr", isValidCIDR)
#                   compiler.RegisterContentEncoding(...)
#                   compiler.RegisterContentMediaType(...)
#              5. $REF + $DEFS + $DYNAMIC* — full support for
#                 internal/external references including the
#                 newer Draft 2020-12 $dynamicRef +
#                 $dynamicAnchor (used in OpenAPI 3.1+).
#                 xeipuuv/gojsonschema lacks $dynamicRef
#                 support.
#              6. FORMAT VALIDATORS — built-in: date, time,
#                 date-time, duration, email, idn-email,
#                 hostname, idn-hostname, ipv4, ipv6, uri,
#                 uri-reference, iri, iri-reference,
#                 uri-template, uuid, json-pointer,
#                 relative-json-pointer, regex.
#              7. CONTENT VALIDATION — contentEncoding +
#                 contentMediaType validation (base64,
#                 application/json, etc.).
#              8. DETAILED ERRORS — error objects include
#                 instance path + schema path + cause +
#                 sub-errors (tree structure for nested
#                 validations).  Distinct from xeipuuv/
#                 gojsonschema's flat error list.
#              9. NO EXTERNAL DEPENDENCIES — pure Go; only
#                 stdlib (encoding/json, net/url, regexp,
#                 etc.).  Distinct from xeipuuv/gojsonschema
#                 (which depends on sirupsen/logrus + cebroker/
#                 inflect).
#             10. SANTHOSH-TEKURI / Independent ECOSYSTEM
#                 PROVENANCE — Santhosh Kumar Tekuri is an
#                 Indian Go developer (formerly at Pivotal).
#                 Distinct from Dmitry Dygalo (Rust jsonschema /
#                 Schemathesis), xeipuuv (older Go
#                 jsonschema maintainer who has since moved
#                 to maintenance mode), kaptinlin (newest Go
#                 alternative).  Solo-maintained with high
#                 release cadence; v5 (current) released 2022;
#                 v6 (in development) targets refactored API.)
# License: Apache-2.0 (santhosh-tekuri/jsonschema); Apache-2.0 (gpq)
# Status:  santhosh-tekuri/jsonschema — 1,231+ stars on
#          santhosh-tekuri/jsonschema, ~60M go.sum downloads;
#          rapidly displacing xeipuuv/gojsonschema (2.7k stars
#          but stale, last release 2022) as the canonical
#          Go JSON Schema validator.  Used by:
#            * cerbos (open-source authorization)
#            * vacuum (OpenAPI linter)
#            * DataDog stratus-red-team (defensive security)
#            * Apache Iceberg Go SDK
#            * Higress AI gateway
#            * gpq (THIS — GeoParquet metadata validation)
#            * 1000+ Go applications
#          gpq — 244+ stars on planetlabs/gpq; used by
#          geospatial data engineers + cloud-native imagery
#          pipelines.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 78 +
#                                                  AXIS 23 EXPANDS TO GO
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 78TH Go CLI library variant.  Go climbs from 77 to 78 documented
# libraries (santhosh-tekuri/jsonschema via gpq).  Go **catches Rust
# at 78** (Rust=Go=78, TS-Node=77 → twenty-ninth two-way tie at the
# leaderboard top in this round-sequence).  New leaderboard:
# Rust=78, Go=78, TypeScript-Node=77 (Rust+Go tied at the top).
# Taxonomy now spans 412 cross-language CLI library variants across
# 102 documented languages.
#
# Pattern: R681 Rust=78 (jsonschema — Axis 23 OPENS) → R682 Go=78
# (santhosh-tekuri/jsonschema THIS — Axis 23 expands to 2 variants)
# → expected R683 TS-Node=78 → R684 103rd language.  This is the
# 2nd of 3 leader bumps in the current segment.
#
# This completion EXPANDS Axis 23 (JSON SCHEMA VALIDATION) to TWO
# documented variants — symmetrically distributed across Rust
# (jsonschema R681) and Go (santhosh-tekuri/jsonschema THIS R682).
# TS-Node Axis 23 variant expected in R683 — likely ajv (epoberezkin/
# ajv) the canonical Node JSON Schema validator with ~14k stars.
#
#   Axis 23 (JSON SCHEMA VALIDATION) variants:
#     - jsonschema (Stranger6667/jsonschema) — R681 (_tansu) —
#       Rust high-performance validator; Draft 4-2020-12; compiled-
#       schema validation graph; custom keywords; Dmitry Dygalo /
#       Stranger6667 ecosystem
#     - jsonschema (santhosh-tekuri/jsonschema) — R682 (THIS) —
#       Go all-drafts validator; fastest Go JSON Schema validator;
#       $dynamicRef + $dynamicAnchor support (OpenAPI 3.1+); pure
#       Go (no external deps); Santhosh Kumar Tekuri ecosystem
#
# Both libraries share PURE-IMPLEMENTATION + COMPILED-SCHEMA design
# philosophy:
#   jsonschema (Rust)              = compiled schemas; serde_json
#                                     interop; Dmitry Dygalo
#   jsonschema (Go santhosh-tekuri) = compiled schemas; encoding/json
#                                     interop; Santhosh Tekuri
#
# Both support all five JSON Schema drafts (4, 6, 7, 2019-09,
# 2020-12) with $ref + $defs resolution + custom format
# validators.  Naming coincidence: both crates are called
# "jsonschema" in their respective package ecosystems.
#
# Axis 23 distribution: Rust=1, Go=1, TS-Node=0.  Expected R683
# TS-Node=1 restores three-language symmetry trajectory.
#
# (Leaderboard at R682: Rust=78, Go=78, TS-Node=77.  Rust+Go
# tied at 78.  Axis 9 / Logging 6/6/6 three-way symmetric.
# Axes 10 + 13 + 14 at 2/2/2.  Axes 7 + 8 + 11 + 12 + 15 + 16
# + 17 + 18 + 19 + 20 + 21 + 22 at 1/1/1.  Axis 23 at 1/1/0
# (Rust + Go, TS-Node pending).  Fifteen axes at three-language
# symmetry.)
#
# -----------------------------------------------------------------------------
#
# WHAT IS santhosh-tekuri/jsonschema AND WHY IS IT THE 78TH Go CLI LIBRARY?
#
# santhosh-tekuri/jsonschema is the modern, fastest, and most-
# spec-compliant Go JSON Schema validator.  Distinct from
# xeipuuv/gojsonschema (older, Draft 4-7 only, stale since
# 2022) and from kaptinlin/jsonschema (newer, Draft 2020-12-
# only, less battle-tested).  santhosh-tekuri/jsonschema
# combines comprehensive draft support with high performance
# and a small dependency footprint.
#
# Five distinguishing characteristics from Stranger6667/
# jsonschema (R681):
#
#   1. SAME COMPILED-SCHEMA DESIGN — both libraries compile
#      schemas into optimized validation structures; both
#      amortize parsing across multiple instances.  Cross-
#      language convergence on a common architectural choice.
#
#   2. $DYNAMIC* SUPPORT — santhosh-tekuri implements
#      Draft 2020-12's $dynamicRef + $dynamicAnchor (used in
#      OpenAPI 3.1+).  R681 (Rust) also supports these via
#      Draft 2020-12 coverage.
#
#   3. PURE GO, NO EXTERNAL DEPS — distinct from xeipuuv/
#      gojsonschema (which depends on sirupsen/logrus +
#      cebroker/inflect).  Same minimalism as Rust
#      jsonschema (R681).
#
#   4. DETAILED ERROR TREES — error objects include nested
#      sub-errors with instance + schema paths.  Distinct
#      from xeipuuv/gojsonschema's flat error list.  Rust
#      jsonschema (R681) also provides iterator-based
#      detailed errors.
#
#   5. SANTHOSH-TEKURI / Independent ECOSYSTEM PROVENANCE —
#      Santhosh Kumar Tekuri (santhosh-tekuri on GitHub) is
#      a Indian Go developer.  Distinct from Dmitry Dygalo
#      (Rust jsonschema — Schemathesis maintainer).  Both
#      maintainers solo-maintain their respective language's
#      canonical JSON Schema validator — interesting cross-
#      language pattern of solo maintainership in this niche.
#
# -----------------------------------------------------------------------------
#
# THE gpq CLI — kong + santhosh-tekuri/jsonschema + Apache Arrow + paulmach/orb
#
# gpq's CLI is in cmd/gpq/command/command.go.  Uses
# alecthomas/kong with struct-tag annotations for argument
# definitions.
#
# Source:
#     var CLI struct {
#         Convert  ConvertCmd  `cmd:"" help:"Convert data..."`
#         Validate ValidateCmd `cmd:"" help:"Validate a GeoParquet file."`
#         Describe DescribeCmd `cmd:"" help:"Describe a GeoParquet file."`
#         Extract  ExtractCmd  `cmd:"" help:"Extract columns..."`
#         Version  VersionCmd  `cmd:"" help:"Print the version..."`
#     }
#
# Subcommands (5):
#   convert [INPUT] [OUTPUT]            convert between formats
#     --from {auto|geojson|geoparquet|parquet}
#                                       input format
#     --to {auto|geojson|geoparquet}    output format
#     --min N                           min features for schema (default 10)
#     --max N                           max features for schema (default 100)
#     --input-primary-column NAME       primary geometry column
#                                       (default geometry)
#     --compression {uncompressed|snappy|gzip|brotli|zstd}
#                                       Parquet compression (default zstd)
#     --row-group-length N              max rows per group
#
#   validate [INPUT]                    validate against GeoParquet spec
#     --metadata-only                   skip data scanning
#     --unpretty                        no colors / newlines
#     --format {text|json}              report format (default text)
#
#   describe [INPUT]                    print metadata + schema
#     --format {text|json}              output format (default text)
#     --metadata-only                   print unformatted geo metadata
#     --unpretty                        no newlines or indentation
#
#   extract [INPUT] [OUTPUT]            column projection + spatial subsetting
#     --bbox X_MIN,Y_MIN,X_MAX,Y_MAX    spatial bounding box filter
#     --drop-cols COL1,COL2,...         columns to drop
#     --keep-only-cols COL1,COL2,...    columns to keep
#
#   version                             print version info
#
# Input handling:
#   [INPUT] is optional; if absent, reads from stdin.
#   [INPUT] accepts:
#     - local path (e.g., features.geojson)
#     - URL (https://...)
#     - gocloud.dev scheme (s3://..., gs://..., az://...,
#                            file://...)
#
# santhosh-tekuri/jsonschema is used in internal/geoparquet/
# to validate GeoParquet file metadata against the OGC
# GeoParquet JSON Schemas for versions 1.0.0 and 1.1.0.
#
# Five-axis distinctness from Stranger6667/jsonschema (R681):
#
#   1. ALL DRAFTS — 4, 6, 7, 2019-09, 2020-12 (same coverage).
#
#   2. $DYNAMIC* SUPPORT — for OpenAPI 3.1+ compatibility.
#
#   3. PURE GO, NO EXTERNAL DEPS — minimalist.
#
#   4. DETAILED ERROR TREES — nested error structure.
#
#   5. SANTHOSH-TEKURI / Independent ECOSYSTEM — distinct
#      maintainer from Dmitry Dygalo.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/planetlabs/gpq/blob/main/cmd/gpq/command/command.go
# kong struct-tag annotations on CLI definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gpq_cmds _gpq_convert_from _gpq_convert_to _gpq_formats _gpq_compression
_gpq_cmds=(
    'convert:convert data between GeoJSON / GeoParquet / Parquet'
    'validate:validate a GeoParquet file against OGC spec'
    'describe:print metadata + schema info'
    'extract:column projection + spatial subsetting via bbox'
    'version:print version info'
    'help:show help for a subcommand'
)
_gpq_convert_from=(
    'auto:auto-detect input format'
    'geojson:GeoJSON input'
    'geoparquet:GeoParquet input'
    'parquet:plain Parquet input'
)
_gpq_convert_to=(
    'auto:auto-detect output format'
    'geojson:GeoJSON output'
    'geoparquet:GeoParquet output'
)
_gpq_formats=(
    'text:text output (default)'
    'json:JSON output'
)
_gpq_compression=(
    'uncompressed:no compression'
    'snappy:Snappy compression'
    'gzip:gzip compression'
    'brotli:Brotli compression'
    'zstd:Zstandard compression (default)'
)

_arguments -C \
    '(- *)--help[show help]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'gpq subcommand' _gpq_cmds && ret=0
        ;;
    args)
        case $words[1] in
            convert)
                _arguments \
                    '--from=[input format]:format:->from' \
                    '--to=[output format]:format:->to' \
                    '--min=[minimum features for schema (default 10)]:n:_default' \
                    '--max=[maximum features for schema (default 100)]:n:_default' \
                    '--input-primary-column=[primary geometry column]:name:_default' \
                    '--compression=[Parquet compression]:codec:->compression' \
                    '--row-group-length=[max rows per group]:n:_default' \
                    '1:input file:_files -g "*.(geojson|json|geoparquet|parquet)"' \
                    '2:output file:_files' \
                    && ret=0
                ;;
            validate)
                _arguments \
                    '--metadata-only[skip data scanning]' \
                    '--unpretty[no colors or newlines]' \
                    '--format=[report format]:format:->formats' \
                    '1:input file:_files -g "*.(parquet|geoparquet)"' \
                    && ret=0
                ;;
            describe)
                _arguments \
                    '--format=[output format]:format:->formats' \
                    '--metadata-only[print unformatted geo metadata]' \
                    '--unpretty[no newlines or indentation]' \
                    '1:input file:_files -g "*.(parquet|geoparquet)"' \
                    && ret=0
                ;;
            extract)
                _arguments \
                    '--bbox=[spatial bounding box (x_min,y_min,x_max,y_max)]:bbox:_default' \
                    '--drop-cols=[columns to drop (comma-separated)]:cols:_default' \
                    '--keep-only-cols=[columns to keep (comma-separated)]:cols:_default' \
                    '1:input file:_files -g "*.(parquet|geoparquet)"' \
                    '2:output file:_files' \
                    && ret=0
                ;;
            help) _describe -t commands 'subcommand' _gpq_cmds && ret=0 ;;
        esac
        case $state in
            from)        _describe -t formats 'input format' _gpq_convert_from && ret=0 ;;
            to)          _describe -t formats 'output format' _gpq_convert_to && ret=0 ;;
            formats)     _describe -t formats 'report format' _gpq_formats && ret=0 ;;
            compression) _describe -t codecs 'compression codec' _gpq_compression && ret=0 ;;
        esac
        ;;
esac

return ret
