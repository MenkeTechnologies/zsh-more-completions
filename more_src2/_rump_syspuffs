#compdef rump_syspuffs
# Documentation: man rump_syspuffs(8)
# Source: netbsd/src usr.sbin/puffs/rump_syspuffs — mount a puffs file server via userspace loop (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:puffs file server:_files' \
    '*::file server arguments:_default' \
    && ret=0

return ret
