#compdef pass-tomb
# Documentation: https://github.com/roddhjav/pass-tomb
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-d --debug)'{-d,--debug}'[show tomb debug messages]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'tomb:create and initialize a new password tomb'
      'open:open the password tomb'
      'close:close the password tomb'
      'timer:show timer status'
    )
    _describe -t commands 'pass tomb command' commands && ret=0
    ;;
  args)
    case $line[1] in
      tomb)
        _arguments \
          '(-n --no-init)'{-n,--no-init}'[skip password store initialization]' \
          '(-p --path)'{-p,--path}'=[target subfolder for the store]:folder:' \
          '(-T --timer)'{-T,--timer}'=[auto-close timer duration]:duration:' \
          '(-k --key)'{-k,--key}'=[tomb key file]:file:_files' \
          '(-t --tomb)'{-t,--tomb}'=[tomb file path]:file:_files' \
          '(-s --size)'{-s,--size}'=[tomb size in MB]:size:' \
          '(-f --force)'{-f,--force}'[force creation]' \
          '--unsafe[accelerate tomb creation (testing)]' \
          '*:gpg-id:' && ret=0
        ;;
      open)
        _arguments \
          '(-T --timer)'{-T,--timer}'=[auto-close timer duration]:duration:' \
          '(-k --key)'{-k,--key}'=[tomb key file]:file:_files' \
          '(-t --tomb)'{-t,--tomb}'=[tomb file path]:file:_files' \
          '(-f --force)'{-f,--force}'[force open even with active swap]' && ret=0
        ;;
      close|timer)
        _nothing
        ret=0
        ;;
    esac
    ;;
esac

return ret
