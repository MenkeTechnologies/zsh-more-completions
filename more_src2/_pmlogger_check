#compdef pmlogger_check
# _pmlogger_check — Performance Co-Pilot pmlogger_check (cron driver that ensures every pmlogger declared in pmlogger.control is running; restarts missing ones, prunes stale state, -c control file, -V verbose, -l log file, -P pidfile, -s do not start daemons, -m mail, -q quiet, -F skip socket check)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmlogger/pmlogger_check on tip.

_pmlogger_check() {
    _arguments \
        '-c+[control file]:file:_files' \
        '-V[verbose]' \
        '-l+[log file]:file:_files' \
        '-P+[pidfile]:file:_files' \
        '-q[quiet]' \
        '-s[do not start daemons]' \
        '-m+[mail address]:addr:' \
        '-F[skip socket check]' \
        '-N[show would-do only]' \
        '-Z+[timezone]:tz:'
}

_pmlogger_check "$@"
