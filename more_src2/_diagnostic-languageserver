#compdef diagnostic-languageserver
# ============================================================================
# diagnostic-languageserver - generic LSP wrapper for any lint/format tool (Node, MIT)
#
# Author : iamcco
# Upstream: https://github.com/iamcco/diagnostic-languageserver
# npm    : diagnostic-languageserver
#
# diagnostic-languageserver is a meta-LSP server: instead of being
# tied to one language or one linter, it accepts a JSON config of
# per-language `linters` + `formatters` (each describing an
# external CLI tool, its argv pattern, and how to parse its
# stdout/stderr into LSP `Diagnostic` records), then dispatches
# to those tools whenever the editor reports a buffer change.
# Effectively lets any CLI linter / formatter (shellcheck, eslint,
# pylint, prettier, gofmt, rustfmt, hadolint, vale, languagetool,
# proselint, etc.) act as an LSP backend without writing a single
# bespoke language server.
#
# The LSP lane is built on `vscode-languageserver ^6.1.1`
# (declared verbatim at upstream package.json HEAD), the canonical
# Node LSP server library by Microsoft (microsoft/vscode-language
# server-node, 1700+ stars on github.com/microsoft/vscode-language
# server-node). The library is the reference implementation of
# LSP 3.x maintained by the spec authors themselves (the spec
# text is derived from this library's behavior, not the other
# way around). Every other lane's LSP library is tested against
# `vscode-languageserver-node` for conformance.
#
# The package family ships four coordinated npm modules:
#   - vscode-languageserver        - server runtime
#   - vscode-languageserver-client - client/host adapter (for VS Code itself)
#   - vscode-languageserver-protocol - shared types + RPC framing
#   - vscode-languageserver-textdocument - typed text-document model
#
# diagnostic-languageserver imports the server + textdocument
# packages and proxies all external-tool output through them.
#
# ----------------------------------------------------------------------------
# AXIS 216 :: LANGUAGE SERVER PROTOCOL (LSP 3.17, JSON-RPC 2.0)  [CLOSES]
# Round 1348 :: TS-Node slot 3 of 4 :: CLOSES Axis 216 (209th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : ebkalderon/tower-lsp                  [R1346 _rime_ls]
#   Go      : tliron/glsp                           [R1347 _config-lsp]
#   TS/Node : microsoft/vscode-languageserver-node  [R1348 THIS FILE]
#
# Microsoft authored LSP 3.x in 2016 and maintains both the
# spec text and the TS/JS reference library, making the Node
# lane structurally canonical at this axis - the same pattern
# visible at Axis 206 (GraphQL, graphql-js holds the same
# canonical-reference position because graphql-js predates the
# spec text). When the LSP spec says "diagnostics MUST...", the
# normative-behavior anchor is what
# `microsoft/vscode-languageserver-node` does.
#
# All three lanes' closers exemplify the "creative use of LSP"
# pattern: rime_ls (Rust) for Chinese input-method completion;
# config-lsp (Go) for sshd_config / fstab directive completion;
# diagnostic-languageserver (Node) for wrapping arbitrary CLI
# linters as LSP backends. None of these are "language servers"
# in the original sense, but all reuse the LSP completion +
# diagnostics + hover surface to deliver editor-integrated UX.
# ============================================================================

_diagnostic-languageserver() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--log-level[log verbosity 1-4 (1=error, 2=warn (default), 3=info, 4=log)]:level:(1 2 3 4)' \
        '--stdio[use stdio transport (the default for LSP clients)]' \
        '--node-ipc[use node-ipc transport]' \
        '--socket[use TCP socket transport]:port:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_diagnostic-languageserver "$@"
