#compdef jcat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/jcat.html
# Source: sleuthkit/sleuthkit man/jcat.1 — display contents of a specific journal block.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[specify file system type]:fstype:(ext3 ext4 ntfs hfs+ list)' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-V[display version]' \
    '-v[verbose output]' \
    '*:image file or journal block:_files' \
    && ret=0

return ret
