#compdef pamstereogram
# Documentation: man pamstereogram (Netpbm)
# Source: produce a single-image stereogram (SIRDS or SIS) from a depth map.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '-verbose[verbose output]' \
    '(-blackandwhite -grayscale -color)-blackandwhite[B/W output]' \
    '(-blackandwhite -grayscale -color)-grayscale[grayscale output]' \
    '(-blackandwhite -grayscale -color)-color[color output]' \
    '-maxval=[max sample value]:value:' \
    '-patfile=[pattern PAM file]:file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '-texfile=[texture PAM file]:file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '-bgcolor=[background color]:color:' \
    '-smoothing=[smoothing radius pixels]:pixels:' \
    '-xbegin=[x start pixels]:pixels:' \
    '-xshift=[x shift pixels]:pixels:' \
    '-yshift=[y shift pixels]:pixels:' \
    '-yfillshift+[y fill shift]:pixels:' \
    '-magnifypat=[pattern magnification]:scale:' \
    '(-guidetop)-guidetop[draw top eye-alignment dots]' \
    '(-guidebottom)-guidebottom[draw bottom eye-alignment dots]' \
    '-guidesize=[dot size pixels]:pixels:' \
    '-dpi=[output dpi]:resolution:' \
    '-crosseyed[cross-eyed viewing]' \
    '-makemask[output occlusion mask]' \
    '-eyesep=[eye separation inches]:inches:' \
    '-depth=[depth fraction]:fraction:' \
    '-planes=[near_pixels,far_pixels]:planes:' \
    '-randomseed=[random seed]:integer:' \
    '-tileable[output pattern is tileable]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:depth map:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
