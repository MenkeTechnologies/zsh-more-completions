#compdef rustc
# Documentation: https://doc.rust-lang.org/rustc/command-line-arguments.html
# Reference accessed: 2026-05-21
# Verified: upstream rustc command-line-arguments docs.

# rustc - the Rust compiler

local curcontext="$curcontext" state line ret=1

local -a _rustc_crate_types=(
  'bin' 'lib' 'rlib' 'dylib' 'cdylib' 'staticlib' 'proc-macro'
)

local -a _rustc_emit_types=(
  'asm' 'llvm-bc' 'llvm-ir' 'obj' 'link' 'dep-info' 'metadata' 'mir'
)

local -a _rustc_color_types=(
  'auto' 'always' 'never'
)

local -a _rustc_editions=(
  '2015' '2018' '2021' '2024'
)

local -a _rustc_error_formats=(
  'human' 'json' 'short'
)

local -a _rustc_print_types=(
  'crate-name' 'file-names' 'sysroot' 'target-libdir' 'cfg' 'target-list'
  'target-cpus' 'target-features' 'relocation-models' 'code-models'
  'tls-models' 'native-static-libs' 'stack-protector-strategies' 'link-args'
  'deployment-target' 'split-debuginfo' 'check-cfg' 'supported-crate-types'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[print help information]' \
  '(- *)'{-V,--version}'[print version information]' \
  '-v[use verbose output]' \
  '--crate-name=[specify crate name]:name:' \
  '--crate-type=[set crate type]:type:_values -s , "crate types" $_rustc_crate_types' \
  '--edition=[Rust edition]:edition:($_rustc_editions)' \
  '--emit=[output kinds to emit]:kinds:_values -s , "emit kinds" $_rustc_emit_types' \
  '*--cfg=[configure compilation environment]:spec:' \
  '*--check-cfg=[provide list of expected cfg names and values]:spec:' \
  '--out-dir=[output directory]:dir:_files -/' \
  '-o+[output filename]:file:_files' \
  '*-L+[add library search path]:dir:_files -/' \
  '*-l+[link native library]:name:' \
  '--target=[target triple]:triple:' \
  '--color=[when to use color]:when:($_rustc_color_types)' \
  '--explain=[provide detailed error explanation]:code:' \
  '*--extern=[external library location]:name=path:' \
  '--print=[print compiler info]:kind:($_rustc_print_types)' \
  '-g[include debug info (-C debuginfo=2)]' \
  '-O[optimize (-C opt-level=3)]' \
  '--test[build a test harness]' \
  '*-W+[set lint warnings]:lint:' \
  '*-A+[allow lint]:lint:' \
  '*-D+[deny lint]:lint:' \
  '*-F+[forbid lint]:lint:' \
  '*--force-warn=[force warn lint]:lint:' \
  '--cap-lints=[set the most restrictive lint level]:level:(allow warn deny forbid)' \
  '*-C+[codegen option]:option:' \
  '*-Z+[unstable option]:option:' \
  '--sysroot=[override the system root]:dir:_files -/' \
  '--error-format=[set how errors are produced]:format:($_rustc_error_formats)' \
  '--diagnostic-width=[terminal width for diagnostics]:width:' \
  '--json=[configure JSON output]:config:' \
  '*:file:_files -g "*.rs"'
