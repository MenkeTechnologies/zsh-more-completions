#compdef gpg-vault gpgvault
# _gpg-vault — gpg-vault CLI minimalist GPG-encrypted password and secret vault tool providing init lock unlock add get edit remove list export import find git-sync-encrypted-store using GnuPG-asymmetric-encryption recipient-key-management gpg-agent integration for a UNIX-friendly secret vault (gpg-vault authors team, shell); getopt
# upstream: https://github.com/aexea/gpg-vault

_gpg-vault() {
    local -a sub=(
        'init:initialize a vault'
        'lock:lock the vault'
        'unlock:unlock the vault'
        'add:add a secret'
        'get:read a secret'
        'edit:edit a secret'
        'remove:remove a secret'
        'list:list entries'
        'find:search entries'
        'export:export the vault'
        'import:import secrets'
        'sync:sync remote'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[recipient gpg key]:str:' \
        '--recipient=+[key id]:str:' \
        '-s+[store dir]:dir:_files -/' \
        '--store=+[dir]:dir:_files -/' \
        '-c[copy to clipboard]' \
        '--clip[copy to clipboard]' \
        '--no-symbols[no symbols]' \
        '--length=+[N]:n:' \
        '--algorithm=+[a]:a:(AES256 CHACHA20 AES192 AES128)' \
        '--git-remote=+[url]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gpg-vault subcommand' sub ;;
        args)
            case $words[1] in
                add|get|edit|remove) _arguments '*:entry name:' ;;
                find) _arguments '*:search term:' ;;
            esac
            ;;
    esac
}

_gpg-vault "$@"
