#compdef redshift-gtk
# _redshift-gtk — Redshift GTK status-icon wrapper; adjusts X color temperature based on geolocation + sun position
# upstream: https://github.com/jonls/redshift

_redshift-gtk() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-t --temperature)'{-t,--temperature}'+[day:night temp K]:dayK:nightK:' \
        '(-l --location)'{-l,--location}'+[latitude:longitude]:lat:lon:' \
        '(-b --brightness)'{-b,--brightness}'+[day:night brightness]:day:night:' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-m --method)'{-m,--method}'+[adjustment method]:method:(randr drm vidmode quartz wingdi dummy)' \
        '(-x --reset)'{-x,--reset}'[reset to neutral and exit]' \
        '(-o --one-shot)'{-o,--one-shot}'[adjust once and exit]' \
        '(-O --one-shot-temp)'{-O,--one-shot-temp}'+[adjust once to temp K]:K:' \
        '(-p --print)'{-p,--print}'[print current period and exit]' \
        '(-r --no-fade)'{-r,--no-fade}'[disable fade between transitions]'
}

_redshift-gtk "$@"
