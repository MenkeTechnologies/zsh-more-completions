#compdef eigenlayer
# Documentation: https://github.com/Layr-Labs/eigenlayer-cli (cmd/eigenlayer/main.go + pkg/*.go)
# Reference accessed: 2026-05-29
# EigenLayer restaking-protocol CLI (urfave/cli/v2).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'operator:operator management commands'
  'rewards:execute onchain operations for the rewards'
  'keys:manage cryptographic keys used in EigenLayer'
  'eigenpod:manage EigenPods in EigenLayer ecosystem'
  'user:user-related operations'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'eigenlayer subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _operator _rewards _keys _eigenpod _allocations
    _operator=(
      'keys:manage operator cryptographic keys'
      'config:configure operator settings'
      'register:register the operator on-chain'
      'status:check operator status'
      'update:update operator information'
      'update-metadata-uri:modify the metadata URI'
      'get-approval:retrieve approval details'
      'set-operator-split:configure operator fee split'
      'get-operator-split:view current operator split'
      'get-operator-pi-split:retrieve performance incentive split'
      'set-operator-pi-split:set performance incentive split'
      'set-operator-set-split:configure operator-set split'
      'get-operator-set-split:view operator-set split'
      'allocations:manage operator allocations'
      'register-operator-sets:add operator to sets'
      'deregister-operator-sets:remove operator from sets'
    )
    _rewards=(
      'claim:claim accumulated rewards'
      'set-claimer:designate a claimer address'
      'show:show rewards information'
    )
    _keys=(
      'create:create new keys'
      'list:list existing keys'
      'import:import keys from external source'
      'export:export keys for backup or transfer'
    )
    _eigenpod=(
      'status:check EigenPod status'
    )
    case $line[1] in
      operator) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'operator' _operator && ret=0 ;;
      rewards) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'rewards' _rewards && ret=0 ;;
      keys) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'keys' _keys && ret=0 ;;
      eigenpod) _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'eigenpod' _eigenpod && ret=0 ;;
    esac
    ;;
esac

return ret
