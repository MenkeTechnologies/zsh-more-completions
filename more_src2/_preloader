#compdef preloader ct-preloader
# _preloader — Google CT log preloader (copy entries from one log to another)
# upstream: https://github.com/google/certificate-transparency-go
# Flags from preload/preloader/preloader.go on tip.

_preloader() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-source_log_uri=[source CT log base URI]:url:_urls' \
        '-target_log_uri=[target CT log base URI]:url:_urls' \
        '-target_bearer_token=[bearer token for the target log]:token:' \
        '-target_temporal_log_cfg=[temporal log config file]:file:_files' \
        '-batch_size=[max entries per get-entries call]:n:' \
        '-num_workers=[concurrent matcher workers]:n:' \
        '-parallel_fetch=[concurrent GetEntries fetches]:n:' \
        '-parallel_submit=[concurrent add-[pre]-chain requests]:n:' \
        '-start_index=[log index to start scanning at]:n:' \
        '-end_index=[log index to stop scanning at (0=current size)]:n:' \
        '-continuous=[continuously fetch new STHs + entries]:bool:(true false)' \
        '-sct_file=[file to save SCTs + leaf data to]:file:_files' \
        '-precerts_only=[match precerts only]:bool:(true false)' \
        '-tls_timeout=[TLS handshake timeout]:dur:' \
        '-response_header_timeout=[HTTP response header timeout]:dur:'
}

_preloader "$@"
