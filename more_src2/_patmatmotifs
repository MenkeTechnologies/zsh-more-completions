#compdef patmatmotifs
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/patmatmotifs.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS patmatmotifs: scan protein with the full PROSITE motif database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence(s)]:protein USA:_files' \
  '-full[provide full documentation for matching patterns]' \
  '-prune[ignore simple post-translational modification patterns]' \
  '-noprune[do not ignore simple PTM patterns]' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(embl genbank gff pir swiss dasgff debug listfile dbmotif diffseq draw restrict excel feattable motif nametable regions seqtable simple srs table tagseq)' \
  '*:protein USA:_files' && ret=0
return ret
