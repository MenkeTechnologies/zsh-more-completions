#compdef pkttyagent
# _pkttyagent — polkit pkttyagent (TTY-based polkit authentication agent for headless and remote shells; -n notify-fd to write listening event to, -p parent-pid attach to a different pid, -s show prompt without registering, --process pid for compat, --version, --help)
# upstream: https://github.com/polkit-org/polkit
# Flags from polkit-org/polkit src/programs/pkttyagent.c on tip.

_pkttyagent() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-n+[notify fd]:fd:' \
        '--notify-fd+[notify fd]:fd:' \
        '-p+[parent pid]:pid:_pids' \
        '--process+[parent pid]:pid:_pids' \
        '-s[show prompt without registering]' \
        '--fallback[fallback agent]'
}

_pkttyagent "$@"
