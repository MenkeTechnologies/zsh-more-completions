#compdef prismsim
# Documentation: https://github.com/prismmodelchecker/prism (prism.PrismCL)
# Documentation: https://github.com/prismmodelchecker/prism/blob/master/prism/etc/scripts/bash_prism_completion.sh
# Reference accessed: 2026-05-27
# Verified: upstream prism.PrismCL.parseArguments() in prismmodelchecker/prism
#   prism/src/prism/PrismCL.java
#
# Note: upstream PRISM does not ship a standalone `prismsim` binary; the
# simulator engine is selected on the main `prism` launcher with `-sim`. This
# completion covers the `-sim*` flag family plus the model/property/IO flags
# typically required to drive a simulation run, matching the
# `prism-sim`-style wrapper conventions used by downstream distributions.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[print help and exit]' \
  '-version[print version and exit]' \
  '-verbose[verbose output]' \
  '-sim[enable simulator (statistical/approximate model checking)]' \
  '-simmethod[simulation method]:method:(ci aci apmc sprt)' \
  '-simsamples[number of samples]:n:' \
  '-simconf[confidence parameter (0<value<1)]:double:' \
  '-simwidth[confidence interval width]:double:' \
  '-simapprox[approximation parameter]:double:' \
  '-simmanual[use given iteration count instead of auto detection]' \
  '-simvar[iterations to conclude variance is zero]:n:' \
  '-simmaxrwd[maximum reward value]:double:' \
  '-simpathlen[maximum simulation path length]:n:' \
  '-simpath[generate a random path]:details:::file:_files' \
  '-pctl[PCTL property to check]:property:' \
  '-property[index of property to check]:n:' \
  '-const[constant definitions, e.g. N=5,K=2]:assignments:' \
  '-dtmc[interpret input as DTMC]' \
  '-ctmc[interpret input as CTMC]' \
  '-mdp[interpret input as MDP]' \
  '-importtrans[import transitions file]:file:_files' \
  '-importstates[import states file]:file:_files' \
  '-importlabels[import labels file]:file:_files' \
  '-importinitdist[import initial distribution]:file:_files' \
  '-exportresults[export results]:file:_files' \
  '-exporttrans[export transition matrix]:file:_files' \
  '-exportstaterewards[export state rewards]:file:_files' \
  '-exporttransrewards[export transition rewards]:file:_files' \
  '-exportstates[export reachable states]:file:_files' \
  '-exportlabels[export labels]:file:_files' \
  '-test[run in test mode]' \
  '-fixdl[fix deadlocks by adding self-loops]' \
  '-noprobchecks[skip probability sum checks]' \
  '-cuddmaxmem[CUDD max memory]:bytes:' \
  '-cuddepsilon[CUDD epsilon]:double:' \
  '-javamaxmem[JVM max memory]:mem (e.g. 4g):' \
  '-javastack[JVM stack size]:size:' \
  '*:model file:_files -g "*.(nm|pm|sm|prism)"' && ret=0

return ret
