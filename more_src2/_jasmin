#compdef jasmin
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/jasmin.1.html
# Reference accessed: 2026-05-19
# Verified: Ubuntu jasmin(1) manpage OPTIONS section documents only
# -d <dir> and -version. Removed invented -help/-encoding/-g/-h/
# -warn/-noWarning flags.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-version[show the program version]' \
  '-d+[destination directory for resulting files]:dir:_files -/' \
  '*: :_files -g "*.j"' && ret=0

return ret
