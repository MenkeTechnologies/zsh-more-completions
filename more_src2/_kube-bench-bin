#compdef kube-bench
# _kube-bench-bin — Aqua Security kube-bench CIS benchmark runner (Aqua Security, Go); evaluates k8s cluster against CIS benchmarks
# upstream: https://github.com/aquasecurity/kube-bench

_kube-bench-bin() {
    local -a sub=(
        'run:run kube-bench (default)'
        'master:run master-node tests'
        'node:run worker-node tests'
        'etcd:run etcd tests'
        'controlplane:run control-plane tests'
        'policies:run policies tests'
        'managedservices:run managedservices tests'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-D+[targets]:list:' \
        '--targets+[targets]:list:' \
        '--asff[output ASFF format]' \
        '--benchmark+[benchmark version]:str:' \
        '--check+[check IDs]:ids:' \
        '-c+[check IDs]:ids:' \
        '--config+[config file]:file:_files' \
        '--config-dir+[config dir]:dir:_files -/' \
        '--exit-code+[exit code on failure]:n:' \
        '--group+[group]:str:' \
        '-g+[group]:str:' \
        '--include-test-output[include raw test output]' \
        '--junit[junit output]' \
        '--json[json output]' \
        '--noremediations[no remediations]' \
        '--noresults[no results]' \
        '--nosummary[no summary]' \
        '--nototals[no totals]' \
        '--outputfile+[output file]:file:_files' \
        '--pgsql[output to postgres]' \
        '--scored[run only scored tests]' \
        '--skip+[skip checks/groups]:ids:' \
        '-s+[skip checks]:ids:' \
        '--unscored[run only unscored]' \
        '--version+[k8s version]:v:' \
        '--logtostderr+[log to stderr]:bool:(true false)' \
        '-V+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kube-bench subcommand' sub ;;
    esac
}

_kube-bench-bin "$@"
