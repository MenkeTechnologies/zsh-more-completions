#compdef redeclipse
# Documentation: https://manpages.debian.org/bookworm/redeclipse/redeclipse.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm redeclipse(6) manpage OPTIONS section.

# Red Eclipse: parkour-FPS based on Cube 2
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '-h-[home directory]:homedir:_files -/' \
  '-p-[include package directory]:packagedir:_files -/' \
  '-o-[Sauerbraten directory]:sauerdir:_files -/' \
  '-g-[output log to file (stdout if no arg)]:logfile:_files' \
  '-df[fullscreen mode]:bool:(0 1)' \
  '-dw-[screen width]:width:' \
  '-dh-[screen height]:height:' \
  '-da-[FSAA samples]:samples:' \
  '-dd-[z-buffer depth]:depth:' \
  '-x-[exec list of commands after startup]:commands:' \
  '-v-[verbosity level]:n:(0 1 2 3 4)' \
  '-ss-[local server type]:n:(0 1 2 3)' \
  '-sm-[master server URL]:servermaster:' \
  '-sa-[master server port]:port:' \
  '*::extra args:_files' && ret=0
return ret
