#compdef growisofs
# Documentation: man growisofs(1)
# Source: dvd+rw-tools growisofs (man + brasero plugin invocations) — DVD+RW/RW DL recorder (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-version[show version]' \
    '-Z+[burn new session to device]:device:_files' \
    '-M+[merge new session into device]:device:_files' \
    '-dvd-compat[finalize DVD+R/RW for DVD-ROM compatibility]' \
    '-overburn[allow over-allocation]' \
    '-use-the-force-luke=-[low-level option]:opt:(notray dao dummy 4gms tty bufsize\:32m bufpct\:5)' \
    '-speed=-[burn speed]:speed:_default' \
    '-dry-run[do not actually write]' \
    '-r[Rock Ridge directory info]' \
    '-J[Joliet directory extensions]' \
    '-iso-level+[ISO 9660 level]:level:(1 2 3 4)' \
    '-allow-limited-size[allow files larger than 4GB]' \
    '-udf[UDF support]' \
    '-dvd-video[DVD-Video data]' \
    '-input-charset+[input charset]:charset:_default' \
    '-graft-points[allow graft points]' \
    '-D[disable deep relocation]' \
    '-path-list+[path list file]:file:_files' \
    '-exclude-list+[exclude list file]:file:_files' \
    '-V+[volume id]:label:_default' \
    '-A+[application id]:appid:_default' \
    '-sysid+[system id]:sysid:_default' \
    '-v[verbose]' \
    '-print-size[print expected size and exit]' \
    '-f[follow symlinks]' \
    '*:file or device:_files' \
    && ret=0

return ret
