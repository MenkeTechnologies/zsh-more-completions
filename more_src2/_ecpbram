#compdef ecpbram
# Documentation: https://manpages.debian.org/testing/fpga-trellis/ecpbram.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-i --input)'{-i+,--input=}'[input configuration file]:file:_files -g "*.config"' \
  '(-o --output)'{-o+,--output=}'[output configuration file]:file:_files -g "*.config"' \
  '(-f --from)'{-f+,--from=}'[original content hex file]:file:_files' \
  '(-t --to)'{-t+,--to=}'[new content hex file]:file:_files' \
  '(-g --generate)'{-g+,--generate=}'[generate random hex into given file]:file:_files' \
  '(-s --seed)'{-s+,--seed=}'[seed random generator with fixed value]:seed:' \
  '(-w --width)'{-w+,--width=}'[BRAM content width in bits]:bits:' \
  '(-d --depth)'{-d+,--depth=}'[BRAM content depth in words]:words:' && ret=0

return ret
