#compdef prunehistory
# Documentation: man prunehistory(8)
# Source: InterNetNews/inn expire/prunehistory.c — remove tokens from history (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[history database path]:file:_files' \
    '-p[pass-through invalid Message-IDs without error]' \
    && ret=0

return ret
