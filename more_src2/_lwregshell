#compdef lwregshell regshell
# Documentation: BeyondTrust lwregshell (PBIS)
# Source: josephholsten/pbis lwreg/shell/regshell.c (master) — Likewise registry shell (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'list:list keys'
    'list_values:list values'
    'cd:change to key (root \\)'
    'pwd:print current key path'
    'add_key:create a new key'
    'delete_key:delete a key'
    'add_value:create a new value'
    'set_value:set a value'
    'delete_value:delete a value'
    'delete_tree:delete a key and subtree'
    'directory:directory listing'
    'import:import .reg file'
    'export:export to .reg file'
    'upgrade:upgrade registry schema'
    'cleanup:cleanup orphaned entries'
    'help:show help'
    'quit:exit interactive shell'
)

_arguments -s -C \
    '--file=[execute commands from file]:file:_files' \
    '--help[show help]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'regshell command' cmds && ret=0 ;;
esac

return ret
