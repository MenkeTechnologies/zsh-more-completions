# ============================================================================
#  _grumphp — GrumPHP: PHP code-quality task runner (git-hook-aware)
#
#  Source-direct extraction from
#    https://github.com/phpro/grumphp/blob/master/src/Console/{Application,
#      ApplicationConfigurator}.php
#    https://github.com/phpro/grumphp/blob/master/src/Console/Command/{Run,
#      Configure,Git/*}Command.php
#    https://github.com/symfony/console (the Symfony Console library)
#
#  Maintained by Phpro (phpro/grumphp).  4293 GH stars.  GrumPHP is a
#  PHP CODE-QUALITY TASK RUNNER — registers itself as a git pre-commit
#  hook and runs configured tasks (phpunit, phpstan, php-cs-fixer,
#  phpcs, php-cs-fixer, psalm, infection, jest/eslint via npm, etc.)
#  against staged files before allowing the commit.  Sister tools:
#  husky (in corpus, JS git hooks), pre-commit (in corpus, Python git
#  hooks), overcommit (Ruby git hooks).
#
#  CLI library taxonomy update: 2nd PHP CLI library — Symfony Console.
#  PHP ecosystem now has 2 documented CLI libraries (R282 + R356
#  Symfony Console) joining the multi-library leaders.  Symfony Console
#  is THE de-facto PHP CLI framework — used by Composer, Laravel
#  artisan, Drush, WP-CLI, PHPUnit, PHPStan, Psalm, PHP-CS-Fixer,
#  PHPCS, Behat, Deployer, Castor, Grumphp, and ALMOST EVERY other
#  major PHP CLI tool.  9820+ GH stars on symfony/console.
#
#  Symfony Console API:
#    use Symfony\Component\Console\Application;
#    use Symfony\Component\Console\Command\Command;
#    use Symfony\Component\Console\Attribute\AsCommand;
#    use Symfony\Component\Console\Input\InputOption;
#
#    #[AsCommand(name: 'run', description: 'Run configured tasks')]
#    class RunCommand extends Command {
#      protected function configure(): void {
#        $this->addOption('testsuite', null, InputOption::VALUE_REQUIRED,
#          'Specify which testsuite to run.', null);
#        $this->addOption('tasks', null, InputOption::VALUE_REQUIRED,
#          'Comma-separated tasks.', null);
#      }
#      public function execute(InputInterface $input,
#                              OutputInterface $output): int {
#        $taskNames = $input->getOption('tasks') ?? '';
#        ...
#      }
#    }
#
#  Symfony Console distinctive features:
#    - PHP 8+ `#[AsCommand(name: 'verb', description: 'X')]` ATTRIBUTE
#      for command registration (since Symfony 5.3); pre-PHP 8 uses
#      `$this->setName('verb')->setDescription('X')` in `configure()`
#    - CLASS-INHERITANCE — each command is a subclass of `Command`
#    - SUBCOMMAND-GROUPING via COLON in command name: `git:init`,
#      `git:commit-msg`, `cache:clear`, `make:controller` — colon is
#      the SUBCOMMAND-NAMESPACE SEPARATOR (vs space-separated like
#      `git init` in other CLIs)
#    - `InputOption::VALUE_REQUIRED` / `VALUE_OPTIONAL` / `VALUE_NONE`
#      / `VALUE_IS_ARRAY` — MODE CONSTANTS for option arity
#    - AUTO-ADDED GLOBAL FLAGS: `--help/-h`, `--version/-V`, `--verbose/
#      -v/-vv/-vvv` (verbosity), `--ansi/--no-ansi`, `--no-interaction/-n`,
#      `--quiet/-q`
#    - $application->getDefinition()->addOption(...) for app-wide globals
#  Brings cross-language CLI library taxonomy variant count to 95;
#  PHP ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from src/Console/*.php):
#
#  Global flag (via ApplicationConfigurator):
#    -c, --config FILE         Path to grumphp config (default:
#                              grumphp.yml in working directory)
#
#  Standard Symfony Console auto-added flags:
#    -h, --help                Show command help
#    -V, --version             Show version
#    -v|-vv|-vvv, --verbose    Increase verbosity (1=normal/2=verbose/
#                              3=debug)
#    -q, --quiet               Suppress output
#    -n, --no-interaction      Do not ask interactive questions
#        --ansi                Force ANSI output
#        --no-ansi             Disable ANSI output
#
#  Commands:
#    run                       Run configured tasks
#      --testsuite NAME        Specify testsuite to run
#      --tasks LIST            Comma-separated tasks (e.g.
#                              --tasks=phpunit,phpstan)
#    configure                 Create a grumphp configuration file
#      --force                 Overwrite existing config
#    git:init                  Register Git hooks (pre-commit, commit-msg)
#    git:deinit                Deregister Git hooks
#    git:pre-commit            Run pre-commit hook (invoked by Git)
#    git:commit-msg            Run commit-msg hook (invoked by Git)
#
#  Dup-skipped neighbors during hunt (already in corpus):
#    - composer (PHP package manager, IN CORPUS, uses Symfony Console)
#    - artisan (Laravel CLI, IN CORPUS, uses Symfony Console)
#    - drush (Drupal CLI, IN CORPUS, uses Symfony Console)
#    - wp-cli (WordPress CLI, IN CORPUS, uses Symfony Console)
#    - phpunit, phpstan, psalm, phpcs, php-cs-fixer (all IN CORPUS,
#      all use Symfony Console)
#    - castor (jolicode/castor, IN CORPUS, uses Symfony Console)
#    - behat (Behat/Behat, IN CORPUS, uses Symfony Console)
#    - deployer (deployphp/deployer, IN CORPUS, uses Symfony Console)
# ============================================================================

_grumphp() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-c --config)'{-c,--config}'=[path to grumphp config]:config file:_files -g "grumphp.{yml,yaml}"' \
    '(-h --help)'{-h,--help}'[show command help]' \
    '(-V --version)'{-V,--version}'[show grumphp version]' \
    '(-v -vv -vvv --verbose)'{-v,-vv,-vvv,--verbose}'[increase verbosity]' \
    '(-q --quiet)'{-q,--quiet}'[suppress output]' \
    '(-n --no-interaction)'{-n,--no-interaction}'[no interactive questions]' \
    '--ansi[force ANSI output]' \
    '--no-ansi[disable ANSI output]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'run:run configured tasks'
        'configure:create a grumphp configuration file'
        'git\:init:register Git hooks'
        'git\:deinit:deregister Git hooks'
        'git\:pre-commit:run pre-commit hook (invoked by Git)'
        'git\:commit-msg:run commit-msg hook (invoked by Git)'
        'help:show help'
        'list:list commands'
      )
      _describe -t commands 'grumphp command' verbs
      ;;
    subargs)
      case $line[1] in
        run)
          _arguments -s -S \
            '--testsuite=[specify testsuite to run]:testsuite' \
            '--tasks=[comma-separated tasks (e.g. phpunit,phpstan)]:tasks'
          ;;
        configure)
          _arguments -s -S \
            '--force[overwrite existing config]'
          ;;
      esac
      ;;
  esac
}

_grumphp "$@"
