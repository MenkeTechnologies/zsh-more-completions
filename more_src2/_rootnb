#compdef rootnb rootnb.exe
# Documentation: https://github.com/root-project/root/blob/master/main/src/nbmain.cxx
# Reference accessed: 2026-05-27
# Verified: upstream nbmain.cxx — rootnb is an execvp() wrapper that forwards
# all argv to `jupyter notebook`, so completion delegates to jupyter-notebook.

# rootnb defines no flags of its own (verified in main/src/nbmain.cxx loop
# `for (int n=1;n<argc;++n) jargv[n+1] = argv[n];`). Reuse the jupyter
# completion if available; otherwise fall back to file completion so the
# wrapper still gets useful path/notebook suggestions.

local curcontext="$curcontext" ret=1

if (( $+functions[_jupyter-notebook] )); then
  _jupyter-notebook "$@" && ret=0
elif (( $+functions[_jupyter] )); then
  _jupyter "$@" && ret=0
else
  _arguments '*:notebook or path:_files -g "*.ipynb"' && ret=0
fi

return ret
