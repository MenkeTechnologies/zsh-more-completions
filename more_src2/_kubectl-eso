#compdef kubectl-eso
# Documentation: https://github.com/josegonzalez/kubectl-eso
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[target namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '--cluster=[kubeconfig cluster to use]:cluster:' \
  '--user=[kubeconfig user to use]:user:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '--as=[username to impersonate]:user:' \
  '*--as-group=[group to impersonate]:group:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml)' \
  '--no-headers[omit table header row]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'get:list ExternalSecrets, Secrets or stores'
      'describe:show detailed info for a resource'
      'sync:force re-sync an ExternalSecret'
      'completion:generate shell completion scripts'
      'version:print version information'
    )
    _describe -t commands 'kubectl-eso command' commands && ret=0
    ;;
  args)
    case $line[1] in
      get)
        _arguments -s -S \
          '1:subcommand:(external-secret external-secrets secret secrets secret-store secret-stores cluster-secret-store cluster-secret-stores)' \
          '*::arg:_default' && ret=0
        ;;
      describe)
        _arguments -s -S \
          '(-d --decode)'{-d,--decode}'[decode base64 Secret data]' \
          '*:: :_default' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
