#compdef linkml-convert
# _linkml-convert — convert data between formats validated against a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from src/linkml/converter/cli.py (click).

_linkml-convert() {
    local -a args
    args=(
        '(-m --module)'{-m+,--module=}'[path to a Python datamodel module]:file:_files -g "*.py"'
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files'
        '(-f --input-format)'{-f+,--input-format=}'[input format (default inferred from suffix)]:format:(yaml json csv tsv rdf ttl jsonld pickle xml)'
        '(-t --output-format)'{-t+,--output-format=}'[output format (default inferred from suffix)]:format:(yaml json csv tsv rdf ttl jsonld pickle xml)'
        '(-C --target-class)'{-C+,--target-class=}'[root class the input instantiates]:class:'
        '--target-class-from-path[infer the target class from the filename]'
        '--no-target-class-from-path[do not infer the target class from the filename]'
        '(-S --index-slot)'{-S+,--index-slot=}'[top-level slot (required for CSV)]:slot:'
        '(-s --schema)'{-s+,--schema=}'[LinkML schema YAML]:file:_files -g "*.(yaml|yml)"'
        '*'{-P+,--prefix=}'[prefix base=URI pair (repeatable)]:base=uri:'
        '--prefix-file=[YAML file of base=URI prefix pairs]:file:_files -g "*.(yaml|yml)"'
        '--validate[validate input against the schema (default)]'
        '--no-validate[skip validation]'
        '--infer[infer missing slot values]'
        '--no-infer[do not infer missing slot values]'
        '*'{-c+,--context=}'[JSON-LD context file (repeatable)]:file:_files -g "*.(jsonld|json)"'
        '--list-wrapper=[wrapper style for CSV / TSV multivalued fields]:style:(square curly paren none)'
        '--list-delimiter=[delimiter for list items in CSV / TSV (default pipe)]:delim:'
        '--list-strip-whitespace[strip whitespace around list delimiters (default)]'
        '--no-list-strip-whitespace[preserve whitespace around list delimiters]'
        '--refuse-delimiter-in-data[error if the data contains the list delimiter literally]'
        '--no-refuse-delimiter-in-data[allow the delimiter to appear in data]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:input data file:_files'
    )
    _arguments -s -S $args
}

_linkml-convert "$@"
