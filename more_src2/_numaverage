#compdef numaverage
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-i[ignore non-numeric lines]' \
  '-I[include empty lines]' \
  '-M[compute mode]' \
  '-m[compute median]' \
  '-l[print lowest value]' \
  '-L[print highest value]' \
  '-N[print count of numbers]' \
  '-s[print standard deviation]' \
  '-h[show help]' \
  '-V[show version]' && ret=0
return ret
