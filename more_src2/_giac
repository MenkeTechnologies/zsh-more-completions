#compdef giac icas
# Documentation: https://manpages.debian.org/testing/xcas/giac.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--version[show version]' \
  '--texmacs[call from TeXmacs]' \
  '--emacs[call from Emacs]' \
  '--sage[call from Sage]' \
  '*:file:_files' && ret=0

return ret
