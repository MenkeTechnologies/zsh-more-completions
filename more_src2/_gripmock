#compdef gripmock
# ============================================================================
# _gripmock — zsh completion for bavix/gripmock, the gRPC mock server
#              CLI for testing and development (direct dep on
#              google.golang.org/grpc — Go=139 leader bump)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/bavix/gripmock
#   Maintainer : bavix
#   License    : MIT
#   Stars      : 67
#   Language   : Go
#   Module     : github.com/bavix/gripmock/v3
#   Binary     : gripmock  (cmd/root.go rootCmd.Use = "gripmock")
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   GripMock is "the fastest and most reliable gRPC mock server for
#   testing and development" — bavix's v3 rewrite of the original
#   tokopedia/gripmock.  It boots a gRPC server that loads stub
#   responses from YAML/JSON files (or descriptor bundles compiled
#   from `.proto` files), supports proxy modes that forward
#   un-stubbed calls to a real upstream server, exposes a parallel
#   REST control plane for stub management, and ships a plugin
#   architecture (Go `.so` template plugins) for runtime stub
#   transformation.  The CLI is built on spf13/cobra and exposes
#   a root server-launcher subcommand plus check / dump / info /
#   proto utility subcommands.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/root.go,
#                       cmd/check.go, cmd/dump.go, cmd/info.go,
#                       cmd/proto.go, cmd/proto_export.go —
#                       spf13/cobra v1.10.2 PersistentFlags +
#                       Flags builder)
#   gripmock [GLOBAL OPTIONS] [PROXY_URLS...]
#   gripmock <SUBCOMMAND> [OPTIONS]
#
#   Root (server-launcher) options:
#     -s, --stub <PATH>             Stub files directory
#     -i, --imports <PATH>...       Proto import-library paths
#                                    (repeatable)
#     --plugins <PATH>...           Template plugin .so paths
#                                    (repeatable)
#     -S, --source <SRC>...         Local descriptor sources for
#                                   proxy modes — .proto, .protoset,
#                                   .pb, or directory  (repeatable)
#
#   Subcommands:
#     check                         Probe an existing gripmock
#                                   server for liveness
#       -t, --timeout <DURATION>    Total readiness timeout
#       --interval <DURATION>       Interval between ping attempts
#       --silent                    Silence errors
#
#     dump                          Export stubs to files
#       --format <FMT>              Output format (yaml|json)
#                                   [default: yaml]
#       -o, --output <DIR>          Output directory
#                                   [default: stubs_export]
#       --scheme <S>                URL scheme (http|https)
#                                   [default: http]
#       --source <SRC>              Filter by source
#                                   (rest|mcp|proxy)
#
#     info                          Show gripmock info + loaded
#                                   plugins (version, Go runtime,
#                                   platform, plugin functions,
#                                   authors, description, deps,
#                                   capabilities)
#
#     proto                         Proto file utilities (parent)
#       export                      Compile .proto files into a
#                                   descriptor bundle (.pb / .pbs)
#         --root <DIR>...             Discovery + import root
#                                     directories  (required,
#                                     repeatable)
#         --import-root <DIR>...      Import-only roots (not
#                                     discovered, not in output)
#         --out <FILE>                Output .pb (raw) or .pbs
#                                     (S2-compressed)  (required)
#         --include <GLOB>...         Glob patterns to include
#                                     [default: **/*.proto]
#         --exclude <GLOB>...         Glob patterns to exclude
#
#   Standard cobra auto-flags:
#     -h, --help                    Show help
#     -v, --version                 Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `google.golang.org/grpc v1.81.1` declared
#   in go.mod — the canonical Go gRPC framework maintained by the
#   gRPC organization at Google (grpc/grpc-go).  google.golang.org
#   /grpc is THE Go gRPC implementation:  it ships
#   `grpc.NewServer`, `grpc.Dial`, `grpc.NewClient`, the
#   `grpc.ServiceRegistrar` interface, `grpc.Code` /
#   `grpc.StatusFromError`, server- and client-streaming method
#   plumbing, interceptors (unary + stream), credentials
#   (`grpc/credentials/insecure`, `grpc/credentials/oauth`,
#   `grpc/credentials/google`), keepalive, retry policy,
#   reflection (`google.golang.org/grpc/reflection`), health
#   (`google.golang.org/grpc/health`), and the
#   `google.golang.org/grpc/balancer` plugin point.  GripMock's
#   `internal/deps.Builder.GRPCServe` wraps `grpc.NewServer` with
#   OpenTelemetry tracing (otelgrpc) and registers dynamically-
#   loaded gRPC services backed by proto-descriptor stubs that
#   the CLI loaded at startup.  Verified via:
#     gh api repos/bavix/gripmock/contents/go.mod
#       → google.golang.org/grpc v1.81.1
#       → github.com/spf13/cobra v1.10.2
#       → module github.com/bavix/gripmock/v3
#     gh api repos/bavix/gripmock/contents/cmd/root.go
#       → rootCmd.Use = "gripmock"
#       → builder.GRPCServe(ctx, params)
#   This entry is the Go=139 leader bump that continues Axis 84
#   (gRPC Framework Library) opened at R925 with Rust=tonic via
#   xline-kv/Xline's xlinectl.
#
#   No completion for `gripmock` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_gripmock() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-s --stub)'{-s,--stub}'=[stub files directory]:dir:_files -/' \
        '*'{-i,--imports}'=[proto import-library path (repeatable)]:dir:_files -/' \
        '*--plugins=[template plugin .so path (repeatable)]:plugin:_files -g "*.so"' \
        '*'{-S,--source}'=[local descriptor source for proxy modes (repeatable)]:source:_files' \
        '1: :_gripmock_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                check)
                    _arguments \
                        '(-t --timeout)'{-t,--timeout}'=[total readiness timeout]:duration:' \
                        '--interval=[interval between ping attempts]:duration:' \
                        '--silent[silence errors]' && ret=0 ;;
                dump)
                    _arguments \
                        '--format=[output format]:format:(yaml json)' \
                        '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
                        '--scheme=[URL scheme]:scheme:(http https)' \
                        '--source=[filter by source]:source:(rest mcp proxy)' && ret=0 ;;
                info)
                    _arguments && ret=0 ;;
                proto)
                    _arguments \
                        '1:proto subcommand:(export)' \
                        '*::arg:->proto_args' && ret=0
                    case $state in
                        proto_args)
                            case $words[1] in
                                export)
                                    _arguments \
                                        '*--root=[discovery + import root (required, repeatable)]:dir:_files -/' \
                                        '*--import-root=[import-only root (repeatable)]:dir:_files -/' \
                                        '--out=[output .pb or .pbs path (required)]:file:_files' \
                                        '*--include=[include glob (repeatable)]:glob:' \
                                        '*--exclude=[exclude glob (repeatable)]:glob:' && ret=0 ;;
                            esac
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_gripmock_commands] )) ||
_gripmock_commands() {
    local -a commands
    commands=(
        'check:probe an existing gripmock server for liveness'
        'dump:export stubs to files'
        'info:show gripmock info and loaded plugins'
        'proto:proto file utilities (export)'
    )
    _describe -t commands 'gripmock command' commands
}

_gripmock "$@"
