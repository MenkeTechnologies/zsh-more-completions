#compdef gdalasyncread
# Documentation: https://github.com/OSGeo/gdal
# Source: OSGeo/gdal apps/gdalasyncread.cpp — async raster read demo using AsyncReader API (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--help-general[show generic GDAL options]' \
    '-ot+[output pixel type]:type:(Byte Int16 UInt16 UInt32 Int32 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
    '-of+[output format]:format:_default' \
    '*-b+[selected band(s)]:band:_default' \
    '-outsize+[output size xsize ysize (or %)]:xsize:_default:ysize:_default' \
    '-srcwin+[source window xoff yoff xsize ysize]:xoff:_default:yoff:_default:xsize:_default:ysize:_default' \
    '*-co+[creation option NAME=VALUE]:option:_default' \
    '*-ao+[async-read option NAME=VALUE]:option:_default' \
    '-to+[timeout in seconds]:timeout:_default' \
    '-multi[multi-threaded read]' \
    '-quiet[suppress output]' \
    '1:src dataset:_files' \
    '2:dst dataset:_files' \
    && ret=0

return ret
