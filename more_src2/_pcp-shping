#compdef pcp-shping
# _pcp-shping — display stats from the PCP shell-ping PMDA (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/shping/pcp-shping.sh (pmgetopt usage block).

_pcp-shping() {
    _arguments \
        '(- *)--help[show help]' \
        '(-l --tags)'{-l,--tags}'[report shell-ping command tag list]' \
        '(-c --status)'{-c,--status}'[report shell-ping service-check control variables]' \
        '*:tag:'
}

_pcp-shping "$@"
