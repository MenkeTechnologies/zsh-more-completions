#compdef gmtmath
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtmath.html
# Source: GenericMappingTools/gmt classic-mode gmtmath — RPN calculator for tables (200+ operators).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[init from file for least-squares fitting]:file:_files' \
    '-C+[restrict to specific columns]:cols:_default' \
    '-E+[min eigenvalue for LSQFIT/SVDFIT]:value:_default' \
    '-I[reverse output row order]' \
    '-N+[col count, time-column index]:opts:_default' \
    '-Q[quick scalar calculation mode]' \
    '-S+[output only first or last row]:which:(first last)' \
    '-T+[1-D array (min/max/inc or file/list)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '*:operator or operand:_default' \
    && ret=0

return ret
