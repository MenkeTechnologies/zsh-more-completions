#compdef istat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/istat.html
# Source: sleuthkit/sleuthkit man/istat.1 — display details of a meta-data structure (inode).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B[display addresses of N disk units]:num:' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-s[time skew of original system in seconds]:seconds:' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-v[verbose output to stderr]' \
    '-V[display version]' \
    '-z[ASCII string of original system time zone]:zone:' \
    '*:image file or inode:_files' \
    && ret=0

return ret
