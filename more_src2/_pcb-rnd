#compdef pcb-rnd
# Documentation: https://manpages.debian.org/testing/pcb-rnd/pcb-rnd.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcb-rnd: fork of gEDA PCB with extensive plugin system
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[print help about topic]:topic:' \
  '-x[export with exporter plugin]:exporter:' \
  '--gui[GUI HID plugin]:hid:(gtk gtk2 gtk4 lesstif batch)' \
  '-c[set configuration node path=val]:path=val:' \
  '*:PCB file:_files -g "*.(pcb|lht|pcb.gz|lht.gz)"' && ret=0
return ret
