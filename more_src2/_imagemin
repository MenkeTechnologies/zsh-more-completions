#compdef imagemin
# ============================================================================
# imagemin - image minification CLI for
#             web optimization
#             (TypeScript/Node, MIT)
#
# Author : Sindre Sorhus + imagemin org
#           (sindresorhus is one of the
#           highest-prolific Node ecosystem
#           contributors; founder of the
#           imagemin organization)
# Upstream: https://github.com/imagemin/imagemin-cli
# npm pkg : imagemin-cli
#
# `imagemin` is a command-line image
# minification tool that orchestrates
# format-specific encoder plugins to
# reduce image file sizes while preserving
# quality. Designed for web asset
# optimization pipelines + build-time image
# processing.
#
# Architecture:
#   1. **Plugin-based** (imagemin core
#      delegates to format-specific
#      encoders via plugin packages:
#      imagemin-mozjpeg + imagemin-pngquant
#      + imagemin-svgo + imagemin-gifsicle
#      + imagemin-webp + ...)
#   2. **Stream-friendly** (input via
#      stdin/positional args; output via
#      stdout or directory)
#   3. **Format-agnostic** (handles JPEG +
#      PNG + GIF + WebP + SVG via the
#      appropriate plugin)
#   4. **Default plugin set**: gifsicle +
#      jpegtran + optipng + svgo (covers
#      the common web image formats)
#
# Distinguishing features vs alternatives:
#   - **THE canonical Node web image
#     minifier** (used by Gulp + Grunt +
#     webpack-image-loader + many static-
#     site generators' image plugins)
#   - **Pluggable encoder selection**
#     (swap default plugins for
#     specialized encoders: pngquant for
#     palette compression + mozjpeg for
#     better JPEG ratios + svgo for SVG
#     optimization + webp for modern
#     format conversion)
#   - **Stdin/stdout pipeline mode**
#     (suitable for shell pipelines +
#     CI/CD asset compilation)
#   - **Glob input support** (process
#     entire directories of images)
#   - **Maintained by Sindre Sorhus**
#     (one of npm's most prolific +
#     widely-trusted contributors;
#     1000+ published npm packages)
#
# Use cases:
#   - Build-time web asset optimization
#     (Gulp + Grunt + webpack plugins
#     internally use imagemin)
#   - CI/CD image compression for static
#     sites (Hugo + Jekyll + 11ty post-
#     build optimization)
#   - Email template image preparation
#     (smaller images = better deliverability
#     + faster client rendering)
#   - Mobile app asset optimization
#     (smaller bundles + faster downloads)
#   - Image upload preprocessing in
#     server-side workflows
#
# Usage:
#   imagemin <path|glob>... --out-dir=build [--plugin=<name>...]
#   imagemin <file> > <output>
#   cat <file> | imagemin > <output>
#
# Flags (meow):
#   -p, --plugin <name>            - override
#                                     default
#                                     plugins
#                                     (repeatable;
#                                     defaults
#                                     to
#                                     gifsicle +
#                                     jpegtran +
#                                     optipng +
#                                     svgo)
#   -o, --out-dir <dir>            - output
#                                     directory
#                                     (required
#                                     for
#                                     multi-
#                                     file/
#                                     glob
#                                     input;
#                                     not used
#                                     for
#                                     stdin/
#                                     stdout
#                                     mode)
#       --plugin.<name>.<opt>=<val> - plugin-
#                                     specific
#                                     option
#                                     (e.g.
#                                     --plugin
#                                     .pngquant
#                                     .quality
#                                     =0.5)
#       --help                     - show
#                                     help
#       --version                  - show
#                                     version
#
# Common plugin packages (install
# separately via npm):
#   imagemin-mozjpeg               - higher
#                                     compression
#                                     ratio
#                                     JPEG
#                                     (use
#                                     instead
#                                     of
#                                     jpegtran)
#   imagemin-pngquant              - PNG
#                                     palette
#                                     compression
#                                     (significantly
#                                     smaller
#                                     than
#                                     optipng
#                                     for
#                                     photos
#                                     -> 256-
#                                     color
#                                     palette)
#   imagemin-webp                  - WebP
#                                     format
#                                     conversion
#   imagemin-svgo                  - SVG
#                                     optimization
#                                     (default)
#   imagemin-gifsicle              - GIF
#                                     optimization
#                                     (default)
#   imagemin-optipng               - PNG
#                                     lossless
#                                     optimization
#                                     (default)
#   imagemin-jpegtran              - JPEG
#                                     lossless
#                                     optimization
#                                     (default)
#   imagemin-jpegoptim             - JPEG
#                                     alternative
#                                     to
#                                     jpegtran
#   imagemin-zopfli                - PNG
#                                     Zopfli
#                                     compression
#                                     (slower
#                                     but
#                                     smaller)
#   imagemin-avif                  - AVIF
#                                     format
#                                     (modern
#                                     replacement
#                                     for
#                                     WebP)
#
# Example invocations:
#   # Default optimization (gifsicle +
#   # jpegtran + optipng + svgo)
#   imagemin images/* --out-dir=build
#
#   # Single file via stdout
#   imagemin foo.png > foo-optimized.png
#
#   # Stdin pipeline mode
#   cat foo.png | imagemin > foo-optimized.png
#
#   # Use specific plugins
#   imagemin foo.png --plugin=pngquant > \
#     foo-optimized.png
#
#   # Multiple plugins (order matters)
#   imagemin images/* --out-dir=build \
#     --plugin=mozjpeg --plugin=pngquant
#
#   # Plugin-specific options
#   imagemin foo.png \
#     --plugin.pngquant.quality=0.5 \
#     > foo-optimized.png
#
#   # Multiple quality values (array)
#   imagemin foo.png \
#     --plugin.pngquant.quality={0.1,0.2} \
#     > foo-optimized.png
#
#   # WebP conversion + preset
#   imagemin foo.png \
#     --plugin.webp.quality=95 \
#     --plugin.webp.preset=icon \
#     > foo-icon.webp
#
#   # Glob pattern + output directory
#   imagemin 'src/images/**/*.{jpg,png,gif}' \
#     --out-dir=dist/images
#
# imagemin's role in the Node web
# ecosystem is foundational - imagemin +
# its plugins are the de-facto canonical
# image minification stack used by:
#   - **gulp-imagemin** (the canonical
#     Gulp imagemin task)
#   - **grunt-contrib-imagemin** (the
#     canonical Grunt imagemin task)
#   - **imagemin-webpack-plugin** (webpack
#     integration)
#   - **gatsby-plugin-imagemin** (Gatsby
#     post-build optimization)
#   - **eleventy-img** (11ty image
#     optimization)
#   - **next-optimized-images** (Next.js
#     image optimization)
#   - Many other build-tool integrations
#
# Sindre Sorhus is one of the most
# prolific Node ecosystem contributors:
#   - **1,000+ npm packages** (many of
#     which are foundational utilities
#     pulled in by other libraries)
#   - **sindresorhus/awesome** (the
#     original awesome-list curation
#     pattern + meta-list of awesome
#     lists; ~300,000 stars across the
#     awesome family)
#   - **chalk** (canonical Node
#     terminal styling library)
#   - **got** (canonical Node HTTP
#     client + competitor to axios)
#   - **execa** (canonical Node
#     subprocess executor)
#   - **boxen** (canonical Node terminal
#     box-drawing utility)
#   - **figlet** (terminal ASCII art)
#   - **meow** (canonical Node CLI
#     helper used by imagemin-cli
#     itself)
#   - **ora** (canonical Node terminal
#     spinner)
#   - **pretty-bytes** (canonical Node
#     byte-formatting utility)
#   - Many other foundational utilities
#
# Sorhus's cross-ecosystem footprint is
# the *single most prolific Node
# canonical-author cohort* by package
# count + collective adoption. His
# packages collectively power a large
# fraction of the Node ecosystem's
# CLI tooling + automation pipelines.
#
# Multi-axis canonical-Node author/org
# cohort extension (now spanning 31
# distinct individuals/orgs after R1567):
#   - + Sindre Sorhus + imagemin org
#     (imagemin/imagemin-cli + chalk +
#     got + execa + meow + ora + 1000+
#     other npm packages; THIS AXIS;
#     canonical Node image minification +
#     foundational CLI tooling
#     infrastructure)
#
# Sorhus's joining the canonical-Node
# cohort represents the *highest-volume
# individual canonical-author* pattern in
# the Node ecosystem - few individuals
# in any language's ecosystem maintain
# as many canonical libraries as Sorhus
# does in Node.
#
# imagemin uses its companion plugins
# (which in turn wrap native binaries
# like mozjpeg + pngquant + gifsicle +
# optipng + jpegtran + libsvgo) for
# actual encoding work. The CLI is the
# orchestration layer that handles input
# resolution + plugin selection +
# output writing.
#
# This is the canonical use case for
# imagemin in production Node CLI
# tooling: build-time image optimization
# in static asset pipelines, where
# format-specific encoders provide
# better compression than generic
# imaging libraries (sharp is faster for
# real-time resize/crop; imagemin
# plugins are better for final
# compression of static assets).
#
# Note: this completion closes Axis 289
# with imagemin rather than sharp; the
# canonical Node imaging library (sharp)
# was previously documented at Axis 138's
# Node closer via vseventer/sharp-cli.
# Axis 289 represents the *image
# minification + web asset optimization*
# subarea distinct from sharp's
# general-purpose imaging library role.
#
# ----------------------------------------------------------------------------
# AXIS 289 :: Image processing libraries
#              (multi-format image I/O +
#              pixel-level manipulation +
#              filters + edge detection +
#              morphology + format
#              conversion)
# Round 1567 :: TS/Node slot 3 of 4 :: CLOSES Axis 289
#
# Cross-language canonical library family
# for this axis (closed):
#   Rust    : image-rs/image           [R1565 _imagecli]
#             (Piston Developers +
#              image-rs maintainers;
#              canonical Rust image
#              ecosystem)
#   Go      : disintegration/imaging   [R1566 _didder]
#             (Grigory Dryapak;
#              canonical Go imaging
#              library; high-level
#              chainable API)
#   TS/Node : imagemin/imagemin        [R1567 THIS FILE]
#             (Sindre Sorhus + imagemin
#              org; canonical Node web
#              image minification +
#              plugin orchestration;
#              CLOSES Axis 289)
#
# Axis 289 closure = 282nd axis closed
# in the corpus. The 3+1 cycle returns
# to slot 1/0/0 for Axis 290 opening at
# the next round.
#
# Note: Axis 138 was the prior image-
# processing axis closure with the
# sharp/sharp-cli + image-rs + golang.org/
# x/image triple. Axis 289 re-explores
# the image processing space with
# specialized CLIs (imagecli pipeline
# DSL + didder dithering algorithms +
# imagemin minification) rather than the
# foundational library wrappers.
#
# Use-case spectrum across Axis 289
# (closed):
#   - imagecli (Rust, image + imageproc):
#     pipeline-DSL image processing CLI
#   - didder (Go, disintegration/
#     imaging): comprehensive image
#     dithering algorithm collection
#   - imagemin (TS-Node, imagemin):
#     plugin-based image minification
#     for web asset optimization
#
# Use-case spectrum spans:
#   - General-purpose pipeline DSL
#     (imagecli)
#   - Specialized algorithm (didder
#     dithering)
#   - Specialized optimization
#     (imagemin minification)
#
# Together they represent the
# *specialized image processing CLI*
# pattern - tools focused on specific
# image transformation domains rather
# than general-purpose imaging libraries.
# This is the canonical pattern for
# domain-specific image tooling in
# production workflows.
# ============================================================================

_imagemin() {
    _arguments \
        '*'{-p,--plugin}'=[override default plugins]:plugin:(gifsicle jpegtran optipng svgo mozjpeg pngquant webp avif jpegoptim zopfli)' \
        '(-o --out-dir)'{-o+,--out-dir=}'[output directory]:dir:_files -/' \
        '--help[show help]' \
        '--version[show version]' \
        '*:image file or glob:_files -g "*.(jpg|jpeg|png|gif|svg|webp|avif)"'
}

_imagemin "$@"
