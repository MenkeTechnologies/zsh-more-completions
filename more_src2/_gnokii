#compdef gnokii
# _gnokii — Gnokii (Linux/BSD library + CLI for Nokia and other phones over IrDA / Bluetooth / serial / USB; subcommands: --identify, --gettime, --settime, --getsms, --sendsms, --writefile, --readfile, --getphonebook, --writephonebook, --deletephonebook, --getringtone, --setringtone, --getlogo, --setlogo, --bigsms, --enterspc, --getsmsc, --setsmsc, --version, --help)
# upstream: https://github.com/gnokii/gnokii
# Subcommands from gnokii/gnokii gnokii/gnokii.c on tip.

_gnokii() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config+[config file]:file:_files' \
        '--phone+[phone section]:section:' \
        '--identify[identify phone]' \
        '--gettime[get time]' \
        '--settime[set time]' \
        '--getsms+[SMS folder/start/end]:spec:' \
        '--sendsms+[destination]:phone:' \
        '--writefile+[file]:file:_files' \
        '--readfile+[start]:n:' \
        '--getphonebook+[memory/start/end]:spec:' \
        '--writephonebook[write phonebook]' \
        '--deletephonebook+[memory/index]:spec:' \
        '--getringtone+[location]:loc:' \
        '--setringtone+[file]:file:_files' \
        '--getlogo+[type loc]:spec:' \
        '--setlogo+[file]:file:_files' \
        '--enterspc[security code]' \
        '--getsmsc+[index]:n:' \
        '--setsmsc[set SMSC]'
}

_gnokii "$@"
