#compdef pharo
# Documentation: https://github.com/pharo-project/pharo
# Documentation: https://github.com/pharo-project/pharo-vm/blob/pharo-12/src/parameters/parameters.c
# Documentation: https://github.com/pharo-project/pharo/blob/Pharo14/src/System-CommandLineHandler/BasicPharoOptionsHandler.class.st
# Reference accessed: 2026-05-27
# Verified: VM flags from pharo-vm/src/parameters/parameters.c (vm_parameters_spec[] and printHelp); image flags from pharo BasicPharoOptionsHandler/PharoOptionsHandler comments

# Zsh completion for Pharo Smalltalk launcher

local curcontext="$curcontext" state line ret=1

local -a pharo_subcommands
pharo_subcommands=(
  'eval:evaluate Smalltalk expression'
  'save:save the image under a new name'
  'clean:clean caches and rebuild from sources'
  'config:read or write image configuration'
  'fileIn:file in legacy Smalltalk source'
  'printVersion:print image version and exit'
  'st:run a Smalltalk script file'
  'test:run unit tests'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[print help message and exit]' \
  '--version[print VM and image version then exit]' \
  '--headless[run in headless mode (no GUI window)]' \
  '--interactive[run in interactive (UI) mode]' \
  '--vm-display-null[use null display (no graphics)]' \
  '--worker[run VM in worker thread]' \
  '--logLevel=[set log level]:level:((1\:ERROR 2\:WARN 3\:INFO 4\:DEBUG 5\:TRACE))' \
  '--maxFramesToLog=[max number of Smalltalk frames to log]:count:' \
  '--maxOldSpaceSize=[max size of old space]:bytes:' \
  '--codeSize=[max size of code zone (default 1M)]:size:' \
  '--edenSize=[size of eden (default 15M)]:size:' \
  '--minPermSpaceSize=[min size of permanent space (default 0k)]:size:' \
  '--maxSlotsForNewSpaceAlloc=[max slots for single young indexable object]:words:' \
  '--stackPageSize=[size of each stack page (default 8k)]:size:' \
  '--workingDirectory=[working directory for the running image]:dir:_files -/' \
  '--avoidSearchingSegmentsWithPinnedObjects[skip pinned-object segments in GC]' \
  '--copyright[print copyright and exit]' \
  '--list[list active command-line handlers]' \
  '--no-quit[keep image running without activating another handler]' \
  '--deploymentPassword=[password required to launch the command]:password:' \
  '--readWriteAccessMode[set disk access to read-write (default)]' \
  '--readOnlyAccessMode[set disk access to read-only]' \
  '--writeOnlyAccessMode[set disk access to write-only]' \
  '--disabledAccessMode[disable disk access]' \
  '--preferences-file=[load preferences from file]:file:_files' \
  '--no-default-preferences[do not load preferences from default locations]' \
  '1:image:_files -g "*.image"' \
  '*:: :->args' && ret=0

case $state in
  args)
    if (( CURRENT == 2 )); then
      _describe -t commands 'pharo subcommand' pharo_subcommands && ret=0
    else
      _files && ret=0
    fi
    ;;
esac

return ret
