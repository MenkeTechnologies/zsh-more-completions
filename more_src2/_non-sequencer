#compdef non-sequencer
# Documentation: http://non-sequencer.tuxfamily.org/MANUAL.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--osc-port=[UDP port for the OSC server]:port:' \
  '*:project:_files' && ret=0

return ret
