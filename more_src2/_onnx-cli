#compdef onnx-cli
# _onnx-cli — Open Neural Network Exchange (ONNX) helpers CLI alias (Linux Foundation / ONNX, Python); custom argparse
# upstream: https://github.com/onnx/onnx

_onnx-cli() {
    local -a sub=(
        'check:check model is valid'
        'optimize:optimize a model'
        'visualize:visualize via netron'
        'shape-inference:run shape inference'
        'simplify:simplify a model'
        'convert:convert from another format'
        'info:show model info'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'onnx-cli subcommand' sub ;;
        args)
            case $words[1] in
                check|info) _arguments \
                    '*:model:_files -g "*.onnx"' ;;
                optimize|simplify|shape-inference) _arguments \
                    '--input=+[input model]:file:_files -g "*.onnx"' \
                    '-i+[input model]:file:_files -g "*.onnx"' \
                    '--output=+[output model]:file:_files -g "*.onnx"' \
                    '-o+[output model]:file:_files -g "*.onnx"' \
                    '--passes=+[passes csv]:list:' \
                    '*:arg:' ;;
                visualize) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '*:model:_files -g "*.onnx"' ;;
                convert) _arguments \
                    '1:from:(pt pb tflite mlmodel caffe2 trt)' \
                    '--input=+[input model]:file:_files' \
                    '--output=+[output ONNX]:file:_files -g "*.onnx"' ;;
            esac
            ;;
    esac
}

_onnx-cli "$@"
