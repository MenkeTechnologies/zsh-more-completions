#compdef foreman-rake
# _foreman-rake — Foreman foreman-rake (Rails rake task runner pre-configured for the Foreman installation; common tasks: db:migrate, db:seed, config, permissions:reset, audits:expire, foreman_tasks:cleanup, restart:resync, plugin:list)
# upstream: https://github.com/theforeman/foreman
# Common rake tasks from Foreman lib/tasks on tip.

_foreman-rake() {
    _arguments \
        '--help[show help]' \
        '--tasks[list tasks]' \
        '--dry-run[print only]' \
        '--trace[backtrace on error]' \
        '--quiet[quiet]' \
        '*-T[describe tasks matching pattern]' \
        '1:task:(db:migrate db:seed db:rollback db:setup db:reset config permissions:reset apipie:cache audits:expire foreman_tasks:cleanup foreman_tasks:reset_failed reports:expire restart:resync_chrooted plugin:list dynflow:install upgrade:run telemetry:print_all environment:cleanup)' \
        '*:rake arg:'
}

_foreman-rake "$@"
