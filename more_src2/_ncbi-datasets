#compdef datasets ncbi-datasets
# _ncbi-datasets — NCBI datasets CLI bulk download client for the NCBI Datasets v2 API fetching genome assemblies gene-data orthologs taxonomy virus protein structure reference-sequence hierarchies as JSONL TSV ZIP packages with sequence FASTA GFF3 GTF GenBank annotations report for downstream analysis (NCBI team, Go); cobra
# upstream: https://www.ncbi.nlm.nih.gov/datasets/

_ncbi-datasets() {
    local -a sub=(
        'completion:generate shell completion'
        'download:download data package'
        'rehydrate:rehydrate a dataset package'
        'summary:print data summary'
        'gene:work with gene data'
        'genome:work with genome data'
        'taxonomy:work with taxonomy data'
        'virus:work with virus data'
        'protein:work with protein data'
        'organelle:work with organelle data'
        'gff:work with GFF feature data'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--api-key=+[key]:str:' \
        '--debug[debug]' \
        '--no-progressbar[no progress bar]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ncbi-datasets subcommand' sub ;;
        args)
            case $words[1] in
                download) _arguments \
                    '1:type:(gene genome taxonomy virus)' \
                    '*:accession:' ;;
                rehydrate) _arguments \
                    '--directory=+[dir]:dir:_files -/' \
                    '--max-workers=+[N]:n:' \
                    '--match=+[regex]:str:' \
                    '--gzip[gzip files]' ;;
            esac
            ;;
    esac
}

_ncbi-datasets "$@"
