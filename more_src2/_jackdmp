#compdef jackdmp
# Documentation: https://www.mankier.com/1/jackd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jackdmp: JACK2 multi-processor server (jackd binary). Server options
# below; per-backend driver options follow `-d driver`.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '(-d --driver)'{-d+,--driver=}'[backend driver]:driver:(alsa coreaudio dummy firewire freebob iio loopback net netadapter netone oss portaudio sun winmme)' \
  '(-R --realtime)'{-R,--realtime}'[use realtime scheduling]' \
  '(-r --no-realtime)'{-r,--no-realtime}'[do not use realtime scheduling]' \
  '(-P --realtime-priority)'{-P+,--realtime-priority=}'[realtime scheduler priority]:priority:' \
  '(-n --name)'{-n+,--name=}'[name this jackd instance]:name:' \
  '(-p --port-max)'{-p+,--port-max=}'[maximum number of ports]:n:' \
  '(-T --temporary)'{-T,--temporary}'[exit once all clients disconnected]' \
  '(-t --timeout)'{-t+,--timeout=}'[client timeout in milliseconds]:ms:' \
  '(-Z --nozombies)'{-Z,--nozombies}'[never remove unresponsive clients]' \
  '(-u --unlock)'{-u,--unlock}'[unlock GTK/QT/FLTK/Wine libraries]' \
  '(-m --no-mlock)'{-m,--no-mlock}'[do not lock memory]' \
  '(-c --clocksource)'{-c+,--clocksource=}'[clock source]:src:(c h s)' \
  '(-a --autoconnect)'{-a+,--autoconnect=}'[self-connect mode char]:mode:' \
  '(-s --silent)'{-s,--silent}'[silence output]' \
  '--replace-registry[remove shared memory registry before startup]' \
  '(-C --internal-session-file)'{-C+,--internal-session-file=}'[load internal clients from file]:file:_files' \
  '*: :_files' && ret=0
return ret
