#compdef rustmailer
# ============================================================================
# rustmailer - Self-hosted email middleware (Rust)
#
# Author : rustmailer.com team
# Upstream: https://github.com/rustmailer/rustmailer
#
# rustmailer is a self-hosted email middleware exposing IMAP / SMTP /
# OAuth2 / event-hook surfaces as a unified REST + gRPC API. It
# manages many email accounts, handles per-account OAuth2 token
# refresh (Gmail / Outlook / Yahoo / generic IMAP+OAuth2), runs
# inbox + folder syncs in the background, exposes an Open Email
# Tracking Service (click / open pixel tracking), and ships a TLS-
# native deployment with built-in metric scraping.
#
# The OAuth2 lane is built on `oauth2 = "5.0.0"` (declared verbatim
# at upstream Cargo.toml HEAD), the canonical Rust OAuth2 client
# library by Alex Ramos (ramosbugs / oauth2-rs, 1180+ stars on
# github.com/ramosbugs/oauth2-rs). The library implements RFC 6749
# (OAuth 2.0 Authorization Framework) end-to-end: authorization
# code + implicit + password + client-credentials + device-code
# grants, refresh-token rotation, token introspection (RFC 7662),
# token revocation (RFC 7009), and the PKCE extension (RFC 7636).
# Strongly typed via Rust newtypes (`AuthUrl`, `TokenUrl`,
# `ClientSecret`, `RedirectUrl`, `Scope`) which catch
# misconfiguration at compile time rather than at the OAuth2
# server's first reject response.
#
# rustmailer uses oauth2-rs for the long-running token refresh
# loops per email account: at sync time it inspects the cached
# token expiry, fires a refresh-token grant if needed, and updates
# the per-account credential record in the redb-backed local store.
#
# ----------------------------------------------------------------------------
# AXIS 207 :: OAUTH 2.0 (RFC 6749 + PKCE RFC 7636 + INTROSPECT RFC 7662)
# Round 1319 :: Rust slot 1 of 4 :: OPENS Axis 207
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : ramosbugs/oauth2-rs              - typed OAuth2 client
#   Go      : golang.org/x/oauth2              - Go-team-maintained OAuth2 client
#   TS/Node : panva/node-openid-client         - OAuth2 + OIDC client
#
# All three are clean-room implementations of RFC 6749 with the
# common PKCE + introspect + revoke extensions. The lane is
# distinct from Axis 202 (JWT), which deals with token *formats*;
# this axis deals with the auth *flow protocol* that ferries the
# tokens between client, authorization server, and resource server.
# RFC 6749 dates to 2012, predating JWT (RFC 7519, 2015) by 3 years
# - in early-OAuth2 deployments, opaque tokens were the norm, and
# JWT-as-access-token only became the default after the OIDC spec
# work in 2014 leaned on it.
# ============================================================================

_rustmailer() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--rustmailer-log-level[log level (default info)]:level:(trace debug info warn error)' \
        '--rustmailer-http-port[HTTP API port (default 15630)]:port:' \
        '--rustmailer-bind-ip[IPv4 bind address (default 0.0.0.0)]:ip:' \
        '--rustmailer-grpc-port[gRPC API port (default 16630)]:port:' \
        '--rustmailer-public-url[public URL for the API (default http://localhost:15630)]:url:' \
        '--rustmailer-email-tracking-url[base URL for email open/click tracking]:url:' \
        '--rustmailer-cors-origins[allowed CORS origins (comma-separated)]:origins:' \
        '--rustmailer-cors-max-age[CORS max-age in seconds (default 86400)]:seconds:' \
        '--rustmailer-send-mail-workers[concurrent SMTP send workers (default 20)]:n:' \
        '--rustmailer-max-email-content-length[max email body length in chars (default 100000)]:n:' \
        '--rustmailer-event-hook-workers[event-hook concurrency (default 20)]:n:' \
        '--rustmailer-ansi-logs[ANSI-color terminal logs (default true)]:bool:(true false)' \
        '--rustmailer-log-to-file[also write logs to disk]:bool:(true false)' \
        '--rustmailer-json-logs[emit logs in JSON format]:bool:(true false)' \
        '--rustmailer-max-server-log-files[log file rotation count]:n:' \
        '--rustmailer-encrypt-password[encryption password (env preferred)]:password:' \
        '--rustmailer-root-dir[root data directory]:directory:_files -/' \
        '--rustmailer-metadata-cache-size[metadata cache size (bytes)]:n:' \
        '--rustmailer-task-queue-cache-size[task queue cache size]:n:' \
        '--rustmailer-envelope-cache-size[envelope cache size]:n:' \
        '--rustmailer-enable-access-token[require access tokens]:bool:(true false)' \
        '--rustmailer-enable-rest-https[enable HTTPS for REST API]:bool:(true false)' \
        '--rustmailer-enable-grpc-https[enable HTTPS for gRPC]:bool:(true false)' \
        '--rustmailer-email-tracking-enabled[enable email-tracking endpoints]:bool:(true false)' \
        '--rustmailer-grpc-enabled[enable gRPC server]:bool:(true false)' \
        '--rustmailer-grpc-compression[gRPC compression algorithm]:algo:(gzip identity)' \
        '--rustmailer-http-compression-enabled[enable HTTP compression]:bool:(true false)' \
        '--rustmailer-cleanup-interval-hours[cleanup task interval in hours]:hours:' \
        '--rustmailer-backup-dir[backup directory]:directory:_files -/' \
        '--rustmailer-max-backups[max backups to keep]:n:' \
        '--rustmailer-metadata-memory-mode-enabled[keep metadata in memory]:bool:(true false)' \
        '--rustmailer-imap-keepalive-enabled[enable IMAP keepalive]:bool:(true false)' \
        '--rustmailer-metadata-snapshot-interval-secs[metadata snapshot interval]:seconds:' \
        '--rustmailer-oauth2-success-redirect[OAuth2 success redirect URL]:url:' \
        '--rustmailer-sync-concurrency[per-account sync concurrency]:n:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_rustmailer "$@"
