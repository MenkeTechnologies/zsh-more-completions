#compdef newfs_v7fs
# Documentation: man newfs_v7fs(8)
# Source: netbsd/src sbin/newfs_v7fs — construct a 7th Edition file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[metadata byte order (default host)]:byte order:(be le pdp)' \
    '-F[create filesystem to regular file (requires -s)]' \
    '-n+[number of inodes (max 65536)]:inodes:_default' \
    '-s+[filesystem size in disk sectors]:sectors:_default' \
    '-V+[verbosity level 0-4 (default 3)]:level:(0 1 2 3 4)' \
    '-Z[fill with zeroes instead of sparse file]' \
    '1:special device:_files' \
    && ret=0

return ret
