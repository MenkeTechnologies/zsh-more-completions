#compdef dkron
# Documentation: https://dkron.io/docs/cli/dkron_agent/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dkron - Distributed job scheduling

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'agent:Start a dkron agent'
      'doc:Generate documentation'
      'keygen:Generate an encryption key'
      'raft:Raft cluster management'
      'leave:Force the agent to leave the cluster'
      'version:Show version'
    )
    _describe -t commands 'dkron command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      agent)
        _arguments -s -S \
          '--bind-addr=[address for network services]:address' \
          '--http-addr=[UI/HTTP listen address]:address' \
          '--advertise-addr=[address to advertise to other nodes]:address' \
          '--advertise-rpc-port=[RPC port to advertise]:port' \
          '--rpc-port=[RPC port]:port' \
          '--datacenter=[data center name]:dc' \
          '--region=[region name]:region' \
          '--profile=[timing profile]:profile:(lan wan local)' \
          '--raft-multiplier=[Raft timing scalar]:n' \
          '--serf-reconnect-timeout=[Serf node reconnect timeout]:duration' \
          '*--join=[initial join address]:address' \
          '*--retry-join=[retry-join address]:address' \
          '--retry-interval=[wait between join attempts]:duration' \
          '--retry-max=[maximum join attempts]:count' \
          '*--tag=[node tag key=value]:tag' \
          '--encrypt=[base64 encryption key]:key' \
          '--log-level=[log level]:level:(debug info warn error)' \
          '--node-name=[unique node name]:name' \
          '--data-dir=[data directory]:directory:_directories' \
          '--server[run as a server]' \
          '--ui[enable web UI]' \
          '--bootstrap-expect=[expected servers for cluster bootstrap]:count' \
          '--enable-prometheus[serve Prometheus metrics]' \
          '--disable-usage-stats[disable anonymous usage stats]' \
          '--config=[config file path]:file:_files' \
          '--cronitor-endpoint=[Cronitor endpoint]:url' \
          '--dog-statsd-addr=[DogStatsD address]:address' \
          '*--dog-statsd-tags=[DogStatsD tags]:tag' \
          '--statsd-addr=[StatsD address]:address' \
          '--mail-host=[mail server host]:host' \
          '--mail-port=[mail server port]:port' \
          '--mail-username=[mail username]:username' \
          '--mail-password=[mail password]:password' \
          '--mail-from=[mail from address]:email' \
          '--mail-payload=[mail payload template]:template' \
          '--mail-subject-prefix=[mail subject prefix]:prefix' \
          '--pre-webhook-endpoint=[pre-execution webhook endpoint]:url' \
          '--pre-webhook-payload=[pre-execution webhook payload]:payload' \
          '*--pre-webhook-headers=[pre-execution webhook header]:header' \
          '--webhook-endpoint=[post-execution webhook endpoint]:url' \
          '--webhook-payload=[post-execution webhook payload]:payload' \
          '*--webhook-headers=[post-execution webhook header]:header' && ret=0
        ;;
      raft)
        local -a subcmds=(
          'list-peers:List raft peers'
          'remove-peer:Remove a raft peer'
        )
        _describe -t subcmds 'raft subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
