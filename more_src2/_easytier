#compdef easytier-core easytier-cli easytier-web
# _easytier — EasyTier decentralized self-hosted mesh VPN supporting P2P transit and NAT traversal (EasyTier team, Rust); clap-derive
# upstream: https://github.com/EasyTier/EasyTier

_easytier-core() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--network-name=+[network name]:str:' \
        '-n+[network name]:str:' \
        '--network-secret=+[network secret]:str:' \
        '-s+[network secret]:str:' \
        '--ipv4=+[node ipv4]:str:' \
        '-i+[node ipv4]:str:' \
        '--peers=+[peer urls csv]:str:' \
        '-p+[peer urls csv]:str:' \
        '--listeners=+[listen urls csv]:str:' \
        '-l+[listen urls csv]:str:' \
        '--external-node=+[external public stun]:str:' \
        '-e+[external public stun]:str:' \
        '--rpc-portal=+[rpc bind]:str:' \
        '--rpc-portal-whitelist=+[CIDR]:str:' \
        '--manual-routes=+[routes csv]:str:' \
        '-r+[routes csv]:str:' \
        '--default-protocol=+[proto]:p:(tcp udp wg ws wss)' \
        '-d+[proto]:p:(tcp udp wg ws wss)' \
        '--dev-name=+[tun name]:str:' \
        '--mtu=+[mtu]:n:' \
        '--enable-encryption[enable encryption]' \
        '--disable-encryption[disable encryption]' \
        '--disable-ipv6[disable ipv6]' \
        '--multi-thread[multi thread]' \
        '-m[multi thread]' \
        '--latency-first[choose lowest latency]' \
        '--enable-exit-node[act as exit node]' \
        '--no-tun[disable tun device]' \
        '--use-smoltcp[use smoltcp]' \
        '--foreign-network-whitelist=+[networks csv]:str:' \
        '--mapped-listeners=+[listeners csv]:str:' \
        '--vpn-portal=+[vpn portal]:str:' \
        '--proxy-networks=+[CIDRs csv]:str:' \
        '-x+[CIDRs csv]:str:' \
        '--socks5=+[port]:port:_ports' \
        '--enable-kcp-proxy[enable kcp]' \
        '--enable-quic-proxy[enable quic]' \
        '--accept-dns[accept dns from peers]' \
        '--enable-magic-dns[magic dns]' \
        '--instance-name=+[name]:str:' \
        '--machine-id=+[id]:str:' \
        '--config-server=+[config server]:str:' \
        '--token=+[token]:str:' \
        '--web-token=+[token]:str:' \
        '--log-level=+[level]:l:(trace debug info warn error off)' \
        '--log-file=+[log file]:file:_files' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-c+[config file]:file:_files -g "*.toml"'
}

_easytier-core "$@"
