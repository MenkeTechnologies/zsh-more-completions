#compdef mocka
# ============================================================================
#  _mocka — MOCKA Modula-2 Compiler System
#
#  Source-direct extraction from
#    https://github.com/trijezdci/MOCKA/blob/master/ver1807/src/MockaArgs.mod
#    https://github.com/trijezdci/MOCKA/blob/master/ver1807/src/MockaShell.mod
#
#  Originally GMD Karlsruhe (1988-2000), then Fraunhofer (2001-2018).
#
#  CLI library taxonomy update: first documented Modula-2 entry. MOCKA's
#  argument parsing is rolled by hand in MockaArgs.mod on top of PIM
#  Modula-2's stdlib `Arguments` module — `IMPORT Arguments` exposes
#  `ArgTable` (pointer to argv) and `GetArgs(VAR argc, VAR argv)`. The
#  module walks argv with a `LOOP ... StrEq(arg, "-flag") ...` ladder,
#  short-circuits on `-help` / `-version` (HALT), and forwards unknown
#  `-X` flags to `SuBase.SetOption(arg, ok)` for single-letter compiler
#  toggles. Brings cross-language CLI library taxonomy variant count to 74.
#
#  Surface (verbatim from MockaArgs.mod `ScanArgs`):
#    -s <module>     compile DEFINITION module       (sets ModeSpec=CompileDefMode)
#    -c <module>     compile IMPLEMENTATION module   (sets ModeSpec=CompileImpMode)
#    -p <module>     bind (link) module              (sets ModeSpec=BindMode)
#    -d <path>       add library search path         (concatenated, space-sep)
#    -D <path>       working library directory       (compilation product output)
#    -link <path>    override linker script          (default /usr/local/bin/mocka/link)
#    -edit <path>    override editor script          (default /usr/local/bin/mocka/edit)
#    -list <path>    override lister script          (default /usr/local/bin/mocka/list)
#    -asm <path>     override assembler script       (default /usr/local/bin/mocka/asm)
#    -syslib <path>  override default library path   (default /usr/local/lib/mocka/mockalib)
#    -prompt <s>     override interactive prompt     (default ">>")
#    -V <variant>    define variant (must not start with '-')
#    -info           show public options (showpublic := TRUE)
#    -options        show active options (show := TRUE)
#    -help           show usage and HALT
#    -version        show release version and HALT
#    -<letter>       fallback: SetOption(letter) for single-char compiler options
#
#  Dup-skipped neighbors during hunt (already in corpus or stock zsh):
#    bolt(IN CORPUS), mu(STOCK), hop(IN CORPUS), dasel, gum, biome, flox,
#    cauwugo, oxfmt, pack, unison, cat, hello, chmcmd.
# ============================================================================

_mocka() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-s[compile DEFINITION part of module]:module name' \
    '-c[compile IMPLEMENTATION part of module]:module name' \
    '-p[bind (link) module into executable]:module name' \
    '*-d[add library search path]:library path:_directories' \
    '-D[working library directory for compilation products]:directory:_directories' \
    '-link[override linker script path]:linker script:_files' \
    '-edit[override editor script path]:editor script:_files' \
    '-list[override lister script path]:lister script:_files' \
    '-asm[override assembler script path]:assembler script:_files' \
    '-syslib[override default system library path]:syslib path:_directories' \
    '-prompt[override interactive shell prompt]:prompt string' \
    '-V[define variant tag (must not start with -)]:variant name' \
    '-info[show public compiler options and exit]' \
    '-options[show active compiler options]' \
    '-help[show usage and exit]' \
    '-version[show MOCKA release version and exit]' \
    '*:Modula-2 source file:_files -g "*.(mod|MOD|def|DEF)"'
}

_mocka "$@"
