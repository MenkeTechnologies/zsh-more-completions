#compdef pg_test_timing
# Documentation: https://www.postgresql.org/docs/current/app-pgtesttiming.html
# Source: postgres/postgres src/bin/pg_test_timing/pg_test_timing.c — measure timing overhead (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-d+,--duration=}'[test duration in seconds]:seconds:_default' \
    {-c+,--cutoff=}'[cutoff percentile]:percent:_default' \
    && ret=0

return ret
