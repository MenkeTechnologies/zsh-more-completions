#compdef pyinstaller
# Documentation: https://pyinstaller.org/en/stable/usage.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--distpath=[where to put the bundled app]:directory:_directories' \
  '--workpath=[where to put temp work files]:directory:_directories' \
  '-y[replace output directory without confirmation]' \
  '--noconfirm[replace output directory without confirmation]' \
  '--upx-dir=[path to UPX utility]:directory:_directories' \
  '--clean[clean PyInstaller cache before building]' \
  '--log-level=[amount of detail in build-time console messages]:level:(TRACE DEBUG INFO WARN DEPRECATION ERROR FATAL)' \
  '-D[create a one-folder bundle]' \
  '--onedir[create a one-folder bundle]' \
  '-F[create a one-file bundled executable]' \
  '--onefile[create a one-file bundled executable]' \
  '--specpath=[folder to store the spec file]:directory:_directories' \
  '-n+[name to assign to the bundled app]:name' \
  '--name=[name to assign to the bundled app]:name' \
  '*--add-data=[additional non-binary files or folders]:src\:dest' \
  '*--add-binary=[additional binary files]:src\:dest' \
  '*-p+[search path for imports]:path:_directories' \
  '*--paths=[search path for imports]:path:_directories' \
  '*--hidden-import=[name of import not visible in code]:module' \
  '*--collect-submodules=[collect all submodules from package]:package' \
  '*--collect-data=[collect all data from package]:package' \
  '*--collect-binaries=[collect all binaries from package]:package' \
  '*--collect-all=[collect submodules, data, and binaries from package]:package' \
  '*--copy-metadata=[copy metadata for package]:package' \
  '*--recursive-copy-metadata=[copy metadata recursively]:package' \
  '*--additional-hooks-dir=[additional path to search for hooks]:directory:_directories' \
  '*--runtime-hook=[path to custom runtime hook file]:file:_files -g "*.py"' \
  '*--exclude-module=[module to exclude]:module' \
  '-d+[debug options]:option:(all imports bootloader noarchive)' \
  '--debug=[debug options]:option:(all imports bootloader noarchive)' \
  '--optimize=[bytecode optimization level]:level:(-1 0 1 2)' \
  '*--python-option=[Python interpreter run-time option]:option' \
  '-s[apply symbol-table strip to executable]' \
  '--strip[apply symbol-table strip to executable]' \
  '--noupx[do not use UPX]' \
  '--upx-exclude=[prevent UPX from compressing binary]:file' \
  '--contents-directory=[onedir supporting files directory name]:name' \
  '-c[open a console window (default)]' \
  '--console[open a console window (default)]' \
  '--nowindowed[open a console window (default)]' \
  '-w[do not open a console window]' \
  '--windowed[do not open a console window]' \
  '--noconsole[do not open a console window]' \
  '--hide-console=[console hiding behavior]:mode:(minimize-early minimize-late hide-late hide-early)' \
  '-i+[apply icon to executable]:icon file:_files' \
  '--icon=[apply icon to executable]:icon file:_files' \
  '--disable-windowed-traceback[disable traceback in windowed mode]' \
  '--splash=[splash screen image]:image:_files' \
  '--version-file=[add version resource (Windows)]:file:_files' \
  '--manifest=[add manifest (Windows)]:file or XML' \
  '*-r+[add or update resource (Windows)]:resource' \
  '*--resource=[add or update resource (Windows)]:resource' \
  '--uac-admin[request admin elevation (Windows)]' \
  '--uac-uiaccess[allow Remote Desktop UI access (Windows)]' \
  '--argv-emulation[enable argv emulation (macOS .app)]' \
  '--osx-bundle-identifier=[macOS bundle identifier]:id' \
  '--target-architecture=[target architecture (macOS)]:arch:(x86_64 arm64 universal2)' \
  '--codesign-identity=[code signing identity (macOS)]:identity' \
  '--osx-entitlements-file=[entitlements file (macOS)]:file:_files' \
  '--runtime-tmpdir=[extraction dir for onefile mode]:path' \
  '--bootloader-ignore-signals[ignore signals in bootloader]' \
  '*:script file:_files -g "*.(py|spec)"' && ret=0

return ret
