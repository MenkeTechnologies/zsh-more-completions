#compdef qodem
# Documentation: https://manpages.opensuse.org/Tumbleweed/qodem/qodem.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (qodem terminal emulator).

local ret=1
_arguments \
  '--capfile=[capture file]:file:_files' \
  '--logfile=[log file]:file:_files' \
  '--dial=[connect to phone book entry n]:n:' \
  '--connect=[host to connect to]:host:_hosts' \
  '--connect-method=[connection method]:method:(ssh rlogin telnet socket shell)' \
  '--username=[username for connection]:user:_users' \
  '--xterm[enable X11 terminal mode]' \
  '--keyfile=[keyboard macro file]:file:_files' \
  '--xl8file=[8-bit translation table file]:file:_files' \
  '--xlufile=[Unicode translation table file]:file:_files' \
  '--scrfile=[script file to execute after connect]:file:_files' \
  '--config=[config file to load]:file:_files' \
  '--create-config=[generate new config file]:file:_files' \
  '--dotqodem-dir=[alternative .qodem directory]:dir:_files -/' \
  '--emulation=[terminal emulation]:emu:' \
  '--codepage=[character encoding]:cp:' \
  '--geometry=[window size COLSxROWS]:WxH:' \
  '--status-line=[status line toggle]:state:(on off)' \
  '--doorway=[doorway mode]:mode:(doorway mixed off)' \
  '--play=[play ANSI music string]:music:' \
  '--play-exit[exit after playing music]' \
  '--read-only[disable disk writes entirely]' \
  '(-x --exit-on-completion)'{-x,--exit-on-completion}'[exit after script]' \
  '--version[show version]' \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' && ret=0
return ret
