#compdef RNALfold
# Documentation: https://www.tbi.univie.ac.at/RNA/RNALfold.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNALfold: compute locally stable secondary structures of long RNAs
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-L --span)'{-L,--span=}'[maximum base pair span (window size)]:span:' \
  '(-T --temp)'{-T,--temp=}'[folding temperature in C]:temp:' \
  '(-z --zscore)'{-z,--zscore=-}'[Z-score threshold]::thresh:' \
  '--zscore-pre-filter[Z-score filter during forward recursion]' \
  '--zscore-report-subsumed[report subsumed structures]' \
  '(-b --backtrack-global)'{-b,--backtrack-global}'[construct global MFE structure]' \
  '(-d --dangles)'{-d,--dangles=}'[dangling end model]:d:(0 1 2 3)' \
  '(-g --gquad)'{-g,--gquad}'[allow G-quadruplexes]' \
  '--noLP[no lonely pairs]' \
  '--noGU[no GU pairs]' \
  '--noClosingGU[no GU at helix ends]' \
  '(-P --paramFile)'{-P,--paramFile=}'[parameter file]:file:_files' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--salt=[salt concentration in molar]:val:' \
  '(-i --infile)'{-i,--infile=}'[input file]:file:_files' \
  '(-o --outfile)'{-o,--outfile=-}'[output file]::file:_files' \
  '--noconv[do not convert T to U]' \
  '--auto-id[auto-generate sequence IDs]' \
  '--shape=[SHAPE reactivity data]:file:_files' \
  '--shapeMethod=[SHAPE conversion strategy]:method:' \
  '--commands=[command/constraints file]:file:_files' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
