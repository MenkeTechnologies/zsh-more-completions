#compdef mayastor-csi-node
# _mayastor-csi-node — Mayastor CSI node plugin (one DaemonSet pod per worker; handles NVMe-oF attach + mount on the node)
# upstream: https://github.com/openebs/mayastor-control-plane
# Flags from control-plane/csi-driver/src/bin/node/{main_,config}.rs on tip (clap); NVMe parameters mirror the kebab-cased CSI Parameters enum.

_mayastor-csi-node() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '--node-name=[Kubernetes node name reported by the plugin]:name:' \
        '--rest-endpoint=[Mayastor REST API endpoint]:url:_urls' \
        '--grpc-endpoint=[node-plugin gRPC endpoint]:hostport:' \
        '--nvme-core-io-timeout=[NVMe core IO timeout (s)]:s:' \
        '--nvme-nr-io-queues=[NVMe nr_io_queues (number of I/O queue pairs)]:n:' \
        '--nvme-keep-alive-tmo=[NVMe keep-alive timeout (s)]:s:' \
        '--nvme-ctrl-loss-tmo=[NVMe controller loss timeout (s)]:s:' \
        '--nvme-reconnect-delay=[NVMe reconnect delay (s)]:s:' \
        '--nvme-io-tmo=[NVMe I/O timeout (s)]:s:' \
        '--enable-registration=[register the node with the control plane on startup]:bool:(true false)' \
        '--csi-socket=[UNIX socket the CSI plugin listens on]:socket:_files' \
        '--node-selector-key=[label key advertised on the node]:key:' \
        '--node-selector-value=[label value advertised on the node]:value:' \
        '--jaeger=[Jaeger collector endpoint]:url:_urls' \
        '--fmt-style=[log format style]:style:(default compact pretty json)' \
        '--fmt-layer=[log layer]:layer:(stdout stderr console)'
}

_mayastor-csi-node "$@"
