#compdef function-hcl
# _function-hcl — Crossplane composition function that evaluates HashiCorp HCL programs to produce managed resources (gRPC server consumed by crossplane)
# upstream: https://github.com/crossplane-contrib/function-hcl
# Flags from function/main.go on tip (alecthomas/kong); TLS_SERVER_CERTS_DIR env var binds to --tls-certs-dir.

_function-hcl() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[emit debug logs in addition to info logs]' \
        '--network=[network on which to listen for gRPC connections]:net:(tcp unix)' \
        '--address=[address on which to listen for gRPC connections]:addr:' \
        '--tls-certs-dir=[directory containing server tls.key + tls.crt + ca.crt (TLS_SERVER_CERTS_DIR env var)]:dir:_files -/' \
        '--insecure[run without mTLS credentials (--tls-certs-dir is ignored)]'
}

_function-hcl "$@"
