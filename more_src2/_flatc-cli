#compdef flatc-cli
# _flatc-cli — Google FlatBuffers flatc compiler CLI alias (Google, C++); custom argparse
# upstream: https://github.com/google/flatbuffers

_flatc-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--binary[binary FlatBuffer output]' \
        '-b[binary FlatBuffer output]' \
        '--text[generate text from FlatBuffer]' \
        '-t[generate text from FlatBuffer]' \
        '-o+[output path]:dir:_files -/' \
        '--output=+[output path]:dir:_files -/' \
        '-I+[include path]:list:_files -/' \
        '-M[print make rules]' \
        '--strict-json[strict JSON]' \
        '--allow-non-utf8[allow non-utf8]' \
        '--natural-utf8[natural utf8]' \
        '--defaults-json[include defaults in JSON]' \
        '--unknown-json[allow unknown fields]' \
        '--no-prefix[no prefix]' \
        '--scoped-enums[use scoped enums]' \
        '--swift-implementation-only[swift implementation only]' \
        '--gen-includes[gen includes]' \
        '--no-includes[no includes]' \
        '--gen-mutable[generate mutators]' \
        '--gen-onefile[generate one file]' \
        '--gen-name-strings[generate name strings]' \
        '--gen-object-api[generate object api]' \
        '--gen-compare[generate compare]' \
        '--gen-nullable[generate nullable]' \
        '--gen-generated[generate generated marker]' \
        '--gen-jvmstatic[generate JVMStatic]' \
        '--gen-all[generate for all dependencies]' \
        '--cpp[generate C++ output]' \
        '-c[generate C++ output]' \
        '--java[generate Java output]' \
        '-j[generate Java output]' \
        '--csharp[generate C# output]' \
        '-n[generate C# output]' \
        '--ts[generate TypeScript output]' \
        '-T[generate TypeScript output]' \
        '--go[generate Go output]' \
        '-g[generate Go output]' \
        '--python[generate Python output]' \
        '-p[generate Python output]' \
        '--lobster[generate Lobster output]' \
        '--lua[generate Lua output]' \
        '--rust[generate Rust output]' \
        '-r[generate Rust output]' \
        '--php[generate PHP output]' \
        '--kotlin[generate Kotlin output]' \
        '--dart[generate Dart output]' \
        '--swift[generate Swift output]' \
        '--reflect-types[reflect types]' \
        '--reflect-names[reflect names]' \
        '--rust-serialize[rust serde]' \
        '--rust-module-root-file[rust module root file]' \
        '--rust-namespace=+[rust namespace]:str:' \
        '--proto[parse proto schema]' \
        '--proto-namespace-suffix=+[proto namespace suffix]:str:' \
        '--oneof-union[oneof to union]' \
        '--keep-prefix[keep prefix]' \
        '--filename-suffix=+[filename suffix]:str:' \
        '--filename-ext=+[filename ext]:str:' \
        '--include-prefix=+[include prefix]:str:' \
        '--bfbs-comments[gen bfbs comments]' \
        '--bfbs-builtins[gen bfbs builtins]' \
        '--bfbs-gen-embed[bfbs gen embed]' \
        '--conform=+[conform to existing schema]:file:_files' \
        '--conform-includes=+[conform includes]:list:_files -/' \
        '--filename-suffix=+[filename suffix]:str:' \
        '--require-explicit-ids[require explicit ids]' \
        '--force-defaults[force defaults]' \
        '--force-empty[force empty]' \
        '--force-empty-vectors[force empty vectors]' \
        '*:schema-or-data:_files'
}

_flatc-cli "$@"
