#compdef inertiad
# _inertiad — Inertia continuous-deployment daemon (ubclaunchpad/inertia)
# upstream: https://github.com/ubclaunchpad/inertia
# Subcommands from daemon/inertiad/main.go (cobra).

_inertiad() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:start the daemon (initialize deployment)'
                'token:produce an API token to use with the daemon'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '(-p --port)'{-p+,--port=}'[daemon port]:port:' \
                        ':host address:_hosts'
                    ;;
            esac
            ;;
    esac
}

_inertiad "$@"
