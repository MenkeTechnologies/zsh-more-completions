#compdef pacemaker-controld
# Documentation: https://clusterlabs.org/projects/pacemaker/man/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. STUB: subdaemon spawned by
# pacemakerd; the only documented CLI options are help/version/verbose.

# Pacemaker CRM control subdaemon (DC election, state transitions)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-\$,--version}'[show version]' \
  '*'{-V,--verbose}'[increase verbosity]' \
  '*::pacemaker-controld args:_files' && ret=0
return ret
