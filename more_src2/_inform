#compdef inform
# Documentation: https://www.inform-fiction.org/manual/html/tables.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# inform: Inform 6 compiler (interactive fiction)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-?[show help]' \
  '-c[centred listing]' \
  '-d[debug mode]' \
  '-D[disable]:switch:' \
  '-e[economy]' \
  '-f[force compilation]' \
  '-g[debug Z-machine]' \
  '-i[ignore errors]' \
  '-k[debug labels]' \
  '-m[memory map]' \
  '-n[no banner]' \
  '-o[output dir]:dir:_files -/' \
  '-p[print summary]' \
  '-q[quiet]' \
  '-r[show warnings as errors]' \
  '-s[statistics]' \
  '-t[token table]' \
  '-u[infrequent attribute list]' \
  '-v3[version 3 Z-code]' \
  '-v4[version 4 Z-code]' \
  '-v5[version 5 Z-code]' \
  '-v6[version 6 Z-code]' \
  '-v7[version 7 Z-code]' \
  '-v8[version 8 Z-code]' \
  '-x[show stats]' \
  '-y[trace verbs]' \
  '-z[memory size]:n:' \
  '+include_path[include path]:dir:_files -/' \
  '+source_path[source path]:dir:_files -/' \
  '*:.inf source file:_files -g "*.inf"' && ret=0
return ret
