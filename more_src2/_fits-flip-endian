#compdef fits-flip-endian
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/fits-flip-endian.1 — endian-swap FITS binary tables (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input file]:file:_files -g "*.{fits,fit,fts}"' \
    '-o+[output file]:file:_files' \
    '*-e+[FITS extension number]:n:_default' \
    '*-s+[data size in bytes]:n:_default' \
    && ret=0

return ret
