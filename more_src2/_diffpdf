#compdef diffpdf
# Documentation: https://manpages.debian.org/trixie/diffpdf/diffpdf.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Qt-based DiffPDF by Mark Summerfield — GUI-first; only -a/--appearance is documented.

_arguments -s \
  '(-a --appearance)'{-a,--appearance}'[start comparison in appearance mode]' \
  '1:file1:_files -g "*.pdf"' \
  '2:file2:_files -g "*.pdf"'
