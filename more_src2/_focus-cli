#compdef focus-cli
# _focus-cli — Ayooluwa Isaiah focus terminal Pomodoro timer CLI alias (ayoisaiah, Go); spf13/cobra
# upstream: https://github.com/ayoisaiah/focus

_focus-cli() {
    local -a sub=(
        'edit-config:edit config file'
        'edit-tags:edit tags'
        'list:list timers'
        'resume:resume paused timer'
        'stats:show stats'
        'delete:delete timers'
        'pause:pause running timer'
        'status:show status of running timer'
        'config:show config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--no-color[no color]' \
        '--disable-notifications[disable notifications]' \
        '-d[disable notifications]' \
        '--sound=+[ambient sound]:s:(off coffee_shop fireplace rain wind river summer_night forest)' \
        '-s+[ambient sound]:s:(off coffee_shop fireplace rain wind river summer_night forest)' \
        '--sound-on-break=+[sound during breaks]:b:(on off)' \
        '--break-sound=+[break-end sound]:s:(loud_bell bell wood_chime fancy_door)' \
        '--work-sound=+[work-end sound]:s:(loud_bell bell wood_chime fancy_door)' \
        '--work-msg=+[work-msg]:str:' \
        '--short-break-msg=+[short break msg]:str:' \
        '--long-break-msg=+[long break msg]:str:' \
        '--work-cmd=+[work-end command]:str:' \
        '--short-break-cmd=+[short break-end command]:str:' \
        '--long-break-cmd=+[long break-end command]:str:' \
        '--work=+[work duration mins]:n:' \
        '-w+[work duration mins]:n:' \
        '--short-break=+[short break mins]:n:' \
        '-s+[short break mins]:n:' \
        '--long-break=+[long break mins]:n:' \
        '-l+[long break mins]:n:' \
        '--long-break-interval=+[long break interval]:n:' \
        '--allow-pausing[allow pausing]' \
        '--auto-start-work[auto start work]' \
        '--auto-start-break[auto start break]' \
        '--strict[strict]' \
        '--tag=+[tag]:list:' \
        '-t+[tag]:list:' \
        '--session-cmd=+[session command]:str:' \
        '--pomos=+[number of pomos]:n:' \
        '-p+[number of pomos]:n:' \
        '--since=+[since]:str:' \
        '--until=+[until]:str:' \
        '--period=+[period]:p:(today yesterday 7days 14days 30days 90days 180days 365days all-time)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'focus subcommand' sub ;;
        args)
            case $words[1] in
                list|stats|delete) _arguments \
                    '--tag=+[tag]:list:' \
                    '-t+[tag]:list:' \
                    '--since=+[since]:str:' \
                    '--until=+[until]:str:' \
                    '--period=+[period]:p:(today yesterday 7days 14days 30days 90days 180days 365days all-time)' \
                    '--json[json output]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_focus-cli "$@"
