#compdef quiz
# Documentation: man quiz(6)
# Source: openbsd/src games/quiz/quiz.c — random knowledge quiz (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-i+[index file]:file:_files' \
    '-t[tutorial mode]' \
    '1::category1:_default' \
    '2::category2:_default' \
    && ret=0

return ret
