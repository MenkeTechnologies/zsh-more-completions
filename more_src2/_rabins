#compdef rabins rabins2
# Documentation: https://manpages.debian.org/testing/argus-client/rabins.1.en.html
# Reference accessed: 2026-05-30
# rabins — process argus(8) records into time/count/size bins. Inherits ra(1) options.

local curcontext="$curcontext" state line ret=1

# Base ra(1) options inherited by all argus clients (subset most relevant to rabins).
local -a _ra_common
_ra_common=(
  '(- *)-h[print help]'
  '-A[print aggregate statistics for input stream on termination]'
  '-c+[delimiter character for output columns]:char:'
  '-D+[debug level to stderr (1-8)]:level:(1 2 3 4 5 6 7 8)'
  '-e+[match regex in flow user data fields]:regex:'
  '-F+[configuration file]:file:_files -g "*.conf"'
  '-H[abbreviate numeric metrics]'
  '-n[modify number-to-name conversion (4-state toggle)]'
  '-N+[process first N records]:N:'
  '-q[quiet mode]'
  '*-r+[read argus data from file]:file:_files -g "*.(argus|arg)"'
  '-R+[recursively process all files in directory]:dir:_directories'
  '*-s+[fields to print]:field:'
  '-S+[remote flow data source URI]:uri:'
  '-t+[time range for matching records]:timerange:'
  '-u[print time values using Unix time format]'
  '-X[reset all options to default values]'
  '-z[modify status field to TCP state changes]'
)

# Aggregation objects (same set as ratop).
local -a _agg_objects
_agg_objects=(
  srcid smac dmac soui doui smpls dmpls svlan dvlan
  saddr daddr matrix proto sport dport stos dtos sttl dttl
  stcpb dtcpb inode sco dco sas das ias
)

_arguments -s -S \
  $_ra_common \
  '-B+[holding time in seconds before closing a bin + outputting]:secs:' \
  '-M+[binning strategy / mode (combinable: e.g. "time hard nomodify")]:mode:(time count size hard nomodify)' \
  '*-m+[aggregation object (repeatable; combines records within bins)]:obj:('"${_agg_objects[*]}"')' \
  '-P+[sort field for output ordering (distinct from -m)]:field:' \
  '-w+[output filename (supports $field and strftime() formatting)]:file:_files' \
  '*:filter expression (BPF-style):' \
  && ret=0

return ret
