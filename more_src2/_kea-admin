#compdef kea-admin
# Documentation: https://kea.readthedocs.io/en/kea-2.6.1/man/kea-admin.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kea-admin: Kea database admin/migration tool. Corrected from prior
# file: -h is database host (with --host), -p is password (--password),
# -n --name, -d is the scripts directory (not a backend enum), added
# long options, -i input file, -V extended version, -y/--yes.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'db-init:initialize a new database schema'
  'db-version:report the database backend version number'
  'db-upgrade:conduct a database schema upgrade'
  'lease-dump:dump the lease database to a CSV file'
  'lease-upload:upload leases from a CSV file to the lease database'
  'stats-recount:recount lease statistics'
)
_arguments -C \
  '(-h --host)'{-h,--host}'[database host]:host:_hosts' \
  '(-P --port)'{-P,--port}'[database connection port]:port:' \
  '(-u --user)'{-u,--user}'[database username]:user:_users' \
  '(-p --password)'{-p,--password}'[database password]:pass:' \
  '(-n --name)'{-n,--name}'[database name]:db:' \
  '(-d --directory)'{-d,--directory}'[scripts directory override]:dir:_directories' \
  '(-i --input)'{-i,--input}'[input CSV file for lease-upload]:file:_files' \
  '(-o --output)'{-o,--output}'[output file for lease-dump]:file:_files' \
  '*'{-x,--extra}'[extra argument passed to the database tool]:opt:' \
  '-4[DHCPv4 leases]' \
  '-6[DHCPv6 leases]' \
  '(-v --version)'{-v,--version}'[display the Kea version]' \
  '-V[display the extended Kea version]' \
  '(-y --yes)'{-y,--yes}'[assume yes when overwriting temporary files]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kea-admin command' commands && ret=0 ;;
esac
return ret
