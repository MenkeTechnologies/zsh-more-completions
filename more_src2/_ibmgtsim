#compdef ibmgtsim IBMgtSim
# Documentation: https://www.unix.com/man-page/centos/1/IBMgtSim/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# IBMgtSim: InfiniBand Management Simulator.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V+[module-verb-pair list (fine-grain log verbosity)]:list:' \
  '-l+[log file]:file:_files' \
  '-p+[server port]:port:' \
  '-w+[number of threads]:num:' \
  '-f+[tcl file to source after fabric setup]:file:_files' \
  '-s+[seed for random number generation]:seed:' \
  '-t+[topology file (required)]:file:_files' && ret=0
return ret
