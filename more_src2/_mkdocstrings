#compdef mkdocstrings
# Documentation: https://mkdocstrings.github.io/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: mkdocstrings is an MkDocs plugin, not a standalone CLI;
# no canonical command-line flags exist upstream.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' && ret=0

return ret
