#compdef dbxcli
# Documentation: upstream README at github.com/dropbox/dbxcli
# Reference accessed: 2026-05-30
# Dropbox dbxcli R60 — unofficial Dropbox CLI. NOTE: latest release
# v3.0.0 (Jan 2019); upstream maintenance is sporadic.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'cp:copy files'
  'get:download a file'
  'put:upload files'
  'ls:list files'
  'mkdir:create a new directory'
  'mv:move files'
  'rm:remove files'
  'du:display usage information'
  'revs:list file revisions'
  'restore:restore files'
  'search:search files'
  'team:team management commands'
  'help:show help'
  'version:show version'
)

local -a _team_subs
_team_subs=(
  'add-member:add a new member to a team'
  'info:get team information'
  'list-groups:list groups'
  'list-members:list team members'
  'remove-member:remove member from a team'
)

_arguments -C -s -S \
  '--as-member=[perform action as specified Member ID]:member-id:' \
  '(-v --verbose)-v[verbose logging]' \
  '(-v --verbose)--verbose[verbose logging]' \
  '--help[show help]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'dbxcli subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      team)
        _arguments \
          '1:team action:(add-member info list-groups list-members remove-member)' && ret=0
        ;;
      cp|mv)
        _arguments \
          '1:source dropbox path:' \
          '2:destination dropbox path:' && ret=0
        ;;
      get)
        _arguments \
          '1:remote dropbox path:' \
          '2:local file:_files' && ret=0
        ;;
      put)
        _arguments \
          '1:local file:_files' \
          '2:remote dropbox path:' && ret=0
        ;;
      ls|du|mkdir|rm|revs|restore|search)
        _arguments \
          '*:dropbox path:' && ret=0
        ;;
    esac
    ;;
esac

return ret
