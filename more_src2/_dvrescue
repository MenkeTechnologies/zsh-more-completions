#compdef dvrescue
# Documentation: source-direct extraction from upstream
# mipops/dvrescue Source/CLI/CommandLine_Parser.cpp's
# `Parse()` argv-walking loop decoded source-direct.  dvrescue
# uses a hand-rolled `for (int i = 1; i < argc; i++)` parser
# with `!strcmp(argv_ansi[i], "--flag")` arms instead of
# getopt — so flag names are extracted from the per-arm string
# constants.
# Reference accessed: 2026-05-30 via gh api.
# MIPoPS dvrescue R206 — pivot to digital-video preservation
# tooling.  dvrescue is the MIPoPS / MediaArea tool for
# capturing DV (Digital Video) from MiniDV / HDV / DVCPRO /
# DVCAM tape via FireWire (DV-AV/C) or Blackmagic DeckLink
# capture cards, plus per-frame error detection + concealment
# + re-capture pass merging.  Used by archives (Library of
# Congress, BFI, NFSA) to digitize legacy DV tape stock.
# Sister tools to the heavily-covered video-codec family
# (ffmpeg, ffprobe, ffplay, x264, x265, mkvextract, mkvinfo,
# mkvmerge, mkvpropedit, ffmpegthumbnailer, mediainfo) already
# in the corpus.

# Closed-captions output format enum decoded source-direct from
# upstream's `ExtensionToCatpionKind()` -> "scc"/"screen"/"srt".
local -a dv_cc_format=(scc screen srt)

# DeckLink video-mode enum from upstream — abbreviated subset
# of the most-common modes (full list is ~30 modes).
local -a dv_decklink_video_modes=(
  'NTSC:NTSC 525i59.94'
  'PAL:PAL 625i50'
  'NTSCp:NTSC 525p59.94'
  'PALp:PAL 625p50'
  'HD720p50:HD 720p50'
  'HD720p5994:HD 720p59.94'
  'HD720p60:HD 720p60'
  'HD1080p2398:HD 1080p23.98'
  'HD1080p24:HD 1080p24'
  'HD1080p25:HD 1080p25'
  'HD1080p2997:HD 1080p29.97'
  'HD1080p30:HD 1080p30'
  'HD1080i50:HD 1080i50'
  'HD1080i5994:HD 1080i59.94'
  'HD1080i60:HD 1080i60'
)

# DeckLink audio-source enum.
local -a dv_decklink_audio_sources=(
  'Embedded:embedded SDI/HDMI audio'
  'AESEBU:AES/EBU audio (XLR)'
  'Analog:analog audio (RCA/balanced TRS)'
  'AnalogXLR:analog XLR (balanced)'
  'AnalogRCA:analog RCA (unbalanced)'
  'Microphone:microphone input'
)

# DeckLink timecode-format enum.
local -a dv_decklink_tc_format=(VITC RP188VITC RP188LTC RP188Any)

# Capture-mode enum.
local -a dv_modes=(
  'capture:start capture from device'
  'list:list available capture devices'
  'status:show device status'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '--version[print version and exit]' \
  '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level (0/5/7/9 or debug)]:level:(0 5 7 9 debug)' \
  '--csv[emit CSV output instead of XML]' \
  '(-x --xml-output)'{-x+,--xml-output=}'[output XML report file]:file:_files -g "*.xml"' \
  '(-s --webvtt-output)'{-s+,--webvtt-output=}'[output WebVTT subtitle file]:file:_files -g "*.vtt"' \
  '(-c --cc-output)'{-c+,--cc-output=}'[output Closed-Captions file]:file:_files' \
  '--cc-format=[Closed-Captions output format]:format:(scc screen srt)' \
  '--cc-tc=[Closed-Captions starting time-code ("dv" or HH:MM:SS;FF)]:tc:' \
  '--caption-presence-change=[emit CC presence-change events]:bool:(y n)' \
  '(--capture -capture)'{--capture,-capture}'[start DV capture from device]' \
  '(--foreground)--foreground[run in foreground (do not daemonize)]' \
  '--in-control[enable interactive control mode]' \
  '(-m --merge)'{-m+,--merge=}'[output merged DV file (multi-pass concealment)]:file:_files' \
  '--merge-log=[output merge-info log file]:file:_files' \
  '--merge-output-speed[include frames with speed-mismatch in merged output]' \
  '--merge-ignore-speed[exclude frames with speed-mismatch from merged output]' \
  '--merge-output-concealed[include concealed frames in merged output]' \
  '--merge-ignore-concealed[exclude concealed frames from merged output]' \
  '--merge-output-nodata[include nodata frames in merged output]' \
  '--merge-ignore-nodata[exclude nodata frames from merged output]' \
  '--merge-log-missing[log missing-frame ranges]' \
  '--merge-hide-missing[hide missing-frame ranges from log]' \
  '--merge-log-intermediate[log intermediate per-pass progress]' \
  '--merge-hide-intermediate[hide intermediate per-pass progress from log]' \
  '(--status -status)'{--status,-status}'[print device status snapshot]' \
  '--control=[send device-control command (play/stop/rewind/ff/pause)]:cmd:(play stop rewind ff fastforward pause)' \
  '(--device -device)'{--device+,-device+}'[capture device handle (DeckLink index or FireWire GUID)]:device:' \
  '(--cmd -cmd)'{--cmd+,-cmd+}'[shell-style device command]:cmd:' \
  '(--mode -mode)'{--mode+,-mode+}'[operating mode]:mode:->modes' \
  '(--speed -speed)'{--speed+,-speed+}'[playback speed factor (e.g. 1 0.5 -1)]:speed:' \
  '--rewind[rewind tape before capture]' \
  '--rewind-count=[number of rewind passes (for tape conditioning)]:n:' \
  '--rewind-basename=[basename for per-pass rewind output files]:basename:' \
  '--use-abst[use Absolute-Sample-based TimeCode for sync]' \
  '(--timeout -timeout)'{--timeout+,-timeout+}'[capture timeout in seconds]:sec:' \
  '--decklink-video-mode=[DeckLink video mode]:mode:->dlmodes' \
  '--decklink-video-source=[DeckLink video input source (SDI/HDMI/Component/Composite/SVideo)]:source:(SDI HDMI Component Composite SVideo OpticalSDI)' \
  '--decklink-audio-source=[DeckLink audio input source]:source:->dlaudio' \
  '--decklink-timecode-format=[DeckLink time-code source]:format:(VITC RP188VITC RP188LTC RP188Any)' \
  '*:input DV file:_files -g "*.(dv|mov|avi|mxf)"'

case $state in
  modes)    _describe -t modes 'dvrescue mode' dv_modes ;;
  dlmodes)  _describe -t dlmodes 'DeckLink video mode' dv_decklink_video_modes ;;
  dlaudio)  _describe -t dlaudio 'DeckLink audio source' dv_decklink_audio_sources ;;
esac
