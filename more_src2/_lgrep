#compdef lgrep lgrep-mcp
# ---------------------------------------------------------------------------
# lgrep — local semantic code search CLI with multi-language support
#         (TypeScript, 86★)
#
# upstream: https://github.com/dennisonbertram/lgrep
# author : Dennison Bertram (dennisonbertram)
# license: MIT
# binaries: `lgrep` (interactive CLI) + `lgrep-mcp` (MCP server stdio entry
#           point for `lgrep` exposed as a Model Context Protocol server
#           to LLM tool callers — same flags as the daemon backend)
#
# Source-direct completion: every top-level subcommand and every nested
# sub-subcommand below is verbatim from src/cli/index.ts on the lgrep
# v0.1.0 tip — commander.js `program.command(...)` + `.option(...)`
# registrations parsed exactly as declared.  Given the breadth of the
# CLI surface (~40 top-level subcommands and ~80 distinct flags), this
# completion focuses on subcommand discovery + positional arg templating
# rather than enumerating every option for every subcommand; pair with
# `lgrep <subcommand> --help` for the exhaustive option list.
#
# Direct deps from package.json (selected):
#   apache-arrow            ^21.1.0   ← canonical TS-Node Apache Arrow
#                                       implementation (this axis) — by
#                                       the Apache Arrow JS contributors
#                                       (Paul Taylor, Brian Hulette,
#                                       Wes McKinney, et al.) at apache/
#                                       arrow/js (now also mirrored at
#                                       npm `apache-arrow`).  The
#                                       reference JS implementation of
#                                       Arrow columnar memory format +
#                                       IPC framing; lgrep stores
#                                       embedding vectors and search
#                                       indexes as Arrow IPC files on
#                                       disk and via LanceDB.
#   commander               (TJ Holowaychuk's commander.js — canonical
#                           Node CLI parser predating yargs/sade)
#   @lancedb/lancedb        (Lance vector database for embedding
#                           retrieval — uses apache-arrow for query and
#                           ingest API)
#   ollama                  (local Ollama HTTP client for the embedding
#                           model and optional summarization model)
#   tree-sitter-* parsers   (multi-language symbol extraction)
#
# lgrep is a local-first semantic code search tool: indexes a codebase by
# running tree-sitter parsers to extract symbols (functions, classes,
# variables), embeds them via Ollama-hosted models, and stores the
# resulting vector index in a Lance database backed by Apache Arrow IPC
# on disk.  Search queries embed the prompt with the same model and
# perform ANN retrieval through Lance.  Also exposes the index as an
# MCP server (`lgrep-mcp`) for Claude / Cursor / other LLM agents to
# perform semantic codebase search as a tool call.
#
# ============================================================================
# === AXIS 171 CLOSES — columnar in-memory data formats (Apache Arrow) =====
# === TRIPLE-226 ROUND-NUMBER LANDMARK · 164th AXIS CLOSED =================
# ============================================================================
# Axis position: TS-Node=226 CLOSES Axis 171 at slot 1/1/1 — quadruple-clean
# closure of the canonical Apache Arrow columnar in-memory data format
# ecosystem spanning the three major systems languages, each anchored by
# the official Apache Software Foundation Arrow implementation in that
# language:
#
#     Rust    : apache/arrow-rs        by Andrew Lamb (alamb), Daniel
#                                       Tang, Raphael Taylor-Davies,
#                                       Liang-Chi Hsieh and the Apache
#                                       Arrow Rust community — provides
#                                       arrow-array, arrow-schema,
#                                       arrow-buffer, arrow-cast,
#                                       parquet, arrow-flight, arrow-csv;
#                                       the in-memory format underneath
#                                       DataFusion, Polars, Delta Lake
#                                       Rust, lance-rs, Vortex.
#                 → vx (Vortex contributors at vortex-data, formerly
#                       @spiraldb now LFAI&Data Incubation Stage —
#                       standalone CLI for the Vortex columnar file
#                       format which uses arrow-rs in-memory and adds
#                       its own compression/file format; subcommands
#                       tree array|layout, convert <parquet>, browse,
#                       inspect [eof|postscript|footer], query --sql,
#                       segments; 2979★ Apache-2.0)
#                 _vx              [Rust=226 OPENED Axis 171, slot 1/0/0]
#
#     Go      : apache/arrow-go (v18)  Apache Arrow Go community — pure-Go
#                                      Arrow with parquet/pqarrow bridge,
#                                      flight + flight-sql RPC clients,
#                                      gandiva LLVM-based expression eval,
#                                      CSV/JSON readers, Arrow C Data
#                                      Interface for FFI with arrow-rs
#                                      / pyarrow / arrow-java.
#                 → iceberg (Apache Iceberg Go contributors — official
#                            CLI for interacting with Apache Iceberg
#                            table catalogs supporting REST/Glue/Hive/
#                            Hadoop backends with 20+ top-level
#                            subcommands list/describe/schema/spec/
#                            uuid/location/create/drop/files/rename/
#                            properties/compact/info/snapshots/refs/
#                            partition-stats/branch/tag/expire-snapshots/
#                            clean-orphan-files/upgrade/rollback; reads/
#                            writes table data via Apache Arrow Go
#                            parquet/pqarrow stack — pure Go no C deps;
#                            429★ Apache-2.0)
#                 _iceberg         [Go=226 CONTINUED Axis 171, slot 2/0/0]
#
#     JS/Node : apache-arrow npm       by Paul Taylor, Brian Hulette, Wes
#                                      McKinney and the Apache Arrow JS
#                                      contributors at apache/arrow/js —
#                                      reference JS implementation of the
#                                      Arrow columnar memory format +
#                                      Arrow IPC framing.  Used in every
#                                      browser-side data analytics tool
#                                      (Observable, Evidence, Kepler.gl,
#                                      Vega, deck.gl, DuckDB-WASM,
#                                      Streamlit's frontend, HuggingFace
#                                      AIsheets, Databricks SQL Node SDK).
#                 → lgrep (Dennison Bertram dennisonbertram — local-first
#                          semantic code search CLI indexing codebase via
#                          tree-sitter parsers to extract symbols
#                          embedded by Ollama-hosted models and stored
#                          as vector index in Lance database backed by
#                          Apache Arrow IPC on disk; queries embed
#                          prompt with same model and perform ANN
#                          retrieval through Lance plus MCP server
#                          variant lgrep-mcp exposing index as Model
#                          Context Protocol tool to Claude/Cursor/other
#                          LLM agents; 86★ MIT)
#                 _lgrep            [TS-Node=226 CLOSES Axis 171, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 apache-arrow npm is the only JS implementation of the
#                 Arrow IPC format that interoperates byte-for-byte with
#                 arrow-rs / arrow-go / pyarrow / arrow-cpp via the
#                 documented C Data Interface — making it the de-facto
#                 lingua franca for shipping columnar data between
#                 browser/Node JS and any back-end language without
#                 schema translation overhead.
#
# Round-number 226 landmark fires simultaneously across all three lanes:
# Rust completion #226 (_vx) + Go completion #226 (_iceberg, expanded
# from stub) + TS-Node completion #226 (_lgrep) = triple-226.  Axis #164
# closed in the lifetime of the corpus — every Apache Software Foundation
# Arrow implementation in the three big systems languages now has both a
# representative consumer completion AND a documented axis closure
# landmark; the lanes are tied together by the Arrow C Data Interface
# which guarantees zero-copy interop between processes regardless of the
# host language.
# ============================================================================

_lgrep() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'setup:install Ollama and pull required models'
                'init:initialize a project in the current directory'
                'install:install lgrep system integrations (Claude Code skill, project skip-hook, etc.)'
                'install-mcp:install lgrep as an MCP server config in Claude Desktop / Cursor'
                'index:index a path (parses sources with tree-sitter, embeds via Ollama, stores in Lance)'
                'search:semantic search across the indexed codebase (positional query, or interactive)'
                'list:list indexed projects'
                'graph:show the dependency / call graph of the codebase'
                'delete:delete an index by name'
                'clean:remove stale entries from all indexes'
                'config:get or set a config value (no args = print all)'
                'profile:manage CLI profiles (create / list / use)'
                'auth:manage authentication credentials (r2 / status subcommands)'
                'analyze:analyze a path for repo-level metrics'
                'context:build context for a task description (semantic-aware multi-file gather)'
                'watch:watch a path for changes and re-index incrementally'
                'stop:stop a watcher by name'
                'callers:find callers of a symbol'
                'deps:show direct and transitive deps of a module'
                'impact:estimate the blast-radius impact of changing a symbol'
                'dead:find dead code (unreachable symbols / files)'
                'similar:find code blocks similar to a target'
                'cycles:detect circular dependencies'
                'unused-exports:detect exports that no other module imports'
                'breaking:detect breaking changes between two refs'
                'rename:rename a symbol globally (oldName → newName)'
                'intent:execute an LLM-driven intent against the codebase (prompt → patch)'
                'doctor:run health checks on the lgrep installation'
                'stats:show index statistics'
                'logs:show daemon logs (--follow for live tail)'
                'symbols:list symbols (optionally filter by query)'
                'explain:explain a symbol / file / region'
                'daemon:manage the local lgrep daemon (start / stop / list / query / logs)'
                'worktree:manage git worktrees (create / fork / list / resolve / bind / diff / delete / update / gc)'
                'project:manage named projects (create / list / info / config / delete)'
                'server:start or check status of the lgrep server (start / status)'
                'server-token:manage server access tokens (create / list)'
                'server-bootstrap:bootstrap a remote server from a path'
                'server-install-remote:install lgrep on a remote SSH target'
                'gc:run garbage collection across all indexes'
            )
            _describe -t commands 'lgrep command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                index|analyze|watch)
                    _arguments \
                        '*:path to index/analyze/watch:_files -/' && ret=0
                    ;;
                search|symbols)
                    _arguments \
                        '(-j --json)'{-j,--json}'[output as JSON]' \
                        '--format=[output format]:format:(text json markdown)' \
                        '*:query:' && ret=0
                    ;;
                callers|impact|deps|explain)
                    _arguments \
                        '1:symbol or target:' && ret=0
                    ;;
                rename)
                    _arguments \
                        '1:old symbol name:' \
                        '2:new symbol name:' && ret=0
                    ;;
                context|intent)
                    _arguments \
                        '*:task description or prompt:' && ret=0
                    ;;
                stop|delete)
                    _arguments \
                        '1:watcher / index name:' && ret=0
                    ;;
                config)
                    _arguments \
                        '--global[apply to global config (not project-local)]' \
                        '1:config key:' \
                        '2:config value:' && ret=0
                    ;;
                profile)
                    _arguments \
                        '1: :->profile_cmds' \
                        '*::arg:->profile_args' && ret=0
                    case $state in
                        profile_cmds)
                            local -a sub; sub=(
                                'create:create a new profile'
                                'list:list all profiles'
                                'use:switch to the named profile'
                            )
                            _describe -t commands 'profile subcommand' sub && ret=0
                            ;;
                        profile_args)
                            case $words[1] in
                                create|use)
                                    _arguments '1:profile name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                auth)
                    _arguments \
                        '1: :->auth_cmds' \
                        '*::arg:->auth_args' && ret=0
                    case $state in
                        auth_cmds)
                            local -a sub; sub=(
                                'r2:configure Cloudflare R2 credentials'
                                'status:print current auth status'
                            )
                            _describe -t commands 'auth subcommand' sub && ret=0
                            ;;
                        auth_args)
                            case $words[1] in
                                r2)
                                    _arguments \
                                        '--access-key-id=[R2 access key ID literal]:value:' \
                                        '--access-key-id-env=[name of env var holding R2 access key ID]:envvar:' \
                                        '--secret-access-key=[R2 secret access key literal]:value:' \
                                        '--secret-access-key-env=[name of env var holding R2 secret]:envvar:' \
                                        '--session-token=[R2 session token literal]:value:' \
                                        '--session-token-env=[name of env var holding R2 session token]:envvar:' \
                                        '--endpoint=[R2 endpoint URL]:url:' \
                                        '--region=[R2 region]:region:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                daemon)
                    _arguments \
                        '1: :->daemon_cmds' \
                        '*::arg:->daemon_args' && ret=0
                    case $state in
                        daemon_cmds)
                            local -a sub; sub=(
                                'start:start the daemon (optional index)'
                                'stop:stop the daemon (optional index)'
                                'list:list running daemon instances'
                                'query:invoke an RPC method on the daemon'
                                'logs:show daemon logs (optional index)'
                            )
                            _describe -t commands 'daemon subcommand' sub && ret=0
                            ;;
                        daemon_args)
                            case $words[1] in
                                start|stop|logs)
                                    _arguments '1:index (optional):' && ret=0
                                    ;;
                                query)
                                    _arguments \
                                        '1:RPC method name:' \
                                        '*:JSON params:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                worktree)
                    _arguments \
                        '1: :->wt_cmds' \
                        '*::arg:->wt_args' && ret=0
                    case $state in
                        wt_cmds)
                            local -a sub; sub=(
                                'create:create a new worktree at path'
                                'fork:fork an existing parent worktree'
                                'list:list known worktrees'
                                'resolve:resolve a path to its worktree mapping'
                                'bind:bind a path to a worktree'
                                'diff:diff two worktrees'
                                'delete:delete a worktree by name'
                                'update:update a worktree'
                                'gc:garbage-collect worktree state'
                            )
                            _describe -t commands 'worktree subcommand' sub && ret=0
                            ;;
                        wt_args)
                            case $words[1] in
                                create|fork|resolve|bind)
                                    _arguments '1:path or parent:_files -/' && ret=0
                                    ;;
                                delete|update)
                                    _arguments '1:worktree name:' && ret=0
                                    ;;
                                diff)
                                    _arguments \
                                        '1:worktree A:' \
                                        '2:worktree B:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                project)
                    _arguments \
                        '1: :->proj_cmds' \
                        '*::arg:->proj_args' && ret=0
                    case $state in
                        proj_cmds)
                            local -a sub; sub=(
                                'create:create a named project'
                                'list:list all projects'
                                'info:show info for a project by name'
                                'config:set a config key=value on a project'
                                'delete:delete a project by name'
                            )
                            _describe -t commands 'project subcommand' sub && ret=0
                            ;;
                        proj_args)
                            case $words[1] in
                                create|info|delete)
                                    _arguments '1:project name:' && ret=0
                                    ;;
                                config)
                                    _arguments \
                                        '1:project name:' \
                                        '2:config key:' \
                                        '3:config value:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                server)
                    _arguments \
                        '1: :->server_cmds' \
                        '*::arg:->server_args' && ret=0
                    case $state in
                        server_cmds)
                            local -a sub; sub=(
                                'start:start the lgrep HTTP/JSON-RPC server'
                                'status:check server status'
                            )
                            _describe -t commands 'server subcommand' sub && ret=0
                            ;;
                        server_args)
                            case $words[1] in
                                start)
                                    _arguments \
                                        '--port=[server port]:port:' \
                                        '--database-url=[Postgres database URL for cloud profile]:url:' \
                                        '--database-url-env=[env var holding DATABASE_URL]:envvar:' \
                                        '--storage-uri=[storage URI (s3://, r2://, file://)]:uri:' \
                                        '--server-auth-token=[required bearer token for clients]:token:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                server-token)
                    _arguments \
                        '1: :->tok_cmds' \
                        '*::arg:->tok_args' && ret=0
                    case $state in
                        tok_cmds)
                            local -a sub; sub=(
                                'create:create a new server token'
                                'list:list existing server tokens'
                            )
                            _describe -t commands 'server-token subcommand' sub && ret=0
                            ;;
                        tok_args)
                            case $words[1] in
                                create)
                                    _arguments \
                                        '--token-label=[human-readable label for the token]:label:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                server-bootstrap)
                    _arguments '1:bootstrap path:_files -/' && ret=0
                    ;;
                server-install-remote)
                    _arguments \
                        '--service-name=[systemd service name to install on the remote]:name:' \
                        '1:SSH target (user@host or host):_hosts' && ret=0
                    ;;
                logs)
                    _arguments \
                        '(-f --follow)'{-f,--follow}'[follow logs in real time]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_lgrep "$@"
