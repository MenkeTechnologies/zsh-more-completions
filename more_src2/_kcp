#compdef kcp
# Documentation: https://github.com/kcp-dev/kcp/blob/main/cmd/kcp/kcp.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cobra command/flag defs).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start the control plane process'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--root-directory=[directory for kcp data (default .kcp)]:dir:_files -/' \
  '--miniproxy-mapping-file=[additional miniproxy mapping file]:file:_files' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'kcp command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          'options:show all start command options:(options)' \
          '*::start arg:_default' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
