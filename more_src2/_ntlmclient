#compdef ntlmclient
# _ntlmclient — Samba ntlmclient (test client for NTLMv1/v2 authentication against a Samba/Windows DC; -U user, -W workgroup, -d debug level, -h help, -V version, -t type (LM|NTLM|NTLMv2|HMAC-MD5|HMAC-SHA1); positional argument is the target server)
# upstream: https://github.com/samba-team/samba (libcli/auth)
# Common flag shape from samba source3/utils/ntlmclient.c on tip.

_ntlmclient() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-U+[user]:user:_users' \
        '-W+[workgroup]:workgroup:' \
        '-d+[debug level]:level:' \
        '-t+[type]:type:(LM NTLM NTLMv2 HMAC-MD5 HMAC-SHA1)' \
        '1:server:_hosts'
}

_ntlmclient "$@"
