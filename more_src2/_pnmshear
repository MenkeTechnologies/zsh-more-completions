#compdef pnmshear
# Documentation: man pnmshear (Netpbm)
# Source: shear a Netpbm image by an angle.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-noantialias[disable supersampling antialiasing]' \
    '-background=[background color for newly exposed pixels]:color:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:shear angle in degrees:' \
    '2:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
