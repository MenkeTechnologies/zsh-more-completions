#compdef pcre2test
# Documentation: pcre2test --help (PCRE2)
# Source: PCRE2 test program for matching patterns against subjects.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)-unittest[run unit tests]' \
    '(-8 -16 -32)-8[use 8-bit library]' \
    '(-8 -16 -32)-16[use 16-bit library]' \
    '(-8 -16 -32)-32[use 32-bit library]' \
    '(-ac -AC)-ac[default pattern modifier PCRE2_AUTO_CALLOUT]' \
    '(-ac -AC)-AC[as -ac + subject callout_extra]' \
    '-b[default pattern modifier fullbincode]' \
    '(- *)-C-[show compile-time option(s) and exit]::arg:(backslash-C bsr ebcdic ebcdic-io ebcdic-nl25 jit jitusable linksize newline pcre2-8 pcre2-16 pcre2-32 unicode)' \
    '--color=-[colorize output]::mode:(always auto never)' \
    '--colour=-[colorize output]::mode:(always auto never)' \
    '-d[default pattern modifier debug]' \
    '-dfa[default subject modifier dfa]' \
    '-E[preprocess input only (#if/#endif)]' \
    '-error+[show messages for error numbers]:n,m,..:' \
    '-i[default pattern modifier info]' \
    '-jit[default pattern modifier jit]' \
    '-jitfast[default pattern modifier jitfast]' \
    '-jitverify[default pattern modifier jitverify]' \
    '(- *)-LM[list modifiers]' \
    '(- *)-LP[list non-script properties]' \
    '(- *)-LS[list supported scripts]' \
    '-malloc[exercise malloc failures]' \
    '-q[quiet (no version banner)]' \
    '-pattern+[default pattern modifier fields]:str:' \
    '-subject+[default subject modifier fields]:str:' \
    '-S+[stack size in MiB]:n:' \
    '(-t -tm -T -TM)-t-[time compilation+exec (repeat N times)]::n:' \
    '(-t -tm -T -TM)-tm-[time execution only]::n:' \
    '(-t -tm -T -TM)-T[same as -t with total]' \
    '(-t -tm -T -TM)-TM[same as -tm with total]' \
    '1:input file:_files' \
    '2:output file:_files' \
    && ret=0

return ret
