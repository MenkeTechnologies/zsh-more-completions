#compdef muraster
# _muraster — Artifex MuPDF muraster command-line rasterizer producing TIFF PCL PWG PCLm PostScript output from PDF/XPS/CBZ/EPUB sources with banding and color management for print pipelines (artifex team, C); custom argparse
# upstream: https://github.com/ArtifexSoftware/mupdf

_muraster() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "*.pwg *.pcl *.pclm *.ps *.tiff *.tif *.png *.pgm *.ppm *.pbm *.pnm *.tga"' \
        '-F+[output format]:f:(pwg pcl pclm ps tiff png pgm ppm pbm pnm tga)' \
        '-p+[password]:str:' \
        '-r+[resolution dpi]:n:' \
        '-R+[resolution H V]:str:' \
        '-W+[width inches]:f:' \
        '-H+[height inches]:f:' \
        '-S+[paper size]:s:(letter legal tabloid ledger executive a3 a4 a5 b3 b4 b5 jis-b3 jis-b4 jis-b5)' \
        '-T+[paper type]:t:(plain bond glossy photo)' \
        '-A+[anti-aliasing bits]:n:(0 1 2 4 8)' \
        '-G+[gamma]:f:' \
        '-I+[invert]' \
        '-N+[no anti-alias]' \
        '-c+[colorspace]:c:(gray mono rgb cmyk grayalpha rgbalpha cmykalpha)' \
        '-e+[icc profile]:file:_files -g "*.icc *.icm"' \
        '-X+[xres]:n:' \
        '-Y+[yres]:n:' \
        '-Z[no banding]' \
        '-b+[band-height pixels]:n:' \
        '-M+[max memory MB]:n:' \
        '-B+[bgcolor hex]:str:' \
        '-P+[duplex]:m:(none short-edge long-edge)' \
        '-D[debug]' \
        '*:input file:_files -g "*.pdf *.xps *.cbz *.epub *.fb2 *.svg *.png *.jpg"'
}

_muraster "$@"
