#compdef pbmtodjvurle
# Documentation: man pbmtodjvurle (Netpbm)
# Source: convert a PBM image to a DJVU RLE foreground stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    '2:djvu rle output:_files' \
    && ret=0

return ret
