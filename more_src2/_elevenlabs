#compdef elevenlabs elevenlabs-cli
# Documentation: https://github.com/elevenlabs/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_elevenlabs() {
    local line state
    local -a commands
    commands=(
        'auth:authentication commands (login, logout, whoami, residency)'
        'agents:manage voice agents (init, add, push, pull, list, status, delete, test, widget, templates, branches)'
        'tools:manage tools (add-webhook, add-client, push, pull, delete)'
        'tests:manage tests (add, push, pull, delete)'
        'components:UI components'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'elevenlabs command' commands
            ;;
        args)
            case $line[1] in
                auth)
                    _arguments '1:subcommand:(login logout whoami residency)'
                    ;;
                agents)
                    _arguments '1:subcommand:(init add push pull list status delete test widget templates branches)'
                    ;;
                tools)
                    _arguments '1:subcommand:(add-webhook add-client push pull delete)'
                    ;;
                tests)
                    _arguments '1:subcommand:(add push pull delete)'
                    ;;
                components)
                    _arguments '1:subcommand:(add)'
                    ;;
            esac
            ;;
    esac
}

_elevenlabs "$@"
