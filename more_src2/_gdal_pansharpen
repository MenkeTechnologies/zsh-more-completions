#compdef gdal_pansharpen gdal_retile gdalcompare gnmanalyse gnmmanage
# Documentation: source-direct extraction from upstream OSGeo/gdal
# swig/python/gdal-utils/osgeo_utils/{gdal_pansharpen,gdal_retile,
# gdalcompare}.py `def Usage(isError):` body `print(..., file=f)`
# blocks + apps/{gnmanalyse,gnmmanage}.cpp `Usage()` C function
# `fprintf(..., "Usage: <prog> ...")` blocks. gdalcompare uses a
# hand-rolled `for i in range(...): if argv[i] == "-X"` loop (NOT
# argparse) so the flag set was extracted by reading both the
# Usage() output AND the argv-walking elif chain.
# Reference accessed: 2026-05-30 via gh api.
# OSGeo GDAL 5-binary harvest R138 — fills the 5 GDAL utility
# binaries not previously covered (the corpus already has the
# heavy hitters: gdalinfo, gdal_translate, gdalwarp, ogr2ogr,
# gdal_grid, gdaladdo, gdalbuildvrt, gdaldem, gdal_contour,
# gdal_calc, gdal_merge, gdal_polygonize, gdal_proximity,
# gdal_sieve, gdal_viewshed, gdal_create, ogrinfo, ogrtindex,
# gdalsrsinfo, gdalmanage, gdaltransform, gdal_rasterize per
# pre-write dup-check).

# Shared (--help, --help-general, -q) base flags used by all 5
# binaries since they share GDAL's CommonArgsProc().
local -a _gdal_common_help
_gdal_common_help=(
  '--help[show help]'
  '--help-general[show GDAL general arguments help]'
)

# Shared resampling-algorithm enum from gdal_retile + gdal_pansharpen
# (-r flag values; pansharpen adds `average` to retile's 5).
local -a _gdal_resampling
_gdal_resampling=(near bilinear cubic cubicspline lanczos)

case $service in

  gdal_pansharpen)
    # Create a dataset resulting from a pansharpening operation
    # (uses a panchromatic band to enhance the spatial resolution
    # of a multispectral dataset).
    _arguments -s -S \
      "${_gdal_common_help[@]}" \
      '-of+[output format (default: based on extension)]:format:' \
      '*-b+[band number to use (repeatable for multi-band output)]:band:' \
      '*-w+[per-spectral-band weight (repeatable; one per spectral input)]:weight:' \
      '-r+[resampling algorithm]:algo:('"${_gdal_resampling[*]}"' average)' \
      '-threads+[parallel threads (ALL_CPUS or a number)]:threads:(ALL_CPUS)' \
      '-bitdepth+[output bit depth in bits]:n:' \
      '-nodata+[NODATA value to set on the output]:val:' \
      '-spat_adjust+[spatial-overlap adjustment policy]:policy:(union intersection none nonewithoutwarning)' \
      '-verbose_vrt[emit the intermediate VRT to stdout]' \
      '*-co+[output-driver creation option (NAME=VALUE; repeatable)]:NAME=VALUE:' \
      '-q[quiet operation]' \
      '1:panchromatic dataset:_files' \
      '*:spectral_dataset(,band=N)... + output dataset:_files'
    ;;

  gdal_retile)
    # Tile a (set of) raster file(s) into a directory of fixed-size
    # output tiles, optionally building lower-resolution pyramid
    # levels.
    _arguments -s -S \
      "${_gdal_common_help[@]}" \
      '-v[verbose output]' \
      '-q[quiet operation]' \
      '*-co+[creation option (NAME=VALUE; repeatable)]:NAME=VALUE:' \
      '-of+[output format]:format:' \
      '-ps+[output tile dimensions in pixels]:pixelWidth:_message :pixelHeight:' \
      '-overlap+[overlap between adjacent tiles in pixels]:val:' \
      '-ot+[output data type]:type:(Byte Int8 Int16 UInt16 UInt32 Int32 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
      '-tileIndex+[name of generated tile-index shapefile]:name:' \
      '-tileIndexField+[field name for tile-index entries]:name:' \
      '-csv+[CSV index file name]:file:_files' \
      '-csvDelim+[CSV field delimiter]:delim:' \
      '-s_srs+[source SRS]:srs_def:' \
      '-pyramidOnly[generate ONLY the pyramid levels (no base-resolution tiles)]' \
      '-levels+[number of pyramid levels (required)]:n:' \
      '-r+[resampling algorithm]:algo:('"${_gdal_resampling[*]}"')' \
      '-useDirForEachRow[create a subdirectory per row of tiles]' \
      '-resume[skip tiles that already exist on disk]' \
      '-targetDir+[output tile directory (required)]:dir:_directories' \
      '*:input raster file(s):_files'
    ;;

  gdalcompare)
    # Compare two GDAL datasets and print a list of differences
    # (intended for regression testing of GDAL drivers).
    _arguments -s -S \
      "${_gdal_common_help[@]}" \
      '-dumpdiffs[dump the actual pixel differences (in addition to the count)]' \
      '-skip_binary[skip binary pixel-data comparison]' \
      '-skip_overviews[skip overview comparison]' \
      '-skip_geolocation[skip geolocation array comparison]' \
      '-skip_geotransform[skip geotransform comparison]' \
      '-skip_metadata[skip metadata comparison]' \
      '-skip_rpc[skip RPC comparison]' \
      '-skip_srs[skip SRS comparison]' \
      '-sds[also compare subdatasets]' \
      '1:golden (reference) file:_files' \
      '2:new file to test:_files'
    ;;

  gnmanalyse)
    # Geographic Network Model (GNM) network-analysis utility:
    # shortest-path / k-shortest-paths / resource analysis on a
    # network dataset.
    _arguments -s -S \
      "${_gdal_common_help[@]}" \
      '-q[quiet operation]' \
      '-quiet[quiet operation (synonym for -q)]' \
      '--long-usage[show full help with per-subcommand detail]' \
      '-ds+[output dataset name]:ds_name:' \
      '-f+[output dataset format]:format:' \
      '-l+[output layer name]:layer:' \
      '*-dsco+[dataset-creation option]:NAME=VALUE:' \
      '*-lco+[layer-creation option]:NAME=VALUE:' \
      '1:operation:(dijkstra kpaths resource)' \
      '*:operation-arguments + <gnm_name>:_files'
    ;;

  gnmmanage)
    # GNM network management utility: create / import / connect /
    # disconnect / rule / autoconnect / delete / change a network
    # dataset.
    _arguments -s -S \
      "${_gdal_common_help[@]}" \
      '-q[quiet operation]' \
      '-quiet[quiet operation (synonym for -q)]' \
      '--long-usage[show full help with per-subcommand detail]' \
      '-f+[output format (used with `create`)]:format:' \
      '-t_srs+[target SRS (used with `create`)]:srs_name:' \
      '*-dsco+[dataset-creation option (used with `create`)]:NAME=VALUE:' \
      '-l+[layer name (used with `import`)]:layer:' \
      '-c+[edge cost (used with `connect`)]:cost:' \
      '-ic+[inverse cost (used with `connect`)]:inv_cost:' \
      '-dir+[direction (used with `connect`)]:dir:' \
      '-bl+[block gfid (used with `change`)]:gfid:' \
      '-unbl+[unblock gfid (used with `change`)]:gfid:' \
      '-unblall[unblock all (used with `change`)]' \
      '1:operation:(info create import connect disconnect rule autoconnect delete change)' \
      '*:operation-arguments + <gnm_name> [<layer>...]:_files'
    ;;

esac
