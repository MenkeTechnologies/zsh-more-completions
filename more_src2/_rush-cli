# _rush-cli — Wei Shen shenwei356 rush-cli CLI command-line frontend wrapping the rush parallel command execution tool similar to GNU parallel xargs awesome-line-based-text-Excel-style-stdin-jobs open-source written in Go fast-CSV-TSV column-based-input multi-line-records partial-restart-on-failure exit-on-error continue-on-error grouping-jobs by-batch-by-line-count temporary-output-to-stderr buffer-size dry-run keep-order trim-input quote-output (Wei Shen shenwei356 team, Go); cobra
# upstream: https://github.com/shenwei356/rush

_rush-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[input file]:file:_files' \
        '*-i+[input file]:file:_files' \
        '--infile=+[file]:file:_files' \
        '-j+[jobs]:n:' \
        '--jobs=+[N]:n:' \
        '-n+[chunks]:n:' \
        '--chunks=+[N]:n:' \
        '-r+[range]:str:' \
        '--records=+[range]:str:' \
        '-c+[continue on error]' \
        '--continue[continue on error]' \
        '-C+[stop on error]' \
        '--stop-on-error[stop on error]' \
        '-d+[delimiter]:str:' \
        '--field-delimiter=+[d]:str:' \
        '-D+[record delimiter]:str:' \
        '--record-delimiter=+[d]:str:' \
        '-T+[trim]:t:(s e b n)' \
        '--trim=+[t]:t:(s e b n)' \
        '-k[keep order]' \
        '--keep-order[keep order]' \
        '-e+[escape]:str:' \
        '--escape=+[c]:str:' \
        '-q+[quote]:str:' \
        '--quote=+[c]:str:' \
        '--immediate-output[immediate output]' \
        '--dry-run[dry run]' \
        '--no-stop-exit[no stop exit]' \
        '-t+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-Z+[Records pipe-out file]:file:_files' \
        '--records-pipe-out=+[file]:file:_files' \
        '-o+[output]:file:_files' \
        '--out-file=+[file]:file:_files' \
        '-s+[fields separator]:str:' \
        '--field-separator=+[c]:str:' \
        '--eval[eval expressions]' \
        '--propagate-exit-status[propagate exit]' \
        '*:command:_command_names'
}

_rush-cli "$@"
