#compdef pvecm
# Documentation: https://pve.proxmox.com/pve-docs/pvecm.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pvecm - Proxmox VE cluster manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new cluster'
  'add:add current node to an existing cluster'
  'addnode:add a node by hostname (internal)'
  'delnode:delete a node from the cluster'
  'status:show cluster status'
  'nodes:show cluster nodes'
  'expected:set expected votes'
  'updatecerts:update node certificates'
  'keygen:generate a corosync key'
  'apiver:show cluster join API version'
  'mtunnel:internal migration tunnel'
  'qdevice:configure external QDevice'
  'help:show help'
)

_arguments -s -S \
  '1:command:->command' \
  '(- *)'{-h,--help}'[show help]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pvecm command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (create)
        _arguments -s -S \
          '1:cluster name' \
          '--nodeid=[node id]:id' \
          '--votes=[number of votes]:count' \
          '--token-coefficient=[token coefficient]:ms' \
          '*--link=[corosync link]:config' && ret=0
        ;;
      (add)
        _arguments -s -S \
          '1:hostname or IP' \
          '--nodeid=[node id]:id' \
          '--votes=[number of votes]:count' \
          '--fingerprint=[certificate fingerprint]:fingerprint' \
          '--force[force operation]' \
          '--use_ssh[use SSH for join]' \
          '*--link=[corosync link]:config' && ret=0
        ;;
      (addnode)
        _arguments -s -S \
          '1:node name' \
          '--apiversion=[API version]:n' \
          '--force[force operation]' \
          '--new_node_ip=[new node IP]:ip' \
          '--nodeid=[node id]:id' \
          '--votes=[number of votes]:count' \
          '*--link=[corosync link]:config' && ret=0
        ;;
      (delnode)
        _arguments -s -S '1:node name' && ret=0
        ;;
      (expected)
        _arguments -s -S '1:expected votes:' && ret=0
        ;;
      (updatecerts)
        _arguments -s -S \
          '--force[force operation]' \
          '--silent[suppress output]' \
          '--unmerge-known-hosts[unmerge known_hosts file]' && ret=0
        ;;
      (keygen)
        _arguments -s -S '1:output file:_files' && ret=0
        ;;
      (qdevice)
        _arguments -s -S '1:subcommand:(setup remove)' '*::arg:_default' && ret=0
        ;;
      (status|nodes|apiver|mtunnel)
        _arguments -s -S && ret=0
        ;;
    esac
    ;;
esac

return ret
