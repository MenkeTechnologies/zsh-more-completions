#compdef marun
# Documentation: https://github.com/huggingface/microagent
# Reference accessed: 2026-05-23
# Verified: marun --help (microagent PyPI console script).

# Zsh completion for marun - run Hugging Face microagent modules

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:module path:_files' && ret=0

return ret
