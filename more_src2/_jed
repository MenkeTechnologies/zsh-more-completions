#compdef jed jed-script xjed
# Documentation: https://raw.githubusercontent.com/hankem/jed/master/doc/manual/jed.tex
# Reference accessed: 2026-05-19
# Verified: jed manual "Starting JED" section + systutorials jed(1).
# Removed invented --help/--version/--secure/--script/'+' switches.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-batch[run JED in batch (non-interactive) mode]' \
  '-n[do not load jed.rc (.jedrc) file]' \
  '-a+[load file as user configuration file instead of .jedrc]:file:_files' \
  '-2[split window]' \
  '-i+[insert file into current buffer]:file:_files' \
  '-l+[load file as S-Lang code]:file:_files' \
  '-f+[execute S-Lang function named function]:function:' \
  '-g+[goto line n in buffer]:n:' \
  '-s+[search forward for string]:string:' \
  '*: :_files' && ret=0

return ret
