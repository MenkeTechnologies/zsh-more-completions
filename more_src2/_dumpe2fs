#compdef dumpe2fs
# _dumpe2fs — dump ext2/3/4 filesystem metadata (e2fsprogs); superblock + group descriptors + journal info
# upstream: https://github.com/tytso/e2fsprogs

_dumpe2fs() {
    _arguments \
        '-b[print bad blocks]' \
        '-h[print superblock only (no group info)]' \
        '-i[image file mode]' \
        '-f[force]' \
        '-V[show version]' \
        '-x[extra info]' \
        '-o+[superblock]:n:' \
        '-O+[options]:opts:' \
        '*:device:_files'
}

_dumpe2fs "$@"
