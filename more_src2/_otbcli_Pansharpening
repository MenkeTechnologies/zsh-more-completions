#compdef otbcli_Pansharpening
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Pansharpening.html
# Source: orfeotoolbox/OTB Pansharpening — fuse high-res panchromatic with multispectral via RCS/LMVM/Bayes.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-inp+[panchromatic input image]:image:_files' \
    '-inxs+[multispectral input image]:image:_files' \
    '-out+[pan-sharpened output]:image:_files' \
    '-method+[pansharpening method]:method:(rcs lmvm bayes)' \
    '-method.rcs.radiusx+[RCS horizontal window radius (default 9)]:n:_default' \
    '-method.rcs.radiusy+[RCS vertical window radius (default 9)]:n:_default' \
    '-method.lmvm.radiusx+[LMVM horizontal window radius (default 3)]:n:_default' \
    '-method.lmvm.radiusy+[LMVM vertical window radius (default 3)]:n:_default' \
    '-method.bayes.lambda+[Bayes weighting lambda (default 0.9999)]:value:_default' \
    '-method.bayes.s+[Bayes S coefficient (default 1)]:value:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
