#compdef nvidia-mig-manager
# _nvidia-mig-manager — Kubernetes-side MIG reconfiguration controller (watches the nvidia.com/mig.config node label and runs the reconfigure script)
# upstream: https://github.com/NVIDIA/mig-parted
# Flags from cmd/nvidia-mig-manager/main.go on tip (urfave/cli/v3).

_nvidia-mig-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--kubeconfig=[absolute path to the kubeconfig file]:file:_files' \
        '(-n --node-name)'{-n,--node-name}'=[node to watch for label changes]:name:' \
        '(-f --config-file)'{-f,--config-file}'=[path to the MIG parted configuration file]:file:_files' \
        '(-s --reconfigure-script)'{-s,--reconfigure-script}'=[script that performs the MIG reconfiguration]:file:_files' \
        '(-m --host-root-mount)'{-m,--host-root-mount}'=[container path where host root is mounted]:dir:_files -/' \
        '(-i --host-nvidia-dir)'{-i,--host-nvidia-dir}'=[host path of NVIDIA managed software dir]:dir:_files -/' \
        '(-o --host-mig-manager-state-file)'{-o,--host-mig-manager-state-file}'=[host path of mig-manager systemd state file]:file:_files' \
        '(-k --host-kubelet-systemd-service)'{-k,--host-kubelet-systemd-service}'=[host kubelet systemd service to restart]:svc:' \
        '(-g --gpu-clients-file)'{-g,--gpu-clients-file}'=[file listing GPU clients to shutdown across reconfig]:file:_files' \
        '(-r --with-reboot)'{-r,--with-reboot}'[reboot the node on reconfig failure]' \
        '(-d --with-shutdown-host-gpu-clients)'{-d,--with-shutdown-host-gpu-clients}'[shutdown/restart host GPU clients across reconfig]' \
        '(-p --default-gpu-clients-namespace)'{-p,--default-gpu-clients-namespace}'=[default namespace for GPU client pods]:ns:' \
        '(-t --nvidia-driver-root --driver-root)'{-t,--nvidia-driver-root,--driver-root}'=[host root path of NVIDIA driver install]:dir:_files -/' \
        '(-a --driver-root-ctr-path)'{-a,--driver-root-ctr-path}'=[container path of NVIDIA driver install]:dir:_files -/' \
        '--cdi-enabled[enable CDI support]' \
        '(-b --dev-root)'{-b,--dev-root}'=[host root path of NVIDIA device nodes]:dir:_files -/' \
        '(-j --dev-root-ctr-path)'{-j,--dev-root-ctr-path}'=[container path of NVIDIA device nodes]:dir:_files -/' \
        '--nvidia-cdi-hook-path=[path to nvidia-cdi-hook binary on the host]:file:_files'
}

_nvidia-mig-manager "$@"
