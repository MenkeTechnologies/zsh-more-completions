#compdef drumstick-metronome
# _drumstick-metronome — ALSA-sequencer MIDI metronome (pedrolcl/drumstick)
# upstream: https://github.com/pedrolcl/drumstick
# Flags from utils/metronome/metronome.cpp (QCommandLineParser).

_drumstick-metronome() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-p --port)'{-p+,--port=}'[destination MIDI port (client:port)]:port:' \
        '(-b --bpm)'{-b+,--bpm=}'[tempo in beats per minute (default 120)]:bpm:'
}

_drumstick-metronome "$@"
