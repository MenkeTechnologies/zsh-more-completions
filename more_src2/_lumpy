#compdef lumpy lumpyexpress
# _lumpy — Ryan Layer Aaron Quinlan lumpy CLI probabilistic structural variant caller integrating multiple SV signals split-read discordant-pair paired-end coverage-depth read-depth Bayesian model producing VCF for deletions duplications inversions translocations across human bacterial population WGS samples (Ryan Layer team, C++); getopt
# upstream: https://github.com/arq5x/lumpy-sv

_lumpy() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-e[show evidence detail]' \
        '-t+[temp dir]:dir:_files -/' \
        '-tt+[trim threshold]:n:' \
        '-mw+[min weight]:n:' \
        '-msw+[min sample weight]:n:' \
        '-pe+[bam,id=,read_group=,histo_file=,mean=,stdev=,read_length=,min_non_overlap=,discordant_z=,back_distance=,weight=,min_mapping_threshold=]:str:' \
        '-sr+[bam,id=,back_distance=,weight=,min_mapping_threshold=]:str:' \
        '-bedpe+[bed file]:file:_files -g "*.bedpe"' \
        '-x+[exclude regions]:file:_files -g "*.bed *.bed.gz"' \
        '-o+[output file]:file:_files -g "*.vcf *.bedpe"' \
        '*::'
}

_lumpy "$@"
