#compdef dead
# _dead — dead Python code finder (asottile/dead)
# upstream: https://github.com/asottile/dead
# Flags from dead.py (argparse).

_dead() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--files=[regex for file inclusion]:regex:' \
        '--exclude=[regex for file exclusion]:regex:' \
        '--tests=[regex marking test files]:regex:' \
        '--track-args[track argument usage of "self"]' \
        '--symbol-allowlist=[file containing allowed unused symbols]:file:_files'
}

_dead "$@"
