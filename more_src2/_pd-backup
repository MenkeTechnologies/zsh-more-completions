#compdef pd-backup
# _pd-backup — TiKV PD cluster metadata backup helper (JSON export)
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-backup/main.go on tip.

_pd-backup() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-pd=[PD address]:url:_urls' \
        '-file=[backup JSON file path]:file:_files' \
        '-cacert=[trusted CA cert file (PEM)]:file:_files' \
        '-cert=[client X509 cert file (PEM)]:file:_files' \
        '-key=[client X509 key file (PEM)]:file:_files'
}

_pd-backup "$@"
