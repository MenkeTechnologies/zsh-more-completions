#compdef openttd
# Documentation: https://manpages.debian.org/bookworm/openttd/openttd.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm openttd(6) manpage / upstream OpenTTD/OpenTTD
# src/openttd.cpp ParseCommandLine().
# Removed from prior file: bogus man.archlinux.org search URL;
# duplicate -v definition (real openttd has only -v as video driver,
# not version); fabricated -X autosave flag and -Z flag.

# openttd: Open Transport Tycoon Deluxe
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-b[blitter]:blitter:' \
  '-c[alternative config file]:file:_files -g "*.cfg(-.)"' \
  '-D[start dedicated server]:bind\:port:' \
  '-d[debug categories=level,...]:cats:' \
  '-f[do not fork dedicated server to background]' \
  '-g[load saved game on startup]:file:_files -g "*.(sav|scn|hgr)(-.)"' \
  '-G[set random seed]:seed:' \
  '-I[set GraphicsSet (override config)]:gfx:' \
  '-l[redirect debug output to host:port]:host\:port:' \
  '-m[music driver]:driver:' \
  '-M[music volume 0-127]:vol:' \
  '-n[start client and connect to host:port[#company]]:host\:port:' \
  '-p[network server password]:pw:' \
  '-P[network company password]:pw:' \
  '-q[query NewGRF file]:file:_files -g "*.grf(-.)"' \
  '-Q[batch NewGRF query mode]' \
  '-r[set resolution WIDTHxHEIGHT]:WxH:' \
  '-s[sound driver]:driver:' \
  '-S[sound set]:set:' \
  '-t[start in given year]:year:' \
  '-v[video driver]:driver:(opengl sdl null dedicated allegro cocoa win32)' \
  '-x[do not write back modified config]' \
  '-Y[base music set]:set:' && ret=0
return ret
