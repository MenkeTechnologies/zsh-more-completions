#compdef gh-fzf
# Documentation: https://github.com/benelan/gh-fzf
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_gh-fzf() {
    local -a commands
    commands=(
        'issue:Fuzzy find issues'
        'pr:Fuzzy find pull requests'
        'repo:Fuzzy find repositories'
    )
    _arguments \
        '1: :->command' \
        '*: :_files'
}

_gh-fzf "$@"
