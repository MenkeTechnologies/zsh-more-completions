#compdef rpicam-hello
# _rpicam-hello — Raspberry Pi Foundation rpicam-hello successor to libcamera-hello CLI for displaying a preview window from a connected Raspberry Pi camera module testing libcamera stack readiness camera enumeration tuning-file (raspberrypi team, C++); boost program_options
# upstream: https://github.com/raspberrypi/rpicam-apps

_rpicam-hello() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[timeout ms]:n:' \
        '--timeout=+[timeout ms]:n:' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--rotation=+[deg]:n:(0 90 180 270)' \
        '--hflip[horizontal flip]' \
        '--vflip[vertical flip]' \
        '--gain=+[F]:f:' \
        '--shutter=+[us]:n:' \
        '--awb=+[mode]:m:(auto incandescent tungsten fluorescent indoor daylight cloudy custom)' \
        '--exposure=+[mode]:m:(normal short long custom)' \
        '--ev=+[F]:f:' \
        '--metering=+[mode]:m:(centre spot average matrix custom)' \
        '--saturation=+[F]:f:' \
        '--sharpness=+[F]:f:' \
        '--contrast=+[F]:f:' \
        '--brightness=+[F]:f:' \
        '--denoise=+[mode]:m:(off cdn_off cdn_fast cdn_hq auto)' \
        '--tuning-file=+[file]:file:_files -g "*.json"' \
        '--info-text=+[text]:str:' \
        '--camera=+[index]:n:' \
        '--list-cameras[list cameras]' \
        '--qt-preview[use Qt preview]' \
        '--preview=+[x,y,w,h]:str:' \
        '-p+[x,y,w,h]:str:' \
        '--fullscreen[fullscreen]' \
        '-f[fullscreen]' \
        '--mode=+[N:N:fmt:packing]:str:' \
        '--autofocus-mode=+[mode]:m:(manual auto continuous)' \
        '--autofocus-range=+[range]:r:(normal macro full)'
}

_rpicam-hello "$@"
