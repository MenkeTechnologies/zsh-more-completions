#compdef drush-launcher
# _drush-launcher — drush-ops drush launcher CLI alias (drush team, PHP); symfony console
# upstream: https://github.com/drush-ops/drush-launcher

_drush-launcher() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--root=+[drupal root]:dir:_files -/' \
        '-r+[drupal root]:dir:_files -/' \
        '--uri=+[uri]:url:_urls' \
        '-l+[uri]:url:_urls' \
        '--include=+[command path]:dir:_files -/' \
        '-i+[command path]:dir:_files -/' \
        '--config=+[config]:dir:_files -/' \
        '-c+[config]:dir:_files -/' \
        '--alias-path=+[alias path]:dir:_files -/' \
        '--define=+[define]:str:' \
        '-D+[define]:str:' \
        '--local[force local launcher]' \
        '--strict=+[strict]:n:' \
        '*:command:'
}

_drush-launcher "$@"
