#compdef git-recent
# Documentation: https://github.com/paulirish/git-recent
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# paulirish/git-recent v2.0+ is an interactive fzf UI with no flags;
# the legacy git-recent-og binary accepts -n<int>.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-n+[show the most recent N branches (legacy git-recent-og)]:count:' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0

return ret
