#compdef fontmatrix
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/fontmatrix.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-l --lang)'{-l,--lang}'[override system locale]:lang code:' \
  '(-la --langs-available)'{-la,--langs-available}'[list available UI translations]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[open specified file]:font file:_files -g "*.{ttf,otf,pfb,pfa,ttc}"' \
  '(-ns --no-splash)'{-ns,--no-splash}'[suppress splash screen]' \
  '*:font file:_files -g "*.{ttf,otf,pfb,pfa,ttc}"' && ret=0

return ret
