# Rican7/define — pflag (define.go, internal/action, internal/config)
_arguments -s -S \
  '--print-config[dump JSON configuration]' \
  '--debug-config[show which config files were loaded]' \
  '--list-sources[list dictionary providers]' \
  '--version[show version]' \
  '(-c --config-file)'{-c,--config-file}'=-[config file path]:file:_files' \
  '--no-config-file[skip all config files]' \
  '--indent-size=-[spaces to indent output]:n:' \
  '--preferred-source=-[default provider key]:source:' \
  '(-s --source)'{-s,--source}'=-[force provider key]:source:' \
  '*:word to define:_default'
