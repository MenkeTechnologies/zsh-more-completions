#compdef imgp
# Documentation: https://github.com/jarun/imgp
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# imgp: multi-core batch image resizer / rotator.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-x --res)'{-x,--res}'=[output resolution HxV / percent / megapixel (MP suffix)]:resolution:' \
  '(-o --rotate)'{-o,--rotate}'=[rotate clockwise by angle in degrees]:angle:' \
  '(-a --adapt)'{-a,--adapt}'[adapt to resolution by orientation]' \
  '(-c --convert)'{-c,--convert}'[convert PNG to JPG]' \
  '(-e --eraseexif)'{-e,--eraseexif}'[erase exif metadata]' \
  '(-f --force)'{-f,--force}'[force exact specified resolution]' \
  '(-H --hidden)'{-H,--hidden}'[include hidden (dot) files]' \
  '(-i --includeimgp)'{-i,--includeimgp}'[re-process _IMGP files]' \
  '(-k --keep)'{-k,--keep}'=[skip images matching dimensions]:WxH:' \
  '(-m --mute)'{-m,--mute}'[operate silently]' \
  '(-M --minres)'{-M,--minres}'=[minimum resolution to process]:WxH:' \
  '(-n --enlarge)'{-n,--enlarge}'[enlarge smaller images]' \
  '(-N --nearest)'{-N,--nearest}'[use nearest neighbor interpolation for PNG]' \
  '(-O --optimize)'{-O,--optimize}'[optimize the output images]' \
  '(-P --progressive)'{-P,--progressive}'[save JPEG images as progressive]' \
  '(-q --quality)'{-q,--quality}'=[quality factor 1-95 (JPEG only)]:quality:' \
  '(-r --recurse)'{-r,--recurse}'[process non-symbolic dirs recursively]' \
  '(-s --size)'{-s,--size}'=[minimum size in bytes to process]:bytes:' \
  '(-w --overwrite)'{-w,--overwrite}'[overwrite source images]' \
  '(-d --debug)'{-d,--debug}'[enable debug logs]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:image file or directory:_files' && ret=0

return ret
