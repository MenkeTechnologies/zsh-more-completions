#compdef genact
# Documentation: https://github.com/svenstaro/genact
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for genact (pretend activity generator)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-l --list-modules)'{-l,--list-modules}'[list available modules]' \
  '*'{-m+,--modules=}'[run specific modules only]:module:(ansible bootlog botnet bruteforce cargo cc composer cryptomining docker_build docker_image_rm download julia kernel_compile memdump mkinitcpio rkhunter simcity terraform uv weblog wpt)' \
  '(-s --speed-factor)'{-s+,--speed-factor=}'[set speed multiplier]:speed:' \
  '(-i --instant-print-lines)'{-i+,--instant-print-lines=}'[instantly print N lines]:lines:' \
  '--exit-after-modules=[exit after N modules]:n:' \
  '--exit-after-time=[exit after specified duration (e.g. 5m)]:duration:' \
  '--print-completions=[print shell completions]:shell:(bash fish zsh powershell elvish)' \
  '--print-manpage[print man page]' && return 0
