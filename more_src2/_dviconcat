#compdef dviconcat
# Documentation: man dviconcat(1) (TeX Live, MC-TeX)
# Source: TeX dviconcat — concatenate DVI files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m+[output magnification]:mag:' \
    '-o+[output file (default stdout)]:file:_files' \
    '*:DVI file:_files -g "*.dvi"' \
    && ret=0

return ret
