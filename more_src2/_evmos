#compdef evmos evmosd
# _evmos — Evmos Foundation evmosd Cosmos-SDK + EVM hybrid daemon for the Evmos chain bridging Ethereum compatible smart contracts and IBC (evmos team, Go); cobra
# upstream: https://github.com/evmos/evmos

_evmos() {
    local -a sub=(
        'init:init node'
        'start:start node'
        'status:show status'
        'tendermint:tendermint commands'
        'comet:comet commands'
        'export:export state'
        'rollback:rollback state'
        'query:query state'
        'tx:transaction operations'
        'keys:key management'
        'add-genesis-account:add genesis account'
        'gentx:generate genesis tx'
        'collect-gentxs:collect gentxs'
        'validate-genesis:validate genesis'
        'snapshots:snapshot operations'
        'config:config operations'
        'debug:debug operations'
        'rosetta:rosetta server'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--home=+[dir]:dir:_files -/' \
        '--keyring-backend=+[backend]:b:(os file kwallet pass test memory)' \
        '--keyring-dir=+[dir]:dir:_files -/' \
        '--chain-id=+[id]:str:' \
        '--node=+[url]:str:' \
        '--output=+[fmt]:f:(text json)' \
        '-o+[fmt]:f:(text json)' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)' \
        '--log-format=+[fmt]:f:(plain json)' \
        '--trace[stack trace on error]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'evmos subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--moniker=+[name]:str:' \
                    '--p2p.laddr=+[addr]:str:' \
                    '--rpc.laddr=+[addr]:str:' \
                    '--grpc.address=+[addr]:str:' \
                    '--api.address=+[addr]:str:' \
                    '--json-rpc.address=+[addr]:str:' \
                    '--json-rpc.ws-address=+[addr]:str:' \
                    '--json-rpc.api=+[apis]:str:' \
                    '--minimum-gas-prices=+[gas]:str:' \
                    '--pruning=+[mode]:m:(default nothing everything custom)' \
                    '--state-sync.snapshot-interval=+[N]:n:' \
                    '--state-sync.snapshot-keep-recent=+[N]:n:' \
                    '--unsafe-skip-upgrades=+[N]:n:' \
                    '--halt-height=+[N]:n:' \
                    '--halt-time=+[unix]:n:' \
                    '--inter-block-cache[inter-block cache]' \
                    '--trace-store=+[file]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_evmos "$@"
