#compdef parpar
# ============================================================================
# parpar - high-performance multi-threaded PAR2
#          creation client (Node.js + native C++ with
#          SIMD-accelerated Reed-Solomon GF(2^16))
#          (CC0-1.0)
#
# Author : Anime Tosho (animetosho)
# Upstream: https://github.com/animetosho/ParPar
# npm    : @animetosho/parpar (binary: parpar /
#           parpar.cmd on Windows)
# Homepage: https://animetosho.org/app/parpar
#
# `parpar` is a high-performance PAR2 (Parchive 2.0)
# parity-archive creation tool. PAR2 is the
# Usenet/binary-newsgroup community's standard
# error-correction format for recovering missing
# or corrupted file pieces during transmission.
#
# PAR2 mathematical foundation: Reed-Solomon
# erasure coding over GF(2^16) (Galois field of
# 65536 elements). Input files are split into
# fixed-size slices; recovery slices are computed
# as linear combinations of the input slices over
# the Galois field. Any K-of-N surviving slices
# (where K = input slice count, N = K +
# recovery_slice_count) can reconstruct the
# original data.
#
# ParPar's distinguishing position vs other PAR2
# tools (par2cmdline, par2cmdline-turbo, MultiPar,
# par2j):
#   - Multi-threaded scalable to many cores
#   - SIMD-accelerated GF(2^16) multiplication via
#     auto-generated assembly:
#     - x86_64: SSE2/SSSE3/AVX/AVX2/AVX512BW/
#       AVX512VBMI/GFNI/AVX10
#     - ARMv7/AArch64: NEON/SVE/SVE2
#     - RISC-V: RVV/Zvbc/Zbc/Zbkc
#   - JIT-compiled XOR-dependency variants
#     (xor-sse, xorjit-sse, xorjit-avx2,
#     xorjit-avx512)
#   - OpenCL GPU offload (experimental)
#   - Multiple GF multiplication strategies
#     selectable via `--method` (lookup,
#     shuffle, affine, clmul, etc.)
#
# Use cases:
#   - Generating PAR2 recovery files for Usenet
#     binary uploads
#   - Bulk-archive parity for cold storage backups
#   - Anti-bit-rot file insurance for long-term
#     archival
#   - Optical-media redundancy (Blu-ray
#     archival without disk-level dvdisaster
#     formatting)
#
# Usage:
#   parpar -s <slice_size/count> \
#           -o <output> [options] [--] <input>...
#
# Most commonly used flags (truncated; see
# `parpar --help-full` for full set):
#
# PAR2 Options:
#   -s, --input-slices <n|size>      - input slice
#                                       size or
#                                       count
#                                       (REQUIRED)
#   -S, --auto-slice-size            - auto-scale
#                                       slice size
#                                       if count
#                                       would
#                                       exceed max
#   -r, --recovery-slices <n|%|size> - number of
#                                       recovery
#                                       slices to
#                                       generate
#       --min-input-slices <v>       - auto-scale
#                                       minimum
#                                       slice
#                                       count
#       --max-input-slices <v>       - auto-scale
#                                       maximum
#                                       slice
#                                       count
#       --slice-size-multiple <v>    - slice size
#                                       multiple
#                                       constraint
#       --min-recovery-slices <v>    - auto-scale
#                                       min recovery
#                                       slice count
#       --max-recovery-slices <v>    - auto-scale
#                                       max recovery
#                                       slice count
#   -e, --recovery-offset <n>        - recovery
#                                       slice start
#                                       offset
#       --recovery-exponents <list>  - exact
#                                       recovery
#                                       exponents
#                                       (CSV)
#   -c, --comment <text>             - PAR2 comment
#                                       (multi)
#       --packet-redundancy <v>      - critical
#                                       packet copy
#                                       count
#       --min-packet-redundancy <n>  - min critical
#                                       packet
#                                       copies
#       --max-packet-redundancy <n>  - max critical
#                                       packet
#                                       copies
#   -f, --filepath-format <fmt>      - path format
#                                       (basename/
#                                       keep/common/
#                                       outrel/path)
#   -B, --filepath-base <dir>        - base path for
#                                       `path`
#                                       format
#       --unicode | --no-unicode     - force
#                                       unicode
#                                       packets on/
#                                       off
#       --ascii-charset <name>       - charset for
#                                       ASCII
#                                       packets
#
# Output Options:
#   -o, --out <file>                 - base PAR2
#                                       file name
#                                       (REQUIRED)
#   -O, --overwrite                  - overwrite
#                                       existing
#                                       files
#       --write-sync                 - fsync written
#                                       files before
#                                       exit
#   -n, --std-naming                 - use standard
#                                       PAR2 naming
#                                       (xxx.vol12-22.par2)
#   -d, --slice-dist <equal|uniform|pow2>
#                                    - slice
#                                       distribution
#                                       across
#                                       files
#   -p, --slices-per-file <v>        - max slices
#                                       per file
#                                       (default
#                                       65535)
#       --slices-first-file <v>      - slice count
#                                       for first
#                                       recovery
#                                       file
#   -F, --recovery-files <n>         - recovery
#                                       volume file
#                                       count
#       --noindex                    - skip index
#                                       file
#                                       generation
#
# I/O Tuning Options:
#       --min-chunk-size <size>      - minimum
#                                       chunking
#                                       size
#                                       (default
#                                       128K)
#       --seq-read-size <size>       - max sequential
#                                       read buffer
#                                       (default 4M)
#       --chunk-read-threads <n>     - max concurrent
#                                       read
#                                       requests
#       --read-buffers <n>           - max read
#                                       buffers
#                                       (default 8)
#       --seq-read-throttle <spec>   - throttle
#                                       sequential
#                                       read speed
#       --chunk-read-throttle <spec> - throttle
#                                       chunked
#                                       read speed
#       --read-hash-queue <n>        - read buffers
#                                       to queue
#                                       for hashing
#       --md5-batch-size <n>         - recovery
#                                       slice batch
#                                       size for
#                                       hashing
#       --recovery-buffers <n>       - recovery
#                                       slices to
#                                       buffer
#       --hash-method <method>       - hashing
#                                       algorithm
#                                       (scalar/
#                                       simd/crc/
#                                       simd-crc/
#                                       bmi/avx512)
#       --md5-method <method>        - top-level
#                                       MD5
#                                       algorithm
#                                       (scalar/
#                                       sse/avx2/
#                                       xop/avx512f/
#                                       avx512vl/
#                                       avx10/neon/
#                                       sve2)
#
# CPU Tuning Options:
#   -m, --memory <size>              - max recovery
#                                       computation
#                                       memory
#                                       (default
#                                       75% RAM up
#                                       to 8GB)
#   -t, --threads <n>                - max threads
#                                       (default
#                                       all CPU
#                                       cores)
#       --proc-batch-size <n>        - GF
#                                       multiply
#                                       batch size
#       --method <strategy>          - GF multiply
#                                       algorithm
#                                       (lookup/
#                                       shuffle/
#                                       affine/
#                                       clmul/
#                                       xor/
#                                       xorjit/...
#                                       per
#                                       architecture)
#       --loop-tile-size <n>         - loop tile
#                                       optimization
#                                       target
#                                       size
#
# OpenCL Options (experimental):
#       --opencl-process [<pct>%]    - enable
#                                       OpenCL GPU
#                                       processing
#       --opencl-device <id>         - OpenCL
#                                       platform/
#                                       device
#                                       selection
#       --opencl-memory <size>       - max OpenCL
#                                       device
#                                       memory
#       --opencl-method <strategy>   - OpenCL GF
#                                       multiply
#                                       algorithm
#                                       (lookup/
#                                       log/by2/
#                                       ...)
#       --opencl-batch-size <n>      - OpenCL
#                                       slice
#                                       batch size
#       --opencl-iter-count <n>      - OpenCL
#                                       workgroup
#                                       iterations
#       --opencl-grouping <n>        - OpenCL
#                                       recovery
#                                       slices per
#                                       workgroup
#       --opencl-minchunk <size>     - min OpenCL
#                                       chunk size
#                                       (default
#                                       32K)
#       --opencl <kv,...>            - inline
#                                       OpenCL
#                                       device
#                                       config
#                                       (k=v,k=v)
#       --opencl-list [all]          - list OpenCL
#                                       devices +
#                                       exit
#       --cpu-minchunk <size>        - target min
#                                       CPU chunk
#                                       size
#                                       (default
#                                       64K)
#
# UI Options:
#       --progress <none|stderr|stdout>
#                                    - progress
#                                       indicator
#                                       destination
#                                       (default
#                                       stderr)
#   -q, --quiet                      - suppress
#                                       info output
#   -?, --help                       - short help
#       --help-full                  - full flag
#                                       list (the
#                                       reference
#                                       this
#                                       completion
#                                       was derived
#                                       from)
#       --version                    - print
#                                       version +
#                                       exit
#       --json                       - format
#                                       output as
#                                       JSON
#
# Input Files (after `--`):
#   -R, --recurse                    - recurse into
#                                       directories
#       --no-recurse                 - do not
#                                       traverse
#                                       subdirs
#   -L, --skip-symlinks              - skip
#                                       symlinks
#   -i, --input-file <file>          - read input
#                                       file list
#                                       from text
#                                       file (-
#                                       for stdin,
#                                       proc://cmd
#                                       for process
#                                       stdout,
#                                       fd://N for
#                                       fd)
#   -0, --input-file0                - same as
#                                       -i but
#                                       null-
#                                       separated
#       --input-file-enc <enc>       - input file
#                                       encoding
#                                       (utf8/
#                                       utf16le/
#                                       latin1)
#
# Examples:
#   parpar -s 1M -r 64 -o my_recovery.par2 file1 file2
#   parpar -s 2000 -r 15.7% -o recovery.par2 *.mkv
#   parpar --method=affine-avx512 -t 16 -s 1M \
#          -r 100 -o recovery.par2 large-archive.tar
#
# The reed-solomon lane in ParPar is the *native
# C++ implementation* shipped in `src/`, `gf16/`,
# `xor_depends/`, and `hasher/` directories. ParPar
# doesn't depend on a Node-JS Reed-Solomon library
# - it ships its own SIMD-accelerated
# implementation as native C++ code compiled via
# node-gyp at install time.
#
# This is structurally significant: rather than
# importing a JS library (which would be slow due
# to JS's lack of SIMD intrinsics until very
# recent v8 versions), ParPar implements Reed-
# Solomon directly in C++ with hand-tuned
# assembly for every major SIMD ISA. The result is
# performance comparable to (or exceeding) Klaus
# Post's klauspost/reedsolomon (Axis 263 Go slot
# R1488) and Darren Ldl's rust-rse/reed-solomon-
# erasure (Axis 263 Rust slot R1487 helyim).
#
# The animetosho/ParPar canonical position:
#   - Industry-standard PAR2 creation tool in the
#     Usenet community (alongside par2cmdline-turbo
#     which has similar SIMD optimizations)
#   - The reference Node.js implementation of
#     Reed-Solomon for binary parity archives
#   - Demonstrates that Node.js can host high-
#     performance computational workloads via
#     native C++ bindings
#
# Anime Tosho's broader Reed-Solomon footprint:
#   - ParPar (THIS BINARY)
#   - parpar.dll/.so/.dylib (the native bindings)
#   - gf16/ - canonical SIMD GF(2^16) arithmetic
#     library (often referenced by other PAR2
#     tooling implementations)
#   - hasher/ - SIMD MD5 + CRC32 implementation
#     (used internally for PAR2 packet integrity
#     checking)
#
# ----------------------------------------------------------------------------
# AXIS 263 :: Reed-Solomon erasure coding libraries
#              (forward error correction via
#              polynomial evaluation over Galois
#              fields)
# Round 1489 :: TS-Node slot 3 of 4 :: CLOSES Axis 263
#                                       (256th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : rust-rse/                   [R1487 _helyim]
#             reed-solomon-erasure
#             (Darren Ldl)
#   Go      : klauspost/reedsolomon       [R1488 _aisnode]
#             (Klaus Post)
#   TS/Node : animetosho/ParPar           [R1489 THIS FILE]
#             (Anime Tosho; native C++
#              bindings + SIMD-
#              accelerated GF(2^16))
#
# animetosho/ParPar closes Axis 263 with the
# *native-bindings-not-pure-JS* pattern. The three
# lanes form a clean spectrum:
#
#   - Rust (reed-solomon-erasure): pure-Rust with
#     SIMD-accel feature; idiomatic streaming API
#   - Go (klauspost/reedsolomon): pure-Go with
#     auto-generated SIMD assembly; the source-
#     of-truth for the cross-language port chain
#   - Node (ParPar): native C++ via node-gyp; not
#     a pure-JS implementation because pure-JS RS
#     is too slow for production use cases
#
# The Node lane is the *fragmented* lane of this
# axis - there is no single canonical Node-JS
# RS library the way klauspost/reedsolomon
# canonically dominates Go. Co-canonicals:
#   - ParPar (THIS FILE): native C++ via node-gyp;
#     PAR2-creation focused
#   - ronomon/reed-solomon (Joran Greef): pure-JS
#     RS for general-purpose use
#   - NebulousLabs/reed-solomon-wasm: Sia
#     blockchain's WASM-wrapped RS
#   - par2cmdline-turbo wrapper (`@animetosho/
#     par2cmdline-turbo`): wrapper around the
#     par2cmdline-turbo C binary
#
# ParPar gets the canonical Node-axis slot because
# of its position in the Usenet binary-archive
# community (one of the largest commercial uses of
# Reed-Solomon outside of distributed storage) +
# its SIMD-accelerated native C++ implementation
# delivers performance comparable to the Go/Rust
# canonicals + it's a self-contained Node binary
# (not just a thin wrapper around external C tooling).
#
# Cross-language interop at the wire-shard level
# - the same (n, k, GF(2^8) or GF(2^16) parameters)
# produce byte-identical parity shards across all
# three lanes. ParPar uses GF(2^16) (PAR2 spec
# requirement) while the Rust/Go canonicals use
# GF(2^8) by default; the math is identical, the
# field size is the only difference.
#
# Use-case spectrum across the three lanes:
#   - helyim (Rust, reed-solomon-erasure):
#     SeaweedFS-clone object store using RS for
#     volume-level erasure coding
#   - aisnode (Go, klauspost/reedsolomon): NVIDIA
#     AIStore daemon using RS for bucket-level
#     erasure coding
#   - parpar (Node, native-C++ GF(2^16)): PAR2
#     parity-archive creator using RS for file-
#     recovery archives
#
# Three lanes, three use-case shapes (object
# storage / AI/ML storage / file-level parity
# archives), three implementation strategies
# (pure-Rust+SIMD / pure-Go+assembly / native-C++
# +node-gyp), all converging on the Reed-Solomon
# polynomial-evaluation + GF arithmetic
# fundamentals.
#
# Axis 263 classification: "port-chain-canonical"
# axis where the Go lane (Klaus Post) is the
# source-of-truth, the Rust lane (Darren Ldl) is
# a direct port, and the Node lane (Anime Tosho) is
# a parallel independent implementation
# specialized to the PAR2 spec.
#
# Three-step canonical lineage of the implementation:
#   Java (Backblaze, 2015) -> Go (klauspost, 2015) ->
#   Rust (darrenldl, 2016)
# (with the Node lane being a parallel independent
# implementation, not part of the lineage)
#
# Application footprint of Reed-Solomon across
# the corpus and the broader software ecosystem:
#   - QR codes (small RS code, e.g. (255, 251)
#     over GF(2^8))
#   - CDs + DVDs + Blu-rays (CIRC encoder)
#   - DSL modems + ADSL2+ (forward error correction)
#   - RAID-6 + RAID-Z2 (dual-parity disk arrays)
#   - HDFS-EC + Ceph erasure-coded pools (Hadoop +
#     OpenStack distributed storage)
#   - Backblaze Vault (Java reference impl)
#   - MinIO erasure-coded buckets (klauspost/
#     reedsolomon)
#   - helyim (Rust, Axis 263 Rust slot)
#   - aisnode (Go, Axis 263 Go slot)
#   - parpar (Node, Axis 263 Node slot, THIS FILE)
#   - Voyager 1+2 Deep Space Network (NASA)
#   - Satellite + spacecraft communications
#   - PAR2 Usenet binary archive recovery (THIS
#     FILE's specialization)
#
# Axis 263 closes the round 1489 cycle - 256th
# axis closed total. The three lanes collectively
# demonstrate Reed-Solomon's position as one of
# the most universal error-correction primitives
# in computing, spanning consumer media + storage
# + telecommunications + space-grade transmission.
# ============================================================================

_parpar() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-s --input-slices)'{-s,--input-slices}'[input slice size or count (required)]:spec:' \
        '(-S --auto-slice-size)'{-S,--auto-slice-size}'[auto-scale slice size if count exceeds max]' \
        '(-r --recovery-slices)'{-r,--recovery-slices}'[number of recovery slices to generate]:spec:' \
        '--min-input-slices=[auto-scale minimum input slice count]:spec:' \
        '--max-input-slices=[auto-scale maximum input slice count]:spec:' \
        '--slice-size-multiple=[slice size multiple constraint]:size:' \
        '--min-recovery-slices=[auto-scale min recovery slice count]:spec:' \
        '--max-recovery-slices=[auto-scale max recovery slice count]:spec:' \
        '(-e --recovery-offset)'{-e,--recovery-offset}'[recovery slice start offset]:n:' \
        '--recovery-exponents=[exact recovery exponents (CSV)]:list:' \
        '*'{-c,--comment}'[PAR2 comment (multi)]:text:' \
        '--packet-redundancy=[critical packet copy count]:spec:' \
        '--min-packet-redundancy=[min critical packet copies]:n:' \
        '--max-packet-redundancy=[max critical packet copies (0=unlimited)]:n:' \
        '(-f --filepath-format)'{-f,--filepath-format}'[file path format]:fmt:(basename keep common outrel path)' \
        '(-B --filepath-base)'{-B,--filepath-base}'[base path for `path` format]:dir:_files -/' \
        '--unicode[force unicode packets ON]' \
        '--no-unicode[force unicode packets OFF]' \
        '--ascii-charset=[charset for ASCII packets]:enc:(utf-8 utf-16le latin1 ascii)' \
        '(-o --out)'{-o,--out}'[base PAR2 file name (required)]:file:_files' \
        '(-O --overwrite)'{-O,--overwrite}'[overwrite existing files]' \
        '--write-sync[fsync written files before exit]' \
        '(-n --std-naming)'{-n,--std-naming}'[use standard PAR2 naming scheme]' \
        '(-d --slice-dist)'{-d,--slice-dist}'[slice distribution across files]:dist:(equal uniform pow2)' \
        '(-p --slices-per-file)'{-p,--slices-per-file}'[max slices per file (default 65535)]:n:' \
        '--slices-first-file=[slice count for first recovery file]:n:' \
        '(-F --recovery-files)'{-F,--recovery-files}'[recovery volume file count]:n:' \
        '--noindex[skip index file generation]' \
        '--min-chunk-size=[minimum chunking size (default 128K)]:size:' \
        '--seq-read-size=[max sequential read buffer (default 4M)]:size:' \
        '--chunk-read-threads=[max concurrent read requests]:n:' \
        '--read-buffers=[max read buffers (default 8)]:n:' \
        '--seq-read-throttle=[throttle sequential read speed]:spec:' \
        '--chunk-read-throttle=[throttle chunked read speed]:spec:' \
        '--read-hash-queue=[read buffers to queue for hashing]:n:' \
        '--md5-batch-size=[recovery slice batch size for hashing]:n:' \
        '--recovery-buffers=[recovery slices to buffer]:n:' \
        '--hash-method=[hashing algorithm]:method:(scalar simd crc simd-crc bmi avx512)' \
        '--md5-method=[top-level MD5 algorithm]:method:(scalar sse avx2 xop avx512f avx512vl avx10 neon sve2)' \
        '(-m --memory)'{-m,--memory}'[max recovery computation memory]:size:' \
        '(-t --threads)'{-t,--threads}'[max threads]:n:' \
        '--proc-batch-size=[GF multiply batch size]:n:' \
        '--method=[GF multiply algorithm]:strategy:(lookup 3p_lookup lookup-sse xor-sse xorjit-sse xorjit-avx2 xorjit-avx512 shuffle-sse shuffle-avx shuffle-avx2 shuffle-avx512 shuffle-vbmi shuffle2x-avx2 shuffle2x-avx512 affine-sse affine-avx2 affine-avx10 affine-avx512 affine2x-sse affine2x-avx2 affine2x-avx10 affine2x-avx512 shuffle-neon clmul-neon shuffle128-sve shuffle128-sve2 shuffle2x128-sve2 shuffle512-sve2 clmul-sha3 clmul-sve2 shuffle128-rvv clmul-rvv)' \
        '--loop-tile-size=[loop tile optimization target size]:n:' \
        '--opencl-process=[enable OpenCL GPU processing]:pct:' \
        '--opencl-device=[OpenCL platform/device selection]:device:' \
        '--opencl-memory=[max OpenCL device memory]:size:' \
        '--opencl-method=[OpenCL GF multiply algorithm]:strategy:(lookup lookup_half lookup_nc lookup_half_nc lookup_grp2 lookup_grp2_nc log log_small log_small2 log_tiny log_small_lm log_tiny_lm by2)' \
        '--opencl-batch-size=[OpenCL slice batch size]:n:' \
        '--opencl-iter-count=[OpenCL workgroup iterations]:n:' \
        '--opencl-grouping=[OpenCL recovery slices per workgroup]:n:' \
        '--opencl-minchunk=[min OpenCL chunk size (default 32K)]:size:' \
        '*--opencl=[inline OpenCL device config (k=v,k=v)]:kv:' \
        '--opencl-list[list OpenCL devices and exit]' \
        '--cpu-minchunk=[target min CPU chunk size (default 64K)]:size:' \
        '--progress=[progress indicator destination]:dest:(none stderr stdout)' \
        '(-q --quiet)'{-q,--quiet}'[suppress info output]' \
        '(- *)'{-\?,--help}'[short help]' \
        '(- *)--help-full[full flag list]' \
        '(- *)--version[print version and exit]' \
        '--json[format output as JSON]' \
        '(-R --recurse)'{-R,--recurse}'[recurse into directories]' \
        '--no-recurse[do not traverse subdirectories]' \
        '(-L --skip-symlinks)'{-L,--skip-symlinks}'[skip symlinks]' \
        '*'{-i,--input-file}'[read input file list from text file]:file:_files' \
        '*'{-0,--input-file0}'[read input file list (null-separated)]:file:_files' \
        '--input-file-enc=[input file encoding]:enc:(utf8 utf16le latin1)' \
        '*:input file:_files'
}

_parpar "$@"
