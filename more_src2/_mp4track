#compdef mp4track
# _mp4track — list/modify track-level fields in MP4 files (enzo1982/mp4v2)
# upstream: https://github.com/enzo1982/mp4v2
# Flags from util/mp4track.cpp (_actionGroup + _parmGroup).

_mp4track() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--track-any[act on any/all tracks]' \
        '--track-index=[act on track index]:idx:' \
        '--track-id=[act on track ID]:id:' \
        '--sample-any[act on any sample (default)]' \
        '--sample-index=[act on sample index]:idx:' \
        '--sample-id=[act on sample ID]:id:' \
        '--colr-parms=[colr params (IDX1,IDX2,IDX3)]:csv:' \
        '--colr-parm-hd[shortcut --colr-parms=1,1,1]' \
        '--colr-parm-sd[shortcut --colr-parms=6,1,6]' \
        '--pasp-parms=[pasp params (hSPACING,vSPACING)]:csv:' \
        '--list[list all tracks]' \
        '--enabled=[set trak.tkhd enabled bit]:bool:(true false)' \
        '--inmovie=[set trak.tkhd inMovie bit]:bool:(true false)' \
        '--inpreview=[set trak.tkhd inPreview bit]:bool:(true false)' \
        '--layer=[set trak.tkhd.layer]:n:' \
        '--altgroup=[set trak.tkhd.alternate_group]:n:' \
        '--volume=[set trak.tkhd.volume]:float:' \
        '--width=[set trak.tkhd.width]:float:' \
        '--height=[set trak.tkhd.height]:float:' \
        '--language=[set trak.mdia.mdhd.language]:lang:' \
        '--hdlrname=[set trak.mdia.hdlr.name]:str:' \
        '--udtaname=[set trak.udta.name.value]:str:' \
        '--udtaname-remove[remove trak.udta.name]' \
        '--colr-list[list all colr-boxes]' \
        '--colr-add[add colr-box to video track]' \
        '--colr-set[set colr-box parms]' \
        '--colr-remove[remove colr-box]' \
        '--pasp-list[list all pasp-boxes]' \
        '--pasp-add[add pasp-box to video track]' \
        '--pasp-set[set pasp-box parms]' \
        '--pasp-remove[remove pasp-box]' \
        '*:MP4 file:_files -g "*.(m4a|m4v|mp4)"'
}

_mp4track "$@"
