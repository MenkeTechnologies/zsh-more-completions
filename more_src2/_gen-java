#compdef gen-java
# _gen-java — generate Java classes from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/javagen.py (click).

_gen-java() {
    local -a args
    args=(
        '(-d --output-directory)'{-d+,--output-directory=}'[output directory]:dir:_files -/'
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files'
        '(-f --format)'{-f+,--format=}'[output format]:format:(java)'
        '--package=[Java package name for generated classes]:package:'
        '--template-dir=[Jinja2 template directory]:dir:_files -/'
        '--template-variant=[named template variant to use]:variant:'
        '--template-file=[explicit template file (overrides --template-dir)]:file:_files'
        '--generate-records[emit Java records instead of classes]'
        '--no-generate-records[emit Java classes (default)]'
        '*--extra-template=[additional named template to render]:template:'
        '*--visitor=[generate a visitor interface for the named class]:class:'
        '--true-enums[emit enums as distinct Java types]'
        '--no-true-enums[emit enums as strings]'
        '--use-aliases[use aliases (when present) for field names]'
        '--no-use-aliases[use canonical slot names for field names]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-java "$@"
