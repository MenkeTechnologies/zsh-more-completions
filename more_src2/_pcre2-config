#compdef pcre2-config
# Documentation: pcre2-config --help (PCRE2)
# Source: print build flags for libpcre2.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--prefix[print install prefix]' \
    '--exec-prefix[print exec prefix]' \
    '--version[print PCRE2 version]' \
    '--libs8[print libs for 8-bit library]' \
    '--libs16[print libs for 16-bit library]' \
    '--libs32[print libs for 32-bit library]' \
    '--libs-posix[print libs for POSIX wrapper]' \
    '--cflags[print compile flags]' \
    '--cflags-posix[print compile flags for POSIX wrapper]' \
    && ret=0

return ret
