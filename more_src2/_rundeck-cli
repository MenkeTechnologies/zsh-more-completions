#compdef rundeck-cli rd
# _rundeck-cli — Rundeck self-service operations runbook automation CLI alias (rundeck team, Java); custom argparse
# upstream: https://github.com/rundeck/rundeck-cli

_rundeck-cli() {
    local -a sub=(
        'adhoc:execute ad-hoc command'
        'executions:executions commands'
        'executions list:list executions'
        'executions follow:follow execution'
        'executions info:execution info'
        'executions kill:kill execution'
        'executions query:query executions'
        'executions deletebulk:bulk delete executions'
        'jobs:jobs commands'
        'jobs list:list jobs'
        'jobs run:run job'
        'jobs forecast:forecast job runs'
        'jobs info:job info'
        'jobs purge:purge jobs'
        'jobs load:load jobs from file'
        'jobs reschedule:reschedule jobs'
        'jobs enableschedule:enable schedule'
        'jobs disableschedule:disable schedule'
        'jobs enableexecution:enable execution'
        'jobs disableexecution:disable execution'
        'projects:projects commands'
        'projects list:list projects'
        'projects info:project info'
        'projects create:create project'
        'projects delete:delete project'
        'projects archives import:import archive'
        'projects archives export:export archive'
        'projects acls list:list project ACLs'
        'projects acls get:get project ACL'
        'projects acls create:create project ACL'
        'projects acls update:update project ACL'
        'projects acls delete:delete project ACL'
        'projects configure:configure project'
        'projects configure get:get config'
        'projects configure set:set config'
        'projects configure update:update config'
        'projects scm:scm commands'
        'projects scm config:scm config'
        'projects scm setup:setup scm'
        'projects scm enable:enable scm'
        'projects scm disable:disable scm'
        'projects scm status:scm status'
        'projects scm perform:perform scm'
        'projects scm inputs:scm inputs'
        'projects scm plugins:scm plugins'
        'keys:keys commands'
        'keys list:list keys'
        'keys info:key info'
        'keys get:get key'
        'keys create:create key'
        'keys update:update key'
        'keys delete:delete key'
        'metrics:metrics'
        'nodes:nodes commands'
        'nodes list:list nodes'
        'plugins:plugins commands'
        'plugins list:list plugins'
        'system:system commands'
        'system info:system info'
        'system mode:mode commands'
        'system mode active:set active'
        'system mode passive:set passive'
        'system logstorage info:log storage info'
        'system logstorage incomplete:incomplete log storage'
        'system logstorage resume:resume log storage'
        'tokens:tokens commands'
        'tokens list:list tokens'
        'tokens create:create token'
        'tokens delete:delete token'
        'users:users commands'
        'users info:user info'
        'users list:list users'
        'users edit:edit user'
        'users me:show current user'
        'webhooks:webhooks commands'
        'webhooks list:list webhooks'
        'webhooks create:create webhook'
        'webhooks info:webhook info'
        'webhooks update:update webhook'
        'webhooks delete:delete webhook'
        'completion:generate completion'
        'help:show help'
        'version:show version'
        'features:list features'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[token]:str:' \
        '--user=+[user]:_users' \
        '--password=+[password]:str:' \
        '--url=+[server URL]:url:_urls' \
        '--api-version=+[version]:n:' \
        '--insecure[skip ssl verify]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '--json[json output]' \
        '--yaml[yaml output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rd subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh)' ;;
                jobs:run) _arguments \
                    '--id=+[job id]:str:' \
                    '-i+[job id]:str:' \
                    '--job=+[job name]:str:' \
                    '-j+[job name]:str:' \
                    '--project=+[project]:str:' \
                    '-p+[project]:str:' \
                    '--follow[follow]' \
                    '-f[follow]' \
                    '--filter=+[node filter]:str:' \
                    '--node=+[node]:str:' \
                    '--user=+[user]:_users' \
                    '--at=+[time]:str:' \
                    '--in=+[duration]:str:' \
                    '--loglevel=+[level]:l:(DEBUG VERBOSE INFO WARN ERROR)' \
                    '--option=+[name=value]:str:' \
                    '-O+[name=value]:str:' \
                    '--option-file=+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_rundeck-cli "$@"
