#compdef palloc
# Documentation: https://docs.openpmix.org/en/latest/man/man1/palloc.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Previous file listed mpirun-style
# --np/--host/--hostfile/--mca which are not part of OpenPMIx palloc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--uri=[server URI]:uri:' \
  '--namespace=[server namespace]:namespace:' \
  '--nspace=[server namespace]:namespace:' \
  '--pid=[server PID]:pid:' \
  '--system-server-first[try system server first]' \
  '--system-server-only[only use system server]' \
  '--system-controller[connect to system controller]' \
  '--tmpdir=[session directory base]:dir:_directories' \
  '--connect-order=[connection order]:order:' \
  '--wait-to-connect=[wait time to connect]:seconds:' \
  '--num-connect-retries=[connection retries]:n:' \
  '--request-id=[allocation request id]:id:' \
  '(-q --queue)'{-q+,--queue=}'[queue name]:queue:' \
  '(-N --nodes)'{-N+,--nodes=}'[number of nodes]:n:' \
  '(-i --image)'{-i+,--image=}'[OS image]:image:' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude nodes]:nodes:' \
  '--wait-all-nodes[wait for all nodes]' \
  '(-w --nodelist)'{-w+,--nodelist=}'[explicit node list]:nodes:' \
  '--uid=[user id]:uid:' \
  '--gid=[group id]:gid:' \
  '(-t --time)'{-t+,--time=}'[wall-clock limit]:time:' \
  '--signal=[signal spec]:sig:' \
  '(-s --share)'{-s,--share}'[allow shared allocation]' \
  '--extend=[extend allocation]:id:' \
  '--shrink=[shrink allocation]:id:' \
  '--no-shell[do not run a shell]' \
  '--begin=[defer until time]:time:' \
  '(-I --immediate)'{-I+,--immediate=}'[immediate allocation timeout]:seconds:' \
  '(-d --dependency)'{-d+,--dependency=}'[dependency spec]:spec:' \
  '--do-not-wait[do not wait for resources]' \
  '*::command:_normal' && ret=0

return ret
