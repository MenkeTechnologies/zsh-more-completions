#compdef passhash
# Documentation: https://www.npmjs.com/package/passhash
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Multiple unrelated tools ship as "passhash"; the npm passhash uses
# interactive prompts with a single documented flag (-f format).
# STUB completion.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-f+[output format template]:format:' \
  '*:args:_files' && ret=0
return ret
