#compdef fc-cache
# Documentation: fc-cache --help (fontconfig)
# Source: fontconfig fc-cache — build font information caches.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-E --error-on-no-fonts)'{-E,--error-on-no-fonts}'[raise an error if no fonts in a directory]' \
    '(-f --force -r --really-force)'{-f,--force}'[scan dirs with apparently valid caches]' \
    '(-f --force -r --really-force)'{-r,--really-force}'[erase all caches then rescan]' \
    '(-s --system-only)'{-s,--system-only}'[scan system-wide directories only]' \
    '(-y --sysroot)'{-y,--sysroot=}'[prepend SYSROOT to all paths]:sysroot:_files -/' \
    '(-v --verbose)'{-v,--verbose}'[display status information]' \
    '(- *)'{-V,--version}'[display fontconfig version and exit]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '*:dir:_files -/' \
    && ret=0

return ret
