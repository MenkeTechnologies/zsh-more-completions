#compdef dmstats
# _device-mapper — device-mapper stats CLI (LVM2 project); collect + report I/O stats on dm regions
# upstream: https://gitlab.com/lvmteam/lvm2

_device-mapper() {
    local -a sub=(
        'clear:clear region counters'
        'create:create stats region'
        'delete:delete stats region'
        'group:create group'
        'list:list regions/groups'
        'print:print stats'
        'report:print formatted report'
        'ungroup:remove group'
        'update_filemap:update filemap region'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--allregions[all regions]' \
        '--alldevices[all devices]' \
        '--noheadings[no header]' \
        '--rows[row format]' \
        '-o+[fields]:fields:' \
        '--sort+[sort key]:key:' \
        '-S+[selection]:str:' \
        '--unbuffered[unbuffered output]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dmstats subcommand' sub ;;
    esac
}

_device-mapper "$@"
