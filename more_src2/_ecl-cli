#compdef ecl-cli ecl2
# _ecl-cli — Embeddable Common Lisp ECL ecl-cli CLI command-line frontend wrapping the ECL Embeddable Common Lisp small footprint Common Lisp implementation written in C compiles to native code via C source and binary code open-source originally Giuseppe Attardi now Daniel Kochmański CLOS MOP threads sockets streams condition handling embedded Lisp C-coded interpreter ANSI Common Lisp small efficient embedded Cygwin Mingw mingw32 mingw64 Apple-clang gcc x86_64 arm aarch64 RISC-V WebAssembly compile load eval REPL interactive batch script noinit norc no-quit norepl quit debugger reset no-banner trap shell-execute pipe (ECL Giuseppe Attardi Daniel Kochmański team, C); custom argparse
# upstream: https://ecl.common-lisp.dev/

_ecl-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--norc[no rc]' \
        '--noinit[no init]' \
        '--noquit[no quit]' \
        '--no-quit[no quit]' \
        '--no-version[no version]' \
        '--quit[quit]' \
        '--no-banner[no banner]' \
        '--norepl[no REPL]' \
        '--debugger[enable debugger]' \
        '--no-debugger[no debugger]' \
        '--reset[reset env]' \
        '--frame-stack=+[N]:n:' \
        '--bind-stack=+[N]:n:' \
        '--c-stack=+[N]:n:' \
        '--lisp-stack=+[N]:n:' \
        '--heap-size=+[N]:n:' \
        '--page-size=+[N]:n:' \
        '--trap-fpe[trap FPE]' \
        '--ignore-fpe[ignore FPE]' \
        '-eval+[expression]:str:' \
        '*-eval+[expression]:str:' \
        '-load+[file]:file:_files -g "*.lisp"' \
        '*-load+[file]:file:_files -g "*.lisp"' \
        '-compile+[file]:file:_files -g "*.lisp"' \
        '*-compile+[file]:file:_files -g "*.lisp"' \
        '-o+[output]:file:_files' \
        '-c+[output]:file:_files' \
        '-h+[header file]:file:_files' \
        '-data+[file]:file:_files' \
        '-s+[script]:file:_files -g "*.lisp"' \
        '-shell+[script]:file:_files -g "*.lisp"' \
        '--shell=+[file]:file:_files -g "*.lisp"' \
        '-batch[batch mode]' \
        '--batch[batch mode]' \
        '-input-encoding=+[enc]:str:' \
        '-output-encoding=+[enc]:str:' \
        '-Q[no system init]' \
        '*:lisp file:_files -g "*.lisp *.lsp *.cl *.fasl *.fas *.o *.fasc"'
}

_ecl-cli "$@"
