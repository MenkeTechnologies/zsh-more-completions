#compdef madmom madmom-cli BeatTracker BeatDetector DBNBeatTracker DBNDownBeatTracker BPMHistogram OnsetDetector NoteTranscriptor TempoEstimator PianoTranscriptor
# _madmom — Sebastian Böck Florian Krebs TU Wien madmom Python audio MIR library beat-tracking onset chord detection (CPJKU team, Python); argparse
# upstream: https://github.com/CPJKU/madmom

_madmom() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--fps=+[N]:n:' \
        '--frame-size=+[N]:n:' \
        '--frame-sizes=+[csv]:str:' \
        '--num-bands=+[N]:n:' \
        '--fmin=+[Hz]:f:' \
        '--fmax=+[Hz]:f:' \
        '--sample-rate=+[Hz]:n:' \
        '--threshold=+[F]:f:' \
        '--smooth=+[F]:f:' \
        '--pre-avg=+[F]:f:' \
        '--post-avg=+[F]:f:' \
        '--pre-max=+[F]:f:' \
        '--post-max=+[F]:f:' \
        '--correct[correct beats]' \
        '--no-correct[no correct]' \
        '--min-bpm=+[F]:f:' \
        '--max-bpm=+[F]:f:' \
        '--num-tempi=+[N]:n:' \
        '--transition-lambda=+[F]:f:' \
        '--save-features=+[bool]:b:(true false)' \
        '--load-features=+[bool]:b:(true false)' \
        '--act[output activations]' \
        '--single[single mode]' \
        '--batch[batch mode]' \
        '--num-threads=+[N]:n:' \
        '-j+[N]:n:' \
        '--jobs=+[N]:n:' \
        '*:input audio:_files -g "*.wav *.mp3 *.flac *.ogg *.aif *.aiff"'
}

_madmom "$@"
