#compdef ollama-run
# Documentation: https://github.com/ollama/ollama/blob/main/cmd/cmd.go
# Reference accessed: 2026-05-20
# Verified: upstream cobra source for `ollama run`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--format=[response format]:format:(json)' \
  '--insecure[use insecure connection]' \
  '--keepalive=[keep model alive duration]:duration' \
  '--nowordwrap[disable word wrapping]' \
  '--verbose[show timing data]' \
  '--think=[set or disable thinking mode]:value:(true false high medium low max)' \
  '--hidethinking[suppress thinking output]' \
  '--experimental[enable experimental features]' \
  '--truncate[truncate prompt input]' \
  '1:model:' \
  '*:prompt:' && return 0
