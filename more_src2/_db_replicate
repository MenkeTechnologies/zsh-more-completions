#compdef db_replicate
# Documentation: db_replicate usage (Berkeley DB 18.1.40)
# Source: provide replication services to a Berkeley DB environment.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-M[initial master]' \
    '-v[verbose]' \
    '-h+[environment home]:dir:_files -/' \
    '-P+[password]:password:' \
    '-T+[number of message-processing threads]:nthreads:' \
    '-t+[election timeout seconds]:seconds:' \
    && ret=0

return ret
