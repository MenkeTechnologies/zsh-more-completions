#compdef loadunimap
# _loadunimap — kbd kbd-tools loadunimap CLI loading a Unicode to font-position mapping file uni file into a Linux console screen driver mapping Unicode codepoints to glyph slots in the currently loaded console font for UTF-8 console text rendering (kbd team, C); getopt
# upstream: https://kbd-project.org/

_loadunimap() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-C+[console device]:file:_files -g "/dev/tty* /dev/vc/*"' \
        '-o+[saveto file]:file:_files -g "*.uni"' \
        '-u[load default]' \
        '*:uni map file:_files -g "*.uni *.map"'
}

_loadunimap "$@"
