#compdef gowebly
# Documentation: https://github.com/gowebly/gowebly
# Source: gowebly/gowebly cmd/cmd.go — Go web-app scaffolder with htmx/Alpine/hyperscript (Go).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gowebly_cmds
_gowebly_cmds=(
    'create:create a new Go web-app project (TUI wizard)'
    'run:run the project in dev mode'
    'doctor:check that all prerequisites are installed'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1: :->command' \
    && ret=0

case $state in
    command)
        _describe -t commands 'gowebly command' _gowebly_cmds && ret=0
        ;;
esac

return ret
