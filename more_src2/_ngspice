#compdef ngspice
# Documentation: https://linux.die.net/man/1/ngspice
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[Show help]' \
  '(- *)'{-v,--version}'[Show version]' \
  {-b,--batch}'[Run in batch mode]' \
  {-i,--interactive}'[Run in interactive mode]' \
  {-s,--server}'[Run as server]' \
  {-p,--pipe}'[Run in pipe mode]' \
  {-r,--rawfile}'[Use raw file for output]:file:_files' \
  {-o,--output}'[Output file]:file:_files' \
  {-n,--no-spiceinit}'[Do not read .spiceinit file]' \
  {-c,--circuitfile}'[Read circuit from file]:file:_files' \
  {-D,--define}'[Define a variable]:variable' \
  '--ciprefix[Prefix for current sources]:prefix' \
  '*:file:_files' && ret=0

return ret
