#compdef jupytext
# Documentation: https://github.com/mwouts/jupytext/blob/main/src/jupytext/cli.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jupytext - Jupyter notebooks as text.
# Corrected from prior file: --sync is -s; added the real --paired-paths/-p,
# --diff/-d, --diff-format, --update-metadata, --warn-only/-w, --stop/-x,
# --pipe-fmt, --execute, --run-path, --show-changes, --pre-commit,
# --pre-commit-mode, --use-source-timestamp, --check-source-is-newer.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--to=[target format]:format:(notebook markdown rmarkdown script auto ipynb md Rmd py R jl)' \
  '--from=[source format]:format:(notebook markdown rmarkdown script auto ipynb md Rmd py R jl)' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '--update[update the .ipynb file rather than overwrite]' \
  '--set-formats=[set jupytext formats in notebook metadata]:formats:' \
  '(-s --sync)'{-s,--sync}'[synchronize all paired representations]' \
  '(-p --paired-paths)'{-p,--paired-paths}'[list the paths of all paired files]' \
  '--pipe=[pipe the notebook through the given command]:command:_command_names' \
  '--check=[run a command on the notebook and fail if it was modified]:command:_command_names' \
  '--pipe-fmt=[format in which the notebook is piped]:format:' \
  '--diff[show the diff with the .py representation]' \
  '-d[show the diff with the .py representation]' \
  '--diff-format=[format used for the diff]:format:' \
  '--test[test round-trip conversion]' \
  '--test-strict[strict round-trip test]' \
  '--warn-only[only issue a warning and continue on errors]' \
  '-w[only issue a warning and continue on errors]' \
  '--stop[stop on the first error]' \
  '-x[stop on the first error]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, do not print logs]' \
  '--show-changes[show the diff resulting from the round trip]' \
  '--format-options=[set format options]:options:' \
  '--opt=[set a jupytext format option]:option (key=value):' \
  '--update-metadata=[update the notebook metadata with the given JSON]:json:' \
  '(-k --set-kernel)'{-k,--set-kernel}'=[set the kernel in the notebook metadata]:kernel:' \
  '--execute[execute the notebook with jupyter nbconvert]' \
  '--run-path=[execute the notebook at the given path]:path:_directories' \
  '--use-source-timestamp[set the modification timestamp from the source file]' \
  '--check-source-is-newer[check that the source is newer than the destination]' \
  '--pre-commit[deprecated pre-commit mode]' \
  '--pre-commit-mode[ignore unspecified args, error if files are modified]' \
  '*:notebook files:_files -g "*.{ipynb,md,Rmd,py,R,jl}"'
