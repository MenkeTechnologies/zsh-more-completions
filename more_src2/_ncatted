#compdef ncatted
# Documentation: https://nco.sourceforge.net/nco.html#ncatted
# Source: nco/nco src/nco/ncatted.c — netCDF attribute editor (C, common NCO option set in nco_ctl.c).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-a+[attribute edit (att_nm,var_nm,mode,att_typ,att_val)]:att_spec:_default' \
    '-D+[debug level]:lvl:_default' \
    '--hdr_pad=[header padding (bytes)]:bytes:_default' \
    '-h[do not append to history attribute]' \
    '-l+[local storage path for remote files]:path:_directories' \
    '-O[overwrite existing output file]' \
    '-p+[path prefix for input filenames]:path:_directories' \
    '-R[retain remotely-retrieved files after use]' \
    '-r[print version info]' \
    '-t[type-match attribute edits]' \
    '--gaa=[global attribute append (att_nm=att_val)]:spec:_default' \
    '--gad=[global attribute delete]:names:_default' \
    '--ram_all[buffer entire file in RAM before write]' \
    '*:netcdf file:_files -g "*.(nc|nc4|cdf|hdf|h5)(-.)"' \
    && ret=0

return ret
