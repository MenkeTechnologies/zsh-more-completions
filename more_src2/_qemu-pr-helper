#compdef qemu-pr-helper
# _qemu-pr-helper — QEMU qemu-pr-helper (SCSI persistent-reservation helper that lets unprivileged QEMU guests issue PERSISTENT RESERVE OUT commands via an out-of-process root daemon; -k unix socket path, -p pidfile, -f run as foreground, -d daemonize, -u user, -g group, -T trace spec)
# upstream: https://gitlab.com/qemu-project/qemu (qemu-pr-helper)
# Flags from qemu scsi/qemu-pr-helper.c on tip.

_qemu-pr-helper() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d[daemonize]' \
        '-f[foreground]' \
        '-k+[unix socket path]:file:_files' \
        '-p+[pidfile]:file:_files' \
        '-u+[run as user]:user:_users' \
        '-g+[run as group]:group:_groups' \
        '-T+[trace spec]:spec:' \
        '-v[verbose]' \
        '-q[quiet]'
}

_qemu-pr-helper "$@"
