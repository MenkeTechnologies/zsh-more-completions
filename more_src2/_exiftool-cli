#compdef exiftool-cli
# _exiftool-cli — Phil Harvey exiftool read/write meta information in files CLI alias (exiftool team, Perl); custom argparse
# upstream: https://github.com/exiftool/exiftool

_exiftool-cli() {
    _arguments \
        '--help[show help]' \
        '-h[short help]' \
        '-ver[show version]' \
        '--ver[show version]' \
        '-a[allow duplicate tags]' \
        '-c+[coordinate format]:str:' \
        '-charset=+[charset]:str:' \
        '-csv=+[CSV file]:file:_files' \
        '-csvDelim=+[delimiter]:str:' \
        '-d+[date format]:str:' \
        '-D[show decimal Group 0]' \
        '-E[escape HTML]' \
        '-ex[escape XML]' \
        '-f[force print all tags]' \
        '-fast[fast scan]' \
        '-fast2[faster scan]' \
        '-fileOrder=+[tag]:str:' \
        '-G+[show group names]:n:' \
        '-h[HTML output]' \
        '-H[show hex tag IDs]' \
        '-htmlDump[full HTML dump]' \
        '-j[JSON output]' \
        '-json[JSON output]' \
        '-l[long format]' \
        '-L[Windows Latin1 charset]' \
        '-lang=+[language]:str:' \
        '-listItem=+[n]:n:' \
        '-m[ignore minor errors]' \
        '-n[no print conversion]' \
        '-p+[print format]:file:_files' \
        '-P[preserve original times]' \
        '-q[quiet]' \
        '-r[recurse subdirectories]' \
        '-R[recurse symlinks]' \
        '-s[short output]' \
        '-S[very short output]' \
        '-sep=+[separator]:str:' \
        '-struct[output structures]' \
        '-t[tab delimited]' \
        '-T[same as -t]' \
        '-u[extract unknown tags]' \
        '-U[extract unknown binary tags]' \
        '-v+[verbose]:n:' \
        '-w+[output ext]:str:' \
        '-W+[output file]:str:' \
        '-X[XML output]' \
        '-overwrite_original[overwrite original]' \
        '-overwrite_original_in_place[overwrite in place]' \
        '-tagsFromFile=+[source file]:file:_files' \
        '-stay_open=+[mode]:str:' \
        '-@+[arg file]:file:_files' \
        '-listg=+[level]:n:' \
        '-list[list tags]' \
        '-listw[list writable tags]' \
        '-listf[list supported formats]' \
        '-listr[list recursive tags]' \
        '-listwf[list writable file types]' \
        '-listx[list as XML]' \
        '-if=+[condition]:str:' \
        '-execute[execute end of args]' \
        '-progress[progress messages]' \
        '*:files or dirs:_files'
}

_exiftool-cli "$@"
