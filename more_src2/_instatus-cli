#compdef instatus-cli instatus
# _instatus-cli — Instatus instatus-cli CLI command-line frontend wrapping the Instatus status page incident communication uptime monitoring platform REST API providing page incident component metric subscriber team member maintenance template public-status-page custom-domain custom-css subscriber-notifications SMS-email-Slack-webhook incident-update private-status-page (Instatus team, JavaScript); custom argparse
# upstream: https://instatus.com/

_instatus-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'page:page operations'
        'incident:incident operations'
        'incident-update:incident update operations'
        'component:component operations'
        'component-group:component group operations'
        'metric:metric operations'
        'metric-data:metric data operations'
        'subscriber:subscriber operations'
        'team:team operations'
        'team-member:team member operations'
        'maintenance:maintenance operations'
        'template:template operations'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--page-id=+[id]:str:' \
        '-p+[page]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'instatus subcommand' sub ;;
        args)
            case $words[1] in
                page|incident|incident-update|component|component-group|metric|metric-data|subscriber|team|team-member|maintenance|template|webhook) _arguments '1:op:(list get create update delete resolve reopen)' '*:id:' ;;
            esac
            ;;
    esac
}

_instatus-cli "$@"
