#compdef dvtm
# Documentation: https://www.brain-dump.org/projects/dvtm/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dvtm - dynamic virtual terminal manager (suckless-style)

local -a arguments

arguments=(
  '-v[print version information]'
  '-M[toggle default mouse grabbing]'
  '-m[set modifier (command) key]:modifier key:'
  '-d[ncurses escape sequence detection delay (seconds)]:seconds:'
  '-h[scrollback history buffer lines]:lines:'
  '-t[set static terminal title]:title:'
  '-s[named pipe for status bar content]:status-fifo:_files'
  '-c[named pipe for command execution]:cmd-fifo:_files'
  '*::command:_command_names -e'
)

_arguments -s -S $arguments
