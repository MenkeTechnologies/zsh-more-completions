#compdef jormungandr
# Documentation: https://github.com/input-output-hk/jormungandr/blob/master/jormungandr/src/settings/command_arguments.rs
# Reference accessed: 2026-05-19
# Verified: upstream structopt CommandLine definition at the URL above.

# Cardano/Jormungandr privacy voting blockchain node.
# Corrected from prior file: removed invented --listen,
# --leadership-logs-max-entries, --quic-tls-cert, --quic-tls-key
# and the --no-rest flag; added the real --public-address,
# --listen-address, --enable-prometheus, --jrpc-listen,
# --rewards-report-all, --full-version, --source-version,
# --storage-check; --secret/--trusted-peer may repeat.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--storage=[blockchain pool storage directory]:dir:_directories' \
  '--config=[node config in YAML format]:file:_files -g "*.{yaml,yml}"' \
  '*--secret=[secret node config in YAML format]:file:_files -g "*.{yaml,yml}"' \
  '--genesis-block=[path to the genesis block (block0)]:file:_files' \
  '*--trusted-peer=[trusted peer in multiformat]:peer:' \
  '--genesis-block-hash=[hash of block0]:hash:' \
  '--enable-prometheus[enable the Prometheus metrics exporter]' \
  '--public-address=[public p2p address advertised to peers]:addr:' \
  '--listen-address=[address to listen for p2p connections]:addr:' \
  '--log-level=[minimum log severity]:level:(off error warn info debug trace)' \
  '--log-format=[log format]:format:(plain json)' \
  '--log-output=[log output target]:target:(stdout stderr syslog journald)' \
  '--rewards-report-all[report all rewards in the distribution history]' \
  '--rest-listen=[REST API listening address]:addr:' \
  '--jrpc-listen=[JRPC API listening address]:addr:' \
  '--full-version[display full version details]' \
  '--source-version[display the sources version]' \
  '--storage-check[initialize the storage and exit]' && ret=0

return ret
