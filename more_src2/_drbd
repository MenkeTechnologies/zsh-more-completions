#compdef drbdadm

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-d --dry-run)'{-d,--dry-run}'[Show what would be done without actually doing it]' \
  '(-c --config-file)'{-c,--config-file}'[Use specified configuration file]:file:_files' \
  '(-s --stacked)'{-s,--stacked}'[Operate on stacked resources]' \
  '--force[Force operation]' \
  '1:command:->cmds' \
  '2:resource:->resources' \
  && ret=0

case $state in
  cmds)
    local -a commands=(
      'attach:Attach local backing block device'
      'detach:Detach from local backing block device'
      'connect:Connect to peer'
      'disconnect:Disconnect from peer'
      'up:Attach and connect'
      'down:Disconnect and detach'
      'primary:Promote to primary role'
      'secondary:Demote to secondary role'
      'invalidate:Invalidate local data, start resync'
      'invalidate-remote:Invalidate remote data, start resync'
      'outdate:Mark data on this node as outdated'
      'resize:Resize the DRBD device'
      'verify:Start online verification'
      'pause-sync:Pause resynchronization'
      'resume-sync:Resume resynchronization'
      'adjust:Adjust configuration on running devices'
      'wait-connect:Wait until connection is established'
      'role:Show current role of resource'
      'cstate:Show current connection state'
      'dstate:Show current disk state'
      'dump:Dump configuration'
      'dump-md:Dump metadata'
      'create-md:Create metadata'
      'wipe-md:Wipe metadata'
      'get-gi:Show generation identifiers'
      'show-gi:Show generation identifiers (verbose)'
      'status:Show status of all resources'
      'sh-dev:Print device name'
      'sh-udev:Print udev info'
      'sh-ll-dev:Print lower-level device name'
    )
    _describe -t commands 'drbdadm command' commands && ret=0
    ;;
  resources)
    local -a resources
    resources=( all )
    # Try to parse resource names from the DRBD config
    if [[ -f /etc/drbd.conf ]]; then
      resources+=( ${(f)"$(grep -oP '^\s*resource\s+\K\S+' /etc/drbd.conf 2>/dev/null)"} )
    fi
    if [[ -d /etc/drbd.d ]]; then
      resources+=( ${(f)"$(grep -oP '^\s*resource\s+\K\S+' /etc/drbd.d/*.res 2>/dev/null)"} )
    fi
    _describe -t resources 'resource' resources && ret=0
    ;;
esac

return ret
