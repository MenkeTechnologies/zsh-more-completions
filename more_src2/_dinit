#compdef dinit
# Documentation: https://davmac.org/projects/dinit/man-pages-html/dinit.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# davmac314/dinit service manager command-line options.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-d --services-dir)'{-d,--services-dir}'=[services directory]:directory:_directories' \
  '(-s --system)'{-s,--system}'[run as system service manager]' \
  '(-u --user)'{-u,--user}'[run as user service manager]' \
  '(-m --system-mgr)'{-m,--system-mgr}'[run as system manager]' \
  '(-p --socket-path)'{-p,--socket-path}'=[control socket path]:socket path:_files' \
  '(-l --log-file)'{-l,--log-file}'=[log file path]:log file:_files' \
  '(-o --container)'{-o,--container}'[run in container mode]' \
  '(-q --quiet)'{-q,--quiet}'[suppress terminal output]' \
  '(-r --auto-recovery)'{-r,--auto-recovery}'[auto-run recovery on boot failure]' \
  '(-b --cgroup-path)'{-b,--cgroup-path}'=[cgroup path]:path' \
  '(-e --env-file)'{-e,--env-file}'=[environment file]:env file:_files' \
  '(-F --ready-fd)'{-F,--ready-fd}'=[readiness notification fd]:fd' \
  '(-t --service)'{-t,--service}'=[service to start]:service' \
  '--console-level=[console log level]:level' \
  '--log-level=[primary log facility level]:level' \
  '*:service name' && ret=0

return ret
