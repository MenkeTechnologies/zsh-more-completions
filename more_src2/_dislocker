#compdef dislocker dislocker-fuse dislocker-file
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/dislocker.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Aorimn/dislocker — read/write BitLocker volumes via FUSE.
# Native dislocker options precede `--`; FUSE options come after.

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '*'{-v,--verbosity}'[increase verbosity]' \
  '-V+[volume to decrypt]:volume:_files -g "*(-%b)"' \
  '--volume=[volume to decrypt]:volume:_files -g "*(-%b)"' \
  '(-p --recovery-password)'{-p+,--recovery-password=}'[recovery password]:password' \
  '(-u --user-password)'{-u,--user-password}'[prompt for user password]' \
  '(-f --bekfile)'{-f+,--bekfile=}'[BEK file]:BEK file:_files' \
  '(-c --clearkey)'{-c,--clearkey}'[use clear key found on volume]' \
  '(-k --fvek)'{-k+,--fvek=}'[FVEK file]:FVEK file:_files' \
  '(-r --readonly)'{-r,--readonly}'[read-only mode]' \
  '(-F --force-block)'{-F+,--force-block=}'[force metadata block N]:block:(1 2 3)' \
  '(-s --stateok)'{-s,--stateok}'[skip BitLocker volume state check]' \
  '(-O --offset)'{-O+,--offset=}'[partition offset in bytes]:offset' \
  '-l+[log file]:file:_files' \
  '-q[quiet]' \
  '1:volume path:_files' \
  '2:mount point:_directories'
