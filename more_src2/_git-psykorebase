#compdef git-psykorebase git-rebase-patch git-rename-branch git-rename-remote git-sed git-squash
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 6. Companion to rounds 150-154 + the pre-existing
# _git-extras / _git-standup / _git-undo (via _ugit) / _git-changelog /
# _git-info / _git-ignore / _git-get standalone files.
# Hunt-skip log this round: git-rscp / git-back / git-blame-someone-else /
# git-bug / git-chore / git-archive-status / git-archive-now / git-refactor
# all 404 on direct fetch from tj/git-extras master.
# git-mv listed in the API directory page but the .1 file itself 404s --
# likely an api-listing artifact (stock git mv covers the surface anyway).

local curcontext="$curcontext" state line ret=1

case $service in

  git-psykorebase)
    # man/git-psykorebase.1 — psyko rebase strategy with --no-ff option.
    #   git-psykorebase <target_branch> [<feature_branch>] [--no-ff]
    #   git-psykorebase --continue
    _arguments -s -S \
      '--no-ff[force a commit message even when no conflicts]' \
      '(- *)--continue[continue the rebase after resolving conflicts]' \
      '1:target branch:__git_branch_names' \
      '2:feature branch (default current):__git_branch_names' \
      && ret=0
    ;;

  git-rebase-patch)
    # man/git-rebase-patch.1 — apply a single patch file as a rebase.
    _arguments -s -S \
      '1:patch file:_files -g "*.(patch|diff)"' \
      && ret=0
    ;;

  git-rename-branch)
    # man/git-rename-branch.1 — rename a branch (local + remote).
    #   git-rename-branch [<old-branch>] <new-branch>
    # If only 1 arg supplied, the current branch is renamed to it.
    _arguments -s -S \
      '1:old branch (default current):__git_branch_names' \
      '2:new branch name:' \
      && ret=0
    ;;

  git-rename-remote)
    # man/git-rename-remote.1 — rename a remote.
    _arguments -s -S \
      '1:old remote name:__git_remotes' \
      '2:new remote name:' \
      && ret=0
    ;;

  git-sed)
    # man/git-sed.1 — bulk sed across tracked files.
    #   git-sed [-c] [-f flags] <search> <replacement> [flags] [-- <pathspec>]
    _arguments -s -S \
      '-c[commit the resulting changes with a standard commit message]' \
      '-f+[sed regex flags (e.g. "g" for global per-line)]:flags:' \
      '*:search/replacement/pathspec:_files' \
      && ret=0
    ;;

  git-squash)
    # man/git-squash.1 — squash branch commits or a commit range.
    #   git-squash [--squash-msg] <source-branch|commit-ref> [<commit-message>]
    # Note: --squash-msg cannot combine with a custom <commit-message>.
    _arguments -s -S \
      '(--squash-msg 2)--squash-msg[commit with concatenated squashed messages]' \
      '1:source branch or commit ref:__git_revisions' \
      '2:commit message (mutex with --squash-msg):' \
      && ret=0
    ;;

esac

return ret
