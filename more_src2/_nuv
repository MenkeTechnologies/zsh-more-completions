#compdef nuv
# Documentation: https://github.com/nuvolaris/nuv
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

local -a tasks=(
  '-login:log into Nuvolaris'
  '-logout:log out'
  '-update:download/update embedded tools and tasks'
  '-info:display information'
  '-task:embedded Task build tool'
  '-wsk:embedded wsk CLI (OpenWhisk)'
  '-basename:embedded basename'
  '-cat:embedded cat'
  '-cp:embedded cp'
  '-curl:embedded curl'
  '-dirname:embedded dirname'
  '-envsubst:embedded envsubst'
  '-grep:embedded grep'
  '-gunzip:embedded gunzip'
  '-gzip:embedded gzip'
  '-head:embedded head'
  '-jq:embedded jq'
  '-ls:embedded ls'
  '-mv:embedded mv'
  '-pwd:embedded pwd'
  '-realpath:embedded realpath'
  '-rm:embedded rm'
  '-sed:embedded sed'
  '-sleep:embedded sleep'
  '-tail:embedded tail'
  '-tar:embedded tar'
  '-tee:embedded tee'
  '-touch:embedded touch'
  '-tr:embedded tr'
  '-unzip:embedded unzip'
  '-wc:embedded wc'
  '-which:embedded which'
  '-zip:embedded zip'
)

_arguments -C \
  '(- *)'{-h,-help}'[show help]' \
  '(- *)-version[show version]' \
  '*::task_or_invocation:->tasks' && ret=0

case $state in
  (tasks) _describe -t tasks 'nuv task' tasks && ret=0 ;;
esac

return ret
