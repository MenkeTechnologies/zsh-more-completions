#compdef jp
# Documentation: https://github.com/jmespath/jp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-f --filename)'{-f,--filename=}'[read JSON from file]:file:_files -g "*.json"' \
  '(-u --unquoted)'{-u,--unquoted}'[print string results without quotes]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  ':jmespath expression:'
