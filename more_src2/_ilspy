#compdef ilspy ilspycmd
# _ilspy — ICSharpCode ILSpy .NET assembly browser/decompiler CLI alias (icsharpcode team, C#); custom argparse
# upstream: https://github.com/icsharpcode/ILSpy

_ilspy() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--project-dir=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--type=+[full type name]:str:' \
        '-t+[full type name]:str:' \
        '--list=+[entity type]:t:(c classes m methods e events f fields p properties)' \
        '-l+[entity type]:t:(c classes m methods e events f fields p properties)' \
        '--language-version=+[version]:l:(CSharp1 CSharp2 CSharp3 CSharp4 CSharp5 CSharp6 CSharp7 CSharp7_1 CSharp7_2 CSharp7_3 CSharp8_0 CSharp9_0 CSharp10_0 CSharp11_0 CSharp12_0 Latest)' \
        '--reference-paths=+[paths csv]:str:' \
        '-r+[paths csv]:str:' \
        '--nested-directories[create nested directories]' \
        '-n[create nested directories]' \
        '--ilcode[generate IL code]' \
        '-il[generate IL code]' \
        '--ilsequence[generate IL sequence]' \
        '--genpdb[generate PDB]' \
        '--usepdb[use PDB]' \
        '--separate-properties[separate properties]' \
        '--show-version[show version]' \
        '--portable-pdb[portable PDB]' \
        '--no-dead-code[no dead code]' \
        '--no-dead-stores[no dead stores]' \
        '--dump-package=+[file]:file:_files' \
        '--use-decompiled-attribute[use decompiled attribute]' \
        '--language=+[lang]:l:(IL CSharp)' \
        '--input=+[assembly]:file:_files' \
        '*:assembly:_files -g "*.{dll,exe,winmd,netmodule}"'
}

_ilspy "$@"
