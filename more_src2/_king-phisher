#compdef KingPhisher KingPhisherServer
# Documentation: https://github.com/rsmusllp/king-phisher/blob/master/king_phisher/startup.py
# Reference accessed: 2026-05-19
# Verified: upstream argparse definitions at the URL above.
# Corrected from prior file: real binaries are KingPhisher (client) and
# KingPhisherServer (server), not king-phisher / -client / -server.
# -L is --log (an enum, not a file); --logger takes a logger name (not
# a file); client -c/--config is a path; server adds -f/--foreground,
# --verify-config and a positional config file.

local curcontext="$curcontext" ret=1

local -a common
common=(
  '(- *)'{-h,--help}'[show help]'
  '(- *)'{-v,--version}'[show version]'
  '(-L --log)'{-L,--log}'=[set the logging level]:level:(DEBUG INFO WARNING ERROR FATAL)'
  '--logger=[specify the root logger]:logger:'
  '--gc-debug-leak[set the gc DEBUG_LEAK flag]'
  '--gc-debug-stats[set the gc DEBUG_STATS flag]'
  '--env-install[install pipenv environment and exit]'
  '--env-update[update pipenv requirements and exit]'
  '--env-verbose[display pipenv output]'
)

case ${service:-$words[1]} in
  KingPhisherServer)
    _arguments -C "${common[@]}" \
      '(-f --foreground)'{-f,--foreground}'[run in the foreground (do not fork)]' \
      '--verify-config[verify the configuration and exit]' \
      '1:config file:_files' && ret=0
    ;;
  *)
    _arguments -C "${common[@]}" \
      '(-c --config)'{-c,--config}'=[specify a configuration file to use]:file:_files' \
      '--no-plugins[disable all plugins]' \
      '--no-style[disable interface styling]' && ret=0
    ;;
esac

return ret
