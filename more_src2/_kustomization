#compdef kustomization kustomize-edit
# _kustomization — Kustomize kustomize edit wrappers (legacy alias for kubernetes-sigs/kustomize edit; subcommands add/remove/set/fix/list edit kustomization.yaml fields like resource, configmap, secret, label, annotation, namespace, namePrefix, nameSuffix, image, patch)
# upstream: https://github.com/kubernetes-sigs/kustomize (kustomize/commands/edit)
# Subcommands from kustomize edit on tip.

_kustomization() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '1: :->verb' \
        '*::arg:->args'
    case $state in
        verb) _describe -t commands 'edit verb' '(add remove set fix list)' ;;
        args)
            _describe -t commands 'target' \
                '(resource configmap secret patch transformer generator buildmetadata namespace nameprefix namesuffix annotation label image basebranch component replicas commonAnnotations commonLabels)'
            ;;
    esac
}

_kustomization "$@"
