#compdef elm2
# _elm2 — Evan Czaplicki Elm Lang elm2 CLI command-line frontend wrapping the Elm a delightful language with no runtime exceptions written in Haskell originally Evan Czaplicki functional programming language for declaratively creating web browser-based graphical user interfaces compiles to JavaScript Elm-Architecture-The-Elm-Architecture make repl reactor install diff publish bump init help version test format elm-format elm-test elm-spa elm-ui browser browser-application-document html debug optimize output report html json (Evan Czaplicki Elm Software Foundation team, Haskell); custom argparse
# upstream: https://elm-lang.org/

_elm2() {
    local -a sub=(
        'make:Compile Elm code'
        'repl:Open Elm REPL'
        'reactor:Start web server for browsing'
        'init:Create elm.json'
        'install:Install a package'
        'bump:Bump version numbers'
        'diff:Diff two versions of a package'
        'publish:Publish a package'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[include Elm debugger]' \
        '--optimize[optimize output]' \
        '--output=+[file]:file:_files -g "*.html *.js *.json"' \
        '--report=+[type]:t:(json)' \
        '--docs=+[file]:file:_files -g "*.json"' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--no-launch[no auto launch]' \
        '--exit-on-warn[exit on warning]' \
        '--silent[silent]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'elm subcommand' sub ;;
        args)
            case $words[1] in
                make) _arguments '*:elm file:_files -g "*.elm"' ;;
                install) _arguments '*:package:' ;;
                diff) _arguments '*:package:' ;;
                repl|reactor|init|bump|publish) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_elm2 "$@"
