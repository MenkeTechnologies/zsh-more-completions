#compdef nettle-hash
# Documentation: nettle-hash --help
# Source: compute a cryptographic hash via libnettle.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)--list[list supported hash algorithms]' \
    '(-a --algorithm)'{-a+,--algorithm=}'[hash algorithm]:alg:(md2 md4 md5 ripemd160 sha1 sha224 sha256 sha384 sha512 sha512_224 sha512_256 sha3_224 sha3_256 sha3_384 sha3_512 gosthash94 streebog256 streebog512 sm3)' \
    '(-l --length)'{-l+,--length=}'[digest length octets]:length:' \
    '--raw[raw binary output]' \
    '*:file:_files' \
    && ret=0

return ret
