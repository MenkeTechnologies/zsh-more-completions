#compdef klee
# Documentation: https://github.com/klee/klee/blob/master/tools/klee/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KLEE cl::opt definitions (tools/klee/main.cpp,
# lib/Core/Executor.cpp, lib/Core/UserSearcher.cpp,
# lib/Solver/SolverCmdLine.cpp).
# Corrected from prior file: --seed-out/--seed-out-dir are really
# --seed-file/--seed-dir; --use-query-loggers is --use-query-log with
# values all:kquery|all:smt2|solver:kquery|solver:smt2; removed
# fabricated --write-pcs/--write-states/--write-traces/--write-smt2s(?)
# kept (real), --use-merge-merge, --use-iv-prinst-ass, --switch-type,
# --allocate-determ*, --max-fork-tries, --max-loop-time,
# --debug-z3/stp-dump-queries, --readable-posix-inputs,
# --symbolic-extra-args, --always-output-seeds, --seed-only,
# --zero-seed-extension. Fixed --search/--solver-backend/--libc/
# --external-calls/--debug-print-instructions enums to upstream values.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show available options]' \
  '(- *)--help-list[show option list]' \
  '(- *)--version[show version]' \
  '--output-dir=[directory for results]:dir:_files -/' \
  '--run-in-dir=[change directory before execution]:dir:_files -/' \
  '--entry-point=[entry function to start execution at]:function:' \
  '--env-file=[initialize environment from file]:file:_files' \
  '--optimize[run optimization passes on the bitcode before execution]' \
  '--posix-runtime[link with the POSIX runtime]' \
  '--libc=[libc to use]:libc:(none klee uclibc)' \
  '--libcxx[link and optimize libcxx into the bitcode]' \
  '--ubsan-runtime[link with the UBSan runtime]' \
  '--max-time=[halt execution after the given duration]:duration:' \
  '--max-instruction-time=[only allow an instruction this long to execute]:duration:' \
  '--max-memory=[refuse to fork when above this memory cap (MB)]:mb:' \
  '--max-memory-inhibit[inhibit forking when above the memory cap]' \
  '--max-static-fork-pct=[maximum percentage spent by an instruction forking]:pct:' \
  '--max-static-solve-pct=[maximum percentage spent in the solver]:pct:' \
  '--max-static-cpfork-pct=[maximum forking percentage per call path]:pct:' \
  '--max-sym-array-size=[concretize symbolic arrays larger than this]:n:' \
  '--watchdog[use a watchdog process to enforce --max-time]' \
  '--exit-on-error[exit if errors occur]' \
  '--exit-on-error-type=[exit on a specific error type]:type:(Abort Assert BadVectorAccess Exec External Free Model Overflow Ptr ReadOnly ReportError User Unhandled)' \
  '--only-output-states-covering-new[only output test cases covering new code]' \
  '--simplify-sym-indices[simplify symbolic accesses using equalities]' \
  '--silent-klee-assume[silently terminate paths with an infeasible assume]' \
  '--external-calls=[external call policy]:policy:(none concrete all)' \
  '--search=[state exploration strategy]:strategy:(dfs bfs random-state random-path nurs:covnew nurs:md2u nurs:depth nurs:rp nurs:icnt nurs:cpicnt nurs:qc)' \
  '--use-batching-search[run a state multiple times before switching]' \
  '--batch-instructions=[instructions per batch in batching search]:n:' \
  '--batch-time=[time per batch in batching search]:duration:' \
  '--use-merge[enable support for path merging via klee_open_merge]' \
  '--use-forked-solver[run the solver in a forked process]' \
  '--use-cex-cache[use the counterexample cache]' \
  '--solver-backend=[core solver backend]:backend:(stp metasmt dummy z3)' \
  '--use-query-log=[log queries]:mode:(all:kquery all:smt2 solver:kquery solver:smt2)' \
  '--write-cov[write coverage information for each test case]' \
  '--write-cvcs[write .cvc files for each test case]' \
  '--write-kqueries[write .kquery files for each test case]' \
  '--write-smt2s[write .smt2 files for each test case]' \
  '--write-test-info[write additional .info files for each test case]' \
  '--write-paths[write .path files for each test case]' \
  '--write-sym-paths[write .sym.path files for each test case]' \
  '--write-ktests[write .ktest files for each test case]' \
  '--write-xml-tests[write .test.xml files for each test case]' \
  '--write-no-tests[do not write any .ktest test files]' \
  '--seed-file=[file to seed exploration from]:file:_files' \
  '--seed-dir=[directory of ktest files to seed exploration from]:dir:_files -/' \
  '--max-tests=[stop running after this many tests]:n:' \
  '--debug-print-instructions=[print instructions during execution]:mode:(all:stderr src:stderr compact:stderr all:file src:file compact:file)' \
  '*: :_files -g "*.bc"' && ret=0

return ret
