#compdef post
# Documentation: man post(8)
# Source: nmh uip/post.c (master) — deliver a message (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-alias+[alias file]:file:_files' \
    '(-check -nocheck)-check[check addresses]' \
    '(-check -nocheck)-nocheck[no check]' \
    '-debug[debug output]' \
    '-dist[redistribute mode]' \
    '-filter+[filter file]:file:_files' \
    '-nofilter[no filter]' \
    '(-format -noformat)-format[format addresses]' \
    '(-format -noformat)-noformat[no format]' \
    '-library+[library directory]:dir:_files -/' \
    '(-mime -nomime)-mime[MIME encode]' \
    '(-mime -nomime)-nomime[no MIME]' \
    '(-msgid -nomsgid)-msgid[add Message-ID]' \
    '(-msgid -nomsgid)-nomsgid[no Message-ID]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-watch -nowatch)-watch[watch delivery]' \
    '(-watch -nowatch)-nowatch[no watch]' \
    '-whom[show recipients]' \
    '-width+[output width]:cols:_default' \
    '(-dashstuffing -nodashstuffing)-dashstuffing[dash-stuff bcc]' \
    '(-dashstuffing -nodashstuffing)-nodashstuffing[no dash-stuff]' \
    '-idanno+[id annotation number]:N:_default' \
    '-client+[SMTP client hostname]:host:_hosts' \
    '-server+[SMTP server]:host:_hosts' \
    '-snoop[snoop SMTP transaction]' \
    '-partno+[part number]:N:_default' \
    '(-sasl -nosasl)-sasl[enable SASL]' \
    '(-sasl -nosasl)-nosasl[disable SASL]' \
    '-saslmaxssf+[SASL max SSF]:ssf:_default' \
    '-saslmech+[SASL mechanism]:mech:_default' \
    '-user+[SASL/auth user]:user:_users' \
    '-port+[SMTP submission port]:port:_default' \
    '(-tls -notls -initialtls)-tls[STARTTLS]' \
    '(-tls -notls -initialtls)-initialtls[implicit TLS]' \
    '(-tls -notls -initialtls)-notls[no TLS]' \
    '-fileproc+[fileproc command]:cmd:_command_names -e' \
    '-mhlproc+[mhlproc command]:cmd:_command_names -e' \
    '-mts+[mail transport]:mts:(smtp sendmail/smtp sendmail/pipe)' \
    '-credentials+[credentials source]:src:(legacy file:)' \
    '-messageid+[message-id style]:style:(localname random)' \
    '-version[show version]' \
    '-help[show help]' \
    '1:file:_files' \
    && ret=0

return ret
