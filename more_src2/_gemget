#compdef gemget
# _gemget — Gemini protocol curl-like client (Go); single-shot gemini:// fetcher with redirect/auth/output-file support
# upstream: https://github.com/makew0rld/gemget

_gemget() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-o --output)'{-o,--output}'+[write to file]:file:_files' \
        '(-d --output-dir)'{-d,--output-dir}'+[output dir]:dir:_files -/' \
        '(-q --quiet)'{-q,--quiet}'[silent mode]' \
        '(-r --max-redirects)'{-r,--max-redirects}'+[max redirects]:n:' \
        '(-R --insecure-redirects)'{-R,--insecure-redirects}'[allow cross-host redirects]' \
        '(-c --cert)'{-c,--cert}'+[client cert]:file:_files' \
        '(-k --key)'{-k,--key}'+[client key]:file:_files' \
        '(-i --input-file)'{-i,--input-file}'+[URL list file]:file:_files' \
        '(-H --header)'{-H,--header}'[print response header]' \
        '(-e --exclude-headers)'{-e,--exclude-headers}'[no headers in output]' \
        '(-s --skip-mode)'{-s,--skip-mode}'+[skip mode]:mode:(none if-not-modified)' \
        '(-M --max-size)'{-M,--max-size}'+[max bytes]:n:' \
        '(-T --max-time)'{-T,--max-time}'+[timeout (sec)]:n:' \
        '*:gemini URL:_urls'
}

_gemget "$@"
