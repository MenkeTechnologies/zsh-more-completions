#compdef gh-models
# Documentation: https://github.com/github/gh-models
# Source: github/gh-models cmd/* — GitHub Models gh extension for AI model inference.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gm_cmds
_gm_cmds=(
    'eval:run evaluation tests against a model with a .prompt.yml file'
    'generate:generate prompts and test data'
    'list:list available models'
    'run:run inference with the specified model'
    'view:view details about a model'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'gh-models command' _gm_cmds && ret=0
        ;;
    args)
        case $words[1] in
            run)
                _arguments \
                    '--file=[path to a .prompt.yml file]:file:_files -g "*.prompt.yml"' \
                    '*--var=[template variable as name=value]:var:_default' \
                    '--max-tokens=[limit the maximum tokens for the response]:n:_default' \
                    '--temperature=[controls randomness (lower = more deterministic)]:temp:_default' \
                    '--top-p=[controls text diversity via cumulative probability]:p:_default' \
                    '--system-prompt=[system prompt for the model]:prompt:_default' \
                    '--org=[organization to attribute usage to]:org:_default' \
                    '*::args:_default' \
                    && ret=0
                ;;
            eval)
                _arguments \
                    '--json[output results in JSON format]' \
                    '--org=[organization to attribute usage to]:org:_default' \
                    '*:prompt-file:_files -g "*.prompt.yml"' \
                    && ret=0
                ;;
            generate)
                _arguments \
                    '--org=[organization to attribute usage to]:org:_default' \
                    '--effort=[effort level]:level:(min low medium high)' \
                    '--groundtruth-model=[model for generating groundtruth outputs]:model:_default' \
                    '--session-file=[session file to load existing context from]:file:_files' \
                    '*--var=[template variable as name=value]:var:_default' \
                    '--http-log=[HTTP log file]:file:_files' \
                    '--instruction-intent=[system instruction for intent generation]:text:_default' \
                    '--instruction-inputspec=[system instruction for input spec generation]:text:_default' \
                    '--instruction-outputrules=[system instruction for output rules generation]:text:_default' \
                    '--instruction-inverseoutputrules=[system instruction for inverse output rules]:text:_default' \
                    '--instruction-tests=[system instruction for tests generation]:text:_default' \
                    '*:prompt-file:_files -g "*.prompt.yml"' \
                    && ret=0
                ;;
            view)
                _arguments '1:model:_default' && ret=0
                ;;
        esac
        ;;
esac

return ret
