#compdef peaclock
# Documentation: https://github.com/octobanana/peaclock/blob/master/doc/help.txt
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help information]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--license[show license]' \
  '(-u --config)'{-u+,--config=}'[initialization config file (use NONE to skip)]:file:_files' \
  '--config-dir=[config directory (use NONE to skip)]:directory:_files -/' \
  '--colour=[color output mode]:mode:(on off auto)' \
  '*:file:_files'
