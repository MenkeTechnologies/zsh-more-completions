#compdef mount_sysctlfs
# Documentation: man mount_sysctlfs(8)
# Source: netbsd/src usr.sbin/puffs/mount_sysctlfs — mount sysctl tree (C, puffs).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r[raw mode, display node contents as binary]' \
    '-o+[mount options]:mntopts:_default' \
    '1:filesystem type (sysctlfs):_default' \
    '2:mount point:_files -/' \
    && ret=0

return ret
