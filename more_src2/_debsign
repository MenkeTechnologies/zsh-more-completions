#compdef debsign
# Documentation: https://manpages.debian.org/debsign
# Source: debian/devscripts scripts/debsign.sh — GPG-sign Debian .dsc/.buildinfo/.changes files (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r+[remote host]:user@host:_default' \
    '-k+[GPG key ID]:keyid:_default' \
    '-p+[signing command]:cmd:_command_names' \
    '-e+[maintainer]:maintainer:_default' \
    '-m+[maintainer (same as -e)]:maintainer:_default' \
    '-S[use changes file made for source-only upload]' \
    '-a+[Debian target architecture]:arch:_default' \
    '-t+[GNU target architecture]:target:_default' \
    '--multi[use most recent multiarch .changes]' \
    '(--no-re-sign)--re-sign[re-sign already-signed file]' \
    '(--re-sign)--no-re-sign[do not re-sign already-signed file]' \
    '--debs-dir=-[directory containing .deb files]:dir:_files -/' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '--help[show help]' \
    '--version[show version]' \
    '*:dsc/buildinfo/changes file:_files -g "*.{dsc,changes,buildinfo}"' \
    && ret=0

return ret
