#compdef mstprivhost mlxprivhost
# Documentation: https://docs.nvidia.com/networking/display/mftv4250/mlxprivhost+-+nic+configuration+by+the+host+restriction+tool+(zero+trust+mode)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mstprivhost (a.k.a. mlxprivhost): NIC configuration by the host restriction
# tool. BlueField-only.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'r:restrict the host'
  'restrict:restrict the host'
  'p:un-restrict (privileged)'
  'privilege:un-restrict (privileged)'
  'q:query current state'
  'query:query current state'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dev)'{-d,--dev}'[device]:dev:' \
  '--disable_port_owner[disable port owner]' \
  '--disable_rshim[disable rshim]' \
  '--disable_tracer[disable tracer]' \
  '--disable_counter_rd[disable counter read]' \
  '--disable_port_rst[disable port reset]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mstprivhost command' commands && ret=0 ;;
esac
return ret
