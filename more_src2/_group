#compdef group
# _group — OpenBSD group(8) frontend (sysadmin tool wrapping groupadd/groupmod/groupdel/groupinfo via add/mod/del/info subcommands)
# upstream: https://github.com/openbsd/src (usr.sbin/user — shares user(8) source tree)
# Subcommands + flags from usr.sbin/user/group.8 on tip.

_group() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'group subcommand' \
                '(add:create a new group mod:modify an existing group del:delete a group info:show group info)'
            ;;
        args)
            case $line[1] in
                add)
                    _arguments \
                        '-o[allow duplicate gid]' \
                        '-v[verbose]' \
                        '-g+[gid]:gid:' \
                        '1:group:_groups'
                    ;;
                mod)
                    _arguments \
                        '-o[allow duplicate gid]' '-v[verbose]' \
                        '-g+[new gid]:gid:' \
                        '-n+[new name]:newname:' \
                        '1:group:_groups'
                    ;;
                del) _arguments '-v[verbose]' '1:group:_groups' ;;
                info) _arguments '-e[exit-status only]' '-v[verbose]' '1:group:_groups' ;;
            esac
            ;;
    esac
}

_group "$@"
