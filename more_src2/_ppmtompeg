#compdef ppmtompeg
# Documentation: man ppmtompeg (Netpbm)
# Source: encode a sequence of Netpbm frames into an MPEG-1 video.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-stat+[append statistics to FILE]:file:_files' \
    '-quiet+[suppress every Nth status line]:n:' \
    '-realquiet[completely silent]' \
    '-no_frame_summary[suppress per-frame summary]' \
    '-snr[compute SNR]' \
    '-bit_rate+[constant bit rate (bits/sec)]:bps:' \
    '-buffer_size+[buffer size]:bytes:' \
    '-float_dct[use float DCT]' \
    '-gop[encode only one GOP]' \
    '-combine_gops+[combine GOP files]:dir:_files -/' \
    '-combine_frames+[combine frame files]:dir:_files -/' \
    '-nice[run nicer]' \
    '1:parameter file:_files' \
    && ret=0

return ret
