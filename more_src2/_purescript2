#compdef purescript2 purs2
# _purescript2 — Phil Freeman PureScript Foundation purescript2 CLI command-line frontend wrapping the PureScript a small strongly typed programming language with expressive types written in and inspired by Haskell that compiles to JavaScript open-source written in Haskell originally Phil Freeman now PureScript Foundation strongly-typed functional Haskell-inspired compiles to JavaScript erl IR Spago Bower Pulp compile bundle docs ide publish repl version hierarchy graph hash output verbose-errors json-errors purs-args codegen no-prefix dump-corefn (Phil Freeman PureScript Foundation team, Haskell); custom argparse
# upstream: https://www.purescript.org/

_purescript2() {
    local -a sub=(
        'compile:Compile PureScript source files'
        'bundle:Bundle compiled JavaScript modules'
        'docs:Generate documentation'
        'graph:Generate module dependency graph'
        'hierarchy:Generate type class hierarchy'
        'ide:Start the language server'
        'publish:Generate publication for Pursuit'
        'repl:Enter the REPL'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--include=+[dir]:dir:_files -/' \
        '*--include=+[dir]:dir:_files -/' \
        '-I+[include]:dir:_files -/' \
        '*-I+[include]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '-o+[output]:dir:_files -/' \
        '--codegen=+[c]:c:(js sourcemaps corefn docs json default)' \
        '*--codegen=+[c]:c:(js sourcemaps corefn docs json default)' \
        '--no-prefix[no prefix comment]' \
        '--verbose-errors[verbose errors]' \
        '--json-errors[JSON errors]' \
        '--print-version[print version]' \
        '--print-coding-errors[print coding errors]' \
        '--dump-corefn[dump corefn]' \
        '--source-maps[source maps]' \
        '--strict[strict]' \
        '--censor-codes=+[codes]:str:' \
        '--censor-warnings[censor warnings]' \
        '--censor-lib[censor lib warnings]' \
        '--censor-src[censor src warnings]' \
        '--show-source-location[show source location]' \
        '--colour-output[colour output]' \
        '-w[watch mode]' \
        '--watch[watch mode]' \
        '--editor-mode[editor mode]' \
        '--config-file=+[file]:file:_files' \
        '--main=+[module]:str:' \
        '-m+[main]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--source-globs[source globs]' \
        '--source-globs-file=+[file]:file:_files' \
        '--module=+[name]:str:' \
        '--no-cache[no cache]' \
        '--no-modules[no modules]' \
        '--manifest=+[file]:file:_files' \
        '--purs-args=+[args]:str:' \
        '--censor-stats[censor stats]' \
        '--editor=+[name]:str:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--output-port=+[port]:n:' \
        '--polling[polling]' \
        '--log-level=+[l]:l:(all none debug info warn error)' \
        '--editor-port=+[port]:n:' \
        '--editor-listen-host=+[host]:_hosts' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'purs subcommand' sub ;;
        args)
            case $words[1] in
                compile|bundle|docs|graph|hierarchy|publish) _arguments '*:purs file:_files -g "*.purs"' ;;
                repl|ide) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_purescript2 "$@"
