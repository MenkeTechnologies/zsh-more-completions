#compdef pamtester
# Documentation: https://manpages.debian.org/bookworm/pamtester/pamtester.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm pamtester(1) manpage OPTIONS.
# Removed from prior file: fabricated -h/--help/-V/--version generic flags
# and bogus man.archlinux.org search URL.

# pamtester: test PAM authentication modules
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-I --item)*'{-I+,--item=}'[provide item=value to authentication module]:item=value:' \
  '(-E --env)*'{-E+,--env=}'[set environment var=value]:var=value:' \
  '1:service:_files -W /etc/pam.d' \
  '2:user:_users' \
  '3:operation:(authenticate acct_mgmt open_session close_session chauthtok)' \
  '*::trailing:' && ret=0
return ret
