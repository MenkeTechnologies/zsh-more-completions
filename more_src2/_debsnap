#compdef debsnap
# Documentation: https://manpages.debian.org/debsnap
# Source: debian/devscripts scripts/debsnap.pl — fetch source/binary packages from snapshot.debian.org (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    {-v,--verbose}'[verbose output]' \
    {-d+,--destdir=}'[destination directory]:dir:_files -/' \
    {-f,--force}'[overwrite existing files]' \
    '--first=-[earliest version to fetch]:version:_default' \
    '--last=-[latest version to fetch]:version:_default' \
    {-l,--list}'[list available versions only]' \
    '--binary[fetch binary packages]' \
    '*'{-a+,--architecture=}'[architecture(s)]:arch:(amd64 i386 arm64 armel armhf mips mips64el ppc64el riscv64 s390x source all)' \
    '1:package name:_default' \
    '*::versions:_default' \
    && ret=0

return ret
