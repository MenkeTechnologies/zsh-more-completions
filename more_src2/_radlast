#compdef radlast
# _radlast — FreeRADIUS radlast (last(1)-style view built from radacct files: per-user RADIUS session history with duration, NAS, source IP and termination reason; -f input file, -n count, -t terminal, -h help, -v version; positional arguments are user names to filter)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radlast.c on tip.

_radlast() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-f+[input file]:file:_files' \
        '-n+[count]:n:' \
        '-t+[terminal]:tty:' \
        '*:user:_users'
}

_radlast "$@"
