#compdef pngcp
# Documentation: https://www.libpng.org/pub/png/libpng-manual.txt
# Source: glennrp/libpng contrib/tools/pngcp.c — copy and re-encode PNG files (C, --long-options).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--verbose[verbose output]' \
    '--no-verbose[disable verbose]' \
    '--warnings[show warnings]' \
    '--no-warnings[suppress warnings]' \
    '--errors[show errors]' \
    '--no-errors[suppress errors]' \
    '--quiet[quiet mode]' \
    '--no-quiet[disable quiet]' \
    '--strict[strict mode]' \
    '--no-strict[disable strict]' \
    '--log[enable logging]' \
    '--no-log[disable logging]' \
    '--continue[continue on errors]' \
    '--no-continue[stop on errors]' \
    '--sizes[print sizes]' \
    '--no-sizes[do not print sizes]' \
    '--search[search compression options]' \
    '--no-search[disable search]' \
    '--nowrite[do not write output]' \
    '--no-nowrite[enable writing]' \
    '--compression=-[compression level]:level:_default' \
    '--text-compression=-[text compression level]:level:_default' \
    '--ICC-profile-compression=-[ICC profile compression level]:level:_default' \
    '--windowBits=-[IDAT zlib window bits]:bits:_default' \
    '--text-windowBits=-[text zlib window bits]:bits:_default' \
    '--ICC-profile-windowBits=-[ICC profile window bits]:bits:_default' \
    '--IDAT-size=-[max IDAT chunk size]:size:_default' \
    '--log-depth=-[search log depth]:depth:_default' \
    '*:PNG files (last is output dir or file):_files -g "*.{png,PNG}"' \
    && ret=0

return ret
