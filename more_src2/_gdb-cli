#compdef gdb-cli
# _gdb-cli — GNU gdb GNU debugger CLI alias (GNU team, C); custom argparse
# upstream: https://sourceware.org/git/binutils-gdb.git

_gdb-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--configuration[print configuration details]' \
        '-symbols=+[symbols file]:file:_files' \
        '-s+[symbols file]:file:_files' \
        '-exec=+[executable]:file:_files' \
        '-e+[executable]:file:_files' \
        '-se=+[symbol+executable]:file:_files' \
        '-core=+[core file]:file:_files' \
        '-c+[core file]:file:_files' \
        '-pid=+[pid]:pid:_pids' \
        '-p+[pid]:pid:_pids' \
        '-command=+[command file]:file:_files' \
        '-x+[command file]:file:_files' \
        '-eval-command=+[command]:str:' \
        '-ex+[command]:str:' \
        '-init-command=+[init command file]:file:_files' \
        '-ix+[init command file]:file:_files' \
        '-init-eval-command=+[init command]:str:' \
        '-iex+[init command]:str:' \
        '-directory=+[directory]:dir:_files -/' \
        '-d+[directory]:dir:_files -/' \
        '-r[read script via shell]' \
        '-readnow[fully read symbol files]' \
        '-readnever[never read symbol files]' \
        '-tty=+[tty]:file:_files' \
        '-t+[tty]:file:_files' \
        '-nx[do not read .gdbinit]' \
        '-n[do not read .gdbinit]' \
        '-nh[do not read ~/.gdbinit]' \
        '-quiet[no introductory messages]' \
        '-silent[no introductory messages]' \
        '-q[no introductory messages]' \
        '-batch[run in batch mode]' \
        '-batch-silent[batch silent]' \
        '-return-child-result[return child result]' \
        '-fullname[output for emacs]' \
        '-f[output for emacs]' \
        '-annotate=+[level]:n:' \
        '-statistics[print statistics on exit]' \
        '-windows[use GUI interface]' \
        '-w[use GUI interface]' \
        '-tui[use TUI interface]' \
        '-nw[do not use GUI]' \
        '-write[write to executable]' \
        '-cd=+[directory]:dir:_files -/' \
        '-data-directory=+[directory]:dir:_files -/' \
        '-D+[directory]:dir:_files -/' \
        '-baud=+[bps]:n:' \
        '-b+[bps]:n:' \
        '-l+[timeout]:n:' \
        '-multi[multi-process mode]' \
        '-interpreter=+[name]:m:(mi mi1 mi2 mi3 console tui)' \
        '-i+[name]:m:(mi mi1 mi2 mi3 console tui)' \
        '*:program:_files'
}

_gdb-cli "$@"
