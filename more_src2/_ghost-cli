#compdef ghost-cli
# _ghost-cli — Tryghost Ghost professional publishing platform installer CLI alias (TryGhost team, Node); commander
# upstream: https://github.com/TryGhost/Ghost-CLI

_ghost-cli() {
    local -a sub=(
        'install:install ghost in current dir'
        'setup:setup ghost installation'
        'start:start ghost'
        'stop:stop ghost'
        'restart:restart ghost'
        'run:run ghost in current console'
        'doctor:check system'
        'update:update ghost'
        'config:edit ghost config'
        'log:show ghost logs'
        'ls:list ghost installs'
        'backup:create backup'
        'restore:restore backup'
        'buster:bust cache'
        'check-update:check for updates'
        'uninstall:uninstall ghost'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-V[verbose]' \
        '--no-color[no color]' \
        '--no-prompt[no prompt]' \
        '--development[dev mode]' \
        '-D[dev mode]' \
        '--auto[auto setup]' \
        '-A[auto setup]' \
        '--dir=+[dir]:dir:_files -/' \
        '-d+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ghost subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '1:version:' \
                    '--zip=+[zip url]:url:_urls' \
                    '--archive=+[archive]:file:_files' \
                    '--v1[v1]' \
                    '--check-empty[check empty dir]' \
                    '--dir=+[dir]:dir:_files -/' \
                    '-d+[dir]:dir:_files -/' \
                    '--no-stack[skip stack check]' \
                    '--no-setup[skip setup]' \
                    '--no-start[do not auto-start]' \
                    '--local[local mode]' \
                    '--db=+[db]:db:(mysql sqlite3)' \
                    '--dbhost=+[db host]:host:_hosts' \
                    '--dbuser=+[db user]:user:_users' \
                    '--dbpass=+[db password]:str:' \
                    '--dbname=+[db name]:str:' \
                    '--url=+[url]:url:_urls' \
                    '--port=+[port]:port:' \
                    '--process=+[process]:p:(systemd local)' \
                    '--stack[setup stack]' \
                    '--mail=+[mail]:m:(SMTP Sendmail Direct)' ;;
                setup) _arguments \
                    '--no-stack[skip stack]' \
                    '--no-setup-linux-user[skip linux user]' \
                    '--no-setup-nginx[skip nginx]' \
                    '--no-setup-ssl[skip ssl]' \
                    '--no-setup-mysql[skip mysql]' \
                    '--no-setup-systemd[skip systemd]' \
                    '--no-start[do not start]' \
                    '--local[local mode]' \
                    '--db=+[db]:db:(mysql sqlite3)' \
                    '--dbhost=+[db host]:host:_hosts' \
                    '--dbuser=+[db user]:user:_users' \
                    '--dbpass=+[db password]:str:' \
                    '--dbname=+[db name]:str:' \
                    '--url=+[url]:url:_urls' \
                    '--port=+[port]:port:' ;;
                update) _arguments \
                    '1:version:' \
                    '--rollback[rollback]' \
                    '--force[force]' \
                    '--zip=+[zip url]:url:_urls' \
                    '--v1[v1]' \
                    '--no-restart[no restart]' \
                    '--no-stop-on-error[no stop on error]' ;;
                start|stop|restart) _arguments \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--enable[enable on boot]' \
                    '-e[enable on boot]' \
                    '--disable[disable on boot]' \
                    '-D[disable on boot]' ;;
                log) _arguments \
                    '1:install name:' \
                    '--number=+[lines]:n:' \
                    '-n+[lines]:n:' \
                    '--follow[follow]' \
                    '-f[follow]' \
                    '--error[errors only]' \
                    '-e[errors only]' ;;
                config) _arguments \
                    '--db=+[db]:db:(mysql sqlite3)' \
                    '--port=+[port]:port:' \
                    '--url=+[url]:url:_urls' ;;
            esac
            ;;
    esac
}

_ghost-cli "$@"
