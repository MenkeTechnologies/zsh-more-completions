#compdef msgchk
# Documentation: man msgchk(1)
# Source: nmh uip/msgchk.c (master) — check mail availability (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-date -nodate)-date[show date of last message]' \
    '(-date -nodate)-nodate[no date]' \
    '*-notify+[notify type]:type:(new mail all)' \
    '*-nonotify+[do not notify type]:type:(new mail all)' \
    '-host+[POP host]:host:_hosts' \
    '-user+[POP username]:user:_default' \
    '-port+[port name/number]:port:_default' \
    '-version[show version]' \
    '-help[show help]' \
    '-snoop[show server transcript]' \
    '-sasl[use SASL]' \
    '-saslmech+[SASL mechanism]:mech:_default' \
    '-proxy+[proxy command]:cmd:_command_names -e' \
    '*:username:_users' \
    && ret=0

return ret
