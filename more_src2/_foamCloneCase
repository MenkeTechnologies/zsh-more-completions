#compdef foamCloneCase
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamCloneCase — copy a case directory with optional time / processor filtering.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-add[copy 1 or more additional files/directories from source case]:files:_files' \
    '-help[print usage]' \
    '-latestTime[clone the latest time directory]' \
    '-no-orig[do not copy 0.orig directory]' \
    '-no-scripts[do not copy shell scripts]' \
    '-processor[copy processor* directories of a decomposed case]' \
    '-startFrom[set the starting time directory name]:time:' \
    '-template[search for source case in template directory paths]' \
    '*:src then dest case:_directories' \
    && ret=0

return ret
