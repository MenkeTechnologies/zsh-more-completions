#compdef R-CMD-build R-CMD-Build
# _R-CMD-build — R Core Team R CMD build build R package source tarball ready for submission (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-build() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-l+[library path]:dir:_files -/' \
        '--library=+[library path]:dir:_files -/' \
        '--force[force]' \
        '--no-build-vignettes[no build vignettes]' \
        '--no-resave-data[no resave data]' \
        '--keep-empty-dirs[keep empty dirs]' \
        '--no-manual[no manual]' \
        '--md5[md5 checksums]' \
        '--resave-data[resave data]' \
        '--no-byte-compile[no byte compile]' \
        '--no-clean-on-error[no clean on error]' \
        '--use-valgrind[use valgrind]' \
        '--compact-vignettes=+[type]:t:(no yes both gs qpdf)' \
        '--output=+[output file]:file:_files -g "*.tar.gz"' \
        '*:package source dir:_files -/'
}

_R-CMD-build "$@"
