#compdef gmtselect
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtselect.html
# Source: GenericMappingTools/gmt classic-mode gmtselect — geospatial record filter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[min coast feature area (km²)]:opts:_default' \
    '-C+[keep records within distance of point list]:opts:_default' \
    '-D+[GSHHG coastline resolution]:res:(full high intermediate low crude)' \
    '-E+[on-boundary classification]:opts:_default' \
    '-F+[keep records inside closed polygons]:file:_files' \
    '-G+[pass records within valid grid areas]:file:_files' \
    '-I+[reverse sense of selection tests]:tests:_default' \
    '-J+[projection]:proj:_default' \
    '-L+[records within distance of line segments]:opts:_default' \
    '-N+[political/geographic feature filter]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-Z+[filter by value range in columns]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
