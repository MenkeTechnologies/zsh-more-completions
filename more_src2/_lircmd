#compdef lircmd
# Documentation: https://manpages.debian.org/bookworm/lirc/lircmd.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm lircmd(8) manpage OPTIONS section.

# lircmd: LIRC mouse daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-n --nodaemon)'{-n,--nodaemon}'[do not fork to background]' \
  '(-s --socket)'{-s,--socket=}'[lircd socket path]:path:_files' \
  '(-O --options-file)'{-O,--options-file=}'[alternative options file]:file:_files' \
  '(-u --uinput)'{-u,--uinput}'[generate Linux input events via uinput]' \
  '(-D --loglevel)'{-D,--loglevel=}'[log level]:level:(error warning info notice debug trace trace1 trace2)' \
  '*:config file:_files' && ret=0
return ret
