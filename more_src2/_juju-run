#compdef juju-run
# Documentation: https://documentation.ubuntu.com/juju/3.6/reference/resource-compute/list-of-commands-available-on-a-compute-resource-provisioned-by-juju/juju-exec/
# Reference accessed: 2026-05-19
# Verified: upstream juju-exec/juju-run docs at the URL above.

# juju-run (legacy name for juju-exec): run commands inside a Juju unit hook context
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--force-remote-unit[skip remote unit validation for the relation context]' \
  '--no-context[run the command outside any unit context]' \
  '--operator[run on the operator rather than the workload (K8s charms)]' \
  '(-r --relation)'{-r+,--relation=}'[run within a specific relation context]:relation:' \
  '--remote-app=[target a specific remote application in the relation context]:app:' \
  '--remote-unit=[target a specific remote unit in the relation context]:unit:' \
  '-u+[specify the unit name explicitly]:unit:' \
  '*:command:' && ret=0
return ret
