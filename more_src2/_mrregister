#compdef mrregister
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrregister.html
# Source: MRtrix3/mrtrix3 cmd/mrregister.cpp — rigid/affine/non-linear inter-subject registration (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-type+[registration type]:choice:(rigid affine nonlinear rigid_affine rigid_nonlinear affine_nonlinear rigid_affine_nonlinear)' \
    '-transformed+[image1 transformed to image2 space]:image:_files' \
    '-transformed_midway+[image1 and image2 in midway space]:image1:_files:image2:_files' \
    '-mask1+[image1 mask for optimisation]:filename:_files -g "*.{nii,nii.gz,mif}"' \
    '-mask2+[image2 mask for optimisation]:filename:_files -g "*.{nii,nii.gz,mif}"' \
    '-mc_weights+[multi-contrast image weights]:weights:_default' \
    '-rigid+[output rigid transformation matrix]:file:_files' \
    '-rigid_1tomidway+[rigid transform image1→midway]:file:_files' \
    '-rigid_2tomidway+[rigid transform image2→midway]:file:_files' \
    '-rigid_init_translation+[rigid translation init mode]:mode:(mass geometric none)' \
    '-rigid_init_rotation+[rigid rotation init mode]:mode:(search moments none)' \
    '-rigid_init_matrix+[init rigid from matrix]:file:_files' \
    '-rigid_scale+[multi-resolution rigid scale factors]:factors:_default' \
    '-rigid_niter+[max rigid iterations per scale]:n:_default' \
    '-rigid_metric+[rigid metric]:type:(diff ncc)' \
    '-rigid_metric.diff.estimator+[rigid diff estimator]:type:(l1 l2 lp none)' \
    '-rigid_lmax+[rigid SH lmax per scale]:n:_default' \
    '-affine+[output affine transformation matrix]:file:_files' \
    '-affine_1tomidway+[affine transform image1→midway]:file:_files' \
    '-affine_2tomidway+[affine transform image2→midway]:file:_files' \
    '-affine_init_translation+[affine translation init mode]:mode:(mass geometric none)' \
    '-affine_init_rotation+[affine rotation init mode]:mode:(search moments none)' \
    '-affine_init_matrix+[init affine from matrix]:file:_files' \
    '-affine_scale+[multi-resolution affine scale factors]:factors:_default' \
    '-affine_niter+[max affine iterations per scale]:n:_default' \
    '-affine_metric+[affine metric]:type:(diff ncc)' \
    '-affine_metric.diff.estimator+[affine diff estimator]:type:(l1 l2 lp none)' \
    '-affine_lmax+[affine SH lmax per scale]:n:_default' \
    '-nl_warp+[output forward and inverse warps]:warp1:_files:warp2:_files' \
    '-nl_warp_full+[output full 5D warp]:image:_files' \
    '-nl_init+[init non-linear from previous warp]:image:_files' \
    '-nl_scale+[multi-resolution NL scale factors]:factors:_default' \
    '-nl_niter+[max NL iterations per scale]:n:_default' \
    '-nl_update_smooth+[NL update smoothing stdev]:value:_default' \
    '-nl_disp_smooth+[NL displacement field smoothing stdev]:value:_default' \
    '-nl_grad_step+[NL gradient step]:value:_default' \
    '-nl_lmax+[NL SH lmax per scale]:n:_default' \
    '-diagnostics_image+[diagnostics image prefix]:prefix:_default' \
    '*:images (image1 image2 + optional contrast images):_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
