#compdef mcrl22lps lps2lts pbes2bool pbessolve mcrl2i ltsconvert ltsgraph ltsview ltscompare lps2pbes besconvert bessolve
# Documentation: https://www.mcrl2.org/web/user_manual/tools/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (mcrl22lps)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-d --debug)'{-d,--debug}'[debug]' \
      '(-e --check-only)'{-e,--check-only}'[only check syntax]' \
      '(-D --delta)'{-D,--delta}'[add true->delta summands]' \
      '(-o --no-rewrite)'{-o,--no-rewrite}'[disable data term rewriting]' \
      '(-l --lin-method)'{-l+,--lin-method=}'[linearisation method]:m:(regular regular2 stack)' \
      '(-c --cluster)'{-c,--cluster}'[cluster summands with identical labels]' \
      '(-n --no-cluster)'{-n,--no-cluster}'[no clustering of intermediate LPS]' \
      '(-m --no-sumelm)'{-m,--no-sumelm}'[skip sum elimination]' \
      '(-z --no-alpha)'{-z,--no-alpha}'[disable alphabet reductions]' \
      '(-a --statenames)'{-a,--statenames}'[use process names in state vars]' \
      '(-w --newstate)'{-w,--newstate}'[encode state vars as enumerated types]' \
      '(-b --binary)'{-b,--binary}'[binary case functions]' \
      '(-f --no-globvars)'{-f,--no-globvars}'[instantiate global vars with constants]' \
      '(-g --no-deltaelm)'{-g,--no-deltaelm}'[do not remove spurious delta summands]' \
      '--no-constelm[skip constant elimination]' \
      '--balance-summands[balance summand trees before linearising]' \
      '(-T --timed)'{-T,--timed}'[preserve timing information]' \
      '(-r --rewriter)'{-r+,--rewriter=}'[rewrite strategy]:r:(jitty jittyc jittyp)' \
      '(-Q --qlimit)'{-Q+,--qlimit=}'[quantifier enumeration limit]:n:' \
      '*: :_files -g "*.mcrl2 *.lps"' && ret=0 ;;
  (lps2lts)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-c --cached)'{-c,--cached}'[cached enumeration]' \
      '(-D --deadlock)'{-D,--deadlock}'[detect deadlock]' \
      '(-l --max)'{-l+,--max=}'[max states]:n:' \
      '(-r --rewriter)'{-r+,--rewriter=}'[rewriter]:r:(jitty jittyc jittyp)' \
      '(-s --strategy)'{-s+,--strategy=}'[strategy]:s:(b d p q r)' \
      '(-t --trace)'{-t+,--trace=}'[traces n]:n:' \
      '*: :_files -g "*.lps *.lts *.aut *.fsm *.dot"' && ret=0 ;;
  (pbes2bool|pbessolve|bessolve)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-c --counter-example)'{-c,--counter-example}'[counter example]' \
      '(-r --rewriter)'{-r+,--rewriter=}'[rewriter]:r:(jitty jittyc)' \
      '(-s --search)'{-s+,--search=}'[search]:s:(breadth depth)' \
      '*: :_files -g "*.pbes *.bes"' && ret=0 ;;
  (ltsconvert|ltsgraph|ltsview|ltscompare)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-q --quiet)'{-q,--quiet}'[quiet]' \
      '(-i --in)'{-i+,--in=}'[input format]:fmt:(aut fsm lts dot)' \
      '(-o --out)'{-o+,--out=}'[output format]:fmt:(aut fsm lts dot)' \
      '(-e --equivalence)'{-e+,--equivalence=}'[equivalence]:e:(none bisim branching-bisim weak-bisim divergence-preserving-branching-bisim trace weak-trace tau-star)' \
      '*: :_files -g "*.lts *.aut *.fsm *.dot"' && ret=0 ;;
  (mcrl2i|lps2pbes|besconvert)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '--version[show version]' \
      '(-v --verbose)'{-v,--verbose}'[verbose]' \
      '(-r --rewriter)'{-r+,--rewriter=}'[rewriter]:r:(jitty jittyc)' \
      '*: :_files' && ret=0 ;;
esac

return ret
