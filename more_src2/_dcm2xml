#compdef dcm2xml
# Documentation: https://support.dcmtk.org/docs-snapshot/dcm2xml.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmdata/apps/dcm2xml.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmdata/apps/dcm2xml.cc OFCommandLine setup + docs/man/dcm2xml.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(+M --load-all)'{+M,--load-all}'[load very long tag values (e.g. pixel data)]' \
  '(-M --load-short)'{-M,--load-short}'[do not load very long values (default)]' \
  '(+R --max-read-length)'{+R+,--max-read-length=}'[set threshold for long values in kbytes]:kbytes:' \
  '(+Cr --charset-require)'{+Cr,--charset-require}'[require declaration of extended charset (default)]' \
  '(+Ca --charset-assume)'{+Ca+,--charset-assume=}'[assume charset if no extended charset declared]:charset:' \
  '(+Cc --charset-check-all)'{+Cc,--charset-check-all}'[check all data elements with string values]' \
  '(+U8 --convert-to-utf8)'{+U8,--convert-to-utf8}'[convert all affected element values to UTF-8]' \
  '(-dtk --dcmtk-format)'{-dtk,--dcmtk-format}'[output in DCMTK-specific format (default)]' \
  '(-nat --native-format)'{-nat,--native-format}'[output in Native DICOM Model format (part 19)]' \
  '(+Xn --use-xml-namespace)'{+Xn,--use-xml-namespace}'[add XML namespace declaration to root element]' \
  '(+Xd --add-dtd-reference)'{+Xd,--add-dtd-reference}'[add reference to document type definition (DTD)]' \
  '(+Xe --embed-dtd-content)'{+Xe,--embed-dtd-content}'[embed document type definition into XML document]' \
  '(+Xf --use-dtd-file)'{+Xf+,--use-dtd-file=}'[use specified DTD file (only with +Xe)]:file:_files' \
  '(+Wn --write-element-name)'{+Wn,--write-element-name}'[write name of the DICOM data elements (default)]' \
  '(-Wn --no-element-name)'{-Wn,--no-element-name}'[do not write name of the DICOM data elements]' \
  '(+Wb --write-binary-data)'{+Wb,--write-binary-data}'[write binary data of OB and OW elements]' \
  '(+Eh --encode-hex)'{+Eh,--encode-hex}'[encode binary data as hex numbers]' \
  '(+Eu --encode-uuid)'{+Eu,--encode-uuid}'[encode binary data as a UUID reference]' \
  '(+Eb --encode-base64)'{+Eb,--encode-base64}'[encode binary data as Base64 (RFC 2045, MIME)]' \
  '1:dcmfile-in:_files' \
  '2:xmlfile-out:_files'
