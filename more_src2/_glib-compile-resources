#compdef glib-compile-resources
# Documentation: glib-compile-resources --help (GLib)
# Source: GLib glib-compile-resources — compile a resource specification into a .gresource binary or C source.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(- *)--version[show version and exit]' \
    '--target=[output file name]:file:_files' \
    '*--sourcedir=[directory to load referenced files from]:dir:_files -/' \
    '(--generate --generate-header --generate-source --generate-dependencies)--generate[generate output by target extension]' \
    '(--generate --generate-header --generate-source --generate-dependencies)--generate-header[generate C header]' \
    '(--generate --generate-header --generate-source --generate-dependencies)--generate-source[generate C source code]' \
    '(--generate --generate-header --generate-source --generate-dependencies)--generate-dependencies[generate dependency list]' \
    '--dependency-file=[name of dependency file to generate]:file:_files' \
    '--generate-phony-targets[include phony targets in dependency file]' \
    '--manual-register[do not auto-create+register resource]' \
    '--internal[do not export functions; declare G_GNUC_INTERNAL]' \
    '--external-data[do not embed resource data; assume external linkage]' \
    '--c-name=[C identifier name used for generated code]:identifier:' \
    '(-C --compiler)'{-C,--compiler=}'[target C compiler command]:cmd:_command_names -e' \
    '*:gresource.xml input:_files -g "*.{gresource.xml,xml}"' \
    && ret=0

return ret
