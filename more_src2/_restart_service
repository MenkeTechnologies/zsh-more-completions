#compdef restart_service
# Documentation: https://github.com/MarcosNicolau/scripts
# Reference accessed: 2026-05-20
# Verified: upstream completion at the URL above.
# STUB: small personal-script wrapper for `systemctl restart <unit>`.

_restart_service() {
  local -a args=(
      # (-) makes an option mutually exclusive with all other options. 
      '1:filename:->files'
  )

  _arguments $args

  case $state in
    files)
       _path_files -W /etc/systemd/system/ -g '*.service' -S /
       _path_files -W /etc/systemd/system/ -g '*.gpg(:r)' -S ' '
      ;;
  esac
}
