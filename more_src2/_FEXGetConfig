#compdef FEXGetConfig
# _FEXGetConfig — inspect resolved FEX-Emu configuration (FEX-Emu/FEX)
# upstream: https://github.com/FEX-Emu/FEX
# Flags from Source/Tools/FEXGetConfig/Main.cpp (cpp-optparse).

_FEXGetConfig() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--install-prefix[print the FEX install prefix]'
        '--app=[load an application profile if it exists]:app:'
        '--current-rootfs[print the directory containing the current rootfs]'
        '--tso-emulation-info[print how FEX emulates the x86-TSO memory model (aarch64)]'
        '--test-fault-granularity[show SIGBUS fault granularity (aarch64)]'
        '--identification-reg-info[print aarch64 identification registers]'
        '--version[print the installed FEX-Emu version]'
    )
    _arguments -s $args
}

_FEXGetConfig "$@"
