#compdef gephi
# _gephi — Gephi Consortium gephi network analysis platform CLI for loading GEXF GraphML CSV social network and biological graph files with layout algorithms ForceAtlas2 Yifan-Hu Fruchterman Reingold (gephi team, Java); Java args
# upstream: https://github.com/gephi/gephi

_gephi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--clean[clean workspace]' \
        '--branding=+[name]:str:' \
        '--cachedir=+[dir]:dir:_files -/' \
        '--userdir=+[dir]:dir:_files -/' \
        '--locale=+[locale]:l:(en_US en_GB de_DE fr_FR es_ES it_IT ja_JP zh_CN zh_TW ru_RU pt_BR)' \
        '-J+[jvm option]:str:' \
        '-jdkhome=+[jdk dir]:dir:_files -/' \
        '--laf=+[look and feel]:l:(default metal nimbus gtk windows mac aqua flatlight flatdark)' \
        '--fontsize=+[N]:n:' \
        '--console[console mode]' \
        '--nosplash[no splash]' \
        '--open=+[file]:file:_files -g "*.gexf *.graphml *.gml *.dl *.dot *.gv *.gdf *.net *.pajek *.csv *.tlp *.tnef *.gefx *.vna *.spreadsheet"' \
        '--export=+[file]:file:_files -g "*.png *.svg *.pdf *.gexf *.graphml *.gml *.gv *.csv *.gdf"' \
        '*:graph file:_files -g "*.gexf *.graphml *.gml *.dl *.dot *.gv *.gdf *.net *.pajek *.csv *.tlp"'
}

_gephi "$@"
