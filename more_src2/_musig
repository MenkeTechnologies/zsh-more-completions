# musig — Shazam-like audio fingerprint database (Go, 442★)
#
# upstream: https://github.com/sfluor/musig
# author : Sylvain Fluri  (sfluor)
# license: MIT
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from cmd/musig/cmd/{root,listen,load,read,record,spec}.go on the musig tip.
#
# Direct deps from go.mod (selected):
#   gonum.org/v1/gonum                ← canonical Go numerical computing
#                                       library (this axis) — by Dan
#                                       Kortschak et al.; powers musig's
#                                       FFT (gonum/dsp/fourier) for the
#                                       spectrogram + fingerprint pipeline
#   github.com/spf13/cobra            (CLI framework)
#   go.etcd.io/bbolt                  (embedded K/V DB for fingerprints)
#
# musig builds Shazam-style "constellation maps" from audio (peak detection
# on FFT-derived spectrograms via gonum/dsp/fourier) and stores the resulting
# hash → song_id index in a BoltDB file.  `musig listen` then matches a
# live-recorded fingerprint against the DB.
#
# === AXIS 166 CONTINUES — linear algebra / numerical computing ecosystem ===
# Axis position: Go=221 continues Axis 166 (slot 2/0/0).  Canonical Go
# numerical computing library is `gonum/gonum` (gonum.org/v1/gonum) by Dan
# Kortschak (kortschak) + the gonum-org collective — a comprehensive
# numerical computing toolkit (BLAS bindings, linear algebra, FFT,
# optimization, statistics, graph algorithms) that's the de-facto Go
# equivalent of NumPy+SciPy.  Used by InfluxData Flux, Uptrace APM,
# c-bata/goptuna hyperparameter search, GRAIL reflow data processing,
# Cockroach DB parsing internals.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=221   _oculante            ← previous round (axis 166 OPENS at 1/0/0)
#   Go=221     ← THIS FILE          (axis 166 continues, slot 2/0/0)
#   TS-Node=221 ← next round        (axis 166 CLOSES at triple-221, slot 1/1/1)
# ---------------------------------------------------------------------------

_musig() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'listen:record microphone and try to find a matching song from the database (Ctrl-C to stop)'
        'load:load all audio files matching a glob into the database (only .wav supported)'
        'read:read the given audio file and try to find its song name'
        'record:record microphone input and save signal to a file'
        'spectrogram:generate a spectrogram PNG image for the given audio file'
        'spec:alias for spectrogram'
        'help:help about a subcommand'
    )

    _arguments -C \
        '--database=[database file to use (default /tmp/musig.bolt)]:file:_files -g "*.bolt"' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'musig command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                listen|record)
                    _arguments \
                        '(-d --duration)'{-d,--duration=}'[duration of listening/recording (default 10s)]:duration:' \
                        '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                load)
                    _arguments \
                        '(-d --dry-run)'{-d,--dry-run}'[disable saving to the database]' \
                        '(-r --reset)'{-r,--reset}'[reset the database if it already exists]' \
                        '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '*:audio file glob:_files -g "*.wav"' && ret=0
                    ;;
                read)
                    _arguments \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1:audio file:_files -g "*.wav"' && ret=0
                    ;;
                spectrogram|spec)
                    _arguments \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '1:audio file:_files -g "*.wav"' \
                        '2:output image:_files -g "*.png"' && ret=0
                    ;;
                help)
                    _describe -t commands 'musig command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_musig "$@"
