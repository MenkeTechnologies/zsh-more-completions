#compdef delocate-addplat delocate-fuse delocate-listdeps delocate-merge delocate-patch delocate-path delocate-wheel
# Documentation: source-direct extraction from upstream
# matthew-brett/delocate pyproject.toml `[project.scripts]`
# (7 entries: `delocate-addplat`/`delocate-fuse`/`delocate-listdeps`/
# `delocate-merge`/`delocate-patch`/`delocate-path`/`delocate-wheel`,
# each mapped to a `delocate.cmd.delocate_<name>:main` entry point)
# + each delocate/cmd/delocate_*.py argparse declarations.
# Reference accessed: 2026-05-30 via gh api.
# matthew-brett delocate R156b — 7-stem multi-binary harvest of
# the macOS dylib delocator suite (the macOS counterpart to
# auditwheel for Linux — bundles dependent .dylib shared libraries
# into a Python wheel so the wheel becomes self-contained).
# Sister to auditwheel (also fresh this round) and the broader
# cibuildwheel/maturin Python-wheel-distribution family.

case $service in

  delocate-wheel)
    # The main delocator: rewrites a wheel to bundle external
    # dylib dependencies and patches install names to use @loader_path.
    _arguments -s -S \
      '(-L --lib-sdir)'{-L+,--lib-sdir=}'[subdirectory in wheel for bundled dylibs (default .dylibs)]:dir:' \
      '(-w --wheel-dir)'{-w+,--wheel-dir=}'[output directory (default in-place)]:dir:_directories' \
      '(-k --check-archs)'{-k,--check-archs}'[fail if any bundled dylib lacks a required arch]' \
      '--require-archs=[required arch list (comma-separated)]:archs:(x86_64 arm64 universal2)' \
      '--require-target-macos-version=[minimum macOS deployment target]:version:' \
      '*:wheel(s) to delocate:_files -g "*.whl"'
    ;;

  delocate-listdeps)
    # List the external dylib dependencies of a wheel.
    _arguments -s -S \
      '(-a --all)'{-a,--all}'[also list non-external (system) deps]' \
      '(-d --depending)'{-d,--depending}'[also print which library depends on each one]' \
      '*:wheel(s):_files -g "*.whl"'
    ;;

  delocate-addplat)
    # Add a macOS platform tag to a wheel name (e.g.
    # macosx_11_0_x86_64.whl -> macosx_11_0_universal2.whl).
    _arguments -s -S \
      '(-c --clobber)'{-c,--clobber}'[overwrite an existing target file]' \
      '--osx-ver=[minimum macOS version to embed]:version:' \
      '*--plat-tag=[platform tag to add (repeatable)]:tag:' \
      '--dual-arch-type=[dual-arch packaging mode]:mode:(intel universal2 universal-fat3)' \
      '(-w --wheel-dir)--wheel-dir=[output directory]:dir:_directories' \
      '--rm-orig[remove the original wheel after adding the tag]' \
      '--skip-errors[continue past wheels that error]' \
      '*:input wheel(s):_files -g "*.whl"'
    ;;

  delocate-fuse)
    # Fuse two wheels (typically an x86_64 + an arm64 wheel) into
    # a single universal2 wheel by combining their dylibs.
    _arguments -s -S \
      '1:first wheel (e.g. x86_64):_files -g "*.whl"' \
      '2:second wheel (e.g. arm64):_files -g "*.whl"'
    ;;

  delocate-merge)
    # Merge dylib dependencies from a second wheel into a first
    # wheel (used when shipping plugin wheels for a host project).
    _arguments -s -S \
      '(-w --wheel-dir)'{-w+,--wheel-dir=}'[output directory]:dir:_directories' \
      '1:host wheel:_files -g "*.whl"' \
      '2:plugin wheel:_files -g "*.whl"'
    ;;

  delocate-patch)
    # Apply a unified diff to a wheel's contents in place.
    _arguments -s -S \
      '(-w --wheel-dir)'{-w+,--wheel-dir=}'[output directory]:dir:_directories' \
      '1:wheel:_files -g "*.whl"' \
      '2:unified-diff file:_files -g "*.(patch|diff)"'
    ;;

  delocate-path)
    # Delocate a tree of dylibs in a filesystem directory (NOT a
    # wheel) so they reference @loader_path-relative paths.
    _arguments -s -S \
      '(-L --lib-path)'{-L+,--lib-path=}'[subdirectory under <path> to copy bundled dylibs into]:dir:' \
      '*:path containing dylibs:_directories'
    ;;

esac
