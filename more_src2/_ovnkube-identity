#compdef ovnkube-identity
# _ovnkube-identity — OVN-K node-identity CSR approver + admission webhook (ovn-kubernetes/ovn-kubernetes)
# upstream: https://github.com/ovn-kubernetes/ovn-kubernetes
# Flags from go-controller/cmd/ovnkube-identity/ovnkubeidentity.go (urfave/cli) on tip.

_ovnkube-identity() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--k8s-apiserver=[apiserver URL]:url:_urls' \
        '--lease-namespace=[leader-election lease namespace]:ns:' \
        '--loglevel=[klog verbosity]:n:(0 1 2 3 4 5)' \
        '--disable-webhook[disable the admission webhook]' \
        '--disable-approver[disable the CSR approver]' \
        '--webhook-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--webhook-host=[webhook bind address]:ip:' \
        '--webhook-port=[webhook bind port]:port:' \
        '--metrics-address=[Prometheus metrics bind host\:port]:host\:port:' \
        '--enable-hybrid-overlay[enable hybrid-overlay support]' \
        '*--extra-allowed-user=[extra usernames allowed by webhook]:user:_users' \
        '--wait-for-kubernetes-api=[startup wait for apiserver readiness]:dur:' \
        '--local-kubernetes-api-port=[local kube-apiserver port (HA-only)]:port:' \
        '--csr-acceptance-conditions=[JSON object of CSR acceptance conditions]:json:' \
        '--pod-admission-conditions=[JSON object of pod admission conditions]:json:'
}

_ovnkube-identity "$@"
