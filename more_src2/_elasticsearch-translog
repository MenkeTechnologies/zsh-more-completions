#compdef elasticsearch-translog
# Documentation: https://github.com/elastic/elasticsearch/pull/19342
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elasticsearch-translog: legacy translog truncator (deprecated 6.0, removed 7.0; use elasticsearch-shard remove-corrupted-data)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-E[config setting key=value]:kv:' \
  '-d[translog dir]:dir:_files -/' \
  '--truncate[truncate translog]' \
  '*::elasticsearch-translog args:_files' && ret=0
return ret
