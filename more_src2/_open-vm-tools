#compdef vmtoolsd vmware-toolbox-cmd vmware-checkvm vmware-rpctool vmware-hgfsclient vmware-network-setup
# _open-vm-tools — open-vm-tools binaries (open-source replacement of VMware Tools for Linux guests; vmtoolsd is the master daemon (-c config file, -d daemonize, -V version, -h help); the user-facing helpers (toolbox-cmd, checkvm, rpctool, hgfsclient, network-setup) accept their own subcommands such as stat/info/timesync/diskwiper/upgrade)
# upstream: https://github.com/vmware/open-vm-tools
# Flags from vmware/open-vm-tools open-vm-tools/services/vmtoolsd on tip.

_open-vm-tools() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-d[daemonize]' \
        '-l+[log file]:file:_files' \
        '-v[verbose]' \
        '*::subcommand or arg:'
}

_open-vm-tools "$@"
