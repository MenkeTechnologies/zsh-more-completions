#compdef eigrpd
# Documentation: https://docs.frrouting.org/en/latest/eigrpd.html
# Reference accessed: 2026-05-17
# Verified: upstream FRR docs at the URL above (eigrpd + common invocation options).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run in daemon mode]' \
  '(-f --config_file)'{-f,--config_file}'+[set configuration file name]:file:_files' \
  '(-i --pid_file)'{-i,--pid_file}'+[pid file]:file:_files' \
  '(-z --socket)'{-z,--socket}'+[zebra socket]:file:_files' \
  '(-A --vty_addr)'{-A,--vty_addr}'+[VTY bind address]:addr:' \
  '(-P --vty_port)'{-P,--vty_port}'+[VTY TCP port]:port:' \
  '(-N --pathspace)'{-N,--pathspace}'+[namespace]:ns:' \
  '(-u --user)'{-u,--user}'+[run as user]:user:_users' \
  '(-g --group)'{-g,--group}'+[run as group]:group:_groups' \
  '(-M --module)'{-M,--module}'+[load extension module]:module:' \
  '--log=[initial logging destination]:dest:(stdout syslog)' \
  '--log-level=[default startup log level]:level:(emergencies alerts critical errors warnings notifications informational debugging)' \
  '--limit-fds=[restrict file descriptor usage]:n:' \
  '--command-log-always[always log all entered commands]' \
  '--tcli[enable transactional CLI mode]' && ret=0

return ret
