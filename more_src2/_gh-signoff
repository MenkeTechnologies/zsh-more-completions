#compdef gh-signoff gh-markdown-preview poutine
# Documentation: upstream READMEs at github.com/{basecamp/gh-signoff,yusukebe/gh-markdown-preview,boostsecurityio/poutine}
# Reference accessed: 2026-05-30
# Mixed bag round — 2 more gh-extensions + 1 standalone supply-chain scanner.
# Hunt-defer log: gh-aw / gh-actions-importer / gh-eco have no per-flag
# surfaces in their READMEs (TUI-driven or sub-sub-command-driven without
# documentation); defer to avoid vibe-coding.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-signoff)
    # basecamp/gh-signoff — local CI sign-off tool.
    # Bare invocation: signs off the current PR.
    # Subcommands: status, install. Bare positionals = signoff step names.
    local -a _subcmds
    _subcmds=(
      'status:show which signoffs have been completed'
      'install:enforce signoff requirements for PR merges'
    )
    _arguments -C -s -S \
      '(-): :->subcmd_or_steps' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd_or_steps)
        _describe -t commands 'subcommand or signoff step name' _subcmds && ret=0
        ;;
      subcmd_args)
        # status / install take no further args per upstream README.
        ;;
    esac
    ;;

  gh-markdown-preview)
    # yusukebe/gh-markdown-preview — local GitHub-styled markdown preview.
    # Accepts optional file positional, stdin pipe, or auto-detects README.
    _arguments -s -S \
      '(--dark-mode --light-mode)--dark-mode[force dark color scheme]' \
      '(--dark-mode --light-mode)--light-mode[force light color scheme]' \
      '(-p --port)-p+[TCP port (default 3333)]:port:' \
      '(-p --port)--port=[TCP port (default 3333)]:port:' \
      '--host=[hostname (default localhost)]:host:' \
      '--disable-auto-open[do not launch browser automatically]' \
      '--disable-reload[disable live reloading]' \
      '--markdown-mode[render as plain markdown instead of GFM]' \
      '*:markdown file (default: auto-detect README):_files -g "*.(md|markdown)"' \
      && ret=0
    ;;

  poutine)
    # boostsecurityio/poutine — Go supply-chain vulnerability scanner.
    # 3 analyze subcommands; global flags --token / --format / --threads /
    # --skip / --fail-on-violation. Config file at .poutine.yml or
    # .github/poutine.yml.
    local -a _subcmds
    _subcmds=(
      'analyze_local:analyze a local repository'
      'analyze_repo:scan a remote GitHub repository'
      'analyze_org:examine all repositories in an organization'
    )
    _arguments -C -s -S \
      '--token=[SCM access token (GitHub or GitLab)]:token:' \
      '--format=[output format]:format:(pretty json sarif)' \
      '--threads=[parallel processing threads]:N:' \
      '*--skip=[exclude rule (repeatable)]:rule:' \
      '--fail-on-violation[exit code 10 on findings]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'poutine subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          analyze_local)
            _arguments \
              '1:repository directory:_files -/' && ret=0
            ;;
          analyze_repo)
            _arguments \
              '1:owner/repo or URL:' && ret=0
            ;;
          analyze_org)
            _arguments \
              '1:organization name:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
