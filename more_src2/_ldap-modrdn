#compdef ldap-modrdn ldapmodrdn-wrapper
# _ldap-modrdn — distro-shipped LDAP modrdn wrapper (alias of ldapmodrdn(1); renames or moves an entry's RDN; -H URI, -D bind DN, -w password, -y password file, -r remove old RDN, -s new superior DN, -x simple bind, -Z TLS, -n dry run, -v verbose, -h help, -V version; positional: current DN newRDN)
# upstream: https://git.openldap.org/openldap/openldap (clients/tools/ldapmodrdn)
# Flags from OpenLDAP clients/tools/ldapmodrdn.c on tip.

_ldap-modrdn() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-H+[URI]:uri:' \
        '-D+[bind DN]:dn:' \
        '-w+[password]:password:' \
        '-y+[password file]:file:_files' \
        '-r[remove old RDN]' \
        '-s+[new superior DN]:dn:' \
        '-x[simple bind]' \
        '-Z[start TLS]' \
        '-ZZ[require start TLS]' \
        '-n[dry run]' \
        '-v[verbose]' \
        '1:current DN:' \
        '2:newRDN:'
}

_ldap-modrdn "$@"
