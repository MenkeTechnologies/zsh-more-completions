#compdef gofmt
# Documentation: gofmt --help
# Source: Go gofmt — format Go source code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-cpuprofile=[write CPU profile to file]:file:_files' \
    '-d[display diffs instead of rewriting files]' \
    '-e[report all errors (not just first 10)]' \
    '-l[list files whose formatting differs]' \
    '-r=[rewrite rule (a[b\:len(a)] -> a[b\:])]:rule:' \
    '-s[simplify code]' \
    '-w[write result to source file]' \
    '*:Go file or directory:_files -g "*.go"' \
    && ret=0

return ret
