#compdef gophish
# _gophish — Gophish open-source phishing toolkit (Go); for authorized red-team/blue-team training campaigns with templates + landing pages + sending profiles
# upstream: https://github.com/gophish/gophish

_gophish() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-config+[YAML config file]:file:_files -g "*.yml"' \
        '-version[show version]' \
        '*:cmd:'
}

_gophish "$@"
