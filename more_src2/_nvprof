#compdef nvprof
# Documentation: https://docs.nvidia.com/cuda/profiler-users-guide/
# Reference accessed: 2026-05-16
# Verified: NVIDIA CUDA Profiler Users Guide. NOTE: nvprof is
# deprecated; use Nsight Systems / Nsight Compute instead.
# Removed from prior file: bogus man.archlinux.org search URL.

# nvprof: NVIDIA CUDA command-line profiler (deprecated)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-e --events)'{-e+,--events=}'[hardware events to profile]:events:' \
  '(-m --metrics)'{-m+,--metrics=}'[metrics to profile]:metrics:' \
  '--kernels=[kernel filter]:kernel:' \
  '--devices=[device filter]:devices:' \
  '--analysis-metrics[collect analysis metrics]' \
  '--profile-from-start=[delay profiling start]:bool:(on off)' \
  '(-t --timeout)'{-t+,--timeout=}'[profiling timeout seconds]:s:' \
  '--concurrent-kernels=[concurrent kernels]:bool:(on off)' \
  '--export-profile=[export profile to file]:file:_files' \
  '--query-events[list available events]' \
  '--query-metrics[list available metrics]' \
  '--profile-api-trace=[API trace mode]:mode:' \
  '--system-profiling[profile entire system]' \
  '--profile-child-processes[profile child processes]' \
  '--profile-all-processes[profile all processes]' \
  '*:cuda executable:_files' && ret=0
return ret
