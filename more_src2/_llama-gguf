#compdef llama-gguf
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/examples/gguf/gguf.cpp
# Reference accessed: 2026-05-27
# Verified: upstream argv parsing in main() of examples/gguf/gguf.cpp
# usage: llama-gguf data.gguf r|w [n]

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:gguf file:_files -g "*.gguf"' \
  '2:mode:((r\:read\ data.gguf w\:write\ data.gguf))' \
  '3:check:((n\:skip\ tensor\ data\ check))' && ret=0

return ret
