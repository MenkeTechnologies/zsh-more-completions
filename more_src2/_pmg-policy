#compdef pmgpolicy pmg-policy
# _pmg-policy — Proxmox Server Solutions pmgpolicy Proxmox Mail Gateway policy management for mail filtering rules (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pmg-api.git

_pmg-policy() {
    local -a sub=(
        'compile:compile policy rules'
        'commit:apply changes'
        'show:show current policies'
        'rebuild-spamassassin:rebuild SA databases'
        'reload:reload policy daemon'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pmg-policy subcommand' sub ;;
        args)
            case $words[1] in
                compile) _arguments \
                    '--testmode[test mode]' \
                    '--verbose[verbose]' ;;
                show) _arguments \
                    '--node=+[node]:str:' \
                    '--filter=+[filter]:str:' ;;
            esac
            ;;
    esac
}

_pmg-policy "$@"
