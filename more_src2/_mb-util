#compdef mb-util
# Documentation: https://github.com/mapbox/mbutil
# Reference accessed: 2026-05-16
# Verified: upstream mapbox/mbutil mb-util script.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# mb-util: MBTiles archive / directory converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--scheme=[tile coordinate scheme]:scheme:(xyz wms tms zyx gwc ags)' \
  '--image_format=[image format]:fmt:(png jpg pbf webp)' \
  '--grid_callback=[grid JSONP callback name]:callback:' \
  '--do_compression[compress tiles in MBTiles]' \
  '--silent[suppress output]' \
  '*:tile dir or .mbtiles:_files' && ret=0
return ret
