#compdef gffcompare
# _gffcompare — Geo Pertea gffcompare classify and compare transcript assemblies to a reference annotation (gpertea team, C++); getopt
# upstream: https://github.com/gpertea/gffcompare

_gffcompare() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[gff list file]:file:_files' \
        '-r+[reference annotation]:file:_files -g "*.gff *.gff3 *.gtf"' \
        '-R[for -r consider only intervals overlapping]' \
        '-Q[for ref consider only intervals overlapping]' \
        '-M[discard single-exon transcripts]' \
        '-N[discard single-exon transcripts and reference matches]' \
        '-D[discard multi-exon transcripts not on same strand]' \
        '-s+[seqs fasta]:file:_files -g "*.fa *.fasta *.fa.gz *.fasta.gz"' \
        '-e+[F]:f:' \
        '-d+[N]:n:' \
        '-T[no tmap output]' \
        '-X[discard duplicates]' \
        '-K[no full intron-chain check]' \
        '-G[generic GFF without exons]' \
        '-S[strict mode]' \
        '-V[verbose]' \
        '-c[count mode]' \
        '-A[match strand even for single-exon]' \
        '-C[show all CDS]' \
        '-F+[F]:f:' \
        '-o+[output prefix]:str:' \
        '--strict-match[strict match]' \
        '--no-merge[do not merge]' \
        '--debug[debug]' \
        '-p+[prefix]:str:' \
        '-X[discard duplicates]' \
        '--chr-stats[show chromosome stats]' \
        '*:input gtf files:_files -g "*.gff *.gff3 *.gtf"'
}

_gffcompare "$@"
