#compdef esctl
# _esctl — CLI to manage Elasticsearch clusters (jeromepin/esctl)
# upstream: https://github.com/jeromepin/esctl
# Subcommands from esctl/cmd/ (cliff).

_esctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '(-q --quiet)'{-q,--quiet}'[suppress output]' \
        '--log-file=[log file]:file:_files' \
        '--context=[config context to use]:context:' \
        '--cluster=[cluster to use]:cluster:' \
        '--user=[user to use]:user:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'alias:manage aliases'
                'cat:run cat APIs'
                'cluster:manage cluster (health, allocation, reroute, ...)'
                'config:manage local esctl config (contexts, clusters, users)'
                'document:document operations'
                'index:manage indices'
                'logging:manage logging levels'
                'migration:migration helpers'
                'node:show node info'
                'raw:run raw API calls'
                'repository:manage snapshot repositories'
                'roles:manage roles'
                'settings:manage cluster / index settings'
                'snapshot:manage snapshots'
                'task:manage tasks'
                'users:manage users'
                'help:show help'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_esctl "$@"
