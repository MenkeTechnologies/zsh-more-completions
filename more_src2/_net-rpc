#compdef net-rpc
# _net-rpc — Samba net rpc helper (programmatic Samba 'net rpc' admin interface: user/group/service/printer/registry/rights/shutdown/share/file/audit/conf/printer/registry/rights/abortshutdown/shutdown/getsid/changetrustpw/oldjoin/join/testjoin/registry/getdomainsid/setdomainsid/changetrustpw; -S server, -U user, -W workgroup, -k Kerberos, -N no password, -d debug level, -h help, -V version)
# upstream: https://github.com/samba-team/samba
# Subcommands from samba/samba source3/utils/net_rpc.c on tip.

_net-rpc() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-S+[server]:host:_hosts' \
        '-U+[user]:user:_users' \
        '-W+[workgroup]:workgroup:' \
        '-k[Kerberos]' \
        '-N[no password]' \
        '-d+[debug level]:level:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'net rpc subcommand' '(user group share service printer registry rights shutdown abortshutdown getsid info testjoin join oldjoin file audit changetrustpw conf trust)' ;;
        args) _arguments '*:argument:' ;;
    esac
}

_net-rpc "$@"
