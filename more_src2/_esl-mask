#compdef esl-mask
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-mask.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-mask: mask regions of a sequence file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-l[lowercase-mask: masked chars lower, unmasked upper]' \
  '-m[mask character (default X)]:char' \
  '-o[output file]:file:_files' \
  '-r[reverse mask: mask outside region start..end]' \
  '-R[random access via SSI-indexed file]' \
  '-x[extend masked regions by N residues each side]:n' \
  '--informat=[input sequence format]:fmt:(fasta embl genbank uniprot stockholm clustal phylip)' \
  '*:sequence file and mask coords:_files' && ret=0
return ret
