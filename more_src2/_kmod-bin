#compdef kmod
# _kmod-bin — kernel module multi-call binary (Lucas De Marchi, C); dispatches to insmod/rmmod/lsmod/modinfo/modprobe/depmod/static-nodes
# upstream: https://github.com/kmod-project/kmod

_kmod-bin() {
    local -a sub=(
        'list:list currently loaded modules'
        'static-nodes:list static device nodes'
        'help:show help'
        'insert:insert a module'
        'remove:remove a module'
    )
    _arguments -C \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kmod subcommand' sub ;;
    esac
}

_kmod-bin "$@"
