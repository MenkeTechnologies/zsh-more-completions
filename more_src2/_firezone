#compdef firezone-gateway firezone-relay firezone-client-headless firezone
# _firezone — Firezone open-source zero-trust access platform with WireGuard kernel datapath (firezone team, Rust/Elixir); clap-derive
# upstream: https://github.com/firezone/firezone

_firezone() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--token=+[auth token]:str:' \
        '-t+[auth token]:str:' \
        '--firezone-api-url=+[api url]:url:_urls' \
        '--api-url=+[api url]:url:_urls' \
        '--portal-url=+[portal url]:url:_urls' \
        '--firezone-id=+[firezone id]:str:' \
        '--firezone-name=+[name]:str:' \
        '--max-partition-time=+[duration]:str:' \
        '--otlp-grpc-endpoint=+[otel endpoint]:url:_urls' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--log-format=+[format]:f:(human json)' \
        '--no-color[disable color]' \
        '--check[health check and exit]' \
        '--metrics-port=+[port]:port:_ports' \
        '--listen=+[bind addr]:str:' \
        '--no-stun[disable STUN]' \
        '--stun-servers=+[servers csv]:str:' \
        '--turn-servers=+[servers csv]:str:' \
        '--dns-control=+[mode]:m:(none systemd-resolved network-manager)' \
        '--mtu=+[bytes]:n:'
}

_firezone "$@"
