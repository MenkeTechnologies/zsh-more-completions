#compdef ppmflash
# Documentation: https://netpbm.sourceforge.net/doc/ppmflash.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:flash factor (0.0=original, 1.0=whiteout):' \
  '2::ppm file:_files -g "*.ppm"' && ret=0

return ret
