#compdef guayadeque
# Documentation: https://github.com/anonbeat/guayadeque/blob/master/src/MainApp.cpp
# Reference accessed: 2026-05-16
# Verified: src/MainApp.cpp guMainApp::OnInit() (lines 303-349) - argv is treated
# as a list of file paths sent via MPRIS DBus AddTracks to a running instance.
# There is no getopt/wxCmdLineParser in the source; no command-line option flags
# exist.
# Removed from prior file: -h/--help, -v/--verbose, -V/--version, --play,
# --play-pause, --stop, --prev, --next - none of these are parsed by Guayadeque
# (the binary only accepts positional file paths).

# Guayadeque: wxWidgets music player and tag editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:music file:_files -g "*.(mp3|flac|ogg|m4a|wav|opus|wma|aac|mp4|m3u|m3u8|pls|cue)"' && ret=0
return ret
