#compdef gptme
# Documentation: https://github.com/gptme/gptme
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version]' \
  '--name=[assign a conversation name]:name:' \
  '(-m --model)'{-m+,--model=}'[LLM model to use]:model:' \
  '(-w --workspace)'{-w+,--workspace=}'[workspace directory]:dir:_files -/' \
  '--agent-path=[agent workspace location]:dir:_files -/' \
  '(-r --resume)'{-r,--resume}'[load most recent conversation]' \
  '--system=[customize system prompt]:prompt:' \
  '(-y --no-confirm)'{-y,--no-confirm}'[skip confirmation prompts]' \
  '(-n --non-interactive)'{-n,--non-interactive}'[run without user interaction]' \
  '--output-format=[output format]:fmt:(text json)' \
  '(-t --tools)'{-t+,--tools=}'[allowed tools (comma-separated)]:tools:' \
  '--tool-format=[tool format]:fmt:(markdown xml tool)' \
  '--no-stream[disable response streaming]' \
  '--show-hidden[display system messages]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*::arguments:_default'
