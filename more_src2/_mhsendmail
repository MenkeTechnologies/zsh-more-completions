#compdef mhsendmail
# _mhsendmail — sendmail-compatible CLI for MailHog / Mailpit (mailhog/mhsendmail)
# upstream: https://github.com/mailhog/mhsendmail
# Flags from cmd/cmd.go (pflag).

_mhsendmail() {
    local -a args
    args=(
        '--smtp-addr=[SMTP server address (default localhost:1025)]:host\:port:'
        '(-f --from)'{-f+,--from=}'[envelope sender]:address:'
        '-i[ignored (sendmail compatibility)]'
        '-o+[ignored (sendmail compatibility)]:opt:'
        '-t[read recipients from the message headers (sendmail compat)]'
        '(-v --verbose)'{-v,--verbose}'[verbose mode (debug output to stderr)]'
        '(- *)'{-h,--help}'[show help]'
        '*:recipient address:'
    )
    _arguments -s -S $args
}

_mhsendmail "$@"
