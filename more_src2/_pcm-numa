#compdef pcm-numa
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-numa.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-numa: Intel PCM NUMA local/remote traffic monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-c=-[core list to monitor]:cores:' \
  '-pid[restrict to PID]:pid:' \
  '-i=-[number of iterations]:n:' \
  '*::pcm-numa args:_files' && ret=0
return ret
