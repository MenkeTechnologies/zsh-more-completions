#compdef flac123
# Documentation: https://manned.org/flac123/cacfb2fa
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flac123: console FLAC player implementing mpg123 remote-control interface.

local ret=1

_arguments -s -S \
  '(- *)'{-?,--help}'[show help]' \
  '(- *)--usage[show brief usage]' \
  '(-d --driver)'{-d+,--driver=}'[libao output driver]:driver:(oss alsa esd arts macosx pulse)' \
  '(-w --wav)'{-w+,--wav=}'[send output to wav file (- for stdout)]:file:_files' \
  '(-R --remote)'{-R,--remote}'[remote mode (mpg123-compatible)]' \
  '(-q --quiet)'{-q,--quiet}'[suppress text output]' \
  '*:FLAC or playlist:_files' && ret=0

return ret
