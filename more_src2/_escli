#compdef escli
# ============================================================================
# _escli — zsh completion for Anaethelion's escli-rs, a modern Rust
#           CLI for Elasticsearch (official `elasticsearch` Rust client)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/Anaethelion/escli-rs
#   Author     : Anaethelion
#   License    : Apache-2.0
#   Language   : Rust
#   Crate      : escli v0.2.0-alpha  (workspace member under escli/)
#   Binary     : escli  (escli/Cargo.toml [[bin]] name = "escli",
#                         path = "src/main.rs" — autogenerated by
#                         `cargo run -p generator --release` from
#                         the Elasticsearch API specs)
#   Last push  : 2026-03-27
#
# WHAT IT IS
#   escli is "a modern, flexible CLI for interacting with
#   Elasticsearch clusters, written in Rust" — Anaethelion's
#   auto-generated wrapper over the full Elasticsearch REST API.
#   The CLI is built in two steps:  `cargo run -p generator` reads
#   the Elasticsearch OpenAPI / REST-spec definitions and generates
#   a complete `escli/src/` tree mirroring every endpoint as a
#   clap-derive subcommand;  `cargo build -p escli` then compiles
#   the resulting binary.  Authentication is API-key or
#   username/password (loaded from a `.env` file or environment
#   variables);  the cluster endpoint is taken from
#   `$ESCLI_URL`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from README.md + escli/Cargo.toml
#                       dependencies — the subcommand surface is
#                       auto-generated so only the documented
#                       top-level command groups are enumerated
#                       here)
#   escli <SUBCOMMAND> [args...]
#
#   Top-level subcommands (documented in README + tapes/):
#     info                             Show cluster info
#                                      (calls `GET /`)
#
#     bulk                             Bulk API
#                                      (`POST _bulk` from a file)
#       --input <FILE>                   NDJSON payload file
#
#     search                           Search API
#                                      (`POST /<index>/_search` —
#                                       request body read from
#                                       stdin)
#       --index <NAME>                   Target index
#
#     esql                             ES|QL query API
#       query                            Run an ES|QL query
#                                        (body from stdin)
#         --format <FMT>                   Output format
#                                          (txt / json / csv /
#                                          tsv / yaml / cbor /
#                                          smile / arrow)
#
#     utils                            Utility commands
#       dump <INDEX>                     Dump every document in an
#                                        index (scrolls through and
#                                        prints as NDJSON)
#
#     completion <SHELL>               Generate shell completion
#                                      script (also supported via
#                                      `COMPLETE=<shell> escli`)
#
#   Auto-generated subcommand groups mirror the Elasticsearch
#   REST API namespaces (cat, cluster, indices, ingest, ml, nodes,
#   security, slm, snapshot, sql, watcher, ...).  Each namespace
#   exposes one subcommand per REST endpoint with that endpoint's
#   path parameters as positionals and its query parameters as
#   clap flags.
#
#   Standard clap auto-flags (and clap_complete integration):
#     -h, --help                       Show help (short)
#         --help                       Show help (long)
#     -V, --version                    Show version
#
#   Environment variables:
#     ESCLI_URL                        Elasticsearch endpoint
#                                      (e.g. https://localhost:9200)
#     ESCLI_API_KEY                    API key for auth
#                                      (recommended)
#     ESCLI_USERNAME                   HTTP-basic-auth username
#                                      (alternative)
#     ESCLI_PASSWORD                   HTTP-basic-auth password
#                                      (alternative)
#     COMPLETE=<shell>                 Print clap_complete-generated
#                                      shell completion to stdout
#                                      (zsh, bash, fish, …)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `elasticsearch` declared in escli/
#   Cargo.toml (workspace-versioned;  bound to the canonical
#   official Elasticsearch Rust client published as
#   crates.io/crates/elasticsearch, maintained by Elastic NV
#   under elastic/elasticsearch-rs).  The crate provides typed
#   `Elasticsearch::new(transport)` constructors, typed request
#   builders for every REST endpoint
#   (`client.cat().indices()`, `client.bulk()`, `client.search()`,
#   `client.esql().query()`, …), connection-pool / SniffedConnection-
#   Pool topology discovery, and full BWC matrix for ES 7.x / 8.x
#   / 9.x.  escli's `escli/src/` (regenerated by the generator
#   crate) calls into this client for every CLI subcommand, so
#   the CLI surface tracks the upstream REST API automatically
#   on each Elasticsearch release.  Verified via:
#     gh api repos/Anaethelion/escli-rs/contents/escli/Cargo.toml
#       → elasticsearch = { workspace = true }
#       → [[bin]] name = "escli" path = "src/main.rs"
#     gh api repos/Anaethelion/escli-rs/contents/README.md
#       → ./escli {info,bulk,search,esql query,utils dump,...}
#   This entry is the Rust=137 leader bump that OPENS Axis 82
#   (Elasticsearch Client Library), pairing with future Go=
#   elastic/go-elasticsearch and TS-Node=@elastic/elasticsearch
#   poles to close the axis at 1/1/1.
#
#   No completion for `escli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_escli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_escli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                info)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
                bulk)
                    _arguments \
                        '--input=[NDJSON payload file]:file:_files -g "*.{ndjson,json}"' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                search)
                    _arguments \
                        '--index=[target index]:index:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                esql)
                    _arguments \
                        '1:esql subcommand:(query)' \
                        '--format=[output format]:format:(txt json csv tsv yaml cbor smile arrow)' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                utils)
                    _arguments \
                        '1:utils subcommand:(dump)' \
                        ':index:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                completion)
                    _arguments \
                        ':shell:(bash zsh fish powershell elvish)' && ret=0 ;;
                cat|cluster|indices|ingest|ml|nodes|security|slm|snapshot|sql|watcher)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_escli_commands] )) ||
_escli_commands() {
    local -a commands
    commands=(
        'info:show cluster info'
        'bulk:bulk index/update/delete from NDJSON file'
        'search:search a target index (body from stdin)'
        'esql:ES|QL query (subcommand: query)'
        'utils:utility commands (dump <index>)'
        'completion:generate shell completion script'
        'cat:_cat API namespace'
        'cluster:_cluster API namespace'
        'indices:_indices API namespace'
        'ingest:_ingest pipeline API namespace'
        'ml:_ml API namespace'
        'nodes:_nodes API namespace'
        'security:_security API namespace'
        'slm:_slm API namespace'
        'snapshot:_snapshot API namespace'
        'sql:_sql API namespace'
        'watcher:_watcher API namespace'
    )
    _describe -t commands 'escli command' commands
}

_escli "$@"
