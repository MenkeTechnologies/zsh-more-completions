#compdef grib_nearest_land
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_nearest_land
# Source: ecmwf/eccodes tools/grib_nearest_land.cc — find the nearest land point for given lat/lon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '1:latlon file:_files' \
    '2:grib orography file:_files' \
    '*:grib file:_files' \
    && ret=0

return ret
