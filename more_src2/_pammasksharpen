#compdef pammasksharpen
# Documentation: man pammasksharpen (Netpbm)
# Source: sharpen a Netpbm image using an unsharp-mask file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-sharpness=[sharpness factor]:realnum:' \
    '-threshold=[edge threshold]:realnum:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:mask file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:input file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
