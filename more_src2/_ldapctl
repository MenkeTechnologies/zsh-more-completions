#compdef ldapctl
# _ldapctl — OpenBSD ldapctl (control ldapd(8) LDAP directory server; stats/compact/index database maintenance, set log level brief/verbose, point at alternate config or database dir or control socket)
# upstream: https://github.com/openbsd/src (usr.sbin/ldapctl)
# Flags + commands from usr.sbin/ldapctl/ldapctl.8 on tip.

_ldapctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-v[verbose]' \
        '-f+[config file (default /etc/ldapd.conf)]:file:_files' \
        '-r+[database directory]:dir:_files -/' \
        '-s+[control socket]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'ldapctl command' \
                '(stats:show statistics compact:compact database index:re-index database log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_ldapctl "$@"
