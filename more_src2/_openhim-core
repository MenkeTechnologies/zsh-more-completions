#compdef openhim-core
# ============================================================================
# _openhim-core — zsh completion for OpenHIM Core, Jembi's Open Health
#                 Information Mediator core daemon (kafkajs producer)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/jembi/openhim-core-js
#   Maintainer : Jembi Health Systems  (https://jembi.org/openhim)
#   License    : MPL-2.0
#   Language   : JavaScript / Node.js (babel-polyfill ES modules)
#   Package    : openhim-core v8.5.1
#   Binary     : openhim-core  (package.json bin: ./bin/openhim-core.js)
#   Last push  : 2026-04-15
#
# WHAT IT IS
#   OpenHIM Core is "the OpenHIM core application that provides
#   logging and routing of HTTP requests" — the central component
#   of the Open Health Information Mediator, a standards-based
#   message mediator originally co-developed with the Council for
#   Scientific and Industrial Research (CSIR) for the Health
#   Information Exchange (HIE) reference architecture.  The daemon
#   accepts inbound HTTPS / TLS-authenticated client requests,
#   matches them against per-channel routing rules, optionally
#   transforms / orchestrates them through downstream routes, logs
#   transaction bodies (mediated by `bodyCull` retention), and
#   publishes channel-level events to a Kafka topic for downstream
#   analytics consumers.
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/openhim-core.js +
#                       src/config/config.js nconf.argv().env('_'))
#   openhim-core [OPTIONS]
#
#   openhim-core has no subcommands;  the daemon starts as soon as
#   the binary is launched.  All runtime configuration flows from
#   `<appRoot>/config/default.json` overlaid by the env-specific
#   `<appRoot>/config/<NODE_ENV>.json` and finally by any user
#   override file passed with `--conf`.
#
#   Options:
#     -v, --version             Print "OpenHIM Core version <X.Y.Z>"
#                               (read directly from package.json) and
#                               exit before requiring lib/server.js
#         --conf <FILE>         Custom config file path (loaded into
#                               nconf as the `customConfigOverride`
#                               store, takes precedence over both the
#                               env-specific and default config files)
#
#   Environment variables:  every config key is also settable as an
#   environment variable using nconf's `_` separator — for example,
#   `nconf.get('mongo.url')` reads from `mongo_url` (or
#   `MONGO_URL`).  The `NODE_ENV` env var selects which
#   `config/<NODE_ENV>.json` file is layered on top of `default.json`.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `kafkajs ^2.2.4` declared in package.json —
#   the canonical pure-JavaScript Apache Kafka client maintained by
#   Tulio Ornelas (tulios/kafkajs).  kafkajs implements the full
#   Kafka 0-9-1+ wire protocol in TypeScript-friendly Node.js with
#   typed Producer + Consumer + Admin APIs, SASL/PLAIN/SCRAM/OAUTH
#   authentication, SSL, schema-registry-friendly transformers, and
#   consumer-group rebalance hooks — and crucially has zero native
#   dependencies (unlike confluent-kafka-go's librdkafka FFI used in
#   _kafy at R878).  OpenHIM Core's `src/kafkaProducer.js`
#   constructs a `Kafka({brokers, clientId, ssl, sasl}).producer()`,
#   connects on daemon boot, and publishes JSON-encoded channel
#   transaction events to the configured Kafka topic for downstream
#   analytics pipelines.  Verified via:
#     gh api repos/jembi/openhim-core-js/contents/package.json
#       → "kafkajs": "^2.2.4"
#     gh api search/code repo:jembi/openhim-core-js kafkajs
#       → src/kafkaProducer.js, package.json
#   This entry is the TS-Node=127 leader bump that CLOSES Axis 72
#   (Apache Kafka Client Library) at 1/1/1 three-language symmetry
#   — pairing Rust=rdkafka 0.37.0 (R877 _openwecd), Go=
#   confluent-kafka-go/v2 v2.11.1 (R878 _kafy), and TS-Node=
#   kafkajs ^2.2.4 (this entry).  Triple-127 landmark on commit.
#
#   No completion for `openhim-core` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_openhim-core() {
    _arguments -s \
        '(- *)'{-v,--version}'[print OpenHIM Core version and exit]' \
        '--conf=[custom config file path (nconf customConfigOverride)]:config file:_files -g "*.{json,yaml,yml}"' \
        '(- *)--help[show help]'
}

_openhim-core "$@"
