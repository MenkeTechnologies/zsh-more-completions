#compdef prow-gerrit
# _prow-gerrit — Prow Gerrit poller that creates ProwJobs from Gerrit changes (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/gerrit/main.go (flag).

_prow-gerrit() {
    _arguments \
        '-cookiefile=[git http.cookiefile path]:file:_files' \
        '-last-sync-fallback=[fallback path for last sync timestamp]:path:' \
        '-dry-run[run in dry-run mode]' \
        '-token-path=[gcloud access token path]:file:_files' \
        '-change-worker-pool-size=[worker pool size per instance]:n:' \
        '-push-gateway-interval=[prometheus push interval]:duration:' \
        '-instance-concurrency-limit=[concurrent calls per Gerrit host (deprecated)]:n:' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files'
}

_prow-gerrit "$@"
