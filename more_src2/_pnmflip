#compdef pnmflip pamflip
# Documentation: pamflip(1) (Netpbm)
# Source: flip/transpose/rotate PAM or PNM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-leftright[flip left for right]' \
    '(-leftright -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-lr[flip left for right]' \
    '(-leftright -lr -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-topbottom[flip top for bottom]' \
    '(-leftright -lr -topbottom -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-tb[flip top for bottom]' \
    '(-leftright -lr -topbottom -tb -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-transpose[transpose rows/columns]' \
    '(-leftright -lr -topbottom -tb -transpose -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-xy[transpose rows/columns]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-reflect[reflect about up-right diagonal]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -r90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-rotate90[rotate counterclockwise 90]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -ccw -rotate180 -r180 -rotate270 -r270 -cw -xform)-r90[rotate counterclockwise 90]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -rotate180 -r180 -rotate270 -r270 -cw -xform)-ccw[rotate counterclockwise 90]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -r180 -rotate270 -r270 -cw -xform)-rotate180[rotate 180]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -rotate270 -r270 -cw -xform)-r180[rotate 180]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -r270 -cw -xform)-rotate270[rotate clockwise 90]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -cw -xform)-r270[rotate clockwise 90]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -ccw -rotate180 -r180 -rotate270 -r270 -xform)-cw[rotate clockwise 90]' \
    '-xform=[multiple-step transformation sequence]:sequence:' \
    '-memsize=[memory limit MB]:mb:' \
    '-pagesize=[page size for ondisk]:bytes:' \
    '-quiet[suppress informational messages]' \
    '-verbose[verbose output]' \
    ':image:_files' \
    && ret=0

return ret
