#compdef gen-owl
# _gen-owl — generate OWL ontology from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/owlgen.py (click).

_gen-owl() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(owl|ttl|nt|rdf|owx)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(turtle xml rdfxml json-ld nt n3 owx)'
        '--metadata-profile=[metadata profile]:profile:(linkml ols)'
        '--type-objects[emit type objects]'
        '--no-type-objects[do not emit type objects]'
        '--metaclasses[emit metaclasses]'
        '--no-metaclasses[do not emit metaclasses]'
        '--add-root-classes[add LinkML root classes]'
        '--no-add-root-classes[skip adding LinkML root classes]'
        '--add-ols-annotations[add OLS-compatible annotations]'
        '--no-add-ols-annotations[skip OLS annotations]'
        '--ontology-uri-suffix=[suffix appended to the ontology IRI]:suffix:'
        '--assert-equivalent-classes[assert owl:equivalentClass for class URI matches]'
        '--no-assert-equivalent-classes[do not assert owl:equivalentClass]'
        '--mixins-as-expressions[encode mixins as class expressions]'
        '--no-mixins-as-expressions[encode mixins as subClassOf instead]'
        '--use-native-uris[use LinkML-native URIs]'
        '--no-use-native-uris[do not use LinkML-native URIs]'
        '--default-permissible-value-type=[OWL type for enum permissible values]:type:(owl:Class owl:NamedIndividual)'
        '--enum-iri-separator=[separator between enum name and value in IRIs]:sep:'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-owl "$@"
