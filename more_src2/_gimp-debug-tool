#compdef gimp-debug-tool gimp-debug-tool-2.0 gimp-debug-tool-3.0
# Documentation: https://manpages.debian.org/gimp-debug-tool
# Source: GNOME/gimp app-tools/gimp-debug-tool.c — GIMP crash-debug dialog launcher (C, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:program:_command_names -e' \
    '2:pid:_default' \
    '3:reason:_default' \
    '4:message:_default' \
    '5:backtrace file:_files' \
    '6::last version:_default' \
    '7::release timestamp:_default' \
    && ret=0

return ret
