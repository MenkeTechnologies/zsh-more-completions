#compdef gorelease
# Documentation: https://pkg.go.dev/golang.org/x/exp/cmd/gorelease
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-base[base version or commit to compare against]:version or commit' \
  '-version[proposed release version]:version' && ret=0

return ret
