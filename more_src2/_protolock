#compdef protolock
# Documentation: https://github.com/nilslice/protolock
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize proto.lock'
  'status:show changes vs lockfile'
  'commit:write current proto state to lockfile'
)

_arguments -C \
  '--lockdir=[directory of proto.lock file]:dir:_files -/' \
  '--protoroot=[root of directory tree of proto files]:dir:_files -/' \
  '--ignore=[comma-list of ignored files]:list:' \
  '--uptodate[require lockfile up to date]' \
  '--plugins=[comma-list of plugins]:list:' \
  '--force[force commit; ignore warnings]' \
  '--strict[enable strict mode]' \
  '--debug[debug logging]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'protolock subcommand' subcommands && ret=0
    ;;
esac

return ret
