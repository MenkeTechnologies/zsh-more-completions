#compdef gowall

_gowall() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_gowall_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                convert)
                    _arguments \
                        '(-i --input)'{-i+,--input=}'[input wallpaper file]:file:_files -g "*(-.)"' \
                        '(-t --theme)'{-t+,--theme=}'[theme name]:theme:' \
                        '(-o --output)'{-o+,--output=}'[output file]:file:_files' && ret=0 ;;
                list)
                    _arguments && ret=0 ;;
            esac ;;
    esac

    return ret
}

(( $+functions[_gowall_commands] )) ||
_gowall_commands() {
    local -a commands=(
        'convert:convert wallpaper colors to a theme'
        'list:list available themes'
    )
    _describe -t commands 'gowall command' commands
}

_gowall "$@"
