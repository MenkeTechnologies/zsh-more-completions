#compdef pamstretch pnminterp
# Documentation: man pamstretch (Netpbm)
# Source: enlarge a Netpbm image by integer factor with linear interpolation between pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-xscale=[horizontal scale]:X:' \
    '-yscale=[vertical scale]:Y:' \
    '-blackedge[fill edges with black]' \
    '-dropedge[drop the last row/column]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:scale N and/or pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
