#compdef nbping
# Documentation: https://github.com/hanshuaikang/Nping
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# hanshuaikang/Nping

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --count)'{-c+,--count=}'[probe count]:count:' \
  '(-i --interval)'{-i+,--interval=}'[interval seconds]:seconds:' \
  '(-6 --force_ipv6)'{-6,--force_ipv6}'[force IPv6]' \
  '(-m --multiple)'{-m+,--multiple=}'[max target addresses]:n:' \
  '(-v --view-type)'{-v+,--view-type=}'[view mode]:type:(graph table point sparkline)' \
  '(-o --output)'{-o+,--output=}'[save results to file]:file:_files' \
  '*:host:_hosts' && ret=0
return ret
