#compdef eu-ranlib
# _eu-ranlib-bin — elfutils ranlib (Ulrich Drepper, Red Hat); generate index for an ar archive
# upstream: https://sourceware.org/elfutils

_eu-ranlib-bin() {
    _arguments \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:archive:_files -g "*.a"'
}

_eu-ranlib-bin "$@"
