#compdef gd2topng
# Documentation: https://manpages.debian.org/unstable/libgd-tools/gd2topng.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gd2topng - convert a GD2 image file to a PNG image
# Usage: gd2topng input.gd2 output.png

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input GD2:_files -g "*.gd2"' \
  '2:output PNG:_files -g "*.png"' && ret=0

return ret
