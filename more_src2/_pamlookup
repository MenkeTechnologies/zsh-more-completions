#compdef pamlookup
# Documentation: man pamlookup (Netpbm)
# Source: replace each pixel of an index image with a color from a lookup PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-lookupfile=[lookup color PAM file]:file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '-byplane[lookup per-plane]' \
    '-missingcolor=[color for unmatched indices]:color:' \
    '-fit[scale indices to lookup table size]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:index pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
