#compdef mhonarc
# Documentation: https://www.mhonarc.org/MHonArc/doc/app-rcidx.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: MHonArc has ~150 single-dash long options. This completion covers the
# most common subset documented in the resource index. Use `mhonarc -help`
# for the full list.

# mhonarc: mail-to-HTML archiver
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-v[show version]' \
  '-add[add messages to existing archive]' \
  '-archive[treat input as an archive (default)]' \
  '-noarchive[treat input as single message]' \
  '-afs[support AFS access lists]' \
  '-annotate[annotate messages]' \
  '-authsort[sort messages by author]' \
  '-noauthsort[do not sort by author]' \
  '-checknoarchive[skip messages with no-archive flag]' \
  '-conlen[honor Content-Length headers]' \
  '-noconlen[ignore Content-Length headers]' \
  '-outdir[output directory]:dir:_files -/' \
  '-quiet[suppress informational messages]' \
  '-single[process a single message to stdout]' \
  '-addressmodifycode[Perl code to modify addresses]:code:' \
  '-attachmentdir[directory for attachments]:dir:_files -/' \
  '-attachmenturl[URL prefix for attachments]:url:' \
  '-rcfile[resource config file]:file:_files' \
  '-definevar[define resource variable]:name=value:' \
  '-doc[print full documentation URL info]' \
  '-editidx[rebuild index files only]' \
  '-genidx[regenerate index pages]' \
  '-modtime[set output file mtime from message date]' \
  '-msgsep[message separator pattern]:regex:' \
  '-mhpattern[MH-style message pattern]:pattern:' \
  '-reconvert[reconvert all messages]' \
  '-rmm[remove specified messages]' \
  '-scan[show scan listing only]' \
  '-spammode[apply spam-protection filters]' \
  '-tidxprefix[thread index filename prefix]:prefix:' \
  '-idxsize[max index size]:n:' \
  '-multipg[paginate index files]' \
  '-nomain[do not generate main index]' \
  '-nothread[do not generate thread index]' \
  '-thread[generate thread index (default)]' \
  '-treverse[reverse thread sort]' \
  '-savemem[reduce memory usage]' \
  '-stdin[read input from stdin]' \
  '*:input:_files' && ret=0
return ret
