#                                              prototype, iroh,
#                                              pingora, hyperium/h3,
#                                              salvo, shadowsocks/
#                                              qtun, Solana lite-rpc,
#                                              bytedance/g3.
#                 → quincy (Jakub Kubík — post-quantum QUIC-based VPN;
#                            "WireGuard but over QUIC with PQ crypto";
#                            quincy-server + quincy-client binaries
#                            use Quinn for the encrypted tunnel
