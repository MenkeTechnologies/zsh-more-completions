_quincy-client() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--config-path=[path to the client.toml (or server.toml) configuration file (default: client.toml in CWD for quincy-client, server.toml for quincy-server)]:path:_files -g "*.(toml|TOML)"' \
        '--env-prefix=[prefix for environment variable overrides (default QUINCY_ — so QUINCY_QUIC__ENDPOINT=... overrides [quic].endpoint in the TOML; double-underscore becomes dot for nested config keys)]:prefix:'
}

_quincy-client "$@"
