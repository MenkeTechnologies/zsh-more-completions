#compdef dockerfile-utils
# Documentation: https://github.com/rcjsuen/dockerfile-utils
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'format:format a Dockerfile'
      'lint:lint a Dockerfile'
    )
    _describe -t commands 'dockerfile-utils command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      format)
        _arguments -s -S \
          '-s+[number of spaces]:spaces' \
          '--spaces=[number of spaces]:spaces' \
          '1:dockerfile:_files' && ret=0
        ;;
      lint)
        _arguments -s -S \
          '1:dockerfile:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
