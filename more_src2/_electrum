#compdef electrum
# _electrum — Thomas Voegtlin Electrum lightweight Bitcoin SPV wallet with hardware-wallet support (spesmilo team, Python); argparse
# upstream: https://github.com/spesmilo/electrum

_electrum() {
    local -a sub=(
        'gui:start GUI'
        'daemon:run daemon'
        'create:create a new wallet'
        'restore:restore from seed'
        'getmasterprivate:show master private key'
        'getmasterxpub:show master xpub'
        'getseed:show seed'
        'getbalance:show balance'
        'getaddresshistory:show address history'
        'history:show wallet history'
        'getunusedaddress:get unused address'
        'getrequest:show payment request'
        'addrequest:create payment request'
        'rmrequest:delete payment request'
        'listrequests:list payment requests'
        'payto:create payment tx'
        'paytomany:create multi-output tx'
        'broadcast:broadcast a tx'
        'signtransaction:sign tx'
        'serialize:serialize tx'
        'deserialize:deserialize tx'
        'signmessage:sign message'
        'verifymessage:verify signature'
        'encrypt:encrypt message'
        'decrypt:decrypt message'
        'listaddresses:list addresses'
        'listunspent:list UTXOs'
        'importprivkey:import private key'
        'sweep:sweep address'
        'gettransaction:lookup tx'
        'setlabel:set label'
        'getalias:show alias'
        'getfeerate:show fee rate'
        'inject_fees:inject fee estimates'
        'bumpfee:bump tx fee'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--testnet[testnet mode]' \
        '--regtest[regtest mode]' \
        '--simnet[simnet mode]' \
        '--signet[signet mode]' \
        '--portable[portable wallet]' \
        '-D+[data directory]:dir:_files -/' \
        '--dir=+[data directory]:dir:_files -/' \
        '-w+[wallet file]:file:_files' \
        '--wallet=+[wallet file]:file:_files' \
        '--forgetconfig[do not save config]' \
        '-V[verbose]' \
        '--verbosity=+[verbosity]:str:' \
        '-o[offline mode]' \
        '--offline[offline mode]' \
        '-s+[ssl server]:url:_urls' \
        '--server=+[ssl server]:url:_urls' \
        '-p+[proxy]:str:' \
        '--proxy=+[proxy]:str:' \
        '--rpchost=+[rpc host]:host:_hosts' \
        '--rpcport=+[rpc port]:port:_ports' \
        '--rpcuser=+[rpc user]:user:_users' \
        '--rpcpassword=+[rpc password]:str:' \
        '--password=+[wallet password]:str:' \
        '--passphrase=+[passphrase]:str:' \
        '--nbits=+[nbits]:n:' \
        '--from_addr=+[from address]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'electrum subcommand' sub ;;
        args)
            case $words[1] in
                daemon) _arguments '1:daemon cmd:(start stop load_wallet close_wallet status)' ;;
                payto|paytomany) _arguments \
                    '--fee=+[fee BTC]:f:' \
                    '--feerate=+[sat/vB]:f:' \
                    '--from_addr=+[from address]:str:' \
                    '--change_addr=+[change address]:str:' \
                    '--rbf[enable RBF]' \
                    '--unsigned[do not sign]' \
                    '--password=+[password]:str:' ;;
            esac
            ;;
    esac
}

_electrum "$@"
