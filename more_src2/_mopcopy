#compdef mopcopy
# Documentation: man mopcopy(1)
# Source: netbsd/src usr.sbin/mopd/mopcopy — convert executables to MOP image (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:input executable (ELF32 or a.out VAX):_files' \
    '2:output MOP image:_files' \
    && ret=0

return ret
