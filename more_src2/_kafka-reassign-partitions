#compdef kafka-reassign-partitions
# Documentation: https://kafka.apache.org/documentation/ (kafka-reassign-partitions.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--additional[Execute this reassignment in addition to any other ongoing ones]'
    '--bootstrap-controller[The controller to use for reassignment]:host\:port:'
    '--bootstrap-server[The server(s) to use for bootstrapping]:host\:port:'
    '--broker-list[The list of brokers to reassign to in the form "0,1,2"]:broker-ids:'
    '--cancel[Cancel an active reassignment]'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--disable-rack-aware[Disable rack aware replica assignment]'
    "--disallow-replication-factor-change[Deny the ability to change a partition's replication factor]"
    '--execute[Kick off the reassignment as specified by --reassignment-json-file]'
    '--generate[Generate a candidate partition reassignment configuration]'
    '--help[Print usage information]'
    '--list[List all active partition reassignments]'
    '--preserve-throttles[Do not modify broker or topic throttles]'
    '--reassignment-json-file[The JSON file with the partition reassignment configuration]:file:_files'
    '--replica-alter-log-dirs-throttle[Throttle replica movement between log dirs (bytes/sec)]:bytes:'
    '--throttle[Throttle partition movement between brokers (bytes/sec)]:bytes:'
    '--timeout[Maximum time in ms to wait for log dir replica assignment to begin]:ms:'
    '--topics-to-move-json-file[Generate a reassignment config to move the given topics]:file:_files'
    '--verify[Verify if the reassignment completed]'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
