#compdef nload
# Documentation: https://man.archlinux.org/man/nload.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Per man page: -a period, -i max_scaling, -o max_scaling, -t interval,
# -u/-U take single-char unit codes [h|H|b|B|k|K|m|M|g|G], -m flag,
# -h short help (no --help). Trailing args are network devices.

_nload_interfaces() {
  local -a interfaces
  if [[ -d /sys/class/net ]]; then
    interfaces=( /sys/class/net/*(N:t) )
  fi
  _describe -t interfaces 'network interface' interfaces
}

_arguments -s -S \
  '-a[average calculation time window]:seconds' \
  '-i[max scaling for incoming traffic graph in kBit/s]:max value' \
  '-o[max scaling for outgoing traffic graph in kBit/s]:max value' \
  '-t[refresh interval]:milliseconds' \
  '-u[display unit for traffic rates]:unit:(h H b B k K m M g G)' \
  '-U[display unit for data amounts]:unit:(h H b B k K m M g G)' \
  '-m[show multiple devices and hide traffic graphs]' \
  '(- *)-h[show help]' \
  '*:network interface:_nload_interfaces'
