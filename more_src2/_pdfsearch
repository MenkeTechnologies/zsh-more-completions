#compdef pdfsearch pdf-search
# _pdfsearch — Patrick Mathieu pdfsearch CLI for indexing and grep-style fuzzy searching across PDF document collections with poppler text extraction and Tantivy-style search backend (PMV-Tech team, Python); argparse
# upstream: https://github.com/PMV-Tech/pdfsearch

_pdfsearch() {
    local -a sub=(
        'index:index a directory of PDFs'
        'search:search index for query'
        'reindex:reindex'
        'stats:show index stats'
        'remove:remove file from index'
        'list:list indexed files'
        'serve:serve search HTTP API'
        'export:export search results'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--index-dir=+[dir]:dir:_files -/' \
        '-i+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.toml *.yaml *.yml"' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pdfsearch subcommand' sub ;;
        args)
            case $words[1] in
                index|reindex) _arguments \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '--ocr[OCR scanned pages]' \
                    '--ocr-language=+[lang]:l:(eng deu fra spa ita por nld rus jpn kor chi_sim chi_tra ara hin)' \
                    '--workers=+[N]:n:' \
                    '--chunk-size=+[chars]:n:' \
                    '--overlap=+[chars]:n:' \
                    '*:dir or file:_files' ;;
                search) _arguments \
                    '--limit=+[N]:n:' \
                    '-n+[N]:n:' \
                    '--snippets[show snippets]' \
                    '--no-snippets[no snippets]' \
                    '--filter=+[expr]:str:' \
                    '--sort=+[s]:s:(relevance date title path size)' \
                    '--format=+[fmt]:f:(text json csv markdown html)' \
                    '--page-range[show page range]' \
                    '*:query:' ;;
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--workers=+[N]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_pdfsearch "$@"
