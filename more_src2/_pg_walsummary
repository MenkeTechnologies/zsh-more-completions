#compdef pg_walsummary
# Documentation: https://www.postgresql.org/docs/current/app-pgwalsummary.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# pg_walsummary: print WAL summary file contents (PG 17+)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-i --individual)'{-i,--individual}'[print one line per modified block]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output except errors]' \
  '*:wal summary file:_files' && ret=0
return ret
