#compdef delayer
# Documentation: man delayer(8)
# Source: InterNetNews/inn backends/delayer.in — delay channel pipe by N seconds (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--delay=[delay seconds]:secs:_default' \
    '(--buffered --no-buffered)--buffered[buffer output (default)]' \
    '(--buffered --no-buffered)--no-buffered[unbuffered output]' \
    '--store=[checkpoint queue file]:file:_files' \
    '*::command:_command_names -e' \
    && ret=0

return ret
