#compdef gdal_sieve gdal_sieve.py
# Documentation: https://gdal.org/programs/gdal_sieve.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-st+[size threshold (pixels)]:n:' \
  '-4[use 4-connectedness]' \
  '-8[use 8-connectedness]' \
  '-nomask[do not use default mask]' \
  '-mask+[mask file]:file:_files' \
  '-of+[output format]:format:' \
  '*-o+[creation option NAME=VALUE]:NAME=VALUE:' \
  '-q[quiet]' \
  '1:source file:_files' \
  '2::destination file:_files' && ret=0

return ret
