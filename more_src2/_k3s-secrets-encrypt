#compdef k3s-secrets-encrypt
# _k3s-secrets-encrypt — control k3s secrets encryption and key rotation (k3s-io/k3s)
# upstream: https://github.com/k3s-io/k3s
# Subcommands from pkg/cli/cmds/secrets_encrypt.go (urfave/cli).

_k3s-secrets-encrypt() {
    local context state state_descr line
    typeset -A opt_args
    local -a common=(
        '--data-dir=[data directory]:dir:_files -/'
        '(-t --token)'{-t+,--token=}'[shared secret for the cluster]:token:'
        '(-s --server)'{-s+,--server=}'[k3s API server URL]:url:_urls'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                status:'print current status of secrets encryption'
                enable:'enable secrets encryption'
                disable:'disable secrets encryption'
                prepare:'prepare for encryption key rotation'
                rotate:'rotate secrets encryption keys'
                reencrypt:'reencrypt all data with new encryption key'
                rotate-keys:'dynamically rotate keys and reencrypt secrets'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                status)
                    _arguments $common \
                        '(-o --output)'{-o+,--output=}'[output format]:format:(text json)' ;;
                prepare|rotate)
                    _arguments $common \
                        '(-f --force)'{-f,--force}'[force this stage]' ;;
                reencrypt)
                    _arguments $common \
                        '(-f --force)'{-f,--force}'[force this stage]' \
                        '--skip[skip removing old key]' ;;
                enable|disable|rotate-keys)
                    _arguments $common ;;
            esac
            ;;
    esac
}

_k3s-secrets-encrypt "$@"
