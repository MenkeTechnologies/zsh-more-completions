#compdef nsd-control-setup
# Documentation: https://manpages.debian.org/bookworm/nsd/nsd-control-setup.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm nsd-control-setup(8) - shell script generates
# NSD remote control TLS certificates.

# nsd-control-setup: generate NSD remote-control TLS certificates
local curcontext="$curcontext" ret=1
_arguments -C \
  '-d[directory for certificate files]:dir:_files -/' && ret=0
return ret
