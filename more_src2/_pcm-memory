#compdef pcm-memory
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-memory.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-memory: Intel PCM memory bandwidth monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-u[update measurements in place]' \
  '-columns=-[number of columns for NUMA node display]:n:' \
  '-nc[suppress per-channel output]' \
  '--nochannel[suppress per-channel output]' \
  '--nocxl[suppress CXL port output]' \
  '-all[display all channels including inactive]' \
  '-pmm[monitor PMM memory bandwidth]' \
  '-pmem[monitor PMM memory bandwidth]' \
  '-mm[monitor detailed PMM memory mode metrics]' \
  '-mixed[monitor PMM mixed mode]' \
  '-partial[monitor partial writes]' \
  '-rank=-[monitor specific DIMM rank]:rank:' \
  '-i=-[number of iterations]:n:' \
  '*::pcm-memory args:_files' && ret=0
return ret
