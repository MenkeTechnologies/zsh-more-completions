#compdef pnmtosgi
# Documentation: man pnmtosgi (Netpbm)
# Source: convert a Netpbm image to an SGI image file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-verbatim -rle)-verbatim[verbatim encoding]' \
    '(-verbatim -rle)-rle[RLE encoding]' \
    '-imagename+[image name in file header]:name:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
