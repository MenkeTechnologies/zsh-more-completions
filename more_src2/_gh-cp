#compdef gh-cp gh-find-code gh-graph gh-user-stars
# Documentation: upstream READMEs at github.com/{mislav/gh-cp,LangLangBart/gh-find-code,kawarimidoll/gh-graph,korosuke613/gh-user-stars}
# Reference accessed: 2026-05-30
# gh-extension family round 6. Companions to rounds 158-162 multi-stems
# and the pre-existing _gh-poi/_gh-notify/_gh-dash/etc files.
# Hunt-defer log this round:
#   gh-download (yuler/gh-download) — README describes capabilities (private
#     repos, GitHub URLs, gh token via gh config get) without naming
#     specific CLI flags. Defer.
#   gh-userfetch (sheepla/gh-userfetch) — ARCHIVED 2022-07-23 with only
#     bare `gh userfetch` documented. Skip per archived-no-surface
#     precedent.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-cp)
    # mislav/gh-cp — copy a single file from a GitHub repo without cloning.
    #   gh cp <repo> <path> <dest>
    _arguments -s -S \
      '1:repo (e.g. cli/cli):' \
      '2:path within repo:' \
      '3:local destination:_files' \
      && ret=0
    ;;

  gh-find-code)
    # LangLangBart/gh-find-code — fzf-driven code search via GitHub REST API.
    #   gh find-code [Flags] [Search Query]
    # Per upstream README the documented CLI flags are -l and -h; everything
    # else is interactive (fzf keybindings: ? / ctrl-b / ctrl-o / ctrl-p /
    # ctrl-r / ctrl-space / ctrl-t / ctrl-x / enter / tab / esc).
    _arguments -s -S \
      '(-h)-h[show help]' \
      '(-l)-l+[result limit (default 30, max 100)]:N:' \
      '*:search query:' \
      && ret=0
    ;;

  gh-graph)
    # kawarimidoll/gh-graph — render GitHub contribution graph in terminal.
    #   gh graph [--pixel CHAR] [--scheme THEME] [--help]
    _arguments -s -S \
      '(- *)--help[show help]' \
      '--pixel=[pixel display character]:char:' \
      '--scheme=[color scheme/theme name]:scheme:' \
      && ret=0
    ;;

  gh-user-stars)
    # korosuke613/gh-user-stars — fzf-driven starred-repo browser.
    #   gh user-stars [NUMBER]
    # NUMBER = batch size (default 50, max 100).
    _arguments -s -S \
      '1:batch size 1-100 (default 50):' \
      && ret=0
    ;;

esac

return ret
