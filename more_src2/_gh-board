#compdef gh-board gh-default-branch gh-prj gh-prpeek gh-workflow-ls
# Documentation: upstream READMEs at github.com/{uzimaru0000/gh-board,daido1976/gh-default-branch,MH4GF/gh-prj,balfons/gh-prpeek,Kesin11/gh-workflow-ls}
# Reference accessed: 2026-05-30
# gh-extension family round 9. Continued TypeScript + Rust slice harvest.
# Hunt-skip log this round:
#   gh-traffic (yskszk63/gh-traffic) — bare `gh traffic` only, no flags
#     documented; skip per the bare-TUI-no-surface precedent.
#   gh-activity (nogtk/gh-activity) — interactive wrapper around `gh pr
#     list` with no documented CLI flags; skip per the same precedent.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-board)
    # uzimaru0000/gh-board — Rust TUI kanban board for GitHub Projects V2.
    #   gh board                                # interactive project selection
    #   gh board --owner <login> <number>       # open specific project
    _arguments -s -S \
      '--owner=[organization or user (@me for current account)]:login:' \
      '--no-cache[bypass local cache and fetch fresh data]' \
      '1:project number:' \
      && ret=0
    ;;

  gh-default-branch)
    # daido1976/gh-default-branch — show / rename repository default branch.
    local -a _subcmds
    _subcmds=(
      'show:display the default branch'
      'rename:change the default branch to a new name'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-default-branch subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          show)
            _arguments \
              '(-n --name-only)-n[output only the branch name]' \
              '(-n --name-only)--name-only[output only the branch name]' && ret=0
            ;;
          rename)
            _arguments '1:new branch name:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-prj)
    # MH4GF/gh-prj — browse and inspect GitHub Projects.
    local -a _subcmds
    _subcmds=(
      'list:list projects in this repository'
      'view:display the information about a project'
    )
    _arguments -C -s -S \
      '(- *)-h[show help]' \
      '(- *)-V[show version]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-prj subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

  gh-prpeek)
    # balfons/gh-prpeek — live PR status monitor.
    #   gh prpeek --repos OWNER/REPO[,OWNER/REPO...]
    #              [--interval SECS] [--labels L1[,L2...]]
    #              [--notify] [--hide-checks] [--show-labels]
    _arguments -s -S \
      '--repos=[target repos (OWNER/REPO[,OWNER/REPO...])]:repos:' \
      '--interval=[update frequency in seconds (default 60)]:secs:' \
      '--labels=[filter by labels (comma-separated)]:labels:' \
      '--notify[enable notifications (default on)]' \
      '--hide-checks[hide individual check results]' \
      '--show-labels[display PR labels in output]' \
      && ret=0
    ;;

  gh-workflow-ls)
    # Kesin11/gh-workflow-ls — expand reusable workflow + composite action calls.
    #   gh workflow-ls [-t TOKEN] <run-URL>
    # -t can be omitted if GITHUB_TOKEN env var is set.
    _arguments -s -S \
      '-t+[GitHub token (overrides $GITHUB_TOKEN)]:token:' \
      '1:GitHub Actions run URL:' \
      && ret=0
    ;;

esac

return ret
