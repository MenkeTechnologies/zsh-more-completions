_kontroll() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-p --port)'{-p,--port}'=[server socket path (Linux/macOS) or port (Windows)]:path-or-port:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _kt_cmds=(
                'status:get the status of the currently connected keyboard'
                'list:list all available keyboards'
                'connect:connect to a keyboard by index'
                'connect-any:connect to the first keyboard detected by Keymapp'
                'set-layer:set the layer of the currently connected keyboard'
                'set-rgb:set the RGB color of a single LED'
                'set-rgb-all:set the RGB color of all LEDs'
                'restore-rgb-leds:restore the RGB color of all LEDs to their default'
                'set-status-led:set or unset a status LED'
                'restore-status-leds:restore all status LEDs to their default'
                'increase-brightness:increase the LED brightness'
                'decrease-brightness:decrease the LED brightness'
                'disconnect:disconnect from the currently connected keyboard'
            )
            _describe -t commands 'kontroll command' _kt_cmds && ret=0
            ;;
        args)
            case $words[1] in
                status)
                    _arguments '(-j --json)'{-j,--json}'[output JSON instead of human-readable text]' && ret=0
                    ;;
                connect|set-layer)
                    _arguments '(-i --index)'{-i,--index}'=[keyboard / layer index]:n:' && ret=0
                    ;;
                set-rgb)
                    _arguments \
                        '(-l --led)'{-l,--led}'=[LED index]:n:' \
                        '(-c --color)'{-c,--color}'=[hex RGB color]:hex:' \
                        '(-s --sustain)'{-s,--sustain}'=[sustain duration]:n:' && ret=0
                    ;;
                set-rgb-all)
                    _arguments \
                        '(-c --color)'{-c,--color}'=[hex RGB color]:hex:' \
                        '(-s --sustain)'{-s,--sustain}'=[sustain duration]:n:' && ret=0
                    ;;
                set-status-led)
                    _arguments \
                        '(-l --led)'{-l,--led}'=[status LED index]:n:' \
                        '(-o --off)'{-o,--off}'[turn the status LED off (default is on)]' \
                        '(-s --sustain)'{-s,--sustain}'=[sustain duration]:n:' && ret=0
                    ;;
                increase-brightness|decrease-brightness)
                    _arguments '(-s --steps)'{-s,--steps}'=[brightness steps (default 1)]:n:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_kontroll "$@"
