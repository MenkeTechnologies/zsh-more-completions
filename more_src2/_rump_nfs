#compdef rump_nfs
# Documentation: man rump_nfs(8)
# Source: netbsd/src usr.sbin/puffs/rump_nfs — mount an NFS share via userspace rump server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (see mount_nfs(8))]:options:_default' \
    '1:NFS share (host\:path):_default' \
    '2:mount point:_files -/' \
    && ret=0

return ret
