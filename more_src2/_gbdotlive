_gbdotlive() {
    _arguments -s -S \
        '-g[play specific game in GUI mode (default true)]' \
        '-G[play specific game in Fyne GUI mode]' \
        '-s[start a cloud-gaming server (Telnet)]' \
        '-S[start a static-image cloud-gaming server (HTTP PNG)]' \
        '-m[turn on sound in GUI mode (default true)]' \
        '-d[use debugger in GUI mode]' \
        '-p[set port for cloud-gaming server (default 1989)]:port:' \
        '-f[set FPS in GUI mode (default 60)]:fps:' \
        '-c[game option list config file path]:config:_files -g "*.json"' \
        '-r[ROM file path to be played in GUI mode]:rom:_files -g "*.(gb|gbc|GB|GBC)"' \
        '-h[show help]' \
        '-help[show help]'
}

