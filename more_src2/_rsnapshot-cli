#compdef rsnapshot-cli
# Documentation: https://github.com/rsnapshot/rsnapshot (rsnapshot-program.pl getopts 'vtxqVDc:')
# Reference accessed: 2026-05-21
# Verified: upstream source at https://raw.githubusercontent.com/rsnapshot/rsnapshot/master/rsnapshot-program.pl
# STUB-ish: rsnapshot-cli mirrors rsnapshot's single-dash CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v[verbose]' \
  '-t[test mode, show shell commands that would be executed]' \
  '-x[one filesystem, do not cross partitions]' \
  '-q[quiet, suppress non-fatal warnings]' \
  '-V[more detailed verbose]' \
  '-D[firehose of diagnostic information]' \
  '-c+[config file]:file:_files' \
  '*: :_values "command" configtest help version version-only check-config-version upgrade-config-file du diff sync hourly daily weekly monthly yearly get-latest-snapshot' && ret=0

return ret
