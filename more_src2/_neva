# ============================================================================
# _neva — zsh completion for nevalang's `neva` CLI, the dataflow
#          programming language with static types and implicit parallelism
#          (163rd programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/nevalang/neva
#   Maintainer : nevalang (Emil Valeev / @emil14 et al.)
#   License    : MIT
#   Stars      : 1069
#   Language   : Go (compiler + runtime)
#   Module     : github.com/nevalang/neva
#   Binary     : neva  (cmd/neva/main.go → cli.NewApp via
#                       urfave/cli/v2 v2.27.1)
#   Source ext : .neva
#   Last push  : 2026-05-31
#
# WHAT IT IS
#   Nevalang ("neva") is "the next-gen programming language for
#   humans and AI" — a hybrid visual/textual dataflow language with
#   static structural types and implicit parallelism by default.
#   Programs are graphs of typed components connected by typed ports;
#   the runtime schedules every component independently, so any two
#   components without an explicit data dependency execute in
#   parallel.  Targets include native (via Go codegen), WebAssembly,
#   pure Go packages, and an inspectable intermediate representation
#   in JSON, YAML, GraphViz DOT, Mermaid, or three.js form.  The
#   driver bundles a project scaffolder, a dependency manager
#   (`neva get`), an installer (`neva install`), a doc/symbol
#   searcher (`neva doc`), and an OS/arch matrix lister
#   (`neva osarch`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from internal/cli/cli.go and the
#                       per-subcommand `internal/cli/<name>.go`
#                       files — urfave/cli/v2 Commands + Flags)
#   neva <SUBCOMMAND> [OPTIONS] [ARGS...]
#
#   Subcommands:
#     version                      Print the current Nevalang version
#
#     upgrade                      Upgrade to the newest Nevalang
#                                  version (runs the install.sh
#                                  script)
#
#     new [<DIR>]                  Scaffold a new neva project
#       -t, --template <REPO>        Template repository (optionally
#                                    suffixed with a revision)
#
#     get <PATH> <VERSION>         Add a dependency to the current
#                                  module
#
#     install <MAIN_PACKAGE>       Build and install a neva program
#
#     run <MAIN_PACKAGE>           Build and run a neva program from
#                                  source
#       --emit-trace                 Write a real-time trace to file
#       --debug-runtime-validation   Enable compiler runtime port
#                                    validation (language devs only)
#       --emit-ir                    Emit intermediate representation
#                                    before running
#       --emit-ir-format <FMT>       IR format if --emit-ir is set
#       --watch                      Rebuild and rerun on file change
#
#     build <MAIN_PACKAGE>         Compile a neva program
#       --output <DIR>               Output directory
#       --emit-trace                 Emit a trace file
#       --debug-runtime-validation   Compiler runtime port validation
#       --target <T>                 Target platform
#                                    (go|wasm|native|ir)
#       --target-os <OS>             Native target OS
#       --target-arch <ARCH>         Native target architecture
#       --target-go-mode <M>         Go target mode (executable|pkg)
#       --target-ir-format <FMT>     IR target format
#                                    (json|yaml|dot|mermaid|threejs)
#       --target-go-runtime-path <P> Go runtime import path
#                                    (only for go target)
#
#     osarch                       List supported OS/arch combos for
#                                  the native target
#
#     doc [PACKAGE_PATH] <PATTERN> Search the standard library for
#                                  symbols using regex
#       -C, --context <N>            Context lines around each match
#
#   Standard urfave/cli auto-flags:
#     -h, --help                   Show help
#     -v, --version                Print version
#
# LANGUAGE-CORPUS POSITION
#   Nevalang is the 163rd programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began at
#   R921 (_graphql-client / graphql-rust Rust=138 OPENS Axis 83
#   GraphQL Client Library) and continued through R922 (_gqlgenc /
#   gqlgo Go=138) and R923 (_gql-tada / 0no-co TS-Node=138 CLOSES
#   Axis 83 at 1/1/1 three-language symmetry — triple-138 landmark
#   and 76th axis closed).  Nevalang joins Corvid (R920 162nd —
#   round-number R920 commit landmark), Soppo (R916 161st), Cyrus
#   (R912 160th — round-number language milestone), Lumina (R908
#   159th), Penne (R904 158th), EndBASIC (R900 157th — R900
#   TRIPLE-9 commit landmark), goboscript (R896 156th), Alan
#   (R892 155th), Mech (R888 154th — triple-8 landmark), Lisette
#   (R884 153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG
#   (R872 150th — round-number language milestone), Roto (R868
#   149th), Pipefish (R864 148th), Mochi (R860 147th), Oden
#   (R856 146th), Hop (R852 145th), Lustre via Kind 2 (R848
#   144th), Ravi (R844 143rd), ZetZ (R840 142nd), Granule (R836
#   141st), Sixten (R832 140th), Imba (R828 139th), Tao (R824
#   138th), Dada (R820 137th), Acton (R816 136th), and Stanza
#   (R812 135th).
#
#   No completion for `neva` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_neva() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_neva_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                version|upgrade|osarch)
                    _arguments && ret=0 ;;
                new)
                    _arguments \
                        '(-t --template)'{-t,--template}'=[template repository (optionally suffixed with revision)]:repo:' \
                        ':project dir:_files -/' && ret=0 ;;
                get)
                    _arguments \
                        ':module path:' \
                        ':version:' && ret=0 ;;
                install)
                    _arguments \
                        ':main package:_files -g "*.neva" -/' && ret=0 ;;
                run)
                    _arguments \
                        '--emit-trace[write real-time trace to file]' \
                        '--debug-runtime-validation[enable compiler runtime port validation]' \
                        '--emit-ir[emit intermediate representation before running]' \
                        '--emit-ir-format=[IR format if --emit-ir is set]:format:(json yaml dot mermaid threejs)' \
                        '--watch[rebuild and rerun when source files change]' \
                        ':main package:_files -g "*.neva" -/' && ret=0 ;;
                build)
                    _arguments \
                        '--output=[output directory]:dir:_files -/' \
                        '--emit-trace[emit trace file]' \
                        '--debug-runtime-validation[enable compiler runtime port validation]' \
                        '--target=[target platform]:target:(go wasm native ir)' \
                        '--target-os=[target OS (only for native target)]:os:' \
                        '--target-arch=[target architecture (only for native target)]:arch:' \
                        '--target-go-mode=[Go target mode]:mode:(executable pkg)' \
                        '--target-ir-format=[IR target format]:format:(json yaml dot mermaid threejs)' \
                        '--target-go-runtime-path=[Go runtime import path (go target only)]:path:' \
                        ':main package:_files -g "*.neva" -/' && ret=0 ;;
                doc)
                    _arguments \
                        '(-C --context)'{-C,--context}'=[context lines around each match]:n:' \
                        '*:package/path or pattern:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_neva_commands] )) ||
_neva_commands() {
    local -a commands
    commands=(
        'version:print current Nevalang version'
        'upgrade:upgrade to newest Nevalang version'
        'new:create new neva project'
        'get:add dependency to current module'
        'install:build and install neva program'
        'run:build and run neva program from source'
        'build:compile neva program'
        'osarch:list supported OS/arch combos for native target'
        'doc:search standard library for symbols using regex'
    )
    _describe -t commands 'neva command' commands
}

_neva "$@"
