#compdef libsodium-config
# _libsodium — libsodium configure helper; prints compile/link flags for libsodium (NaCl-compatible crypto library)
# upstream: https://github.com/jedisct1/libsodium

_libsodium() {
    _arguments \
        '--prefix[print install prefix]' \
        '--exec-prefix[print exec prefix]' \
        '--libs[print linker flags]' \
        '--cflags[print compile flags]' \
        '--version[print version]' \
        '--includedir[print include dir]' \
        '--libdir[print lib dir]' \
        '--datarootdir[print data root dir]'
}

_libsodium "$@"
