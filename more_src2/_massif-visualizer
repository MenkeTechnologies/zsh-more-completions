#compdef massif-visualizer
# _massif-visualizer — Massif heap profile visualizer (Qt/KDE); UI for valgrind --tool=massif output
# upstream: https://invent.kde.org/sdk/massif-visualizer

_massif-visualizer() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:' \
        '*:massif file:_files -g "massif.out*"'
}

_massif-visualizer "$@"
