#compdef git-sync
# Documentation: https://github.com/kubernetes/git-sync
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Kubernetes sidecar that clones and keeps a git repo in sync.

_arguments -s -S \
  '--repo=[remote git repo to sync]:url:' \
  '--root=[working directory for git-sync]:dir:_files -/' \
  '--ref=[git revision (branch, tag, hash) to check out]:ref:' \
  '--period=[wait between sync attempts]:duration:' \
  '--one-time[exit after completing a single sync]' \
  '--depth=[create a shallow clone of this depth]:n:' \
  '--max-failures=[consecutive failures allowed before aborting]:n:' \
  '--init-max-failures=[failure threshold during initial sync]:n:' \
  '--link=[symlink name pointing at current git dir]:name:' \
  '--sync-timeout=[total time allowed for one sync]:duration:' \
  '--webhook-url=[URL to call after successful syncs]:url:' \
  '--http-bind=[bind address for HTTP endpoint]:addr:' \
  '--group-write[ensure data written is group writable]' \
  '--github-app-client-id=[client id for GitHub app authentication]:id:' \
  '(-v --verbose)'{-v,--verbose}'[adjust logging verbosity]' \
  '--version[print version and exit]' \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '*::args:_default' && return 0
