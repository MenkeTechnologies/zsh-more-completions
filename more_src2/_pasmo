#compdef pasmo
# Documentation: https://manpages.ubuntu.com/manpages/jammy/en/man1/pasmo.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-d[show debug info during assembly]' \
  '-1[debug info including first pass]' \
  '-v[verbose progress info]' \
  '-8[warn about non-8080 Z80 instructions]' \
  '--86[generate 8086 code]' \
  '--alocal[autolocal mode for underscore-prefixed labels]' \
  '--amsdos[Amsdos header for Amstrad CPC disk]' \
  '--bin[pure binary output (default)]' \
  '--bracket[parentheses reserved for expressions]' \
  '-B[parentheses reserved for expressions]' \
  '--cdt[CDT tape image for Spectrum]' \
  '--cdtbas[CDT format with BASIC loader]' \
  '--equ[predefine labels]:label:' \
  '-E[predefine labels]:label:' \
  '--err[direct errors to standard output]' \
  '--hex[Intel HEX output]' \
  '-I+[include search path]:dir:_files -/' \
  '--msx[header for BLOAD in MSX BASIC]' \
  '--name[header name]:name:' \
  '--nocase[case-insensitive identifiers]' \
  '--plus3dos[PLUS3DOS header for Spectrum disk]' \
  '--prl[PRL format for CP/M Plus RSX]' \
  '--public[include only PUBLIC symbols in listing]' \
  '--tap[TAP tape image for Spectrum]' \
  '--tapbas[TAP format with BASIC loader]' \
  '--tzx[TZX tape image for Spectrum]' \
  '--tzxbas[TZX format with BASIC loader]' \
  '-w[warn about non-8080 Z80 instructions]' \
  '-h[show help]' \
  '--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '*: :_files -g "*.(asm|s|z80|inc)"' && ret=0

return ret
