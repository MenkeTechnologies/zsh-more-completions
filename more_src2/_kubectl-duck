#compdef kubectl-duck
# Documentation: https://github.com/n3wscott/kubectl-duck
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --v)'{-v+,--v=}'[log level for V logs]:level:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'list:list CustomResourceDefinitions that implement ducktypes'
      'get:get resource instances of a given ducktype'
    )
    _describe -t commands 'kubectl-duck command' commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
