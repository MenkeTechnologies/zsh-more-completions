#compdef llvm-dis
# _llvm-dis — LLVM bitcode disassembler (LLVM project, C++); convert LLVM bitcode (.bc) to IR (.ll)
# upstream: https://github.com/llvm/llvm-project

_llvm-dis() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-f[force overwrite]' \
        '-o+[output file]:file:_files' \
        '--show-annotations[show annotations]' \
        '--print-thinlto-index-only[print thinlto index only]' \
        '--materialize-metadata[materialize metadata]' \
        '--preserve-ll-uselistorder[preserve use-list order]' \
        '*:file:_files -g "*.bc"'
}

_llvm-dis "$@"
