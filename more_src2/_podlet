#compdef podlet
# Documentation: https://github.com/containers/podlet
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-f --file)'{-f+,--file=}'[generate file(s) instead of stdout]:file:_files' \
  '(-u --unit-directory)'{-u,--unit-directory}'[generate file(s) in podman unit directory]' \
  '--quadlets-file=[generate a single .quadlets file]:name' \
  '(-n --name)'{-n+,--name=}'[override generated file name]:name' \
  '--overwrite[overwrite existing files]' \
  '(-s --split-options)'{-s+,--split-options=}'[split quadlet options]:options' \
  '--skip-services-check[skip check for existing services]' \
  '(-p --podman-version)'{-p+,--podman-version=}'[podman compatibility version]:version' \
  '(-a --absolute-host-paths)'{-a,--absolute-host-paths}'[convert relative paths to absolute]' \
  '--service-name=[change systemd service name]:name' \
  '(-d --description)'{-d+,--description=}'[add unit description]:description' \
  '*--wants=[weak requirement dependencies]:units' \
  '*--requires=[stronger requirement dependencies]:units' \
  '*--binds-to=[binding dependencies]:units' \
  '*--part-of=[part-of dependencies]:units' \
  '*--upholds=[upholds dependencies]:units' \
  '*--before=[ordering dependency: before]:units' \
  '*--after=[ordering dependency: after]:units' \
  '(-i --install)'{-i,--install}'[add [Install] section]' \
  '*--wanted-by=[weak parent dependencies]:units' \
  '*--required-by=[stronger parent dependencies]:units' \
  '*--upheld-by=[upheld-by dependencies]:units' \
  '--disable-default-quadlet-dependencies[disable default network dependencies]' \
  '--no-start-with-pod[prevent container units from starting with pod]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'podman:generate a Quadlet file from a Podman command'
      'compose:generate Quadlet files from a compose file'
      'generate:generate a Quadlet file from an existing object'
      'help:print help information'
    )
    _describe -t commands 'podlet command' commands && ret=0
    ;;
  args)
    case $line[1] in
      compose)
        _arguments \
          '--pod[generate a pod quadlet]' \
          '*:compose file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      generate)
        _arguments '1:type:(container volume network kube image pod)' && ret=0
        ;;
      podman)
        _arguments '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
