#compdef nc
# Documentation: man nc(1) on macOS
# Source: macOS / Apple nc (netcat) — arbitrary TCP and UDP connections and listens.
# Reference accessed: 2026-06-10
# NOTE: this is Apple's nc, distinct from GNU netcat / OpenBSD netcat.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-4 -6)-4[force IPv4 addresses only]' \
    '(-4 -6)-6[force IPv6 addresses only]' \
    '-A[set SO_RECV_ANYIF on the socket]' \
    '-b+[bind socket to interface]:boundif:_net_interfaces' \
    '-c[send CRLF as line-ending]' \
    '-D[enable SO_DEBUG on socket]' \
    '-C[do not use cellular data context]' \
    '-d[do not attempt to read from stdin]' \
    '(- *)-h[print nc help]' \
    '-i+[delay between sent/received lines and between ports]:interval-seconds:' \
    '-G+[TCP connect timeout (s)]:conntimeout:' \
    '-H+[initial TCP keepalive idle (s)]:keepidle:' \
    '-I+[TCP keepalive interval (s)]:keepintvl:' \
    '-J+[TCP keepalive packet count]:keepcnt:' \
    '-k[keep listening after current connection closes]' \
    '-l[listen for incoming connection]' \
    '-L+[probes before declaring peer unreachable]:num-probes:' \
    '-n[no DNS or service lookups]' \
    '-p+[source port]:source-port:' \
    '-r[choose source/destination ports randomly]' \
    '-s+[source IP address]:source-ip:_hosts' \
    '-t[answer telnet DO/WILL with DONT/WONT]' \
    '-U[use Unix domain sockets]' \
    '-u[use UDP instead of TCP]' \
    '*-v[verbose output]' \
    '-w+[idle-connection timeout (s)]:timeout:' \
    '-X+[proxy protocol]:proxy-version:(4 5 connect)' \
    '-x+[proxy address\:port]:proxy-address\:port:' \
    '-z[port scan: do not send data]' \
    '--apple-delegate-pid=[delegate socket to PID]:pid:_pids' \
    '--apple-delegate-uuid=[delegate socket to UUID]:uuid:' \
    '--apple-ext-bk-idle[mark socket for extended background idle]' \
    '--apple-nowakefromsleep=[exclude port from sleep wake list]:n:' \
    '--apple-ecn=[explicit congestion notification mode]:mode:' \
    '1:hostname:_hosts' \
    '*:port[s]:_ports' \
    && ret=0

return ret
