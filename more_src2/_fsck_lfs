#compdef fsck_lfs
# Documentation: man fsck_lfs(8)
# Source: netbsd/src sbin/fsck_lfs — LFS consistency check and repair (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[suppress available block accounting discrepancies]' \
    '-b+[block to use as superblock]:block:_default' \
    '-d[debugging output]' \
    '-f[force checking regardless of clean flag]' \
    '-i+[disk address of index file inode]:idaddr:_default' \
    '-m+[mode bits for lost+found (default 1700)]:mode:_default' \
    '(-y)-n[assume no to all prompts, no write access]' \
    '-p[preen mode]' \
    '-q[quiet mode for clean filesystems]' \
    '-U[resolve user identifiers to usernames]' \
    '(-n)-y[assume yes to all prompts]' \
    '*:filesystem:_files' \
    && ret=0

return ret
