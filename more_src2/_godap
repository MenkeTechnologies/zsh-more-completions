#compdef godap
# Documentation: https://github.com/Macmod/godap
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# cobra (godap.go). Secondary: `godap version`
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-P --port)'{-P,--port}'=-[LDAP port 0=auto]:port:' \
  '(-u --username)'{-u,--username}'=-[bind DN or user]' \
  '(-p --password)'{-p,--password}'=-[bind password]' \
  '--passfile=-[password file or - for stdin]:file:_files' \
  '(-d --domain)'{-d,--domain}'=-[NTLM/Kerberos domain]' \
  '(-H --hash)'{-H,--hash}'=-[NTLM hash]' \
  '--hashfile=-[NTLM hash file]:file:_files' \
  '(-k --kerberos)'{-k,--kerberos}'[Kerberos via KRB5CCNAME]' \
  '(-t --spn)'{-t,--spn}'=-[Kerberos SPN e.g. ldap/dc]' \
  '--kdc=-[KDC address if not LDAP host]:host:' \
  '(-r --rootDN)'{-r,--rootDN}'=-[starting base DN]' \
  '(-f --filter)'{-f,--filter}'=-[initial search filter]:filter:' \
  '(-E --emojis)'{-E,--emojis}'[prefix rows with emojis]' \
  '(-C --colors)'{-C,--colors}'[colorized output]' \
  '(-F --format)'{-F,--format}'[pretty-print attribute values]' \
  '(-A --expand)'{-A,--expand}'[expand multi-valued attrs]' \
  '(-L --limit)'{-L,--limit}'=-[multi-value display limit]:n:' \
  '(-M --cache)'{-M,--cache}'[cache loaded entries in memory]' \
  '(-D --deleted)'{-D,--deleted}'[include deleted AD objects]' \
  '(-T --timeout)'{-T,--timeout}'=-[LDAP timeout seconds]:sec:' \
  '(-s --schema)'{-s,--schema}'[load server schema GUIDs]' \
  '(-G --paging)'{-G,--paging}'=-[paging size]:n:' \
  '(-I --insecure)'{-I,--insecure}'[skip TLS verify]' \
  '(-S --ldaps)'{-S,--ldaps}'[LDAP over TLS]' \
  '(-x --socks)'{-x,--socks}'=-[SOCKS proxy for connect]:proxy:' \
  '--timefmt=-[LDAP timestamp format string]:fmt:' \
  '--crt=-[client cert PEM]:file:_files' \
  '--key=-[client key PEM]:file:_files' \
  '--pfx=-[client PKCS#12 bundle]:file:_files' \
  '--attrsort=-[attribute ordering]:mode:(none asc desc)' \
  '--offset=-[hours added to formatted times]:hours:' \
  '--exportdir=-[Ctrl+S export directory]:dir:_directories' \
  '(-b --backend)'{-b,--backend}'=-[directory quirks]:flavor:(msad basic auto)' \
  '1:LDAP host or version:(version)' \
  '*::ignored:_default'
