#compdef pvereport
# _pvereport — Proxmox Server Solutions pvereport generate system diagnostic information report for Proxmox VE (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pve-manager.git

_pvereport() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--debug[debug]' \
        '*:section:'
}

_pvereport "$@"
