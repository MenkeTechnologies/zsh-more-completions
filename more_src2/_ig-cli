#compdef ig-cli ig
# _ig-cli — Inspektor Gadget ig-cli CLI command-line frontend to the Inspektor Gadget eBPF-based collection of tools for debugging tracing-Kubernetes-CRI-K8s-pods-containers tcp dns mount network exec open snapshot biolatency biolocstall execsnoop top-cpu top-file top-block top-tcp seccomp-profile (Inspektor Gadget team, Go); cobra
# upstream: https://www.inspektor-gadget.io/

_ig-cli() {
    local -a sub=(
        'audit:audit subcommands'
        'profile:profile subcommands'
        'snapshot:snapshot subcommands'
        'top:top subcommands'
        'trace:trace subcommands'
        'advise:advise subcommands'
        'run:run gadget by image'
        'attach:attach to a target'
        'detach:detach from a target'
        'deploy:deploy in-cluster'
        'undeploy:undeploy from cluster'
        'image:OCI image operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--node=+[node]:str:' \
        '--podname=+[name]:str:' \
        '--containername=+[name]:str:' \
        '--labels=+[k=v]:str:' \
        '--filter=+[expr]:str:' \
        '--timeout=+[sec]:n:' \
        '-o+[output]:f:(json yaml table custom-columns columns)' \
        '--output=+[format]:f:(json yaml table custom-columns columns)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ig-cli subcommand' sub ;;
        args)
            case $words[1] in
                trace) _arguments '1:gadget:(dns exec mount network open signal sni tcp udp tcpconnect tcpdrop bind capabilities oomkill)' ;;
                top) _arguments '1:gadget:(block-io file tcp ebpf)' ;;
                snapshot) _arguments '1:gadget:(process socket)' ;;
                profile) _arguments '1:gadget:(block-io cpu mountnsid)' ;;
                audit) _arguments '1:gadget:(seccomp)' ;;
            esac
            ;;
    esac
}

_ig-cli "$@"
