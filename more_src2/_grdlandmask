#compdef grdlandmask
# Documentation: https://docs.generic-mapping-tools.org/latest/grdlandmask.html
# Source: GenericMappingTools/gmt classic-mode grdlandmask — generate a land/water mask grid from GSHHG coastlines.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A+[feature area filter + hierarchy + Antarctica]:opts:_default' \
    '-D+[GSHHG resolution]:res:(full high intermediate low crude)' \
    '-E+[treat boundary as outside / trace border]:opts:_default' \
    '-N+[mask values (wet/dry or ocean/land/lake/island/pond)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-r[pixel registration (default gridline)]' \
    '-x+[CPU cores limit]:n:_default' \
    && ret=0

return ret
