#compdef pmie_quick
# _pmie_quick — Performance Co-Pilot pmie_quick (one-shot driver: spawns pmie with a rule file against the live pmcd, prints any firing actions to stdout instead of writing to log file; -h host, -a archive, -t interval, -c rules, -V verbose, -S/-T start/finish; positional rule file)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmie/pmie_quick on tip.

_pmie_quick() {
    _arguments \
        '-c+[rules file]:file:_files' \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-t+[interval]:interval:' \
        '-V[verbose]' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-Z+[timezone]:tz:' \
        '1:rule file:_files'
}

_pmie_quick "$@"
