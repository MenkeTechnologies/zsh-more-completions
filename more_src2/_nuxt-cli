#compdef nuxt-cli
# Documentation: https://www.npmjs.com/package/@nuxt/cli
# Reference accessed: 2026-05-23
# Verified: npx @nuxt/cli --help.

# Zsh completion for nuxt-cli - Nuxt CLI (nuxi)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add Nuxt modules'
  'add-template:create a new template file'
  'analyze:analyze production bundle'
  'build:build for production'
  'cleanup:clean generated files and caches'
  'dev:run development server'
  'devtools:enable or disable Nuxt devtools'
  'generate:build and prerender routes'
  'info:show Nuxt project information'
  'init:initialize a Nuxt project'
  'module:manage Nuxt modules'
  'prepare:prepare types and manifests'
  'preview:preview production build'
  'start:start production server'
  'test:run tests'
  'typecheck:run TypeScript checks'
  'upgrade:upgrade Nuxt dependencies'
)

_arguments -C   '--cwd=[working directory]:dir:_directories'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'nuxt-cli command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
