#compdef esl-alimerge
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-alimerge.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-alimerge: merge multiple alignments into one
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-o[output file]:file:_files' \
  '-v[verbose, print sizes and transferred annotations (requires -o)]' \
  '--list=[input is a file listing alignment files]:file:_files' \
  '--small[memory-saving mode (Pfam format only)]' \
  '--rfonly[only include nongap RF columns]' \
  '--outformat=[output alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip)' \
  '--rna[assume RNA]' \
  '--dna[assume DNA]' \
  '--amino[assume protein]' \
  '*:alignment files:_files' && ret=0
return ret
