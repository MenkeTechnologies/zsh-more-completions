# -----------------------------------------------------------------------------
#
# WHAT IS PYRET AND WHY IS IT THE 73RD LANGUAGE?
#
# Pyret (https://www.pyret.org, https://github.com/brownplt/pyret-
# lang, 1126+ stars) is **Brown University's PLT group's
# pedagogical programming language** — created by Shriram
# Krishnamurthi (Brown CS professor, ACM Fellow, recipient of the
# 2018 ACM Karl V. Karlstrom Outstanding Educator Award for
# computing education work) and co-developed by Joe Politz, Justin
# Pombrio, Daniel Patterson, and several PLT graduate students.
#
# Pyret was designed as the SUCCESSOR to How-to-Design-Programs
# (HtDP) — the seminal 2001 CS-education textbook by Matthias
# Felleisen, Robert Bruce Findler, Matthew Flatt, and Shriram
# Krishnamurthi.  HtDP uses Racket as its teaching language.
# After 10+ years of teaching with Racket, the Brown PLT team
# wanted a language designed FROM SCRATCH for pedagogy.  Pyret
# resulted in 2010-2014.
#
# Pyret's distinguishing characteristics:
#
#   1. CHECK BLOCKS AS FIRST-CLASS SYNTAX — Every Pyret function
#      can (and should) have an inline `check` block:
#
#          fun double(x :: Number) -> Number:
#            x * 2
#          where:
#            double(2) is 4
#            double(0) is 0
#            double(-3) is -6
#            double(2.5) is 5
#          end
#
#      The `where:` clause is a CHECK BLOCK that's executed
#      automatically when the file runs (unless `--no-check-mode`
#      is passed).  Compare:
#         * Racket:  REQUIRES test cases in separate `test`
#                     submodule
#         * Python:  pytest/unittest in separate files
#         * Pyret:    check blocks inline with function definition
#      FIRST documented language with first-class inline check
#      blocks as language syntax.
#
#   2. GRADUAL TYPING — Pyret programs can be written WITHOUT
#      any type annotations:
#
#          fun greet(name): "Hello, " + name end
#
#      OR with type annotations:
#
#          fun greet(name :: String) -> String: "Hello, " + name end
#
#      OR partially:
#
#          fun process(data, factor :: Number): data * factor end
#
#      The type checker only checks annotated parts; runtime
#      errors handle the rest.  This lets students START programming
#      without types, then add types as they learn the type system.
#      Compare:
#         * Python:    types are optional but tools (mypy) require
#                       opt-in
#         * TypeScript: types are central; can disable but most
#                       projects enforce
#         * Pyret:     types are SYNTACTICALLY OPTIONAL with
#                       runtime checking
#      FIRST documented language with gradual typing as a core
#      pedagogical-design feature.
#
#   3. TABLES PRIMITIVE — Pyret has SPREADSHEET-LIKE TABLES as a
#      first-class data type:
#
#          import tables as T
#
#          students = table: name :: String, grade :: Number
#            row: "Alice", 95
#            row: "Bob", 87
#            row: "Charlie", 92
#          end
#
#          passing = students
#            .filter(lam(r): r["grade"] >= 90 end)
#            .transform("grade", lam(g): g + 5 end)
#          # Tables are immutable; methods return new tables
#
#      Compare every other documented language — none have
#      first-class table primitives.  Compare:
#         * Pandas DataFrame: Python library, not language
#         * SQL:               relational query language but not
#                               general-purpose
#         * Pyret:             tables are NATIVE syntactic forms
#      FIRST documented language with native first-class table
#      primitives.
#
#   4. big-bang INTERACTIVE GRAPHICS — Pyret's `big-bang` function
#      (inherited from Racket's "How to Design Programs" universe
#      library) drives interactive graphical programs:
#
#          import image as I
#          import world as W
#
#          fun draw-state(s): I.circle(s, "solid", "red") end
#          fun next-state(s): s + 1 end
#
#          W.big-bang(10, [list:
#            W.on-tick(next-state, 1),
#            W.to-draw(draw-state, 200, 200),
#          ])
#
#      Compare:
#         * Racket's universe.rkt: same library; Pyret inherits
#                                   the design
#         * Pygame:                 Python, library-not-language
#         * processing.org:         Java/JavaScript, library
#         * Pyret:                  big-bang is a CANONICAL idiom
#                                    taught to ALL Pyret learners
#      FIRST documented general-purpose-pedagogy language with
#      big-bang interactive-graphics protocol built into curriculum
#      design.
#
#   5. BROWN PLT + BOOTSTRAP K-12 PROVENANCE — Pyret is used in
#      curricula at:
#         - Brown University CS17/CS18 (intro programming sequence)
#         - Bootstrap Algebra (5th-9th grade math via Pyret;
#                                deployed in 17 US states + 8
#                                countries)
#         - Bootstrap Reactive (high-school CS via interactive
#                                graphics)
#         - Bootstrap Data Science (high-school stats via tables)
#         - Bootstrap Physics (mechanics via animation)
#         - Hundreds of universities worldwide that teach with
#           "Programming and Programming Languages" textbook
#           (Krishnamurthi's OPEN-source CS textbook used in 100+
#            courses)
#      Compare:
#         * Logtalk R533:    academic + research provenance
#         * Modelica R529:  Linköping University academic
#         * Yorick R553:    LLNL national-lab
#         * Pyret:           K-12 + university pedagogy at scale
#      FIRST documented language with formal K-12 curriculum
#      adoption at scale.
#
# Pyret's relationship to other documented languages:
#
#   * Like Racket          — sister Brown PLT language
#                              (Racket inherits HtDP from Felleisen
#                              et al., Pyret is HtDP's successor)
#   * Like Python          — syntactic resemblance (indentation,
#                              colons), but Pyret is functional
#   * Like Haskell         — strong functional emphasis
#   * Like Scheme          — homoiconic lineage
#   * Like Logtalk R533    — pedagogical-design first
#   * Unlike all of the above — CHECK BLOCKS as syntactic
#                                primitives + gradual typing +
#                                first-class tables + big-bang
#                                interactive graphics + K-12
#                                curriculum adoption at scale.
#
# -----------------------------------------------------------------------------
#
# THE pyret CLI — command-line-args + command-line-usage Composition
#
# pyret's argv parser is 75lb/command-line-args (configurable
# argv-token-iteration parser) + command-line-usage (templated
# help-text rendering with inline markup):
#
#     const usage = require('command-line-usage');
#     const commandLineArgs = require('command-line-args');
#     // ... extensive usages object describing CLI sections ...
#
#     const optionDefinitions = [
#         { name: 'help', alias: 'h', type: Boolean, group: 'meta' },
#         { name: 'version', alias: 'v', type: Boolean, group: 'meta' },
#         { name: 'quiet', alias: 'q', type: Boolean, group: 'meta' },
#         { name: 'program', alias: 'p', defaultOption: true },
#         { name: 'outfile', alias: 'o' },
#         { name: 'perilous', type: Boolean },
#         { name: 'type-check', alias: 'y', type: Boolean },
#         { name: 'checks', alias: 'e' },
#         { name: 'no-check-mode', alias: 'k', type: Boolean },
#         { name: 'shutdown', alias: 's', type: Boolean },
#         { name: 'port', alias: 't', type: String },
#     ];
#     const opts = commandLineArgs(optionDefinitions, {camelCase: true});
#
# Distinguishing aspects of 75lb's command-line-args:
#   * Option groups: `group: 'meta'` lets you organize options into
#     categories displayed in different sections of help output
#   * Default options: `defaultOption: true` makes one positional
#     argument automatic without explicit `--name`
#   * Type coercion: `type: Boolean` / `type: String` / `type: Number`
#     auto-parses argument values
#   * Multiple values: `multiple: true` for repeatable flags
#
# Distinguishing aspects of command-line-usage:
#   * Tagged-template help text: `{bold key}` / `{underline value}` /
#     `{italic note}` / `{red error}` inline markup converted to
#     ANSI escape sequences at render time
#   * Multi-section help: header / description / examples /
#     option-list / synopsis / footer
#   * Option-list auto-rendering: pass optionDefinitions + adornments
#     (typeLabel, description) and get formatted help output
#
# Distinct from every other documented TS-Node CLI library on FIVE
# specific axes:
#
#   1. OPTION GROUPS FOR HELP-TEXT ORGANIZATION — Every other
#      documented TS-Node argv parser uses flat option lists.
#      command-line-args supports `group: 'name'` attribute that
#      organizes options into named groups; command-line-usage
#      renders separate sections for each group in help output.
#      FIRST documented TS-Node argv parser with option groups for
#      help-text organization.
#
#   2. TAGGED-TEMPLATE HELP-TEXT MARKUP — Every other documented
#      TS-Node argv parser uses plain-text or chalk-styled help.
#      command-line-usage uses inline curly-brace markup ({bold},
#      {underline}, {italic}, {red}, {green}) within help strings
#      that's auto-converted to ANSI at render time.  FIRST
#      documented TS-Node CLI library with tagged-template inline
#      markup for help text.
#
#   3. SEPARATE PARSING AND HELP-RENDERING LIBRARIES — Every other
#      documented TS-Node argv parser bundles parsing and help
#      generation.  75lb separates them into command-line-args
#      (parsing only) and command-line-usage (help rendering
#      only).  Apps choose to use one without the other.  FIRST
#      documented TS-Node argv-parsing approach with separated
#      parsing/help-rendering libraries.
#
#   4. defaultOption FOR POSITIONAL DEFAULT — Every other
#      documented TS-Node argv parser requires explicit positional
#      argument declarations.  command-line-args has
#      `defaultOption: true` on a single named option that
#      AUTOMATICALLY consumes positional arguments without
#      `--name`.  FIRST documented TS-Node argv parser with
#      default-positional-option semantics.
#
#   5. PEDAGOGICAL-LANGUAGE PROVENANCE — Every other documented
#      TS-Node CLI library is general-purpose.  pyret-npm
#      specifically exists to deliver a CS-education-pedagogy
#      compiler to npm registry, making 75lb's libraries available
#      to a pedagogical audience (CS instructors, K-12 Bootstrap
#      coordinators).  FIRST documented TS-Node CLI library
#      adopted as part of a K-12 + university pedagogical tooling
#      stack.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/brownplt/pyret-npm/blob/master/pyret.js
# command-line-args + command-line-usage configuration.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-h --help)'{-h,--help}'[show this help message and exit]' \
    '(-v --version)'{-v,--version}'[print version information]' \
    '(-q --quiet)'{-q,--quiet}'[do not show progress indicator output]' \
    '(-p --program)'{-p+,--program=}'[path to the .arr program to compile and run (default positional)]:file:_files -g "*.arr"' \
    '(-o --outfile)'{-o+,--outfile=}'[file to put the standalone compiled .jarr output into]:file:_files -g "*.jarr"' \
    '--perilous[compromise error semantics for speed (skip annotation checks)]' \
    '(-y --type-check)'{-y,--type-check}'[turn on the type-checker]' \
    '(-e --checks)'{-e+,--checks=}'[which checks to execute]:checks:(all none main "only\:pattern")' \
    '(-k --no-check-mode)'{-k,--no-check-mode}'[omit check blocks during compilation]' \
    '(-s --shutdown)'{-s,--shutdown}'[shut down the currently-running compile server]' \
    '(-t --port)'{-t+,--port=}'[socket file path for compile server (default /tmp/parley-<user>/comm.sock)]:socket:' \
    '*:Pyret source file:_files -g "*.arr"' \
    && ret=0

return ret
