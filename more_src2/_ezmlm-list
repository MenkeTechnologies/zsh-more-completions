#compdef ezmlm-list
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-list.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-n+[print only the subscriber count]:msgnum:' \
  '-m[use configured subscriber database (default)]' \
  '-M[use standard subscriber database]' \
  '-N[list subscriber addresses, one per line (default)]' \
  '-S+[connect to given subscriber database plugin]:subdb:' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' \
  '2:base:' && ret=0

return ret
