#compdef kwalletd6
# Documentation: https://invent.kde.org/frameworks/kwallet
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: KDE Plasma 6 wallet daemon; accepts only the KAboutData standard
# Qt/KDE options. No domain-specific CLI flags.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--author[show author information]' \
  '(- *)--license[show license information]' \
  '--platform=[Qt platform plugin]:platform:' \
  '--style=[Qt widget style]:style:' && ret=0
return ret
