#compdef ksnip
# _ksnip — cross-platform screenshot tool with annotation (ksnip/ksnip)
# upstream: https://github.com/ksnip/ksnip
# Flags from src/backend/commandLine/CommandLine.cpp (QCommandLineParser).

_ksnip() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(-r --rectarea)'{-r,--rectarea}'[select a rectangular area to capture]'
        '(-l --lastrectarea)'{-l,--lastrectarea}'[capture using the last rectangular area]'
        '(-f --fullscreen)'{-f,--fullscreen}'[capture full screen including all monitors]'
        '(-m --current)'{-m,--current}'[capture the screen the cursor is on]'
        '(-a --active)'{-a,--active}'[capture the currently focused window]'
        '(-u --windowundercursor)'{-u,--windowundercursor}'[capture the window under the cursor]'
        '(-t --portal)'{-t,--portal}'[capture via the xdg-desktop-portal screenshot interface]'
        '(-d --delay)'{-d+,--delay=}'[delay before taking the screenshot (seconds)]:seconds:'
        '(-c --cursor)'{-c,--cursor}'[capture the mouse cursor on the screenshot]'
        '(-e --edit)'{-e+,--edit=}'[edit an existing image in ksnip]:image:_files -g "*.{png,jpg,jpeg,bmp,gif,tiff,webp}"'
        '(-s --save)'{-s,--save}'[save to the default location without opening the editor]'
        '(-p --saveto)'{-p+,--saveto=}'[save to the given path without opening the editor]:file:_files'
        '(-o --upload)'{-o,--upload}'[upload via the default uploader without opening the editor]'
        '1:image to edit:_files -g "*.{png,jpg,jpeg,bmp,gif,tiff,webp}"'
    )
    _arguments $args
}

_ksnip "$@"
