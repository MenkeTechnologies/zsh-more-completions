#compdef mdl
# Documentation: https://github.com/markdownlint/markdownlint/blob/main/lib/mdl/cli.rb
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mdl (Ruby markdownlint)

_arguments -s -S \
  '(-a --show-aliases)'{-a,--show-aliases}'[show rule alias rather than rule ID]' \
  '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-i --ignore-front-matter)'{-i,--ignore-front-matter}'[ignore YAML front matter]' \
  '(-w --warnings)'{-w,--warnings}'[show kramdown warnings]' \
  '(-t --tags)'{-t,--tags}'[only process rules with given tags]:tags:' \
  '(-r --rules)'{-r,--rules}'[only process given rules]:rules:' \
  '(-s --style)'{-s,--style}'[load a given style]:style:_files' \
  '(-l --list-rules)'{-l,--list-rules}'[list enabled rules]' \
  '(-g --git-recurse)'{-g,--git-recurse}'[process only files tracked by git]' \
  '(-u --rulesets)'{-u,--rulesets}'[load additional ruleset files]:rulesets:_files' \
  '(-d --skip-default-ruleset)'{-d,--skip-default-ruleset}'[skip loading the default ruleset]' \
  '(-f --fix)'{-f,--fix}'[automatically fix resolvable issues]' \
  '(-j --json)'{-j,--json}'[output results in JSON format]' \
  '(-S --sarif)'{-S,--sarif}'[output results in SARIF format]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:markdown file:_files -g "*.md *.markdown *.mdown"' && return 0
