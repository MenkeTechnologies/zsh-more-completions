#compdef protoc-gen-connect-go
# ---------------------------------------------------------------------------
# protoc-gen-connect-go — Connect-Go protoc plugin (Go, 3,925★ org)
#
# upstream: https://github.com/connectrpc/connect-go
#           (cmd/protoc-gen-connect-go/main.go)
# project: Connect by Buf — drop-in gRPC + gRPC-Web + HTTP/JSON for Go
# license: Apache-2.0
#
# Source-direct completion: every flag below is verbatim from
# cmd/protoc-gen-connect-go/main.go on the connect-go tip.
#
# Usage:
#   protoc --connect-go_out=gen --connect-go_opt=package_suffix=connect path/to/file.proto
#   With buf:
#     plugins:
#       - local: protoc-gen-connect-go
#         out: gen
#         opt: package_suffix=connect,simple=true
#
# Direct deps from cmd/protoc-gen-connect-go/main.go imports:
#   connectrpc.com/connect                ← Connect protocol (this axis lane)
#   google.golang.org/protobuf            (protogen / protoreflect / pluginpb)
#   google.golang.org/grpc                (via connect's gRPC-compat layer)
#
# === AXIS 162 CONTINUES — gRPC service framework ecosystem ===
# Axis position: Go=217 continues Axis 162 (slot 2/0/0).  Canonical Go gRPC
# implementation is `google.golang.org/grpc` (the official gRPC-Go SDK).
# Connect-Go is a drop-in alternative that ALSO speaks gRPC (binary) +
# gRPC-Web (browser) + Connect's own HTTP/JSON protocol over a single
# server handler — and its protoc plugin generates code consumable by all
# three transports.  Used by Buf-developer-experience pipelines, gRPC web
# frontends without grpc-web translators, and hybrid REST+gRPC services.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=217   _volo                ← previous round (axis 162 OPENS at 1/0/0)
#   Go=217     ← THIS FILE          (axis 162 continues, slot 2/0/0)
#   TS-Node=217 ← next round        (axis 162 CLOSES at triple-217, slot 1/1/1)
# ---------------------------------------------------------------------------

_protoc-gen-connect-go() {
    _arguments -s -S \
        '(- *)--help[print plugin help text and exit]' \
        '(- *)-h[print plugin help text and exit]' \
        '(- *)--version[print connectrpc.com/connect version and exit]'

    # When invoked by protoc the plugin reads a CodeGeneratorRequest from
    # stdin and the per-invocation options come in via --connect-go_opt=KEY=VALUE
    # in the protoc invocation. The available KEYs (verbatim from main.go):
    #
    #   package_suffix=<name>   (default "connect")
    #     Generate files into a sub-package using the given suffix. An empty
    #     suffix denotes generating into the same package as the base pb.go.
    #   simple=true|false       (default false)
    #     Generate client and handler interfaces with simple function
    #     signatures, eliminating connect.Request/Response wrapper types.
}

_protoc-gen-connect-go "$@"
