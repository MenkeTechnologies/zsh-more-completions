#compdef kcachegrind
# _kcachegrind — KCachegrind callgrind profile visualizer (KDE/Qt); UI for callgrind/cachegrind output
# upstream: https://kcachegrind.github.io

_kcachegrind() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:' \
        '--display+[X display]:display:' \
        '*:callgrind file:_files -g "*.out*"'
}

_kcachegrind "$@"
