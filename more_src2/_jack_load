#compdef jack_load
# Documentation: https://jackaudio.org/
# Source: manpages.debian.org/jack_load.1 — load / unload an in-process JACK client (shared library).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --init)'{-i+,--init=}'[init string passed to the in-process client]:init str:' \
    '(-s --server)'{-s+,--server=}'[JACK server name]:server:' \
    '(-w --wait)'{-w,--wait}'[wait for signal then unload the client]' \
    '*:client name:' \
    && ret=0

return ret
