#compdef dh_movefiles
# _dh_movefiles — debhelper to move files from debian/tmp into packages (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_movefiles(1) man page.

_dh_movefiles() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '--sourcedir=[move files from this directory (relative)]:dir:' \
        '*-X+[exclude files matching pattern]:pattern:' \
        '*--exclude=[exclude files matching pattern]:pattern:' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '*-i[arch-indep packages only]' \
        '*-a[arch-dep packages only]' \
        '-O+[option passed to the helper]:opt:' \
        '*:file or directory under debian/tmp:_files'
}

_dh_movefiles "$@"
