_mosdns() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'start:start mosdns main program'
        'service:manage mosdns as a system service'
        'config:generate or convert mosdns config file'
        'probe:run DNS server transport tests'
        'help:show help for a subcommand'
        'completion:generate shell completion script'
    )

    local -a svc_subs
    svc_subs=(
        'install:install mosdns as a system service'
        'uninstall:uninstall the mosdns service'
        'start:start the installed service'
        'stop:stop the installed service'
        'restart:restart the installed service'
        'status:show service status'
    )

    local -a cfg_subs
    cfg_subs=(
        'conv:convert config file between yaml/json/toml/hcl extensions'
        'gen:generate a template config file'
    )

    local -a probe_subs
    probe_subs=(
        'idle-timeout:probe a server idle timeout'
        'conn-reuse:check RFC 1035 connection-reuse support'
        'pipeline:check RFC 7766 query-pipelining support'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'mosdns subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                start)
                    _arguments \
                        '(-c --config)'{-c+,--config=}'[config file]:config file:_files -g "*.(yaml|yml|json|toml|hcl)"' \
                        '(-d --dir)'{-d+,--dir=}'[working directory]:dir:_files -/' \
                        '--cpu=[set runtime.GOMAXPROCS]:n:' && ret=0
                    ;;
                service)
                    _describe -t commands 'service subcommand' svc_subs && ret=0
                    ;;
                config)
                    _arguments -C \
                        '(-): :->cfgsub' \
                        '*::cfgarg:->cfgarg' && ret=0
                    case $state in
                        cfgsub)
                            _describe -t commands 'config subcommand' cfg_subs && ret=0
                            ;;
                        cfgarg)
                            case $line[1] in
                                conv)
                                    _arguments \
                                        '(-i --in)'{-i+,--in=}'[input config file]:input:_files' \
                                        '(-o --out)'{-o+,--out=}'[output config file]:output:_files' && ret=0
                                    ;;
                                gen)
                                    _arguments '1:config file path:_files' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                probe)
                    _arguments -C \
                        '(-): :->probesub' \
                        '*::probearg:->probearg' && ret=0
                    case $state in
                        probesub)
                            _describe -t commands 'probe subcommand' probe_subs && ret=0
                            ;;
                        probearg)
                            _arguments '1:server address (tcp://addr\:port or tls://addr\:port):' && ret=0
                            ;;
                    esac
                    ;;
                completion)
                    _arguments '1:shell:(bash zsh fish powershell)' && ret=0
                    ;;
                help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_mosdns "$@"
