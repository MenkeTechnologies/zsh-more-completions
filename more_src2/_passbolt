#compdef passbolt
# Documentation: https://github.com/passbolt/go-passbolt-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create entities (resource/folder/user/group)'
  'update:update entities'
  'delete:delete entities'
  'list:list entities'
  'get:get a single entity'
  'share:share a resource or folder'
  'move:move an entity to another folder'
  'configure:configure CLI authentication and MFA'
  'verify:enable server verification'
  'exec:execute a command with secret env vars'
  'healthcheck:check server health'
  'completion:generate shell completion'
  'help:show help'
)

local -a entities=(
  'resource:password / credential'
  'folder:organizational container'
  'user:team member'
  'group:user group'
  'share:permission assignment'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--serverAddress=[passbolt server URL]:url:' \
  '--userPassword=[private key passphrase]:password:' \
  '--userPrivateKey=[user private key (PGP)]:key:' \
  '--userPrivateKeyFile=[user private key file]:file:_files' \
  '--config=[config file]:file:_files -g "*.{yaml,yml,json}"' \
  '--mfa-mode=[MFA mode]:mode:(noop interactive)' \
  '--mfa-totp-token=[TOTP token]:token:' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '*'{-c+,--column=}'[output column]:column:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'passbolt command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create|update|delete|list|get|move)
        _describe -t entities 'entity' entities && ret=0
        case $words[2] in
          (resource)
            _arguments \
              '--name=[resource name]:name:' \
              '--username=[username]:username:' \
              '--uri=[URI]:uri:' \
              '--password=[password]:pass:' \
              '--description=[description]:desc:' \
              '--folderParent=[parent folder id]:id:' \
              '--id=[resource id]:id:' && ret=0 ;;
          (folder)
            _arguments \
              '--name=[folder name]:name:' \
              '--folderParent=[parent folder id]:id:' \
              '--id=[folder id]:id:' && ret=0 ;;
          (user)
            _arguments \
              '--username=[username (email)]:email:' \
              '--firstName=[first name]:fname:' \
              '--lastName=[last name]:lname:' \
              '--role=[role]:role:(user admin)' \
              '--id=[user id]:id:' && ret=0 ;;
          (group)
            _arguments \
              '--name=[group name]:name:' \
              '--id=[group id]:id:' && ret=0 ;;
        esac ;;
      (share)
        _describe -t entities 'entity' entities && ret=0
        _arguments \
          '--id=[resource/folder id]:id:' \
          '--type=[permission type]:type:(1 7 15 -1)' \
          '--user=[user id to share with]:user:' \
          '--group=[group id to share with]:group:' && ret=0 ;;
      (configure)
        _arguments '*::sub:(server mfa key)' && ret=0 ;;
      (exec)
        _arguments \
          '--secret=[map env var to secret id]:env=id:' \
          '*::cmd:_command_names' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
