#compdef radsniff
# _radsniff — FreeRADIUS radsniff (libpcap-based RADIUS traffic decoder; -i interface, -r pcap input, -w pcap output, -F filter expr, -P pcap filter, -A include ACCT, -C output CSV, -s shared secret, -d dictionary dir, -D output dir, -O log live to socket, -p timeout, -q quiet, -x debug, -h help, -v version)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radsniff.c on tip.

_radsniff() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-i+[interface]:interface:_net_interfaces' \
        '-r+[pcap input]:file:_files -g "*.(pcap|pcapng)"' \
        '-w+[pcap output]:file:_files -g "*.(pcap|pcapng)"' \
        '-F+[filter expr]:filter:' \
        '-P+[BPF filter]:filter:' \
        '-A[include accounting]' \
        '-C[CSV output]' \
        '-s+[shared secret]:secret:' \
        '-d+[dictionary dir]:dir:_files -/' \
        '-D+[output dir]:dir:_files -/' \
        '-O+[live socket]:socket:' \
        '-p+[timeout]:seconds:' \
        '-q[quiet]' \
        '-x[debug]'
}

_radsniff "$@"
