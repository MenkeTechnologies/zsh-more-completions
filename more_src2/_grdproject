#compdef grdproject
# Documentation: https://docs.generic-mapping-tools.org/latest/grdproject.html
# Source: GenericMappingTools/gmt classic-mode grdproject — forward / inverse grid projection (geo ↔ rectangular).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-J+[projection]:proj:_default' \
    '-C+[coords relative to projection center (+offsets)]:opts:_default' \
    '-D+[output grid spacing]:spacing:_default' \
    '-E+[output DPI resolution]:dpi:_default' \
    '-F+[force 1:1 scaling + units]:units:(m f k M n u)' \
    '-I[inverse (rectangular → geo)]' \
    '-M+[projected measurement unit]:unit:(c i p)' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-j+[spherical distance mode]:mode:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '-r[pixel registration (default gridline)]' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
