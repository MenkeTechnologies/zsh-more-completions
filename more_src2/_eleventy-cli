#compdef eleventy-cli eleventy
# _eleventy-cli — Eleventy 11ty static site generator CLI alias (Zach Leatherman, JavaScript); minimist
# upstream: https://github.com/11ty/eleventy

_eleventy-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--input=+[input dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '--config=+[config file]:file:_files -g ".eleventy.js eleventy.config.cjs eleventy.config.mjs eleventy.config.js"' \
        '--data=+[data dir]:dir:_files -/' \
        '--formats=+[output formats]:list:(md html njk liquid hbs pug ejs jstl webc)' \
        '--quiet[quiet]' \
        '--dryrun[dry run]' \
        '--watch[watch]' \
        '--serve[serve]' \
        '--port=+[port]:port:' \
        '--incremental[incremental build]' \
        '--ignore-initial[ignore initial]' \
        '--to=+[output destination]:t:(fs json ndjson)' \
        '--pathprefix=+[path prefix]:str:' \
        '--loglevel=+[log level]:level:(debug info warn error)' \
        '*:arg:'
}

_eleventy-cli "$@"
