#compdef pmval
# _pmval — Performance Co-Pilot pmval (sample a single PCP metric over time; -h host, -a archive, -t interval, -s samples, -i instance list, -v verbose, -w wider value column, -d delta, -V verbose, -r raw counter values, -F filter, -O sample offset, -A align time, -S start, -T finish)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmval/pmval.c on tip.

_pmval() {
    _arguments \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-L[local context]' \
        '-t+[interval]:interval:' \
        '-s+[samples]:n:' \
        '-i+[instance list]:instances:' \
        '-v[verbose]' \
        '-V[very verbose]' \
        '-w+[width]:width:' \
        '-d+[delta]:delta:' \
        '-r[raw counters]' \
        '-F+[filter]:filter:' \
        '-O+[sample offset]:offset:' \
        '-A+[align time]:time:' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-z[archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-n+[namespace]:file:_files' \
        '-x+[extra args]:args:' \
        '*:metric:'
}

_pmval "$@"
