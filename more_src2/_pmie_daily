#compdef pmie_daily
# _pmie_daily — Performance Co-Pilot pmie_daily (daily cron driver complementing pmlogger_daily; rotates pmie log files, prunes old ones based on --rotate/--keep, optionally compresses via --compress-format, -c control, -V verbose, -K dry-run, -N show would-do only)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmie/pmie_daily on tip.

_pmie_daily() {
    _arguments \
        '-c+[control file]:file:_files' \
        '-V[verbose]' \
        '-K[dry run]' \
        '-N[show would-do only]' \
        '-x+[exec command]:command:' \
        '-X+[compress program]:compress:' \
        '-m+[mail address]:addr:' \
        '-Z+[timezone]:tz:' \
        '--compress-format+[format]:format:(xz gz bz2 zstd)' \
        '--rotate+[days]:n:' \
        '--keep+[count]:n:'
}

_pmie_daily "$@"
