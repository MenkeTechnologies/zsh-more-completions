#compdef dyninstAPI dyninst
# _dyninst — Dyninst dynamic-binary-instrumentation library helpers (UMich/UMD); CLI shims around DyninstAPI for runtime binary patching
# upstream: https://github.com/dyninst/dyninst

_dyninst() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-arch+[architecture]:arch:(x86_64 aarch64 ppc64le)' \
        '-bin+[binary]:file:_files' \
        '-pid+[attach PID]:pid:_pids' \
        '-output+[output binary]:file:_files' \
        '-instrument+[instrument script]:file:_files' \
        '-mode+[mode]:mode:(rewrite attach create)' \
        '-debug[debug]' \
        '-verbose[verbose]' \
        '*:cmd:'
}

_dyninst "$@"
