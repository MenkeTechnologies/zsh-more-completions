#compdef gst-dots-viewer
# Documentation: https://gstreamer.freedesktop.org/documentation/gst-devtools/index.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gst-dots-viewer: GStreamer pipeline visualization web server (1.26+).
# Reads .dot files from GST_DEBUG_DUMP_DOT_DIR (or $XDG_CACHE_HOME/gstreamer-dots).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*:dot file:_files -g "*.dot"' && ret=0

return ret
