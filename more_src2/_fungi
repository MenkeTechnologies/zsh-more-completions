#compdef fungi
# ============================================================================
# _fungi — zsh completion for enbop/fungi, "build a private P2P device
#           network for capability-first services" on top of rust-libp2p
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/enbop/fungi
#   Maintainer : enbop
#   License    : Apache-2.0
#   Stars      : 125
#   Language   : Rust
#   Crate      : fungi  (workspace member; binary fungi/Cargo.toml
#                         [package] name = "fungi",
#                         default-run = "fungi")
#   Binary     : fungi  (fungi/src/main.rs)
#   Last push  : 2026-05-30
#
# WHAT IT IS
#   Fungi is "a platform built for seamless multi-device
#   integration" — a private peer-to-peer device-mesh daemon and
#   control CLI for capability-first services.  It bundles a
#   long-running daemon that maintains libp2p connections to your
#   other Fungi nodes (peers, devices, relays), an embedded
#   wasmtime-based WASI runtime that exposes WebAssembly services
#   over the P2P fabric, and a one-binary control surface that
#   discovers / publishes / invokes those services by name.  The
#   driver dispatches `init`, `daemon`, `migrate` for lifecycle
#   management;  `info`, `device`, `connection`, `peer`, `service`,
#   `catalog`, `access`, `security`, `relay` for control plane
#   administration;  `ping` for live connection observability;  and
#   `run` / `serve` for the bundled wasmtime WebAssembly runner.
#   Any unrecognized first positional is forwarded to a Dynamic
#   service invocation against the configured device context.
#
# CLI ARGUMENT GRAMMAR  (verbatim from fungi/src/commands/mod.rs
#                       clap-derive `FungiArgs` / `CommonArgs` /
#                       `Commands` — clap 4 with derive feature)
#   fungi [COMMON OPTIONS] <SUBCOMMAND> [args...]
#
#   Common options (top-level CommonArgs flattened in every
#   invocation):
#     -f, --fungi-dir <DIR>         Fungi config directory
#                                   [default: channel-specific dir]
#     -d, --device <DEVICE>         Device context for dynamic
#                                   service shortcuts
#
#   Subcommands:
#     init                          Initialize a Fungi configuration
#                                   (generate keypair + jule.mod-
#                                   like fungi.toml)
#     migrate                       Migrate existing config dir to
#                                   current schema
#     daemon                        Start a Fungi daemon (or daemon-
#                                   managed background services)
#                                   With a nested `relay-server`
#                                   subcommand for relay mode.
#     relay <SUBCMD>                Manage relay configuration for
#                                   the local daemon
#     info <SUBCMD>                 Show daemon information
#     security | sec <SUBCMD>       Manage runtime safety boundary
#                                   settings
#     service | svc <ARGS>          Manage services
#     device <ARGS>                 Device discovery and saved
#                                   devices
#     connection | conn <SUBCMD>    Connection observability and
#                                   diagnostics
#     ping <PEER>                   Continuously ping all active
#                                   connections to a device
#       --interval-ms <N>             Ping interval in milliseconds
#                                     [default: 2000]
#       -v, --verbose                 Show detailed output
#                                     [default: false]
#     run                           [WASI runtime] Run a WebAssembly
#                                   module (re-exported wasmtime
#                                   command)
#     serve                         [WASI runtime] Serve wasi-http
#                                   requests (re-exported wasmtime
#                                   command)
#     <DYNAMIC>                     Any unrecognized first positional
#                                   is forwarded as a service
#                                   invocation through the dynamic
#                                   subcommand handler
#
#   Hidden control-plane subcommands (still functional but excluded
#   from `--help`):
#     catalog <SUBCMD>              Browse published remote services
#     access <SUBCMD>               Manage local access entries for
#                                   remote services
#     peer <SUBCMD>                 Query and administer remote peers
#
#   Standard clap auto-flags:
#     -h, --help                    Show help
#     -V, --version                 Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `libp2p = { version = "0.56", features = [
#   ...] }`, `libp2p-identity`, `libp2p-swarm`, and `multiaddr`
#   declared in fungi/Cargo.toml (via workspace dependencies).
#   `libp2p` is THE canonical Rust libp2p stack maintained by the
#   libp2p project (libp2p/rust-libp2p, 5529 stars).  rust-libp2p
#   exposes a modular peer-to-peer networking framework:  the
#   `Swarm<Behaviour>` abstraction, the `NetworkBehaviour` trait,
#   transports (TCP, QUIC, WebSocket, WebRTC, memory), upgrades
#   (TLS 1.3, noise), multiplexers (yamux, mplex), connection
#   limits, identification protocol, ping/kademlia/gossipsub/
#   floodsub/rendezvous protocols, and the multiaddr addressing
#   scheme.  Fungi's `fungi-swarm` crate constructs a
#   `Swarm<FungiBehaviour>` that composes Kademlia DHT, gossipsub
#   eventing, identify, ping, and a custom request-response
#   capability-routing protocol;  every peer-to-peer message
#   traverses the rust-libp2p Swarm event loop.  Verified via:
#     gh api repos/enbop/fungi/contents/Cargo.toml
#       → libp2p = { version = "0.56", features = [...] }
#       → libp2p-identity = { version = "0.2", features =
#           ["secp256k1", "serde", "rand"] }
#       → libp2p-swarm = "0.47"
#       → multiaddr (workspace dep)
#     gh api repos/enbop/fungi/contents/fungi/Cargo.toml
#       → name = "fungi"; default-run = "fungi"
#       → libp2p = { workspace = true }
#     gh api repos/enbop/fungi/contents/fungi/src/commands/mod.rs
#       → #[derive(Subcommand)] pub enum Commands { Init(...),
#         Migrate(...), Daemon(...), Relay(...), Info(...),
#         Security(...), Service(...), ... }
#   This entry is the Rust=140 leader bump (round-number Rust=140
#   landmark) that OPENS Axis 85 (P2P / libp2p Networking Stack)
#   at 1/0/0.  Pairing Go and TS-Node bumps will follow at R930
#   and R931 (Go=140 candidates `go-libp2p`-based CLIs;
#   TS-Node=140 candidates `js-libp2p`-based CLIs).
#
#   No completion for `fungi` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_fungi() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-f --fungi-dir)'{-f,--fungi-dir}'=[Fungi config directory]:dir:_files -/' \
        '(-d --device)'{-d,--device}'=[device context for dynamic service shortcuts]:device:' \
        '1: :_fungi_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                ping)
                    _arguments \
                        '--interval-ms=[ping interval in milliseconds]:ms:' \
                        '(-v --verbose)'{-v,--verbose}'[show detailed output]' \
                        ':peer device:' && ret=0 ;;
                daemon)
                    _arguments \
                        '1::daemon subcommand:(relay-server)' \
                        '*::arg:' && ret=0 ;;
                relay)
                    _arguments \
                        '1:relay subcommand:(list add remove enable disable)' \
                        '*::arg:' && ret=0 ;;
                info)
                    _arguments \
                        '1:info subcommand:(version status identity)' \
                        '*::arg:' && ret=0 ;;
                security|sec)
                    _arguments \
                        '1:security subcommand:(show set reset)' \
                        '*::arg:' && ret=0 ;;
                service|svc)
                    _arguments \
                        '1:service subcommand:(list publish unpublish status)' \
                        '*::arg:' && ret=0 ;;
                connection|conn)
                    _arguments \
                        '1:connection subcommand:(list show stats)' \
                        '*::arg:' && ret=0 ;;
                device)
                    _arguments \
                        '1:device subcommand:(list add remove rename pair)' \
                        '*::arg:' && ret=0 ;;
                catalog|access|peer)
                    _arguments \
                        '*: :' && ret=0 ;;
                init|migrate|run|serve)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_fungi_commands] )) ||
_fungi_commands() {
    local -a commands
    commands=(
        'init:initialize a Fungi configuration and generate a keypair'
        'migrate:migrate existing config dir to current schema'
        'daemon:start a Fungi daemon'
        'relay:manage relay configuration for the local daemon'
        'info:show daemon information'
        'security:manage runtime safety boundary settings (alias sec)'
        'service:manage services (alias svc)'
        'device:device discovery and saved devices'
        'connection:connection observability and diagnostics (alias conn)'
        'ping:continuously ping all active connections to a device'
        'run:[WASI runtime] run a WebAssembly module'
        'serve:[WASI runtime] serve wasi-http requests'
    )
    _describe -t commands 'fungi command' commands
}

_fungi "$@"
