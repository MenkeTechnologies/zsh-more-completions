#compdef pcp-iostat
# Documentation: https://man7.org/linux/man-pages/man1/pcp-iostat.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '-A+[alignment of sampling]:align:' \
  '--align=[alignment of sampling]:align:' \
  '-a+[archive source]:archive:_files' \
  '--archive=[archive source]:archive:_files' \
  '-h+[target host]:host:_hosts' \
  '--host=[target host]:host:_hosts' \
  '-O+[time origin]:time:' \
  '--origin=[time origin]:time:' \
  '-S+[start time]:time:' \
  '--start=[start time]:time:' \
  '-s+[number of samples]:samples:' \
  '--samples=[number of samples]:samples:' \
  '-T+[finish time]:time:' \
  '--finish=[finish time]:time:' \
  '-t+[sampling interval]:interval:' \
  '--interval=[sampling interval]:interval:' \
  '-Z+[timezone specification]:tz:' \
  '--timezone=[timezone specification]:tz:' \
  '-z[use host timezone]' \
  '--hostzone[use host timezone]' \
  '-G+[aggregate statistics]:method:(sum avg min max)' \
  '--aggregate=[aggregate statistics]:method:(sum avg min max)' \
  '-P+[decimal places for reporting]:precision:' \
  '--precision=[decimal places for reporting]:precision:' \
  '-R+[filter devices by regex pattern]:pattern:' \
  '--regex=[filter devices by regex pattern]:pattern:' \
  '-u[disable value interpolation for archive replay]' \
  '--no-interpolation[disable value interpolation for archive replay]' \
  '-x+[extended reporting (dm,t,h,noidle)]:options:' \
  '-V[display version and exit]' \
  '--version[display version and exit]' && ret=0

return ret
