#compdef dify
# Documentation: https://docs.dify.ai/en/develop-plugin/getting-started/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# langgenius/dify-plugin-daemon — Cobra CLI for Dify plugin development.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'plugin:plugin development commands'
  'bundle:bundle multiple plugins'
  'signature:plugin signature verification'
  'version:show version'
  'help:show help for a command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dify command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (plugin)
        local -a plugin_cmds=(
          'init:create new plugin (interactive)'
          'package:compress plugin to .difypkg'
          'checksum:generate plugin hash'
          'permission:modify manifest permissions'
          'module:plugin module operations'
          'cleanup:remove outdated plugin versions'
        )
        _describe -t commands 'plugin subcommand' plugin_cmds && ret=0
        ;;
      (bundle)
        _describe -t commands 'bundle subcommand' '(package:combine plugins into .difybndl)' && ret=0
        ;;
    esac
    ;;
esac

return ret
