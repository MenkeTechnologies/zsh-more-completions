#compdef logdissect
# Documentation: https://github.com/dogoncouch/logdissect
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--verbose[enable verbose output]' \
  '-s[silence terminal output]' \
  '--list-parsers[list available parsers]' \
  '-p[select a parser]:parser:(syslog syslogiso syslognohost tcpdump ldjson windowsrsyslog)' \
  '(-z --unzip)'{-z,--unzip}'[include gzip-compressed files]' \
  '-t[timezone offset (e.g. +0500)]:tzone:' \
  '--dhost=[match destination host]:host:' \
  '--shost=[match source host]:host:' \
  '--source=[match log source]:source:' \
  '--process=[match source process]:process:' \
  '--protocol=[match protocol]:protocol:' \
  '--grep=[filter lines matching pattern]:pattern:' \
  '--rgrep=[filter lines NOT matching pattern]:pattern:' \
  '--rdhost=[exclude destination host]:host:' \
  '--rshost=[exclude source host]:host:' \
  '--rsource=[exclude log source]:source:' \
  '--rprocess=[exclude source process]:process:' \
  '--rprotocol=[exclude protocol]:protocol:' \
  '--last=[filter last time period (e.g. 5m, 3h, 2d)]:period:' \
  '--range=[filter time range (YYYYMMDDhhmm-YYYYMMDDhhmm)]:range:' \
  '--utc[use UTC for range matching]' \
  '--outlog=[output to a standard log file]:file:_files' \
  '--label=[label type]:label:(fname fpath)' \
  '--sojson=[output single-object JSON]:file:_files' \
  '--linejson=[output line-delimited JSON]:file:_files' \
  '--pretty[apply pretty formatting to JSON]' \
  '*:log file:_files' && ret=0

return ret
