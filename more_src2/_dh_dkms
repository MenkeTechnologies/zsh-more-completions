#compdef dh_dkms
# Documentation: https://manpages.debian.org/dh_dkms
# Source: dkms debian/scripts/dh_dkms.in — install DKMS conf file and integration hooks (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--no-act[do not act]' \
    '(-l --legacy)'{-l,--legacy}'[legacy mode]' \
    '-V-[package version]::version:_default' \
    '*-O+[passthrough option]:opt:_default' \
    '*:dkms.conf file:_files -g "*.{conf,dkms}"' \
    && ret=0

return ret
