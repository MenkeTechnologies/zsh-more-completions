#compdef gltfjsx
# ============================================================================
#  _gltfjsx — gltfjsx: Convert glTF 3D model files into React Three Fiber
#             JSX components (Pmndrs / poimandres)
#
#  Source-direct extraction from
#    https://github.com/pmndrs/gltfjsx/blob/main/cli.js
#    https://github.com/sindresorhus/meow (the meow CLI helper library
#    by Sindre Sorhus)
#
#  Maintained by Paul Henschel and the Pmndrs (Poimandres) collective
#  (pmndrs/gltfjsx).  5798 GH stars.  gltfjsx is THE STANDARD TOOL for
#  converting glTF/GLB 3D model files into React Three Fiber JSX
#  components — used by the React-Three-Fiber community for embedding
#  3D models into React applications.  Reads a .glb/.gltf file,
#  analyzes its node hierarchy, materials, textures, and animations,
#  and emits a typed React component that wraps `@react-three/drei`'s
#  `useGLTF` hook.  Sister tools: gltf-pipeline (CesiumJS, in corpus),
#  gltf-transform (donmccurdy/gltf-transform CLI, IN CORPUS),
#  @react-three/drei (R3F helpers library), three.js (3D engine, IN
#  CORPUS via _threejs-related), Blender glTF exporter.
#
#  CLI library taxonomy update: 4th TypeScript-Node CLI library —
#  Sindre Sorhus's **meow** (sindresorhus/meow).  TypeScript-Node
#  ecosystem now has 4 documented CLI libraries (R340 oclif + R341
#  yargs + R343 tj/commander.js + R393 meow).
#
#  meow (sindresorhus/meow) is Sindre Sorhus's MINIMALIST Node.js
#  CLI helper — Sindre's tagline: "CLI app helper".  Designed for
#  small Node.js scripts that need argument parsing without the
#  framework-heavy overhead of oclif (R340) or the fluent-builder
#  ceremony of yargs (R341) and commander.js (R343).  Distinct from
#  other Node.js CLI libs by being USAGE-STRING-AS-DOCUMENTATION
#  combined with a TYPED FLAG SCHEMA object — caller writes the
#  Markdown-like help text VERBATIM and supplies a flags object for
#  parsing semantics.  Used by FKill (Sindre's process killer, IN
#  CORPUS via _fkill), Taskbook (Klaus Sinani tasks/notes CLI 9317
#  stars, IN CORPUS via _taskbook), gltfjsx (Pmndrs 3D model
#  converter, 5798 stars), Hocuspocus (Ueberdosis Yjs CRDT WebSocket
#  backend, 2345 stars), spotify-dl (1642 stars), manage-wifi-cli
#  (Sindre's macOS Wi-Fi toggler, 111 stars), and HUNDREDS of
#  Sindre Sorhus's own tools + community Node.js CLI tools that
#  follow the "meow-style" minimalist pattern.
#
#  meow API:
#    #!/usr/bin/env node
#    import meow from 'meow';
#
#    const cli = meow(`
#        Usage
#          $ mytool [options] <input>
#
#        Options
#          --output, -o   Output file path
#          --verbose, -v  Verbose output
#          --count, -n    Iteration count (default: 1)
#          --format, -f   Output format (default: json)
#
#        Examples
#          $ mytool --output=out.txt input.txt
#          $ mytool -o out.txt -v input.txt
#    `, {
#      importMeta: import.meta,
#      flags: {
#        output: { type: 'string', shortFlag: 'o' },
#        verbose: { type: 'boolean', shortFlag: 'v' },
#        count: { type: 'number', shortFlag: 'n', default: 1 },
#        format: { type: 'string', shortFlag: 'f', default: 'json',
#                  choices: ['json', 'yaml', 'xml'] },
#        tags: { type: 'string', isMultiple: true },
#        config: { type: 'string', isRequired: true },
#      },
#      booleanDefault: undefined,  // distinguish false from unset
#    });
#
#    if (cli.input.length === 0) {
#      console.log(cli.help);
#      process.exit(1);
#    }
#
#    // Access:
#    //   cli.input  — array of positional args
#    //   cli.flags  — parsed flag values (typed)
#    //   cli.help   — auto-generated help string from usage
#    //   cli.pkg    — package.json contents
#    //   cli.unnormalizedFlags — flags before kebab-to-camelCase
#
#  meow distinctive features:
#    - USAGE STRING AS HELP TEXT — caller writes the COMPLETE help
#      text in markdown-ish format as the FIRST argument; meow does
#      NOT auto-generate help from the flags schema
#    - FLAGS SCHEMA — second argument is an object with `flags`,
#      `importMeta`, `booleanDefault`, `allowUnknownFlags`, etc.
#    - `flags: { NAME: { type, shortFlag, default, isRequired,
#      isMultiple, choices, aliases } }` — per-flag schema with:
#      * `type: 'string'` / `'number'` / `'boolean'` — TYPE COERCION
#      * `shortFlag: 'x'` — single-char short alias
#      * `default: VALUE` — fallback when flag not provided
#      * `isRequired: true` — required flag (errors on parse if missing)
#      * `isMultiple: true` — repeatable flag (returns array)
#      * `choices: ['a', 'b']` — ENUM/CHOICES validation
#      * `aliases: ['alt1', 'alt2']` — additional long-name aliases
#    - `importMeta: import.meta` — REQUIRED in modern ESM meow for
#      package.json resolution (replaces older `pkg`/`autoVersion`
#      args from CommonJS meow v9-)
#    - `booleanDefault: undefined` — when set, boolean flags default
#      to `undefined` rather than `false`, allowing caller to
#      distinguish "explicitly false" from "not set"
#    - `allowUnknownFlags: true` — permit flags not in schema (default:
#      throws on unknown flags)
#    - `helpIndent: NUMBER` — auto-indent help text by N spaces
#    - `inferType: true` — infer type from default value (no `type` needed)
#    - `description: 'short desc'` — pkg.description in help (auto-pulled)
#    - `version: 'X.Y.Z'` — override pkg.version
#    - `autoHelp: false` — disable auto `--help`/`-h` (rarely useful)
#    - `autoVersion: false` — disable auto `--version`/`-v`
#    - `argv: ['custom', 'argv']` — override process.argv (for testing)
#    - RESULT OBJECT:
#      * `cli.input: string[]` — POSITIONAL args
#      * `cli.flags: object` — parsed flag values, CAMEL-CASED
#        (kebab-case in source → camelCase in result, e.g.
#         `--my-flag` → `cli.flags.myFlag`)
#      * `cli.unnormalizedFlags: object` — flags BEFORE camelCase
#      * `cli.help: string` — auto-generated help text including the
#        usage string + flags schema summary
#      * `cli.pkg: object` — package.json contents (for version/desc)
#      * `cli.showHelp(N)` — print help to stderr and exit with code N
#      * `cli.showVersion()` — print version and exit
#    - AUTO-INJECTED `--help`/`-h` and `--version`/`-v` flags
#    - KEBAB-TO-CAMEL CONVERSION — `--my-flag` → `cli.flags.myFlag`
#      automatically (camelCase result keys)
#    - PROCESS EXIT model via `cli.showHelp(N)` or `cli.showVersion()`
#      or caller's own `process.exit(N)`
#  Distinct from R340 TypeScript-Node oclif (Salesforce's CLI
#  framework with plugin system + `@Command` class + `flags = {}`
#  static prop), R341 TypeScript-Node yargs (Node.js fluent builder
#  via `.option('name', {})` / `.command('cmd', desc, builder, handler)`
#  chains), R343 TypeScript-Node tj/commander.js (Node.js fluent
#  builder by TJ Holowaychuk via `.option('-o, --output <file>',
#  'Output')` / `.command('cmd <arg>')`), R389 Deno @std/cli
#  (Deno's stdlib parse-args — closest concept analog with schema-
#  driven boolean/string/default/alias keys but Deno ecosystem).
#  meow's approach: USAGE STRING AS HELP TEXT (caller writes complete
#  markdown-ish help) + FLAGS SCHEMA object (second argument with
#  `flags: { NAME: { type, shortFlag, default, isRequired, isMultiple,
#  choices, aliases } }`) + KEBAB-TO-CAMEL automatic conversion +
#  `importMeta: import.meta` REQUIRED for ESM package.json resolution
#  + `cli.input` POSITIONAL args + `cli.flags` CAMEL-CASED result +
#  `cli.help`/`cli.pkg`/`cli.showHelp()`/`cli.showVersion()` accessors
#  + AUTO-INJECTED `--help`/`--version` + PROCESS EXIT controlled by
#  caller — corpus's **first documented usage-string-as-help-with-
#  typed-flags-schema Node.js CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 132; TypeScript-Node
#  ecosystem now has 4 documented CLI libraries.
#
#  Surface (verbatim from `cli.js` meow flags schema):
#
#  Options:
#    -o, --output FILE              Output file name/path (string)
#    -t, --types                    Add TypeScript definitions (boolean)
#    -k, --keepnames                Keep original names (boolean)
#    -K, --keepgroups               Keep (empty) groups, disable pruning
#                                   (boolean)
#    -b, --bones                    Lay out bones declaratively
#                                   (boolean, default false)
#    -m, --meta                     Include metadata (as userData)
#                                   (boolean)
#    -s, --shadows                  Let meshes cast/receive shadows
#                                   (boolean)
#    -p, --printwidth N             Prettier printWidth (number, default 120)
#    -p, --precision N              Number of fractional digits
#                                   (number, default 3; NOTE: shortFlag
#                                   collision with --printwidth in source)
#    -d, --draco PATH               Draco binary path (string)
#    -r, --root DIR                 Directory from which .gltf is served
#                                   (string)
#    -i, --instance                 Instance re-occurring geometry (boolean)
#    -I, --instanceall              Instance every geometry (boolean)
#    -E, --exportdefault            Use default export (boolean)
#    -T, --transform                Transform the asset for the web
#                                   (draco, prune, resize) (boolean)
#    -R, --resolution N             Texture resize resolution
#                                   (number, default 1024)
#    -j, --keepmeshes               Do not join compatible meshes
#                                   (boolean, default false)
#    -M, --keepmaterials            Do not palette-join materials
#                                   (boolean, default false)
#    -f, --format FORMAT            Texture format (string, default "webp")
#    -S, --simplify                 Mesh simplification (boolean, default false)
#        --ratio N                  Simplifier ratio (number, default 0.75)
#        --error N                  Simplifier error threshold
#                                   (number, default 0.001)
#    -q, --degrade PATTERN          Degrade-pattern for textures (string)
#    -Q, --degraderesolution N      Degraded texture resolution
#                                   (number, default 512)
#    -c, --console                  Log JSX to console, no file output
#                                   (boolean)
#    -D, --debug                    Debug output (boolean)
#
#  Auto-injected by meow:
#    -h, --help                     Show help (auto-added)
#    -v, --version                  Show version (auto-added)
#
#  Positional:
#    MODEL.glb                      glTF/GLB 3D model file to convert
#                                   (single required positional)
#
#  Output:
#    By default, gltfjsx emits a JSX file with the same name as the
#    input (capitalized first letter), or .tsx if --types is set.
#    Use --output/-o to specify a custom output path.
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also meow users):
#    - fkill (IN CORPUS via _fkill — Sindre Sorhus's fabulous process
#      killer 6989 stars; uses meow but already documented under
#      different attribution)
#    - taskbook (IN CORPUS via _taskbook — Klaus Sinani tasks/notes
#      9317 stars; uses meow)
#    - hocuspocus (Ueberdosis 2345 stars — Yjs CRDT WebSocket backend,
#      FUTURE candidate for collaboration scope)
#    - spotify-dl (SwapnilSoni1999 1642 stars — Spotify downloader,
#      FUTURE candidate)
#    - manage-wifi-cli (Sindre Sorhus 111 stars — macOS Wi-Fi toggle,
#      smaller community)
#    - bemuse / mtd / kalastatic / envsubst / spotify-dl / hundreds
#      of community Node.js CLI tools (smaller user bases each)
# ============================================================================

_gltfjsx() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-o --output)'{-o,--output}'=[output file name/path]:file:_files' \
    '(-t --types)'{-t,--types}'[add TypeScript definitions]' \
    '(-k --keepnames)'{-k,--keepnames}'[keep original names]' \
    '(-K --keepgroups)'{-K,--keepgroups}'[keep empty groups (disable pruning)]' \
    '(-b --bones)'{-b,--bones}'[lay out bones declaratively]' \
    '(-m --meta)'{-m,--meta}'[include metadata (as userData)]' \
    '(-s --shadows)'{-s,--shadows}'[let meshes cast/receive shadows]' \
    '--printwidth=[Prettier printWidth (default 120)]:width' \
    '(-p --precision)'{-p,--precision}'=[fractional digits (default 3)]:n' \
    '(-d --draco)'{-d,--draco}'=[Draco binary path]:path:_files' \
    '(-r --root)'{-r,--root}'=[directory from which .gltf is served]:dir:_directories' \
    '(-i --instance)'{-i,--instance}'[instance re-occurring geometry]' \
    '(-I --instanceall)'{-I,--instanceall}'[instance every geometry]' \
    '(-E --exportdefault)'{-E,--exportdefault}'[use default export]' \
    '(-T --transform)'{-T,--transform}'[transform asset for web (draco, prune, resize)]' \
    '(-R --resolution)'{-R,--resolution}'=[texture resize resolution (default 1024)]:px' \
    '(-j --keepmeshes)'{-j,--keepmeshes}'[do not join compatible meshes]' \
    '(-M --keepmaterials)'{-M,--keepmaterials}'[do not palette-join materials]' \
    '(-f --format)'{-f,--format}'=[texture format (default webp)]:format:(webp jpg png ktx2)' \
    '(-S --simplify)'{-S,--simplify}'[mesh simplification]' \
    '--ratio=[simplifier ratio (default 0.75)]:ratio' \
    '--error=[simplifier error threshold (default 0.001)]:threshold' \
    '(-q --degrade)'{-q,--degrade}'=[degrade pattern for textures]:pattern' \
    '(-Q --degraderesolution)'{-Q,--degraderesolution}'=[degraded texture resolution (default 512)]:px' \
    '(-c --console)'{-c,--console}'[log JSX to console (no file output)]' \
    '(-D --debug)'{-D,--debug}'[debug output]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:glTF/GLB model file:_files -g "*.(glb|gltf)"'
}

_gltfjsx "$@"
