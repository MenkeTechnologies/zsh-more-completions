#compdef impacket-getNPUsers
# Documentation: https://github.com/fortra/impacket/blob/master/examples/GetNPUsers.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-getNPUsers: AS-REP roasting (users with DONT_REQ_PREAUTH).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-request[request actual AS-REP for users]' \
  '-outputfile[output filename for hashes]:file:_files' \
  '-format[hash output format]:fmt:(hashcat john)' \
  '-usersfile[file with usernames, one per line]:file:_files' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-dc-host[domain controller hostname]:host:_hosts' \
  '*::positional:_files' && ret=0
return ret
