#compdef fbgrab
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/fbgrab.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu jammy fbgrab(1) manpage OPTIONS section.

# fbgrab: framebuffer screenshot tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-\?[display help]' \
  '-c[grab /dev/ttyN]:n:' \
  '-C[switch to /dev/ttyN then grab after delay]:n:' \
  '-d[framebuffer device]:device:_files -g "/dev/fb*"' \
  '-i[enable PNG interlacing]' \
  '-s[sleep N seconds before grabbing]:n:' \
  '*:output PNG:_files -g "*.png"' && ret=0
return ret
