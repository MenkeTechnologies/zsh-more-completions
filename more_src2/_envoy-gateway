#compdef envoy-gateway
# _envoy-gateway — Envoy Gateway control plane (k8s-native Envoy Proxy gateway implementing Gateway API)
# upstream: https://github.com/envoyproxy/gateway
# Subcommands from cmd/envoy-gateway/root/root.go on tip; flags from internal/cmd/{server,certgen,envoy,versions}.go.

_envoy-gateway() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'server:run the Envoy Gateway control plane'
                'envoy:run Envoy data-plane lifecycle helpers (shutdown / shutdown-manager)'
                'certgen:generate/rotate control-plane TLS certs'
                'version:show versions'
            )
            _describe -t commands 'envoy-gateway command' subs
            ;;
        args)
            case $line[1] in
                server)
                    _arguments \
                        '(-c --config-path)'{-c+,--config-path=}'[control-plane config path]:file:_files'
                    ;;
                certgen)
                    _arguments \
                        '(-l --local)'{-l,--local}'[run in local mode (no k8s client)]' \
                        '--config-home=[config home directory]:dir:_files -/' \
                        '(-o --overwrite)'{-o,--overwrite}'[overwrite existing control-plane certs]' \
                        '--disable-topology-injector[disable topology injector cert generation]'
                    ;;
                envoy)
                    _arguments -C \
                        '1: :->envoyCmd' \
                        '*::arg:->envoyArgs'
                    case $state in
                        envoyCmd)
                            local -a subs=(
                                'shutdown:trigger graceful shutdown of Envoy proxy'
                                'shutdown-manager:run shutdown manager sidecar'
                            )
                            _describe -t commands 'envoy command' subs
                            ;;
                        envoyArgs)
                            case $line[1] in
                                shutdown)
                                    _arguments \
                                        '--drain-timeout=[total drain duration]:dur:' \
                                        '--min-drain-duration=[minimum drain duration]:dur:' \
                                        '--exit-at-connections=[exit when active connections fall to this count]:n:'
                                    ;;
                                shutdown-manager)
                                    _arguments \
                                        '--ready-timeout=[max wait for shutdown ready state]:dur:'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                version)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output format]:fmt:(yaml json)'
                    ;;
            esac
            ;;
    esac
}

_envoy-gateway "$@"
