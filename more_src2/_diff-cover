#compdef diff-cover diff-quality
# Documentation: https://github.com/Bachmann1234/diff_cover (diff_cover/diff_cover_tool.py argparse)
# Reference accessed: 2026-05-29
# diff-cover/diff-quality — compute coverage/quality of changed lines vs branch.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*--format=[output format (format\:path pairs allowed)]:format:_files' \
  '--show-uncovered[show uncovered lines on the console]' \
  '--expand-coverage-report[append missing lines based on previous-line hits]' \
  '--external-css-file=[write CSS into an external file]:file:_files -g "*.css"' \
  '--compare-branch=[branch to compare against]:branch:' \
  '--fail-under=[error exit if coverage/quality below this value]:percent:' \
  '(--ignore-staged)--ignore-unstaged[ignore unstaged changes]' \
  '(--ignore-unstaged)--ignore-staged[ignore staged changes]' \
  '--include-untracked[include untracked files]' \
  '*--exclude=[exclude files (glob pattern)]:glob:' \
  '*--include=[include files (glob pattern)]:glob:' \
  '*--src-roots=[source directory (jacoco coverage reports only)]:dir:_directories' \
  '--diff-range-notation=[git notation for branch comparison (default ...)]:notation:(.. ...)' \
  '--ignore-whitespace[ignore whitespace in diff]' \
  '(-q --quiet)'{-q,--quiet}'[only print errors and failures]' \
  '(-c --config-file)'{-c,--config-file=}'[configuration file]:file:_files -g "*.(toml|cfg|ini|yaml|yml)"' \
  '--diff-file=[diff file to use instead of computing one]:file:_files' \
  '--total-percent-float[show total coverage/quality as float rounded to 2 decimals]' \
  '*:coverage report:_files -g "*.(xml|info)"' && ret=0

return ret
