#compdef polkadot-launch
# _polkadot-launch — Paritytech polkadot-launch local Polkadot relay-chain plus parachain test orchestrator predecessor to Zombienet (paritytech team, TypeScript); commander
# upstream: https://github.com/paritytech/polkadot-launch

_polkadot-launch() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--test[run in test mode]' \
        '-t[run in test mode]' \
        '--monitor[enable monitor]' \
        '-m[enable monitor]' \
        '--monitor-interval=+[ms]:n:' \
        '--logger=+[type]:l:(console file pino)' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--log-file=+[log file]:file:_files' \
        '--no-color[disable color]' \
        '*:config:_files -g "*.json *.toml *.yaml *.yml"'
}

_polkadot-launch "$@"
