#compdef pytube
# _pytube — YouTube downloader (pytube/pytube)
# upstream: https://github.com/pytube/pytube
# Flags from pytube/cli.py (argparse).

_pytube() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '--itag=[itag for the desired stream]:itag:'
        '(-r --resolution)'{-r+,--resolution=}'[stream resolution to download]:res:(144p 240p 360p 480p 720p 1080p 1440p 2160p)'
        '(-l --list)'{-l,--list}'[list available streams for the URL]'
        '(-v --verbose)'{-v,--verbose}'[increase logging verbosity]'
        '--logfile=[log debug/error messages to this file]:file:_files'
        '--build-playback-report[save HTML + JS to disk for debugging]'
        '(-c --caption-code)'{-c+,--caption-code=}'[caption language code (en, es, ...)]:code:'
        '(-lc --list-captions)'{-lc,--list-captions}'[list available caption tracks]'
        '(-t --target)'{-t+,--target=}'[download target directory]:dir:_files -/'
        '(-a --audio)'{-a-,--audio=-}'[download audio-only stream (optional codec)]::codec:(mp4 webm)'
        '(-f --ffmpeg)'{-f-,--ffmpeg=-}'[mux best video+audio via ffmpeg (optional res)]::res:(best 144p 240p 360p 480p 720p 1080p)'
        '1:YouTube /watch or /playlist URL:'
    )
    _arguments -s $args
}

_pytube "$@"
