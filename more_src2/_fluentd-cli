#compdef fluentd-cli fluentdctl
# _fluentd-cli — Fluentd unified logging layer CLI alias (Fluentd Project, Ruby); custom argparse
# upstream: https://github.com/fluent/fluentd

_fluentd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '--plugin=+[plugin search path]:dir:_files -/' \
        '-p+[plugin search path]:dir:_files -/' \
        '--inline-config=+[inline config]:str:' \
        '-i+[inline config]:str:' \
        '--no-supervisor[no supervisor]' \
        '--workers=+[number of workers]:n:' \
        '-w+[number of workers]:n:' \
        '--root-dir=+[root dir]:dir:_files -/' \
        '--log=+[log file]:file:_files' \
        '-o+[log file]:file:_files' \
        '--log-rotate-age=+[log rotate age]:n:' \
        '--log-rotate-size=+[log rotate size]:size:' \
        '--log-event-verbose[log event verbose]' \
        '--daemon=+[pid file]:file:_files' \
        '-d+[pid file]:file:_files' \
        '--under-supervisor[under supervisor]' \
        '--no-supervisor-pidfile=+[no supervisor pid file]:file:_files' \
        '--user=+[run as user]:str:_users' \
        '--group=+[run as group]:str:_groups' \
        '--umask=+[umask]:str:' \
        '--gemfile=+[gemfile]:file:_files' \
        '--gem-install-options=+[gem install opts]:str:' \
        '--show-plugin-config=+[show plugin config]:str:' \
        '--dry-run[dry run]' \
        '--use-v1-config[use v1 config]' \
        '--use-v0-config[use v0 config]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--ignore-repeated-log-interval=+[interval]:n:' \
        '--strict-config-value[strict config value]' \
        '--enable-input-metrics[enable input metrics]' \
        '--enable-size-metrics[enable size metrics]' \
        '*:arg:'
}

_fluentd-cli "$@"
