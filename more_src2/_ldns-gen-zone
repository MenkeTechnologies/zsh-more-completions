#compdef ldns-gen-zone
# _ldns-gen-zone — NLnet Labs ldns-gen-zone (read a zonefile and pad it with artificial NS RRsets and DS records — useful for benchmarking signing/serving)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-gen-zone.c usage on tip.

_ldns-gen-zone() {
    _arguments \
        '-h[show help]' \
        '-v[show version and exit]' \
        '-a+[add N artificial delegations (NS RRsets)]:n:' \
        '-p+[percent of NS RRsets to add DS RRsets to]:n:' \
        '-o+[set $ORIGIN]:origin:' \
        '-s[input zone is already sorted/canonical (faster DS insertion)]' \
        '1:zonefile:_files'
}

_ldns-gen-zone "$@"
