#compdef ldeep
# Documentation: https://github.com/franc-pentest/ldeep/blob/master/README.rst
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a modes ldap_cmds cache_cmds

modes=(
  'ldap:live LDAP queries'
  'cache:work with cached JSON dumps'
)

ldap_cmds=(
  'auth_policies:auth policies'
  'bitlockerkeys:BitLocker keys'
  'computers:computers'
  'conf:configuration partition'
  'delegations:delegations'
  'dns_records:DNS records'
  'domain_policy:domain policy'
  'fsp:foreign security principals'
  'fsmo:FSMO roles'
  'gmsa:gMSA accounts'
  'gpo:Group Policy Objects'
  'groups:groups'
  'machines:machines'
  'ou:organizational units'
  'pkis:PKI'
  'pso:PSO'
  'sccm:SCCM'
  'schema:LDAP schema'
  'server_info:server info'
  'shadow_principals:shadow principals'
  'silos:authentication silos'
  'smsa:sMSA'
  'subnets:subnets'
  'templates:templates'
  'trusts:trusts'
  'users:users'
  'zones:DNS zones'
  'from_guid:lookup by GUID'
  'from_sid:lookup by SID'
  'laps:LAPS passwords'
  'memberships:memberships of account'
  'membersof:members of group'
  'object:object'
  'sddl:SDDL'
  'silo:silo info'
  'zone:zone info'
  'all:dump all'
  'enum_users:enumerate users'
  'search:LDAP search'
  'whoami:whoami'
  'add_to_group:add user to group'
  'change_uac:change UAC'
  'create_computer:create computer account'
  'create_user:create user'
  'modify_password:reset password'
  'remove_from_group:remove user from group'
  'unlock:unlock account'
)

cache_cmds=(${ldap_cmds:#(templates|all|enum_users|search|whoami|add_to_group|change_uac|create_computer|create_user|modify_password|remove_from_group|unlock):*})

_arguments -C \
  '--version[show version]' \
  '(-o --outfile)'{-o,--outfile}'=[output file]:file:_files' \
  '--security_desc[retrieve security descriptors]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->mode' \
  '*::arg:->args' && ret=0

case $state in
  (mode) _describe -t modes 'ldeep mode' modes && ret=0 ;;
  (args)
    case $line[1] in
      (ldap)
        _arguments -C \
          '(-d --domain)'{-d,--domain}'=[domain]:domain:' \
          '(-s --ldapserver)'{-s,--ldapserver}'=[LDAP URL]:url:' \
          '(-b --base)'{-b,--base}'=[base DN]:dn:' \
          '(-t --type)'{-t,--type}'=[auth type]:type:(ntlm simple)' \
          '--throttle=[seconds]:n:' \
          '--page_size=[page size]:n:' \
          '(-n --no-encryption)'{-n,--no-encryption}'[no encryption]' \
          '(-u --username)'{-u,--username}'=[username]:user:' \
          '(-p --password)'{-p,--password}'=[password]:pw:' \
          '(-H --ntlm)'{-H,--ntlm}'=[LM:NT hash]:hash:' \
          '(-k --kerberos)'{-k,--kerberos}'[use Kerberos]' \
          '--pfx-file=[PFX file]:file:_files' \
          '--pfx-pass=[PFX password]:pw:' \
          '--cert-pem=[cert PEM]:file:_files' \
          '--key-pem=[key PEM]:file:_files' \
          '(-a --anonymous)'{-a,--anonymous}'[anonymous bind]' \
          '*: :->cmd' && ret=0
        [[ $state == cmd ]] && _describe -t cmds 'ldap command' ldap_cmds && ret=0 ;;
      (cache)
        _arguments -C \
          '(-d --dir)'{-d,--dir}'=[cache dir]:dir:_files -/' \
          '(-p --prefix)'{-p,--prefix}'=[cache prefix]:prefix:' \
          '*: :->cmd' && ret=0
        [[ $state == cmd ]] && _describe -t cmds 'cache command' cache_cmds && ret=0 ;;
    esac
    ;;
esac

return ret
