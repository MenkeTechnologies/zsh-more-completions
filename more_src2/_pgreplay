#compdef pgreplay
# _pgreplay — replay PostgreSQL log files against a database (laurenz/pgreplay)
# upstream: https://github.com/laurenz/pgreplay
# Flags from pgreplay(1) man page.

_pgreplay() {
    _arguments \
        '(- *)-V[show version]' \
        '-c[log file is csvlog format (recommended)]' \
        '-b+[start timestamp YYYY-MM-DD HH\:MM\:SS.FFF]:timestamp:' \
        '-e+[end timestamp YYYY-MM-DD HH\:MM\:SS.FFF]:timestamp:' \
        '-q[backslash escapes single quote in literals]' \
        '*-D+[only log entries for this database]:database:' \
        '*-U+[only log entries for this username]:user:' \
        '-h+[target database host or UNIX socket dir]:host:_hosts' \
        '-p+[target TCP port]:port:' \
        '-W+[password for all users]:password:' \
        '-s+[replay speed factor (default 1)]:factor:' \
        '-E+[log file encoding]:encoding:' \
        '-j[jump ahead when all connections idle]' \
        '-n[dry-run (no server connection)]' \
        '-X+[extra libpq connection options]:opts:' \
        '-o+[output file (with -f)]:file:_files' \
        '-r[print statistics report]' \
        '-f[output parsed log to file (replay-file format)]' \
        '*:input file:_files'
}

_pgreplay "$@"
