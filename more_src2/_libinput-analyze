#compdef libinput-analyze
# _libinput-analyze — analyze recorded libinput events (libinput/libinput)
# upstream: https://gitlab.freedesktop.org/libinput/libinput
# Subcommands derived from tools/libinput-analyze-*.py.

_libinput-analyze() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:feature:(buttons per-slot-delta recording touch-down-state)' \
        '*:event-file:_files -g "*.(yaml|yml)"'
}

_libinput-analyze "$@"
