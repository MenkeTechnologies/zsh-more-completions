#compdef lsappinfo
# Documentation: lsappinfo --help (macOS 26 LaunchServices)
# Source: query and manipulate LaunchServices application info.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'list:show app list and per-app info'
    'processlist:show ASNs in app array'
    'visibleProcessList:show ASNs of visible apps (front-to-back)'
    'front:show ASN of front app'
    'info:show app info for specifier'
    'setinfo:set key/value pairs in app info'
    'metainfo:show session meta info'
    'setmetainfo:set session meta info key/value pairs'
    'find:find processes matching key/value pairs'
    'setfront:set the front app'
    'launch:launch an app using launch-info pairs'
    'kill:kill app(s)'
    'register:register an app with LaunchServices'
    'signal:signal that the specified app is ready'
    'quit:signal that the specified app is exiting'
    'send:send a notification'
    'listen:add/modify notification listener'
    'unlisten:remove notification listener'
    'wait:wait in runloop for events'
)

_arguments -C -s \
    '(- *)--version[show version]' \
    '(-v --verbose -q --quiet)'{-v,--verbose}'[verbose output]' \
    '(-v --verbose -q --quiet)'{-q,--quiet}'[quiet output]' \
    '(-defaultSession -currentSession)-defaultSession[use kLSDefaultSessionID]' \
    '(-defaultSession -currentSession)-currentSession[use kLSCurrentSessionID]' \
    '-debug[log level LOG_DEBUG]' \
    '-info[log level LOG_INFO]' \
    '-notice[log level LOG_NOTICE]' \
    '-warning[log level LOG_WARNING]' \
    '-err[log level LOG_ERR]' \
    '-critical[log level LOG_CRIT]' \
    '-alert[log level LOG_ALERT]' \
    '-emergency[log level LOG_EMERG]' \
    '-debugserver[talk to LSDEBUGSERVER instead of real LAS]' \
    '-useserver+[talk to LAS server with given name]:server name:' \
    '-all[show full info instead of summary]' \
    '(-nonames)-names[show app names in asn lists]' \
    '(-names)-nonames[hide app names in asn lists]' \
    '(-noxml)-xml[output as XML]' \
    '(-xml)-noxml[output as text]' \
    '-debuglogname+[name for LAS debug output log]:name:' \
    '1:command:->verbs' \
    '*::args:_normal' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
