_emoj() {
    _arguments -s -S \
        '(-c --copy)'{-c,--copy}'[copy the first emoji to the clipboard]' \
        '(-s --skin-tone)'{-s,--skin-tone=}'[set and persist the default emoji skin tone (0 to 5)]:tone:(0 1 2 3 4 5)' \
        '(-l --limit)'{-l,--limit=}'[maximum number of emojis to display (default 7)]:count:' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '*:search text:'
}

_emoj "$@"
