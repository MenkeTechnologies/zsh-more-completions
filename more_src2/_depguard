#compdef depguard
# _depguard — Go linter for package import guards (OpenPeeDeeP/depguard)
# upstream: https://github.com/OpenPeeDeeP/depguard

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'=[configuration file]:file:_files' \
  '*:Go packages or directories:_files -/'
