#compdef impala-shell
# _impala-shell — Apache Impala impala-shell (interactive Impala SQL shell; -i Impala host:port, -q single query string, -f script file, --quiet, --print_header, -B no-format batch mode, -o output file, --output_delimiter, -d/--database default DB, -k kerberos, --ssl, --ca_cert, --variable key=value, --refresh_after_connect, --history_file, --query_option key=value)
# upstream: https://github.com/apache/impala (shell)
# Flags from Apache Impala shell/option_parser.py on tip.

_impala-shell() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[impalad host:port]:host:port:_hosts' \
        '--impalad+[impalad host:port]:host:port:_hosts' \
        '-q+[query string]:query:' \
        '--query+[query string]:query:' \
        '-f+[script file]:file:_files -g "*.sql"' \
        '--query_file+[script file]:file:_files -g "*.sql"' \
        '--quiet[quiet]' \
        '--print_header[print header]' \
        '-B[batch mode]' \
        '--delimited[batch mode]' \
        '-o+[output file]:file:_files' \
        '--output_file+[output file]:file:_files' \
        '--output_delimiter+[delimiter]:delim:' \
        '-d+[default db]:db:' \
        '--database+[default db]:db:' \
        '-k[kerberos auth]' \
        '--kerberos[kerberos auth]' \
        '-s+[kerberos service]:service:' \
        '--kerberos_service_name+[kerberos service]:service:' \
        '--ssl[enable TLS]' \
        '--ca_cert+[CA cert]:file:_files' \
        '*--variable+[key=value]:var:' \
        '--refresh_after_connect[refresh metadata]' \
        '--history_file+[history file]:file:_files' \
        '*--query_option+[key=value]:opt:' \
        '-u+[user]:user:_users' \
        '--user+[user]:user:_users' \
        '-l[ldap auth]' \
        '--ldap[ldap auth]' \
        '--config_file+[config file]:file:_files'
}

_impala-shell "$@"
