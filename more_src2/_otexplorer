#compdef otexplorer
# ============================================================================
#  _otexplorer — otexplorer: OpenType font table explorer (Google Fonts'
#                fontations Rust toolkit)
#
#  Source-direct extraction from
#    https://github.com/googlefonts/fontations/blob/main/otexplorer/src/main.rs
#    https://github.com/matklad/xflags (the xflags library by Aleksey
#    Kladov / matklad)
#
#  Maintained by Google Fonts contributors (googlefonts/fontations).
#  771 GH stars.  fontations is Google Fonts' OpenType font parsing,
#  manipulation, and rendering library suite written in Rust — used
#  in Google's internal font infrastructure (Google Fonts library
#  serving billions of font requests per day), Skia text shaping
#  (via skrifa), Android/Chrome font systems, and the FontC font
#  compiler.  The `otexplorer` binary is a `ttx`-like (FontTools)
#  font table inspector — reads a TrueType/OpenType font file and
#  prints a textual representation of any table or subtable.  Sister
#  tools: fonttools / ttx (Python font tools, IN CORPUS via _ttx),
#  otfinfo (Adobe Font Development Kit, IN CORPUS via _otfinfo),
#  font-validator (Microsoft), fc-list (FontConfig, IN CORPUS),
#  pyftsubset (FontTools subsetter, IN CORPUS).
#
#  CLI library taxonomy update: 10th Rust CLI library — Aleksey
#  "matklad" Kladov's **xflags** (matklad/xflags).  Rust ecosystem
#  now has 10 documented CLI libraries — TAKING THE SOLO LEAD as the
#  MOST-DOCUMENTED CLI LANGUAGE in the cross-language taxonomy
#  ahead of Go (9) and TypeScript-Node (9).
#
#  xflags (matklad/xflags) is Aleksey "matklad" Kladov's MINIMAL
#  declarative-macro Rust CLI library — used by rust-analyzer (THE
#  official Rust language server, used by all major Rust IDEs:
#  VS Code, IntelliJ-Rust, Neovim rust-tools, Helix, Zed; created
#  and maintained by matklad himself), fontations (Google Fonts'
#  Rust font toolkit, 771 stars), Google Fonts font-codegen,
#  paradigmxyz/solar Solana Rust toolchain, p4lang/p4analyzer
#  (Intel P4 language analyzer), pascalkuthe/OpenVAF (Verilog-A
#  compiler), Alacritty/vim helpers, and many Rust internal tools
#  that need declarative argv parsing without clap's heavy
#  dependency footprint (~30MB compile time savings vs clap).
#
#  xflags API:
#    xflags::xflags! {
#      /// Top-level command description.
#      /// Multi-line doc comments become --help text.
#      cmd mytool {
#        /// Required positional argument
#        required input: PathBuf
#
#        /// Optional value-taking flag with short+long
#        optional -o, --output output: PathBuf
#
#        /// Repeatable flag (collects into Vec)
#        repeated -I, --include include: String
#
#        /// Boolean flag (no value)
#        optional -v, --verbose
#
#        /// Typed argument (any FromStr type)
#        optional -p, --port port: u16
#
#        /// Subcommands via nested cmd blocks
#        cmd build {
#          /// Build target
#          required target: String
#          optional -j, --jobs jobs: u32
#        }
#
#        cmd test {
#          repeated patterns: String
#        }
#
#        /// Default subcommand when no command name matches
#        default cmd help {
#          optional name: String
#        }
#      }
#    }
#
#    fn main() {
#      let args = Mytool::from_env_or_exit();
#      // args.input: PathBuf (always present, since required)
#      // args.output: Option<PathBuf>
#      // args.include: Vec<String>
#      // args.verbose: bool
#      // args.port: Option<u16>
#      // args.subcommand: MytoolCmd { Build(BuildArgs), Test(TestArgs),
#      //                              Help(HelpArgs) }
#    }
#
#  xflags distinctive features:
#    - DECLARATIVE MACRO `xflags::xflags! { ... }` — Rust proc-macro
#      that takes a DECLARATIVE COMMAND SPEC and generates a Rust
#      struct + parser at COMPILE TIME (NO runtime overhead, zero
#      string-format-string interpretation at runtime)
#    - SIMPLEST AMONG RUST CLI LIBS — no traits, no derive
#      attributes, no complicated generics; just `cmd NAME { ... }`
#      blocks with `required` / `optional` / `repeated` / `default
#      cmd` / nested `cmd` keywords
#    - `cmd NAME { ... }` — top-level command (binary name)
#    - `required NAME: TYPE` — REQUIRED positional or value-taking
#      flag (errors if missing)
#    - `optional [-SHORT,] [--LONG] NAME: TYPE` — OPTIONAL with
#      optional short/long flags
#    - `optional [-SHORT,] [--LONG]` (no NAME) — BOOLEAN flag (no
#      value)
#    - `repeated [-SHORT,] [--LONG] NAME: TYPE` — REPEATABLE
#      (returns `Vec<TYPE>`)
#    - `default cmd NAME { ... }` — DEFAULT subcommand when no
#      command name matches (one default per command)
#    - NESTED `cmd NAME { ... }` — nested subcommands; generates
#      `enum CmdName { Sub1(Sub1Args), Sub2(Sub2Args), ... }` for
#      caller dispatch
#    - DOC COMMENTS BECOME --help TEXT — `///` comments above
#      cmd/required/optional/repeated lines become the help output
#    - TYPED VIA Rust's `FromStr` — any type implementing
#      `FromStr` works (u32, PathBuf, String, custom enums)
#    - `Args::from_env_or_exit()` — main entry; prints help/error and
#      calls `std::process::exit(N)` on parse failure
#    - `Args::from_env()` — RESULT variant; returns `Result<Args,
#      xflags::Error>` for caller to handle
#    - `Args::from_args(args)` — explicit args slice (for testing)
#    - GENERATED STRUCT — each option becomes a typed field:
#      * `required NAME: T` → `name: T` (always present)
#      * `optional NAME: T` → `name: Option<T>` (None if not present)
#      * `optional -f` (no NAME) → `f: bool` (presence flag)
#      * `repeated NAME: T` → `name: Vec<T>`
#      * `cmd SUB { ... }` → `subcommand: CmdEnum`
#    - AUTO-GENERATED --help/-h on every subcommand and the top
#      level
#    - AUTO-GENERATED ERROR MESSAGES with positional context
#    - SOMETIMES-INCLUDED `--version`/`-V` (when caller manually
#      adds version handling)
#    - NO env-var fallback support (caller adds manually)
#    - NO validator/coercer support beyond FromStr
#    - NO `--no-FLAG` negation (caller hand-rolls)
#    - TINY CRATE — xflags is ~600 LOC pure Rust + the proc-macro;
#      compile time is dramatically faster than clap (~30MB build
#      cache savings on a typical Rust project)
#  Distinct from R275 Rust clap-derive (Salesforce-acquired Salesforce
#  framework... wait that's wrong, clap is by Kevin K., clap_derive
#  is `#[derive(Parser)]` proc-macro — closest concept analog with
#  similar derive-on-struct philosophy but clap has 10x more
#  features and ~30MB compile-time cost), R330 Rust bpaf (functional
#  applicative combinator style), R344 Rust google/argh (derive-on-
#  struct similar to clap_derive but Google-flavored and smaller),
#  R347 Rust RazrFalcon/pico-args (LOW-LEVEL iterator-based parser),
#  Rust stdlib (no stdlib CLI parser; std::env::args() is raw iter),
#  Rust gumdrop (proc-macro derive — also derive-on-struct).
#  xflags' approach: DECLARATIVE MACRO BLOCK SYNTAX with
#  `cmd NAME { required/optional/repeated/default cmd/cmd NAME }`
#  keywords + DOC COMMENTS BECOME --help TEXT + COMPILE-TIME STRUCT
#  GENERATION via proc-macro + TYPED VIA Rust `FromStr` + GENERATED
#  STRUCT with typed fields per option + AUTO-GENERATED --help on
#  every subcommand + AUTO-GENERATED ERROR MESSAGES + TINY CRATE
#  (~600 LOC, ~30MB compile-time savings vs clap) — corpus's **first
#  documented declarative-macro-block-syntax Rust CLI library**.
#  Brings cross-language CLI library taxonomy variant count to 143;
#  Rust ecosystem now has 10 documented CLI libraries — TAKING THE
#  SOLO LEAD as the MOST-DOCUMENTED CLI LANGUAGE in the cross-
#  language taxonomy ahead of Go (9) and TypeScript-Node (9).
#
#  Surface (verbatim from `otexplorer/src/main.rs` `xflags::xflags!`
#  block):
#
#  Options:
#    -i, --index INDEX              Font index within TrueType
#                                   Collection (TTC) file (optional u32)
#    -l, --list                     List all tables in font and exit
#                                   (optional boolean)
#    -q, --query QUERY              Print specific subtable/value via
#                                   query path (e.g.
#                                   GPOS.lookup_list.lookup_offsets.1)
#                                   (optional Query type)
#    -t, --tables INCLUDE           Comma-separated list of tables to
#                                   INCLUDE (only print these)
#    -x, --exclude EXCLUDE          Comma-separated list of tables to
#                                   EXCLUDE (print everything except)
#
#  Auto-injected by xflags:
#    -h, --help                     Show help with auto-formatted
#                                   sections from doc comments
#
#  Positional:
#    INPUT                          Path to TrueType/OpenType font file
#                                   (.ttf, .otf, .ttc, .otc) — REQUIRED
#
#  Examples:
#    otexplorer font.ttf                # Print all tables
#    otexplorer -l font.ttf             # List tables only
#    otexplorer -t GPOS,GSUB font.ttf   # Only GPOS and GSUB tables
#    otexplorer -x glyf font.ttf        # Skip glyf table
#    otexplorer -q GPOS.lookup_list.lookup_offsets.1.subtable_offsets.0 font.ttf
#                                       # Print specific subtable
#    otexplorer -i 2 collection.ttc     # Inspect font index 2 in TTC
#
#  Query syntax (verbatim from --help):
#    Queries begin with a table tag, then zero or more path elements
#    separated by `.`.  Path elements are field names or array
#    indexes.  Queries are CASE-INSENSITIVE and FUZZILY MATCHED.
#    Example: -q GPOS.look.off.1.off.0 fuzzy-matches to
#             -q GPOS.lookupListOffset.lookupOffsets.1.subtableOffsets.0
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also xflags users):
#    - rust-analyzer (IN CORPUS via _rust-analyzer — THE official
#      Rust language server, created and maintained by matklad
#      himself; uses xflags as its CLI library; flagship xflags use
#      case; already documented under different attribution)
#    - font-codegen (sister tool to otexplorer in fontations workspace
#      — internal Google Fonts codegen, not user-facing)
#    - solar (paradigmxyz/solar — Solana Rust toolchain xtask CLI)
#    - p4-analyzer (p4lang/p4analyzer — Intel P4 language analyzer)
#    - OpenVAF (pascalkuthe/OpenVAF — Verilog-A compiler, niche)
#    - vi/http_file_uploader (vi/http_file_uploader — small upload tool)
#    - many rust-template xtask scripts (xtask pattern in Rust
#      workspaces uses xflags heavily for internal CLI tasks)
# ============================================================================

_otexplorer() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-i --index)'{-i,--index}'=[font index in TTC collection]:index' \
    '(-l --list)'{-l,--list}'[list all tables and exit]' \
    '(-q --query)'{-q,--query}'=[query path (e.g. GPOS.lookup_list.0)]:query' \
    '(-t --tables)'{-t,--tables}'=[comma-separated tables to include]:tables' \
    '(-x --exclude)'{-x,--exclude}'=[comma-separated tables to exclude]:tables' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:font file:_files -g "*.(ttf|otf|ttc|otc|woff|woff2)"'
}

_otexplorer "$@"
