#compdef ldns-nsec3-hash
# _ldns-nsec3-hash — NLnet Labs ldns-nsec3-hash (compute the NSEC3 hash for a domain name given algorithm, iteration count, and salt)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-nsec3-hash.c usage on tip.

_ldns-nsec3-hash() {
    _arguments \
        '-a+[NSEC3 hashing algorithm]:alg:(1)' \
        '-t+[number of hash iterations]:n:' \
        '-s+[salt (hex string)]:hex:' \
        '1:domain:'
}

_ldns-nsec3-hash "$@"
