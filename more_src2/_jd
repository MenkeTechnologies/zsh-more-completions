#compdef jd
# Documentation: https://github.com/josephburnett/jd/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: josephburnett/jd upstream README options. Fixed -t
# translate value (jd2patch/yaml2json forms, not jd/patch/merge)
# and added -setkeys/-o/-precision/-port/-opts.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-set[treat arrays as sets]' \
  '-mset[treat arrays as multisets/bags]' \
  '-setkeys=[keys to identify set objects]:keys:' \
  '-color[print color diff]' \
  '-yaml[read and write YAML instead of JSON]' \
  '-p[apply the diff as a patch]' \
  '-f=[diff format]:format:(jd patch merge)' \
  '-t=[translate between formats e.g. jd2patch or yaml2json]:translation:' \
  '-o=[write output to file instead of stdout]:file:_files' \
  '-precision=[maximum absolute difference for numbers to be equal]:n:' \
  '-port=[serve the web UI on the given port]:port:' \
  '-opts=[JSON array of comparison options]:json:' \
  '1:first file:_files' \
  '2:second file:_files' && ret=0
return ret
