local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# 5 subcommands decoded source-direct from
# SUBCOMMANDS block at Main.lean:218-223
local -a docgen4_subcmds=(
  'single:populate database with documentation for a single module'
  'genCore:populate database with documentation for a Lean core module'
  'bibPrepass:run the bibliography prepass (copy bibliography file to output)'
  'headerData:produce header-data.bmp for embedding declarations'
  'fromDb:generate HTML documentation from the SQLite database'
)

_arguments -C \
  '(- *)'{-h,--help}'[display Cli auto-generated help]' \
  '(- *)'{-v,--version}'[display version information]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'doc-gen4 subcommand' docgen4_subcmds && ret=0
    ;;
  args)
    case $words[1] in
      single)
        # 1 flag + 3 positional args from singleCmd
        # spec at Main.lean:154-160
        _arguments -s -S \
          '(-b --build)'{-b+,--build=}'[build directory (default: .lake/build)]:build dir:_files -/' \
          '(-h --help)'{-h,--help}'[display single help]' \
          '1:module name (dotted notation):' \
          '2:SQLite database path:_files' \
          '3:source URI (computed by Lake facet):' && ret=0
        ;;
      genCore)
        # 1 flag + 2 positional args
        _arguments -s -S \
          '(-b --build)'{-b+,--build=}'[build directory]:build dir:_files -/' \
          '(-h --help)'{-h,--help}'[display genCore help]' \
          '1:core module prefix (Init, Lean, Std, Lake):(Init Lean Std Lake)' \
          '2:SQLite database path:_files' && ret=0
        ;;
      bibPrepass)
        # 3 flags + variadic positional
        _arguments -s -S \
          '(-n --none)'{-n,--none}'[disable bibliography in this project]' \
          '(-j --json)'{-j,--json}'[input file is .json (citekey/tag/html/plaintext)]' \
          '(-b --build)'{-b+,--build=}'[build directory]:build dir:_files -/' \
          '(-h --help)'{-h,--help}'[display bibPrepass help]' \
          '*:bibliography file (.bib or .json):_files -g "*.(bib|json)"' && ret=0
        ;;
      headerData)
        # 1 flag only
        _arguments -s -S \
          '(-b --build)'{-b+,--build=}'[build directory]:build dir:_files -/' \
          '(-h --help)'{-h,--help}'[display headerData help]' && ret=0
        ;;
      fromDb)
        # 2 flags + 1 required + variadic positional
        _arguments -s -S \
          '(-b --build)'{-b+,--build=}'[build directory (default: .lake/build)]:build dir:_files -/' \
          '(-m --manifest)'{-m+,--manifest=}'[manifest output file listing generated HTML]:manifest file:_files' \
          '(-h --help)'{-h,--help}'[display fromDb help]' \
          '1:SQLite database path:_files' \
          '*:module roots (optional; computes transitive closure):' && ret=0
        ;;
    esac
    ;;
esac

return ret
