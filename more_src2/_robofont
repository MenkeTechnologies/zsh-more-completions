#compdef robofont robofont-cli
# _robofont — Frederik Berlaen RoboFont commercial macOS font editor CLI for executing UFO macros .roboFontExt extensions Python scripts and Robofont batch operations across UFO sources (FontBureau team, Python); argparse
# upstream: https://robofont.com/

_robofont() {
    local -a sub=(
        'open:open UFO in RoboFont'
        'install:install extension'
        'uninstall:uninstall extension'
        'list-extensions:list installed extensions'
        'run-script:run Python script'
        'batch:run batch operation'
        'check:run UFO checks'
        'generate:generate font binary'
        'compare:compare UFOs'
        'export-features:export features'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'robofont subcommand' sub ;;
        args)
            case $words[1] in
                generate) _arguments \
                    '--format=+[f]:f:(otf ttf otfcff variableTTF variableCFF2 mm)' \
                    '--output=+[dir]:dir:_files -/' \
                    '--decompose[decompose]' \
                    '--remove-overlap[remove overlap]' \
                    '--auto-hint[auto hint]' \
                    '--release-mode[release mode]' \
                    '*:UFO files:_files -g "*.ufo *.ufoz"' ;;
                install|uninstall) _arguments '*:extension:_files -g "*.roboFontExt"' ;;
                run-script|batch) _arguments \
                    '--vanilla[use vanilla mode]' \
                    '--no-gui[no GUI]' \
                    '*:script:_files -g "*.py"' ;;
                open) _arguments '*:UFO file:_files -g "*.ufo *.ufoz *.designspace"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_robofont "$@"
