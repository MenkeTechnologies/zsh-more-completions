#compdef esl-translate
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-translate.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-translate: 6-frame translate DNA, extract ORFs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-c[NCBI transl_table genetic code id]:code' \
  '-l[minimum ORF length in amino acids]:n' \
  '-m[require ATG (Met) initiator]' \
  '-M[require any initiator allowed by transl_table]' \
  '-W[windowed reading for large sequences (file input only)]' \
  '--informat=[input sequence format]:fmt:(fasta embl genbank uniprot)' \
  '--watson[forward (Watson) strand only]' \
  '--crick[reverse (Crick) strand only]' \
  '*:DNA sequence file:_files' && ret=0
return ret
