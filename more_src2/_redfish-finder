#compdef redfish-finder
# Documentation: https://github.com/nhorman/redfish-finder/blob/master/redfish-finder
# Reference accessed: 2026-05-16
# Verified: upstream redfish-finder argparse - only -s and argparse-provided -h.

# redfish-finder: discover BMC Redfish endpoint and configure host interface
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --shutdown)'{-s,--shutdown}'[tear down BMC interface and scrub config]' && ret=0
return ret
