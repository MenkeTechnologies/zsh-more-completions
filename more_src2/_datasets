#compdef datasets dataformat
# _datasets — NCBI datasets and dataformat CLI for accessing NCBI Datasets API genome assemblies gene annotations records (ncbi team, Go); cobra
# upstream: https://github.com/ncbi/datasets

_datasets() {
    local -a sub=(
        'download:download datasets'
        'summary:summarize datasets'
        'rehydrate:rehydrate stub datasets'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--api-key=+[NCBI API key]:str:' \
        '--debug[debug logging]' \
        '--no-progressbar[no progress bar]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datasets subcommand' sub ;;
        args)
            case $words[1] in
                download) _arguments \
                    '1:type:(genome gene virus taxonomy organelle)' ;;
                summary) _arguments \
                    '1:type:(genome gene virus taxonomy organelle ortholog assembly cyanide)' ;;
                rehydrate) _arguments \
                    '--directory=+[directory]:dir:_files -/' \
                    '--match=+[regex]:str:' \
                    '--list[list files]' \
                    '--max-workers=+[N]:n:' \
                    '--gzip[gzip rehydrated files]' \
                    '--dry-run[dry run]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_datasets "$@"
