#compdef prometheus-operator
# _prometheus-operator — Prometheus Operator main controller (prometheus-operator/prometheus-operator)
# upstream: https://github.com/prometheus-operator/prometheus-operator
# Flags from cmd/operator/main.go parseFlags() on tip.

_prometheus-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-as=[impersonate user]:user:' \
        '-apiserver=[apiserver URL (omit to use service-account in-cluster)]:url:_urls' \
        '-cert-file=[TLS client cert file]:file:_files' \
        '-key-file=[TLS client key file]:file:_files' \
        '-ca-file=[TLS CA file]:file:_files' \
        '-tls-insecure[skip apiserver TLS verification]' \
        '-kubelet-service=[Service/Endpoints object for kubelets (namespace/name)]:ref:' \
        '-kubelet-selector=[label selector to filter nodes]:sel:' \
        '-kubelet-node-address-priority=[node address priority]:pri:(internal external)' \
        '-kubelet-endpointslice[create EndpointSlice for kubelet targets]' \
        '-kubelet-endpoints=[create Endpoints for kubelet targets]:bool:(true false)' \
        '-kubelet-sync-period=[kubelet Endpoints reconcile interval]:dur:' \
        '-kubelet-http-metrics=[include HTTP metrics port (10255)]:bool:(true false)' \
        '-prometheus-config-reloader=[config-reloader image]:image:' \
        '-config-reloader-cpu-request=[config-reloader CPU request (0 disables)]:qty:' \
        '-config-reloader-cpu-limit=[config-reloader CPU limit (0 disables)]:qty:' \
        '-config-reloader-memory-request=[config-reloader memory request (0 disables)]:qty:' \
        '-config-reloader-memory-limit=[config-reloader memory limit (0 disables)]:qty:' \
        '-enable-config-reloader-probes[enable probes on config-reloader container]' \
        '-alertmanager-default-base-image=[Alertmanager default base image]:image:' \
        '-prometheus-default-base-image=[Prometheus default base image]:image:' \
        '-thanos-default-base-image=[Thanos default base image]:image:' \
        '-controller-id=[controller-id reconciliation filter]:id:' \
        '-repair-policy-for-statefulsets=[stuck STS repair policy]:policy:(none evict delete)' \
        '-namespaces=[allow-list namespaces]:list:' \
        '-deny-namespaces=[deny-list namespaces]:list:' \
        '-prometheus-instance-namespaces=[namespaces watched for Prometheus CRs]:list:' \
        '-alertmanager-instance-namespaces=[namespaces watched for Alertmanager CRs]:list:' \
        '-alertmanager-config-namespaces=[namespaces watched for AlertmanagerConfig CRs]:list:' \
        '-thanos-ruler-instance-namespaces=[namespaces watched for ThanosRuler CRs]:list:' \
        '-watch-referenced-objects-in-all-namespaces[watch referenced objects cluster-wide]' \
        '*-annotations=[default annotation key=value to add to managed objects]:kv:' \
        '*-labels=[default label key=value to add to managed objects]:kv:' \
        '-cluster-domain=[cluster DNS domain]:domain:' \
        '-prometheus-instance-selector=[label selector for Prometheus CRs]:sel:' \
        '-alertmanager-instance-selector=[label selector for Alertmanager CRs]:sel:' \
        '-thanos-ruler-instance-selector=[label selector for ThanosRuler CRs]:sel:' \
        '-secret-field-selector=[field selector for Secrets]:sel:' \
        '-secret-label-selector=[label selector for Secrets]:sel:' \
        '-web.listen-address=[HTTP/HTTPS bind host\:port]:host\:port:' \
        '-web.tls-cert-file=[TLS cert file]:file:_files' \
        '-web.tls-key-file=[TLS key file]:file:_files' \
        '-web.client-ca-file=[client CA bundle]:file:_files' \
        '-log-format=[log format]:fmt:(logfmt json)' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-version[print version and exit]'
}

_prometheus-operator "$@"
