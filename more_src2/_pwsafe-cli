#compdef pwsafe-cli pwsafe
# Documentation: https://www.mankier.com/1/pwsafe
# Reference accessed: 2026-05-16
# Verified: pwsafe(1) manpage.

# pwsafe: command-line Password Safe (Nicolas Dade)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--createdb[create new database]' \
  '--exportdb[export database as text]' \
  '--mergedb=[merge database file into current]:file:_files' \
  '--passwd[change database passphrase]' \
  '--list=-[list entries matching regex]:regex:' \
  '(-a --add)'{-a,--add=-}'[add entry]:name:' \
  '(-e --edit)'{-e,--edit=}'[edit entry by regex]:regex:' \
  '--delete=[delete entry by name]:name:' \
  '(-f --file)'{-f,--file=}'[database file (default ~/.pwsafe.dat)]:file:_files' \
  '--dbversion=[database version]:version:(1 2)' \
  '(-I --case)'{-I,--case}'[regex is case-sensitive]' \
  '-l[show login and notes in list output]' \
  '(-u --username)'{-u,--username}'[show username of listed account]' \
  '(-p --password)'{-p,--password}'[show password of listed account]' \
  '(-E --echo)'{-E,--echo}'[force echo to stdout]' \
  '(-o --output)'{-o,--output=}'[redirect output to file]:file:_files' \
  '(-x --xclip)'{-x,--xclip}'[copy to X clipboard]' \
  '(-d --display)'{-d,--display=}'[override $DISPLAY]:display:' \
  '(-s --selection)'{-s,--selection=}'[X selection]:selection:(Primary Secondary Clipboard Both)' \
  '(-G --ignore)'{-G,--ignore=}'[ignore hosts]:NAME@HOST:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' && ret=0
return ret
