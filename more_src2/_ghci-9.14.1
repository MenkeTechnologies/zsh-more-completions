#compdef ghci-9.14.1
# Documentation: https://downloads.haskell.org/ghc/latest/docs/users_guide/ghci.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*-package+[use package]:package:' \
  '*-i+[add to import path]:dir:_files -/' \
  '*-I+[add to C include path]:dir:_files -/' \
  '-fbreak-on-exception[break on uncaught exceptions]' \
  '-fbreak-on-error[break on errors]' \
  '-ignore-dot-ghci[do not load .ghci]' \
  '-ghci-script+[GHCi script]:file:_files' \
  '*:Haskell source / object:_files -g "*.(hs|lhs|o|so|dll|dylib)"' && ret=0

return ret
