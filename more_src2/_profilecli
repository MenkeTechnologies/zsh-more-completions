#compdef profilecli
# Documentation: https://github.com/grafana/pyroscope/blob/main/cmd/profilecli/main.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose logging]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'admin:administrative tasks for Pyroscope operators'
      'query:query profile store'
      'query-tracer:analyze query traces'
      'upload:upload profile(s)'
      'canary-exporter:run the canary exporter'
      'ready:check Pyroscope health'
      'source-code:operations on source code mappings'
      'recording-rules:operations on recording rules'
      'debuginfo:operations on debuginfo (experimental)'
      'help:show help'
    )
    _describe -t commands 'profilecli command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
