#compdef mount_devfs
# Documentation: https://www.ipnom.com/FreeBSD-Man-Pages/mount_std.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mount_devfs: mount the devfs file system. Syntax: mount_devfs [-o options] devfs mount_point
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[mount options (comma-separated: ro,rw,nodev,noexec,nosuid,union)]:options' \
  '1:source:(devfs)' \
  '2:mount point:_files -/' && ret=0

return ret
