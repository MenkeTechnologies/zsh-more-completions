#compdef pyrefly
# Documentation: https://github.com/facebook/pyrefly/tree/main/pyrefly/lib/commands
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Pyrefly (Meta Python type checker)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:type-check Python files'
  'lsp:run the language server'
  'init:initialize Pyrefly config (migrate from Mypy/Pyright)'
  'infer:generate inferred type annotations'
  'suppress:silence existing type errors'
  'dump-config:dump effective configuration'
  'report:produce reports'
  'stubgen:generate type stubs'
  'buck-check:type-check Buck targets'
  'tsp:run the type server protocol'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'pyrefly command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (check)
        _arguments \
          '--project-excludes=[paths to exclude]:patterns' \
          '--search-path=[additional search paths]:dir:_files -/' \
          '--python-version=[target Python version]:version:(3.8 3.9 3.10 3.11 3.12 3.13 3.14)' \
          '--output-format=[output format]:format:(text json)' \
          '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
          '--config=[path to config file]:file:_files' \
          '*:file or directory:_files' && ret=0
        ;;
      (lsp)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      (init|infer|suppress|dump-config|report|stubgen|buck-check|tsp)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*: :_files' && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
