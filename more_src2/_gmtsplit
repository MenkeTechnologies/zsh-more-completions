#compdef gmtsplit
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtsplit.html
# Source: GenericMappingTools/gmt src/gmtsplit.c — split xyz files into segments by gaps/direction (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[azimuth/tolerance]:azimuth:_default' \
    '-C+[course change threshold]:course:_default' \
    '-D+[minimum segment distance]:distance:_default' \
    '-F+[xy and z filter widths]:filters:_default' \
    '-N+[output file template]:template:_default' \
    '-Q+[output column flags]:flags:_default' \
    '-S[input has 5 cols x,y,z,d,h]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[segment gaps]:gap:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-q+[record selection]:cols:_default' \
    '-s+[skip records with NaN]:cols:_default' \
    '*:input table:_files' \
    && ret=0

return ret
