#compdef gh-contribs gh-code-scanning gh-gonest gh-repo-list gh-worktree
# Documentation: upstream READMEs at github.com/{MintArchit/gh-contribs,advanced-security/gh-code-scanning,emmanuel-ferdman/gh-gonest,gh640/gh-repo-list,bjester/gh-worktree}
# Reference accessed: 2026-05-30
# gh-extension family round 7. Companions to rounds 158-163 multi-stems
# and the pre-existing _gh-poi/_gh-notify/_gh-dash/etc files.
# Hunt-skip log this round:
#   gh-lazy (gizmo385/gh-lazy) — Textual TUI tool, no documented CLI flags
#     beyond bare `gh lazy`. Skip per the bare-TUI-no-surface precedent.
#   gh-ost (mattn/gh-ost) — already covered at more_src/_gh-ost.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-contribs)
    # MintArchit/gh-contribs — terminal contribution graph (8 flag pairs).
    _arguments -s -S \
      '(-s --scheme)-s+[color scheme]:scheme:(gh_contrast vibrant dracula nord gold sunset mint)' \
      '(-s --scheme)--scheme=[color scheme]:scheme:(gh_contrast vibrant dracula nord gold sunset mint)' \
      '(-g --glyph)-g+[character glyph]:glyph:(square dot fisheye diamond plus block)' \
      '(-g --glyph)--glyph=[character glyph]:glyph:(square dot fisheye diamond plus block)' \
      '(-u --user)-u+[display another user'\''s graph]:username:' \
      '(-u --user)--user=[display another user'\''s graph]:username:' \
      '(-w --weeks)-w+[week range]:weeks:' \
      '(-w --weeks)--weeks=[week range]:weeks:' \
      '(-p --portrait)-p[portrait orientation]' \
      '(-p --portrait)--portrait[portrait orientation]' \
      '(-l --labels)-l[include day labels]' \
      '(-l --labels)--labels[include day labels]' \
      '(-t --total)-t[show total contribution count]' \
      '(-t --total)--total[show total contribution count]' \
      '(-d --double)-d[double glyph width]' \
      '(-d --double)--double[double glyph width]' \
      && ret=0
    ;;

  gh-code-scanning)
    # advanced-security/gh-code-scanning — bulk Code Scanning automation.
    local -a _subcmds
    _subcmds=(
      'enable:deploy Code Scanning with CodeQL workflow'
      'alerts:output Code Scanning alerts'
      'analyses:display or delete Code Scanning analyses'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-code-scanning subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          enable)
            _arguments \
              '--force[overwrite existing workflows]' \
              '--git-push[commit directly instead of creating a PR]' \
              '--workflow=[custom CodeQL workflow file]:file:_files -g "*.(yml|yaml)"' \
              '1:owner/repo:' && ret=0
            ;;
          alerts)
            _arguments \
              '1:owner/repo:' && ret=0
            ;;
          analyses)
            _arguments \
              '--delete[remove analyses]' \
              '--ref=[filter by git branch/ref]:ref:__git_branch_names' \
              '1:owner/repo:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-gonest)
    # emmanuel-ferdman/gh-gonest — clean up phantom (deleted-repo)
    # GitHub notifications.
    _arguments -s -S \
      '--dry-run[preview changes safely]' \
      '--after=[filter by date]:date:' \
      && ret=0
    ;;

  gh-repo-list)
    # gh640/gh-repo-list — list repositories by --type enum (required).
    _arguments -s -S \
      '--type=[which repos to list (required)]:type:(own starred viewer-status)' \
      && ret=0
    ;;

  gh-worktree)
    # bjester/gh-worktree — git worktree manager with gh integration.
    local -a _subcmds
    _subcmds=(
      'init:initialize a repository for worktrees'
      'create:create a new worktree with optional base ref'
      'checkout:create a worktree from a PR number/URL/branch'
      'remove:delete a worktree (--force for unmerged commits)'
      'install:set up as gh extension or standalone tool'
      'version:display installed version'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-worktree subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          remove)
            _arguments \
              '--force[remove worktree even with unmerged commits]' \
              '1:worktree:_files -/' && ret=0
            ;;
          install)
            _arguments \
              '(--gh-ext --path-bin)--gh-ext[install as gh extension]' \
              '(--gh-ext --path-bin)--path-bin[install as standalone tool on PATH]' && ret=0
            ;;
          checkout)
            _arguments \
              '1:PR number, URL, or branch name:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
