#compdef matrix-commander-rs
# _matrix-commander-rs — Matrix CLI client in Rust (8go/matrix-commander-rs)
# upstream: https://github.com/8go/matrix-commander-rs
# Flags from src/main.rs (clap derive).

_matrix-commander-rs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]:check:(check)' \
        '--usage[print short usage]' \
        '--manual[show full manual]' \
        '--readme[show README]' \
        '--contribute[show contribution info]' \
        '*-d[debug (repeatable)]' \
        '*--debug[debug (repeatable)]' \
        '--log-level=[log level per crate]:list:(error warn info debug trace)' \
        '*--verbose[verbose (repeatable)]' \
        '--plain[plain text output]' \
        '(-c --credentials)'{-c+,--credentials=}'[credentials file]:file:_files' \
        '(-s --store)'{-s+,--store=}'[Matrix store dir]:dir:_files -/' \
        '--login=[login method]:method:(password sso)' \
        '--verify=[verification method]:method:(emoji manual manual-device device)' \
        '--bootstrap[bootstrap cross-signing]' \
        '--homeserver=[homeserver URL]:url:' \
        '--user-login=[Matrix user ID]:user:' \
        '--password=[password]:pass:' \
        '--device=[device name]:dev:' \
        '--room-default=[default room]:room:' \
        '--devices[list devices]' \
        '--timeout=[request timeout (s)]:secs:' \
        '*'{-m+,--message=}'[message text]:msg:' \
        '--markdown[format messages as Markdown]' \
        '--code[format messages as code blocks]' \
        '--html[format messages as HTML]' \
        '*'{-r+,--room=}'[room]:room:' \
        '*'{-f+,--file=}'[file to send]:file:_files' \
        '--notice[send as m.notice]' \
        '--emote[send as m.emote]' \
        '--sync=[sync type]:type:(full off)' \
        '(-l --listen)'{-l+,--listen=}'[listen type]:type:(forever once tail all never)' \
        '--tail=[number of tail messages]:n:' \
        '(-y --listen-self)'{-y,--listen-self}'[listen to own messages]' \
        '--whoami[print user-id and exit]' \
        '(-o --output)'{-o+,--output=}'[output format]:fmt:(text json json-spec json-max)' \
        '*--file-name=[output filename]:file:_files' \
        '*--room-get-info=[get info for room]:room:'
}

_matrix-commander-rs "$@"
