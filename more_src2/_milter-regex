#compdef milter-regex
# Documentation: https://www.mankier.com/8/milter-regex
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c+[configuration file]:file:_files' \
  '-d[do not detach; verbose debug to stdout]' \
  '-f+[syslog facility]:facility:' \
  '-G+[pipe group ID]:group:_groups' \
  '-j+[chroot directory]:dir:_files -/' \
  '-l+[max log level]:level:' \
  '-m+[ignore mail body after N lines]:lines:' \
  '-P+[pipe permission mode]:mode:' \
  '-p+[sendmail interface pipe]:pipe:_files' \
  '-r+[PID file]:file:_files' \
  '-t[test configuration and exit]' \
  '-U+[pipe user ID]:user:_users' \
  '-u+[run as user]:user:_users' && ret=0

return ret
