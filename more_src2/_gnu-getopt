#compdef gnu-getopt
# Documentation: https://man7.org/linux/man-pages/man1/getopt.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for GNU getopt (util-linux build; use gnu-getopt on BSD/macOS)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[usage]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-a --alternative)'{-a,--alternative}'[allow long options with single -]' \
  '(-l --longoptions)'{-l,--longoptions}'[long opts]:list' \
  '(-o --options)'{-o,--options}'[short opt string]:string' \
  '(-q --quiet)'{-q,--quiet}'[no errors]' \
  '(-Q --quiet-output)'{-Q,--quiet-output}'[no normal output]' \
  '(-s --shell)'{-s,--shell}'[shell]:shell:(bash sh tcsh csh)' \
  '(-u --unquoted)'{-u,--unquoted}'[do not quote]' \
  '(-T --test)'{-T,--test}'[test mode]' \
  '*::args: _normal' && ret=0

return ret
