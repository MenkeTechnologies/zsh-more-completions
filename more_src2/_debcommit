#compdef debcommit
# Documentation: https://manpages.debian.org/debcommit
# Source: debian/devscripts scripts/debcommit.pl — commit debian/changelog entries (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    {-r,--release}'[commit and tag as a release]' \
    {-m+,--message=}'[commit message]:message:_default' \
    {-n,--noact}'[do not actually commit]' \
    {-d,--diff}'[show what would be committed without commit]' \
    {-C,--confirm}'[confirm commit message]' \
    {-e,--edit}'[edit commit message]' \
    {-a,--all}'[include all changed files]' \
    {-c+,--changelog=}'[changelog file]:file:_files' \
    '(--no-strip-message)'{-s,--strip-message}'[strip the "* " from changelog entries]' \
    '--no-strip-message[keep the "* " in commit message]' \
    '(--no-sign-commit)--sign-commit[GPG-sign the commit]' \
    '--no-sign-commit[do not GPG-sign the commit]' \
    '(--no-sign-tags)--sign-tags[GPG-sign release tags]' \
    '--no-sign-tags[do not GPG-sign release tags]' \
    '(--no-signoff)--signoff[add Signed-off-by trailer]' \
    '--no-signoff[do not add Signed-off-by]' \
    '(--no-changelog-info)--changelog-info[populate fields from changelog]' \
    '--no-changelog-info[do not populate fields]' \
    '(--no-release-use-changelog -R)'{-R,--release-use-changelog}'[use changelog for release commit]' \
    '--no-release-use-changelog[do not use changelog]' \
    '*:files to commit:_files' \
    && ret=0

return ret
