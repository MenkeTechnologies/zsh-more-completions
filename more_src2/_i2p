#compdef i2p i2prouter i2psnark
# _i2p — Invisible Internet Project i2p router CLI for the I2P anonymous overlay network managing the Java-based router console eepsite hosting i2psnark torrent client i2psam tunnels and address book (i2p team, Java); shell wrapper
# upstream: https://github.com/i2p/i2p.i2p

_i2p() {
    local -a sub=(
        'start:start I2P router'
        'stop:stop I2P router'
        'restart:restart I2P router'
        'status:show router status'
        'console:open router console'
        'graceful:graceful shutdown'
        'install:install I2P'
        'uninstall:uninstall I2P'
        'dump:dump JVM state'
        'condrestart:conditional restart'
        'run:run I2P in foreground'
        'log:show logs'
        'logs:show logs'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--work-dir=+[dir]:dir:_files -/' \
        '--log-dir=+[dir]:dir:_files -/' \
        '--pid-file=+[file]:file:_files' \
        '--router-config=+[file]:file:_files -g "*.config router.config"' \
        '--app-config=+[file]:file:_files -g "*.config"' \
        '--no-banner[no banner]' \
        '--no-update-check[no update check]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'i2p subcommand' sub ;;
        args) ;;
    esac
}

_i2p "$@"
