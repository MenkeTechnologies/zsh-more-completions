#compdef kubectl-conditioner
# Documentation: https://github.com/devbytes-cloud/conditioner
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-conditioner (devbytes-cloud/conditioner): sets node conditions.
# Accepts one or more node names as positional arguments.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--type=[condition type to interact with]:type:' \
  '--status=[condition status: true, false, or blank for unknown]:status:(true false)' \
  '--reason=[machine-readable reason for the condition]:reason:' \
  '--message=[human-readable transition message]:message:' \
  '(-x --remove)'{-x,--remove}'[remove the specified condition from a node]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '*:node:_default'
