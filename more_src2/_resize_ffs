#compdef resize_ffs
# Documentation: man resize_ffs(8)
# Source: netbsd/src sbin/resize_ffs — resize an FFS file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[check whether new size would change filesystem]' \
    '-p[show progress information]' \
    '-s+[target size in disk sectors]:size:_default' \
    '-v[additional diagnostic output]' \
    '-y[skip confirmation prompts]' \
    '1:special device:_files' \
    && ret=0

return ret
