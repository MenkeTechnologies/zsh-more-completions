#compdef malli-cli
# _malli-cli — Tommi Reiman malli data-driven schema CLI alias (metosin team, Clojure); tools.deps function CLI
# upstream: https://github.com/metosin/malli

_malli-cli() {
    local -a sub=(
        'validate:validate data against schema'
        'explain:explain validation errors'
        'coerce:coerce data with transformer'
        'parse:parse data'
        'generate:generate sample data'
        'schema:show schema info'
        'json-schema:convert to JSON Schema'
        'swagger:convert to Swagger'
        'transformer:transform data'
        'transformer-strip-extra:strip extra keys'
        'transformer-string:string transformer'
        'transformer-json:json transformer'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'malli subcommand' sub ;;
        args)
            case $words[1] in
                validate|explain|coerce|parse|generate|json-schema|swagger) _arguments \
                    ':schema=+[schema edn]:str:' \
                    ':data=+[data edn]:str:' \
                    ':data-file=+[data file]:file:_files' \
                    ':schema-file=+[schema file]:file:_files' \
                    ':transformer=+[transformer]:t:(string-transformer json-transformer strip-extra-keys-transformer collection-transformer key-transformer)' \
                    ':registry=+[registry]:str:' \
                    ':output=+[output file]:file:_files' \
                    ':output-format=+[format]:f:(edn json transit)' ;;
            esac
            ;;
    esac
}

_malli-cli "$@"
