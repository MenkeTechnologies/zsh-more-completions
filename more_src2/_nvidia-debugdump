#compdef nvidia-debugdump
# Documentation: https://download.nvidia.com/XFree86/Linux-x86_64/396.51/README/nvidia-debugdump.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --list)'{-l,--list}'[list NVIDIA GPU devices]' \
  '(-D --dumpall)'{-D,--dumpall}'[dump all components for a device]' \
  '(-z --debug)'{-z,--debug}'[verbose debug-level output]' \
  '--device=[target device index]:idx:' \
  '--file=[output file]:file:_files' && ret=0

return ret
