#compdef esbuild
# _esbuild-bin — esbuild extreme-speed JS/TS bundler + minifier (Evan Wallace, Go); production-grade Go-based bundler used by Vite/Snowpack
# upstream: https://github.com/evanw/esbuild

_esbuild-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--bundle[bundle all imports]' \
        '--outfile=+[output file]:file:_files' \
        '--outdir=+[output dir]:dir:_files -/' \
        '--outbase=+[output base]:dir:_files -/' \
        '--platform=+[platform]:platform:(browser node neutral)' \
        '--target=+[target]:target:' \
        '--format=+[format]:fmt:(cjs esm iife)' \
        '--external:+[external import]:name:' \
        '--global-name=+[global name (iife)]:name:' \
        '--minify[minify all]' \
        '--minify-whitespace[minify whitespace]' \
        '--minify-identifiers[minify identifiers]' \
        '--minify-syntax[minify syntax]' \
        '--sourcemap[generate sourcemap]' \
        '--sourcemap=+[sourcemap mode]:mode:(external inline both linked)' \
        '--sources-content=+[include sources]:bool:(true false)' \
        '--source-root=+[source root]:str:' \
        '--sourcefile=+[source file name]:str:' \
        '--legal-comments=+[legal comments]:mode:(none inline eof linked external)' \
        '--banner:+[banner]:str:' \
        '--footer:+[footer]:str:' \
        '--tsconfig=+[tsconfig]:file:_files' \
        '--resolve-extensions=+[extensions]:ext:' \
        '--main-fields=+[main fields]:str:' \
        '--conditions=+[exports conditions]:str:' \
        '--public-path=+[public path]:str:' \
        '--inject:+[inject file]:file:_files' \
        '--loader=+[default loader]:loader:(js jsx ts tsx css json text base64 file dataurl binary default empty copy)' \
        '--loader:.+[ext loader]:ext.loader:' \
        '--keep-names[keep function/class names]' \
        '--charset=+[charset]:charset:(ascii utf8)' \
        '--color=+[color]:when:(true false)' \
        '--log-level=+[log level]:level:(verbose debug info warning error silent)' \
        '--log-limit=+[log limit]:n:' \
        '--log-override:+[log override]:setting:' \
        '--watch[watch and rebuild]' \
        '--serve=+[serve host:port]:hostport:' \
        '--servedir=+[serve dir]:dir:_files -/' \
        '--metafile=+[write metafile]:file:_files' \
        '--analyze[print metafile analysis]' \
        '--tree-shaking=+[tree shaking]:bool:(true false)' \
        '--define:+[define]:name=val:' \
        '--alias:+[alias]:from=to:' \
        '--pure:+[pure call]:fn:' \
        '--jsx=+[JSX mode]:mode:(transform preserve)' \
        '--jsx-factory=+[JSX factory]:name:' \
        '--jsx-fragment=+[JSX fragment]:name:' \
        '--asset-names=+[asset names]:pattern:' \
        '--entry-names=+[entry names]:pattern:' \
        '--chunk-names=+[chunk names]:pattern:' \
        '*:file:_files'
}

_esbuild-bin "$@"
