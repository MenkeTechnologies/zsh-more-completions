#compdef ppmdim
# Documentation: man ppmdim (Netpbm)
# Source: dim a PPM image by a multiplicative factor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:dim factor (0..1):' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
