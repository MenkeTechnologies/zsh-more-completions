#compdef root-config
# Documentation: https://github.com/root-project/root/blob/master/config/root-config.in
# Reference accessed: 2026-05-27
# Verified: upstream case "$1" branches in config/root-config.in

# root-config: print build configuration / flags / libraries for compiling
# against ROOT.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help and exit]' \
  '(- *)--version[print ROOT version]' \
  '(- *)--git-revision[print git revision number]' \
  '(- *)--arch[print compiler/OS architecture]' \
  '(- *)--platform[print operating system platform]' \
  '(- *)--config[print CMake configuration arguments]' \
  '--prefix=-[installation prefix]::dir:_files -/' \
  '--exec-prefix=-[execution prefix]::dir:_files -/' \
  '--cflags[print compiler flags and header paths]' \
  '--auxcflags[print auxiliary compiler flags]' \
  '--ldflags[print linker flags]' \
  '--cc[print C compiler used at build time]' \
  '--cxx[print C++ compiler used at build time]' \
  '--f77[print Fortran compiler used at build time]' \
  '--ld[print linker used at build time]' \
  '--cxxstandard[print C++ standard version]' \
  '--libs[print regular ROOT libraries]' \
  '--glibs[print regular + GUI libraries]' \
  '--evelibs[print regular + GUI + Eve libraries]' \
  '--auxlibs[print auxiliary system libraries]' \
  '--new[enable libNew library]' \
  '--nonew[disable libNew library]' \
  '--bindir[print executable directory]' \
  '--libdir[print library directory]' \
  '--incdir[print header directory]' \
  '--etcdir[print configuration directory]' \
  '--tutdir[print tutorials directory]' \
  '--srcdir[print source directory]' \
  '--features[list supported features]' \
  '--has-*[test if feature is compiled in]' \
  '--noauxlibs[omit auxiliary libraries from --libs]' \
  '--noauxcflags[omit auxiliary compiler flags from --cflags]' \
  '--noldflags[omit linker flags]' \
  '--ncpu[print number of available CPU cores]' \
  '--python-version[print Python version used by ROOT]' \
  '--python3-version[print Python 3 version used by ROOT]' && ret=0

return ret
