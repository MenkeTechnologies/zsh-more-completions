#compdef geph4-client
# Documentation: https://github.com/geph-official/geph4-client
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

# Subcommands defined in src/config.rs Opt enum: connect, bridge-test, sync, binder-proxy, debugpack
commands=(
  'connect:connect to Geph network'
  'bridge-test:test bridge connection'
  'sync:sync exits/subscription info'
  'binder-proxy:JSON-RPC proxy to binder'
  'debugpack:export debug logs'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'geph4-client command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (connect)
        _arguments \
          '--credential-cache=[credential cache path]:dir:_files -/' \
          '--use-bridges[force bridge usage]' \
          '--http-listen=[HTTP proxy listen address]:addr:' \
          '--socks5-listen=[SOCKS5 listen address]:addr:' \
          '--stats-listen=[stats REST listen address]:addr:' \
          '--dns-listen=[DNS listen address]:addr:' \
          '--exit-server=[exit server hostname]:host:_hosts' \
          '--exclude-prc[exclude PRC domains]' \
          '--vpn-mode=[VPN mode]:mode:(inherited-fd tun-no-route tun-route windivert stdio)' \
          '*--forward-ports=[SSH-style local-remote forward host:port:::host:port]:spec:' \
          'auth-password[password auth]' \
          'auth-keypair[keypair auth]' \
          '--username=[username]:user:' \
          '--password=[password]:pw:' \
          '--sk-path=[private key file]:file:_files' && ret=0 ;;
      (debugpack)
        _arguments \
          '--export-to=[export debug pack to file]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
