#compdef kwok
# Documentation: https://kwok.sigs.k8s.io/docs/generated/kwok/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kwok (kubernetes-sigs/kwok). Single-binary simulator (no subcommands).
# Removed from prior file: invented `create`, `delete`, `get`, `hack`,
# `help`, `version` subcommands and `--name` / `--namespace` flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--cidr=[pod IP range]:cidr:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--master=[Kubernetes API server address]:url:' \
  '--node-name=[node name]:name:' \
  '--node-ip=[node IP]:ip:' \
  '--node-port=[node port]:port:' \
  '--node-lease-duration-seconds=[lease duration]:seconds:' \
  '--manage-all-nodes[watch all nodes]' \
  '--manage-single-node=[watch specific named node]:name:' \
  '--manage-nodes-with-label-selector=[select nodes by labels]:selector:' \
  '--manage-nodes-with-annotation-selector=[select nodes by annotations]:selector:' \
  '*--enable-crds=[custom resources to support]:crd:' \
  '--server-address=[server exposure address]:address:' \
  '--tls-cert-file=[HTTPS certificate]:file:_files' \
  '--tls-private-key-file=[HTTPS private key]:file:_files' \
  '--tracing-endpoint=[tracing destination]:endpoint:' \
  '--tracing-sampling-rate-per-million=[tracing sampling rate]:rate:' \
  '(-v --v)'{-v+,--v=}'[log verbosity level]:level:' && ret=0

return ret
