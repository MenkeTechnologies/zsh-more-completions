#compdef debrelease
# Documentation: https://manpages.debian.org/debrelease
# Source: debian/devscripts scripts/debrelease.sh — release wrapper around dupload/dput (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--dput)--dupload[use dupload (default)]' \
    '(--dupload)--dput[use dput]' \
    '--multi[search for multiarch .changes (dpkg-cross)]' \
    '--debs-dir=-[directory with .changes/.deb]:dir:_files -/' \
    '--check-dirname-level=-[directory check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory regex]:regex:_default' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '*::dupload/dput options:_default' \
    && ret=0

return ret
