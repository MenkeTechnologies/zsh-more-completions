#compdef pamsharpmap
# Documentation: man pamsharpmap (Netpbm)
# Source: produce a per-pixel sharpness map of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:image file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
