#compdef groupinfo
# _groupinfo — OpenBSD groupinfo (low-level binary behind group info; displays group name/gid/members or with -e returns only exit status indicating existence)
# upstream: https://github.com/openbsd/src (usr.sbin/user)
# Flags from usr.sbin/user/groupinfo.8 on tip.

_groupinfo() {
    _arguments \
        '-e[exit-status only (check existence)]' \
        '1:group:_groups'
}

_groupinfo "$@"
