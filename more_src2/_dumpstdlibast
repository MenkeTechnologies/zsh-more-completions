#compdef dumpstdlibast jsonnet-deps jsonnet-lint
# Documentation: source-direct extraction from upstream
# google/go-jsonnet cmd/{dumpstdlibast,jsonnet-deps,jsonnet-lint}/
# *.go - these are NOT the C++ jsonnet binaries (already covered as
# `jsonnet`/`jsonnetfmt`); these are the Go port's auxiliary
# binaries. jsonnet-deps + jsonnet-lint use hand-rolled
# `processArgs(...)` loops walking os.Args (NOT flag.Var or cobra),
# so the option set was extracted by reading the `usage()` func
# bodies and matching `arg == "-X" || arg == "--Y"` chains;
# dumpstdlibast has no flags - it just takes a single positional
# argument per `if len(os.Args) != 2 { ... }`.
# Reference accessed: 2026-05-30 via gh api.
# google/go-jsonnet aux R135a — 3-stem multi-binary harvest of the
# 3 go-jsonnet auxiliary binaries that ship from cmd/* alongside
# the main `jsonnet` + `jsonnetfmt` ports (already covered in
# earlier rounds). Filename uses alphabetically-first stem
# `dumpstdlibast` (d < j).

# Shared 3-flag option set used by both jsonnet-deps and jsonnet-lint
# (extracted from each binary's hand-rolled processArgs loop).
local -a _jsonnet_aux_common
_jsonnet_aux_common=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-v --version)'{-v,--version}'[print version and exit]'
  '*'{-J+,--jpath=}'[additional library search dir (repeatable; right-most wins)]:dir:_directories'
)

case $service in

  dumpstdlibast)
    # Dump the parsed AST of a Jsonnet file using the internal
    # program.SnippetToAST helper. Takes a single positional file
    # path; no other flags. Used by go-jsonnet upstream developers
    # to debug parser changes.
    _arguments -s -S \
      '1:jsonnet file:_files -g "*.(jsonnet|libsonnet)"'
    ;;

  jsonnet-deps)
    # Print the transitive `import` and `importstr` dependency list
    # of a Jsonnet file in Make-compatible format. Used by build
    # systems to generate dependency rules.
    _arguments -s -S \
      "${_jsonnet_aux_common[@]}" \
      '(-o --output-file)'{-o+,--output-file=}'[write dependency list to file instead of stdout]:file:_files' \
      '*:jsonnet file:_files -g "*.(jsonnet|libsonnet)"'
    ;;

  jsonnet-lint)
    # Static-analyze a Jsonnet file for common errors without
    # actually evaluating it.
    _arguments -s -S \
      "${_jsonnet_aux_common[@]}" \
      '*:jsonnet file:_files -g "*.(jsonnet|libsonnet)"'
    ;;

esac
