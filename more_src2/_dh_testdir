#compdef dh_testdir
# Documentation: https://manpages.debian.org/dh_testdir
# Source: Debian/debhelper dh_testdir — test that source directory contains required files (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '--no-act[do not act]' \
    '*-O+[passthrough option]:opt:_default' \
    '*:expected file:_files' \
    && ret=0

return ret
