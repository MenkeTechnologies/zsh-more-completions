#compdef e4crypt
# Documentation: man e4crypt(8)
# Source: tytso/e2fsprogs misc/e4crypt.c (master) — ext4 encryption helper (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '1:command:(help add_key get_policy new_session set_policy)' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmdargs)
        case $line[1] in
            add_key)
                _arguments \
                    '-S+[salt value]:salt:_default' \
                    '-k+[keyring]:keyring:(@us @u @s @g @p @t)' \
                    '-p+[padding (4 8 16 32)]:pad:(4 8 16 32)' \
                    '-v[verbose]' \
                    '-q[quiet]' \
                    '*:directory:_files -/' ;;
            get_policy)
                _arguments '*:path:_files -/' ;;
            new_session)
                _arguments ;;
            set_policy)
                _arguments \
                    '1:policy descriptor:_default' \
                    '*:directory:_files -/' ;;
            help)
                _arguments '1::command:(add_key get_policy new_session set_policy)' ;;
        esac
        ;;
esac

return ret
