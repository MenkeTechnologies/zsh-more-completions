#compdef feedone
# Documentation: man feedone(8)
# Source: InterNetNews/inn frontends/feedone.c — feed one article to innd (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m+[specified Message-ID]:msgid:_default' \
    '-p[use POST, not IHAVE]' \
    '-r[random Message-ID]' \
    '-t[tracing]' \
    '1:article file:_files' \
    && ret=0

return ret
