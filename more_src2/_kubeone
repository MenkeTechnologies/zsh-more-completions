#compdef kubeone
# Documentation: https://github.com/kubermatic/kubeone
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'addons:manage cluster addons'
      'apply:reconcile the cluster from a manifest'
      'certificates:perform certificate operations'
      'completion:generate shell completion scripts'
      'config:configuration helpers'
      'document:generate documentation'
      'etcd-operations:perform etcd-related operations'
      'init:initialize a new KubeOne configuration'
      'kubeconfig:download kubeconfig for the cluster'
      'local:operate on the local node'
      'migrate:migration utilities'
      'mirror-images:mirror container images'
      'proxy:proxy configuration helpers'
      'reset:reset the cluster'
      'status:check cluster status'
      'ui:launch the user interface'
      'version:print version information'
      'help:help about any command'
    )
    _describe -t commands 'kubeone command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      apply|kubeconfig|status|reset)
        _arguments -s -S \
          '(-m --manifest)'{-m+,--manifest=}'[kubeone manifest]:file:_files' \
          '(-t --tfjson)'{-t+,--tfjson=}'[terraform output json]:file:_files' \
          '(-y --auto-approve)'{-y,--auto-approve}'[auto approve plan]' \
          '--kubeconfig=[path to kubeconfig]:file:_files' \
          '*: : _default' \
          && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
