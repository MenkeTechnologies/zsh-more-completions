#compdef named-nzd2nzf
# Documentation: https://bind9.readthedocs.io/en/latest/manpages.html
# Source: isc-projects/bind9 bin/tools/named-nzd2nzf.c — convert NZD database to NZF format on stdout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:nzd file:_files -g "*.nzd(-.)"' \
    && ret=0

return ret
