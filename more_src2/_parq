#compdef parq
# Documentation: upstream README at github.com/chhantyal/parquet-cli
# Reference accessed: 2026-05-30 via WebFetch.
# parq R109 — lightweight Python CLI for inspecting Apache Parquet
# files (entry point of the `parquet-cli` PyPI package — distinct
# from the parquet-tools Python package already covered as
# `more_src/_parquet-tools`, and from Apache parquet-rs's `cli`
# feature binaries covered as the multi-stem `more_src/_parquet-read`
# from R108).

_arguments -s -S \
  '(-s --schema)'{-s,--schema}'[show schema information]' \
  '--head=[show first N rows]:N:' \
  '--tail=[show last N rows]:N:' \
  '(-c --count)'{-c,--count}'[show total row count]' \
  '(- *)'{-h,--help}'[show help]' \
  '1:parquet file:_files -g "*.parquet"'
