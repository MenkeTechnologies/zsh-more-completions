#compdef geant4-config
# Documentation: https://github.com/Geant4/geant4/blob/master/cmake/Templates/geant4-config.in
# Reference accessed: 2026-05-27
# Verified: upstream cmake/Templates/geant4-config.in case branches.

# geant4-config — print build configuration / flags / libraries / dataset
# information for compiling and linking against Geant4.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help message and exit]' \
  '(- *)-\?[show help message and exit]' \
  '(- *)--usage[display brief usage message]' \
  '(- *)--version[print Geant4 version]' \
  '--prefix[print Geant4 installation prefix]' \
  '--cxxstd[print C++ standard Geant4 was compiled against]' \
  '--tls-model[print Thread Local Storage model used]' \
  '--cflags[print preprocessor and compiler flags]' \
  '--cflags-without-gui[print compiler flags excluding GUI components]' \
  '--libs[print linker flags for all Geant4 libraries]' \
  '--libs-without-gui[print linker flags excluding GUI components]' \
  '--has-feature[test if a feature is enabled]:feature:' \
  '--features[list enabled and disabled features]' \
  '--sh[print sh/bash env-var commands (eval-able)]' \
  '--csh[print csh env-var commands (eval-able)]' \
  '--datasets[print dataset name, env var, and path (one per line)]' \
  '--check-datasets[print dataset name, install status, and expected location]' \
  '--install-datasets[download and install any missing datasets]' && ret=0

return ret
