#compdef pkexec
# _pkexec — polkit pkexec (run a command as another user, by default root, with policykit authorization checking; --user run as specific target user, --disable-internal-agent disable the built-in TTY agent, --keep-cwd keep current working directory, --version, --help; positional command and its args)
# upstream: https://github.com/polkit-org/polkit
# Flags from polkit-org/polkit src/programs/pkexec.c on tip.

_pkexec() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-u+[target user]:user:_users' \
        '--user+[target user]:user:_users' \
        '--disable-internal-agent[disable internal agent]' \
        '--keep-cwd[keep cwd]' \
        '*::command:_command_names -e'
}

_pkexec "$@"
