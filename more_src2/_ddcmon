#compdef ddcmon
# Documentation: i2c-tools ddcmon
# Source: i2c-tools eeprom/ddcmon (master) — decode VESA DDC EDID monitor data (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1::I2C bus:_default' \
    '2::EEPROM address (default 0x50):_default' \
    && ret=0

return ret
