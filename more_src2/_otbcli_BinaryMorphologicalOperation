#compdef otbcli_BinaryMorphologicalOperation
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_BinaryMorphologicalOperation.html
# Source: orfeotoolbox/OTB BinaryMorphologicalOperation — dilate/erode/opening/closing.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[output image]:image:_files' \
    '-channel+[channel index (default 1)]:n:_default' \
    '-structype+[structuring element shape]:shape:(box ball cross)' \
    '-xradius+[SE horizontal radius (default 5)]:n:_default' \
    '-yradius+[SE vertical radius (default 5)]:n:_default' \
    '-foreval+[foreground value (default 1.0)]:value:_default' \
    '-backval+[background value (default 0.0)]:value:_default' \
    '-filter+[morphological operation]:op:(dilate erode opening closing)' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
