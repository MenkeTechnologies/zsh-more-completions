#compdef pmlogger_merge
# _pmlogger_merge — Performance Co-Pilot pmlogger_merge (low-level helper used by pmlogger_daily to concatenate a sequence of pmlogger archives into a single archive; -f input list file, -V verbose, -q quiet, -S start, -T finish, positional input archive list followed by output archive prefix)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmlogger/pmlogger_merge on tip.

_pmlogger_merge() {
    _arguments \
        '-f+[input list file]:file:_files' \
        '-V[verbose]' \
        '-q[quiet]' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-Z+[timezone]:tz:' \
        '-r[remove inputs]' \
        '*:archive:_files'
}

_pmlogger_merge "$@"
