#compdef rocfft-test rocfft-rider rocfft-bench rocfft-information
# _rocfft — AMD ROCm rocFFT discrete Fast Fourier Transform CUDA-equivalent library tests and benchmark runners (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocFFT

_rocfft() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--gtest_filter=+[pattern]:str:' \
        '--gtest_list_tests[list tests]' \
        '--gtest_repeat=+[N]:n:' \
        '--gtest_random_seed=+[N]:n:' \
        '--gtest_print_time=+[bool]:b:(0 1)' \
        '--gtest_output=+[format:file]:str:' \
        '--gtest_break_on_failure[break on failure]' \
        '--gtest_throw_on_failure[throw on failure]' \
        '--gtest_catch_exceptions=+[bool]:b:(0 1)' \
        '--gtest_color=+[mode]:m:(yes no auto)' \
        '-N+[transform length]:n:' \
        '--length=+[transform length]:n:' \
        '-b+[batch size]:n:' \
        '--batch=+[batch size]:n:' \
        '-t+[fft type]:t:(c2c c2r r2c)' \
        '--transformType=+[fft type]:t:(c2c c2r r2c)' \
        '-d+[direction]:d:(-1 1 forward backward inverse)' \
        '--direction=+[direction]:d:(-1 1 forward backward inverse)' \
        '-p+[precision]:p:(single double half)' \
        '--precision=+[precision]:p:(single double half)' \
        '--placement=+[mode]:m:(in-place out-of-place)' \
        '--itype=+[input type]:t:(complex real)' \
        '--otype=+[output type]:t:(complex real)' \
        '--devices=+[devices csv]:str:' \
        '--threads=+[N]:n:' \
        '--ntrial=+[N]:n:' \
        '--callbacks[use callbacks]' \
        '--graph[use graph capture]' \
        '--scale=+[F]:f:' \
        '--vsname=+[name]:str:' \
        '--vsbench=+[name]:str:'
}

_rocfft "$@"
