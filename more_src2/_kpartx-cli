#compdef kpartx-cli
# _kpartx-cli — multipath-tools kpartx create device maps from partition tables CLI alias (multipath-tools team, C); custom argparse
# upstream: https://github.com/opensvc/multipath-tools

_kpartx-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[add partition mappings]' \
        '-r[read-only mappings]' \
        '-d[delete partition mappings]' \
        '-u[update partition mappings]' \
        '-l[list partitions]' \
        '-f[force creation]' \
        '-v[verbose]' \
        '-g[force GUID partition table]' \
        '-G+[force]:str:' \
        '-n[no partitions discovered]' \
        '-s[sync mode]' \
        '-p+[partition delimiter]:str:' \
        '-t+[partition table type]:t:(dos gpt bsd sun mac aix amiga)' \
        '-b[bypass udev daemon]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper,loop}*"'
}

_kpartx-cli "$@"
