#compdef gdcmpap3
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmpap3.cxx — PAPYRUS 3.0 → DICOM converter (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input PAPYRUS 3.0 file]:file:_files -g "*.pa3"' \
    '(-o --output)'{-o+,--output=}'[output DICOM file]:file:_files' \
    '(-S --split)'{-S,--split}'[split single PAPYRUS 3.0 into multiple DICOM files]' \
    '--decomp-pap3[use PAPYRUS 3.0 to decompress]' \
    '--check-iop[check Image Orientation (Patient) attribute]' \
    '--root-uid=[Root UID]:uid:_default' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '1:input.pa3:_files -g "*.pa3"' \
    '2:output.dcm:_files' \
    && ret=0

return ret
