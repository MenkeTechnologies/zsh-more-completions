#compdef picrust2 picrust2_pipeline.py
# _picrust2 — Langille Lab picrust2 CLI Phylogenetic Investigation of Communities by Reconstruction of Unobserved States v2 pipeline predicting metagenome functional content from 16S rRNA amplicon sequences using phylogenetic placement with EPA-ng SEPP producing per-sample KO EC MetaCyc-pathway abundances (Langille Lab team, Python); argparse
# upstream: https://github.com/picrust/picrust2

_picrust2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[study fasta]:file:_files -g "*.fa *.fasta *.fna"' \
        '--study_fasta=+[file]:file:_files -g "*.fa *.fasta *.fna"' \
        '-i+[input biom/tsv]:file:_files -g "*.biom *.tsv *.txt"' \
        '--input=+[file]:file:_files -g "*.biom *.tsv *.txt"' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '--ref_dir=+[dir]:dir:_files -/' \
        '-r+[ref hierarchy]:dir:_files -/' \
        '-p+[processes]:n:' \
        '--processes=+[N]:n:' \
        '-t+[placement tool]:t:(epa-ng sepp)' \
        '--placement_tool=+[t]:t:(epa-ng sepp)' \
        '-e+[max NSTI]:str:' \
        '--max_nsti=+[N]:str:' \
        '--no_pathways[skip pathway abundance prediction]' \
        '--regroup_map=+[file]:file:_files' \
        '--remove_intermediate[remove intermediate]' \
        '--stratified[stratified output]' \
        '--no_descriptions[no functional descriptions]' \
        '--per_sequence_contrib[per sequence contributions]' \
        '--coverage[output coverage table]' \
        '--in_traits=+[t]:t:(EC KO COG PFAM TIGRFAM PHENO)' \
        '*::'
}

_picrust2 "$@"
