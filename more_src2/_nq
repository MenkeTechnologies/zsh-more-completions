#compdef nq fq tq
# Documentation: https://github.com/leahneukirchen/nq/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nq queue tools - upstream README documents:
#   nq [-q] [-w] [-t] CMD...   - enqueue (suppress id, wait, test)
# The fq/tq names here are historical aliases kept by the plugin; only
# nq is documented as the canonical binary upstream.

local cmd=${words[1]:t}

case $cmd in
  nq)
    _arguments \
      '-q[suppress job id output]' \
      '-w[wait for jobs to finish]' \
      '-t[test if there are jobs that need waiting]' \
      '*:: :_normal'
    ;;
  fq|tq)
    _arguments \
      '-q[quiet output]' \
      '*:job file:_files -g ",*"'
    ;;
esac
