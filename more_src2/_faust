#compdef faust
# Documentation: https://faustdoc.grame.fr/manual/options/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-v[show version]' \
  '(- *)-version[show version]' \
  '-a+[architecture file]:file:_files -g "*.cpp" -g "*.h"' \
  '-i[inline architecture files]' \
  '-o+[output file]:file:_files' \
  '-A+[architecture dir]:dir:_files -/' \
  '-I+[import dir]:dir:_files -/' \
  '-L+[library file]:file:_files' \
  '-lang+[target language]:lang:(c cpp cmajor codebox csharp dlang fir interp java julia ocpp rust wast wasm cmajor jax llvm jsfx)' \
  '-cn+[class name]:name:' \
  '-fn+[function name]:name:' \
  '-uim[user interface macros]' \
  '-mcd+[max copy delay]:n:' \
  '-mdd+[max delay length]:n:' \
  '-mds+[max ds size]:n:' \
  '-mts[mathematical typestyle]' \
  '-mdoc[generate mathdoc]' \
  '-mdlang+[mathdoc language]:lang:' \
  '-stripdoc[strip doc tags]' \
  '-flist[list source files]' \
  '-norm[normalize]' \
  '-O+[optimization]:level:(0 1 2 3)' \
  '-vec[vector code generation]' \
  '-sch[schedule mode]' \
  '-omp[OpenMP]' \
  '-pl[parallel]' \
  '-d[debug]' \
  '-tg[task graph]' \
  '-sg[signal graph]' \
  '-lb[list dsp blocks]' \
  '-svg[generate SVG]' \
  '-xml[generate XML]' \
  '-json[generate JSON]' \
  '-blur[block diagram]' \
  '*:faust source:_files -g "*.dsp"' && ret=0

return ret
