#compdef genisoimage
# Documentation: man genisoimage(1)
# Source: Distrotech/cdrkit genisoimage/genisoimage.c (master) — ISO 9660 image generator (C, ld_options).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '-abstract+[abstract filename]:file:_files' \
    '(-A --appid)'{-A+,--appid=}'[application id]:appid:_default' \
    '-biblio+[bibliographic filename]:file:_files' \
    '-cache-inodes[cache inode info]' \
    '-no-cache-inodes[disable inode caching]' \
    '-check-oldnames[check 31-char ISO9660 names]' \
    '-check-session+[check session number]:session:_default' \
    '-copyright+[copyright filename]:file:_files' \
    '-debug[show debug output]' \
    '(-b --eltorito-boot)'{-b+,--eltorito-boot=}'[El Torito boot image]:file:_files' \
    '-eltorito-alt-boot[next entry on El Torito catalog]' \
    '(-B --sparc-boot)'{-B+,--sparc-boot=}'[SPARC boot image]:file:_files' \
    '(-G --generic-boot)'{-G+,--generic-boot=}'[generic boot image]:file:_files' \
    '(-c --eltorito-catalog)'{-c+,--eltorito-catalog=}'[El Torito catalog filename]:catalog:_default' \
    '(-C --cdrecord-params)'{-C+,--cdrecord-params=}'[cdrecord -msinfo params]:lba1,lba2:_default' \
    '(-d --omit-period)'{-d,--omit-period}'[omit trailing period from filenames]' \
    '-dir-mode+[mode of all directories]:mode:_default' \
    '(-D --disable-deep-relocation)'{-D,--disable-deep-relocation}'[no Rock Ridge directory relocation]' \
    '-file-mode+[mode of all plain files]:mode:_default' \
    '(-f --follow-links)'{-f,--follow-links}'[follow symlinks]' \
    '-gid+[group owner of files]:gid:_default' \
    '-uid+[user owner of files]:uid:_default' \
    '-graft-points[allow graft-points]' \
    '-root+[relocate root]:dir:_files -/' \
    '-old-root+[old relocation root]:dir:_files -/' \
    '*-hide+[hide entry from ISO9660 tree]:glob:_default' \
    '-hide-list+[hide list file]:file:_files' \
    '*-hidden+[set hidden attribute]:glob:_default' \
    '-hidden-list+[hidden list file]:file:_files' \
    '*-hide-joliet+[hide from Joliet tree]:glob:_default' \
    '-hide-joliet-list+[Joliet hide list]:file:_files' \
    '-hide-joliet-trans-tbl[do not show TRANS.TBL in Joliet tree]' \
    '-hide-rr-moved[hide RR_MOVED directory]' \
    '-gui[GUI mode]' \
    '-input-charset+[input charset]:charset:_default' \
    '-output-charset+[output charset]:charset:_default' \
    '-iso-level+[ISO 9660 level]:level:(1 2 3 4)' \
    '(-J --joliet)'{-J,--joliet}'[Joliet directory extensions]' \
    '-joliet-long[allow 103-byte Joliet filenames]' \
    '-jcharset+[Joliet charset]:charset:_default' \
    '-allow-limited-size[allow files larger than 4GB]' \
    '(-L --allow-leading-dots)'{-L,--allow-leading-dots}'[allow leading dots]' \
    '-log-file+[log file]:file:_files' \
    '*'{-m+,--exclude=}'[exclude pattern]:glob:_default' \
    '-exclude-list+[exclude list file]:file:_files' \
    '-pad[pad image to 32k]' \
    '-no-pad[disable padding]' \
    '(-M --prev-session)'{-M+,--prev-session=}'[previous session info]:device:_files' \
    '(-N --omit-version-number)'{-N,--omit-version-number}'[omit version number]' \
    '-new-dir-mode+[mode for new dirs]:mode:_default' \
    '-force-rr[force Rock Ridge extensions]' \
    '-no-rr[disable Rock Ridge]' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '-path-list+[path list file]:file:_files' \
    '(-p --preparer)'{-p+,--preparer=}'[image preparer]:string:_default' \
    '-print-size[print expected ISO size and exit]' \
    '(-P --publisher)'{-P+,--publisher=}'[image publisher]:string:_default' \
    '-quiet[run quietly]' \
    '(-r --rational-rock)'{-r,--rational-rock}'[Rock Ridge w/ rationalized perms]' \
    '(-R --rock)'{-R,--rock}'[generate Rock Ridge directory info]' \
    '-sectype+[sector type]:type:_default' \
    '-V+[volume id]:label:_default' \
    '*:directory:_files -/' \
    && ret=0

return ret
