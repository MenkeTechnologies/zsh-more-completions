#compdef opensearch-dashboards osd
# _opensearch-dashboards — OpenSearch Dashboards (AWS fork of Kibana) (OpenSearch Project, Node.js); commander
# upstream: https://github.com/opensearch-project/OpenSearch-Dashboards

_opensearch-dashboards() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.(yml|yaml)"' \
        '-c+[config file]:file:_files -g "*.(yml|yaml)"' \
        '--port=+[server port]:port:' \
        '-p+[server port]:port:' \
        '--host=+[server host]:host:_hosts' \
        '-H+[server host]:host:_hosts' \
        '--log-file=+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--quiet[quiet]' \
        '-Q[quiet]' \
        '--silent[silent]' \
        '-S[silent]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--dev[dev mode]' \
        '--ssl[enable SSL]' \
        '--no-base-path[disable base path]' \
        '--no-watch[disable watch]' \
        '--no-optimizer[disable optimizer]' \
        '--no-base-path-proxy[disable base path proxy]' \
        '--no-cache[no cache]' \
        '--no-dev-config[no dev config]' \
        '--opensearch.hosts=+[opensearch host]:url:_urls' \
        '--opensearch.username=+[opensearch user]:str:_users' \
        '--opensearch.password=+[opensearch password]:str:' \
        '--opensearch.ssl.verificationMode=+[ssl verification mode]:mode:(none certificate full)' \
        '--server.basePath=+[base path]:str:' \
        '--plugin-path=+[plugin path]:dir:_files -/' \
        '*:arg:'
}

_opensearch-dashboards "$@"
