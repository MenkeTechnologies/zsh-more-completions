#compdef fjira
# Documentation: https://github.com/mk-5/fjira
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fjira: cobra-based TUI Jira client by mk-5.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --project)'{-p+,--project=}'[open a specific project directly]:project:' \
  '1:command or issue key:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      'completion:generate shell autocompletion scripts'
      'filters:search using saved Jira filters'
      'jql:execute custom JQL queries'
      'workspace:manage multiple workspace configurations'
      'version:display fjira version'
      'help:show help'
    )
    _describe -t commands 'fjira command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (workspace)
        _arguments \
          '--new=[create a new workspace]:name:' \
          '--edit=[edit an existing workspace]:name:' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
