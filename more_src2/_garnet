#compdef garnet GarnetServer
# _garnet — Microsoft Garnet (RESP-compatible cache-store server in C# / .NET; Redis-protocol drop-in with Tsavorite log-structured storage)
# upstream: https://github.com/microsoft/garnet
# Flags from libs/host/Configuration/Options.cs on tip (CommandLineParser); ~100+ options total — common subset enumerated below.

_garnet() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[server port]:port:' \
        '--bind=[bind addresses (comma-separated)]:list:' \
        '(-m --memory)'{-m+,--memory=}'[total main-log memory in bytes]:size:' \
        '(-p --page)'{-p+,--page=}'[main-log page size in bytes]:size:' \
        '(-s --segment)'{-s+,--segment=}'[main-log on-disk segment size]:size:' \
        '(-i --index)'{-i+,--index=}'[hash index start size in bytes]:size:' \
        '--index-max-size=[hash index max size in bytes]:size:' \
        '--mutable-percent=[percentage of log memory kept mutable]:n:' \
        '--readcache[enable read cache]' \
        '--readcache-memory=[read cache memory in bytes]:size:' \
        '--storage-tier[enable storage tiering of records to disk]' \
        '--logdir=[storage directory for the hybrid log]:dir:_files -/' \
        '(-c --checkpointdir)'{-c+,--checkpointdir=}'[checkpoint directory]:dir:_files -/' \
        '(-r --recover)'{-r,--recover}'[recover from latest checkpoint + log on startup]' \
        '--no-pubsub[disable pub/sub]' \
        '--no-obj[disable object data structures]' \
        '--cluster[enable cluster mode]' \
        '--clean-cluster-config[start with a clean cluster config]' \
        '--cluster-announce-port=[announced cluster port]:port:' \
        '--cluster-announce-ip=[announced cluster IP]:ip:' \
        '--cluster-announce-hostname=[announced cluster hostname]:host:_hosts' \
        '--cluster-username=[intra-cluster auth username]:user:' \
        '--cluster-password=[intra-cluster auth password]:pwd:' \
        '--cluster-timeout=[cluster node timeout in seconds]:sec:' \
        '--gossip-sp=[percent of nodes to gossip with per iteration]:n:' \
        '--auth=[authentication mode]:mode:(NoAuth Password Aad Acl AclWithAad)' \
        '--password=[password for Password auth]:pwd:' \
        '--acl-file=[external ACL user file]:file:_files' \
        '--aad-authority=[AAD authority URL]:url:_urls' \
        '--aad-audiences=[AAD audiences (comma-separated)]:list:' \
        '--aad-issuers=[AAD issuers (comma-separated)]:list:' \
        '--tls[enable TLS]' \
        '--cert-file-name=[TLS cert file]:file:_files' \
        '--cert-subject-name=[TLS cert subject name]:cn:' \
        '--client-certificate-required[require client TLS cert]' \
        '--issuer-certificate-path=[issuer cert file]:file:_files' \
        '--aof-enable[enable AOF logging]' \
        '--aof-commit-freq=[AOF commit frequency (ms)]:ms:' \
        '--aof-commit-wait[wait for AOF flush before replying]' \
        '--aof-replay-task-count=[AOF replay tasks per replica sublog]:n:' \
        '--latency-monitor[track event latencies]' \
        '--slowlog-max-len=[slowlog entry retention count]:n:' \
        '--metrics-sampling-freq=[metrics sampling frequency (sec, 0=off)]:sec:' \
        '(-q --quiet)'{-q,--quiet}'[suppress server version + ASCII banner]' \
        '--logger-level=[logging level]:level:(Trace Debug Information Warning Error Critical None)' \
        '--disable-console-logger[disable console logger]' \
        '--file-logger=[write logger output to file]:file:_files' \
        '--minthreads=[min worker threads]:n:' \
        '--maxthreads=[max worker threads]:n:' \
        '--miniothreads=[min IO completion threads]:n:' \
        '--maxiothreads=[max IO completion threads]:n:' \
        '--network-connection-limit=[max concurrent connections]:n:' \
        '--use-azure-storage[use Azure Page Blobs for storage]' \
        '--storage-service-uri=[Azure Blobs storage URI]:url:_urls' \
        '--storage-string=[Azure Blobs connection string]:str:' \
        '--enable-debug-command=[allow DEBUG]:scope:(no local all)' \
        '--enable-module-command=[allow MODULE]:scope:(no local all)' \
        '--protected-mode[enable protected mode]' \
        '*--loadmodulecs=[module to load (repeatable)]:file:_files' \
        '*--extension-bin-paths=[allowed module-load directory (repeatable)]:dir:_files -/' \
        '--unixsocket=[unix socket path to bind]:file:_files' \
        '--max-databases=[max logical databases]:n:' \
        '--lua[enable Lua scripts]' \
        '--lua-memory-management-mode=[Lua memory mode]:mode:(Default Tracked Managed)' \
        '--lua-script-memory-limit=[Lua script memory limit]:size:' \
        '--config-import-path=[import config from this path on startup]:file:_files' \
        '--config-export-path=[export effective config to this path on startup]:file:_files'
}

_garnet "$@"
