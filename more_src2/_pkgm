#compdef pkgm
# _pkgm — install pkgx packages into /usr/local (pkgxdev/pkgm)
# upstream: https://github.com/pkgxdev/pkgm
# Subcommands from pkgm.ts (Deno parseArgs switch).

_pkgm() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-p --pin)'{-p,--pin}'[pin installed packages to the resolved version]' \
        '1: :_pkgm_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                install|i|local-install|li|stub|shim|uninstall|rm|up|update|upgrade|pin|outdated)
                    _arguments '*:package:' && ret=0 ;;
                list|ls) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pkgm_commands] )) ||
_pkgm_commands() {
    local -a commands
    commands=(
        'install:install pkgx packages to /usr/local'
        'i:alias of install'
        'local-install:install pkgx packages under ~/.local'
        'li:alias of local-install'
        'stub:install shim stubs for pkgx packages'
        'shim:alias of stub'
        'uninstall:uninstall pkgx packages'
        'rm:alias of uninstall'
        'list:list installed pkgm packages'
        'ls:alias of list'
        'up:update installed packages (alias of update / upgrade)'
        'update:update installed packages'
        'upgrade:upgrade installed packages (alias of update)'
        'pin:pin a package to the currently installed version'
        'outdated:list installed packages with newer versions available'
    )
    _describe -t commands 'pkgm command' commands
}

_pkgm "$@"
