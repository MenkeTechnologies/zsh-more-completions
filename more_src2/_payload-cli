#compdef payload-cli
# _payload-cli — James Mikrut Payload TypeScript headless CMS CLI alias (payloadcms team, TypeScript); commander
# upstream: https://github.com/payloadcms/payload

_payload-cli() {
    local -a sub=(
        'build:build admin and config'
        'dev:start dev server'
        'generate:types:generate ts types'
        'generate:graphqlschema:generate graphql schema'
        'generate:importmap:generate import map'
        'migrate:run migrations'
        'migrate:create:create migration'
        'migrate:down:rollback migration'
        'migrate:status:show migration status'
        'migrate:refresh:refresh migrations'
        'migrate:reset:reset migrations'
        'migrate:fresh:fresh migrate'
        'create:create payload app'
        'login:login'
        'logout:logout'
        'info:show env info'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "payload.config.{js,ts,mjs,cjs}"' \
        '-c+[config file]:file:_files -g "payload.config.{js,ts,mjs,cjs}"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'payload subcommand' sub ;;
        args)
            case $words[1] in
                dev) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--watch[watch mode]' ;;
                migrate:create) _arguments \
                    '1:name:' \
                    '--skip-empty[skip empty]' \
                    '--force-accept-warning[force]' ;;
                migrate|migrate:down|migrate:refresh|migrate:reset|migrate:fresh) _arguments \
                    '--name=+[migration name]:str:' \
                    '--force-accept-warning[force]' ;;
                generate:types|generate:graphqlschema|generate:importmap) ;;
                create) _arguments \
                    '1:project name:' \
                    '-t+[template]:t:(blank website ecommerce)' \
                    '--template=+[template]:t:(blank website ecommerce)' \
                    '--db=+[db adapter]:db:(mongodb postgres sqlite)' \
                    '--use-npm[use npm]' \
                    '--use-pnpm[use pnpm]' \
                    '--use-yarn[use yarn]' \
                    '--use-bun[use bun]' \
                    '--no-deps[skip install]' \
                    '--secret=+[payload secret]:str:' ;;
            esac
            ;;
    esac
}

_payload-cli "$@"
