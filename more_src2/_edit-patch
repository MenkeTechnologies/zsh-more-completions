#compdef edit-patch add-patch
# Documentation: https://manpages.debian.org/edit-patch
# Source: debian/devscripts scripts/edit-patch.sh — add/edit quilt patches (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:patch name:_files -g "*.patch"' \
    && ret=0

return ret
