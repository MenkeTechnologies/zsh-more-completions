# nhedger/gh-clean-forks - gh extension for cleaning forked repos.

_gh-clean-forks() {
    _arguments \
        '--dry-run[preview changes without deleting]' \
        '--force[delete all forks, including those with open PRs]' \
        '--help[show help]'
}

_gh-clean-forks "$@"
