#compdef dch debchange
# Documentation: https://manpages.debian.org/dch
# Source: debian/devscripts scripts/debchange.pl — Debian changelog editor (Perl, Getopt::Long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    {-i,--increment}'[increment version (default if no other action)]' \
    {-a,--append}'[append entry to current changelog version]' \
    {-e,--edit}'[edit changelog in editor]' \
    {-r,--release}'[release the package]' \
    '--create[create a new changelog]' \
    '--package=-[package name (with --create)]:package:_default' \
    {-v+,--newversion=}'[new version]:version:_default' \
    {-b,--force-bad-version}'[force bad version number]' \
    '--allow-lower-version=-[allow lower version matching pattern]:pattern:_default' \
    '--force-distribution[force distribution name even if not standard]' \
    {-d,--fromdirname}'[derive version from parent dir name]' \
    '-p[preserve dir/file name]' \
    '(--no-preserve)--preserve[preserve dir/file name]' \
    '--no-preserve[do not preserve]' \
    {-D+,--distribution=}'[distribution]:dist:(unstable testing stable oldstable experimental UNRELEASED)' \
    {-u+,--urgency=}'[urgency]:urgency:(low medium high emergency critical)' \
    {-n,--nmu}'[non-maintainer upload]' \
    '--bin-nmu[binary-only NMU]' \
    {-q,--qa}'[QA upload]' \
    {-R,--rebuild}'[no-change rebuild upload]' \
    {-s,--security}'[security upload]' \
    '--team[team upload]' \
    {-U,--upstream}'[upstream release]' \
    '--bpo[backport upload]' \
    '--sloppy[force a less-strict mode]' \
    '--lts[LTS upload]' \
    '--stable[stable upload]' \
    {-l+,--local=}'[local suffix]:suffix:_default' \
    '(--no-query)--query[query bug database]' \
    '--no-query[do not query bug database]' \
    '*--closes=-[close bug number(s)]:bugs:_default' \
    {-c+,--changelog=}'[changelog file]:file:_files' \
    '--news=-[edit NEWS file]::file:_files' \
    '(--no-multimaint)--multimaint[group entries by maintainer]' \
    '--no-multimaint[do not group entries]' \
    '(--no-multimaint-merge)--multimaint-merge[merge changes by same maintainer]' \
    '--no-multimaint-merge[do not merge changes]' \
    {-m,--maintmaint}'[do not change maintainer]' \
    {-M,--controlmaint}'[use maintainer from debian/control]' \
    {-t,--mainttrailer}'[do not change trailer]' \
    '--check-dirname-level=-[directory check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory regex]:regex:_default' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '--release-heuristic=-[release detection heuristic]:heur:(log changelog)' \
    '--empty[add empty changelog entry]' \
    '(--no-auto-nmu)--auto-nmu[automatic NMU detection]' \
    '--no-auto-nmu[disable auto-NMU detection]' \
    '(--no-force-save-on-release)--force-save-on-release[force save on release]' \
    '--no-force-save-on-release[do not force save]' \
    '--vendor=-[vendor name]:vendor:_default' \
    '*:changelog text:_default' \
    && ret=0

return ret
