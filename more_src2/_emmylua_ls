#compdef emmylua_ls
# Documentation: https://github.com/EmmyLuaLs/emmylua-analyzer-rust
# Reference accessed: 2026-05-16
# Verified: EmmyLuaLs/emmylua-analyzer-rust README CLI section.
# This is the Rust implementation (not the Node language server).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --stdio/--node-ipc/--socket/--pipe/--clientProcessId
# (those are Node LSP transports — Rust emmylua_ls uses
# -c/--communication stdio|tcp).

# emmylua_ls: Lua language server (Rust impl)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --communication)'{-c+,--communication=}'[transport]:mode:(stdio tcp)' \
  '--port=[TCP port (default 5007)]:port:' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--log-path=[log directory]:dir:_files -/' && ret=0
return ret
