#compdef gotator

local curcontext="$curcontext" state line ret=1

_arguments \
  '-sub[file with subdomains]:subdomains file:_files' \
  '-perm[file with permutations]:permutation file:_files' \
  '-depth[permutation depth (1-3)]:depth:(1 2 3)' \
  '-numbers[append numbers range]:range' \
  '-prefixes[prefixes to use]:prefixes' \
  '-suffixes[suffixes to use]:suffixes' \
  '-mindup[minimum duplicates to keep]:count' \
  '-md[remove duplicates]' \
  '-adv[enable advanced mode]' \
  '-t[number of threads]:threads' \
  '-silent[suppress output]' \
  '-fast[enable fast mode]' \
  && ret=0

return ret
