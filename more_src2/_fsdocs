#compdef fsdocs
# Documentation: https://github.com/fsprojects/FSharp.Formatting/tree/main/src/fsdocs-tool
# Reference accessed: 2026-05-27
# Verified: upstream Program.fs verb list and BuildCommand.fs / InitCommand.fs
# `Option` attribute declarations in fsprojects/FSharp.Formatting.

local curcontext="$curcontext" state line ret=1

local -a _fsdocs_subcommands
_fsdocs_subcommands=(
  'build:build documentation for a solution based on content and defaults'
  'watch:build the documentation, watch for changes and serve it'
  'init:initialize a docs folder with a default index.md (and optional _template.html)'
  'convert:convert a single .md/.fsx/.ipynb document without building a full site'
)

local -a _fsdocs_build_opts
_fsdocs_build_opts=(
  '--input=[input directory of documentation content]:dir:_files -/'
  '*--projects=[project files to build API docs for]:project:_files -g "*.*proj"'
  '--output=[output folder]:dir:_files -/'
  '--noapidocs[disable generation of API docs]'
  '--ignoreuncategorized[disable generation of "Other" category for uncategorized docs]'
  '--ignoreprojects[disable project cracking]'
  '--strict[fail if there is a problem generating docs]'
  '--eval[evaluate F# fragments in scripts]'
  '--qualify[qualify API doc output by collection name]'
  '--saveimages=[save referenced images]:mode:(some none all)'
  '--sourcefolder=[source folder at time of component build]:dir:_files -/'
  '--sourcerepo=[source repository URL for GitHub links]:url:'
  '--linenumbers[add line numbers]'
  '--nonpublic[also generate documentation for non-public members]'
  '--mdcomments[assume /// comments in F# code are markdown style]'
  '*--parameters=[additional substitution parameters: key1 value1 key2 value2]:kv:'
  '--nodefaultcontent[do not copy default content/templates]'
  '*--properties=[properties to dotnet msbuild, e.g. Configuration=Release]:property:'
  '*--fscoptions=[extra flags for F# compiler analysis]:fsc-opt:'
  '--clean[clean the output directory]'
)

local -a _fsdocs_watch_extra_opts
_fsdocs_watch_extra_opts=(
  '--noserver[do not serve content when watching]'
  '--nolaunch[do not launch a browser window]'
  '--open=[URL extension to launch http://localhost:<port>/<ext>]:url-ext:'
  '--port=[port to serve content for http://localhost serving]:port:'
  '--root=[override the root URL for generated pages]:url:'
)

local -a _fsdocs_convert_opts
_fsdocs_convert_opts=(
  '(-o --output)'{-o+,--output=}'[output file path]:file:_files'
  '--template=[path to HTML template file, or "fsdocs"]:template:_files'
  '--outputformat=[output format]:format:(html ipynb latex fsx markdown)'
  '--eval[evaluate F# fragments in scripts]'
  '--linenumbers[add line numbers]'
  '*--parameters=[additional substitution parameters]:kv:'
  '--no-embed-resources[disable automatic inlining of local CSS/JS/images]'
)

local -a _fsdocs_init_opts
_fsdocs_init_opts=(
  '--input=[directory to initialize (default: docs)]:dir:_files -/'
  '--force[overwrite existing files]'
  '--with-template[also scaffold a _template.html file]'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'fsdocs subcommand' _fsdocs_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments $_fsdocs_build_opts \
          '*:input:_files' && ret=0
        ;;
      watch)
        _arguments $_fsdocs_build_opts $_fsdocs_watch_extra_opts \
          '*:input:_files' && ret=0
        ;;
      convert)
        _arguments $_fsdocs_convert_opts \
          '*:input:_files -g "*.(md|fsx|ipynb)"' && ret=0
        ;;
      init)
        _arguments $_fsdocs_init_opts && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
