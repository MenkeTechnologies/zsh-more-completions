_oxyromon() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_oxyromon_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                import-roms)
                    _arguments \
                        '(-s --system)'{-s,--system}'=[select system by name]:system:' \
                        '*:ROM file or directory:_files' && ret=0 ;;
                convert-roms)
                    _arguments \
                        '(-f --format)'{-f,--format}'=[destination format]:format:(zip 7z chd cso rvz nsz xso zso original)' \
                        '*'{-g,--game}'=[select games by name (repeatable)]:game:' && ret=0 ;;
                import-dats|import-irds|import-patches)
                    _arguments '*:DAT/IRD/patch file:_files' && ret=0 ;;
                info|config|create-dats|download-dats|purge-irds|sort-roms|export-roms|rebuild-roms|check-roms|purge-roms|purge-systems|generate-playlists|benchmark|server)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_oxyromon_commands] )) ||
_oxyromon_commands() {
    local -a commands
    commands=(
        'info:print system information'
        'config:manage the oxyromon config'
        'create-dats:create custom DAT files from a ROM directory'
        'import-dats:import DAT files into the database'
        'download-dats:download DAT files from No-Intro / Redump / TOSEC'
        'import-irds:import IRD (PS3 ISO Rebuild Data) files'
        'import-patches:import xdelta / BPS / IPS / UPS / PPF patch files'
        'import-roms:validate and import ROM files or directories'
        'purge-irds:purge IRDs not associated with any game'
        'sort-roms:sort ROMs into per-system directory layout'
        'convert-roms:convert ROM files between common formats'
        'export-roms:export ROMs to a generic directory structure'
        'rebuild-roms:rebuild ROMs from raw files via checksum matching'
        'check-roms:verify checksums for imported ROMs'
        'purge-roms:remove ROMs from the database + trash directory'
        'purge-systems:remove systems and all associated ROMs'
        'generate-playlists:generate per-system .m3u playlists for emulator frontends'
        'benchmark:benchmark disk + decompression against the configured ROM set'
        'server:start the async-graphql HTTP server (feature: server)'
    )
    _describe -t commands 'oxyromon command' commands
}

_oxyromon "$@"
