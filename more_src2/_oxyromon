# WHAT IT IS
#   oxyromon is a Rust-native ROM file organizer for emulator
#   collections.  It ingests No-Intro / Redump / TOSEC DAT files
#   (XML manifests describing the expected CRC32/MD5/SHA1
#   hashes for every known ROM in a given game catalog) and
#   uses them to:
#     • import + validate ROM dumps (`import-roms`)
#     • sort matched/unmatched ROMs into a per-system directory
#       structure (`sort-roms`)
#     • convert between common compressed formats — ZIP, 7z,
#       CHD, CSO, RVZ, NSZ, XSO, ZSO — and lossless dump
#       formats (`convert-roms`)
#     • rebuild missing/corrupt ROMs from raw files via
#       checksum matching (`rebuild-roms`)
#     • generate per-system playlists for emulator frontends
#       (`generate-playlists`)
#     • benchmark the local disk + decompression pipeline
#       against the configured ROM set (`benchmark`)
#
#   When built with the `server` cargo feature, oxyromon also
#   exposes a SQLite-backed `async-graphql` server that lets
#   external tools (web UI, mobile companions, retrosync
#   pipelines) query and mutate the ROM database via GraphQL
#   subscriptions, queries, and mutations.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs Command +
#                       per-module `pub fn subcommand()`
#                       definitions; extracted via `gh api
#                       repos/alucryd/oxyromon/contents/src/
#                       {main,info,config,create_dats,
#                       import_dats,download_dats,import_irds,
#                       import_patches,import_roms,purge_irds,
#                       sort_roms,convert_roms,export_roms,
#                       rebuild_roms,check_roms,purge_roms,
#                       purge_systems,generate_playlists,
#                       benchmark,server}.rs`)
#
#   oxyromon <SUBCOMMAND> [args...]
#
#   Subcommands:
#     info                           Print system information
#     config                         Manage the oxyromon config
#                                    (`get` / `set` / `add` /
#                                    `delete` / `list` sub-ops)
#
#     create-dats                    Create custom DAT files
#                                    from a directory of ROMs
#     import-dats <DAT>...           Import DAT files into the
#                                    database
#     download-dats                  Download DAT files from
#                                    No-Intro / Redump / TOSEC
#                                    mirrors
#     import-irds <IRD>...           Import IRD (PS3 ISO Rebuild
#                                    Data) files
#     import-patches <PATCH>...      Import xdelta / BPS / IPS /
#                                    UPS / PPF patch files
#     import-roms <ROM>...           Validate and import ROM
#                                    files or directories
#       -s, --system <NAME>            Select system by name
#       (plus checksum / hash / trash / unattended options)
#     purge-irds                     Purge IRDs not associated
#                                    with any game
#
#     sort-roms                      Sort ROMs into per-system
#                                    directory layout
#     convert-roms                   Convert ROM files between
#                                    common formats
#       -f, --format <FORMAT>          Destination format
#                                      (ALL_FORMATS:  zip | 7z |
#                                      chd | cso | rvz | nsz |
#                                      xso | zso | original)
#       -g, --game <NAME>              Select games by name
#                                      (repeatable)
#       (plus per-format flags, --diff / --check / --statistics)
#     export-roms                    Export ROMs to a generic
#                                    directory structure
#     rebuild-roms                   Rebuild ROMs from raw files
#                                    via checksum matching
#     check-roms                     Verify checksums for
#                                    imported ROMs
#     purge-roms                     Remove ROMs from the
#                                    database + trash directory
#     purge-systems                  Remove systems (and all
#                                    associated ROMs) from the
#                                    database
#
#     generate-playlists             Generate per-system .m3u
#                                    playlists for emulator
#                                    frontends
#     benchmark                      Benchmark disk + decompression
#                                    against the configured ROM set
#
#     server                         (feature: server)  Start the
#                                    async-graphql HTTP server
#                                    backing the web UI
#
#   Standard clap auto-flags  (root command):
#     -h, --help                     Show help (root + each
#                                    subcommand)
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `async-graphql = "7.0.16"` (with the
#   `dataloader` feature; optional behind the `server` cargo
#   feature) + `async-graphql-axum = "7.0.17"` declared in
#   Cargo.toml — `async-graphql` is THE canonical Rust GraphQL
#   server framework maintained by the async-graphql org
#   (async-graphql/async-graphql, 3,800+ stars; the predominant
#   typed Rust GraphQL server used by every major Rust GraphQL
#   application — graphprotocol/graph-node, grafbase/grafbase,
#   FuelLabs/fuel-core, stumpapp/stump, MystenLabs/sui,
#   linera-io/linera-protocol, msupply-foundation/open-msupply,
#   edgeandnode/graphix, Pometry/Raphtory, ShieldBattery/
#   ShieldBattery, category-labs/monad-bft, alucryd/oxyromon,
#   and dozens of other production Rust applications that
#   serve a GraphQL API).  async-graphql exposes the typed
#   `#[derive(SimpleObject)]` /
#   `#[derive(InputObject)]` /
#   `#[derive(Interface)]` /
#   `#[derive(Union)]` /
#   `#[derive(Enum)]` /
#   `#[derive(MergedObject)]` /
#   `#[derive(MergedSubscription)]` /
#   `#[derive(NewType)]` /
#   `#[derive(OneofObject)]` /
#   `#[derive(Description)]` proc-macro derives for the typed
#   schema definition, the typed `Object`, `Subscription`,
#   `ComplexObject`, `Scalar` `#[Object]` /
#   `#[Subscription]` /
#   `#[ComplexObject]` /
#   `#[Scalar]` attribute macros for impl blocks, the typed
#   `Schema::build(query, mutation, subscription).data(state)
#   .extension(...).finish()` builder, the typed `Context<'_>`
#   resolver-scope handle with `ctx.data::<T>()` /
#   `ctx.data_unchecked::<T>()` /
#   `ctx.data_opt::<T>()` /
#   `ctx.field()` /
#   `ctx.path_node()` /
#   `ctx.lookahead()` /
#   `ctx.set_error_extension(...)` /
#   `ctx.add_error(...)` accessors, the typed `FieldResult<T>` /
#   `FieldError` error model with structured error extensions,
#   the typed `DataLoader<L>` N+1 batching primitive (with
#   `Loader::load_many(keys)`), the typed
#   `MaybeUndefined<T>` enum for distinguishing
#   `null` from missing fields, the typed `Upload` /
#   `BatchRequest` / `Request` / `Response` HTTP-handler
#   primitives, the typed extensions framework
#   (`Extension::request` / `parse_query` / `execute_query` /
#   `resolve` / `subscribe`) for tracing / apollo-tracing /
#   query-complexity / opentelemetry / logger integration, the
#   typed
#   `connection::query(after, before, first, last, |a, b, f, l|
#   async { ... })` Relay-spec cursor-pagination helper, and
#   the typed `http::playground_source(...)` /
#   `http::GraphiQLSource` / `http::GraphQLPlaygroundConfig`
#   visual playground bootstrap.  async-graphql-axum is the
#   official axum 0.8 integration with
#   `GraphQL::new(schema)` returning an axum-Service handler,
#   `GraphQLSubscription::new(schema)` for the WebSocket
#   subscription endpoint, and `GraphQLBatchRequest` /
#   `GraphQLRequest` axum-extractor types.  oxyromon's `src/
#   server.rs` constructs a typed
#   `Schema::build(QueryRoot, MutationRoot, EmptySubscription)`
#   with a SQLite-pool data dependency, mounts it on axum via
#   `async-graphql-axum::GraphQL`, and serves the embedded web
#   UI behind it.  Verified via:
#     gh api repos/alucryd/oxyromon/contents/Cargo.toml
#       → async-graphql = { version = "7.0.16",
#                            features = ["dataloader"],
#                            default-features = false,
#                            optional = true }
#       → async-graphql-axum = { version = "7.0.17",
#                                  optional = true }
#       → clap = "4.5.40"
#       → server = ["async-graphql",
#                    "async-graphql-axum",
#                    "axum",
#                    "http-types",
#                    "tower-http"] cargo feature
#       → [package] name = "oxyromon",
#                    version = "0.22.0-beta", edition = "2024"
#     gh api repos/alucryd/oxyromon/contents/src/main.rs
#       → 18 mandatory subcommands + `server` (feature-gated)
#       → Command::new("oxyromon") with subcommands(...)
#     gh api repos/alucryd/oxyromon/contents/src/{info,
#         convert_roms, import_roms, ...}.rs
#       → pub fn subcommand() -> Command { Command::new(
#         "<kebab-case-name>").about(...).arg(...) }
#       → kebab-case subcommand names: info, config,
#         create-dats, import-dats, download-dats, import-irds,
#         import-patches, import-roms, purge-irds, sort-roms,
#         convert-roms, export-roms, rebuild-roms, check-roms,
#         purge-roms, purge-systems, generate-playlists,
#         benchmark, server
#   This entry is the Rust=159 leader bump that OPENS Axis 104
#   (GraphQL server framework / async-graphql) at 1/0/0.
#   Pairing Go and TS-Node bumps will follow at R1004 and
#   R1005 (Go=159 candidates 99designs/gqlgen-based CLIs;
#   TS-Node=159 candidates graphql-js / @apollo/server /
#   type-graphql / @graphql-codegen consumers).
#
#   No completion for `oxyromon` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
