#compdef pms
# Documentation: https://github.com/ambientsound/pms
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pms - Practical Music Search (MPD client)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[print program version]' \
  '(-d --debug)'{-d,--debug=}'[write debugging info to file]:file:_files' \
  '--host=[MPD host]:host:_hosts' \
  '--port=[MPD port]:port:' \
  '--password=[MPD password]:password:' \
  && ret=0

return ret
