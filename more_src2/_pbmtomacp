#compdef pbmtomacp
# Documentation: man pbmtomacp (Netpbm)
# Source: convert a PBM image to MacPaint format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-left+[left margin in pixels]:n:' \
    '-right+[right margin in pixels]:n:' \
    '-top+[top margin in pixels]:n:' \
    '-bottom+[bottom margin in pixels]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
