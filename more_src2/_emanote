#compdef emanote

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'run:serve development server'
  'gen:generate static site'
)

_arguments -s -S \
  '*--layers[note directories]:note directory:_files -/' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'emanote subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run)
        _arguments -s -S \
          '--host[host to bind to]:host:' \
          '--port[port to listen on]:port:' \
          '--open[open browser automatically]' && ret=0
        ;;
      (gen)
        _arguments -s -S \
          '--dest[output directory]:output directory:_files -/' && ret=0
        ;;
    esac
    ;;
esac

return ret
