#compdef operator-lifecycle-manager olm-cli2
# _operator-lifecycle-manager — Operator Framework operator-lifecycle-manager CLI command-line frontend wrapping the OLM Operator Lifecycle Manager controller providing system OperatorGroup CatalogSource Subscription InstallPlan ClusterServiceVersion CSV install-upgrade-delete dependency-resolver-stable-fast-alpha bundle-package channel manual-approval workflow (Operator Framework team, Go); cobra
# upstream: https://olm.operatorframework.io/

_operator-lifecycle-manager() {
    local -a sub=(
        'install:install OLM'
        'uninstall:uninstall OLM'
        'list-installed:list installed operators'
        'install-operator:install an operator'
        'uninstall-operator:uninstall an operator'
        'upgrade-operator:upgrade an installed operator'
        'pause-operator:pause an installed operator'
        'unpause-operator:unpause an installed operator'
        'channels:list available channels for a package'
        'catalog:catalog management'
        'subscription:subscription management'
        'installplan:install plan management'
        'csv:CSV management'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '--catalog=+[name]:str:' \
        '--channel=+[name]:str:' \
        '--source-namespace=+[ns]:str:' \
        '--package=+[name]:str:' \
        '--approval=+[a]:a:(Automatic Manual)' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'operator-lifecycle-manager subcommand' sub ;;
        args)
            case $words[1] in
                install-operator|uninstall-operator|upgrade-operator|pause-operator|unpause-operator|channels) _arguments '*:package name:' ;;
                catalog|subscription|installplan|csv) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_operator-lifecycle-manager "$@"
