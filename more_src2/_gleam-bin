#compdef gleam
# _gleam-bin — Gleam type-safe language for the BEAM and JavaScript (Louis Pilfold, Rust); compile/run/test Gleam projects
# upstream: https://github.com/gleam-lang/gleam

_gleam-bin() {
    local -a sub=(
        'add:add dependency'
        'build:build project'
        'check:type-check'
        'clean:clean build artifacts'
        'compile-package:compile single package'
        'completion:print shell completion'
        'deps:dependency commands'
        'docs:generate docs'
        'export:export build artifacts'
        'fix:apply automated fixes'
        'format:format code'
        'help:show help'
        'hex:hex commands'
        'lsp:run language server'
        'new:create new project'
        'publish:publish package'
        'remove:remove dependency'
        'run:run main module'
        'shell:start interactive shell'
        'test:run tests'
        'update:update deps'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gleam subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '--name+[project name]:str:' \
                    '--description+[description]:str:' \
                    '--template+[template]:template:(lib)' \
                    '--skip-git[skip git init]' \
                    '--skip-github[skip github actions]' \
                    '*:dir:_files -/' ;;
                run|test) _arguments \
                    '--target+[target]:target:(erlang javascript)' \
                    '-t+[target]:target:(erlang javascript)' \
                    '--runtime+[js runtime]:runtime:(node deno bun)' \
                    '-r+[js runtime]:runtime:(node deno bun)' \
                    '--module+[module to run]:module:' \
                    '-m+[module to run]:module:' \
                    '--no-print-progress[no progress]' ;;
                build) _arguments \
                    '--warnings-as-errors[warnings as errors]' \
                    '--target+[target]:target:(erlang javascript)' \
                    '-t+[target]:target:(erlang javascript)' \
                    '--no-print-progress[no progress]' ;;
                format) _arguments \
                    '--check[check only]' \
                    '--stdin[read stdin]' \
                    '*:file:_files -g "*.gleam"' ;;
                add|remove) _arguments \
                    '--dev[dev deps]' \
                    '*:package:' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish)' ;;
            esac
            ;;
    esac
}

_gleam-bin "$@"
