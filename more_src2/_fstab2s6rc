#compdef fstab2s6rc rngseed s6-chroot s6-freeramdisk s6-hostname s6-logwatch s6-mount s6-pivotchroot s6-ps s6-swapoff s6-swapon s6-umount
# Documentation: source-direct extraction from upstream
# skarnet/s6-linux-utils src/s6-linux-utils/*.c USAGE strings +
# subgetopt_r option-string specs + skalibs GOL_main gol_bool +
# gol_arg tables + case-arm decoding for the mutex flag groups
# (rngseed: -r/-R credentialed-vs-uncredentialed entropy reads,
# -n/-N blocking-vs-nonblocking, -w/-W credentialed-vs-uncredentialed
# entropy writes; fstab2s6rc: -A/-a noauto-include xor noauto-exclude,
# -U/-u uuid-omit xor uuid-include, -E/-e essential-xor-not).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet s6-linux-utils R125 — 12-stem multi-binary harvest of the
# Linux-specific system-administration utilities that compose with
# the s6 init+supervision stack (R117-R124). Filename uses the
# alphabetically-first stem `fstab2s6rc` since `f` < `r` < `s`.

case $service in

  fstab2s6rc)
    # Generate an s6-rc compiled-db source tree from /etc/fstab
    # entries (one s6-rc service per fstab mountpoint).
    _arguments -s -S \
      '(-A --include-noauto -a --exclude-noauto)'{-A,--include-noauto}'[include fstab entries marked "noauto"]' \
      '(-A --include-noauto -a --exclude-noauto)'{-a,--exclude-noauto}'[exclude fstab entries marked "noauto"]' \
      '(-U --without-uuid -u --with-uuid)'{-U,--without-uuid}'[use plain device paths (do NOT emit UUID= lookups)]' \
      '(-U --without-uuid -u --with-uuid)'{-u,--with-uuid}'[emit UUID= lookups for filesystems that have one]' \
      '(-E --essential -e --not-essential)'{-E,--essential}'[mark generated services essential (failure halts boot)]' \
      '(-E --essential -e --not-essential)'{-e,--not-essential}'[mark generated services non-essential]' \
      '(-F --fstab)'{-F+,--fstab=}'[alternative fstab file (default /etc/fstab)]:fstab:_files' \
      '(-m --mode)'{-m+,--mode=}'[octal permissions on output service-dirs (default 0755)]:mode (octal):' \
      '(-B --bundle)'{-B+,--bundle=}'[s6-rc bundle name to group all mounts under]:bundle:' \
      '(-d --base-dependency)'{-d+,--base-dependency=}'[s6-rc base-dependency the mounts wait on]:service:' \
      '1:output s6-rc compiled-db source directory:_directories'
    ;;

  rngseed)
    # Maintain the kernel CSPRNG seed across reboots: at boot, read
    # the saved seed and inject it via the RNDADDENTROPY ioctl; at
    # shutdown, save a fresh seed for next boot.
    _arguments -s -S \
      '-d+[seed directory (default /var/lib/rngseed)]:seeddir:_directories' \
      '-v+[verbosity level]:level:' \
      '(-R)-r[READ the saved seed AND credit it as authoritative entropy]' \
      '(-r)-R[READ the saved seed WITHOUT crediting it as entropy]' \
      '(-N)-n[do NOT block waiting for entropy on read]' \
      '(-n)-N[BLOCK on read until enough entropy is available]' \
      '(-W)-w[WRITE a fresh seed file using credited entropy]' \
      '(-w)-W[WRITE a fresh seed file using UNcredited entropy]'
    ;;

  s6-chroot)
    # Like chroot(8): change root to dir, then chain-load prog.
    # Minimalist; no -u/-g/-G or shell selection.
    _arguments -s -S \
      '1:new root directory:_directories' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-freeramdisk)
    # Free a Linux ramdisk device (calls BLKFLSBUF + ioctl).
    _arguments -s -S \
      '1:ramdisk device:_files -g "/dev/ram*"'
    ;;

  s6-hostname)
    # Print or set the kernel hostname (sethostname(2) / gethostname).
    # With no arg: print current hostname. With arg: set hostname.
    _arguments -s -S \
      '1:new hostname (omit to print current):_hosts'
    ;;

  s6-logwatch)
    # Tail a directory of s6-log rotated log files, printing new
    # entries as they arrive. -m caps the size of each individual
    # printed entry.
    _arguments -s -S \
      '-m+[max chars to print per log entry (truncate longer)]:chars:' \
      '1:s6-log directory:_directories'
    ;;

  s6-mount)
    # Static-build-friendly mount(8) replacement. Supports both the
    # mount-all form (-a/-z fstab) and the single-mount form
    # (-t type -o options device mountpoint).
    _arguments -s -S \
      '-n[do NOT update /etc/mtab (no-op kept for util-linux compat)]' \
      '-z+[alternative fstab file (default /etc/fstab; used with -a)]:fstab:_files' \
      '-a[mount-all: process every entry in fstab]' \
      '(-w)-r[mount read-only (sets ro in -o options)]' \
      '(-r)-w[mount read-write (sets rw in -o options; default)]' \
      '-t+[filesystem type]:type:(ext4 ext3 ext2 btrfs xfs zfs f2fs vfat tmpfs proc sysfs devtmpfs cgroup cgroup2 overlay)' \
      '*-o+[comma-separated mount options (repeatable)]:opt1\[,opt2,...\]:' \
      '1:device or source:_files' \
      '2:mountpoint:_directories'
    ;;

  s6-pivotchroot)
    # Atomically swap the root filesystem (Linux pivot_root(2) +
    # chroot), then chain-load prog. Used by s6-linux-init during
    # initramfs handoff.
    _arguments -s -S \
      '1:place inside new-root to receive the old root:_directories' \
      '2:place inside old-root that holds the new root:_directories' \
      '*:program and arguments:_command_names -e'
    ;;

  s6-ps)
    # ps(1) replacement that reads /proc directly. -l selects the
    # built-in long format; -o overrides with a custom field list.
    _arguments -s -S \
      '-H[hierarchical tree mode (indent children under parents)]' \
      '(-l -o)-l[long-list format with default fields]' \
      '(-l -o)-o+[custom field list (comma-separated)]:fields:_values -s , field pid ppid pgid sid uid gid user group tty tpgid stat command args nice pri rtprio policy cputime utime stime start_time vsize rss start ttime' \
      '-w+[column spacing in spaces (default 1)]:spaces:' \
      '-W+[wchan symbol resolution file (default /proc/kallsyms)]:file:_files'
    ;;

  s6-swapoff)
    # swapoff(8): disable swap on the given device, or all entries
    # in /etc/fstab with -a.
    _arguments -s -S \
      '-a[disable swap on every fstab entry marked as swap]' \
      '1:swap device:_files -g "/dev/*"'
    ;;

  s6-swapon)
    # swapon(8): enable swap on the given device, or all entries
    # in /etc/fstab with -a.
    _arguments -s -S \
      '-a[enable swap on every fstab entry marked as swap]' \
      '1:swap device:_files -g "/dev/*"'
    ;;

  s6-umount)
    # umount(8): unmount the given mountpoint, or all in fstab
    # with -a.
    _arguments -s -S \
      '-a[unmount every entry in fstab]' \
      '1:mountpoint or device:_files'
    ;;

esac
