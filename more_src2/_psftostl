#compdef psftostl
# Documentation: https://github.com/dr-yd/psftools
# Reference accessed: 2026-05-20
# Verified: psftools project; psftostl is a positional-argument converter
# (input PSF -> output STL). STUB completion (no flag set).

# psftostl: convert Linux PSF console font to STL (3D printable model)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:input PSF file and output STL:_files -g "*.(psf|psf.gz|stl)"' && ret=0
return ret
