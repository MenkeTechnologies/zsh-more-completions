#compdef gdnsd gdnsdctl
# _gdnsd — Brandon Black gdnsd geographically-aware authoritative DNS server with TCP/UDP listener (gdnsd team, C); custom argparse
# upstream: https://github.com/gdnsd/gdnsd

_gdnsd() {
    local -a sub=(
        'start:start daemon'
        'stop:stop daemon'
        'restart:restart daemon'
        'reload-zones:reload zone files'
        'replace:zero-downtime replace'
        'status:show daemon status'
        'checkconf:validate configuration'
        'check-zones:validate zone files'
        'pid:show pid file'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config directory]:dir:_files -/' \
        '--config-dir=+[config directory]:dir:_files -/' \
        '-D[debug mode]' \
        '--debug[debug mode]' \
        '-f[run in foreground]' \
        '--foreground[run in foreground]' \
        '-x[no syslog]' \
        '--no-syslog[no syslog]' \
        '-l[force replace]' \
        '-i[idempotent mode]' \
        '-s[strict mode]' \
        '-S[strictest mode]' \
        '-R[show running pid only]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gdnsd subcommand' sub ;;
    esac
}

_gdnsd "$@"
