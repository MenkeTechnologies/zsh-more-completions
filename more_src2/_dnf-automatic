#compdef dnf-automatic
# Documentation: https://dnf.readthedocs.io/en/latest/automatic.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--installupdates[install updates]' \
  '--downloadupdates[download updates]' \
  '--timer[run as timer]' \
  '(- *)'{-h,--help}'[show help]' \
  ':config file:_files -g "*.conf"'
