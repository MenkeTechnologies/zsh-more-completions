#compdef gscan2pdf
# Documentation: https://gscan2pdf.sourceforge.net/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gscan2pdf: GUI to scan documents and save as PDF / DjVu / image
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--device=[scanner device]:device:' \
  '--import=[import these files at startup]:file:_files' \
  '--import-all=[import all pages of files]:file:_files' \
  '--log=[log to file]:file:_files' \
  '--debug[set log level to debug]' \
  '--info[set log level to info]' \
  '--warn[set log level to warn]' \
  '--error[set log level to error]' \
  '--fatal[set log level to fatal]' \
  '*:files to import:_files -g "*.(pdf|djvu|tif|tiff|jpg|jpeg|png|pnm|pbm|pgm|ppm|gif)"' && ret=0
return ret
