#compdef nix-eval-jobs
# _nix-eval-jobs — parallel Nix attribute set evaluator (nix-community/nix-eval-jobs)
# upstream: https://github.com/nix-community/nix-eval-jobs
# Flags from src/eval-args.cc (Nix args framework).

_nix-eval-jobs() {
    _arguments \
        '(- *)--help[show help]' \
        '--impure[allow impure expressions]' \
        '--force-recurse[force recursion (ignore recurseIntoAttrs)]' \
        '--gc-roots-dir=[GC roots directory]:dir:_files -/' \
        '--workers=[number of evaluator workers]:n:' \
        '--max-memory-size=[max memory per worker (MB)]:size:' \
        '--flake[treat input as a flake]' \
        '--meta[include derivation meta in output]' \
        '--constituents[evaluate Hydra aggregate constituents]' \
        '--check-cache-status[check cache status in output]' \
        '--show-input-drvs[show input derivations in output]' \
        '--show-trace[show trace on Nix errors]' \
        '--no-instantiate[skip instantiation]' \
        '--expr=[evaluate expression instead of file]:expr:' \
        '--apply=[apply Nix expression to results]:expr:' \
        '--select=[select attributes from output]:expr:' \
        '*--override-input=[override flake input]:name=ref:' \
        '--reference-lock-file=[reference flake lock]:file:_files' \
        '1:nix expression:_files'
}

_nix-eval-jobs "$@"
