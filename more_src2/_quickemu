#compdef quickemu
# Documentation: https://github.com/quickemu-project/quickemu/blob/master/quickemu
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for quickemu - quickly create and run virtual machines

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--vm=[specify VM configuration file]:config file:_files -g "*.conf"' \
  '--access=[access mode]:mode' \
  '--braille[enable braille support]' \
  '--cpu-pinning[enable CPU pinning]' \
  '--delete-disk[delete the disk image]' \
  '--delete-vm[delete the VM and its disk image]' \
  '--display=[set display backend]:display:(gtk sdl cocoa none spice spice-app)' \
  '--fullscreen[start VM in fullscreen mode]' \
  '--ignore-msrs-always[KVM ignore unhandled MSRs]' \
  '--ignore-tsc-warning[ignore TSC warning]' \
  '--kill[kill the running VM process]' \
  '--offline[run in offline mode]' \
  '--shortcut[create a desktop shortcut]' \
  '--snapshot=[snapshot action]:action:(apply create delete info)' \
  '--status-quo[do not commit changes to disk]' \
  '--viewer=[SPICE viewer]:viewer:(spicy remote-viewer none)' \
  '--width=[screen width]:px' \
  '--height=[screen height]:px' \
  '--ssh-port=[SSH port forwarding]:port' \
  '--spice-port=[SPICE port]:port' \
  '--public-dir=[public directory]:dir:_files -/' \
  '--monitor=[QEMU monitor mode]:mode' \
  '--monitor-telnet-host=[monitor telnet host]:host' \
  '--monitor-telnet-port=[monitor telnet port]:port' \
  '--monitor-cmd=[send monitor command]:cmd' \
  '--serial=[serial mode]:mode' \
  '--serial-telnet-host=[serial telnet host]:host' \
  '--serial-telnet-port=[serial telnet port]:port' \
  '--keyboard=[keyboard type]:type' \
  '--keyboard_layout=[keyboard layout]:layout' \
  '--mouse=[mouse type]:type' \
  '--usb-controller=[USB controller]:controller' \
  '--sound-card=[sound card]:card' \
  '--sound-duplex[full duplex audio]' \
  '--extra_args=[pass extra arguments to QEMU]:arguments' \
  '--version[display version information]' \
  '(-h --help)'{-h,--help}'[display help]' && ret=0

return ret
