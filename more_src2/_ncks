#compdef ncks
# _ncks — NCO project ncks netCDF Kitchen Sink extracts subsets converts inspects netCDF and HDF data (nco team, C); custom argparse
# upstream: https://github.com/nco/nco

_ncks() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-3[output netCDF3 classic]' \
        '-4[output netCDF4]' \
        '-5[output netCDF5 64-bit data]' \
        '-6[output netCDF3 64-bit offset]' \
        '-7[output netCDF4 classic]' \
        '-a[no alphabetize variables]' \
        '-A[append mode]' \
        '-b+[binary output file]:file:_files' \
        '--binary-file=+[binary output file]:file:_files' \
        '-C[no coordinate variables]' \
        '--no-coords[no coordinate variables]' \
        '-c[include coordinate variables]' \
        '--coords[include coordinate variables]' \
        '-d+[dim:[min[,max[,stride[,subcycle]]]]]:str:' \
        '--dimension=+[dim:[min[,max[,stride[,subcycle]]]]]:str:' \
        '-F[fortran indexing]' \
        '--fortran[fortran indexing]' \
        '-g+[group spec]:str:' \
        '--group=+[group spec]:str:' \
        '-G+[group path]:str:' \
        '--grp-path=+[group path]:str:' \
        '-H[print data values]' \
        '--data[print data values]' \
        '-L+[compression level]:n:' \
        '--dfl-lvl=+[compression level]:n:' \
        '-m[print metadata]' \
        '--metadata[print metadata]' \
        '-M[print global metadata only]' \
        '--Metadata[print global metadata only]' \
        '-n[no append]' \
        '--no-append[no append]' \
        '-o+[output file]:file:_files -g "*.nc *.nc4 *.cdf *.h5 *.hdf"' \
        '--output=+[output file]:file:_files -g "*.nc *.nc4 *.cdf *.h5 *.hdf"' \
        '-O[overwrite existing]' \
        '--overwrite[overwrite existing]' \
        '-p+[path to input]:dir:_files -/' \
        '--path=+[path to input]:dir:_files -/' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[print revision]' \
        '--revision[print revision]' \
        '-s+[format string]:str:' \
        '--string=+[format string]:str:' \
        '-S+[shell script]:file:_files' \
        '--script=+[shell script]:file:_files' \
        '-t+[number of threads]:n:' \
        '--thr-nbr=+[number of threads]:n:' \
        '-u[print units]' \
        '--units[print units]' \
        '-v+[variables csv]:str:' \
        '--variable=+[variables csv]:str:' \
        '-x[exclude]' \
        '--exclude[exclude]' \
        '--mta_drc=+[dir]:dir:_files -/' \
        '--no-tmp-fl[no tmp file]' \
        '--ram_all[all in RAM]' \
        '*:input file:_files -g "*.nc *.nc4 *.cdf *.h5 *.hdf"'
}

_ncks "$@"
