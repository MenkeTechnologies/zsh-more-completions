#compdef goa
# _goa — Goa design-first Go API generator (Raphael Simon); generates HTTP + gRPC server + client from DSL
# upstream: https://github.com/goadesign/goa

_goa() {
    local -a sub=(
        'gen:generate code from design'
        'example:generate example service from design'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'goa subcommand' sub ;;
        args)
            case $words[1] in
                gen|example) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '-debug[debug log]' \
                    '*:design package:' ;;
            esac
            ;;
    esac
}

_goa "$@"
