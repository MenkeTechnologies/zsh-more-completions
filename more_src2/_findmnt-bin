#compdef findmnt
# _findmnt-bin — util-linux find mount point in /proc/self/mountinfo; canonical mount inspector
# upstream: https://github.com/util-linux/util-linux

_findmnt-bin() {
    _arguments \
        '(-A --all)'{-A,--all}'[disable filters]' \
        '(-a --ascii)'{-a,--ascii}'[ASCII tree drawing]' \
        '(-b --bytes)'{-b,--bytes}'[print sizes in bytes]' \
        '(-C --nocanonicalize)'{-C,--nocanonicalize}'[do not canonicalize]' \
        '(-c --canonicalize)'{-c,--canonicalize}'[canonicalize paths]' \
        '(-D --df)'{-D,--df}'[df-like output]' \
        '(-d --direction)'{-d,--direction}'+[direction]:dir:(forward backward)' \
        '(-e --evaluate)'{-e,--evaluate}'[evaluate tags]' \
        '(-F --tab-file)'{-F,--tab-file}'+[file]:file:_files' \
        '(-f --first-only)'{-f,--first-only}'[only first match]' \
        '(-i --invert)'{-i,--invert}'[invert sense]' \
        '(-J --json)'{-J,--json}'[json output]' \
        '(-k --kernel)'{-k,--kernel}'[from kernel mount table]' \
        '(-l --list)'{-l,--list}'[list format]' \
        '(-M --mountpoint)'{-M,--mountpoint}'+[mountpoint]:dir:_files -/' \
        '(-m --mtab)'{-m,--mtab}'[use /etc/mtab]' \
        '(-N --task)'{-N,--task}'+[task]:pid:_pids' \
        '(-n --noheadings)'{-n,--noheadings}'[no header]' \
        '(-O --options)'{-O,--options}'+[options]:opts:' \
        '(-o --output)'{-o,--output}'+[columns]:cols:' \
        '(-P --pairs)'{-P,--pairs}'[key=value output]' \
        '(-p --poll)'{-p,--poll}'+[poll events]:n:' \
        '(-R --submounts)'{-R,--submounts}'[print submounts]' \
        '(-r --raw)'{-r,--raw}'[raw output]' \
        '(-S --source)'{-S,--source}'+[source]:source:' \
        '(-s --fstab)'{-s,--fstab}'[use /etc/fstab]' \
        '(-T --target)'{-T,--target}'+[target]:dir:_files -/' \
        '(-t --types)'{-t,--types}'+[fs types]:types:' \
        '(-U --uniq)'{-U,--uniq}'[uniq output]' \
        '(-u --notruncate)'{-u,--notruncate}'[do not truncate]' \
        '(-v --nofsroot)'{-v,--nofsroot}'[do not print fs subroot]' \
        '(-W --output-all)'{-W,--output-all}'[all columns]' \
        '(-w --timeout)'{-w,--timeout}'+[poll timeout]:ms:' \
        '(-x --verify)'{-x,--verify}'[verify fstab]' \
        '(-y --shell)'{-y,--shell}'[shell variable output]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '*:dir:_files'
}

_findmnt-bin "$@"
