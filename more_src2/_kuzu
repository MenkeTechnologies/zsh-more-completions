#compdef kuzu
# Documentation: https://github.com/kuzudb/kuzu/blob/master/tools/shell/embedded_shell.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kuzu shell (kuzudb/kuzu). Flags taken from the CLI11 definition in the
# tools/shell sources. Removed from prior file: bogus man.archlinux.org
# search URL. Added missing flags --max_db_size, --no_progress_bar,
# --ignore_wal_replay_errors, --init.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --default_bp_size)'{-d+,--default_bp_size=}'[buffer pool size in MB]:mb:' \
  '--max_db_size=[maximum database size in bytes]:bytes:' \
  '(-r --read_only)'{-r,--read_only}'[open database read-only]' \
  '(-p --path_history)'{-p+,--path_history=}'[shell history directory]:dir:_files -/' \
  '(-m --mode)'{-m+,--mode=}'[output mode]:mode:(box column csv tsv html json line list markdown table trash)' \
  '(-s --no_stats)'{-s,--no_stats}'[hide query statistics]' \
  '(-b --no_progress_bar)'{-b,--no_progress_bar}'[disable progress bar]' \
  '(-w --ignore_wal_replay_errors)'{-w,--ignore_wal_replay_errors}'[ignore WAL replay failures]' \
  '(-i --init)'{-i+,--init=}'[path to startup script]:file:_files' \
  '--no_compression[disable compression]' \
  ':database:_files'
