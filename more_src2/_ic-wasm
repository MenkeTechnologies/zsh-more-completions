#compdef ic-wasm
# Documentation: https://github.com/dfinity/ic-wasm
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# DFINITY ic-wasm: WebAssembly post-processor for ICP canisters.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'metadata:manage metadata sections in Wasm modules'
  'info:print information about the Wasm canister'
  'shrink:remove unused functions and debug info'
  'optimize:invoke wasm optimizations (O0-O4, Os, Oz)'
  'resource:limit resource usage (Motoko Playground)'
  'check-endpoints:verify exports match Candid interface'
  'instrument:add execution tracing / WASI compat'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output wasm path]:file:_files' \
  '1:input wasm:_files -g "*.wasm"' \
  '2: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ic-wasm subcommand' subcommands && ret=0
    ;;
esac

return ret
