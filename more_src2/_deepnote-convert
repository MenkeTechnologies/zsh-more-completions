#compdef deepnote-convert
# ============================================================================
#  _deepnote-convert — deepnote-convert: Deepnote's notebook-import
#                      CLI — converts Jupyter (.ipynb) and other
#                      notebook formats into Deepnote's native
#                      .deepnote project format
#
#  Source-direct extraction from
#    https://github.com/deepnote/deepnote/blob/main/packages/convert/src/bin.ts
#    https://github.com/deepnote/deepnote/blob/main/packages/convert/package.json (bin: deepnote-convert)
#    https://github.com/privatenumber/cleye (the cleye library by
#    Hiroki "privatenumber" Osame — author of tsx, esbuild-loader,
#    and many TypeScript ecosystem tools)
#
#  Maintained by Deepnote Inc. (Czech/US data-science platform
#  company).  Deepnote main repo: 2,913 GH stars.  Deepnote is a
#  Jupyter-replacement collaborative notebook with AI-first design,
#  sleek UI, real-time multi-user editing, integrated SQL +
#  Python + R + JavaScript runtimes, and direct connections to
#  warehouses/databases (Snowflake, BigQuery, Postgres, MongoDB,
#  Databricks, etc.).  deepnote-convert is the CLI that ingests
#  Jupyter .ipynb files (and other notebook formats) and produces
#  Deepnote's native .deepnote project archive format for upload
#  into the platform.  Sister tools: jupyter (in corpus + STOCK
#  scientific computing via _jupyter), jupytext (jupyter ↔ py/md
#  converter — in corpus via _jupytext), nbconvert (Jupyter
#  convert — in corpus via _jupyter-nbconvert), papermill (parametrized
#  notebook execution — in corpus via _papermill), nbdime (in
#  corpus via _nbdime — notebook diff/merge), marimo (reactive
#  Python notebooks — in corpus via _marimo), pluto (Julia reactive
#  notebooks — Pluto.jl), observable-cli (Observable HQ).
#
#  CLI library taxonomy update: 15th TypeScript/Node CLI library
#  — Hiroki "privatenumber" Osame's **cleye** (privatenumber/cleye).
#  TypeScript-Node ecosystem now has 15 documented CLI libraries
#  — TYING WITH RUST AND GO at the top of the cross-language
#  taxonomy in a THREE-WAY TIE at 15 each.  🎉 TypeScript-Node
#  CATCHES UP — restoring three-way parity (Rust=15, Go=15,
#  TypeScript-Node=15).
#
#  cleye (privatenumber/cleye, 661 stars) is Hiroki "privatenumber"
#  Osame's STRONGLY-TYPED Node.js CLI builder.  Distinguishing
#  philosophy: TYPE INFERENCE FIRST — cleye's `flags: { foo:
#  { type: String, ... } }` schema uses TYPE CONSTRUCTORS as the
#  type spec (literally `String`/`Number`/`Boolean`/`Array`/custom
#  parser functions), and TypeScript infers the final parsed args
#  type from the schema constructors AUTOMATICALLY — so
#  `argv.flags.singleFile` is typed as `boolean` because schema
#  said `type: Boolean`.  Used by privatenumber/tsx (THE FLAGSHIP
#  cleye user — TypeScript Execute 12,010 stars — IN CORPUS via
#  _tsx; cleye is privatenumber's own tool used by privatenumber's
#  own most-popular project), Nutlope/aicommits (AI commit
#  generator 9,000 stars — IN CORPUS via _aicommits), tak-bro/
#  aicommit2 (AI commit generator 517 stars — IN CORPUS via
#  _aicommit2), backstage/backstage (Spotify's developer portal
#  33,482 stars — uses cleye in cli-module-auth), deepnote/deepnote
#  (2,913 stars), maoosi/prisma-appsync (Prisma + AWS AppSync
#  231 stars), gptlint/gptlint (LLM-powered linter 293 stars),
#  khulnasoft/commit-agent, MantisWare/commit-ai, schummar/runp
#  (run npm-script parallel), bisquit/ts-rename-all, Artmann/
#  olingo, dexaai/xbot, gong9/image-compression-tool, and many
#  other Node/TypeScript CLIs that prefer privatenumber's strongly-
#  typed schema over commander/yargs builders.
#
#  cleye API:
#    import { cli, command } from 'cleye'
#
#    // SINGLE COMMAND:
#    const argv = cli({
#      name: 'mytool',
#      version: '1.0.0',
#      description: 'My tool description',
#
#      // POSITIONAL params declared as STRING ARRAY:
#      //   '<name>' — required positional
#      //   '[name]' — optional positional
#      //   '<name...>' — rest positional (array)
#      parameters: ['<path>', '[outputDir]'],
#
#      flags: {
#        // TYPE is the constructor — String/Number/Boolean/Array/
#        // custom function — and TypeScript infers parsed type
#        projectName: {
#          description: 'The Deepnote project name',
#          type: String,
#        },
#        outputPath: {
#          alias: 'o',                       // -o short alias
#          description: 'Output path',
#          type: String,
#        },
#        count: {
#          alias: 'n',
#          description: 'Number of items',
#          type: Number,                     // typed as number
#          default: 10,
#        },
#        singleFile: {
#          description: 'Output single file',
#          type: Boolean,                    // boolean flag
#          default: false,
#        },
#        // ARRAY: type: [String] (array of strings) — repeatable
#        // --include foo --include bar -> ['foo', 'bar']
#        include: {
#          alias: 'i',
#          description: 'Include pattern',
#          type: [String],                   // ARRAY of strings
#        },
#        // CUSTOM PARSER FUNCTION:
#        // type: (raw: string) => parse(raw)
#        port: {
#          description: 'Port number',
#          type: (raw: string) => parseInt(raw, 10),
#        },
#      },
#
#      // Optional ignore hook for unrecognized flags
#      ignore: (type, value) => type === 'unknown-flag',
#    })
#
#    // argv is TYPE-INFERRED:
#    //   argv._.path: string                  (from positional)
#    //   argv._.outputDir?: string             (optional positional)
#    //   argv.flags.projectName?: string
#    //   argv.flags.outputPath?: string
#    //   argv.flags.count: number
#    //   argv.flags.singleFile: boolean
#    //   argv.flags.include?: string[]
#    //   argv.flags.port?: number
#    //   argv.unknownFlags: { [key: string]: any }
#
#    // SUBCOMMANDS via `command()`:
#    const buildCmd = command({
#      name: 'build',
#      flags: { ... },
#      run: ({ flags }) => { ... },
#    })
#    const argv = cli({
#      name: 'mytool',
#      commands: [buildCmd, otherCmd],
#    })
#
#  cleye distinctive features:
#    - TYPE-CONSTRUCTOR-AS-TYPE-SPEC — `type: String` (the JavaScript
#      String constructor itself) is the type declaration.
#      TypeScript infers parsed type from the constructor via
#      `InstanceType<typeof String>` style inference.  Same for
#      Number, Boolean, Array constructors.
#    - CUSTOM PARSER FUNCTIONS as types — `type: (raw: string) =>
#      parseFloat(raw)` makes a flag's parsed type the function's
#      return type
#    - ARRAY TYPES via `type: [String]` (array literal) — REPEATABLE
#      flag (`--include a --include b` → `['a', 'b']`)
#    - PARAMETERS schema as STRING ARRAY — positional spec is the
#      literal POSIX usage-line style: `parameters: ['<name>',
#      '[optional]', '<rest...>']` where `<>` = required, `[]` =
#      optional, `...` = rest
#    - PARSED RESULT has THREE TOP-LEVEL KEYS:
#      * `argv._` — POSITIONALS as an object keyed by the
#        parameter NAME (from `parameters: ['<path>']` becomes
#        `argv._.path`); raw positionals also available as
#        `argv._.array` and `argv._.first`/`argv._.second`/etc.
#      * `argv.flags` — parsed flag values (type-inferred from
#        schema)
#      * `argv.unknownFlags` — any flags not in the schema (caller
#        can ignore or error)
#    - SUBCOMMAND COMPOSITION via `command()` + `commands:[...]` —
#      each subcommand is a separate cli-like object with its own
#      `parameters`/`flags`/`run` handler
#    - AUTO --help / -h / --version / -v generation from `name`/
#      `version`/`description`/flag metadata; pretty terminal
#      output with colors
#    - `ignore` hook for custom unknown-flag/unknown-arg handling
#      (used by tsx to pass-through unknown flags to the underlying
#      node command)
#    - STRICT-MODE by default — errors on unknown flags unless
#      `ignore` hook overrides
#    - INSPIRED BY commander.js (parameters string syntax) +
#      type-fest (TypeScript constructor-as-type pattern) +
#      privatenumber's own preference for STRONGLY TYPED APIs
#  Distinct from R236 commander (TJ Holowaychuk's chained-builder
#  with subcommand-tree — Vue CLI/jest/ngx; cleye SHARES commander's
#  parameters string syntax `<name>`/`[name]`/`<name...>` but uses
#  schema object instead of chained-builder), R237 oclif (Heroku/
#  Salesforce enterprise framework with plugin discovery), yargs
#  (Bash-style yargs-parser — npm/jest), R398 meow (Sindre Sorhus
#  zero-config using minimist), R399 substack/minimist (the
#  ORIGINAL micro-arg-parser), R400 cac (Anthony Fu — uses mri
#  internally), R403 clipanion (Yarn's class-based with `@Command()`
#  decorators), R406 vercel/arg (spec-object schema with built-in
#  type COERCION FUNCTIONS as types — CONCEPTUALLY SIMILAR to
#  cleye's constructor-as-type approach but vercel/arg uses its
#  own constants like `arg.COUNT` rather than JS native constructors),
#  R409 mri (lukeed minimal parser — what cac/sade use internally),
#  R412 citty (UnJS TypeScript-first DECLARATIVE-SCHEMA using
#  STRING type names like 'string'/'boolean' — DIFFERENT from
#  cleye's JS-NATIVE-CONSTRUCTOR-as-type), R415 cmd-ts (Schniz's
#  PARSER COMBINATOR algebra borrowed from Haskell — uses Type
#  INTERFACE for custom parsers vs cleye's function-as-type),
#  R418 gluegun (Infinite Red TOOLBOX PATTERN — pre-populated
#  helper bag).  TypeScript-Node documented libraries so far:
#  commander, oclif, yargs, meow, minimist, cac, clipanion, arg,
#  mri, sade, citty, cmd-ts, gluegun, cleye (this round)... 15
#  total.  cleye's distinguishing feature vs all other TS-Node
#  libs: cleye is the ONLY ONE that uses JavaScript-NATIVE
#  CONSTRUCTORS (String/Number/Boolean/Array as values) as the
#  type spec — every other lib uses either string type names
#  ('string'/'boolean'), parser-combinator Type interfaces, or
#  type COERCION FUNCTIONS.  cleye's approach: TYPE-CONSTRUCTOR-
#  AS-TYPE-SPEC with `cli({ name, version, description,
#  parameters, flags, ignore, commands })` schema-object builder
#  + `parameters: ['<name>', '[opt]', '<rest...>']` POSIX-style
#  positional spec + `flags: { name: { type: String|Number|Boolean|
#  [String]|customFn, alias, description, default } }` schema +
#  `argv._` (positionals object keyed by parameter NAME) + `argv.
#  flags` (type-inferred parsed flags) + `argv.unknownFlags`
#  (catch-all for unknown) + `command()` factory for subcommands
#  + `commands: [...]` array composition + AUTO --help/--version
#  + `ignore` hook for unknown-flag pass-through (used by tsx to
#  forward flags to node) + STRICT-MODE error on unknown flags
#  default + INSPIRED BY commander.js parameters syntax + type-
#  fest constructor-as-type pattern — corpus's **first documented
#  type-constructor-as-type-spec TypeScript-Node CLI library**.
#  Brings cross-language CLI library taxonomy variant count to
#  161; TypeScript-Node ecosystem now has 15 documented CLI
#  libraries — TYING WITH RUST AND GO at the top of the cross-
#  language taxonomy in a THREE-WAY TIE at 15.
#
#  Surface (verbatim from `packages/convert/src/bin.ts` cleye cli()
#  call):
#
#  Usage:
#    deepnote-convert [options] <path>
#
#  Positional (REQUIRED):
#    <path>                         Path to notebook file (.ipynb)
#                                   or directory containing
#                                   notebooks to convert into the
#                                   Deepnote project format
#
#  Options:
#        --projectName <NAME>       The name of the Deepnote project
#                                   (becomes the project name when
#                                   the .deepnote archive is
#                                   uploaded to deepnote.com)
#    -o, --outputPath <PATH>        The path where the .deepnote
#                                   file will be saved (default:
#                                   inferred from project name)
#        --cwd <DIR>                The working directory to resolve
#                                   paths relative to (default:
#                                   process.cwd())
#        --singleFile               Output a single file with
#                                   outputs included (disables
#                                   snapshot mode; default: false)
#        --help                     Show help (auto-generated by
#                                   cleye)
#        --version                  Show version (auto-generated
#                                   by cleye from package.json
#                                   version)
#
#  Examples:
#    deepnote-convert notebook.ipynb                                    # Basic conversion
#    deepnote-convert --projectName "My Analysis" notebook.ipynb        # Named project
#    deepnote-convert -o output.deepnote notebook.ipynb                 # Custom output path
#    deepnote-convert --cwd /work/notebooks notebook.ipynb              # Resolve paths from /work
#    deepnote-convert --singleFile notebook.ipynb                       # Single-file mode (no snapshot)
#    deepnote-convert -o my.deepnote --projectName "Analysis 2025" --singleFile data/eda.ipynb
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also cleye users):
#    - tsx (IN CORPUS via _tsx — privatenumber/tsx TypeScript
#      Execute 12,010 stars; FLAGSHIP cleye user; previously
#      documented but cleye library not formally entered into
#      taxonomy)
#    - aicommits (IN CORPUS via _aicommits — Nutlope/aicommits
#      9,000 stars AI commit generator; uses cleye)
#    - aicommit2 (IN CORPUS via _aicommit2 — tak-bro/aicommit2
#      517 stars; uses cleye)
#    - backstage (Spotify backstage 33,482 stars — uses cleye in
#      cli-module-auth submodule; FUTURE candidate for
#      backstage-cli-module-auth completion)
#    - prisma-appsync (maoosi/prisma-appsync 231 stars — FUTURE
#      candidate)
#    - gptlint (gptlint/gptlint 293 stars — FUTURE candidate)
# ============================================================================

_deepnote-convert() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[show help]' \
    '--version[show version]' \
    '--projectName=[the name of the Deepnote project]:name:' \
    '(-o --outputPath)'{-o,--outputPath=}'[the path where the .deepnote file will be saved]:path:_files' \
    '--cwd=[the working directory to resolve paths relative to]:dir:_directories' \
    '--singleFile[output a single file with outputs included (disables snapshot mode)]' \
    ':path:_files -g "*.ipynb"'
}

_deepnote-convert "$@"
