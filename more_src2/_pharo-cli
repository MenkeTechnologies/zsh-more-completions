_pharo-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--headless[headless]' \
        '--no-default-preferences[no default preferences]' \
        '--interactive[interactive mode]' \
        '--no-quit[no quit]' \
        '--vm-display-fbdev[framebuffer display]' \
        '--vm-display-null[null display]' \
        '--vm-display-X11[X11 display]' \
        '--vm-sound-null[null sound]' \
        '--vm-sound-alsa[alsa sound]' \
        '--vm-sound-oss[OSS sound]' \
        '--logfile=+[file]:file:_files' \
        '--noscripts[no scripts]' \
        '--keep-alive[keep alive]' \
        '--doit=+[expression]:str:' \
        '-D+[expression]:str:' \
        '*-D+[expression]:str:' \
        '--save[save image]' \
        '--quit[quit after script]' \
        '--no-banner[no banner]' \
        '--print-stack[print stack]' \
        '--check-vm[check VM]' \
        '--vm-debug[VM debug]' \
        '--vm-info[VM info]' \
        '--vm-version[VM version]' \
        '--list-modules[list modules]' \
        '--vm-display-headless[headless display]' \
        '--vm-prefer-mali[prefer Mali]' \
        '--memory=+[N]:n:' \
        '-mmap=+[N]:n:' \
        '--start[start image]' \
        '--no-stop[no stop]' \
        '--encoding=+[enc]:str:' \
        '--max-old-space-size=+[N]:n:' \
        '--snapshot=+[name]:str:' \
        '--no-default-preferences[no preferences]' \
        '--copyrights[show copyrights]' \
        '--save-as=+[file]:file:_files' \
        '--package=+[name]:str:' \
        '--load=+[file]:file:_files -g "*.st"' \
        '*:script:_files -g "*.st *.image *.changes"'
}

_pharo-cli "$@"
