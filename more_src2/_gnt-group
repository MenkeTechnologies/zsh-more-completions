#compdef gnt-group
# _gnt-group — Google Ganeti gnt-group CLI for managing Ganeti virtualisation cluster node groups separate scheduling and topology domains add modify rename remove evacuate list info disk-templates ipolicy diskparams (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-group() {
    local -a sub=(
        'add:add new node group'
        'assign-nodes:assign nodes to group'
        'evacuate:evacuate group nodes'
        'info:show group info'
        'list:list node groups'
        'list-tags:list group tags'
        'add-tags:add tags'
        'remove-tags:remove tags'
        'modify:modify group'
        'remove:remove group'
        'rename:rename group'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '--reason=+[text]:str:' \
        '--submit[submit only]' \
        '--print-job-id[print job id]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-group subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--node-parameters=+[K=V csv]:str:' \
                    '--alloc-policy=+[a]:a:(preferred allocatable unallocable last_resort)' \
                    '--ipolicy-bounds-specs=+[csv]:str:' \
                    '--ipolicy-spindle-ratio=+[F]:f:' \
                    '--ipolicy-vcpu-ratio=+[F]:f:' \
                    '--ipolicy-disk-templates=+[csv]:str:' \
                    '--disk-parameters=+[K=V csv]:str:' \
                    '--diskparams=+[K=V csv]:str:' \
                    '--tags=+[csv]:str:' \
                    '*:group name:' ;;
                evacuate) _arguments \
                    '-I+[iallocator]:str:' \
                    '--iallocator=+[iallocator]:str:' \
                    '--target-groups=+[csv]:str:' \
                    '*:group name:' ;;
                modify|info|remove|rename) _arguments \
                    '*:group name:' ;;
            esac
            ;;
    esac
}

_gnt-group "$@"
