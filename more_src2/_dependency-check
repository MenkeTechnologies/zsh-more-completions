#compdef dependency-check
# Documentation: https://jeremylong.github.io/DependencyCheck/dependency-check-cli/arguments.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--advancedHelp[show advanced options]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--project=[project name]:name' \
  '(-s --scan)'{-s,--scan=}'[path to scan]:path:_files' \
  '*--exclude=[Ant-style pattern to exclude]:pattern' \
  '(-o --out)'{-o,--out=}'[output directory]:dir:_files -/' \
  '(-f --format)'{-f,--format=}'[report format]:format:(HTML XML JSON CSV SARIF JUNIT JENKINS GITLAB ALL)' \
  '(-l --log)'{-l,--log=}'[log file]:file:_files' \
  '--suppression=[suppression XML]:file:_files -g "*.xml"' \
  '--failOnCVSS=[fail on CVSS >= threshold]:score' \
  '--junitFailOnCVSS=[JUNIT fail threshold]:score' \
  '(-n --noupdate)'{-n,--noupdate}'[disable NVD-CVE updates]' \
  '--updateonly[only run update phase]' \
  '--purge[remove local NVD copy]' \
  '--enableExperimental[enable experimental analyzers]' \
  '*:properties or paths: _default'
