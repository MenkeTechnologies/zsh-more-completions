#compdef dte
# Documentation: https://craigbarnes.gitlab.io/dte/dte.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-c+[run command after startup]:command' \
  '-t+[jump to ctag]:ctag' \
  '-r+[load custom rc file]:rcfile:_files' \
  '-s+[load and validate syntax file]:syntax file:_files' \
  '-b+[dump built-in config or syntax file]:rcname' \
  '-B[list available built-in config names]' \
  '-H[disable history file persistence]' \
  '-K[enter key-name display mode]' \
  '-R[skip reading rc file]' \
  '-P[print terminal color palette]' \
  '*:file:_files' && return 0
