#compdef maas-region-controller maas-region
# Documentation: https://github.com/maas/maas/tree/master/src/maasserver/management/commands
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# maas-region-controller: MAAS region controller management commands
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'createadmin:create a MAAS administrator'
  'changepassword:change MAAS account password'
  'changepasswords:change multiple MAAS account passwords'
  'configauth:configure region-controller authentication'
  'config_tls:configure TLS'
  'config_vault:configure HashiCorp Vault'
  'apikey:get/manage API key for a user'
  'shell:open Django shell against MAAS DB'
  'dbshell:open Django DB shell'
  'dbupgrade:run database migrations'
  'edit_named_options:edit BIND named.conf options'
  'generate_api_doc:generate API documentation'
  'generate_oapi_spec:generate OpenAPI specification'
  'local_config_get:get local config value'
  'local_config_set:set local config value'
  'local_config_reset:reset local config'
  'msm:MAAS Site Manager command'
  'runserver:run development server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'region-controller command' commands && ret=0 ;;
esac
return ret
