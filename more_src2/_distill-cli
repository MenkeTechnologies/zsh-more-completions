#compdef distill-cli
# Documentation: https://github.com/awslabs/distill-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# distill-cli: AWS Transcribe + Bedrock audio summarizer. Flags from README.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-i --input-audio-file)'{-i,--input-audio-file}'[audio file to summarize]:file:_files' \
  '(-o --output-type)'{-o,--output-type}'[output format]:format:(terminal text word markdown slack)' \
  '(-l --language-code)'{-l,--language-code}'[input language code]:code:' \
  '(-d --delete-s3-object)'{-d,--delete-s3-object}'[delete S3 object after run]:flag:(Y N)' \
  '*::arguments:_default'
