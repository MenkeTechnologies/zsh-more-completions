#compdef grub-editenv
# _grub-editenv — GRUB grub-editenv (manipulate the GRUB env-block (grubenv) file used to persist last-good kernels, retry counts and user variables; subcommands: create, list, set NAME=VALUE, unset NAME; first positional argument is the env-block file (default /boot/grub/grubenv), then the subcommand)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-editenv.c on tip.

_grub-editenv() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1::env block file:_files' \
        '2::command:(create list set unset)' \
        '*::name=value:'
}

_grub-editenv "$@"
