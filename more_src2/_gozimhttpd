#compdef gozimhttpd gozimindex
# ============================================================================
# _gozimhttpd — zsh completion for **gozimhttpd** + **gozimindex** —
#            akhenakh/gozim, the Go reader / HTTP server / full-text
#            indexer for the **ZIM (Zeno IMproved) compressed open
#            archive format** — the OpenZIM/Kiwix file format that
#            packages entire Wikipedia / Wiktionary / Wikivoyage /
#            Wikisource / Project Gutenberg / StackExchange / TED /
#            Khan Academy / Wikibooks / arXiv snapshots into a
#            single compressed offline-readable file (the file
#            format used by every Kiwix reader on the planet for
#            offline-Wikipedia distribution to schools, prisons,
#            air-gapped networks, expeditions, and humanitarian
#            response scenarios).  `gozimhttpd` serves a ZIM archive
#            over HTTP as a browsable wiki;  `gozimindex` builds a
#            full-text Bleve inverted index over the archive
#            contents for the search functionality.  Go=181 leader
#            bump continuing Axis 126 (pure-Rust + pure-Go +
#            pure-Lucene full-text search / inverted-index engine
#            taxonomy) at 2/0/0 via the canonical Go-side library
#            **github.com/blevesearch/bleve**.
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/akhenakh/gozim
#   Maintainer : Fabrice Aneche (akhenakh on GitHub);  French
#                 Go developer, also the author of `dragonboat-
#                 example`, `regionagogo` (the geospatial point-
#                 in-polygon service that resolves lat/lon to
#                 country / region in O(log n) via S2 cells +
#                 R-trees), and contributor to the OpenZIM
#                 community alongside the Kiwix Foundation
#   License    : MIT
#   Stars      : 200+ on github.com/akhenakh/gozim
#   Language   : Go  (Go-standard `flag` package for the CLI
#                 surface + blevesearch/bleve v1.0.14 for the
#                 full-text inverted index + goleveldb storage
#                 backend + golang-lru ARC cache + GeertJohan/
#                 go.rice for embedded templates + PuerkitoBio/
#                 goquery for HTML parsing during indexing +
#                 klauspost/compress for fast LZ-family
#                 decompression + ulikunitz/xz + klauspost/
#                 compress/zstd for ZIM's optional Zstandard
#                 compressed clusters + ckb / cjk / fa / fr /
#                 it / en / pt / hi / ar / pt language
#                 analyzers from bleve)
#   Binaries   : gozimhttpd   — HTTP wiki server
#                gozimindex   — full-text Bleve index builder
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   The **ZIM file format** (filename `.zim`) is the open
#   archive format created by the openZIM project (joint
#   between Wikimedia CH + Kiwix) for packaging entire wiki +
#   media collections into a single compressed indexed file
#   suitable for offline reading.  Every Kiwix download (the
#   Kiwix Foundation publishes monthly snapshots of every
#   major Wikipedia language at https://download.kiwix.org)
#   is a `.zim` file.  ZIM is used by:
#
#     • **Internet-in-a-Box** (libraryforall.org) — pocket-
#       sized server appliance for under-served communities
#     • **Kiwix for Schools** — offline curriculum delivery
#     • **One Laptop Per Child** — preloaded education content
#     • **Wikimed** — offline medical Wikipedia for clinicians
#       in low-connectivity contexts
#     • **Disaster-response NGOs** — Médecins Sans Frontières,
#       UNHCR, Red Cross for field-deployed knowledge access
#     • **NASA + DoD + research stations** — Antarctic
#       research stations (McMurdo / Amundsen-Scott), ISS
#       crew Earth-knowledge cache, submarine + ship libraries
#     • **Prison-education programs** — air-gapped Wikipedia
#       access (the offline format is a hard requirement
#       since the institutions don't allow internet)
#
#   The official desktop / mobile reader is **Kiwix** (kiwix-
#   desktop, kiwix-android, kiwix-ios, kiwix-serve);  `gozim`
#   is the **pure-Go alternative reader + indexer** — useful
#   when you want to embed ZIM serving into a Go service
#   without taking on Kiwix's C++ + Qt dependency footprint,
#   or when you want to serve ZIM files from a small VPS /
#   container / serverless function with minimal binary
#   bloat.
#
#   Two-binary architecture (the conventional Bleve pattern of
#   separating the index-building step from the serving step):
#
#     • **gozimindex** — read a ZIM archive, parse each
#                       article's HTML with goquery, extract
#                       the title + plain-text body, run the
#                       per-language Bleve analyzer + stemmer
#                       chain, and write a Bleve-indexed
#                       directory of indexable files
#                       (goleveldb-backed segments)
#     • **gozimhttpd** — open a ZIM archive + the (optional)
#                       Bleve index directory, serve every
#                       article on `/<articleSlug>` over HTTP,
#                       provide a `/search?q=...` endpoint
#                       backed by the Bleve index, and stream
#                       through the article's MIME-typed
#                       bytes (text/html + image/png + image/
#                       svg+xml + video/webm + every other
#                       MIME type embedded in the ZIM)
#
# CLI ARGUMENT GRAMMAR  (verbatim from
#                       `cmd/gozimhttpd/main.go` +
#                       `cmd/gozimindex/main.go` `flag.<Type>(...)`
#                       declarations;  extracted via raw fetch
#                       of both files)
#
# === gozimhttpd ============================================================
#
#   gozimhttpd [FLAGS...]
#
#   Flags:
#     -port <N>                       port to listen to;  read
#                                     HOST env if not specified;
#                                     default 8080
#     -path <PATH>                    path for the ZIM file
#                                     (REQUIRED)
#     -index <PATH>                   path for the Bleve index
#                                     directory (optional;
#                                     without this, the /search
#                                     endpoint is disabled)
#     -mmap                           use mmap for ZIM file
#                                     access (faster, but
#                                     OS-pages the archive
#                                     instead of explicit read
#                                     calls)
#     -cpuprofile <FILE>              write CPU profile to file
#                                     (the standard runtime/
#                                     pprof.StartCPUProfile
#                                     mechanism)
#
# === gozimindex ============================================================
#
#   gozimindex [FLAGS...]
#
#   Flags:
#     -path <PATH>                    path for the ZIM file
#                                     (REQUIRED)
#     -index <PATH>                   path for the Bleve index
#                                     directory (REQUIRED;
#                                     written to disk)
#     -lang <LANG>                    language for indexation;
#                                     selects the Bleve
#                                     analyzer + stemmer chain;
#                                     values:  ar, ca, ckb, el,
#                                     eu, gl, hy, in, ja, bg,
#                                     cjk, cs, fa, ga, hi, id,
#                                     it, pt, en, fr (with
#                                     "ennostemm" /
#                                     "frnostemm" stem-free
#                                     variants used when -lang
#                                     en or fr is selected to
#                                     avoid over-stemming
#                                     Wikipedia titles)
#     -batchsize <N>                  Bleve batch size for
#                                     index writes (default
#                                     1000)
#     -content                        EXPERIMENTAL: index the
#                                     full HTML content of
#                                     each article (default
#                                     off: title-only index,
#                                     much smaller +
#                                     faster);  set to true
#                                     for full-content search
#                                     at the cost of larger
#                                     index files
#     -cpuprofile <FILE>              write CPU profile to file
#
# AXIS / CORPUS POSITION
#   `akhenakh/gozim`'s `go.mod` declares a **direct** dependency
#   on `github.com/blevesearch/bleve v1.0.14` along with typed
#   per-language analyzer imports (`_
#   "github.com/blevesearch/bleve/analysis/lang/{ar,cjk,ckb,en,
#   fa,fr,hi,it,pt}"`) and the typed goleveldb storage backend
#   (`_ "github.com/blevesearch/bleve/index/store/goleveldb"`).
#   `cmd/gozimindex/main.go` constructs the index via typed
#   `bleve.NewIndexMapping()` / typed
#   `bleve.NewDocumentMapping()` / typed
#   `bleve.NewTextFieldMapping()` / typed
#   `bleve.NewMemOnly(mapping)` /  typed `bleve.New(indexPath,
#   mapping)` /  typed `index.Index(id, doc)` /  typed
#   `index.Batch(batch)`.  `cmd/gozimhttpd/main.go` opens the
#   index via typed `bleve.Open(indexPath)`, processes search
#   queries with typed `bleve.NewQueryStringQuery(q)` /  typed
#   `bleve.NewSearchRequest(query)` /  typed
#   `index.Search(searchRequest)` /  typed `*SearchResult`
#   handling.
#
#   **bleve** (`github.com/blevesearch/bleve`) is **THE canonical
#   pure-Go full-text search library** — Marty Schoch's
#   reference pure-Go implementation of an inverted-index
#   search engine modeled architecturally on Apache Lucene
#   (the same architectural inspiration as tantivy on the Rust
#   side).  In active development since 2014, with 10,700+ ★
#   on github.com/blevesearch/bleve.  Originally developed at
#   Couchbase Inc. as the search engine inside Couchbase
#   Server's Full-Text Search service (FTS), then donated to
#   the community under the `blevesearch/` GitHub org but with
#   continued Couchbase maintenance + funding.  Bleve is **the
#   dominant Go-side inverted-index library by an order of
#   magnitude** — the alternatives are `riot` (smaller scope,
#   primarily Chinese), `go-fts` (toy implementations), or
#   forking an external Lucene-via-JVM service (defeats the
#   purpose of using Go).
#
#   bleve ships:
#
#     • Typed `bleve.Index`            top-level index handle
#                                      with typed `bleve.New`,
#                                      `bleve.NewMemOnly`,
#                                      `bleve.NewUsing`,
#                                      `bleve.Open`,
#                                      `bleve.OpenUsing`
#                                      constructors
#     • Typed `bleve.IndexMapping`     typed
#                                      `bleve.NewIndexMapping`
#                                      builder + typed
#                                      `DocumentMapping` +
#                                      typed `FieldMapping`
#                                      for typed per-field
#                                      analyzer + index +
#                                      store + term-vector
#                                      configuration
#     • Typed pluggable storage         the typed
#       backends                        `index.KVStore`
#                                      interface with concrete
#                                      typed `goleveldb`
#                                      (default) / `boltdb` /
#                                      `gtreap` (in-memory) /
#                                      `moss` / `metrics`
#                                      backends
#     • Typed query AST                typed `query.Query`
#                                      interface + typed
#                                      concrete `MatchQuery`,
#                                      `MatchPhraseQuery`,
#                                      `BooleanQuery`,
#                                      `TermQuery`,
#                                      `PhraseQuery`,
#                                      `PrefixQuery`,
#                                      `RegexpQuery`,
#                                      `FuzzyQuery`,
#                                      `WildcardQuery`,
#                                      `QueryStringQuery`,
#                                      `NumericRangeQuery`,
#                                      `DateRangeQuery`,
#                                      `TermRangeQuery`,
#                                      `IPRangeQuery`,
#                                      `BoolFieldQuery`,
#                                      `DocIDQuery`,
#                                      `GeoBoundingBoxQuery`,
#                                      `GeoDistanceQuery`,
#                                      `MatchAllQuery`,
#                                      `MatchNoneQuery`,
#                                      `DisjunctionQuery`,
#                                      `ConjunctionQuery`
#     • Typed language analyzers       typed
#                                      `analysis/lang/<code>`
#                                      packages providing
#                                      typed character-filter
#                                      + tokenizer + token-
#                                      filter chains for:
#                                      Arabic, Bulgarian,
#                                      Catalan, Chinese-Japanese-
#                                      Korean (CJK n-gram),
#                                      Sorani (Central
#                                      Kurdish), Czech, Danish,
#                                      Dutch, English (with +
#                                      without Porter stemmer),
#                                      Finnish, French (with +
#                                      without snowball
#                                      stemmer), Galician,
#                                      German, Greek, Hindi,
#                                      Hungarian, Indonesian,
#                                      Italian, Japanese
#                                      (kagome), Norwegian,
#                                      Persian (Farsi),
#                                      Portuguese, Romanian,
#                                      Russian, Spanish,
#                                      Swedish, Turkish, Thai,
#                                      Vietnamese
#     • Typed tokenizers               typed `tokenizer.Tokenizer`
#                                      interface + concrete
#                                      typed `unicode` (ICU-
#                                      compliant), `whitespace`,
#                                      `single`, `letter`,
#                                      `ngram`, `edgeNgram`,
#                                      `web`, `regexp`,
#                                      `character` tokenizers
#     • Typed token filters            typed `tokenfilter.
#                                      TokenFilter` interface +
#                                      concrete typed
#                                      `apostrophe`, `case`,
#                                      `compound`, `dictCompound`,
#                                      `edgeNgram`, `keyword`,
#                                      `length`, `lowercase`,
#                                      `ngram`, `porter`,
#                                      `reverse`, `shingle`,
#                                      `snowball`, `stop`,
#                                      `truncate`, `unicode`,
#                                      `unique` filters
#     • Typed character filters        typed `charfilter.
#                                      CharFilter` interface +
#                                      typed concrete
#                                      `htmlCharFilter`,
#                                      `regexpCharFilter`,
#                                      `zerowidthnonjoiner`
#                                      filters
#     • Typed faceted search            typed `bleve.Facet`
#                                      builders (numeric +
#                                      date range + term
#                                      facets), typed
#                                      drill-down across
#                                      typed `FacetResults`
#     • Typed geospatial search        typed
#                                      `GeoBoundingBoxQuery`,
#                                      `GeoDistanceQuery`,
#                                      `GeoBoundingPolygonQuery`,
#                                      `GeoShapeQuery`
#     • Typed highlighting              typed
#                                      `bleve.NewHighlight()` /
#                                      `Highlight.AddField` /
#                                      typed `Fragment` /
#                                      `FragmentMap`
#     • Typed scoring                  typed BM25 + TF-IDF
#                                      scoring + typed custom
#                                      `Scorer` interface
#     • Typed Bleve HTTP API           typed `bleveHTTP` package
#                                      with full REST surface
#                                      (the Bleve example HTTP
#                                      server pattern)
#     • Typed Bleve gRPC              limited;  community
#                                      packages
#     • Typed batch operations         typed `index.NewBatch()` /
#                                      `Batch.Index` /
#                                      `Batch.Delete` /
#                                      `index.Batch(b)` for
#                                      atomic multi-doc writes
#     • Typed multi-segment merger
#     • Typed schema-aware mapping
#       with typed nested-object
#       drill-down via Lucene-style
#       dotted paths
#     • Typed index alias              typed
#                                      `bleve.NewIndexAlias`
#                                      for transparent
#                                      multi-index search
#                                      (the alias-as-virtual-
#                                      index pattern)
#
#   bleve is the inverted-index library behind essentially
#   every modern Go-based search system:
#
#     • **Grafana** (200,000+ ★) — bleve in the
#       `pkg/services/search` layer for dashboard +
#       organization search
#     • **Gitea** (50,000+ ★) — the self-hosted Git forge;
#       bleve for code search + issue search inside
#       repositories (covered as `_gitea`)
#     • **AlistGo/alist** — multi-cloud file index browser;
#       bleve for the cross-cloud file-search backend
#     • **Keybase client** — Keybase's KBFS+chat client;
#       bleve for the chat-message search backend
#     • **LocalAI** (mudler/LocalAI, 26,000+ ★) — the local
#       LLM inference API gateway;  bleve for the gallery
#       model-search backend
#     • **git-bug** — distributed bug tracker stored as git
#       objects (covered as `_git-bug`);  bleve for the
#       cross-issue full-text search
#     • **OpenCloud** (opencloud-eu/opencloud) — the open-
#       source Nextcloud alternative;  bleve in the search
#       service
#     • **Moira** (the alerting system based on Graphite);
#       bleve for the trigger + tag search
#     • **Couchbase Server Full-Text Search** — bleve's
#       original commercial home, where it remains the FTS
#       engine
#     • **Hugo** (the static site generator;  uses bleve for
#       site-wide content search in the dev server)
#     • **NetCap** (dreadl0ck/netcap) — network-traffic
#       analysis framework;  bleve for searching captured
#       audit records
#     • **Semaphore CI** MCP server — bleve for the
#       conversational-CI knowledge base
#     • **Rvn0xsy/red-tldr** — red-team knowledge-base CLI;
#       bleve for the search index over the offline
#       penetration-testing reference cards
#     • **smart-mcp-proxy/mcpproxy-go** — MCP gateway with
#       bleve for tool registry search
#     • **rubiojr/goin** — personal information indexer
#     • **akhenakh/gozim** (this very project)
#     • **JustaPenguin/assetto-server-manager** — Assetto
#       Corsa racing server's UI bleve-indexes session +
#       lap data
#     • **synnaxlabs/synnax** — hardware control + telemetry
#       platform's bleve-indexed time-series metadata
#     • **suntong/doc-search** — document search CLI
#     • Plus thousands of internal Go search backends.
#
#   The bleve project is structurally significant because it
#   was the **first mature pure-Go Lucene-equivalent** — every
#   prior Go attempt at a search engine either:
#     (a) cgo-wrapped libxapian or libCLucene (defeating the
#         single-binary deployment benefit of Go),
#     (b) called out to an external Elasticsearch / Solr /
#         OpenSearch HTTP API (vendor coupling + extra
#         deployment surface),
#     (c) implemented a toy inverted index that didn't survive
#         past prototype.
#   bleve was the first that matched Lucene feature-for-
#   feature on the index + query path (BM25, phrase queries,
#   regex, fuzzy, faceting, geo, language analyzers,
#   highlighting) while shipping as a single static-linked Go
#   binary with no external runtime dependency.
#
#   Verified via:
#     gh api repos/akhenakh/gozim/contents/go.mod
#       → module github.com/akhenakh/gozim
#       → require github.com/blevesearch/bleve v1.0.14  (DIRECT)
#       → require github.com/PuerkitoBio/goquery v1.8.0
#       → require github.com/hashicorp/golang-lru v0.5.4
#     raw.githubusercontent.com akhenakh/gozim main
#         cmd/gozimhttpd/main.go
#       → port      = flag.Int("port", -1, ...)
#       → zimPath   = flag.String("path", "", ...)
#       → indexPath = flag.String("index", "", ...)
#       → mmap      = flag.Bool("mmap", false, ...)
#       → cpuprofile= flag.String("cpuprofile", "", ...)
#       → import "github.com/blevesearch/bleve"
#       → import _ "github.com/blevesearch/bleve/analysis/
#                       lang/{ar,cjk,ckb,en,fa,fr,hi,it,pt}"
#       → import _ "github.com/blevesearch/bleve/index/store/
#                       goleveldb"
#     raw.githubusercontent.com akhenakh/gozim main
#         cmd/gozimindex/main.go
#       → path         = flag.String("path", "", ...)
#       → indexPath    = flag.String("index", "", ...)
#       → cpuprofile   = flag.String("cpuprofile", "", ...)
#       → lang         = flag.String("lang", "", ...)
#       → batchSize    = flag.Int("batchsize", 1000, ...)
#       → indexContent = flag.Bool("content", false, ...)
#       → bleve.Config.DefaultKVStore = "goleveldb"
#       → mapping := bleve.NewIndexMapping()
#       → fieldMapping := bleve.NewTextFieldMapping()
#
#   This entry is the Go=181 leader bump that continues Axis 126
#   (pure-Rust + pure-Go + pure-Lucene full-text search /
#   inverted-index engine taxonomy) at 2/0/0 following R1076
#   _bayard (Rust=181 OPENED via mosuka/bayard on
#   quickwit-oss/tantivy 0.18 + lindera-tantivy 0.16.2 CJK
#   morphological analyzers).  TS-Node=181 closing pair on
#   deck for R1078 via a TS/JS consumer of the canonical
#   JavaScript-side Lucene port (the natural pick is
#   **MinSearch** by lucaong, the dominant pure-JS in-memory
#   inverted-index library, or **lunr.js** by olivernn, the
#   classic JS Lucene port that pre-dates MiniSearch and is
#   still widely embedded in static-site search via Hugo +
#   Jekyll + Eleventy).
#
#   No completion for `gozimhttpd` or `gozimindex` ships with
#   Apple zsh (/usr/share/zsh/*/functions) or Homebrew zsh-
#   completions (/opt/homebrew/share/zsh/site-functions) —
#   confirmed absent.
# ============================================================================

_gozimhttpd() {
    case "$service" in
        gozimhttpd)
            _arguments -s -S \
                '-port[port to listen to (read HOST env if unset; default 8080)]:port:' \
                '-path[path for the ZIM file (REQUIRED)]:zim file:_files -g "*.zim"' \
                '-index[path for the Bleve index directory (enables /search)]:index dir:_files -/' \
                '-mmap[use mmap for ZIM file access]' \
                '-cpuprofile[write CPU profile to file]:profile file:_files' \
                '-h[show help]' \
                '-help[show help]'
            ;;
        gozimindex)
            _arguments -s -S \
                '-path[path for the ZIM file (REQUIRED)]:zim file:_files -g "*.zim"' \
                '-index[path for the Bleve index directory (REQUIRED)]:index dir:_files -/' \
                '-lang[Bleve language analyzer]:lang:(ar bg ca ckb cjk cs el en eu fa fr ga gl hi hy id in it ja pt)' \
                '-batchsize[size of Bleve index batches (default 1000)]:n:' \
                '-content[EXPERIMENTAL: index full HTML content of each article]' \
                '-cpuprofile[write CPU profile to file]:profile file:_files' \
                '-h[show help]' \
                '-help[show help]'
            ;;
    esac
}

_gozimhttpd "$@"
