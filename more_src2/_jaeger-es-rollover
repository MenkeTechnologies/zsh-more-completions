#compdef jaeger-es-rollover
# _jaeger-es-rollover — Jaeger Elasticsearch index rollover manager (jaegertracing/jaeger)
# upstream: https://github.com/jaegertracing/jaeger
# Subcommands + flags from cmd/es-rollover/{main,app}/{flags,init,rollover,lookback}.go on tip.

_jaeger-es-rollover() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--index-prefix=[Jaeger index prefix]:prefix:' \
        '--archive[handle archive indices]' \
        '--es.username=[Elasticsearch username]:user:' \
        '--es.password=[Elasticsearch password]:pass:' \
        '--es.use-ilm[manage indices via ILM]' \
        '--es.ilm-policy-name=[ILM policy name]:name:' \
        '--timeout=[master-node response timeout (s)]:n:' \
        '--skip-dependencies[skip dependencies index rollover]' \
        '--adaptive-sampling[rollover the adaptive-sampling index]' \
        '--es.tls.enabled[enable TLS for Elasticsearch]' \
        '--es.tls.ca=[CA cert file]:file:_files' \
        '--es.tls.cert=[client cert file]:file:_files' \
        '--es.tls.key=[client key file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                init:'create Jaeger indices and aliases'
                rollover:'roll over the write alias to a new index'
                lookback:'remove old indices from the read alias'
            )
            _describe -t commands 'jaeger-es-rollover command' cmds
            ;;
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--shards=[number of shards]:n:' \
                        '--replicas=[number of replicas]:n:' \
                        '--priority-span-template=[ESv8 jaeger-span template priority]:n:' \
                        '--priority-service-template=[ESv8 jaeger-service template priority]:n:' \
                        '--priority-dependencies-template=[ESv8 jaeger-dependencies template priority]:n:' \
                        '--priority-sampling-template=[ESv8 jaeger-sampling template priority]:n:' \
                        ':es-url:_urls'
                    ;;
                rollover)
                    _arguments \
                        '--conditions=[rollover conditions JSON]:json:' \
                        ':es-url:_urls'
                    ;;
                lookback)
                    _arguments \
                        '--unit=[lookback unit]:unit:(seconds minutes hours days weeks months years)' \
                        '--unit-count=[lookback unit count]:n:' \
                        ':es-url:_urls'
                    ;;
            esac
            ;;
    esac
}

_jaeger-es-rollover "$@"
