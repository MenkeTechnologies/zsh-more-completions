#compdef flock-cli
# _flock-cli — util-linux flock manage file locks from shell scripts CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_flock-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[command]:str:' \
        '--command=+[command]:str:' \
        '-E+[exit status]:n:' \
        '--conflict-exit-code=+[exit status]:n:' \
        '-e[exclusive lock]' \
        '--exclusive[exclusive lock]' \
        '-F[no fork]' \
        '--no-fork[no fork]' \
        '-n[non blocking]' \
        '--nonblock[non blocking]' \
        '-o[close fd before running command]' \
        '--close[close fd before running command]' \
        '-s[shared lock]' \
        '--shared[shared lock]' \
        '-u[unlock]' \
        '--unlock[unlock]' \
        '-w+[timeout seconds]:str:' \
        '--timeout=+[timeout seconds]:str:' \
        '--fcntl[use fcntl]' \
        '--ofd[use OFD locks]' \
        '--verbose[verbose]' \
        '*:file or fd command:_files'
}

_flock-cli "$@"
