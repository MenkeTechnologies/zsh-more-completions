#compdef gvedit
# Documentation: https://www.graphviz.org/doc/info/command.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files -g "*.{dot,gv}"' && ret=0

return ret
