#compdef nix-instantiate
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-instantiate
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--parse[parse only, print AST]' \
  '--eval[parse and evaluate]' \
  '--find-file[find file in search path]' \
  '--strict[evaluate strictly]' \
  '--raw[print evaluation result as raw string]' \
  '--json[output as JSON]' \
  '--xml[output as XML]' \
  '--read-write-mode[evaluate in read-write mode]' \
  '--arg[set function argument]:name: :value:' \
  '--argstr[set function argument as string]:name: :value:' \
  '(-A --attr)'{-A,--attr}'[select attribute]:attribute:' \
  '(-E --expr)'{-E,--expr}'[evaluate expression]:expression:' \
  '(-I --include)'{-I,--include}'[add path to search path]:path:_files' \
  '--add-root[add a GC root for derivations]:path:_files' \
  '--indirect[use indirect GC root]' \
  '*:nix files:_files -g "*.nix"' && ret=0

return ret
