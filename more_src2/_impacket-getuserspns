#compdef impacket-getuserspns
# Documentation: https://github.com/fortra/impacket/blob/master/examples/GetUserSPNs.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-getuserspns: Kerberoasting (TGS for SPN-enabled users).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-target-domain[domain to query if different from user domain]:domain:' \
  '-no-preauth[account without preauth for ST request]:user:' \
  '-stealth[remove SPN filter from LDAP query]' \
  '-machine-only[query machine accounts only]' \
  '-usersfile[file with usernames, one per line]:file:_files' \
  '-request[request TGS for users (JtR/hashcat format)]' \
  '-request-user[request TGS for specific user]:user:' \
  '-request-machine[request TGS for specific machine SPN]:machine:' \
  '-save[save TGS to disk in ccache format]' \
  '-outputfile[output filename for hashes]:file:_files' \
  '-no-rc4[do not force RC4-HMAC for TGT]' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-dc-host[domain controller hostname]:host:_hosts' \
  '*::positional:_files' && ret=0
return ret
