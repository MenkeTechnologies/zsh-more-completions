#compdef kafkacat kcat
# Documentation: https://github.com/edenhill/kcat/blob/master/kcat.c (usage())
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kafkacat was renamed to kcat. Removed invented -Y (Go-like format) and
# -U (unionize offsets); corrected -Z (send empty as NULL, not print NULL)
# and -o enum; added real -M -d -E -z -k -H -O flags.

local -a arguments

arguments=(
  '-P[Producer mode]'
  '-C[Consumer mode]'
  '-G[High-level KafkaConsumer group mode]:group id:'
  '-L[Metadata List mode]'
  '-Q[Query mode]'
  '-M[Start Mock cluster]:broker count:'
  '-t[Topic to consume from, produce to, or list]:topic:'
  '-p[Partition]:partition:'
  '-b[Bootstrap broker(s) host[\:port]]:brokers:'
  '-D[Message delimiter string]:delim:'
  '-K[Key delimiter (same format as -D)]:delim:'
  '-c[Limit message count]:count:'
  '-m[Metadata request timeout (seconds)]:seconds:'
  '-F[Read configuration properties from file]:file:_files'
  '-X[Set librdkafka configuration property (or list/dump)]:property:'
  '-d[Enable librdkafka debugging]:debug contexts:'
  '-q[Be quiet (verbosity set to 0)]'
  '-v[Increase verbosity]'
  '-E[Do not exit on non-fatal error]'
  '-V[Print version]'
  '-h[Print usage help]'
  '-z[Message compression]:codec:(snappy gzip lz4)'
  '-k[Use a fixed key for all messages]:key:'
  '*-H[Add a message header (header=value)]:header:'
  '-l[Send messages from a file separated by delimiter]'
  '-T[Output sent messages to stdout, acting like tee]'
  '-Z[Send empty messages as NULL messages]'
  '-o[Offset to start consuming from]:offset:'
  '-e[Exit successfully when last message received]'
  '-f[Output formatting string]:format:'
  '-J[Output with JSON envelope]'
  '-s[Deserialize keys/values (key=<serdes> or value=<serdes>)]:serdes spec:'
  '-r[Schema registry URL]:url:'
  '-O[Print message offset using -K delimiter]'
  '-u[Unbuffered output]'
)

_arguments -s $arguments
