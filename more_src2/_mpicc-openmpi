#compdef mpicc-openmpi
# Documentation: https://docs.open-mpi.org/en/v5.0.x/man-openmpi/man1/ompi-wrapper-compiler.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Pass-through wrapper using
# --showme[:compile|:link|:command|:incdirs|:libdirs|:libs|:version|:help].

# mpicc-openmpi: Open MPI C compiler wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '--showme[show full compile/link command]' \
  '--showme:compile[show compile flags]' \
  '--showme:link[show link flags]' \
  '--showme:command[show underlying command]' \
  '--showme:incdirs[show include directories]' \
  '--showme:libdirs[show library directories]' \
  '--showme:libs[show libraries]' \
  '--showme:version[show Open MPI version]' \
  '--showme:help[show help]' \
  '*:C source:_files -g "*.(c|h|o|a|so)(-.)"' && ret=0
return ret
