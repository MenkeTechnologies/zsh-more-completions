#compdef envinfo
# Documentation: https://github.com/tabrindle/envinfo

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--system[print operating system, CPU, memory and shell info]' \
  '--binaries[print binary versions (Node, npm, Yarn, pnpm, etc.)]' \
  '--browsers[print installed browser versions]' \
  '--languages[print installed language versions]' \
  '--managers[print package manager versions]' \
  '--utilities[print utility versions (Make, CMake, GCC, etc.)]' \
  '--servers[print server software versions (Apache, Nginx)]' \
  '--SDKs[print SDK versions (iOS, Android)]' \
  '--IDEs[print IDE versions]' \
  '--virtualization[print virtualization software versions (Docker, etc.)]' \
  '--npmPackages[print local npm package versions]:packages:' \
  '--npmGlobalPackages[print global npm package versions]:packages:' \
  '--duplicates[print duplicate npm packages]' \
  '--fullTree[traverse entire node_modules tree]' \
  '--json[output as JSON]' \
  '--markdown[output as Markdown]' \
  '--console[output to console (default)]' \
  '--clipboard[copy output to clipboard]' \
  '--preset=[use preset configuration]:preset:(react expo)' \
  '--raw[output raw data without formatting]' \
  && return 0
