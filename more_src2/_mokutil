#compdef mokutil
# _mokutil — Gary Lin mokutil Linux utility to manage Machine Owner Key MOK store used with Secure Boot shim (Lcp team, C); custom argparse
# upstream: https://github.com/lcp/mokutil

_mokutil() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--list-enrolled[list enrolled keys]' \
        '-l[list enrolled keys]' \
        '--list-new[list new keys to be enrolled]' \
        '-N[list new keys to be enrolled]' \
        '--list-delete[list keys to be deleted]' \
        '-D[list keys to be deleted]' \
        '--import=+[key file]:file:_files -g "*.der *.crt *.pem *.cer"' \
        '-i+[key file]:file:_files -g "*.der *.crt *.pem *.cer"' \
        '--delete=+[key file]:file:_files -g "*.der *.crt *.pem *.cer"' \
        '-d+[key file]:file:_files -g "*.der *.crt *.pem *.cer"' \
        '--revoke-import[revoke import]' \
        '--revoke-delete[revoke delete]' \
        '--export[export keys to files]' \
        '-x[export keys to files]' \
        '--password[change MOK password]' \
        '-p[change MOK password]' \
        '--clear-password[clear MOK password]' \
        '-c[clear MOK password]' \
        '--disable-validation[disable signature validation]' \
        '--enable-validation[enable signature validation]' \
        '--sb-state[show secure boot state]' \
        '--test-key=+[key file]:file:_files' \
        '-t+[key file]:file:_files' \
        '--reset[reset MOK list]' \
        '--generate-hash=+[password]:str:' \
        '-g+[password]:str:' \
        '--hash-file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '--root-pw[use root password]' \
        '-P[use root password]' \
        '--simple-hash[simple hash]' \
        '-s[simple hash]' \
        '--ignore-db[ignore db]' \
        '--use-db[use db]' \
        '--mokx[manage MOKX blacklist]' \
        '-X[manage MOKX blacklist]' \
        '--timeout=+[seconds]:n:' \
        '--set-verbosity=+[bool]:b:(true false)' \
        '--pk[manage UEFI PK]' \
        '--kek[manage UEFI KEK]' \
        '--db[manage UEFI db]' \
        '--dbx[manage UEFI dbx]'
}

_mokutil "$@"
