#compdef karbon
# _karbon — Calligra Karbon vector graphics editor (KDE/calligra)
# upstream: https://github.com/KDE/calligra
# Flags from karbon/main.cpp (KoApplication — standard Qt/KDE options + files).

_karbon() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--help-all[show help including Qt/KDE options]'
        '(- *)'{-v,--version}'[show version]'
        '--author[print application author info]'
        '--license[print license info]'
        '--print[print the document and exit]'
        '--print-and-exit[print the document and exit immediately]'
        '--template[create a new document from this template]'
        '--profile=[output a benchmark profile]:profile:'
        '*:Karbon document:_files -g "*.{karbon,svg,svgz,wpg,wmf,emf,eps,ps,pdf,xfig,fig,odg,fodg,otg}"'
    )
    _arguments -s $args
}

_karbon "$@"
