#compdef q
# Documentation: https://github.com/harelba/q/blob/master/doc/USAGE.markdown
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-V --verbose)'{-V,--verbose}'[output debug information]' \
  '(-S --save-db-to-disk)'{-S+,--save-db-to-disk=}'[persist db to sqlite file]:file:_files' \
  '(-C --caching-mode)'{-C+,--caching-mode=}'[caching mode]:mode:(none read readwrite)' \
  '--overwrite-qsql=[overwrite existing .qsql cache files]:value:' \
  '--max-attached-sqlite-databases=[concurrent db attach limit]:n:' \
  '(-H --skip-header)'{-H,--skip-header}'[input file has header]' \
  '(-d --delimiter)'{-d+,--delimiter=}'[input delimiter]:char:' \
  '(-p --pipe-delimited)'{-p,--pipe-delimited}'[input uses pipe delimiter]' \
  '(-t --tab-delimited)'{-t,--tab-delimited}'[input is tab delimited]' \
  '(-e --encoding)'{-e+,--encoding=}'[input encoding]:encoding:' \
  '(-z --gzipped)'{-z,--gzipped}'[input data is gzipped]' \
  '(-A --analyze-only)'{-A,--analyze-only}'[analyze input without executing query]' \
  '(-m --mode)'{-m+,--mode=}'[input parsing mode]:mode:(fluffy relaxed strict)' \
  '(-c --column-count)'{-c+,--column-count=}'[column count]:n:' \
  '(-k --keep-leading-whitespace)'{-k,--keep-leading-whitespace}'[preserve leading spaces]' \
  '--disable-double-double-quoting[disable "" escape sequence]' \
  '--disable-escaped-double-quoting[disable backslash double-quote escape]' \
  '--as-text[treat all columns as text]' \
  '(-w --input-quoting-mode)'{-w+,--input-quoting-mode=}'[input quoting mode]:mode:(all minimal none)' \
  '(-M --max-column-length-limit)'{-M+,--max-column-length-limit=}'[max column length]:n:' \
  '(-U --with-universal-newlines)'{-U,--with-universal-newlines}'[handle universal newlines]' \
  '(-D --output-delimiter)'{-D+,--output-delimiter=}'[output field delimiter]:char:' \
  '(-P --pipe-delimited-output)'{-P,--pipe-delimited-output}'[output with pipe delimiter]' \
  '(-T --tab-delimited-output)'{-T,--tab-delimited-output}'[output with tab delimiter]' \
  '(-O --output-header)'{-O,--output-header}'[output header line]' \
  '(-b --beautify)'{-b,--beautify}'[beautify output]' \
  '(-f --formatting)'{-f+,--formatting=}'[output column formatting]:spec:' \
  '(-E --output-encoding)'{-E+,--output-encoding=}'[output encoding]:encoding:' \
  '(-W --output-quoting-mode)'{-W+,--output-quoting-mode=}'[output quoting mode]:mode:(all minimal nonnumeric none)' \
  '(-L --list-user-functions)'{-L,--list-user-functions}'[list user-defined functions]' \
  '(-q --query-filename)'{-q+,--query-filename=}'[read query from file]:file:_files' \
  '(-Q --query-encoding)'{-Q+,--query-encoding=}'[query encoding]:encoding:' \
  '*:query or file:_files' && ret=0
return ret
