#compdef krunner5
# Documentation: https://invent.kde.org/plasma/plasma-workspace/-/blob/master/krunner/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream plasma-workspace krunner/main.cpp QCommandLineParser
# (same binary as krunner, versioned alias). Fixed #compdef collision:
# this file previously also claimed krunner6, duplicating _krunner6.

# krunner5: KDE Plasma launcher (KF5 build)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --clipboard)'{-c,--clipboard}'[use the clipboard contents as query]' \
  '(-d --daemon)'{-d,--daemon}'[start KRunner in the background, do not show it]' \
  '--replace[replace an existing instance]' \
  '--runner=[show only results from the given plugin]:runner:' \
  '--list[list available plugins]' \
  '*:query:' && ret=0
return ret
