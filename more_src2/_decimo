local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# Rounding-mode enum values from choices string
# at main.mojo:84
local -a rounding_modes=(
  'half-even:banker rounding (default)'
  'half-up:traditional rounding'
  'half-down:round half toward zero'
  'up:always round away from zero'
  'down:always round toward zero (truncate)'
  'ceiling:always round toward positive infinity'
  'floor:always round toward negative infinity'
)

# 10 spec fields (1 positional + 5 options + 4
# flags) decoded source-direct from DecimoArgs
# struct at main.mojo:34-104.
_arguments -s -S \
  '(- *)'{-h,--help}'[display argmojo auto-generated help]' \
  '(-F --file)'{-F+,--file=}'[evaluate expressions from a file (one per line)]:expressions file:_files' \
  '(-P --precision)'{-P+,--precision=}'[number of significant digits (1-1,000,000,000; default 50)]:digits:' \
  '(-R --rounding-mode)'{-R+,--rounding-mode=}'[rounding mode for the final result]:mode:->rounding_modes' \
  '--delimiter=[digit-group separator (e.g. "_" gives 1_234.567_89)]:char:' \
  '(-S --scientific -E --engineering)'{-S,--scientific}'[output in scientific notation (mutex with -E)]' \
  '(-S --scientific -E --engineering)'{-E,--engineering}'[output in engineering notation, exponent multiple of 3]' \
  '--pad[pad trailing zeros to the specified precision]' \
  '(-A --about --info)'{-A,--about}'[display version, author, license, and links]' \
  '(-A --about --info)--info[alias for --about]' \
  '*:math expression (e.g. "1+2*sqrt(3)" or "sin(pi/2)"):' && ret=0

case $state in
  rounding_modes)
    _describe -t rounding_modes 'rounding mode' rounding_modes && ret=0
    ;;
esac

return ret
