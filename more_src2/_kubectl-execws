#compdef kubectl-execws
# Documentation: https://github.com/jpts/kubectl-execws
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--as=[impersonate another user]:user:' \
  '(-c --container)'{-c+,--container=}'[container name]:container:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '(-v --loglevel)'{-v+,--loglevel=}'[set loglevel (default 2)]:level:' \
  '(-n --namespace)'{-n+,--namespace=}'[set namespace]:namespace:' \
  "--no-sanity-check[don't make preflight request to ensure pod exists]" \
  '--node-direct-exec[partially bypass the API server using the kubelet API]' \
  '--node-direct-exec-ip=[node IP to use with direct-exec feature]:ip:' \
  "(-k --skip-tls-verify)"{-k,--skip-tls-verify}"[don't perform TLS certificate verification]" \
  '(-i --stdin)'{-i,--stdin}'[pass stdin to container]' \
  '(-t --tty)'{-t,--tty}'[stdin is a TTY]' \
  '*:pod and command:_default'
