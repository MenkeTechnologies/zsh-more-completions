#compdef kafka-groups
# Documentation: https://kafka.apache.org/documentation/ (kafka-groups.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '--bootstrap-server[REQUIRED: The Kafka server to connect to]:host\:port:'
    '--command-config[Property file containing configs to be passed to Admin Client]:file:_files'
    '--consumer[Filter the groups to show all kinds of consumer groups]'
    "--group-type[Filter the groups based on group type]:type:(classic consumer share streams)"
    '--help[Print usage information]'
    '--list[List the groups]'
    '--protocol[Filter the groups based on protocol type]:protocol:'
    '--share[Filter the groups to show share groups]'
    '--streams[Filter the groups to show streams groups]'
    '--version[Display Kafka version]'
)

_arguments -s -S $arguments
