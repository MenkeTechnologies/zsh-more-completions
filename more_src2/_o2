#compdef o2
# Documentation: https://github.com/openobserve/o2-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'list:display resources'
  'get:retrieve a specific resource'
  'create:add a new resource'
  'update:modify an existing resource'
  'delete:remove a resource'
  'configure:manage profiles and credentials'
  'organization:organization resource subcommands'
  'dashboard:dashboard resource subcommands'
  'template:template resource subcommands'
  'destination:destination resource subcommands'
  'dest:destination resource subcommands (alias)'
  'pipeline:pipeline resource subcommands'
  'function:function resource subcommands'
  'alert:alert resource subcommands'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--profile=[use specific profile]:profile:' \
  '--org=[override organization]:org:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table json yaml wide)' \
  '--config=[config file]:file:_files -g "*.{yaml,yml}"' \
  '1: :->verb' \
  '*::arg:->args' && ret=0

case $state in
  (verb) _describe -t verbs 'o2 verb' verbs && ret=0 ;;
  (args)
    case $line[1] in
      (create|list|get|update|delete)
        _arguments \
          '*::resource:(template dest destination dashboard pipeline function alert organization)' \
          '-f+[input YAML/JSON file]:file:_files' \
          '--type=[filter by type]:type:' \
          '--folder=[filter by folder]:folder:' \
          '--enabled-only[show only enabled resources]' && ret=0 ;;
    esac ;;
esac

return ret
