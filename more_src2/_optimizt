#
# THE optimizt CLI
#
# optimizt is a single-command CLI built on
# commander v9.x.  Invocation:
#   optimizt [options] <dir> [file ...]
#
# Arguments:
#   <dir> [files...]                paths to optimize
#                                   (directories +
#                                   files + glob
#                                   patterns supported)
#
# Options:
#   --avif                          create AVIF and exit
#                                   (companion-only mode;
#                                   does NOT modify originals)
#   --webp                          create WebP and exit
#                                   (companion-only mode;
#                                   does NOT modify originals)
#   -f, --force                     force create AVIF and
#                                   WebP even when the
#                                   companion would be
#                                   larger than original
#   -l, --lossless                  perform lossless
#                                   optimizations (no
#                                   perceptual quality loss)
#   -v, --verbose                   verbose output (per-file
#                                   before/after stats)
#   -c, --config <path>             custom config file
#                                   (overrides defaults)
#   -o, --output <path>             write output to a
#                                   directory instead of
#                                   in-place
#   -V, --version                   show version
#
# Common invocations:
#   # Optimize all images in current dir + subdirs
#   # in-place (recompresses PNGs, JPEGs, GIFs, SVGs)
#   optimizt .
#
#   # Generate AVIF companions for every JPEG/PNG in src/
#   # (originals untouched)
#   optimizt --avif src/
#
#   # Generate WebP companions
#   optimizt --webp src/
#
#   # Generate BOTH AVIF and WebP for picture-element
#   # workflow
#   optimizt --avif src/ && optimizt --webp src/
#
#   # Lossless mode (e.g. for archival assets)
#   optimizt -l --avif src/
#
#   # Force generate even when companion is larger
#   optimizt -f --avif src/
#
#   # Verbose progress with per-file stats
#   optimizt -v src/
#
#   # Custom encoder configuration
#   optimizt -c ./optimizt.config.cjs src/
#
#   # Output to separate directory (preserve originals)
#   optimizt -o dist/optimized src/
#
#   # Glob patterns
#   optimizt 'src/**/*.{png,jpg}'
#
#   # Mixed positional args
#   optimizt src/icons logo.png photo.jpg
#
#   # CI pipeline: optimize + emit AVIF + WebP + report
#   optimizt -v src/ \
#     && optimizt -v --avif src/ \
#     && optimizt -v --webp src/
#
# OPTIONS (sourced directly from
# https://github.com/funbox/optimizt/blob/main/cli.js):
#
#   --avif                          create AVIF and exit
#   --webp                          create WebP and exit
#   -f, --force                     force create AVIF and WebP
#   -l, --lossless                  perform lossless optimizations
#   -v, --verbose                   be verbose
#   -c, --config <path>             custom configuration file
#   -o, --output <path>             output directory
#   -V, --version                   print version
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--avif[create AVIF companions and exit]' \
    '--webp[create WebP companions and exit]' \
    '(-f --force)'{-f,--force}'[force create AVIF and WebP even when larger]' \
    '(-l --lossless)'{-l,--lossless}'[perform lossless optimizations]' \
    '(-v --verbose)'{-v,--verbose}'[be verbose (per-file before/after stats)]' \
    '(-c --config)'{-c,--config}'=[use custom configuration file]:config:_files' \
    '(-o --output)'{-o,--output}'=[write output to directory]:output directory:_directories' \
    '*:image file or directory:_files -g "*.(png|jpg|jpeg|gif|svg|webp|avif|tif|tiff|PNG|JPG|JPEG|GIF|SVG|WEBP|AVIF|TIF|TIFF)" -/' \
    && ret=0

return ret
