#compdef gshhg
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/gshhg/gshhg.html
# Source: GenericMappingTools/gmt supplements/gshhg — convert GSHHG / WDBII binary files to GMT tables.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[min polygon area]:value:_default' \
    '-G[Octave/Matlab format (NaN-segmented)]' \
    '-I+[extract polygon by ID (c=continents)]:id:_default' \
    '-L[segment headers only (no data)]' \
    '-N+[hierarchical level filter]:level:_default' \
    '-Q+[river-lake handling]:opts:(e i)' \
    '*-V[verbose (stackable)]' \
    '-bo+[binary output format]:format:_default' \
    '-do+[NaN output → nodata]:value:_default' \
    '-o+[output column selection]:cols:_default' \
    '*:GSHHG binary file:_files -g "*.(b|gshhs_*.b|wdb_*.b)(-.)"' \
    && ret=0

return ret
