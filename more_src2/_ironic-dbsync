#compdef ironic-dbsync
# Documentation: https://docs.openstack.org/ironic/latest/cli/ironic-dbsync.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# ironic-dbsync: DB schema management
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create_schema:create database tables based on the most current version'
  'online_data_migrations:migrate database objects to their most recent versions'
  'revision:create a new revision file'
  'stamp:stamp the revision table with the version specified'
  'upgrade:upgrade existing database tables'
  'version:output the current database version'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "(-d --debug)"{-d,--debug}"[set log level to debug]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'ironic-dbsync command' commands && ret=0
    ;;
  args)
    case $line[1] in
      online_data_migrations)
        _arguments \
          '--max-count=[maximum number of objects to migrate]:number:' \
          '*--option=[additional migration parameter MIGRATION.KEY=VALUE]:option:' && ret=0
        ;;
      revision)
        _arguments \
          '(-m --message)'{-m,--message=}'[comment to add to the revision]:message:' \
          '--autogenerate[compare table metadata with the database]' && ret=0
        ;;
      stamp)
        _arguments '--revision=[revision number to stamp]:revision:' && ret=0
        ;;
      upgrade)
        _arguments '--revision=[target upgrade version]:revision:' && ret=0
        ;;
    esac
    ;;
esac
return ret
