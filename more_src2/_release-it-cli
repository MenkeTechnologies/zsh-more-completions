#compdef release-it-cli
# Documentation: https://github.com/release-it/release-it
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

(( $+functions[_release-it] )) || autoload -Uz _release-it 2>/dev/null
if (( $+functions[_release-it] )); then
  _release-it "$@"
  return
fi

_arguments \
  '*::release-it arg:_files' && ret=0

return ret
