#compdef radiusd
# _radiusd — OpenBSD radiusd (RADIUS protocol server daemon; enable via rcctl enable radiusd; reads /etc/radiusd.conf; pluggable modules under /usr/libexec/radiusd handle auth methods like radius/eap/ipcp/file)
# upstream: https://github.com/openbsd/src (usr.sbin/radiusd)
# Flags from usr.sbin/radiusd/radiusd.8 on tip.

_radiusd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-f+[config file (default /etc/radiusd.conf)]:file:_files'
}

_radiusd "$@"
