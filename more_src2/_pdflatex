#compdef pdflatex pdftex latex tex luatex lualatex etex pdfetex
# _pdflatex — TeX Live pdflatex / latex / luatex / lualatex / etex (TeX engines; -interaction selects how to handle errors, -output-format pdf|dvi, -output-directory, -synctex, -shell-escape gates \write18, -jobname overrides aux/log filename, -file-line-error formats errors)
# upstream: https://tug.org/svn/texlive (Build/source/texk/web2c/pdftexdir)
# Flags from web2c pdftexdir/pdftex.web on tip.

_pdflatex() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-fmt+[format name]:fmt:' \
        '-interaction+[error mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
        '-output-format+[output format]:fmt:(pdf dvi)' \
        '-output-directory+[output dir]:dir:_files -/' \
        '-output-comment+[output comment]:text:' \
        '-aux-directory+[auxiliary file dir]:dir:_files -/' \
        '-jobname+[job name (no extension)]:name:' \
        '-synctex+[synctex level]:level:(-1 0 1)' \
        '-file-line-error[show errors as file:line:msg]' \
        '-no-file-line-error[plain error format]' \
        '-shell-escape[enable \\write18]' \
        '-no-shell-escape[disable \\write18]' \
        '-shell-restricted[restricted \\write18]' \
        '-recorder[create .fls]' \
        '-parse-first-line[parse first line for options]' \
        '-no-parse-first-line[do not parse first line]' \
        '-mktex+[on-the-fly mktex]:fmt:(fmt mf tex tfm)' \
        '-no-mktex+[disable on-the-fly mktex]:fmt:(fmt mf tex tfm)' \
        '-enc[support enc-Tex]' \
        '-etex[enable e-TeX extensions]' \
        '-translate-file+[input translation file]:file:_files' \
        '-default-translate-file+[default translation file]:file:_files' \
        '-progname+[program name]:name:' \
        '-ini[treat as ini phase]' \
        '-draftmode[no PDF output]' \
        '-8bit[8-bit clean]' \
        '*:tex file:_files -g "*.(tex|ltx|latex)"'
}

_pdflatex "$@"
