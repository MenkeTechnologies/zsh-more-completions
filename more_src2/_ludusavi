#compdef ludusavi
# Documentation: https://github.com/mtkennerly/ludusavi/blob/master/docs/cli.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--config=[custom configuration directory]:directory:_directories' \
  '--no-manifest-update[skip automatic manifest checks]' \
  '--try-manifest-update[ignore manifest update errors]' \
  '--debug[max logging and open log folder]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'backup:back up game save data'
      'restore:restore game save data'
      'complete:generate shell completion scripts'
      'backups:show and manage existing backups'
      'find:locate game titles in the manifest'
      'manifest:manage the game database'
      'config:configure ludusavi settings'
      'cloud:synchronize backups to cloud storage'
      'wrap:execute backup/restore around game launch'
      'api:process bulk requests via JSON input'
      'schema:display JSON/YAML schemas'
      'gui:launch the graphical interface'
      'help:display help information'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
