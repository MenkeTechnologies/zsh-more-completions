#compdef mpd
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mpd.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (and `mpd --help` locally).

# Zsh completion for mpd - Music Player Daemon

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose log mode]' \
  '--stderr[print messages to stderr]' \
  '--no-daemon[do not detach from console]' \
  '--kill[kill the running mpd instance]' \
  '--no-config[do not read config file]' \
  '1:config file:_files' \
  && ret=0

return ret
