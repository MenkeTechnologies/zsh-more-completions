#compdef pamaddnoise
# Documentation: man pamaddnoise (Netpbm)
# Source: add a chosen noise distribution to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-type+[noise type]:type:(gaussian multiplicative_gaussian impulse laplacian poisson)' \
    '-sigma1+[gaussian sigma1]:value:' \
    '-sigma2+[gaussian sigma2]:value:' \
    '-mgsigma+[multiplicative gaussian sigma]:value:' \
    '-tolerance+[impulse tolerance ratio]:ratio:' \
    '-lsigma+[laplacian sigma]:value:' \
    '-lambda+[poisson lambda]:value:' \
    '-seed+[random seed]:int:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
