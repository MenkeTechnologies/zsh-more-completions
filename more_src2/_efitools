#compdef efitools
# Documentation: https://git.kernel.org/pub/scm/linux/kernel/git/jejb/efitools.git/about/
# Reference accessed: 2026-05-17
# Verified: upstream efitools repo at the URL above (Matthew Garrett / James Bottomley).

# efitools umbrella: EFI variable / Secure Boot tools (sign-efi-sig-list, hash-to-efi-sig-list, cert-to-efi-sig-list, ...)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'cert-to-efi-sig-list:convert x509 cert to EFI sig list'
  'sign-efi-sig-list:sign an EFI sig list'
  'hash-to-efi-sig-list:add file hash to EFI sig list'
  'efi-readvar:read EFI variables'
  'efi-updatevar:update EFI variables'
  'KeyTool.efi:run KeyTool.efi inside EFI shell'
  'flash-var:flash a single variable'
  'efi-decode-cert:decode an EFI cert'
  'mokutil:MOK signing helper'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'efitools command' commands && ret=0 ;;
esac
return ret
