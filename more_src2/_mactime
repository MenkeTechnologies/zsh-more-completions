#compdef mactime
# Documentation: https://www.sleuthkit.org/sleuthkit/man/mactime.html
# Source: sleuthkit/sleuthkit man/mactime.1 — create an ASCII timeline of file activity from body files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[location of body file (fls -m / ils -m output)]:body file:_files' \
    '-g[location of group file]:group file:_files' \
    '-p[location of passwd file]:passwd file:_files' \
    '-i[location of day/hour index file to write to]:index spec:' \
    '-d[display timeline and index files in comma delimited format]' \
    '-h[display header info about the session]' \
    '-V[display version to stdout]' \
    '-m[display month as a number instead of name]' \
    '-y[display date in ISO 8601 format]' \
    '-z[timezone where data was collected (or "list" for valid zones)]:zone:' \
    '*:date range:_default' \
    && ret=0

return ret
