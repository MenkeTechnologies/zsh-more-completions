#compdef llama-simple llama-simple-chat llama-lookup-merge llama-convert-llama2c-to-ggml llama-vdot llama-q8dot
# Documentation: source-direct extraction from upstream
# ggml-org/llama.cpp
#   examples/simple/simple.cpp:                     -m -n -ngl + [prompt]
#   examples/simple-chat/simple-chat.cpp:           -m -c -ngl
#   examples/lookup/lookup-merge.cpp:               positional .bin parts + -h
#   examples/convert-llama2c-to-ggml/convert-llama2c-to-ggml.cpp:
#                                                   --copy-vocab-from-model FNAME
#                                                   --llama2c-model FNAME (REQUIRED)
#                                                   --llama2c-output-model FNAME
#                                                   -h / --help
#   pocs/vdot/vdot.cpp:                             3 ints: nloop scalar useQ4_1
#   pocs/vdot/q8dot.cpp:                            2 ints: nloop type
# Binary-target mapping decoded source-direct from each
# directory's `CMakeLists.txt` `set(TARGET llama-<name>)` line.
# Reference accessed: 2026-05-30 via gh api.
# ggml-org llama.cpp R165 — 6-stem multi-binary harvest of the
# remaining llama.cpp companion examples / pocs not yet covered.
# Sister tools to the heavily-covered llama-cli / llama-server /
# llama-bench / llama-quantize / llama-perplexity / llama-batched
# / llama-batched-bench / llama-tokenize / llama-gguf /
# llama-gguf-split / llama-cvector-generator / llama-imatrix /
# llama-export-lora / llama-finetune / llama-eval-callback /
# llama-embedding / llama-lookahead / llama-lookup / llama-
# parallel / llama-passkey / llama-retrieval / llama-save-load-
# state / llama-speculative / llama-tts family already in the
# corpus.

case $service in

  llama-simple)
    # Hand-rolled argv-walking via strcmp(argv[i], "-X") loop.
    _arguments -s -S \
      '-m+[GGUF model file (required)]:file:_files -g "*.gguf"' \
      '-n+[number of tokens to predict (default 32)]:n:' \
      '-ngl+[number of layers to offload to GPU]:n:' \
      '*:prompt:'
    ;;

  llama-simple-chat)
    _arguments -s -S \
      '-m+[GGUF model file (required)]:file:_files -g "*.gguf"' \
      '-c+[context size (default 2048)]:n:' \
      '-ngl+[number of layers to offload to GPU]:n:'
    ;;

  llama-lookup-merge)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '*:n-gram lookup .bin parts (last argv is merged output):_files -g "*.bin"'
    ;;

  llama-convert-llama2c-to-ggml)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--copy-vocab-from-model=[GGUF llama-model or llama2.c vocab file to copy vocab from]:file:_files' \
      '--llama2c-model=[REQUIRED: Karpathy llama2.c .bin model to convert]:file:_files -g "*.bin"' \
      '--llama2c-output-model=[output GGUF model path]:file:_files'
    ;;

  llama-vdot)
    # Bare positional 3-arg dot-product micro-benchmark.
    _arguments -s -S \
      '1:nloop (default 10):' \
      '2:scalar (0|1 default 0):(0 1)' \
      '3:useQ4_1 (0|1 default 0):(0 1)'
    ;;

  llama-q8dot)
    # Bare positional 2-arg Q8 dot-product micro-benchmark.
    _arguments -s -S \
      '1:nloop (default 10):' \
      '2:type (0|1 default 1):(0 1)'
    ;;

esac
