# _impacket-cli — Impacket Python script collection (SecureAuth/Fortra, Python); SMB/MSRPC/Kerberos tooling for authorized AD pentests
# upstream: https://github.com/fortra/impacket

_impacket-cli() {
    _arguments \
        '-h[show help]' \
        '-debug[debug log]' \
        '-target-ip+[target IP]:ip:' \
        '-aesKey+[Kerberos AES key]:key:' \
        '-k[use Kerberos auth]' \
        '-no-pass[do not request password]' \
        '-hashes+[NTLM hash LMHASH:NTHASH]:hashes:' \
        '-dc-ip+[DC IP]:ip:' \
        '-codec+[output codec]:codec:' \
        '-shell-type+[shell]:shell:(cmd powershell)' \
        '-share+[share]:share:' \
        '-mode+[execution mode]:mode:(SHARE SERVER)' \
        '-c+[command]:cmd:' \
        '-port+[port]:port:' \
        '-protocol+[protocol]:proto:(SMB MSRPC)' \
        '-silentcommand[no echo on stdin]' \
        '-keys[show secret keys]' \
        '-history[get last password history]' \
        '-system+[SYSTEM file]:file:_files' \
        '-security+[SECURITY file]:file:_files' \
        '-sam+[SAM file]:file:_files' \
        '-ntds+[NTDS.dit file]:file:_files' \
        '-use-vss[use vss snapshot]' \
        '-resumefile+[resume file]:file:_files' \
        '-just-dc[only DC accounts]' \
        '-just-dc-ntlm[only DC NTLM]' \
        '-just-dc-user+[only this user]:user:' \
        '-pwd-last-set[show pwd last set]' \
        '-user-status[show user status]' \
        '-history[show password history]' \
        '*::user@host:'
}

_impacket-cli "$@"
