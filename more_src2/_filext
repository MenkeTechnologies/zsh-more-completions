#compdef filext
# _filext — print the extension portion of a file path (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from filext.c (single-letter getopt-style).

_filext() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '*:file path:_files'
}

_filext "$@"
