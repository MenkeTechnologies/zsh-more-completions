#compdef pgstream
# Documentation: https://github.com/xataio/pgstream
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(-c --config)'{-c,--config=}'[config file (yaml or env)]:file:_files' \
  '--source=[source type]:type:(postgres kafka)' \
  '--source-url=[source connection URL]:url:' \
  '--target=[target type]:type:(elasticsearch opensearch webhooks postgres kafka)' \
  '--target-url=[target connection URL]:url:' \
  '--log-level=[logger level]:level:(trace debug info warn error)' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'init:initialize pgstream state in the source database'
      'run:start streaming data to the configured target'
      'snapshot:perform a point-in-time snapshot'
      'status:show replication status'
      'destroy:remove pgstream state from the source database'
      'help:show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '--init[initialize state before running]' \
          '--snapshot-tables=[tables to snapshot]:tables:' \
          '--log-level=[logger level]:level:(trace debug info warn error)' && ret=0
        ;;
      snapshot)
        _arguments \
          '--reset[reset snapshot state]' \
          '--tables=[tables to snapshot]:tables:' \
          '--log-level=[logger level]:level:(trace debug info warn error)' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
