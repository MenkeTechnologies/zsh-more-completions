#compdef kvmexit kvmexit-bpfcc
# _kvmexit — summarize KVM VMEXIT reasons (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/kvmexit.py (argparse).

_kvmexit() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '(-m --max-parallelism)'{-m+,--max-parallelism=}'[post-processing parallelism]:n:'
        '(-d --debug)'{-d,--debug}'[enable debug facilities]'
        '1:duration (seconds):'
    )
    _arguments $args
}

_kvmexit "$@"
