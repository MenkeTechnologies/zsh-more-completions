#compdef ffmpegthumbnailer
# Documentation: https://github.com/dirkvdb/ffmpegthumbnailer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --input)'{-i,--input}'+[input video file]:file:_files -g "*.{mp4,mkv,avi,mov,wmv,flv,webm,m4v,mpg,mpeg,ts,vob,3gp,ogv}(-.)"' \
  '(-o --output)'{-o,--output}'+[output image file]:file:_files' \
  '(-s --size)'{-s,--size}'+[thumbnail size (pixels)]:size:' \
  '(-t --seek)'{-t,--seek}'+[time to seek to (percentage or hh:mm:ss)]:time:' \
  '(-q --quality)'{-q,--quality}'+[image quality (0-10)]:quality:' \
  '(-c --strip)'{-c,--strip}'[strip PNG metadata]' \
  '(-a --maintain-aspect-ratio)'{-a,--maintain-aspect-ratio}'[maintain aspect ratio]' \
  '(-f --film-strip)'{-f,--film-strip}'[overlay film strip effect]' \
  '(-p --smart)'{-p,--smart}'[use smart frame detection]' \
  '-w[workaround for older FFmpeg versions]' \
  '-m[prefer embedded image metadata over video content]' \
  '-v[print version]' && ret=0

return ret
