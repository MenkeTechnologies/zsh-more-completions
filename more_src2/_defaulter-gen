#compdef defaulter-gen
# _defaulter-gen — Kubernetes defaulter-function generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/defaulter-gen/args/args.go on tip.

_defaulter-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-file=[generated defaults file basename]:file:_files' \
        '*--extra-peer-dirs=[extra peer directories (comma-sep)]:list:' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '--build-tag=[Go build tag identifying generated files]:tag:' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_defaulter-gen "$@"
