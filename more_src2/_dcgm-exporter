#compdef dcgm-exporter
# _dcgm-exporter — NVIDIA DCGM Prometheus exporter (per-GPU/MIG/NvSwitch/CPU metrics)
# upstream: https://github.com/NVIDIA/dcgm-exporter
# Flags from pkg/cmd/app.go on tip (urfave/cli/v2).

_dcgm-exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-f --collectors)'{-f,--collectors}'=[file containing DCGM fields to collect]:file:_files' \
        '(-a --address)'{-a,--address}'=[HTTP listen address (host:port)]:addr:' \
        '(-c --collect-interval)'{-c,--collect-interval}'=[metric collection interval (ms)]:ms:' \
        '(-k --kubernetes)'{-k,--kubernetes}'[map metrics to Kubernetes pods]' \
        '--kubernetes-enable-pod-labels[include kubernetes pod labels in metrics]' \
        '--kubernetes-enable-pod-uid[include kubernetes pod UID in metrics]' \
        '--kubernetes-gpu-id-type=[GPU ID type used to map k8s resources to pods]:type:(uid device-name)' \
        '--kubernetes-pod-label-allowlist-regex=[csv regex for pod-label allowlist]:csv:' \
        '(-o --use-old-namespace)'{-o,--use-old-namespace}'[use 1.x metric namespace]' \
        '(-r --remote-hostengine-info)'{-r,--remote-hostengine-info}'=[remote DCGM hostengine host:port]:hostport:' \
        '(-d --devices)'{-d,--devices}'=[GPU devices to monitor (f|g[:id1,-id2]|i[:id1,-id2])]:spec:' \
        '(-s --switch-devices)'{-s,--switch-devices}'=[NvSwitch devices to monitor]:spec:' \
        '(-p --cpu-devices)'{-p,--cpu-devices}'=[CPU devices to monitor]:spec:' \
        '(-n --no-hostname)'{-n,--no-hostname}'[omit hostname from output]' \
        '--fake-gpus[accept fake GPUs (testing only)]' \
        '(-m --configmap-data)'{-m,--configmap-data}'=[ConfigMap NAMESPACE:NAME for metric data]:spec:' \
        '--web-systemd-socket[use systemd socket activation (Linux)]' \
        '--web-config-file=[Prometheus exporter-toolkit web config]:file:_files' \
        '(-x --xid-count-window-size)'{-x,--xid-count-window-size}'=[active-XID counting window (ms)]:ms:' \
        '(--rbmn --replace-blanks-in-model-name)'{--rbmn,--replace-blanks-in-model-name}'[replace blanks in GPU model name with dashes]' \
        '--debug[enable debug output]' \
        '--clock-events-count-window-size=[clock-event counting window (ms)]:ms:' \
        '--enable-dcgm-log[write DCGM logs to stdout]' \
        '--dcgm-log-level=[DCGM log verbosity]:level:(NONE FATAL ERROR WARN INFO DEBUG VERB)' \
        '--log-format=[log output format]:fmt:(text json)' \
        '--pod-resources-kubelet-socket=[kubelet pod-resources socket path]:socket:_files' \
        '--hpc-job-mapping-dir=[HPC job mapping file directory]:dir:_files -/' \
        '--nvidia-resource-names=[csv of nvidia resource names (e.g. nvidia.com/a100)]:csv:' \
        '--kubernetes-virtual-gpus[capture metrics for virtual GPUs (time-sharing/MPS)]' \
        '--dump-enabled[enable file-based debug dumps]' \
        '--dump-directory=[dump file directory]:dir:_files -/' \
        '--dump-retention=[dump retention period (hours; 0 = no cleanup)]:n:' \
        '--dump-compression[gzip-compress dump files]' \
        '--kubernetes-enable-dra[capture metrics for DRA-managed GPUs]' \
        '--disable-startup-validate[disable startup validation checks]' \
        '--enable-gpu-bind-unbind-watch[watch for GPU bind/unbind events (requires DCGM 4.5+)]' \
        '--gpu-bind-unbind-poll-interval=[bind/unbind poll interval]:duration:' \
        '--enable-pprof[expose /debug/pprof endpoints]'
}

_dcgm-exporter "$@"
