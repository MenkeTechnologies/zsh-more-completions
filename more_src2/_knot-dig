#compdef knot-dig
# Documentation: https://gitlab.nic.cz/knot/knot-dns/-/raw/master/src/utils/kdig/kdig_params.c
# Documentation: https://www.knot-dns.cz/docs/latest/html/man_kdig.html
# Reference accessed: 2026-05-27
# Verified: upstream kdig_params.c print_help() and getopt switch cases
# (knot-dig is a distribution-supplied alias for the same binary).

# knot-dig: Knot DNS advanced DNS lookup utility (libknot equivalent of ISC dig).
local -a query_options
query_options=(
  '+multiline[wrap long records to more lines]'
  '+nomultiline[do not wrap long records]'
  '+short[show record data only]'
  '+noshort[show full output]'
  '+generic[use generic representation format]'
  '+nogeneric[do not use generic representation]'
  '+aaflag[set AA flag]'
  '+noaaflag[unset AA flag]'
  '+tcflag[set TC flag]'
  '+notcflag[unset TC flag]'
  '+rdflag[set RD flag (default)]'
  '+nordflag[unset RD flag]'
  '+recurse[set RD flag (alias of +rdflag)]'
  '+norecurse[unset RD flag (alias of +nordflag)]'
  '+raflag[set RA flag]'
  '+noraflag[unset RA flag]'
  '+zflag[set zero flag bit]'
  '+nozflag[unset zero flag bit]'
  '+adflag[set AD flag (default)]'
  '+noadflag[unset AD flag]'
  '+cdflag[set CD flag]'
  '+nocdflag[unset CD flag]'
  '+doflag[set DO flag]'
  '+nodoflag[unset DO flag]'
  '+dnssec[alias of +doflag]'
  '+nodnssec[alias of +nodoflag]'
  '+deflag[set DE flag]'
  '+nodeflag[unset DE flag]'
  '+validate[re-query for SOA and DNSKEY, validate DNSSEC]'
  '+novalidate[disable DNSSEC validation]'
  '+all[show all packet sections]'
  '+noall[suppress all packet sections]'
  '+qr[show query packet]'
  '+noqr[hide query packet]'
  '+header[show packet header (default)]'
  '+noheader[hide packet header]'
  '+comments[show commented section names (default)]'
  '+nocomments[hide commented section names]'
  '+opt[show EDNS pseudosection (default)]'
  '+noopt[hide EDNS pseudosection]'
  '+opttext[try to show unknown EDNS options as text]'
  '+noopttext[do not try to interpret unknown EDNS options]'
  '+optpresent[show EDNS in presentation format]'
  '+nooptpresent[do not show EDNS in presentation format]'
  '+question[show question section (default)]'
  '+noquestion[hide question section]'
  '+answer[show answer section (default)]'
  '+noanswer[hide answer section]'
  '+authority[show authority section (default)]'
  '+noauthority[hide authority section]'
  '+additional[show additional section (default)]'
  '+noadditional[hide additional section]'
  '+tsig[show TSIG pseudosection (default)]'
  '+notsig[hide TSIG pseudosection]'
  '+stats[show trailing packet statistics (default)]'
  '+nostats[hide packet statistics]'
  '+class[show DNS class (default)]'
  '+noclass[hide DNS class]'
  '+ttl[show TTL value (default)]'
  '+nottl[hide TTL value]'
  '+crypto[show binary parts of RRSIGs and DNSKEYs (default)]'
  '+nocrypto[hide binary parts of RRSIGs and DNSKEYs]'
  '+tcp[use TCP protocol]'
  '+notcp[do not force TCP]'
  '+ignore[do not switch to TCP automatically when truncated]'
  '+noignore[switch to TCP automatically when truncated]'
  '+keepopen[keep the TCP connection open to be reused]'
  '+nokeepopen[close the TCP connection]'
  '+tls[use TLS (opportunistic privacy)]'
  '+notls[do not use TLS]'
  '+tls-ca[use TLS with out-of-band privacy profile]:file:_files'
  '+notls-ca[do not use TLS CA file]'
  '+tls-pin=[use TLS with pinned certificate]:base64:'
  '+notls-pin[do not use pinned certificate]'
  '+tls-hostname=[use TLS with remote server hostname]:hostname:'
  '+notls-hostname[do not specify TLS hostname]'
  '+tls-sni=[use TLS with Server Name Indication]:sni:'
  '+notls-sni[do not specify TLS SNI]'
  '+tls-keyfile=[use TLS with a client keyfile]:file:_files'
  '+notls-keyfile[do not use TLS keyfile]'
  '+tls-certfile=[use TLS with a client certfile]:file:_files'
  '+notls-certfile[do not use TLS certfile]'
  '+tls-ocsp-stapling[use TLS with valid stapled OCSP response]'
  '+notls-ocsp-stapling[disable TLS OCSP stapling]'
  '+https[use HTTPS protocol]'
  '+nohttps[do not use HTTPS protocol]'
  '+https-get[use HTTPS with GET method instead of POST]'
  '+nohttps-get[use HTTPS with POST method]'
  '+quic[use QUIC protocol]'
  '+noquic[do not use QUIC protocol]'
  '+nsid[request NSID]'
  '+nonsid[do not request NSID]'
  '+zoneversion[request the EDNS zone version]'
  '+nozoneversion[do not request the EDNS zone version]'
  '+bufsize=[set EDNS buffer size]:bytes:'
  '+nobufsize[do not set EDNS buffer size]'
  '+padding[pad with EDNS(0)]'
  '+nopadding[do not pad with EDNS(0)]'
  '+alignment[pad with EDNS(0) to blocksize]'
  '+noalignment[do not pad to blocksize]'
  '+subnet=[set EDNS(0) client subnet addr/prefix]:subnet:'
  '+nosubnet[do not set EDNS(0) client subnet]'
  '+edns[use EDNS]'
  '+noedns[do not use EDNS]'
  '+msgdelay=[wait this ms before receiving each XFR message]:ms:'
  '+nomsgdelay[do not delay XFR messages]'
  '+timeout=[set wait for reply interval in seconds]:seconds:'
  '+notimeout[do not set timeout]'
  '+retry=[set number of retries]:n:'
  '+noretry[do not retry]'
  '+expire[set the EXPIRE EDNS option]'
  '+noexpire[unset the EXPIRE EDNS option]'
  '+cookie[attach EDNS(0) cookie to the query]'
  '+nocookie[do not attach EDNS(0) cookie]'
  '+badcookie[repeat a query with the correct cookie]'
  '+nobadcookie[do not repeat query with corrected cookie]'
  '+ednsopt=[set custom EDNS option CODE[:HEX]]:opt:'
  '+noednsopt[do not set custom EDNS option]'
  '+proxy=[add PROXYv2 header with src and dest addresses]:saddr-daddr:'
  '+noproxy[do not add PROXYv2 header]'
  '+json[use JSON for output encoding (RFC 8427)]'
  '+nojson[do not use JSON output]'
  '+idnin[use IDN transformation on input (default)]'
  '+noidnin[do not use IDN transformation on input]'
  '+idnout[use IDN transformation on output (default)]'
  '+noidnout[do not use IDN transformation on output]'
)

local curcontext="$curcontext" ret=1
_arguments -s \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '-b+[set source IP address]:address:_hosts' \
  '-c+[explicit query class]:class:(IN CH HS NONE ANY)' \
  '-d[enable debug messages]' \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '-k+[use TSIG key from file]:keyfile:_files' \
  '-p+[set nameserver port]:port:' \
  '*-q+[set query name]:name:' \
  '*-t+[explicit query type]:type:(A AAAA ANY AXFR CNAME DNSKEY DS HINFO IXFR MX NS NSEC NSEC3 PTR RRSIG SOA SRV TXT CAA HTTPS SVCB)' \
  '(-V --version)'{-V,--version}'[print version and exit]' \
  '-x+[reverse (PTR) query]:address:' \
  '-y+[TSIG authentication ([alg:]name:key)]:tsig:' \
  '-E+[export dnstap trace]:tapfile:_files' \
  '-G+[generate output from dnstap file]:tapfile:_files' \
  $query_options \
  '*:name:_hosts' && ret=0
return ret
