#compdef named-cli
# _named-cli — ISC named BIND DNS server CLI alias (ISC team, C); custom argparse
# upstream: https://github.com/isc-projects/bind9

_named-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[ipv4 only]' \
        '-6[ipv6 only]' \
        '-c+[config file]:file:_files -g "named.conf"' \
        '-d+[debug level]:n:' \
        '-D+[string]:str:' \
        '-E+[engine]:str:' \
        '-f[run in foreground]' \
        '-g[run in foreground, log to stderr]' \
        '-L+[log file]:file:_files' \
        '-M+[mem mgmt]:str:' \
        '-m+[memory usage debug flags]:str:' \
        '-n+[number of cpus]:n:' \
        '-p+[port]:port:' \
        '-s[print mem stats on exit]' \
        '-S+[max sockets]:n:' \
        '-t+[chroot dir]:dir:_files -/' \
        '-T+[advanced testing options]:str:' \
        '-u+[user]:_users' \
        '-U+[number of UDP listeners]:n:' \
        '-v[show version]' \
        '-X+[lock file]:file:_files' \
        '*:arg:'
}

_named-cli "$@"
