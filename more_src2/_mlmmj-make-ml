#compdef mlmmj-make-ml
# Documentation: https://mlmmj.org/mlmmj-make-ml.html
# Reference accessed: 2026-05-30
# mlmmj-make-ml — interactive script to create a new mlmmj mailing list directory structure.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '-L+[list name]:name:' \
  '-s+[spool directory (default /var/spool/mlmmj)]:dir:_directories' \
  '-a[create /etc/aliases entries]' \
  '-c+[user to chown spool dir (default no chown)]:user:_users' \
  '-z[placeholder option (no current function)]' \
  && ret=0

return ret
