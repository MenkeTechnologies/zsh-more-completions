#compdef grub-bios-setup
# _grub-bios-setup — GRUB grub-bios-setup (write the GRUB boot loader stage 1 to a BIOS-style disk's MBR or PBR using an already-built core.img; -d directory, -b boot.img path, -c core.img path, -f force, -m device map, -s skip filesystem check, --no-rs-codes do not add reed-solomon codes, --allow-floppy, --verbose, -h help; positional argument is the target disk)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-bios-setup.c on tip.

_grub-bios-setup() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d+[directory]:dir:_files -/' \
        '-b+[boot.img]:file:_files' \
        '-c+[core.img]:file:_files' \
        '-f[force]' \
        '--force[force]' \
        '-m+[device map]:file:_files' \
        '-s[skip fs check]' \
        '--no-rs-codes[no Reed-Solomon codes]' \
        '--allow-floppy[allow floppy]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:device:_files -g "/dev/*"'
}

_grub-bios-setup "$@"
