#compdef mp3val
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mp3val.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '-l[log file]:file:_files' \
  '-f[try fix errors]' \
  '-si[suppress INFO]' \
  '-p[pipe mode]' \
  '-v[show version]' \
  '*:file:_files -g "*.mp3"'
