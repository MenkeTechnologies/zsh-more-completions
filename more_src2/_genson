#compdef genson
# Documentation: https://github.com/wolverdude/GenSON
# Reference accessed: 2026-05-23
# Verified: genson --help.

# Zsh completion for genson - unified JSON Schema generator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-d --delimiter)'{-d+,--delimiter=}'[delimiter for multiple JSON objects]:delimiter:' \
  '(-e --encoding)'{-e+,--encoding=}'[file encoding]:encoding:' \
  '(-i --indent)'{-i+,--indent=}'[indentation spaces]:spaces:' \
  '(-s --schema)'{-s+,--schema=}'[existing schema file]:file:_files' \
  '-$[schema URI]:uri:' \
  '*:object:JSON object file:_files' && ret=0

return ret
