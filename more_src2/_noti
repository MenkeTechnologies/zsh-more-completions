#compdef noti
# Documentation: https://github.com/variadico/noti/blob/main/docs/man/noti.1.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display version]' \
  {-t,--title}'=[notification title]:title' \
  {-m,--message}'=[notification message]:message' \
  {-b,--banner}'[trigger banner notification]' \
  '--icon=[notification icon path or name]:icon:_files' \
  {-s,--speech}'[trigger speech notification]' \
  {-c,--bearychat}'[trigger BearyChat notification]' \
  '--keybase[trigger Keybase notification]' \
  {-p,--pushbullet}'[trigger Pushbullet notification]' \
  {-o,--pushover}'[trigger Pushover notification]' \
  {-u,--pushsafer}'[trigger Pushsafer notification]' \
  {-l,--simplepush}'[trigger Simplepush notification]' \
  {-n,--gchat}'[trigger Google Chat notification]' \
  {-i,--chanify}'[trigger Chanify notification]' \
  {-k,--slack}'[trigger Slack notification]' \
  '--twilio[trigger Twilio SMS notification]' \
  '--ntfy[trigger ntfy notification]' \
  {-w,--pwatch}'=[monitor a process by PID]:pid' \
  {-f,--file}'=[path to noti.yaml configuration file]:file:_files' \
  '--verbose[verbose output]' \
  '*:command:_command_names -e' \
  && ret=0

return ret
