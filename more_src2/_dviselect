#compdef dviselect
# Documentation: man dviselect(1) (TeX Live, MC-TeX)
# Source: TeX dviselect — extract pages from DVI files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[absolute page numbers (use leading =)]' \
    '-i+[input DVI file]:file:_files -g "*.dvi"' \
    '-o+[output DVI file]:file:_files -g "*.dvi"' \
    '*:page-list / DVI files:_files -g "*.dvi"' \
    && ret=0

return ret
