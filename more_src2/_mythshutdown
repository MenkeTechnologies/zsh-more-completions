#compdef mythshutdown
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythshutdown/mythshutdown_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythshutdown: MythTV scheduled shutdown helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '(-w --setwakeup)'{-w,--setwakeup=}'[set wakeup time]:time:' \
  '(-t --setscheduledwakeup)'{-t,--setscheduledwakeup}'[set scheduled wakeup]' \
  '(-q --shutdown)'{-q,--shutdown}'[shutdown]' \
  '(-x --safeshutdown)'{-x,--safeshutdown}'[safe shutdown]' \
  '(-p --startup)'{-p,--startup}'[startup]' \
  '(-c --check)'{-c,--check}'[check]' \
  '--lock[disable shutdown]' \
  '(-u --unlock)'{-u,--unlock}'[unlock shutdown]' \
  '(-s --status)'{-s,--status}'[status]' \
  '--utc[UTC time]' \
  '--localtime[local time]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
