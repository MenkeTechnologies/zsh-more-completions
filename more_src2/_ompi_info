#compdef ompi_info ompi-info
# _ompi_info — Open MPI ompi_info display Open MPI runtime and build information component frameworks (open-mpi team, C); custom argparse
# upstream: https://github.com/open-mpi/ompi

_ompi_info() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[print all configuration]' \
        '--all[print all configuration]' \
        '-c[show config]' \
        '--config[show config]' \
        '-p+[plugin path]:str:' \
        '--param=+[plugin name:value]:str:' \
        '--internal[show internal MCA params]' \
        '--level=+[level]:l:(1 2 3 4 5 6 7 8 9)' \
        '--parsable[parsable output]' \
        '--parseable[parsable output]' \
        '--pretty-print[pretty print]' \
        '--selected-only[selected only]' \
        '--type=+[component type]:str:' \
        '--variable=+[variable name]:str:' \
        '*:framework:'
}

_ompi_info "$@"
