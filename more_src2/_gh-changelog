#compdef gh-changelog gh-screensaver gh-sbom gh-slack gh-yule-log gh-models
# Documentation: upstream READMEs at github.com/{chelnak/gh-changelog,vilmibm/gh-screensaver,advanced-security/gh-sbom,rneatherway/gh-slack,leereilly/gh-yule-log,github/gh-models}
# Reference accessed: 2026-05-30
# gh-extension family round 4. Companions to the rounds 158-160 multi-stems
# and the pre-existing _gh-poi/_gh-notify/_gh-dash/etc files.
# Hunt-skip log this round:
#   gh-actions-cache — ARCHIVED 2024-10-21; upstream README states the
#     functionality is now native `gh cache`. Skip per the
#     deprecated-tool-with-supersedence precedent.
#   gh-profile — ARCHIVED; official multi-account support was added to
#     `gh` in v2.40.0. Skip.
#   gh-grep — surfaces "--include/--exclude/line-numbers/URLs/match-counts/
#     filename-only" without specific flag names. Defer until exact flag
#     names are documented.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-changelog)
    # chelnak/gh-changelog — Keep-a-Changelog generator.
    local -a _subcmds
    _subcmds=(
      'new:create a new changelog'
      'show:view the current changelog'
      'config:check configuration'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-changelog subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          new)
            _arguments \
              '--next-version=[unreleased version label]:version:' \
              '--from-version=[changelog start point]:version:' \
              '--latest[generate only the most recent release]' \
              '--logger=[output mode]:mode:(spinner console)' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-screensaver)
    # vilmibm/gh-screensaver — terminal screensaver animations.
    # Bare `gh screensaver` picks one at random; -s NAME runs a specific
    # screensaver; -l lists available ones; per-screensaver options come
    # after `--`.
    _arguments -s -S \
      '(-l)-s+[run a specific screensaver]:name:(fireworks starfield pipes pollock life)' \
      '(-s)-l[list available screensavers]' \
      '--color=[color mode]:mode:(full off)' \
      '*::extra args after --:' \
      && ret=0
    ;;

  gh-sbom)
    # advanced-security/gh-sbom — generate SPDX (default) or CycloneDX SBOMs.
    _arguments -s -S \
      '-c[output CycloneDX format (default SPDX)]' \
      '-l[enrich with licensing info from ClearlyDefined (CycloneDX only)]' \
      && ret=0
    ;;

  gh-slack)
    # rneatherway/gh-slack — archive Slack conversations as markdown.
    local -a _subcmds
    _subcmds=(
      'read:export Slack messages to markdown from a permalink'
      'send:post a message to a Slack channel'
      'api:make a direct Slack API call'
      'auth:retrieve Slack authentication credentials'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-slack subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          read)
            _arguments \
              '1:Slack permalink:' && ret=0
            ;;
          send)
            _arguments \
              '1:channel:' \
              '*:message:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-yule-log)
    # leereilly/gh-yule-log — animated Yule log screensaver.
    # Upstream README documents a single flag.
    _arguments -s -S \
      '--contribs[customize the display around your GitHub contribution history]' \
      && ret=0
    ;;

  gh-models)
    # github/gh-models — AI model integration for the gh CLI.
    local -a _subcmds
    _subcmds=(
      'list:show available AI models'
      'run:run a prompt against a model (REPL or single-shot)'
      'eval:test prompts using .prompt.yml files'
      'generate:auto-generate test cases via PromptPex methodology'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-models subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          run)
            _arguments \
              '1:model (e.g. openai/gpt-4o-mini):' \
              '*:prompt:' && ret=0
            ;;
          eval)
            _arguments \
              '*:prompt YAML file:_files -g "*.prompt.(yml|yaml)"' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
