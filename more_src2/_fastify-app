#compdef fastify-app
# Documentation: https://www.npmjs.com/package/create-fastify-app
# Reference accessed: 2026-05-24
# Verified: npm view create-fastify-app bin (fastify-app); npx create-fastify-app --help output.

# Zsh completion for fastify-app - Fastify project generator and plugin adder

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-d --directory)'{-d,--directory}'[Fastify project folder]:directory:_directories'   '(-h --help)'{-h,--help}'[show help message]'   '1: :->cmd'   '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'command'       run       'generate:project:generate a ready-to-use Fastify project'       'generate:service:generate service skeleton in project'       'add:mysql:add fastify-mysql plugin'       'add:mongo:add fastify-mongodb plugin'       'add:cors:add fastify-cors plugin'       'add:redis:add fastify-redis plugin'       'add:postgres:add fastify-postgres plugin'       'add:pov:add Point-Of-View plugin' && ret=0
    ;;
  args)
    _arguments -C '*:arguments:' && ret=0
    ;;
esac

return ret
