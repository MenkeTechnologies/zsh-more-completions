#compdef ippregfile ippeveprinter
# Documentation: https://www.cups.org/doc/man-ippeveprinter.html
# Reference accessed: 2026-05-16
# Verified: no `ippregfile` binary exists in CUPS, ippsample, or pappl;
# the closest match is `ippeveprinter` (IPP Everywhere printer
# emulator), which this completion targets. The misspelled name is
# accepted via #compdef alias for backwards compatibility.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# ippregfile -> ippeveprinter: IPP Everywhere printer emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-2[enable two-sided printing]' \
  '-A[require IPP authentication]' \
  '-D[print device URI]:uri:' \
  '-F[supported document format types]:type:' \
  '-M[manufacturer]:mfg:' \
  '-P[PostScript PPD file]:file:_files' \
  '-V[IPP version]:version:(1.1 2.0)' \
  '-c[command to handle print jobs]:cmd:_command_names' \
  '-d[spool directory]:dir:_files -/' \
  '-f[supported document formats]:types:' \
  '-i[icon PNG file]:file:_files -g "*.png(-.)"' \
  '-k[keep job files after printing]' \
  '-l[printer location]:location:' \
  '-m[printer model]:model:' \
  '-n[server hostname]:host:_hosts' \
  '-p[server port]:port:' \
  '-r[Bonjour service subtypes]:subtypes:' \
  '-s[print speed in pages/min]:speed:' \
  '*-v[verbose (repeatable)]' \
  '--no-web-forms[disable web-based admin forms]' \
  '--pam-service=[PAM service name]:service:' \
  '*:printer name:' && ret=0
return ret
