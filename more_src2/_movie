#compdef movie
# Documentation: https://docs.generic-mapping-tools.org/latest/movie.html
# Source: GenericMappingTools/gmt src/movie.c — animate a sequence of GMT plots into video/GIF (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[canvas size or named preset]:canvas:_default' \
    '-N+[movie name prefix]:prefix:_default' \
    '-T+[time/frame specification]:opts:_default' \
    '-A+[audio file]:file:_files -g "*.{wav,mp3,aac,flac,ogg}"' \
    '-D+[frame rate (fps)]:rate:_default' \
    '-E+[title page settings]:opts:_default' \
    '-F+[output format]:opts:(gif mp4 webm png)' \
    '-G+[background fill / pen]:opts:_default' \
    '-H+[plot scaling factor for sub-pixel]:scale:_default' \
    '-I+[include file (script)]:file:_files' \
    '-K+[fade settings]:opts:_default' \
    '-L+[label placement info]:opts:_default' \
    '-M+[master frame settings]:opts:_default' \
    '-P+[progress indicator settings]:opts:_default' \
    '-Q[debug mode; do not delete temp dir]' \
    '-Sb+[background script]:file:_files' \
    '-Sf+[foreground script]:file:_files' \
    '-W+[working directory]:dir:_files -/' \
    '-Z[delete master script after run]' \
    '-x+[parallel jobs (negative=cores-N)]:n:_default' \
    '*-V[verbose (stackable)]' \
    '1:mainscript:_files' \
    && ret=0

return ret
