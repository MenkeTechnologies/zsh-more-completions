#compdef nvmmctl
# Documentation: man nvmmctl(8)
# Source: netbsd/src usr.sbin/nvmmctl — NVMM virtual machine control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:command:(identify list)' \
    '*::argument:_default' \
    && ret=0

return ret
