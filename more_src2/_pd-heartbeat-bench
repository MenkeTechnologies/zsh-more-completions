#compdef pd-heartbeat-bench
# _pd-heartbeat-bench — TiKV PD region-heartbeat load generator
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-heartbeat-bench/config/config.go on tip.

_pd-heartbeat-bench() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[heartbeat-bench config file]:file:_files' \
        '--pd-endpoints=[PD leader address]:host\:port:' \
        '--log-file=[log file path]:file:_files' \
        '--status-addr=[status endpoint bind host\:port]:host\:port:' \
        '--cacert=[trusted CA cert file (PEM)]:file:_files' \
        '--cert=[client X509 cert file (PEM)]:file:_files' \
        '--key=[client X509 key file (PEM)]:file:_files' \
        '--epoch-ver=[initial region epoch version]:n:' \
        '--metrics-addr=[address to scrape metrics from]:host\:port:'
}

_pd-heartbeat-bench "$@"
