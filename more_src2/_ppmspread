#compdef ppmspread
# Documentation: man ppmspread (Netpbm)
# Source: randomly displace pixels of a PPM image by up to N pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:max spread amount:' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
