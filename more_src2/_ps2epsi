#compdef ps2epsi
# Documentation: man ps2epsi(1)
# Source: Ghostscript ghostpdl ps2epsi (master) — wrap PostScript with EPSI preview (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:input PostScript file:_files -g "*.{ps,eps,cps,epsf}"' \
    '2::output EPSI file:_files -g "*.epsi"' \
    && ret=0

return ret
