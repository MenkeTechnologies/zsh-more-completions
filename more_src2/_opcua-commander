# ============================================================================
# _opcua-commander — zsh completion for the canonical node-opcua TUI client
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/node-opcua/opcua-commander
#   Author     : Etienne Rossignon (Sterfive)
#   License    : MIT
#   Stars      : 264
#   Language   : TypeScript
#   npm        : opcua-commander v0.40.0
#   Binary     : opcua-commander  (package.json bin → bin/opcua-commander)
#   Last push  : 2026-03-29
#
# WHAT IT IS
#   opcua-commander is the OFFICIAL CLI from the node-opcua organization —
#   "a opcua client with blessed (ncurses)".  It is a TypeScript Node.js
#   command-line OPC Unified Architecture (OPC UA, IEC 62541) client that
#   connects to an OPC UA server endpoint, opens an interactive ncurses TUI
#   built with the `blessed` library, and lets you browse the address space,
#   monitor variable subscriptions, perform historical reads, and exercise
#   the complete OPC UA security model — including the MessageSecurityMode
#   enum (None / Sign / SignAndEncrypt) and SecurityPolicy enum (None,
#   Basic128Rsa15, Basic256, Basic256Sha256, Aes128_Sha256_RsaOaep,
#   Aes256_Sha256_RsaPss, plus PubSub variants).  X.509 user certificates
#   are supported via `--userCertificate` and `--userCertificatePrivateKey`,
#   and UserNameIdentityToken auth via `--userName` / `--password`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from lib/index.ts yargs builder)
#   opcua-commander --endpoint <URL> [OPTIONS]
#
#   Options (yargs `.alias()` short flags shown after the long form):
#     --endpoint, -e <URL>             OPC UA endpoint URL  (REQUIRED)
#                                      e.g. opc.tcp://localhost:49230
#     --securityMode, -s <MODE>        message security mode
#                                      None | Sign | SignAndEncrypt
#     --securityPolicy, -P <POLICY>    security policy
#                                      None | Basic128Rsa15 | Basic256 |
#                                      Basic256Sha256 | Aes128_Sha256_RsaOaep
#                                      | Aes256_Sha256_RsaPss |
#                                      PubSub_Aes128_CTR | PubSub_Aes256_CTR
#     --userName, -u <USER>            UserNameIdentityToken username
#     --password, -p <PASS>            UserNameIdentityToken password
#     --node, -n <NODEID>              nodeId of value to monitor
#                                      e.g. "ns=0;i=2258"
#     --history <STRING>               make a historical read
#     --userCertificate, -c <FILE>     X.509 user certificate (PEM format)
#     --userCertificatePrivateKey, -x <FILE>
#                                      X.509 private key associated with the
#                                      user certificate
#     --timeout, -t <SECONDS>          connection timeout
#     --verbose, -v                    display extra information
#     --help, -h                       show help
#     --version                        show version
#
# EXAMPLES  (from yargs `.example(...)` declarations in lib/index.ts)
#   opcua-commander --endpoint opc.tcp://localhost:49230 -P=Basic256 -s=Sign
#   opcua-commander -e opc.tcp://localhost:49230 -P=Basic256 -s=Sign \
#                   -u JoeDoe -p P@338@rd
#   opcua-commander --endpoint opc.tcp://localhost:49230 -n="ns=0;i=2258"
#
# AXIS / CORPUS POSITION
#   Direct dependency on the `node-opcua` family of packages declared in
#   package.json `"dependencies"` block:
#     "node-opcua-client":               "^2.138.1"
#     "node-opcua-pki":                  "^4.16.0"
#     "node-opcua-certificate-manager":  "^2.134.0"
#   These are the canonical TypeScript/Node.js OPC-UA libraries maintained
#   by the node-opcua organization (https://github.com/node-opcua/node-opcua,
#   1638 stars).  Verified via:
#     gh api repos/node-opcua/opcua-commander/contents/package.json
#       + gh api .../contents/lib/index.ts
#   This entry is the TS-Node=112 leader bump that CLOSES Axis 57
#   (OPC-UA Industrial Automation Library) at 1/1/1 three-language symmetry:
#     Rust   = opcua 0.12              (R817, `opcua-client`, tuiopcclient)
#     Go     = github.com/gopcua/opcua (R818, `opcuacheck`,    obowersa)
#     TS-Node = node-opcua-client      (R819, `opcua-commander`, node-opcua)
#   Reaches the triple-112 landmark Rust=Go=TS-Node=112.
#
#   No completion for `opcua-commander` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_opcua-commander() {
    _arguments -s \
        '(-e --endpoint)'{-e+,--endpoint=}'[OPC UA endpoint URL (REQUIRED)]:endpoint url:_opcua_commander_endpoints' \
        '(-s --securityMode)'{-s+,--securityMode=}'[message security mode]:mode:(None Sign SignAndEncrypt)' \
        '(-P --securityPolicy)'{-P+,--securityPolicy=}'[security policy]:policy:(None Basic128Rsa15 Basic256 Basic256Sha256 Aes128_Sha256_RsaOaep Aes256_Sha256_RsaPss PubSub_Aes128_CTR PubSub_Aes256_CTR)' \
        '(-u --userName)'{-u+,--userName=}'[UserNameIdentityToken username]:username:_users' \
        '(-p --password)'{-p+,--password=}'[UserNameIdentityToken password]:password:' \
        '(-n --node)'{-n+,--node=}'[nodeId to monitor (e.g. "ns=0;i=2258")]:node id:' \
        '--history=[make a historical read]:history spec:' \
        '(-c --userCertificate)'{-c+,--userCertificate=}'[X.509 user certificate (PEM)]:cert file:_files -g "*.(pem|crt|cer)"' \
        '(-x --userCertificatePrivateKey)'{-x+,--userCertificatePrivateKey=}'[X.509 user private key]:key file:_files -g "*.(pem|key)"' \
        '(-t --timeout)'{-t+,--timeout=}'[connection timeout (seconds)]:seconds:' \
        '(-v --verbose)'{-v,--verbose}'[display extra information]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]'
}

(( $+functions[_opcua_commander_endpoints] )) ||
_opcua_commander_endpoints() {
    if [[ -prefix opc.tcp:// || -prefix opc.https:// || -prefix opc.wss:// ]]; then
        _message 'OPC UA endpoint URL'
    else
        _alternative \
            'examples:OPC UA endpoint:(opc.tcp://localhost:49230 opc.tcp://localhost:4840 opc.tcp://opcuademo.sterfive.com:26543)'
    fi
}

_opcua-commander "$@"
