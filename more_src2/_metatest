#compdef metatest
# Documentation: $(metatest 2>&1) "Usage: metatest list|TEST"
# Reference accessed: 2026-05-19
# Verified: invocation of installed `metatest` (Homebrew check formula helper)
# prints "Usage: metatest list|TEST"; it accepts a single test name or `list`.
# STUB: no flag set documented; one positional argument.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:meta test name (or list):' && ret=0

return ret
