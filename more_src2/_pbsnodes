#compdef pbsnodes
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/pbsnodes.8B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pbsnodes: query/modify PBS node state
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a[show all nodes / all attributes]' \
  '-A[append note attribute (comma separated)]:note:' \
  '-c[clear OFFLINE state]' \
  '-d[print MOM diagnostics]' \
  '-l[list node names and their state]' \
  '-m[change power state]:state:(running standby suspend hibernate shutdown)' \
  '-N[specify a note attribute]:text:' \
  '-n[show note attribute (requires -l)]' \
  '-o[add OFFLINE state]' \
  '-p[purge node record]' \
  '-q[suppress error messages]' \
  '-r[reset (clear OFFLINE + add DOWN)]' \
  '-s[server hostname or IP]:server:_hosts' \
  '-x[XML-like output]' \
  '--xml[XML-like output]' \
  '*:node:_hosts' && ret=0
return ret
