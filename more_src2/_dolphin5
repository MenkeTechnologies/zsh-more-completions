#compdef dolphin5 dolphin
# Documentation: https://linuxcommandlibrary.com/man/dolphin
# Reference accessed: 2026-05-16
# Verified: dolphin(1) reference. Real flags confirmed: --select,
# --split, --new-window, --daemon.
# Removed from prior file: bogus man.archlinux.org search URL.

# dolphin5/dolphin: KDE file manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--select[open with files/dirs selected in parent folder]' \
  '--new-window[force a new window]' \
  '--split[open two directories side by side]' \
  '--daemon[start as background D-Bus service]' \
  '*:url:_files' && ret=0
return ret
