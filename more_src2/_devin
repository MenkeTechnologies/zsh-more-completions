#compdef devin
# Documentation: https://cli.devin.ai/docs/reference/commands
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Devin for Terminal CLI (Cognition AI)

_devin() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--model[Set the AI model for this session]:model:'
        '--permission-mode[Set permission mode]:mode:(normal dangerous bypass)'
        '--respect-workspace-trust[Honor workspace trust settings]'
        '(-c --continue)'{-c,--continue}'[Resume the most recent session]'
        '(-r --resume)'{-r,--resume}'[Resume a specific session by ID]:id:'
        '(-p --print)'{-p,--print}'[Non-interactive mode: print response and exit]'
        '--prompt-file[Load initial prompt from a file]:file:_files'
        '--config[Specify custom configuration path]:file:_files'
        '--json[Output results in raw JSON]'
        '(-h --help)'{-h,--help}'[Display help for command]'
    )

    subcmds=(
        'auth:Manage authentication (login/logout/status)'
        'mcp:Manage Model Context Protocol servers'
        'rules:Manage agent rules'
        'skills:Manage custom skills'
        'list:List recent sessions'
        'ls:List sessions (alias)'
        'setup:Interactive setup wizard for auth and MCP'
        'shell:Manage shell integration (setup)'
        'update:Check for and install CLI updates'
        'uninstall:Uninstall the Devin CLI'
        'version:Display current CLI version'
        'acp:Run as Agent Client Protocol server (stdio)'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'devin commands' subcmds
            ;;
        args)
            case $line[1] in
                auth)
                    local -a auth_subcmds
                    auth_subcmds=(
                        'login:Authenticate via browser or manual token'
                        'logout:Clear stored credentials'
                        'status:Check current login status'
                    )
                    _describe -t commands 'auth subcommands' auth_subcmds
                    ;;
                mcp)
                    local -a mcp_subcmds
                    mcp_subcmds=(
                        'add:Add an MCP server'
                        'list:List MCP servers'
                        'get:Get details for an MCP server'
                        'remove:Remove an MCP server'
                        'login:Authenticate with an MCP server'
                        'logout:Sign out of an MCP server'
                    )
                    _describe -t commands 'mcp subcommands' mcp_subcmds
                    ;;
                rules)
                    local -a rules_subcmds
                    rules_subcmds=(
                        'list:List agent rules'
                        'show:Show a rule'
                        'paths:Show rule file paths'
                    )
                    _describe -t commands 'rules subcommands' rules_subcmds
                    ;;
                skills)
                    local -a skills_subcmds
                    skills_subcmds=(
                        'list:List skills'
                        'show:Show a skill'
                        'paths:Show skill file paths'
                    )
                    _describe -t commands 'skills subcommands' skills_subcmds
                    ;;
            esac
            ;;
    esac
}

_devin "$@"
