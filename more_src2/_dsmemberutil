#compdef dsmemberutil
# Documentation: dsmemberutil usage (macOS 26)
# Source: query and manipulate Directory Services group memberships.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'getuuid:get UUID for a user/group identifier'
    'getid:get id for a user/group identifier'
    'getsid:get SID for a user/group identifier'
    'checkmembership:test whether a user is in a group'
    'flushcache:flush the membership resolution cache'
    'dumpstate:dump current membership state'
    'statistics:show membership-resolver statistics'
)

_arguments -C -s \
    '(- *)-h[show help]' \
    '-v[verbose mode]' \
    '1:command:->verbs' \
    '*::args:_normal' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
