# wrong target (the prior file documented `lsd` file lister flags, not
# the Leapsight Semantic Dataspace CLI binary named `lsd-cli`).

# lsd-cli: Leapsight Semantic Dataspace command line tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --host)'{-h+,--host=}'[LSD host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[LSD port]:port:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--help[show help]' \
  '*:tenant:' && ret=0
return ret
