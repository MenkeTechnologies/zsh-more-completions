#compdef esedbinfo esedbexport
# _libesedb — libyal Extensible Storage Engine Database (Microsoft Jet Blue / ESE .edb) parser used by AD ntds.dit, Windows Search WebCacheV01.dat, IE WebCacheV01.dat, SRUM SRUDB.dat
# upstream: https://github.com/libyal/libesedb

_libesedb() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-m+[mode]:mode:(tables all)' \
        '-T+[table name]:table:' \
        '-t+[target dir]:dir:_files -/' \
        '-X[exclusive]' \
        '*:ESE database:_files -g "*.(edb|dit|dat)"'
}

_libesedb "$@"
