#compdef denoctl deno-ctl
# _denoctl — denoctl CLI lightweight controller frontend to the Deno JavaScript TypeScript runtime providing process supervision watch-restart cluster spawning multi-instance load-balancing similar to PM2 for-deno deno-run-deno-task-deno-bench-deno-compile flag-forwarding and stdin-stream-aggregation (denoctl authors team, Rust); clap
# upstream: https://deno.land/

_denoctl() {
    local -a sub=(
        'start:start a deno process'
        'stop:stop a managed process'
        'restart:restart a process'
        'reload:reload a process'
        'list:list managed processes'
        'logs:show process logs'
        'monit:monitor processes'
        'save:save process list'
        'resurrect:restore saved process list'
        'startup:install startup unit'
        'unstartup:remove startup unit'
        'kill:kill all managed processes'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-i+[instances]:n:' \
        '--instances=+[N]:n:' \
        '--max-memory-restart=+[size]:str:' \
        '--watch[watch and restart]' \
        '--no-watch[disable watch]' \
        '--log-date-format=+[format]:str:' \
        '--log=+[file]:file:_files' \
        '--out=+[file]:file:_files' \
        '--err=+[file]:file:_files' \
        '--allow-net[deno allow-net]' \
        '--allow-read[deno allow-read]' \
        '--allow-write[deno allow-write]' \
        '--allow-env[deno allow-env]' \
        '--allow-run[deno allow-run]' \
        '--allow-all[deno -A]' \
        '--unstable[deno unstable APIs]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'denoctl subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments '*:script file:_files -g "*.ts *.js *.tsx *.jsx *.mjs *.cjs"' ;;
                stop|restart|reload|logs) _arguments '*:name or id:' ;;
            esac
            ;;
    esac
}

_denoctl "$@"
