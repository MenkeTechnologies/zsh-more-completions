#compdef pscoast
# Documentation: https://docs.generic-mapping-tools.org/latest/coast.html
# Source: GenericMappingTools/gmt classic-mode coast — plot coastlines / borders / rivers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A+[area/level filter]:filter:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[lake fill]:fill:_default' \
    '-D+[GSHHG resolution]:res:(full high intermediate low crude)' \
    '-E+[country polygon select+style]:spec:_default' \
    '-F+[panel behind embellishments]:opts:_default' \
    '-G+[dry-area fill / clip]:fill:_default' \
    '-I+[draw rivers (type/pen)]:rivers:_default' \
    '-L+[map scale bar]:opts:_default' \
    '-M[dump data as multisegment ASCII (no plot)]' \
    '-N+[political boundaries (1=national,2=state,a=marine)]:spec:_default' \
    '-Q[end existing clip path]' \
    '-S+[water-area fill / clip]:fill:_default' \
    '-T+[direction rose (-Td) or magnetic (-Tm)]:spec:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[shoreline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-t+[transparency percent]:pct:_default' \
    '-p+[perspective view]:perspective:_default' \
    && ret=0

return ret
