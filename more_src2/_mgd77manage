#compdef mgd77manage
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77manage.html
# Source: GenericMappingTools/gmt supplements/mgd77 — manage MGD77+ netCDF custom columns (add/delete/update).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[add column (table/formula/grid-sample)]:opts:_default' \
    '-D+[delete column(s) by abbreviation]:cols:_default' \
    '-E+[fill char for empty strings]:char:_default' \
    '-F[force-mode: modify standard MGD77 columns]' \
    '-I+[metadata for extra columns]:opts:_default' \
    '-N+[distance unit]:unit:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-je[spherical distance computation method]' \
    '-n+[grid interpolation mode]:mode:_default' \
    '*:GEODAS-ID:_default' \
    && ret=0

return ret
