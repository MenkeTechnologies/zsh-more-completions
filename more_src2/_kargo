#compdef kargo
# Documentation: https://github.com/akuity/kargo/blob/main/cmd/cli/root.go
# Reference accessed: 2026-05-19
# Verified: upstream source (cmd.AddCommand calls) at the URL above.
# Akuity Kargo (multi-stage GitOps promotion). Removed invented global
# --kubeconfig (no root persistent flags); added config and logs commands.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'apply:Apply a resource from a file or stdin'
  'approve:Manually approve a piece of freight for a stage'
  'config:Manage Kargo CLI configuration'
  'create:Create a resource'
  'dashboard:Open the Kargo dashboard'
  'delete:Delete resources'
  'get:Display one or many resources'
  'grant:Grant a role to a user or grant permissions to a role'
  'login:Log in to a Kargo API server'
  'logs:Print the logs for a resource'
  'logout:Log out of the Kargo API server'
  'promote:Promote a piece of freight'
  'refresh:Refresh a resource'
  'revoke:Revoke a role from a user or revoke permissions from a role'
  'server:Start a local Kargo API server'
  'update:Update a resource'
  'verify:Verify a stage'
  'version:Display version information'
  'completion:Generate the autocompletion script'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kargo command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      get|delete|create)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--project=[specify project]:project' \
          '(-o --output)'{-o,--output}'=[output format]:format:(json yaml)' \
          '*:resource' && ret=0
        ;;
      promote)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--freight=[freight to promote]:freight' \
          '--freight-alias=[freight alias to promote]:alias' \
          '--name=[name of the freight to promote]:name' \
          '--stage=[target stage]:stage' \
          '--project=[specify project]:project' && ret=0
        ;;
      approve)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--freight=[freight to approve]:freight' \
          '--freight-alias=[freight alias to approve]:alias' \
          '--stage=[stage to approve for]:stage' \
          '--project=[specify project]:project' && ret=0
        ;;
      refresh)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--wait[wait for the refresh to complete]' \
          '*:resource' && ret=0
        ;;
      login)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--admin[log in as the admin user]' \
          '--password=[admin user password]:password' \
          '--kubeconfig[log in using local kubeconfig]' \
          '--sso[log in via SSO]' \
          '--port=[port for SSO callback server]:port' \
          '1:server address' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
