#compdef in2csv
# Documentation: https://csvkit.readthedocs.io/en/latest/scripts/in2csv.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# in2csv (csvkit): convert common tabular formats to CSV
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --delimiter)'{-d+,--delimiter=}'[delimiting character]:delimiter:' \
  '(-t --tabs)'{-t,--tabs}'[input is tab-delimited]' \
  '(-q --quotechar)'{-q+,--quotechar=}'[quote character]:char:' \
  '(-u --quoting)'{-u+,--quoting=}'[quoting style]:style:(0 1 2 3)' \
  '(-b --no-doublequote)'{-b,--no-doublequote}'[do not double quotes inside fields]' \
  '(-p --escapechar)'{-p+,--escapechar=}'[escape character]:char:' \
  '(-z --maxfieldsize)'{-z+,--maxfieldsize=}'[max field size]:n:' \
  '(-e --encoding)'{-e+,--encoding=}'[input encoding]:encoding:' \
  '--encoding-xls=[XLS input encoding]:encoding:' \
  '(-y --snifflimit)'{-y+,--snifflimit=}'[dialect sniff limit (bytes)]:n:' \
  '(-I --no-inference)'{-I,--no-inference}'[disable type inference]' \
  '(-f --format)'{-f+,--format=}'[input format]:format:(csv dbf fixed geojson grib2 hdf5 json ndjson parquet xls xlsx)' \
  '(-s --schema)'{-s+,--schema=}'[fixed-width schema CSV]:file:_files' \
  '(-k --key)'{-k+,--key=}'[top-level key for JSON]:key:' \
  '(-n --names)'{-n,--names}'[print sheet names]' \
  '--sheet=[Excel sheet to convert]:sheet:' \
  '--write-sheets=[write all sheets to files (or "-")]:prefix:' \
  '--use-sheet-names[use sheet names as output file names]' \
  '--reset-dimensions[ignore XLSX worksheet dimensions]' \
  '--date-format=[strptime date format]:format:' \
  '--datetime-format=[strptime datetime format]:format:' \
  '--null-value=[treat value as NULL]:value:' \
  '(-K --skip-lines)'{-K+,--skip-lines=}'[skip N initial rows]:n:' \
  '--zero[use zero-based indexing]' \
  '(-H --no-header-row)'{-H,--no-header-row}'[no header row]' \
  '(-v --verbose)'{-v,--verbose}'[verbose tracebacks]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:input file:_files' && return 0
