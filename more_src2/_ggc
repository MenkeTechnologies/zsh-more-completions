#compdef ggc
# Documentation: https://github.com/bmf-san/ggc
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# bmf-san/ggc - modern Git CLI / TUI. Subcommand list matches
# cmd/completions/ggc.zsh shipped with the upstream binary.

local curcontext="$curcontext" state line ret=1 expl

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'ggc command' compadd -- \
    add am archive bisect blame branch checkout cherry-pick clean clone \
    commit completion config debug-keys describe diff fetch grep help hook \
    log merge mv pull push rebase remote reset restore revert rm show stash \
    status submodule switch tag version
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
