#compdef dockerfile-lint
# _dockerfile-lint — rule-based Dockerfile linter (projectatomic/dockerfile_lint)
# upstream: https://github.com/projectatomic/dockerfile_lint

_arguments -s -S \
    '(-f --file)'{-f,--file}'=[Dockerfile to lint]:file:_files' \
    '(-r --rulefile)'{-r,--rulefile}'=[rule file]:file:_files -g "*.yaml *.yml *.json"' \
    '(-j --json)'{-j,--json}'[output results as JSON]' \
    '(-p --permissive)'{-p,--permissive}'[permissive mode (warn instead of error)]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]'
