#compdef pamthreshold
# Documentation: man pamthreshold (Netpbm)
# Source: threshold a Netpbm image to monochrome with simple / local / dual schemes.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-simple -local -dual)-simple[simple global threshold]' \
    '(-simple -local -dual)-local=[local-window threshold (widthxheight)]:window:' \
    '(-simple -local -dual)-dual=[dual-pass threshold (widthxheight)]:window:' \
    '-threshold=[threshold value 0..1]:threshold:' \
    '-contrast=[contrast threshold (local/dual)]:threshold:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
