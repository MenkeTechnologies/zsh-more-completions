#compdef instana instana-cli
# _instana — IBM Instana APM CLI (IBM Instana, Go); spf13/cobra
# upstream: https://github.com/instana/instana-agent

_instana() {
    local -a sub=(
        'application:manage applications'
        'service:manage services'
        'endpoint:manage endpoints'
        'event:manage events'
        'issue:manage issues'
        'incident:manage incidents'
        'snapshot:manage snapshots'
        'release:manage releases'
        'alert:manage alerts'
        'maintenance:manage maintenance windows'
        'metric:metric queries'
        'trace:fetch traces'
        'config:manage CLI config'
        'login:authenticate'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--instana-url=+[instana base url]:url:_urls' \
        '--api-token=+[instana api token]:str:' \
        '--insecure[skip tls verify]' \
        '--format=+[output format]:fmt:(table json yaml csv)' \
        '-o+[output format]:fmt:(table json yaml csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'instana subcommand' sub ;;
        args)
            case $words[1] in
                application|service|endpoint|event|issue|incident|snapshot|release|alert|maintenance) _arguments \
                    '1:cmd:(list get create update delete)' \
                    '--id=+[resource id]:id:' \
                    '*:arg:' ;;
                metric) _arguments \
                    '1:cmd:(query catalog)' \
                    '--metric=+[metric]:str:' \
                    '--from=+[from timestamp ms]:ts:' \
                    '--to=+[to timestamp ms]:ts:' \
                    '--rollup=+[rollup seconds]:n:' ;;
                trace) _arguments \
                    '1:cmd:(get list download)' \
                    '--trace-id=+[trace id]:str:' \
                    '--limit=+[limit]:n:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_instana "$@"
