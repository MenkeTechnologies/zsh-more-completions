#compdef purc
# =============================================================================
# purc — Vincent Wei + XueShuming's "the prime HVML
#          interpreter for C/C++ language" — a
#          standalone interpreter + debugger for HVML
#          (Hybrid Virtual Markup Language), a
#          descriptive markup-based programming
#          language proposed by Vincent Wei (also
#          author of MiniGUI, one of the earliest
#          open-source software projects in China).
#          HVML treats programs as XML-like documents
#          where elements + attributes define
#          computation; PurC parses those documents,
#          loads predefined dynamic variables, runs
#          the resulting coroutine pipeline against
#          a chosen renderer (headless / thread-local /
#          UNIX-socket / WebSocket), and emits the
#          rendered output.  PurC stands for both
#          "Prime HVML inteRpreter for C/C++" and
#          "Purring Cat" (the project mascot).
#          Distinguishing from XSLT (XML-as-program
#          for transformation; narrower scope), XQuery
#          (XML as data query lang; not general
#          purpose), HTML5 web browsers (HTML as
#          markup, not as program), DocBook + LaTeX
#          (declarative document languages, not
#          interpreted), and conventional scripting
#          languages (Python/JavaScript/Lua) (text-
#          based, not markup-based) by:
#            - MARKUP-AS-CODE — HVML programs are
#              well-formed XML documents where the
#              tag structure IS the program structure.
#              Elements like `<init>`, `<update>`,
#              `<choose>`, `<test>`, `<iterate>`,
#              `<forget>`, `<observe>`, `<execute>`
#              correspond to statements; attributes
#              configure their behavior.  No
#              parentheses, no curly braces, no
#              semicolons — just XML
#            - PREDEFINED DYNAMIC OBJECTS — HVML's
#              Predefined Variables V1.0 spec
#              defines a standard library of dynamic
#              objects ($SYS, $DOC, $URL, $L, $T,
#              $REQ, $TIMERS, $STREAM, $DATETIME,
#              $EJSON, $LOGGING, etc.) accessible as
#              `$variable_name.method(args)`.  These
#              are the "stdlib" any HVML program can
#              assume exists
#            - COROUTINE-FIRST EXECUTION MODEL —
#              every HVML program is a coroutine;
#              `-l, --parallel` lets multiple programs
#              run as concurrent coroutines sharing a
#              single PurC runtime; coroutines
#              communicate via STREAMS + EVENTS, not
#              shared memory
#            - PLUGGABLE RENDERER ARCHITECTURE — `-c,
#              --rdr-comm=<headless|thread|socket>`
#              selects how HVML programs render
#              their output:
#              * `headless` (default) — discard output
#                (suitable for compute-only HVML)
#              * `thread` — use in-process renderer
#                (`foil` text-mode renderer if
#                enabled, or `seeker` event-stream
#                renderer)
#              * `socket` — connect to external
#                renderer over UNIX domain socket
#                (`unix:///var/tmp/purcmc.sock`) or
#                WebSocket (`ws://...`) — used by GUI
#                HVML apps that render to a separate
#                xGUI process
#            - URL-CENTRIC INPUT — every HVML program
#              has a URL (typically `file://path/to/
#              program.hvml`); the runner name defaults
#              to `md5sum(first_url)` so different
#              programs get isolated runtime state
#              automatically
#            - DATA FETCHER ABSTRACTION — `-d,
#              --data-fetcher=<local|remote>` selects
#              how HVML's `$STREAM` and HTTP-fetching
#              primitives resolve URLs:
#              * `local` — only `file://` URLs
#                supported (no network access)
#              * `remote` — full URL scheme support
#                (http, https, ftp, etc.) via the
#                bundled `purc-fetcher` companion
#                binary
#            - REQUEST DATA INJECTION — `-j, --request=
#              <file|->` passes a JSON file (or
#              stdin via `-`) as the request payload
#              to the HVML programs; available as
#              `$REQ` inside the running coroutine.
#              `-q, --query='key=value&...'` provides
#              an alternative URL-query-string-style
#              request format
#            - USER-DEFINED QUERY KEYS — `--query-foo
#              bar` appends `foo=bar` to the implicit
#              query string; no need to manually
#              build query strings with `&` separators
#            - APP + RUNNER IDENTITY — `-a, --app=<n>`
#              + `-r, --runner=<n>` declare the
#              process-level identity that HVML
#              programs see via `$SYS.app` +
#              `$SYS.runner`.  Defaults to
#              `cn.fmsoft.hvml.purc` + first-program
#              URL md5sum
#            - PAGE + LAYOUT + TOOLKIT STYLING —
#              `--pageid=<id>` + `--layout-style=<>`
#              + `--toolkit-style=<>` + `--transition-
#              style=<>` configure the renderer-side
#              presentation of HVML programs that
#              target `plainwin` or `widget` page
#              types
#            - HARDENED RUNTIME — `--chroot <path>` +
#              `--setuser <user>` + `--setgroup
#              <group>` + `--daemon` provide standard
#              Unix process-hardening flags for
#              production deployments; appropriate
#              for running untrusted HVML programs
#              in isolation
#            - OUTPUT INSPECTION — `-p, --print-docs`
#              prints documents generated by
#              coroutines to STDOUT; `-t, --print-
#              result` prints exit results to STDOUT;
#              useful for CI integration + debugging
#            - VERBOSE MODE — `-v, --verbose` traces
#              every HVML evaluation step + every
#              predefined variable resolution;
#              indispensable for HVML programmers
#              learning the semantics
#            - 1,050+ STARS ON HVML/PurC — backed by
#              Vincent Wei + FMSoft (Beijing); the
#              HVML organization at github.com/HVML
#              hosts the language spec + multiple
#              related tools.  LGPLv3 license allows
#              commercial use under standard LGPL
#              dynamic-linking terms
#          Used by: HVML programmers (a small but
#          growing community in China, expanding
#          internationally as English docs improve),
#          researchers studying markup-based
#          programming languages, MiniGUI ecosystem
#          users who want to embed HVML in C/C++
#          applications, and curiosity-driven PL
#          enthusiasts interested in the road less
#          traveled by language designers.
#
# Author:  Vincent Wei (魏永明; also author of MiniGUI),
#          XueShuming, and the HVML team at FMSoft
#          (https://www.fmsoft.cn).  HVML language
#          specification at https://github.com/HVML/
#          hvml-docs.  PurC implementation at
#          https://github.com/HVML/PurC.
# Source:  https://github.com/HVML/PurC
#          https://github.com/HVML/PurC/blob/master/Source/Executables/purc/purc.c
# Manpage: No traditional manpage; `purc --help`
#          shows the comprehensive getopt-style help
#          + a copying notice.  Language specification
#          + tutorials at https://github.com/HVML/
#          hvml-docs.  An "HVML Programable Markup
#          Language" tutorial + a "Learn HVML
#          Programming in 30 Minutes" intro article
#          are available in both English and Chinese
# Library: PurC is implemented in C; depends on its
#          own runtime (purc + purc-fetcher) +
#          optionally Foil (built-in text-mode
#          renderer) + Seeker (built-in event-stream
#          renderer).  Built via CMake.  Not part of
#          the cross-language CLI library taxonomy
#          which tracks Rust/Go/TS-Node libraries —
#          PurC is a STANDALONE LANGUAGE
#          INTERPRETER entry.
# License: LGPL-3.0-or-later (PurC library + tools)
# Status:  1,050+ stars on HVML/PurC; active
#          development (latest commit 2026-05-31);
#          version 0.9.30; Linux + macOS support,
#          Windows port in progress.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY — 124th LANGUAGE CLOSES 3+1 MICRO-CYCLE
# -----------------------------------------------------------------------------
# This completion is the **124th language** entry in
# the cross-language CLI library taxonomy.  It closes
# the current 3+1 micro-cycle that began with R765
# Rust=99 (dockrtui/bollard OPENS Axis 44 Docker
# Client) → R766 Go=99 (dobi/fsouza/go-dockerclient
# continues Axis 44) → R767 TS-Node=99 (glci/
# dockerode CLOSES Axis 44 at 1/1/1) → R768 THIS
# (124th language).
#
# WHY HVML/PurC IS A DISTINCTIVE 124th-LANGUAGE
# ENTRY:
#
#   HVML occupies a unique position in the cross-
#   language taxonomy because it is the ONLY MARKUP-
#   BASED PROGRAMMING LANGUAGE among the corpus's
#   123 existing language slots.  Every other entry
#   uses text-based syntax (curly-brace, S-
#   expression, ML-influenced, Python-indent, etc.).
#   HVML instead uses well-formed XML/HTML markup
#   as its program syntax, with elements like
#   `<init>`, `<update>`, `<iterate>`, `<choose>`,
#   `<test>` carrying the semantic weight that
#   `let`, `=`, `for`, `if/else`, `match`
#   carry in conventional languages.
#
#   Distinguishing features in the broader cross-
#   language landscape:
#
#     1. MARKUP-AS-PROGRAM-SYNTAX — most languages
#        use text syntax with optional comments
#        marked by punctuation (// or #).  HVML
#        inverts this: the program IS XML; comments
#        are XML comments (<!--...-->).  Tooling
#        designed for XML (formatters, validators,
#        editors) Just Works for HVML
#
#     2. ASIAN PROVENANCE + CHINESE PL HISTORY —
#        HVML emerged from FMSoft (Beijing) +
#        Vincent Wei's two-decade open-source track
#        record (MiniGUI being the most prominent
#        prior project).  Few other corpus entries
#        come from the Chinese open-source PL
#        community; wenyan-lang (R716, classical
#        Chinese as syntax) is the only other
#        prominent example
#
#     3. PREDEFINED DYNAMIC OBJECTS as STDLIB —
#        instead of a module system, HVML's
#        Predefined Variables V1.0 spec defines a
#        standard set of dynamic objects every
#        program can use.  Different from Lua's
#        `_G`, Python's `__builtins__`, or JS's
#        global; the spec is normative + portable
#        across implementations
#
#     4. COROUTINE + STREAM + EVENT FIRST —
#        concurrency is built into the language
#        execution model from the start.  Every
#        program is a coroutine; multiple programs
#        run in parallel via `--parallel`; they
#        communicate via streams + events, not
#        shared memory
#
#     5. PLUGGABLE RENDERER ARCHITECTURE — separates
#        program execution (the purc binary) from
#        output rendering (foil / seeker / external
#        socket-connected GUI).  Few other corpus
#        languages have this clean separation of
#        compute from presentation
#
#     6. LGPL-3.0 — most ownership-typed-systems
#        + verification-language entries in the
#        corpus use MIT/Apache 2.0/BSD.  LGPL-3.0
#        represents the "free-for-commercial-use-
#        with-conditions" middle ground important
#        in some industry contexts
#
# Cross-language CLI library taxonomy after R768:
#   * 124 languages
#   * 477 total CLI library variants (Rust 99 / Go 99 /
#     TS-Node 99)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * 37 axes at 1/1/1 three-language symmetric
#   * **ALL THREE LANGUAGES at N=99**; next leader
#     bumps will each cross 100-library landmark
#
# Cross-language ECOSYSTEM context (Markup/Document-
# Based Programming Languages family in this
# corpus):
#   * HTML (technically not Turing-complete in spec;
#     extensively in corpus indirectly via web
#     frameworks)
#   * XSLT (XML transformation lang; in corpus as
#     `_xsltproc`)
#   * XQuery (XML data query lang; in corpus via
#     BaseX + Saxon)
#   * Wenyan (R716 classical Chinese as syntax; in
#     corpus)
#   * HVML / PurC (R768 THIS) — markup-as-program
#     for general-purpose computation, the only
#     XML-based GENERAL-PURPOSE language in the
#     corpus
#
# HVML joins this small markup-based-language
# family but is uniquely a GENERAL-PURPOSE
# programming language (not transformation,
# query, or stylistic syntax).
#
# Comparison to other 124th-language candidates:
#   * HVML/PurC (R768 THIS) — Vincent Wei + FMSoft,
#     1,050 stars, LGPL-3.0, active, MARKUP-AS-
#     PROGRAM uniqueness
#   * Borgo — 4,638 stars but binary name is
#     `compiler` (too generic); no clean install
#   * Wing — 5,386 stars but already in corpus as
#     `_wing`
#   * Cyber — already in corpus
#   * Pluto — already in corpus
#   * Ferret — already in corpus
#   * Onyx — already in corpus
#   * Vale — already in corpus
#   * Dora — already in corpus
#   * Eta — already in corpus
#   * Crystal — already in corpus
#   * Pyret — already in corpus
#   * Whiley — `_wyc` already in corpus
#
# HVML/PurC is the chosen 124th-language entry
# because:
#   - It has a real, installable CLI interpreter
#     (`purc`) with extensive option set (~22
#     long-options) suitable for a comprehensive
#     completion
#   - The markup-as-program design is structurally
#     distinct from every prior language entry in
#     the corpus's 123 existing slots
#   - Active maintenance + 1,050 stars indicate
#     non-trivial community traction
#   - The HVML organization at github.com/HVML
#     hosts multiple related repos (HVML spec,
#     documentation, syntax highlighters, sample
#     programs) suggesting an active ecosystem
#     beyond just the interpreter
#   - Vincent Wei's prior MiniGUI track record
#     (since 1999, one of the oldest Chinese open-
#     source projects) lends substantial provenance
#     to the language design
#   - The LGPL-3.0 license fills a gap in the
#     corpus's MIT-dominant license distribution
#
# -----------------------------------------------------------------------------
#
# THE purc CLI
#
# purc is a single-command HVML interpreter +
# debugger CLI built on getopt_long.  Invocation:
#   purc [ options ... ] [ file | url ] ... | [ app_desc_json | app_desc_ejson ]
#
# Positional arguments:
#   <file|url>...                     one or more HVML
#                                     source files
#                                     (.hvml or .html
#                                     suffix) or URLs
#                                     (file://... or
#                                     http(s)://...)
#   <app_desc_json>                   an app
#                                     description JSON
#                                     file (alternate
#                                     to file/url list)
#   <app_desc_ejson>                  an app
#                                     description
#                                     EJSON file
#
# Identity:
#   -a, --app=<NAME>                  app name
#                                     (default cn.
#                                     fmsoft.hvml.purc)
#   -r, --runner=<NAME>               runner name
#                                     (default md5sum
#                                     of first URL)
#
# Data fetching:
#   -d, --data-fetcher=<local|remote> data fetcher
#                                     (default local)
#
# Renderer:
#   -c, --rdr-comm=<KIND>             renderer comm:
#                                     headless |
#                                     thread |
#                                     socket
#   -u, --rdr-uri=<URI>               renderer URI or
#                                     shortname
#
# Request data:
#   -j, --request=<FILE|->            JSON request
#                                     file (- for
#                                     stdin)
#   -q, --query=<STRING>              URL query-
#                                     string-style
#                                     request data
#       --query-<KEY> <VALUE>         user-defined
#                                     key-value
#                                     appended to
#                                     query string
#
# Presentation (for `plainwin`/`widget` pages):
#       --pageid=<ID>                 page identifier
#       --layout-style=<STYLE>        layout style
#       --toolkit-style=<STYLE>       toolkit style
#       --transition-style=<STYLE>    transition style
#       --allow-switching-rdr         allow renderer
#                                     switching
#       --allow-scaling-by-density    allow scaling
#                                     by density
#
# Process hardening:
#   -R, --chroot=<PATH>               chroot to PATH
#   -U, --setuser=<USER>              setuid to USER
#   -G, --setgroup=<GROUP>            setgid to GROUP
#   -D, --daemon                      daemonize
#
# Execution + output:
#   -l, --parallel                    execute multiple
#                                     programs in
#                                     parallel
#   -p, --print-docs                  print documents
#                                     generated by
#                                     coroutines to
#                                     stdout
#   -t, --print-result                print exit
#                                     results to
#                                     stdout
#   -v, --verbose                     verbose
#
# Info:
#       --copying                     show detailed
#                                     copying info
#                                     and exit
#       --version                     show version
#                                     and exit
#   -h, --help                        show help
#
# Common invocations:
#   # Run an HVML program with the local data fetcher
#   purc hello.hvml
#
#   # Run via file URL
#   purc file:///path/to/program.hvml
#
#   # Pass request data from a JSON file
#   purc -j request.json program.hvml
#
#   # Pass request data via stdin
#   echo '{"name":"World"}' | purc -j - program.hvml
#
#   # Pass request data as URL query string
#   purc --query='name=World&lang=en' program.hvml
#
#   # User-defined query keys
#   purc --query-name World --query-lang en program.hvml
#
#   # Use the remote data fetcher for http(s) URLs
#   purc -d remote http://example.com/program.hvml
#
#   # Use the thread-based renderer with Foil text-mode
#   purc -c thread -u foil program.hvml
#
#   # Connect to a UNIX-socket-based renderer
#   purc -c socket -u unix:///var/tmp/purcmc.sock program.hvml
#
#   # Connect to a WebSocket-based renderer
#   purc -c socket -u ws://localhost:9090 program.hvml
#
#   # Run multiple programs as parallel coroutines
#   purc --parallel program1.hvml program2.hvml program3.hvml
#   purc -l program1.hvml program2.hvml
#
#   # Print all documents generated by the coroutines
#   purc -p program.hvml
#
#   # Print exit results of each coroutine
#   purc -t program.hvml
#
#   # Verbose mode (trace every evaluation step)
#   purc -v program.hvml
#
#   # Daemonize with hardened identity
#   purc -D -R /var/lib/purc/sandbox -U purc -G purc \
#       --rdr-comm socket --rdr-uri unix:///var/tmp/purcmc.sock \
#       /etc/purc/main.hvml
#
#   # Show version
#   purc --version
#
#   # Show full GPL copying notice
#   purc --copying
#
# OPTIONS (sourced directly from
# https://github.com/HVML/PurC/blob/master/Source/Executables/purc/purc.c):
#
# (See documentation above for the complete flag
# set.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _purc_data_fetchers
_purc_data_fetchers=(
    'local:use built-in fetcher; only file:// URLs'
    'remote:use remote fetcher; supports http/https/ftp'
)

local -a _purc_rdr_comm
_purc_rdr_comm=(
    'headless:built-in headless renderer (default)'
    'thread:in-process thread-based renderer (foil/seeker)'
    'socket:external UNIX/Local-Domain-Socket or WebSocket renderer'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version and exit]' \
    '(- *)--copying[show detailed copying info and exit]' \
    '(-a --app)'{-a,--app}'=[specify app name (default cn.fmsoft.hvml.purc)]:app name: ' \
    '(-r --runner)'{-r,--runner}'=[specify runner name (default md5 of first URL)]:runner name: ' \
    '(-d --data-fetcher)'{-d,--data-fetcher}'=[data fetcher]:fetcher:->fetcher' \
    '(-c --rdr-comm)'{-c,--rdr-comm}'=[renderer communication method]:comm:->rdrcomm' \
    '(-u --rdr-uri)'{-u,--rdr-uri}'=[renderer URI or shortname]:uri: ' \
    '(-j --request)'{-j,--request}'=[JSON request file (- for stdin)]:request file:_files -g "*.(json|JSON)"' \
    '(-q --query)'{-q,--query}'=[URL query string for request data]:query string: ' \
    '*--query-=[user-defined query key-value pair]:value: ' \
    '--pageid=[page identifier]:page id: ' \
    '--layout-style=[layout style]:layout: ' \
    '--toolkit-style=[toolkit style]:toolkit: ' \
    '--transition-style=[transition style]:transition: ' \
    '--allow-switching-rdr[allow switching renderer]' \
    '--allow-scaling-by-density[allow scaling by density]' \
    '(-R --chroot)'{-R,--chroot}'=[chroot path before execution]:chroot path:_directories' \
    '(-U --setuser)'{-U,--setuser}'=[setuid to user]:user:_users' \
    '(-G --setgroup)'{-G,--setgroup}'=[setgid to group]:group:_groups' \
    '(-D --daemon)'{-D,--daemon}'[daemonize the process]' \
    '(-l --parallel)'{-l,--parallel}'[execute multiple programs in parallel]' \
    '(-p --print-docs)'{-p,--print-docs}'[print documents generated by coroutines to stdout]' \
    '(-t --print-result)'{-t,--print-result}'[print exit result of coroutines to stdout]' \
    '(-v --verbose)'{-v,--verbose}'[execute with verbose output]' \
    '*:HVML file or URL:_files -g "*.(hvml|html|json|ejson|HVML|HTML|JSON)"' \
    && ret=0

case $state in
    fetcher)
        _describe -t fetchers 'data fetcher' _purc_data_fetchers && ret=0
        ;;
    rdrcomm)
        _describe -t rdrcomms 'renderer comm method' _purc_rdr_comm && ret=0
        ;;
esac

return ret
