#compdef miditui
# ============================================================================
# miditui - Terminal MIDI sequencer + player (Rust, MIT)
#
# Author : Max Woolf (minimaxir)
# Upstream: https://github.com/minimaxir/miditui
#
# miditui is a ratatui-driven DAW-style terminal application for
# composing, mixing, and playing MIDI music. It provides a piano
# roll editor, an interactive keyboard for live note input, multi-
# track composition with unlimited tracks, real-time SoundFont
# synthesis (rustysynth + rodio audio output), WAV export, and
# JSON project save/load with autosave + crash recovery.
#
# The MIDI file lane is built on `midly = "0.5"` (declared verbatim
# at upstream Cargo.toml HEAD), the canonical Rust MIDI parser +
# writer by kovaxis (github.com/kovaxis/midly, 180+ stars).
# midly implements the SMF (Standard MIDI File) format end-to-end:
# SMF0/1/2 file formats, the full Channel/SysEx/Meta event
# taxonomy, variable-length quantity decoding, running status,
# pitch bend / aftertouch / control change, tempo + time signature
# meta events, lyrics + markers, and bidirectional encoding -
# every byte of the SMF spec round-trips through the library's
# typed API (`Smf::parse(bytes) -> Smf` and `smf.write_std(writer)`).
#
# ----------------------------------------------------------------------------
# AXIS 204 :: MIDI / STANDARD MIDI FILE (SMF 0/1/2)
# Round 1310 :: Rust slot 1 of 4 :: OPENS Axis 204
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : kovaxis/midly                  - SMF 0/1/2 parser + writer (speed-focused)
#   Go      : gomidi/midi                    - SMF + live MIDI I/O umbrella
#   TS/Node : Tonejs/Midi                    - SMF parser + writer for JS / TypeScript
#
# All three target the same SMF wire format (1996 MMA spec)
# but converged on different ergonomics: midly in Rust is zero-
# copy parsing-focused (returns slices into the input buffer for
# track events, no allocation per event); gomidi/midi in Go
# wraps both file I/O and live MIDI device I/O (RtMidi C library)
# behind a single import path; Tonejs/Midi in JS is class-based
# with chainable mutation (`.addTrack().addNote({pitch, ticks, ...})`).
#
# miditui is the Rust opener and stress-tests midly with a full
# DAW workflow: read SoundFonts (.sf2 via rustysynth), edit + insert
# notes through the piano roll, synthesize audio in real-time via
# rodio, and export to .mid (midly emit) or .wav (rustysynth +
# rodio). The "MIDI in / WAV out" pipeline exercises every event
# class in the SMF taxonomy.
# ============================================================================

_miditui() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-n --new)'{-n,--new}'[start a fresh project (skip autosave recovery)]' \
        '(-sf --soundfont)'{-sf,--soundfont}'[load a specific SoundFont file (.sf2)]:soundfont:_files -g "*.sf2"' \
        '(- *)'{-h,--help}'[print help]'
}

_miditui "$@"
