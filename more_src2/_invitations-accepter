#compdef invitations-accepter
# _invitations-accepter — Prow tool that accepts GitHub repo collaboration invitations (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/invitations-accepter/main.go (flag).

_invitations-accepter() {
    _arguments \
        '-dry-run=[dry run for testing]:val:(true false)' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls' \
        '-github-app-id=[GitHub App ID]:id:' \
        '-github-app-private-key-path=[GitHub App private key]:file:_files'
}

_invitations-accepter "$@"
