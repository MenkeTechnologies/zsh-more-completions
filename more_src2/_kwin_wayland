#compdef kwin_wayland
# _kwin_wayland — KDE Plasma kwin_wayland CLI launching the KWin compositor and window manager native Wayland session backend on DRM gbm Xwayland virtual headless framebuffer modes with seat input device permissions and per-display socket binding (KDE team, C++); Qt argparse
# upstream: https://invent.kde.org/plasma/kwin

_kwin_wayland() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--socket=+[socket name]:str:' \
        '--no-global-shortcuts[disable global shortcuts]' \
        '--lockscreen[start in lockscreen mode]' \
        '--no-lockscreen[do not start in lockscreen mode]' \
        '--no-kactivities[disable kactivities]' \
        '--replace[replace existing]' \
        '--xwayland[start Xwayland]' \
        '--no-xwayland[do not start Xwayland]' \
        '--xwayland-display=+[display]:str:' \
        '--xwayland-xauthority=+[file]:file:_files' \
        '--virtual[use virtual backend]' \
        '--width=+[w]:n:' \
        '--height=+[h]:n:' \
        '--scale=+[s]:n:' \
        '--output-count=+[N]:n:' \
        '--drm[use drm backend]' \
        '--fb-device=+[file]:file:_files -g "/dev/fb*"' \
        '--wayland-socket-fd=+[fd]:n:' \
        '--inputmethod=+[interpreter]:file:_files' \
        '--locale1[use locale1]' \
        '--exit-with-session=+[session]:str:' \
        '--wayland-display=+[name]:str:' \
        '*:exec:_files'
}

_kwin_wayland "$@"
