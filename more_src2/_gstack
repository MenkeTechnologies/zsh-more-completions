#compdef gstack
# Documentation: https://linux.die.net/man/1/gstack
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gstack: print stack trace of a running process (wraps gdb).

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:pid:_pids' && ret=0

return ret
