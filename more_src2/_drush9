#compdef drush9
# _drush9 — Drupal drush9 Drupal Shell binary CLI for Drupal 9/10/11 administration site-install module-enable config-export theme-install pm-update entity-updates queue-run user operations via Composer-installed drush (drush-ops team, PHP); Symfony Console
# upstream: https://github.com/drush-ops/drush

_drush9() {
    local -a sub=(
        'cache:rebuild:rebuild cache'
        'config:edit:edit config interactively'
        'config:export:export config'
        'config:import:import config'
        'config:status:config status'
        'core:cron:run cron'
        'core:status:show site status'
        'core:rsync:rsync between aliases'
        'core:requirements:show requirements'
        'deploy:run deploy hook'
        'deploy:hook:run deploy hooks'
        'entity:delete:delete entity'
        'entity:save:save entity'
        'image:flush:flush image style'
        'language:add:add language'
        'language:info:show language info'
        'locale:check:check translations'
        'locale:update:update translations'
        'maint:get:get maintenance mode'
        'maint:set:set maintenance mode'
        'migrate:import:run migration'
        'migrate:status:migration status'
        'migrate:reset-status:reset migration status'
        'migrate:stop:stop migration'
        'migrate:rollback:rollback migration'
        'php:eval:evaluate PHP'
        'php:script:run PHP script'
        'pm:install:install module'
        'pm:uninstall:uninstall module'
        'pm:list:list modules'
        'queue:list:list queues'
        'queue:run:run queue'
        'queue:delete:delete queue'
        'role:create:create role'
        'role:perm:add:add role permission'
        'site:install:install drupal site'
        'sql:cli:open SQL CLI'
        'sql:dump:dump SQL'
        'sql:query:run SQL query'
        'sql:sync:sync SQL between aliases'
        'state:get:get state'
        'state:set:set state'
        'theme:install:install theme'
        'updatedb:run database updates'
        'user:create:create user'
        'user:login:login as user'
        'user:block:block user'
        'user:unblock:unblock user'
        'user:password:set password'
        'watchdog:list:list watchdog'
        'watchdog:show:show watchdog'
        'help:show help'
        'list:list commands'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '-n[no confirm]' \
        '--no[no confirm]' \
        '-r+[drupal root]:dir:_files -/' \
        '--root=+[drupal root]:dir:_files -/' \
        '-l+[uri]:str:' \
        '--uri=+[uri]:str:' \
        '-d[debug]' \
        '--debug[debug]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '--format=+[format]:f:(table list json yaml csv var_dump var_export print_r tsv string md xml)' \
        '--fields=+[csv]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drush9 subcommand' sub ;;
        args) ;;
    esac
}

_drush9 "$@"
