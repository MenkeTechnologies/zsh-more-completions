#compdef refind-install mkrlconf refind-mkdefault refind-mvrefind refind-mkfont
# Documentation: https://www.rodsbooks.com/refind/installing.html
# Documentation: https://www.rodsbooks.com/refind/refind-install.html
# Documentation: https://www.rodsbooks.com/refind/mkrlconf.html
# Documentation: https://www.rodsbooks.com/refind/refind-mkdefault.html
# Documentation: https://www.rodsbooks.com/refind/mvrefind.html
# Reference accessed: 2026-05-27
# Verified: upstream rodsbooks.com refind man pages (refind project, Roderick W. Smith)

# Zsh completion for the rEFInd EFI boot manager helper scripts.

local curcontext="$curcontext" state line ret=1
local cmd=${words[1]}

case $cmd in
  refind-install)
    _arguments -s -S \
      '--alldrivers[copy all driver files for the system architecture]' \
      '--nodrivers[skip driver installation for reading /boot]' \
      '--shim[set up Secure Boot via Shim]:shim-file:_files' \
      '--preloader[set up Secure Boot via PreLoader]:preloader-file:_files' \
      '--localkeys[generate and use locally-stored Machine Owner Key for signing]' \
      '--encryptkeys[encrypt the locally-stored private key with a password]' \
      '--ownhfs[install to an HFS+ volume other than the default Mac boot volume]:device:_files' \
      '--notesp[install to the current macOS root partition instead of the ESP]' \
      '--root[install from a live CD or rescue system rooted at mount-point]:mount-point:_files -/' \
      '--usedefault[install using default/fallback EFI filename to a device]:device:_files' \
      '--keepname[preserve regular rEFInd filename when used with shim]' \
      '--shortform[use bless shortform option (macOS)]' \
      '--yes[assume yes to all prompts]' && ret=0
    ;;
  mkrlconf)
    _arguments -s -S \
      '--force[replace an existing /boot/refind_linux.conf]' && ret=0
    ;;
  refind-mkdefault)
    _arguments -s -S \
      '(-L --label)'{-L+,--label=}'[search efibootmgr output for this label instead of "refind"]:label:' && ret=0
    ;;
  refind-mvrefind)
    # refind-mvrefind takes two positional arguments and no documented options.
    _arguments \
      '1:source:_files -/' \
      '2:destination:_files -/' && ret=0
    ;;
  refind-mkfont)
    # refind-mkfont is a thin wrapper around FontForge with no documented CLI flags.
    _arguments '*:font:_files' && ret=0
    ;;
esac

return ret
