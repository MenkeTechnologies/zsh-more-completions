#compdef ggh
# Documentation: https://github.com/byawitz/ggh
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# byawitz/ggh - SSH session memory wrapper.
# Real flag set per internal/command/flags.go: --history, --config, '-' (dash).
# Any other args are forwarded straight to ssh.

local ret=1
_arguments -s -S \
  '--history[list saved history non-interactively]' \
  '--config[list ssh config hosts non-interactively]' \
  '*::host:_ssh_hosts' && ret=0
return ret
