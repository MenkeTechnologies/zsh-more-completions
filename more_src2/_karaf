#compdef karaf
# Documentation: https://github.com/apache/karaf/blob/main/assemblies/features/base/src/main/filtered-resources/resources/bin/karaf
# Reference accessed: 2026-05-19
# Verified: upstream bin/karaf script (case statement) at the URL above.
# Prior file invented "clean", "help" and "shutdown" args; real arguments
# are the case branches below (no arg = console mode).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'console:start Karaf with local console access (default)'
  'server:start without local console (with remote shell)'
  'run:run in foreground with full logging output'
  'daemon:start as background daemon process'
  'debug:enable JVM debugging mode'
  'debugs:enable JVM debugging with suspend-on-start'
  'status:report the running instance status'
  'stop:terminate the running Karaf instance'
  'client:connect to a remote Karaf instance'
  'classpath:display the configured classpath'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'karaf argument' subcommands && ret=0
    ;;
esac

return ret
