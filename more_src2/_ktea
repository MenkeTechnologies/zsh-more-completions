#compdef ktea
# Documentation: https://github.com/jonas-grgt/ktea/blob/main/cmd/ktea/main.go
# Reference accessed: 2026-05-19
# Verified: upstream cmd/ktea/main.go flag.BoolVar definitions - only
# -debug and -plain-fonts are parsed (Go flag package, single dash).
# Removed from prior file: fabricated -h/--help, -V/--version, --config
# flags and bogus man.archlinux.org search URL.

local curcontext="$curcontext" ret=1

_arguments -s \
  '-debug[enable debug logging to debug.log]' \
  '-plain-fonts[disable NerdFonts (if you see weird icons)]' && ret=0

return ret
