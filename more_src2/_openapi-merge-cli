#compdef openapi-merge-cli
# _openapi-merge-cli — merge multiple OpenAPI specs into one (robertmassaioli/openapi-merge)
# upstream: https://github.com/robertmassaioli/openapi-merge
# Flags from packages/openapi-merge-cli/src/index.ts (commander).

_openapi-merge-cli() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[merge configuration file]:file:_files -g "*.json"' \
        '--restrict-output-to=[refuse to write outside this dir]:dir:_files -/'
}

_openapi-merge-cli "$@"
