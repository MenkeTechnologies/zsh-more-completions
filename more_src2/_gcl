#compdef gcl
# Documentation: man gcl(1)
# Source: GNU Common Lisp gcl (man) — Common Lisp Ansi subset (C + Lisp).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-eval+[evaluate Lisp expression]:expr:_default' \
    '*-load+[load Lisp file]:file:_files -g "*.{lisp,lsp}"' \
    '-f+[execute script file]:file:_files' \
    '-batch[batch mode (no REPL)]' \
    '-dir+[startup directory]:dir:_files -/' \
    '-libdir+[library directory]:dir:_files -/' \
    '-compile+[compile Lisp file]:file:_files -g "*.{lisp,lsp}"' \
    '-o-file+[compiled output object file]:file:_files' \
    '-c-file+[generated C output file]:file:_files' \
    '-h-file+[generated H output file]:file:_files' \
    '-data-file+[output data file]:file:_files' \
    '-system-p[system mode for compilation]' \
    '--[separator; rest passed to si\:\:\*command-args\*]' \
    '*::lisp args:_default' \
    && ret=0

return ret
