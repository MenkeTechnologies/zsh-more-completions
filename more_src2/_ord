#compdef ord
# Documentation: https://github.com/ordinals/ord
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ord: ordinal theory CLI for Bitcoin
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'server:run block explorer / index server'
  'wallet:wallet management (requires Bitcoin Core)'
  'index:build the satoshi index'
  'find:find satoshi location'
  'list:list satoshis in a UTXO'
  'parse:parse satoshi names/numbers'
  'subsidy:show subsidy of a block'
  'supply:show ordinal supply'
  'teleburn:generate teleburn addresses'
  'epochs:list epoch sat ranges'
  'env:set up env for development'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ord command' commands && ret=0 ;;
esac

return ret
