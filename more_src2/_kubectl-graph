#compdef kubectl-graph
# Documentation: https://github.com/steveteuber/kubectl-graph/blob/main/pkg/cmd/cmd.go
# Reference accessed: 2026-05-19
# Verified: upstream source (pkg/cmd/cmd.go) flag definitions at the URL
# above. configFlags adds standard kubectl genericclioptions flags.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[list objects across all namespaces]' \
  '--chunk-size=[return large lists in chunks (0 disables)]:size:' \
  '(-t --truncate)'{-t+,--truncate=}'[truncate node name to N characters]:n:' \
  '--field-selector=[field selector to filter on]:selector:' \
  '(-l --selector)'{-l+,--selector=}'[label selector to filter on]:selector:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(aql arangodb cql cypher dot graphviz mermaid)' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '*::resource or args:_default'
