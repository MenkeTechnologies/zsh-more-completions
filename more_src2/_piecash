#compdef piecash
# _piecash — read/write GnuCash books from Python (sdementen/piecash)
# upstream: https://github.com/sdementen/piecash
# Subcommands from piecash/scripts/.

_piecash() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'ledger:export GnuCash book to ledger-cli format'
                'qif-export:export GnuCash book to QIF format'
                'export:export GnuCash data'
                'prices:download prices for commodities'
                'sql:execute SQL helper'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                ledger)
                    _arguments \
                        '(--locale --no-locale)--locale[use locale currency format]' \
                        '(--locale --no-locale)--no-locale[do not use locale currency format]' \
                        '(--commodity-notes --no-commodity-notes)--commodity-notes[include commodity notes]' \
                        '(--commodity-notes --no-commodity-notes)--no-commodity-notes[exclude commodity notes]' \
                        '(--short-account-names --no-short-account-names)--short-account-names[use short account names]' \
                        '(--short-account-names --no-short-account-names)--no-short-account-names[use full account names]' \
                        '--output=[output file (- for stdout)]:file:_files' \
                        '1:GnuCash book:_files -g "*.gnucash"'
                    ;;
                qif-export) _arguments '--output=[output file]:file:_files' '1:GnuCash book:_files' ;;
                prices) _arguments '1:GnuCash book:_files' ;;
                sql) _arguments '1:GnuCash book:_files' ;;
            esac
            ;;
    esac
}

_piecash "$@"
