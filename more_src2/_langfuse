#compdef langfuse langfuse-cli
# Documentation: https://github.com/langfuse/langfuse-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Commands are auto-generated from
# the Langfuse OpenAPI spec via specli; resource/action lists below are a
# representative subset documented in upstream README.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'api:invoke any Langfuse API endpoint (resource + action)'
  'get-skill:print the agent skill file for use in AI prompts'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--public-key=[Langfuse public key]:key:' \
  '--secret-key=[Langfuse secret key]:key:' \
  '--host=[Langfuse host URL]:url:' \
  '--env=[load env vars from file]:file:_files' \
  '--profile=[use named config profile]:profile:' \
  '--json[output JSON]' \
  '--curl[print curl command for the request]' \
  '--limit=[pagination limit]:n:' \
  '--refetch-api-spec[refetch OpenAPI spec]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'langfuse command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (api)
        local -a resources=(
          '__schema:print full OpenAPI schema'
          'traces:traces (list/get)'
          'observations:observations'
          'sessions:sessions'
          'prompts:prompts (list/get/create)'
          'datasets:datasets'
          'dataset-items:dataset items'
          'score-v2s:scores v2'
          'projects:projects'
          'organizations:organizations'
          'metrics:metrics'
          'media:media files'
          'comments:comments'
          'annotations:annotation queues'
          'health:server health'
          'ingestion:ingestion endpoint'
        )
        _describe -t res 'resource' resources && ret=0
        local -a actions=(
          'list:list resources'
          'get:fetch a single resource'
          'create:create a resource'
          'update:update a resource'
          'delete:delete a resource'
        )
        _describe -t actions 'action' actions && ret=0 ;;
    esac ;;
esac

return ret
