#compdef jbang
# Documentation: https://github.com/jbangdev/jbang/blob/main/src/main/java/dev/jbang/cli/JBang.java
# Reference accessed: 2026-05-19
# Verified: jbangdev/jbang source — JBang.java subcommands array
# and global @Option set; RunMixin.java / BuildMixin.java for the
# run-command options. Removed invented global --config option.

# Zsh completion for jbang - Java scripting

local curcontext="$curcontext" state line ret=1

_jbang_commands() {
  local -a commands=(
    'run:builds and runs provided script'
    'build:compiles and caches script without running'
    'edit:setup a temporary project for an IDE'
    'init:initialize a script'
    'alias:manage aliases for scripts'
    'template:manage templates for scripts'
    'catalog:manage catalogs of aliases'
    'trust:manage which URLs you trust'
    'cache:manage cache (clear)'
    'completion:output completion script for shell'
    'jdk:manage installed JDKs'
    'version:display version info'
    'wrapper:create/remove jbang wrapper script'
    'info:provides info about the script'
    'app:install or manage jbang scripts as system commands'
    'export:export script as jar, mvn, native, portable, etc.'
    'config:manage jbang configuration'
    'deps:print the resolved dependencies of a script'
  )
  _describe -t commands 'jbang command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[display version info]' \
  '--preview[enable jbang preview features]' \
  '--verbose[jbang will be verbose on what it does]' \
  '--quiet[jbang will be quiet, only print on error]' \
  '(-x --stacktrace)'{-x,--stacktrace}'[print exceptions stacktraces to stderr]' \
  '(-o --offline)'{-o,--offline}'[work offline, fail-fast if dependencies missing]' \
  '--fresh[use fresh (non-cached) resources]' \
  '1: :_jbang_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-j --java)'{-j,--java}'[JDK version to use]:version:' \
          '(-m --main)'{-m,--main}'[main class to use when running]:class:' \
          '*'{-R,--runtime-option}'[options to pass to the Java runtime]:option:' \
          '--jfr=[start a JFR recording]::config:' \
          '(-d --debug)'{-d,--debug}'[launch with java debug enabled on port]::port:' \
          '--ea[enable assertions]' \
          '--esa[enable system assertions]' \
          '*--javaagent=[use the given jar as a javaagent]:agent:' \
          '(-i --interactive)'{-i,--interactive}'[activate interactive mode]' \
          '*:script:_files' && ret=0
        ;;
      build|info|export|deps|edit)
        _arguments \
          '*:script:_files' && ret=0
        ;;
      init)
        _arguments \
          '(-t --template)'{-t,--template}'[init script with a template]:template:' \
          '--force[force overwrite of existing files]' \
          '*:file:_files' && ret=0
        ;;
      alias)
        _arguments \
          '1:subcommand:(add list remove)' \
          '*:alias:' && ret=0
        ;;
      catalog)
        _arguments \
          '1:subcommand:(add list remove update)' && ret=0
        ;;
      template)
        _arguments \
          '1:subcommand:(add list remove)' && ret=0
        ;;
      jdk)
        _arguments \
          '1:subcommand:(install list uninstall default java-env home)' && ret=0
        ;;
      app)
        _arguments \
          '1:subcommand:(install uninstall list setup)' && ret=0
        ;;
      cache)
        _arguments \
          '1:subcommand:(clear)' && ret=0
        ;;
      trust)
        _arguments \
          '1:subcommand:(add list remove)' && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
