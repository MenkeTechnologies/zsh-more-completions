#compdef gdal_footprint
# Documentation: https://gdal.org/en/stable/programs/gdal_footprint.html
# Source: OSGeo/gdal apps/gdal_footprint_bin.cpp — compute polygon footprint of a raster.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--help-general[show generic GDAL options]' \
    '(-q --quiet)'{-q,--quiet}'[suppress progress output]' \
    '*-b+[band of interest (1-based)]:band:_default' \
    '-combine_bands+[mask combination]:mode:(union intersection)' \
    '-ovr+[overview level (0-based)]:idx:_default' \
    '-srcnodata+[input nodata values]:vals:_default' \
    '-t_cs+[target coordinate system]:cs:(pixel georef)' \
    '-t_srs+[target CRS]:srs:_default' \
    '-split_polys[split multipolygons into single-polygon features]' \
    '-convex_hull[compute convex hull of polygons]' \
    '-densify+[max distance between consecutive output points]:value:_default' \
    '-simplify+[tolerance for merging consecutive points]:value:_default' \
    '-min_ring_area+[minimum ring area threshold]:area:_default' \
    '-max_points+[max points per geometry (default 100)]:n:_default' \
    '*-oo+[dataset open option NAME=VALUE]:option:_default' \
    '-of+[output format]:format:_default' \
    '-location_field_name+[field name for input path (default location)]:name:_default' \
    '-no_location[disable writing input dataset path]' \
    '-write_absolute_path[write absolute path]' \
    '*-lco+[layer creation option NAME=VALUE]:option:_default' \
    '*-dsco+[dataset creation option NAME=VALUE]:option:_default' \
    '-lyr_name+[output layer name (default footprint)]:name:_default' \
    '-overwrite[replace existing target layer]' \
    '-dst_field+[destination field name]:name:_default' \
    '1:input file:_files' \
    '2:output file:_files' \
    && ret=0

return ret
