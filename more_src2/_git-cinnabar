#compdef git-cinnabar git-remote-hg
# Documentation: https://github.com/glandium/git-cinnabar
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-cinnabar - Mercurial<->Git bridge

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'setup:initialize git-cinnabar after install'
      'upgrade:upgrade metadata for older versions'
      'hg2git:translate Mercurial changeset to git commit'
      'git2hg:translate git commit to Mercurial changeset'
      'fetch:fetch from a Mercurial repository'
      'fsck:validate and repair metadata'
      'reclone:reclone repositories using git-cinnabar'
      'rollback:roll back to a previous state'
      'data:dump or inspect raw data'
      'unbundle:apply a Mercurial bundle'
      'bundle:create a Mercurial bundle'
    )
    _describe -t commands 'git-cinnabar command' commands && ret=0
    ;;
  args)
    case $line[1] in
      fsck)
        _arguments -s -S \
          '--full[perform a complete validation pass]' && ret=0
        ;;
      fetch)
        _arguments -s -S \
          '--tags[fetch tags]' \
          '*:args:_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
