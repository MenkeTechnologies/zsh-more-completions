#compdef licensor
# Documentation: https://github.com/raftario/licensor
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# licensor SPDX_ID [copyright_holder] [--skip-optional]

local ret=1
_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)--licenses[list available licenses]' \
  '--skip-optional[skip optional sections]' \
  '1::SPDX license id:' \
  '2::copyright holder name:' && ret=0
return ret
