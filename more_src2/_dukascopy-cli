#compdef dukascopy-cli dukascopy-node
# ---------------------------------------------------------------------------
# dukascopy-cli / dukascopy-node — download historical and real-time price
#                                   tick data for Crypto / Stocks / ETFs /
#                                   CFDs / Forex from Dukascopy Bank
#                                   (TypeScript/Node.js, 769★)
#
# upstream: https://github.com/Leo4815162342/dukascopy-node
# author : Leonid Pyrlia (Leo4815162342)
# license: MIT
# npm    : `dukascopy-node` v1+
# binaries: both `dukascopy-cli` and `dukascopy-node` resolve to
#           ./dist/cli/index.js — `dukascopy-node` is the "use the
#           library name as the bin name" alias, `dukascopy-cli` is the
#           canonical bin name; either invocation works identically.
#
# Source-direct completion: every flag below is verbatim from src/cli/
# config.ts on the Leo4815162342/dukascopy-node tip — commander.js
# `program.option(...)` / `program.requiredOption(...)` registrations
# parsed exactly as declared.
#
# Direct deps from package.json (selected):
#   dayjs              1.11.10  ← canonical Node.js / browser modern
#                                 datetime library (this axis) — by
#                                 iamkun (Yuche Wu) at the dayjs
#                                 collective; 2KB minified gzipped
#                                 immutable date wrapper inspired by
#                                 Moment.js's API surface but without
#                                 Moment.js's 70KB footprint.  Pulled
#                                 in here alongside `dayjs/plugin/utc`
#                                 + `dayjs/plugin/timezone` for the
#                                 IANA-aware date arithmetic that
#                                 powers `--date-from` / `--date-to`
#                                 normalization across the configured
#                                 `--time-zone`.
#   commander                   (TJ Holowaychuk's commander.js)
#   chalk + debug + fs-extra    (utility stack)
#   fastest-validator           (fastestvalidator.com Icebob's runtime
#                                schema validator for the parsed CLI
#                                config object)
#
# dukascopy-node downloads OHLC/tick price data from Dukascopy Bank's
# public historical-data feed for any instrument they cover (FX pairs,
# crypto, stocks, ETFs, CFDs).  Date ranges, timeframe aggregation
# (tick → mn1), price-type (bid/ask), volumes, UTC offset, and output
# format (csv/json/array) all configurable.  Caches batch downloads
# locally under `--cache-path` to avoid re-fetching the same artifact.
# Common workflow: backtest engines that need a year of M5 EURUSD bars
# pipe this CLI's `--format csv` output straight into pandas/polars.
#
# ============================================================================
# === AXIS 177 CLOSES — modern datetime libraries (post-stdlib/Moment.js) ==
# === TRIPLE-232 ROUND-NUMBER LANDMARK · 170th AXIS CLOSED =================
# ============================================================================
# Axis position: TS-Node=232 CLOSES Axis 177 at slot 1/1/1 — quadruple-clean
# closure of the canonical modern datetime library ecosystem spanning the
# three major systems languages.  All three lanes anchor on a single
# library by a single recognized maintainer that improves upon the
# language's stdlib/legacy datetime API (chrono / time / Moment.js):
#
#     Rust    : jiff                    by Andrew Gallant (BurntSushi/
#                                        jiff); inspired by JavaScript's
#                                        Temporal proposal and Java's
#                                        java.time package.  DST-safe
#                                        calendar+absolute duration
#                                        arithmetic, IANA TZDB, RFC 5545
#                                        recurrence rules, typed Zoned/
#                                        DateTime/Span trinity that
#                                        prevents chrono-style pitfalls
#                                        around naive timezone math.
#                 → bttf (Andrew Gallant BurntSushi — Back to the Future
#                          command-line tool for datetime arithmetic
#                          parsing formatting and tagging; CLI surface
#                          over the jiff API by the jiff author himself
#                          with span / time / tag / tz / untag subtrees;
#                          657★ Unlicense OR MIT v0.1.4)
#                 _bttf            [Rust=232 OPENED Axis 177, slot 1/0/0]
#
#     Go      : github.com/dromara/carbon  by gouguoyin (formerly
#                                          golang-module/carbon, now at
#                                          the dromara collective);
#                                          fluent date library inspired
#                                          by PHP's Carbon, providing
#                                          rich datetime parsing /
#                                          formatting / arithmetic /
#                                          timezone-conversion /
#                                          localized-output for 17+
#                                          human languages.
#                 → ddns-route53 (Kevin Alvarez crazy-max CrazyMax —
#                                 Dynamic DNS for Amazon Route 53 on a
#                                 time-based schedule; routes log
#                                 timestamps + schedule arithmetic
#                                 through dromara/carbon/v2; 407★ MIT v2)
#                 _ddns-route53   [Go=232 CONTINUED Axis 177, slot 2/0/0]
#
#     JS/Node : dayjs                   by iamkun (Yuche Wu) at the
#                                       dayjs collective; 2KB minified
#                                       gzipped immutable date wrapper
#                                       with Moment.js-compatible API
#                                       surface but 1/40th the bundle
#                                       size.  THE modern Moment.js
#                                       successor — used by Element-UI,
#                                       Naive UI, Quasar, every Vue/
#                                       React i18n library, and the
#                                       majority of Node CLIs that emit
#                                       user-visible timestamps.
#                 → dukascopy-cli (Leonid Pyrlia Leo4815162342 — download
#                                  historical+real-time price tick data
#                                  for Crypto/Stocks/ETFs/CFDs/Forex
#                                  from Dukascopy Bank; date-range
#                                  arithmetic across instrument-specific
#                                  TZ offsets via dayjs + utc + timezone
#                                  plugins; 769★ MIT)
#                 _dukascopy-cli  [TS-Node=232 CLOSES Axis 177, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 dayjs is the de-facto npm datetime library for size-
#                 sensitive contexts — the @types/luxon + luxon combo
#                 weighs 70KB+; dayjs ships 2KB minified.  For CLI tools
#                 that ship via npm and care about cold-start install
#                 size + parse time, dayjs is the default pick.
#
# Round-number 232 landmark fires simultaneously across all three lanes:
# Rust completion #232 (_bttf) + Go completion #232 (_ddns-route53) +
# TS-Node completion #232 (_dukascopy-cli) = triple-232.  Axis #170
# closed in the lifetime of the corpus — every modern datetime library
# in the three big systems languages that improves upon its respective
# language's stdlib / legacy datetime API now has both a representative
# consumer completion AND a documented axis closure landmark; the lanes
# are tied together by a common design discipline (immutable date
# wrapper + IANA timezone integration + DST-safe arithmetic + fluent or
# typed API surface that prevents stdlib pitfalls).
# ============================================================================

_dukascopy-cli() {
    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-d --debug)'{-d,--debug}'[output extra debugging (env DEBUG=dukascopy-node:cli:*)]' \
        '(-s --silent)'{-s,--silent}'[hide the search config in the CLI output]' \
        '(-i --instrument)'{-i,--instrument=}'[trading instrument (REQUIRED; e.g. eurusd, btcusd, aapl)]:instrument:' \
        '(-from --date-from)'{-from,--date-from=}'[from date (REQUIRED; yyyy-mm-dd)]:from date:' \
        '(-to --date-to)'{-to,--date-to=}'[to date (default `now`; yyyy-mm-dd or `now`)]:to date:' \
        '(-t --timeframe)'{-t,--timeframe=}'[timeframe aggregation (default d1)]:timeframe:(tick s1 m1 m5 m15 m30 h1 h4 d1 mn1)' \
        '(-p --price-type)'{-p,--price-type=}'[price type (default bid)]:price type:(bid ask)' \
        '(-utc --utc-offset)'{-utc,--utc-offset=}'[UTC offset in minutes (default 0)]:minutes:' \
        '(-v --volumes)'{-v,--volumes}'[include volumes (default false)]' \
        '(-vu --volume-units)'{-vu,--volume-units=}'[volume units (default millions)]:unit:(millions thousands units)' \
        '(-fl --flats)'{-fl,--flats}'[include flats (0-volume bars) (default false)]' \
        '(-f --format)'{-f,--format=}'[output format (default json)]:format:(csv json array)' \
        '(-dir --directory)'{-dir,--directory=}'[download directory (default ./download)]:directory:_files -/' \
        '(-bs --batch-size)'{-bs,--batch-size=}'[batch size of downloaded artifacts (default 10)]:N:' \
        '(-bp --batch-pause)'{-bp,--batch-pause=}'[pause between batches in ms (default 1000)]:milliseconds:' \
        '(-ch --cache)'{-ch,--cache}'[use cache (default false)]' \
        '(-chpath --cache-path)'{-chpath,--cache-path=}'[folder path for cache data (default ./.dukascopy-cache)]:directory:_files -/' \
        '(-df --date-format)'{-df,--date-format=}'[date format (dayjs format string)]:format:' \
        '(-tz --time-zone)'{-tz,--time-zone=}'[IANA timezone (e.g. America/New_York; pairs with dayjs/plugin/timezone)]:tz:' \
        '(-r --retries)'{-r,--retries=}'[number of retries for a failed artifact download (default 0)]:N:' \
        '(-rp --retry-pause)'{-rp,--retry-pause=}'[pause between retries in milliseconds (default 500)]:milliseconds:' \
        '(-re --retry-on-empty)'{-re,--retry-on-empty}'[retry requests with successful but 0-byte responses (ignored if --retries is 0)]' \
        '(-fr --no-fail-after-retries)'{-fr,--no-fail-after-retries}'[do NOT fail after all retries exhausted (ignored if --retries is 0)]' \
        '(-fn --file-name)'{-fn,--file-name=}'[custom file name for the generated file]:filename:' \
        '(-in --inline)'{-in,--inline}'[remove newlines from output file (only with json/array formats)]'
}

_dukascopy-cli "$@"
