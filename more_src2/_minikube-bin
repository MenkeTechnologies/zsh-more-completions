#compdef minikube
# _minikube-bin — Minikube local k8s cluster (kubernetes/minikube, Go); single-node k8s for dev with multiple drivers
# upstream: https://github.com/kubernetes/minikube

_minikube-bin() {
    local -a sub=(
        'addons:enable/disable addons'
        'cache:cache images'
        'completion:print shell completion'
        'config:modify config'
        'cp:copy file in/out of cluster'
        'dashboard:open dashboard'
        'delete:delete cluster'
        'docker-env:set docker env'
        'help:show help'
        'image:image commands'
        'ip:print cluster IP'
        'kubectl:run kubectl'
        'license:print licenses'
        'logs:print logs'
        'mount:mount host dir'
        'node:add/list/remove nodes'
        'options:print global flags'
        'pause:pause k8s control plane'
        'podman-env:set podman env'
        'profile:manage profiles'
        'service:expose service'
        'ssh:ssh into node'
        'ssh-key:print ssh key path'
        'ssh-host:print ssh host'
        'start:start a cluster'
        'status:show cluster status'
        'stop:stop cluster'
        'tunnel:run network tunnel'
        'unpause:unpause control plane'
        'update-check:check for updates'
        'update-context:update kube context'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-v+[log verbosity]:n:' \
        '--alsologtostderr[log to stderr too]' \
        '--log_dir+[log dir]:dir:_files -/' \
        '--log_file+[log file]:file:_files' \
        '--logtostderr[log to stderr]' \
        '--stderrthreshold+[stderr threshold]:n:' \
        '-p+[profile]:profile:' \
        '--profile+[profile]:profile:' \
        '--rootless[rootless docker]' \
        '--user+[user]:user:' \
        '--vmodule+[vmodule]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'minikube subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--driver+[driver]:driver:(docker virtualbox kvm2 hyperkit hyperv parallels vmware vmwarefusion podman ssh none)' \
                    '--cpus+[cpus]:n:' \
                    '--memory+[memory]:size:' \
                    '--disk-size+[disk size]:size:' \
                    '--cni+[cni plugin]:cni:(auto bridge calico cilium flannel kindnet)' \
                    '--container-runtime+[container runtime]:rt:(docker cri-o containerd)' \
                    '--kubernetes-version+[k8s version]:v:' \
                    '--addons+[addons]:addons:' \
                    '--nodes+[node count]:n:' \
                    '--image-mirror-country+[image mirror country]:str:' \
                    '--listen-address+[listen address]:addr:' \
                    '--apiserver-port+[apiserver port]:port:' ;;
                addons) _arguments '1:addons cmd:(disable enable list)' '*:addon:' ;;
                config) _arguments '1:config cmd:(defaults get set unset view)' '*:args:' ;;
                node) _arguments '1:node cmd:(add list delete start stop)' '*:args:' ;;
                profile) _arguments '1:profile cmd:(list)' '*:args:' ;;
                service) _arguments '*:service name:' \
                    '--url[print url]' \
                    '--https[https]' \
                    '-n+[namespace]:ns:' \
                    '--namespace+[namespace]:ns:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_minikube-bin "$@"
