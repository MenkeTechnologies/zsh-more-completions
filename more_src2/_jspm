#compdef jspm
# Documentation: https://github.com/jspm/jspm-cli/blob/main/cli/docs.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jspm - import map package manager (jspm/jspm-cli)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _jspm_common
_jspm_common=(
  '(-q --quiet)'{-q,--quiet}'[quiet output]'
  '(-d --dir)'{-d+,--dir=}'[package directory to operate on]:dir:_files -/'
  '--disable-warning=[disable specific warnings (comma-separated)]:warnings:'
  '(-h --help)'{-h,--help}'[display help]'
)

local -a _jspm_map
_jspm_map=(
  '(-m --map)'{-m+,--map=}'[file containing initial import map]:file:_files'
  '(-C --conditions)'{-C+,--conditions=}'[comma-separated environment condition overrides]:conditions:'
  '(-r --resolution)'{-r+,--resolution=}'[comma-separated dependency resolution overrides]:resolution:'
  '(-p --provider)'{-p+,--provider=}'[default module provider]:provider:(jspm.io nodemodules deno jsdelivr unpkg esm.sh jspm.io#system)'
  '--cache=[cache mode for fetches]:mode:(online offline no-cache)'
  '--release[enable release mode]'
  '--integrity[add module integrity attributes to the import map]'
  '--preload=[add module preloads to HTML output]::mode:(static dynamic)'
  '--root=[URL to treat as server root]:url:'
  '(-f --flatten-scopes)'{-f,--flatten-scopes}'[flatten import map scopes]'
  '(-s --combine-subpaths)'{-s,--combine-subpaths}'[combine import map subpaths under folder maps]'
  '(-c --compact)'{-c,--compact}'[output a compact import map]'
  '--stdout[output the import map to stdout]'
  '(-o --out)'{-o+,--out=}'[file to inject the final import map into]:file:_files'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'init:initialize a new project'
      'ls:list package exports'
      'install:install dependencies into an import map'
      'serve:start a development server'
      'build:build a project from the import map'
      'publish:publish a package'
      'auth:authenticate with a provider'
      'clear-cache:clear the local jspm cache'
    )
    _describe -t commands 'jspm commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      init)
        _arguments -s -S "${_jspm_common[@]}" '1:directory:_files -/' && ret=0
        ;;
      ls)
        _arguments -s -S \
          '(-f --filter)'{-f+,--filter=}'[filter exports by pattern]:pattern:' \
          '(-l --limit)'{-l+,--limit=}'[limit number of exports displayed]:number:' \
          '(-p --provider)'{-p+,--provider=}'[provider to use]:provider:(jspm.io nodemodules deno jsdelivr unpkg esm.sh jspm.io#system)' \
          "${_jspm_common[@]}" \
          '1:package:' && ret=0
        ;;
      install)
        _arguments -s -S "${_jspm_map[@]}" "${_jspm_common[@]}" '*:package:' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-p --port)'{-p+,--port=}'[port to run the server on]:port:' \
          '--no-type-stripping[disable TypeScript type stripping]' \
          '--static[static server only]' \
          '--no-install[disable automatic import map installs]' \
          "${_jspm_map[@]}" "${_jspm_common[@]}" \
          '1:directory:_files -/' && ret=0
        ;;
      build)
        _arguments -s -S \
          '--no-minify[disable build minification]' \
          '(-o --out)'{-o+,--out=}'[output directory for the build]:dir:_files -/' \
          '--install[generate import map after build completes]' \
          '--hash-entries[hash entry point filenames in the output]' \
          '--integrity[add module integrity attributes]' \
          '--preload=[add module preloads to HTML output]::mode:(static dynamic)' \
          '--root=[URL to treat as server root]:url:' \
          '(-f --flatten-scopes)'{-f,--flatten-scopes}'[flatten import map scopes]' \
          '(-s --combine-subpaths)'{-s,--combine-subpaths}'[combine import map subpaths]' \
          '(-c --compact)'{-c,--compact}'[output a compact import map]' \
          '--stdout[output the import map to stdout]' \
          '(-m --map)'{-m+,--map=}'[file containing initial import map]:file:_files' \
          '(-C --conditions)'{-C+,--conditions=}'[environment condition overrides]:conditions:' \
          '(-r --resolution)'{-r+,--resolution=}'[dependency resolution overrides]:resolution:' \
          '(-p --provider)'{-p+,--provider=}'[default module provider]:provider:(jspm.io nodemodules deno jsdelivr unpkg esm.sh jspm.io#system)' \
          '--cache=[cache mode]:mode:(online offline no-cache)' \
          '--release[enable release mode]' \
          "${_jspm_common[@]}" && ret=0
        ;;
      publish)
        _arguments -s -S \
          '--no-usage[disable printing HTML/JS import code examples]' \
          '(-w --watch)'{-w,--watch}'[watch for changes and republish]' \
          '(-n --name)'{-n+,--name=}'[publish with a custom name]:name:' \
          '--eject=[eject a published package instead of publishing]:package:' \
          "${_jspm_map[@]}" "${_jspm_common[@]}" && ret=0
        ;;
      auth)
        _arguments -s -S \
          '(-u --username)'{-u+,--username=}'[username for authentication]:username:' \
          '--no-open[disable automatically opening the authorization URL]' \
          "${_jspm_common[@]}" \
          '1:provider:' && ret=0
        ;;
      clear-cache)
        _arguments -s -S "${_jspm_common[@]}" && ret=0
        ;;
    esac
    ;;
esac

return ret
