#compdef lbdbq lbdb
# Documentation: man lbdbq(1)
# Source: RolandRosenfeld/lbdb lbdbq.sh.in (master) — Little Brother's Database query (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1::search pattern:_default' \
    && ret=0

return ret
