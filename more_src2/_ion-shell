#compdef ion
# _ion-shell — Ion modern Rust shell (Redox OS Team); fast, type-safe shell with arrays, methods, BraceExpand
# upstream: https://gitlab.redox-os.org/redox-os/ion

_ion-shell() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --command)'{-c,--command}'+[command]:code:' \
        '(-f --file)'{-f,--file}'+[script file]:file:_files -g "*.ion"' \
        '(-i --interactive)'{-i,--interactive}'[interactive]' \
        '(-n --no-execute)'{-n,--no-execute}'[parse only]' \
        '(-x --no-color)'{-x,--no-color}'[no color]' \
        '(-T --print-commands)'{-T,--print-commands}'[trace commands]' \
        '(-o --options)'{-o,--options}'+[option]:opt:' \
        '*:script:_files -g "*.ion"'
}

_ion-shell "$@"
