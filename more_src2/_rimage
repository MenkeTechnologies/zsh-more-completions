#compdef rimage
# _rimage — Sound Open Firmware DSP image builder + signer (thesofproject/rimage)
# upstream: https://github.com/thesofproject/rimage
# Flags from src/rimage.c (getopt).

_rimage() {
    local -a args
    args=(
        '(- *)-h[show help]'
        '-c+[ADSP descriptor / TOML config]:file:_files -g "*.toml"'
        '-o+[output firmware file]:file:_files'
        '-k+[signing key file]:file:_files -g "*.pem"'
        '-v[verbose output]'
        '-r[enable relocatable ELF files]'
        '-s+[MEU signing offset (disables rimage signing)]:offset:'
        '-a+[ABI version]:abi:'
        '-i+[IMR type]:type:'
        '-f+[firmware version: major.minor.micro]:version:'
        '-b+[build version]:build:'
        '-e[build extended manifest]'
        '-l[loadable-modules image (no bootloader)]'
        '-y+[verify a signed file]:file:_files'
        '-q+[resign an existing binary]:file:_files'
        '-p[set the PV bit]'
        '*:ELF input file:_files'
    )
    _arguments -s $args
}

_rimage "$@"
