#compdef odbc2parquet
# Documentation: https://github.com/pacman82/odbc2parquet
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'query:query an ODBC data source and write a parquet file'
  'insert:insert parquet data into a database table'
  'list-drivers:list available ODBC drivers'
  'list-data-sources:list configured ODBC data sources'
  'completions:generate shell completion scripts'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '--log-style=[log style]:style:(auto always never)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'odbc2parquet command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (query)
        _arguments \
          '(-c --connection-string)'{-c,--connection-string}'=[ODBC connection string]:conn:' \
          '(-u --user)'{-u,--user}'=[database user]:user:' \
          '(-p --password)'{-p,--password}'=[database password]:password:' \
          '--dsn=[ODBC data source name]:dsn:' \
          '--batch-size-row=[batch size in rows]:n:' \
          '--batch-size-memory-limit=[batch size memory limit in MiB]:mib:' \
          '--batches-per-file=[batches per parquet file]:n:' \
          '--row-groups-per-file=[row groups per file]:n:' \
          '--file-size-threshold=[file size threshold]:size:' \
          '--encoding=[column encoding]:enc:' \
          '--column-compression-default=[default column compression]:comp:(uncompressed snappy gzip lzo brotli lz4 zstd)' \
          '--prefer-varbinary[map char/varchar to byte arrays]' \
          '--parquet-column-encoding=[per-column encoding]:enc:' \
          '--no-empty-file[do not create empty files]' \
          '--driver-does-not-support-64bit-integers[64-bit integer workaround]' \
          '1:output parquet file:_files -g "*.parquet"' \
          '*:SQL query:' && ret=0 ;;
      (insert)
        _arguments \
          '(-c --connection-string)'{-c,--connection-string}'=[ODBC connection string]:conn:' \
          '(-u --user)'{-u,--user}'=[database user]:user:' \
          '(-p --password)'{-p,--password}'=[database password]:password:' \
          '--dsn=[ODBC data source name]:dsn:' \
          '1:input parquet file:_files -g "*.parquet"' \
          '2:target table:' && ret=0 ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0 ;;
    esac ;;
esac

return ret
