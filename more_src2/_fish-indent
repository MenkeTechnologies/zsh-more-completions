#compdef fish-indent fish_indent
# Documentation: https://fishshell.com/docs/current/cmds/fish_indent.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--ansi[colorize output with ANSI escape sequences]' \
  '--html[output HTML with syntax highlighting]' \
  '(-i --no-indent)'{-i,--no-indent}'[do not indent; reformat to one job per line]' \
  '--only-indent[do not reformat, only indent each line]' \
  '--only-unindent[do not reformat, only unindent each line]' \
  '(-w --write)'{-w,--write}'[write to file in-place]' \
  '(-c --check)'{-c,--check}'[check if file is already indented]' \
  '--dump-parse-tree[dump parsed statements to stderr]' \
  '*:file:_files' && ret=0

return ret
