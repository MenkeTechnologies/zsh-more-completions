#compdef net
# Documentation: https://manpages.debian.org/net
# Source: samba-team/samba source3/utils/net.c — Samba administration tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    {-h,--help}'[show help]' \
    {-w+,--workgroup=}'[workgroup name]:workgroup:_default' \
    {-W+,--myworkgroup=}'[client workgroup]:workgroup:_default' \
    {-U+,--user=}'[user[%password]]:user:_users' \
    {-A+,--authfile=}'[auth file]:file:_files' \
    {-N,--no-pass}'[do not prompt for password]' \
    {-k,--use-kerberos}'[use Kerberos]' \
    {-d+,--debuglevel=}'[debug level]:level:_default' \
    {-s+,--configfile=}'[smb.conf path]:file:_files' \
    {-l+,--log-basename=}'[log file basename]:base:_default' \
    {-S+,--server=}'[server to query]:server:_hosts' \
    {-I+,--ipaddress=}'[server IP address]:ip:_default' \
    {-p+,--port=}'[port]:port:_default' \
    {-n+,--myname=}'[client NetBIOS name]:name:_default' \
    {-c+,--container=}'[LDAP container]:container:_default' \
    '--option=-[smb.conf option]:option:_default' \
    '1:command:(rpc rap ads file share session server domain printq user group groupmap sam validate groupmember usersidlist password primarytrust setauthuser getauthuser eventlog cache afs changesecretpw changetrustpw conf dom getdomainsid getlocalsid help idmap join lookup maxrid notify offlinejoin printing registry serverid service setdomainsid setlocalsid status tdb time usershare vfs witness admin)' \
    '*::subcommand args:_default' \
    && ret=0

return ret
