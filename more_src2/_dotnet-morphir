#compdef dotnet-morphir
# ============================================================================
#  _dotnet-morphir — Morphir CLI tool for working with Morphir IR
#                    (FINOS Morphir .NET implementation)
#
#  Source-direct extraction from
#    https://github.com/finos/morphir-dotnet/blob/main/src/Morphir/Program.cs
#    https://github.com/finos/morphir-dotnet/blob/main/src/Morphir.Tooling/MorphirCli.cs
#    https://github.com/finos/morphir-dotnet/blob/main/src/Morphir.Tooling/Scenarios/*.cs
#    https://github.com/dotnet/command-line-api (System.CommandLine library)
#
#  Maintained by FINOS (Fintech Open Source Foundation) — finos/morphir-
#  dotnet.  13 GH stars (small but real production foundation tool).
#  Morphir is a business-logic-as-data system — captures business
#  logic in a language-neutral Intermediate Representation (IR) and
#  emits code in multiple target languages (Scala, TypeScript, etc.).
#  dotnet-morphir provides the .NET CLI implementation for IR
#  verification, distribution management, and tooling.  Sister tools:
#  morphir (Elm/TypeScript reference implementation), morphir-scala
#  (Scala reference implementation).
#
#  CLI library taxonomy update: 2nd C# CLI library — System.CommandLine.
#  C# ecosystem now has 2 documented CLI libraries (R286 + R359
#  System.CommandLine) joining the multi-library leaders.
#  System.CommandLine (formerly System.CommandLine.DragonFruit) is
#  Microsoft's modern .NET CLI parser — designed by the .NET team for
#  the `dotnet` CLI itself and adopted by many .NET command-line tools.
#  Distributed as `System.CommandLine` NuGet package.
#
#  System.CommandLine API:
#    using System.CommandLine;
#
#    var rootCommand = new RootCommand("description");
#    var verbCommand = new Command("verb", "description");
#
#    var pathArgument = new Argument<FileInfo>("file-path") {
#      Description = "..."
#    };
#    verbCommand.Arguments.Add(pathArgument);
#
#    var formatOption = new Option<string?>("--format") {
#      Description = "..."
#    };
#    verbCommand.Options.Add(formatOption);
#
#    verbCommand.SetAction(parseResult => {
#      var path = parseResult.GetValue(pathArgument);
#      var format = parseResult.GetValue(formatOption);
#      ...
#    });
#
#    rootCommand.Subcommands.Add(verbCommand);
#    return rootCommand.Parse(args).Invoke();
#
#  System.CommandLine distinctive features:
#    - TYPED `Argument<T>` and `Option<T>` GENERIC TYPES — T is the
#      CLR type for type-safe value access (`FileInfo`/`int`/`string?`/
#      etc.)
#    - `cmd.Subcommands.Add(child)` — explicit subcommand registration
#    - `cmd.Options.Add(opt)` / `cmd.Arguments.Add(arg)` — explicit
#      option/argument registration
#    - `cmd.SetAction(parseResult => {...})` — HANDLER as LAMBDA
#      receiving `ParseResult` instance
#    - `parseResult.GetValue(option)` — TYPED ACCESSOR
#    - `RootCommand` — top-level command (inherits from Command)
#    - `--help`/`--version`/`-?` AUTO-ADDED by framework
#    - SYSTEM.COMMANDLINE-DRAGONFRUIT — alternative ENTRY-POINT-METHOD
#      style where `static int Main(string arg, int count = 1)` becomes
#      the CLI automatically (similar to Python typer's @app.command
#      auto-CLI-from-signature)
#  Used by Microsoft dotnet CLI itself, dotnet-monitor, dotnet-counters,
#  dotnet-trace, dotnet-stack, dotnet-dump, dotnet-gcdump, dotnet-sos,
#  dotnet-symbol, Microsoft.OpenApi.OData.Tool, and many other .NET
#  CLI tools.  Distinct from R286 (C# 1 entry — likely CommandLineParser
#  or McMaster.Extensions.CommandLineUtils), R322 Java JCommander
#  (annotations), R340 oclif (TS class-inheritance with static fields),
#  R341 yargs (TS fluent builder), R343 commander.js (TS explicit-
#  instance builder), R356 Symfony Console (PHP class-inheritance with
#  PHP-8 attribute), R346 mainargs (Scala method annotations).
#  Brings cross-language CLI library taxonomy variant count to 98;
#  C# ecosystem now has 2 documented CLI libraries.
#
#  Surface (verbatim from src/Morphir/Program.cs + Scenarios/*.cs):
#
#  Top-level commands:
#    info                          Get info about workspace/project
#    ir verify <file-path>         Verify Morphir IR JSON against schema
#      --schema-version N          Schema version (1, 2, or 3;
#                                  auto-detected)
#      --json                      Output results in JSON format
#      --quiet                     Suppress output (exit code only)
#    dist                          Manage Morphir distributions
#      dist list                   List installed distributions
#        --platform RID            Platform RID
#        --local                   List only local installations
#      dist install <url> <ver>    Install a distribution
#        --platform RID
#        --local                   Install locally
#      dist use <version>          Set active distribution version
#        --platform RID
#        --local
#    tool                          Manage Morphir tools
#    extension                     Manage Morphir extensions
#    -v, --version                 Show Morphir version
#    --help, -?                    Show help (System.CommandLine auto-add)
#
#  Dup-skipped neighbors during hunt (already in corpus):
#    - km (microsoft/kernel-memory — IN CORPUS via _km, uses
#      Spectre.Console.Cli not System.CommandLine — DIFFERENT modern
#      .NET CLI framework; HOLD for future round)
#    - dotnet-monitor, dotnet-counters, dotnet-trace (all IN CORPUS)
#    - cyclonedx-cli (IN CORPUS)
# ============================================================================

_dotnet-morphir() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-v --version)'{-v,--version}'[show Morphir version]' \
    '(--help -?)'{--help,-\?}'[show help]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'info:get info about workspace/project'
        'ir:Morphir IR utilities (verify)'
        'dist:manage Morphir distributions'
        'tool:manage Morphir tools'
        'extension:manage Morphir extensions'
      )
      _describe -t commands 'dotnet-morphir subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        ir)
          if [[ $CURRENT == 2 ]]; then
            _describe -t subcommands 'ir subcommand' \
              'verify:verify Morphir IR JSON against schema'
          else
            _arguments -s -S \
              '--schema-version=[schema version (1, 2, or 3)]:version:(1 2 3)' \
              '--json[output results in JSON format]' \
              '--quiet[suppress output (exit code only)]' \
              '1:IR JSON file:_files -g "*.json"'
          fi
          ;;
        dist)
          if [[ $CURRENT == 2 ]]; then
            local -a sub=(
              'list:list installed distributions'
              'install:install a distribution'
              'use:set active distribution version'
            )
            _describe -t subcommands 'dist subcommand' sub
          else
            _arguments -s -S \
              '--platform=[platform RID (defaults to current)]:RID' \
              '--local[scope to local (project) installation]'
          fi
          ;;
        tool|extension)
          _message "$line[1] subcommand"
          ;;
      esac
      ;;
  esac
}

_dotnet-morphir "$@"
