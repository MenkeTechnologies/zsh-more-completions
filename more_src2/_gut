#compdef gut
# Documentation: https://github.com/julien040/gut
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# julien040/gut — beginner friendly CLI for git (see `gut --help`).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'save:commit changes using gitmoji'
  'sync:sync local repo with remote'
  'goto:rewind working tree to a particular commit'
  'fix:helper to resolve mistakes with git'
  'revert:return project to a previous state'
  'undo:discard changes since the last commit'
  'ignore:download .gitignore templates'
  'whereami:show where HEAD points to'
  'switch:create a new branch or switch to existing one'
  'attributes:download .gitattributes templates'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'gut' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
