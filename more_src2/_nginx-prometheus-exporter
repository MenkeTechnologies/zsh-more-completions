#compdef nginx-prometheus-exporter
# _nginx-prometheus-exporter — F5 NGINX Prometheus exporter (scrapes NGINX stub_status / NGINX Plus API and exports metrics)
# upstream: https://github.com/nginxinc/nginx-prometheus-exporter
# Flags from exporter.go on tip + kingpinflag/web (--web.listen-address, --web.systemd-socket, --web.config.file) + promslog (--log.level, --log.format).

_nginx-prometheus-exporter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[show version and exit]' \
        '--web.telemetry-path=[path under which to expose metrics]:path:' \
        '--nginx.plus[scrape NGINX Plus API instead of stub_status]' \
        '*--nginx.scrape-uri=[URI or unix socket to scrape (repeatable)]:uri:_urls' \
        '--nginx.ssl-verify=[verify upstream TLS cert]:bool:(true false)' \
        '--nginx.ssl-ca-cert=[CA cert PEM file]:file:_files' \
        '--nginx.ssl-client-cert=[client cert PEM file]:file:_files' \
        '--nginx.ssl-client-key=[client key PEM file]:file:_files' \
        '--nginx.proxy-protocol=[send PROXY protocol header to upstream]:bool:(true false)' \
        '--nginx.timeout=[scrape timeout]:dur:' \
        '*--prometheus.const-label=[constant label=value pair (repeatable)]:label:' \
        '*--web.listen-address=[listen address (repeatable for systemd socket activation)]:addr:' \
        '--web.systemd-socket[use systemd socket activation listener]' \
        '--web.config.file=[TLS/auth config file]:file:_files' \
        '--log.level=[log level]:level:(debug info warn error)' \
        '--log.format=[log format]:fmt:(logfmt json)'
}

_nginx-prometheus-exporter "$@"
