#compdef ffmpeg2theora
# Documentation: https://manpages.debian.org/testing/ffmpeg2theora/ffmpeg2theora.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--info[print info]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files -g "*.ogv"' \
  '(-v --videoquality)'{-v,--videoquality}'+[video quality 0-10]:q:' \
  '(-V --videobitrate)'{-V,--videobitrate}'+[video bitrate kbps]:kbps:' \
  '(-a --audioquality)'{-a,--audioquality}'+[audio quality -2 to 10]:q:' \
  '(-A --audiobitrate)'{-A,--audiobitrate}'+[audio bitrate kbps]:kbps:' \
  '(--soft-target)--soft-target[soft bitrate target (default)]' \
  '(--two-pass)--two-pass[two-pass encoding]' \
  '(--first-pass)--first-pass[first pass]:file:_files' \
  '(--second-pass)--second-pass[second pass]:file:_files' \
  '(--optimize)--optimize[lossless transcode optimization]' \
  '(--max_size)--max_size=+[max size WxH]:WxH:' \
  '(--width)--width=+[video width]:px:' \
  '(--height)--height=+[video height]:px:' \
  '(--keyint)--keyint=+[keyframe interval]:n:' \
  '(--aspect)--aspect=+[aspect ratio W:H]:ratio:' \
  '(--pixel-aspect)--pixel-aspect=+[pixel aspect]:ratio:' \
  '(--framerate)--framerate=+[FPS]:fps:' \
  '(--noaudio)--noaudio[no audio]' \
  '(--novideo)--novideo[no video]' \
  '(--no-skeleton)--no-skeleton[no skeleton metadata]' \
  '(--seek-index)--seek-index[seek index]' \
  '(--starttime)--starttime=+[start time]:sec:' \
  '(--endtime)--endtime=+[end time]:sec:' \
  '(--cropright)--cropright=+[crop right]:px:' \
  '(--cropleft)--cropleft=+[crop left]:px:' \
  '(--croptop)--croptop=+[crop top]:px:' \
  '(--cropbottom)--cropbottom=+[crop bottom]:px:' \
  '(--inputfps)--inputfps=+[force input FPS]:fps:' \
  '(--no-upscaling)--no-upscaling[no upscaling]' \
  '(--samplerate)--samplerate=+[audio sample rate Hz]:hz:' \
  '(--channels)--channels=+[audio channels]:n:' \
  '(--title)--title=+[title metadata]:title:' \
  '(--artist)--artist=+[artist metadata]:artist:' \
  '(--date)--date=+[date metadata]:date:' \
  '(--location)--location=+[location metadata]:loc:' \
  '(--organization)--organization=+[organization]:org:' \
  '(--copyright)--copyright=+[copyright]:copy:' \
  '(--license)--license=+[license]:lic:' \
  '(--contact)--contact=+[contact]:contact:' \
  '*:input:_files' && ret=0

return ret
