#compdef fvm
# _fvm-bin — Flutter Version Management CLI (Leo Farias, Dart); per-project Flutter SDK pinning
# upstream: https://github.com/leoafarias/fvm

_fvm-bin() {
    local -a sub=(
        'api:internal API commands'
        'completion:print shell completion'
        'config:configure FVM'
        'destroy:remove FVM cache'
        'doctor:show diagnostic info'
        'exec:run command with cached SDK'
        'flavor:flavor commands'
        'global:set global SDK version'
        'help:show help'
        'install:install specific SDK'
        'list:list installed SDKs'
        'flutter:run flutter inside FVM'
        'dart:run dart inside FVM'
        'releases:list available releases'
        'remove:remove cached SDK'
        'spawn:spawn command with version'
        'use:set local project SDK version'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--verbose[verbose]' \
        '--cache-path+[cache path]:dir:_files -/' \
        '--git-cache+[git cache]:dir:_files -/' \
        '--use-git-cache+[use git cache]:bool:(true false)' \
        '--no-update-check[no update check]' \
        '--flutter-url+[flutter mirror url]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fvm subcommand' sub ;;
        args)
            case $words[1] in
                use|install|remove|global) _arguments \
                    '--force[force]' \
                    '-f[force]' \
                    '--pin[pin to commit]' \
                    '--skip-setup[skip setup]' \
                    '--skip-pub-get[skip pub get]' \
                    '*:version:' ;;
                config) _arguments \
                    '--cache-path+[cache path]:dir:_files -/' \
                    '--git-cache+[git cache]:bool:(true false)' \
                    '--update-check+[update check]:bool:(true false)' \
                    '--ls[list config]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_fvm-bin "$@"
