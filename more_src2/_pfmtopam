#compdef pfmtopam
# Documentation: man pfmtopam (Netpbm)
# Source: convert a Portable Float Map (.pfm) image to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxval=[output PAM maxval]:n:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pfm file:_files -g "*.pfm"' \
    && ret=0

return ret
