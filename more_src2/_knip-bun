#compdef knip-bun
# Documentation: https://www.npmjs.com/package/knip
# Reference accessed: 2026-05-23
# Verified: npm view knip bin; npx knip --help.

# Zsh completion for knip-bun - Knip unused-code scanner (Bun entry bin)

local curcontext="$curcontext" state line ret=1

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '--version[show version]'   '--config=[config file]:file:_files'   '--workspace=[workspace path]:dir:_directories'   '--production[analyze production code only]'   '--strict[strict mode]'   '--fix[auto-fix issues where possible]'   '--watch[watch mode]'   '--cache[use cache]'   '--no-cache[disable cache]'   '--reporter=[reporter format]:format:(compact codeowners json)'   '*:files:_files' && ret=0

return ret
