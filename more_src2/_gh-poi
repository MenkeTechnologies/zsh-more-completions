#compdef gh-poi
# Documentation: https://github.com/seachicken/gh-poi (main.go + cmd/lock)
# Reference accessed: 2026-05-29
# gh-poi — GitHub CLI extension to delete merged local branches safely.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'lock:prevent specified branches from being deleted'
  'unlock:allow locked branches to be deleted again'
  'protect:alias for lock (deprecated)'
  'unprotect:alias for unlock (deprecated)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--state=[which pull-request state to target for deletion]:state:(closed merged)' \
  '--scan=[scanning approach]:mode:(quick deep)' \
  '--dry-run[display branches marked for deletion without removing]' \
  '--debug[enable debug logging output]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'gh-poi subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      lock|protect|unlock|unprotect)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '*:branch:' && ret=0
        ;;
    esac
    ;;
esac

return ret
