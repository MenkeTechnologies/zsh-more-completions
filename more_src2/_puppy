#compdef puppy
# =============================================================================
# puppy — Takashi Yoneuchi's "example implementation of a tiny Web
#         browser for educational purposes" — a from-scratch
#         pedagogical Rust web browser that demonstrates how a
#         modern browser works internally.  puppy implements
#         (intentionally minimally and pedagogically) the full
#         browser engine stack:
#           - HTTP/1.1 fetcher (via reqwest)
#           - HTML5 tokenizer + parser (DOM tree construction)
#           - CSS2 parser + cascading + computed-style resolution
#           - JavaScript engine integration (via rusty_v8 — V8 in Rust)
#           - Layout engine (block + inline flow)
#           - Cursive-rendered text UI (no graphical rendering;
#             pages display as TUI representations)
#           - URL bar + history + navigation
#         Designed to be read TOP-TO-BOTTOM as educational source
#         code by students learning browser internals.  Used as
#         course material at Shift-JS (Yoneuchi's training
#         consultancy) and university security classes studying
#         browser-attack-surface analysis.
#
# Author:  Takashi Yoneuchi (@lmt-swallow, <takashi.yoneuchi@shift-js.info>)
#          — Japanese security engineer + Shift-JS founder; created
#          puppy in 2021 as a pedagogical reference for teaching
#          browser internals at his Shift-JS workshops.
# Source:  https://github.com/lmt-swallow/puppy-browser
# CLI:     src/main.rs + src/cli/opts.rs (uses structopt + clap-
#                                          verbosity-flag for argv
#                                          parsing + cursive for the
#                                          entire browser UI)
# Library: gyscos/cursive
#          ("A Text User Interface library for the Rust programming
#           language" — Alexandre Bury's RETAINED-MODE Rust TUI
#           library, predating ratatui by 4 years, the Rust
#           parallel to Go's tview R535 and TypeScript-Node's
#           blessed R536)
# License: MIT
# Status:  Active educational reference — 644+ stars on
#          lmt-swallow/puppy-browser; cursive itself is 4799+ stars
#          on gyscos/cursive with 9 years of active development
#          (2016-2026).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — RUST CROSSES TO 42
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 42ND Rust CLI library variant.  Rust climbs from 41 to 42
# documented libraries (gyscos/cursive via puppy).  New leaderboard:
# Rust=42 SOLO LEAD, Go=41, TypeScript-Node=41 (three-way tie at 41
# from R536 broken after R537 Wuffs new-language pause).  Taxonomy
# now spans 277 cross-language CLI library variants across 67
# documented languages.
#
# This completion COMPLETES THE RETAINED-MODE-TUI TRIPLE across the
# top three languages — bringing Rust to paradigm parity with Go and
# TypeScript-Node which both have BOTH retained-mode AND modern-
# paradigm TUI frameworks documented:
#
#   * Rust:    ratatui R530 (immediate-mode) + cursive R538 (RETAINED-MODE)
#   * Go:      bubbletea R531 (Elm) + tview R535 (retained-mode)
#   * TS-Node: ink R532 (React) + blessed R536 (retained-mode)
#
# Three POLAR-OPPOSITE modern paradigms (immediate-mode / Elm / React)
# now have RETAINED-MODE counterparts in each of the top three
# languages.  The RETAINED-MODE TRIPLE represents the
# CLASSICAL TUI PARADIGM — widgets as persistent objects mutated in
# place, the same model used by ncurses (1993), GTK (1998), Qt
# (1991), AppKit (1989), Java Swing (1998).  By completing this
# triple, the taxonomy now documents BOTH the classical and the
# modern TUI paradigms in all three top-language ecosystems.
#
# Pattern: 3 leader bumps (R534/R535/R536 restoring tie at 41) →
# 1 new lang (R537 Wuffs) → R538 (THIS) starts next leader-bump
# triple with Rust=42 via cursive.  Per established pattern, R539
# should bring Go to 42 and R540 should bring TS-Node to 42.
#
# -----------------------------------------------------------------------------
#
# WHAT IS cursive AND WHY IS IT THE 42ND RUST CLI LIBRARY?
#
# cursive (https://github.com/gyscos/cursive, 4799+ stars) is
# **Alexandre "Gyscos" Bury's "A Text User Interface library for the
# Rust programming language"** — the canonical Rust RETAINED-MODE
# TUI library that PRECEDED ratatui (and its predecessor tui-rs) by
# 4 years.  cursive was created in 2016, when tui-rs (predecessor of
# ratatui R530) started in 2019.  cursive is the Rust parallel to
# Go's tview (created 2018, R535) and TypeScript-Node's blessed
# (created 2013, R536).
#
# cursive's distinguishing characteristics:
#
#   1. RETAINED-MODE WIDGET TREE — cursive applications instantiate
#      widget objects that LIVE in a tree until removed:
#
#          let mut siv = cursive::default();
#          siv.add_layer(Dialog::around(TextView::new("Hello!"))
#              .title("Greeting")
#              .button("Quit", |s| s.quit()));
#          siv.run();
#
#      The `Dialog` and `TextView` are persistent objects.
#      Selection, scroll position, focus all live in the widget
#      tree across event-loop iterations.  Compare ratatui R530
#      (immediate-mode — widgets recreated each frame).  cursive is
#      the FIRST documented Rust retained-mode TUI library.
#
#   2. BACKEND-AGNOSTIC RENDERING — cursive supports 5 different
#      terminal backends, swappable via Cargo features:
#         * `crossterm-backend`  (default; cross-platform via
#                                  crossterm-rs — same as ratatui's
#                                  default backend)
#         * `termion-backend`    (Unix-only via termion)
#         * `ncurses-backend`    (real ncurses bindings — gives
#                                  cursive its name)
#         * `pancurses-backend`  (cross-platform ncurses wrapper)
#         * `blt-backend`        (BearLibTerminal — for tile-based
#                                  graphical/grid display)
#      Compare ratatui's `Backend` trait (crossterm / termwiz /
#      termion / 3 community backends), tview's tcell-only backend,
#      bubbletea's tighter crossterm integration.  cursive is the
#      FIRST documented Rust TUI library that supports both ANSI-
#      escape-based AND real-ncurses backends — letting users pick
#      based on their platform's terminfo quality.
#
#   3. CALLBACK-BASED EVENT HANDLING — cursive widgets register
#      callbacks via `.set_on_submit(callback)`, `.set_on_select(
#      callback)`, `.set_on_edit(callback)`.  Callbacks receive a
#      `&mut Cursive` siv reference and can mutate any part of the
#      widget tree.  Compare:
#         * ratatui R530: every frame rebuilds widget tree from
#                         current app state (no callbacks)
#         * tview R535:    callbacks attached to widgets that
#                          mutate state in place
#         * blessed R536:  event handlers + style tags
#      cursive's callback model is most similar to tview's but
#      with Rust's borrow-checker requiring more explicit closures.
#      FIRST documented Rust TUI library with retained-mode
#      callback events.
#
#   4. BUILT-IN WIDGET CATALOG (~30+ widgets) — cursive ships with
#      a comprehensive widget set:
#         * Layout containers: `LinearLayout`, `ListView`, `Panel`,
#           `Dialog`, `Layer`, `OnLayoutView`, `PaddedView`,
#           `ResizedView`, `ShadowView`, `StackView`
#         * Selectable widgets: `SelectView`, `Checkbox`, `Button`,
#           `RadioButton`, `RadioGroup`
#         * Display widgets: `TextView`, `TextArea`, `EditView`,
#           `ProgressBar`, `Slider`, `Menubar`
#         * Misc: `DummyView`, `Canvas`, `OnEventView`,
#           `LastSizeView`
#         * Community add-ons: `cursive-aligned-view`,
#           `cursive-async-view`, `cursive-tabs`, `cursive_hexview`,
#           `cursive-spinner-view`, `cursive-multiplex`
#      Compare tview's ~16 built-ins, blessed's 30+, ratatui's ~14.
#      cursive's catalog is comparable to blessed and broader than
#      tview/ratatui.
#
#   5. THREAD-SAFE CALLBACK SINK — cursive provides a `CbSink`
#      `Sender<Box<dyn FnOnce(&mut Cursive) + Send>>` that lets
#      background threads inject callbacks into the cursive event
#      loop.  Background HTTP requests, async I/O, or worker
#      threads can update the UI safely:
#
#          let sink = siv.cb_sink().clone();
#          std::thread::spawn(move || {
#              let result = expensive_http_get();
#              sink.send(Box::new(move |s| {
#                  s.call_on_name("output", |view: &mut TextView| {
#                      view.set_content(result);
#                  });
#              })).unwrap();
#          });
#
#      No other documented TUI library has this exact pattern.
#      Compare:
#         * ratatui R530: rebuild widget tree from shared app
#                          state mutated by other threads
#         * bubbletea R531: send tea.Msg to the runtime from
#                            tea.Cmd functions
#         * tview R535: QueueUpdateDraw with callback
#         * blessed R536: emit events via socket.io or in-process
#      cursive's `CbSink` is the FIRST documented Rust thread-safe
#      cross-thread TUI update channel pattern.
#
# cursive's relationship to other documented Rust CLI libraries:
#
#   * Like ratatui R530 — full-screen TUI, takes over terminal
#   * Like ratatui R530 — backend-trait abstraction (cursive has
#                          5 backends, ratatui has 3 official + 3
#                          community)
#   * Unlike ratatui R530 — RETAINED-MODE vs immediate-mode.
#                            cursive widgets are persistent objects;
#                            ratatui widgets are rebuilt each frame.
#   * Closest cross-language analogs:
#         * Go:      tview R535 (retained-mode + tcell)
#         * TS-Node: blessed R536 (retained-mode + terminfo)
#     The RETAINED-MODE TUI triple (R535 tview / R536 blessed /
#     R538 cursive THIS) is now COMPLETE across all top three
#     languages, parallel to the modern-paradigm triple
#     (R530 ratatui / R531 bubbletea / R532 ink).
#
# -----------------------------------------------------------------------------
#
# THE puppy CLI — structopt + clap-verbosity-flag + cursive Composition
#
# puppy's argv parser is structopt (already documented R228 sntrup):
#
#     #[derive(StructOpt, Debug)]
#     pub struct Opts {
#         #[structopt(flatten)]
#         pub common_opts: CommonOpts,
#         #[structopt(subcommand)]
#         pub sub_command: SubCommand,
#     }
#
#     pub struct CommonOpts {
#         #[structopt(flatten)]
#         pub verbose: Verbosity,
#     }
#
#     pub enum SubCommand {
#         Open(open::Opts),
#         Completion(completion::Opts),
#         #[structopt(name = "js")]
#         JavaScript,
#     }
#
# Three subcommands:
#   * `puppy open [URL]`        — launch TUI browser (default URL
#                                  is http://example.com)
#   * `puppy js`                  — JavaScript REPL via rusty_v8
#                                  bindings
#   * `puppy completion {zsh,bash,fish}` — emit shell completion
#                                  script
#
# Verbosity is flattened from `clap_verbosity_flag::Verbosity`:
#   * `-v`     — verbose (Info)
#   * `-vv`    — very verbose (Debug)
#   * `-vvv`   — extremely verbose (Trace)
#   * `-q`     — quiet (Warn only)
#   * `-qq`    — very quiet (Error only)
#
# The COMPLETION subcommand is itself a meta-feature: `puppy
# completion zsh` emits a structopt-generated zsh completion
# script for the `puppy` binary itself.  This is a self-
# referential pattern shared by clap-derive / structopt /
# clap_complete users.
#
# Distinct from every other documented Rust TUI library on FIVE
# specific axes:
#
#   1. RETAINED-MODE WIDGET TREE — Every other documented Rust TUI
#      library (ratatui R530) uses immediate-mode rendering.
#      cursive uses RETAINED-MODE: widgets are persistent objects
#      mutated in place.  FIRST documented Rust retained-mode
#      TUI library.
#
#   2. BACKEND-AGNOSTIC INCLUDING REAL NCURSES — Every other
#      documented Rust TUI library (ratatui R530) uses only ANSI-
#      escape-based backends (crossterm/termwiz/termion).  cursive
#      supports real ncurses bindings + pancurses + BearLibTerminal
#      AS WELL AS ANSI backends.  FIRST documented Rust TUI library
#      that supports real-ncurses-bindings backends.
#
#   3. CALLBACK-BASED EVENT HANDLING — Every other documented Rust
#      TUI library (ratatui R530) reads events in the application
#      main loop.  cursive uses widget-attached callbacks (set_on_
#      submit, set_on_select, set_on_edit).  FIRST documented Rust
#      TUI library with retained-mode callback events.
#
#   4. THREAD-SAFE CALLBACK SINK — Every other documented Rust TUI
#      library uses shared application state mutated by other
#      threads (Arc<Mutex<State>>).  cursive provides a `CbSink`
#      channel for sending closures from background threads into
#      the UI thread.  FIRST documented Rust TUI library with
#      cross-thread callback channel.
#
#   5. ~30+ BUILT-IN WIDGETS — Every other documented Rust TUI
#      library (ratatui R530) ships with ~14 built-in widgets.
#      cursive ships with ~30+ widgets including LinearLayout,
#      Panel, Dialog, StackView, RadioGroup, Slider, Menubar.
#      FIRST documented Rust TUI library with 30+ built-in widgets
#      including dialog/panel/menubar primitives.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/lmt-swallow/puppy-browser/blob/master/src/cli/
# opts.rs and src/cli/subcommand/{open,javascript,completion}.rs )
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
    'open:launch the TUI browser at a URL (default http://example.com)'
    'js:start the JavaScript REPL via rusty_v8'
    'completion:emit a shell completion script for the puppy binary'
)

_arguments -s -C \
    '(-h --help)'{-h,--help}'[print help and exit]' \
    '(-V --version)'{-V,--version}'[print version and exit]' \
    '*-v[increase verbosity (repeat for more verbose: -vv debug, -vvv trace)]' \
    '*-q[decrease verbosity (repeat: -qq for errors only)]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case "$state" in
    cmd)
        _describe -t commands 'puppy subcommand' commands && ret=0
        ;;
    args)
        case "${words[1]}" in
            open)
                _arguments -s \
                    '1:URL to open:' \
                    && ret=0
                ;;
            completion)
                local -a shells=(
                    'bash:emit bash completion script'
                    'zsh:emit zsh completion script'
                    'fish:emit fish completion script'
                )
                _describe -t shells 'shell' shells && ret=0
                ;;
            js)
                # No additional arguments for the js subcommand
                ;;
        esac
        ;;
esac

return ret
