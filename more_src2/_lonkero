#compdef lonkero
# ---------------------------------------------------------------------------
# lonkero — enterprise web security scanner for actual pentests (Rust, 922★)
#
# upstream: https://github.com/bountyyfi/lonkero
# author : Bountyy Oy  <info@bountyy.fi>  (Finnish offensive security firm)
# license: proprietary (license-file in repo)
#
# Source-direct completion: every subcommand and every flag below is verbatim
# from src/cli/main.rs `Cli` clap-derive struct + `Commands` enum on the
# lonkero v3.7.3 tip.
#
# Direct deps from Cargo.toml (selected):
#   tungstenite       ^0.28      ← canonical Rust WebSocket library (this
#                                  axis) — by snapview
#   tokio-tungstenite ^0.29 with native-tls
#   tokio             ^1.48      (full + tracing)
#   clap              (derive)
#   anyhow, tracing
#
# lonkero ships 94+ vulnerability scanner modules, an intelligent
# context-aware scanning mode, headless-browser session recording, multi-role
# authz testing, AI-powered conversational pentesting (Claude or Ollama),
# and the Browser-Assist Chrome extension for authentic TLS fingerprints.
# tungstenite powers the WebSocket bidirectional channel between the scanner
# core and the Browser-Assist extension.
#
# === AXIS 164 OPENER — WebSocket library ecosystem ===
# Axis position: Rust=219 OPENS Axis 164 at slot 1/0/0.  Canonical Rust
# WebSocket library is `tungstenite` (and async wrapper `tokio-tungstenite`)
# by snapview — RFC-6455-compliant, fast, low-allocation, used by Slack
# realtime clients, blockchain RPC stacks, web frontends, pentest agents.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=219   ← THIS FILE              (axis 164 OPENS, slot 1/0/0)
#   Go=219     ← next round              (axis 164 continues, slot 2/0/0)
#   TS-Node=219 ← round after            (axis 164 CLOSES at triple-219, slot 1/1/1)
# ---------------------------------------------------------------------------

_lonkero() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'scan:scan a target for vulnerabilities'
        'list:list available scanner modules'
        'validate:validate target URL(s)'
        'init:generate sample configuration file'
        'version:show scanner version and build info'
        'license:manage license (activate/status/deactivate)'
        'ml:Machine Learning settings and statistics'
        'ai:AI-powered interactive security testing (Claude or Ollama)'
        'help:print help for a subcommand'
    )

    _arguments -C \
        '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
        '(-d --debug)'{-d,--debug}'[enable debug output]' \
        '(-q --quiet)'{-q,--quiet}'[quiet mode - only show vulnerabilities]' \
        '(-c --config)'{-c,--config=}'[configuration file path]:config:_files -g "*.(toml|yaml|yml)"' \
        '(-L --license-key)'{-L,--license-key=}'[license key (or set LONKERO_LICENSE_KEY env var)]:license key:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'lonkero command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                scan)     _lonkero_scan    && ret=0 ;;
                list)
                    _arguments \
                        '(-v --verbose)'{-v,--verbose}'[show detailed information]' \
                        '(-c --category)'{-c,--category=}'[filter by category]:category:' \
                        '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                validate)
                    _arguments \
                        '(-h --help)'{-h,--help}'[print help]' \
                        '*:target URL(s):' && ret=0
                    ;;
                init)
                    _arguments \
                        '(-o --output)'{-o,--output=}'[output path for config file (default lonkero.toml)]:file:_files -g "*.toml"' \
                        '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                version)
                    _arguments '(-h --help)'{-h,--help}'[print help]' && ret=0
                    ;;
                license) _lonkero_license && ret=0 ;;
                ml)      _lonkero_ml      && ret=0 ;;
                ai)      _lonkero_ai      && ret=0 ;;
                help)
                    _describe -t commands 'lonkero command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# `lonkero scan <targets...>` — scan one or more URLs
_lonkero_scan() {
    _arguments \
        '(-m --mode)'{-m,--mode=}'[scan mode]:mode:(intelligent fast normal thorough insane)' \
        '(-o --output)'{-o,--output=}'[output file path]:file:_files' \
        '(-f --format)'{-f,--format=}'[output format]:format:(json html pdf sarif markdown csv xlsx)' \
        '--subdomains[enable subdomain enumeration]' \
        '--dorks[generate Google dork queries for reconnaissance]' \
        '--crawl=[enable web crawler (default true)]:bool:(true false)' \
        '--max-depth=[maximum crawl depth (default 3)]:depth:' \
        '--concurrency=[maximum concurrent requests (default 50)]:n:' \
        '--timeout=[request timeout in seconds (default 30)]:seconds:' \
        '--user-agent=[custom User-Agent string]:UA string:' \
        '--cookie=[authentication cookie]:cookie:' \
        '--token=[authentication bearer token]:token:' \
        '--basic-auth=[HTTP Basic auth (user:pass)]:user\:pass:' \
        '--auth-username=[auto-login username]:username:' \
        '--auth-password=[auto-login password]:password:' \
        '--auth-login-url=[custom login URL for auto-login]:url:' \
        '*'{-H,--header=}'[custom header (Name: Value)]:header:' \
        '*--skip=[skip specific scanner modules (repeatable)]:module:' \
        '*--only=[run only specific scanner modules (repeatable)]:module:' \
        '--proxy=[proxy URL (http://host:port)]:proxy:' \
        '--insecure[disable TLS certificate verification]' \
        '--rate-limit=[rate limit (requests per second, default 100)]:rps:' \
        '--no-rate-limit[disable rate limiting entirely (use with caution)]' \
        '--admin-username=[admin username for multi-role authorization testing]:username:' \
        '--admin-password=[admin password for multi-role authorization testing]:password:' \
        '--admin-login-url=[admin login URL]:url:' \
        '--multi-role[enable multi-role authorization testing]' \
        '--record-session[enable session recording during headless crawling]' \
        '--session-output=[session recording output file (default session_recording.har)]:file:_files -g "*.(har|json|html)"' \
        '--session-format=[session recording format]:format:(har json html)' \
        '--payload-intensity=[payload intensity override]:intensity:(auto minimal standard extended maximum)' \
        '--browser-assist[route requests through real browser for authentic TLS fingerprints]' \
        '--auth-type=[Browser-Assist authorization type]:type:(self-authorized customer-authorized)' \
        '*--scope=[scope patterns for Browser-Assist mode (e.g. *.example.com)]:pattern:' \
        '--audit-log=[audit log output path for Browser-Assist mode]:file:_files' \
        '--no-ml[disable ML model scoring (model scoring is one-way, no data leaves your machine)]' \
        '(-h --help)'{-h,--help}'[print help]' \
        '*:target URL(s):'
}

# `lonkero license <action>`
_lonkero_license() {
    local -a lcmds
    lcmds=(
        'activate:activate a license key'
        'status:show current license status'
        'deactivate:deactivate the current license'
    )
    _describe -t commands 'license action' lcmds
}

# `lonkero ml <action>`
_lonkero_ml() {
    local -a mcmds
    mcmds=(
        'enable:enable ML features with GDPR consent'
        'disable:disable ML features'
        'status:show ML stats and model status'
    )
    _describe -t commands 'ml action' mcmds
}

# `lonkero ai <target> [opts]` — AI-driven conversational pentesting
_lonkero_ai() {
    _arguments \
        '--provider=[LLM provider]:provider:(claude ollama)' \
        '--model=[provider-specific model (e.g. claude-sonnet-4-5-20250929, llama3.1\:70b)]:model:' \
        '--api-key=[API key for Claude (or set ANTHROPIC_API_KEY env)]:api key:' \
        '--ollama-url=[Ollama server URL (default http://localhost:11434)]:url:' \
        '--auto[run in auto mode (AI drives the entire pentest)]' \
        '--max-rounds=[maximum autonomous rounds in auto mode (default 20)]:n:' \
        '--cookie=[authentication cookie to pass through to lonkero scans]:cookie:' \
        '--token=[authentication bearer token]:token:' \
        '(-h --help)'{-h,--help}'[print help]' \
        '1:target URL:'
}

_lonkero "$@"
