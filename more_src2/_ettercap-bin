#compdef ettercap
# _ettercap-bin — Ettercap MITM tool (Alberto Ornaghi, Marco Valleri, C); used in authorized network audits
# upstream: https://github.com/Ettercap/ettercap

_ettercap-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-T[text mode]' \
        '-C[curses mode]' \
        '-G[GTK mode]' \
        '-D[daemon mode]' \
        '-i+[interface]:iface:_net_interfaces' \
        '-I[show interfaces]' \
        '-w+[write pcap]:file:_files' \
        '-r+[read pcap]:file:_files' \
        '-Y+[bridge iface]:iface:_net_interfaces' \
        '-u[unified sniffing]' \
        '-d[do not resolve hosts]' \
        '-F+[filter file]:file:_files' \
        '-V+[viewmode]:mode:(hex ascii text ebcdic html utf8)' \
        '-q[quiet]' \
        '-Z[do not resolve services]' \
        '-z+[gateway]:ip:' \
        '-M+[mitm method]:method:(arp icmp dhcp port ndp acklist arpprison)' \
        '-P+[plugin]:plugin:' \
        '-L+[log file]:file:_files' \
        '-l+[log info file]:file:_files' \
        '-m+[message file]:file:_files' \
        '-S[do not save logs]' \
        '-A[do not start ARP cache poisoning]' \
        '-K+[loaded etterfilter]:file:_files' \
        '-N[no MitM]' \
        '-R[reversed match]' \
        '-t+[protocol]:proto:(tcp udp all)' \
        '-O+[output file]:file:_files' \
        '-f+[scan file]:file:_files' \
        '-j+[scan file (legacy)]:file:_files' \
        '-x+[remote bridge]:str:' \
        '--silent[silent]' \
        '*:target1 / target2:'
}

_ettercap-bin "$@"
