#compdef lnav
# Documentation: https://man.archlinux.org/man/lnav.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lnav - the log file navigator

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[print help and exit]' \
  '(- *)-H[display the internal help text]' \
  '(- *)-V[print version information]' \
  '-C[check configuration and exit]' \
  '-c[execute the given lnav command, SQL query, or script]:command:' \
  '-e[execute a shell command-line and display its output]:shell command:' \
  '-d[write debug messages to file]:debug file:_files' \
  '-f[execute commands from file]:file:_files' \
  '-I[add a configuration directory]:directory:_files -/' \
  '-i[install the given format files]:format file:_files' \
  '-m[switch to management command-line mode]' \
  '-n[run without curses UI (headless mode)]' \
  '-N[do not open the default syslog file]' \
  '-q[quiet mode]' \
  '-r[recursively load files from directories]' \
  '-R[load older rotated log files]' \
  '-S[index log content from the given timestamp]:timestamp:' \
  '-U[index log content until the given timestamp]:timestamp:' \
  '-t[prepend timestamps to data piped from stdin]' \
  '-u[update formats installed from git repositories]' \
  '-W[print warnings related to lnav configuration]' \
  '*:log file:_files' && ret=0

return ret
