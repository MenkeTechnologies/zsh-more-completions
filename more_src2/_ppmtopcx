#compdef ppmtopcx
# Documentation: man ppmtopcx (Netpbm)
# Source: convert a PPM image to ZSoft PCX.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-24bit -8bit)-24bit[24-bit PCX (true color)]' \
    '(-24bit -8bit)-8bit[8-bit PCX (palette)]' \
    '-packed[packed PCX]' \
    '-stdpalette[use standard 16-color palette]' \
    '-palette=[palette file]:file:_files' \
    '-planes=[number of bit-planes]:n:(1 2 4 8)' \
    '-xpos=[column offset]:cols:' \
    '-ypos=[row offset]:rows:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
