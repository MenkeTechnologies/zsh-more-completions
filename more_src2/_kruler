#compdef kruler
# Documentation: https://invent.kde.org/graphics/kruler/-/blob/master/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream kruler/main.cpp - only KAboutData::setupCommandLine
# (no custom QCommandLineOption). Removed fabricated --display option.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' && ret=0

return ret
