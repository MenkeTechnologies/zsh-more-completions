#compdef etandem
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/etandem.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS etandem: looking for tandem repeats in nucleic-acid sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[DNA sequence]:DNA USA:_files' \
  '-minrepeat=[minimum repeat unit size]:size:' \
  '-maxrepeat=[maximum repeat unit size]:size:' \
  '-threshold=[score threshold to report]:score:' \
  '-mismatch[allow mismatches]' \
  '-uniform[only report uniform tandem repeats]' \
  '-origfile=[original tandem report]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '-rformat=[report format]:format:(table excel feattable gff3 listfile pir simple swiss tagseq)' \
  '*:DNA USA:_files' && ret=0
return ret
