#compdef gdal_polygonize gdal_polygonize.py
# Documentation: https://gdal.org/programs/gdal_polygonize.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-8[use 8-connectedness (default 4)]' \
  '-nomask[ignore default validity masks]' \
  '-mask+[mask file]:file:_files' \
  '-f+[output OGR format]:format:' \
  '-b+[band number or "mask"]:band:' \
  '*-o+[polygonize option NAME=VALUE]:NAME=VALUE:' \
  '*-lco+[layer creation option]:NAME=VALUE:' \
  '-q[quiet mode]' \
  '-overwrite[overwrite output layer]' \
  '1:source raster:_files' \
  '2:dest vector:_files' \
  '3::layer name:' \
  '4::field name (default DN):' && ret=0

return ret
