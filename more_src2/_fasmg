#compdef fasmg
# Documentation: https://flatassembler.net/docs.php?article=manual_g
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# fasmg: flat assembler g (target-agnostic macro assembler)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-i[include file]:file:_files' \
  '-r[recursion limit]:n:' \
  '-e[exit pass count]:n:' \
  '-c[max errors before abort]:n:' \
  '-n[mute info messages]' \
  '-v[print extended info]:val:(0 1)' \
  '-d[predefine a symbol]:symbol=value:' \
  '-s[symbols dump]:file:_files' \
  '1:source file:_files -g "*.asm"' \
  '2:output file:_files' && ret=0
return ret
