#compdef ex_doc
# Documentation: https://github.com/elixir-lang/ex_doc/blob/main/lib/ex_doc/cli.ex
# Reference accessed: 2026-05-27
# Verified: upstream switches and aliases in ExDoc.CLI.main/2.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c+,--config=}'[configuration file (.exs or .config)]:file:_files' \
  '--canonical=[preferred URL with rel="canonical" link]:url:' \
  '--favicon=[path to favicon image (PNG, JPEG, SVG)]:file:_files' \
  '--no-footer[do not render the footer]' \
  '(-f --formatter)*'{-f+,--formatter=}'[docs formatter to use]:formatter:(html epub markdown)' \
  '--homepage-url=[URL linked from the site name]:url:' \
  '--language=[primary BCP 47 language tag]:lang:' \
  '(-l --logo)'{-l+,--logo=}'[path to project logo image]:file:_files' \
  '(-m --main)'{-m+,--main=}'[entry-point page in docs]:page:' \
  '(-o --output)'{-o+,--output=}'[output directory for docs]:dir:_files -/' \
  '--package=[Hex package name]:package:' \
  '*--paths=[prepend path (glob) to Erlang code path]:path:_files -/' \
  '--proglang=[project programming language]:lang:(elixir erlang)' \
  '(-q --quiet)'{-q,--quiet}'[only output warnings and errors]' \
  '--source-ref=[branch, commit, or tag for source link inference]:ref:' \
  '(-u --source-url)'{-u+,--source-url=}'[URL to the source code]:url:' \
  '--warnings-as-errors[exit non-zero if generation produced warnings]' \
  '(-v --version)'{-v,--version}'[print ExDoc version]' \
  '1:project:' \
  '2:version:' \
  '*:beam-dir:_files -/' && ret=0

return ret
