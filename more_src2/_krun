#compdef krun
# _krun — Containers project krun CLI launcher around libkrun for running unmodified Linux user-space applications inside a lightweight Hypervisor-Framework-based microVM Krunfw kernel KVM HVF macOS Hypervisor.framework Linux-KVM x86-64 ARM64 architecture for OCI-runtime spec-compatible containers (containers team, C); cobra
# upstream: https://github.com/containers/libkrun

_krun() {
    local -a sub=(
        'create:create a new krun VM'
        'start:start a stopped krun VM'
        'state:show VM state'
        'kill:kill the VM'
        'delete:delete VM'
        'exec:exec in a running krun VM'
        'ps:list processes'
        'pause:pause VM'
        'resume:resume VM'
        'list:list managed VMs'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--root=+[dir]:dir:_files -/' \
        '--log=+[file]:file:_files' \
        '--log-format=+[fmt]:f:(text json)' \
        '--socket-path=+[file]:file:_files' \
        '--rootfs=+[dir]:dir:_files -/' \
        '--bundle=+[dir]:dir:_files -/' \
        '--no-pivot[no pivot root]' \
        '--keep-stdin[keep stdin open]' \
        '--detach[detach]' \
        '--pid-file=+[file]:file:_files' \
        '--console-socket=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krun subcommand' sub ;;
        args)
            case $words[1] in
                start|state|kill|delete|exec|pause|resume) _arguments '*:vm id:' ;;
                create) _arguments '*:bundle:_files -/' ;;
            esac
            ;;
    esac
}

_krun "$@"
