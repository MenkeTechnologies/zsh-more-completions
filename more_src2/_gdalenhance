#compdef gdalenhance
# Documentation: https://github.com/OSGeo/gdal
# Source: OSGeo/gdal apps/gdalenhance.cpp — apply histogram equalisation to raster (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--help-general[show generic GDAL options]' \
    '-of+[output format]:format:_default' \
    '*-co+[creation option NAME=VALUE]:option:_default' \
    '-ot+[output pixel type]:type:(Byte Int16 UInt16 UInt32 Int32 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
    '-equalize[apply histogram equalisation]' \
    '-config+[config file]:file:_files' \
    '-quiet[suppress output]' \
    '1:src dataset:_files' \
    '2:dst dataset:_files' \
    && ret=0

return ret
