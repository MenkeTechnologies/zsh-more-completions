#compdef pbs_server
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man8/pbs_server.8B.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pbs_server: PBS/TORQUE batch server daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[accounting file path]:file:_files' \
  '-a[scheduling state]:val:(true false)' \
  '-d[home directory (PBS_HOME)]:dir:_files -/' \
  '-H[alternative hostname]:host:_hosts' \
  '-L[log file path]:file:_files' \
  '-l[scheduler host/port list]:spec:' \
  '-M[mom port]:port:' \
  '-p[port for batch requests]:port:' \
  '-R[mom RPP port]:port:' \
  '-S[scheduler port]:port:' \
  '-t[startup type]:type:(create cold warm hot)' \
  '*::pbs_server args:_files' && ret=0
return ret
