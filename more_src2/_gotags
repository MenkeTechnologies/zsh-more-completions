#compdef gotags
# Documentation: https://github.com/jstemmer/gotags
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-L+[read source file names from file (- for stdin)]:file:_files' \
  '-R[recurse into directories]' \
  '-f+[write output to file (- for stdout)]:file:_files' \
  '-silent[suppress error output]' \
  '-sort[sort tags]' \
  '-tag-relative[make file paths relative to tag file directory]' \
  '-v[display version]' \
  '*:go source:_files -g "*.go(-.)"'
