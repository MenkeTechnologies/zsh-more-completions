#compdef kserve-manager kserve-controller-manager
# _kserve-manager — KServe controller manager (kserve/kserve)
# upstream: https://github.com/kserve/kserve
# Flags from cmd/manager/main.go + controller-runtime zap.Options on tip.

_kserve-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--webhook-port=[webhook server port]:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--health-probe-addr=[health probe bind address]:host\:port:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '--zap-stacktrace-level=[stacktrace threshold]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_kserve-manager "$@"
