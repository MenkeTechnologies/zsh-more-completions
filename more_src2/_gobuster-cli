#compdef gobuster-cli
# _gobuster-cli — OJ Reeves gobuster brute-force URI/dir/DNS subdomain tool CLI alias (OJ team, Go); cobra
# upstream: https://github.com/OJ/gobuster

_gobuster-cli() {
    local -a sub=(
        'dir:directory/file enumeration mode'
        'dns:DNS subdomain enumeration'
        'fuzz:URL fuzzing mode'
        'gcs:google cloud storage enumeration'
        's3:S3 bucket enumeration'
        'tftp:TFTP enumeration'
        'vhost:virtual host enumeration'
        'version:show version'
        'help:show help'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--delay=+[time]:str:' \
        '-d+[time]:str:' \
        '--no-color[no color]' \
        '--no-error[no error log]' \
        '--no-progress[no progress]' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--pattern=+[pattern file]:file:_files' \
        '-p+[pattern file]:file:_files' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--threads=+[threads]:n:' \
        '-t+[threads]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--wordlist=+[wordlist file]:file:_files' \
        '-w+[wordlist file]:file:_files' \
        '--wordlist-offset=+[offset]:n:' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gobuster subcommand' sub ;;
        args)
            case $words[1] in
                dir) _arguments \
                    '--url=+[target URL]:url:_urls' \
                    '-u+[target URL]:url:_urls' \
                    '--cookies=+[cookies]:str:' \
                    '-c+[cookies]:str:' \
                    '--extensions=+[extensions csv]:str:' \
                    '-x+[extensions csv]:str:' \
                    '--username=+[user]:_users' \
                    '-U+[user]:_users' \
                    '--password=+[password]:str:' \
                    '-P+[password]:str:' \
                    '--useragent=+[user agent]:str:' \
                    '-a+[user agent]:str:' \
                    '--headers=+[headers]:str:' \
                    '-H+[headers]:str:' \
                    '--proxy=+[proxy URL]:url:_urls' \
                    '--timeout=+[timeout]:str:' \
                    '--follow-redirect[follow redirects]' \
                    '-r[follow redirects]' \
                    '--status-codes=+[codes csv]:str:' \
                    '-s+[codes csv]:str:' \
                    '--status-codes-blacklist=+[codes csv]:str:' \
                    '-b+[codes csv]:str:' \
                    '--insecuressl[insecure ssl]' \
                    '-k[insecure ssl]' \
                    '--exclude-length=+[lengths csv]:str:' \
                    '--add-slash[add slash]' \
                    '-f[add slash]' \
                    '--discover-backup[discover backup files]' \
                    '--expanded[expanded mode]' \
                    '-e[expanded mode]' \
                    '--hide-length[hide length]' \
                    '-n[no status code]' \
                    '--random-agent[random user agent]' ;;
                dns) _arguments \
                    '--domain=+[domain]:str:' \
                    '-d+[domain]:str:' \
                    '--show-ips[show ips]' \
                    '-i[show ips]' \
                    '--show-cname[show CNAME]' \
                    '-c[show CNAME]' \
                    '--resolver=+[resolver]:str:' \
                    '-r+[resolver]:str:' \
                    '--timeout=+[timeout]:str:' \
                    '--wildcard[force continue on wildcard]' ;;
                vhost) _arguments \
                    '--url=+[target URL]:url:_urls' \
                    '-u+[target URL]:url:_urls' \
                    '--exclude-length=+[lengths csv]:str:' \
                    '--append-domain[append domain]' \
                    '-c+[cookies]:str:' \
                    '--cookies=+[cookies]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gobuster-cli "$@"
