#compdef mongokerberos
# Documentation: https://www.mongodb.com/docs/manual/reference/program/mongokerberos/
# Reference accessed: 2026-05-19
# Verified: upstream mongokerberos reference page.

# mongokerberos: Kerberos configuration validator for MongoDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '(--client)--server[run in server mode]' \
  '(--server)--client[run in client mode]' \
  '(-f --config)'{-f+,--config=}'[server-mode config file]:file:_files' \
  '--setParameter=[set configurable parameter]:parameter:' \
  '--host=[server hostname for client-mode test]:host:_hosts' \
  '(-u --username)'{-u+,--username=}'[username for Kerberos auth test]:user:_users' \
  '--gssapiServiceName=[GSSAPI service name]:name:' \
  '--gssapiHostName=[GSSAPI host name]:host:_hosts' \
  '*::mongokerberos args:_files' && ret=0
return ret
