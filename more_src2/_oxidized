#compdef oxidized
# Documentation: https://github.com/ytti/oxidized (lib/oxidized/cli.rb optparse)
# Reference accessed: 2026-05-29
# Oxidized — network device configuration backup tool (Ruby).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage information]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--support[display support diagnostics and exit]' \
  '(- *)--show-exhaustive-config[output entire configuration including defaults and exit]' \
  '(-d --debug)'{-d,--debug}'[enable debugging mode]' \
  '--daemonize[fork the process and run as a daemon]' \
  '--home-dir=[Oxidized home directory]:dir:_directories' \
  '--config-file=[Oxidized configuration file path]:file:_files' && ret=0

return ret
