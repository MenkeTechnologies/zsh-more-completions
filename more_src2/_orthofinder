#compdef orthofinder
# _orthofinder — David Emms Steve Kelly orthofinder CLI comparative genomics tool inferring orthologs paralogs ortholog-trees rooted species-tree gene-tree DLCpar DLC duplication-loss-coalescence reconciliation per-species orthogroup-counts statistics summary HTML reports for protein FASTA inputs (David Emms team, Python); argparse
# upstream: https://github.com/davidemms/OrthoFinder

_orthofinder() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-f+[input fasta dir]:dir:_files -/' \
        '-b+[previous results dir]:dir:_files -/' \
        '-fg+[previous orthogroups dir]:dir:_files -/' \
        '-ft+[previous tree results]:dir:_files -/' \
        '-t+[threads BLAST]:n:' \
        '-a+[threads OrthoFinder]:n:' \
        '-d[input DNA]' \
        '-M+[method]:m:(dendroblast msa)' \
        '-S+[search]:s:(diamond diamond_ultra_sens blast mmseqs)' \
        '-A+[MSA]:m:(mafft muscle)' \
        '-T+[tree]:t:(fasttree raxml raxml-ng iqtree)' \
        '-s+[species tree]:file:_files' \
        '-I+[inflation]:n:' \
        '-x+[orthoxml output]:file:_files' \
        '-p+[temp pickled files]:dir:_files -/' \
        '-1[stop after orthogroups]' \
        '-X[no MSAs]' \
        '-z[skip duplicate detection]' \
        '-n+[name]:str:' \
        '-o+[output dir]:dir:_files -/' \
        '-y[split paralogous clades]' \
        '--save-space[save space]' \
        '*::'
}

_orthofinder "$@"
