#compdef eks-node-viewer
# Documentation: https://github.com/awslabs/eks-node-viewer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--version[Show version]' \
  '(-r --resources)'{-r,--resources}'=[CPU resources string]:string:' \
  '(-n --node-sort)'{-n,--node-sort}'=[Sort nodes by field]:field:' \
  '--kubeconfig=[path]:file:_files' \
  '--context=[kube context]:context:' \
  '*::args: _default'
