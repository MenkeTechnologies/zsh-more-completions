#compdef mommy
# Documentation: https://github.com/FWDekker/mommy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[open the mommy manual page]' \
  '(- *)'{-v,--version}'[show version information]' \
  '-1[write output to stdout instead of stderr]' \
  '(-p --pipefail)'{-p,--pipefail}'[enable pipefail in evaluated commands]' \
  '(-t --toggle)'{-t,--toggle}'[toggle whether mommy displays output]' \
  '(-c --config)'{-c+,--config=}'[read config from file]:file:_files' \
  '(-d --global-config-dirs)'{-d+,--global-config-dirs=}'[colon-separated global config dirs]:dirs:' \
  '-e[evaluate the following command (eval mode)]' \
  '--eval[evaluate the following command (eval mode)]' \
  '-s[respond to the given exit status (status mode)]:status:' \
  '--status=[respond to the given exit status (status mode)]:status:' \
  '*::command:_command_names' && ret=0

return ret
