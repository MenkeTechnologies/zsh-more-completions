#compdef rbac-lookup
# Documentation: https://rbac-lookup.docs.fairwinds.com/usage/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '--context=[context to use for Kubernetes config]:context:' \
  '--gke[enable GKE integration]' \
  '(-k --kind)'{-k+,--kind=}'[filter by RBAC subject kind]:kind:(user group serviceaccount)' \
  '--kubeconfig=[config file location]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(normal wide)' \
  '*::args: _default'
