#compdef jscpd
# Documentation: https://github.com/kucherenko/jscpd/blob/master/apps/jscpd/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-l,--min-lines}'[min size of duplication in lines]:lines:' \
  {-k,--min-tokens}'[min size of duplication in tokens]:tokens:' \
  {-x,--max-lines}'[max source size in lines]:lines:' \
  {-z,--max-size}'[max source size in bytes]:size:' \
  {-t,--threshold}'[exit with error when duplications exceed threshold]:threshold:' \
  {-c,--config}'[path to JSON config file]:file:_files' \
  {-i,--ignore}'[glob patterns for excluded files (comma-separated)]:pattern:' \
  '--ignore-pattern[regexp patterns for code blocks to ignore]:pattern:' \
  {-r,--reporters}'[reporters comma-separated]:reporter:(console consoleFull ai json xml csv markdown html sarif verbose badge)' \
  {-o,--output}'[report output directory]:directory:_files -/' \
  {-m,--mode}'[detection quality mode]:mode:(strict mild weak)' \
  {-f,--format}'[formats to analyze comma-separated]:formats:' \
  '--formats-exts[define formats with file extensions (e.g. javascript:es,es6)]:spec:' \
  '--formats-names[map extensionless files to formats by filename]:spec:' \
  {-p,--pattern}'[glob pattern to find files to detect]:pattern:' \
  {-b,--blame}'[get git author/date info for duplications]' \
  {-s,--silent}'[do not print progress and result to console]' \
  '--store[custom duplication store (e.g. leveldb)]:store:' \
  '--store-path[LevelDB cache directory for parallel runs]:directory:_files -/' \
  {-a,--absolute}'[use absolute paths in reports]' \
  {-n,--noSymlinks}'[do not follow symlinks when scanning files]' \
  '--ignoreCase[ignore case of symbols in code (experimental)]' \
  '--skipComments[strip comments (shorthand for --mode weak)]' \
  '--noTips[suppress tip messages]' \
  {-g,--gitignore}'[ignore files matched by .gitignore]' \
  {-d,--debug}'[show options and selected files; skip detection]' \
  {-v,--verbose}'[verbose output during detection]' \
  '--list[list supported formats]' \
  '--skipLocal[detect duplicates across folders only, not within]' \
  '--exitCode[custom exit code when duplications are found]:code:' \
  '*:path:_files'
