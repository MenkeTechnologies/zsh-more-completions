#
# Execution modes (mutually exclusive "modal options"):
#   (default)            Compile + run module
#   -c                   Compile-only (produce .fam)
#   -i                   Interactive Falcon REPL
#   -S                   Output assembly (debug)
#   -t                   Output syntactic tree (debug)
#   -y                   Output string translation table
#   -x                   Execute pre-compiled .fam binary
#   --cgi                CGI execution mode
#
# Compilation options (c_opts):
#   -d <directive>=<val>  Set directive
#   -D <constant>=<val>   Set constant
#   -E <encoding>         Source file encoding (overrides -e)
#   -f                    Force recompile (ignore .fam cache)
#   -m                    Don't compile in memory (use temp files)
#   -T                    Treat module as .ftd (template document)
#
# Run options (r_opts):
#   -C                    Check memory allocation correctness
#   -e <encoding>         VM I/O encoding
#   -F <file>             Output TRACE debug to file (debug build only)
#   -l <lang>             Preferential module language
#   -L <path>             Add load path (`;`-separated; lead-`;`
#                          removes std paths)
#   -M                    Don't save .fam compiled modules
#   -p <module>           Preload (pump in) module (repeatable)
#   -P                    Ignore system PATH + FALCON_LOAD_PATH
#   -r                    Don't recompile (ignore sources)
#
# General options:
#   -h, -?                Brief help
#   -H                    Detailed help
#   -o <file>             Output file
#   -s                    Errors to stdout instead of stderr
#   -v                    Version
#   -w                    Wait for console after exit
#
# Five-axis distinctness of Falcon from every other documented
# language:
#
#   1. EXPLICIT SIX-PARADIGM FUSION — Falcon's design thesis is
#      unifying imperative + prototype-OOP + functional +
#      statement-oriented + tabular + message-passing in one
#      language.
#
#   2. .fam BYTECODE FORMAT since 2003 — predates GraalVM truffle
#      + LLVM-bitcode-as-IR with its own intermediate format
#      designed for Falcon's six-paradigm semantics.
#
#   3. FTD TEMPLATE-DOCUMENT MODE BUILT-IN — `-T` flag enables
#      PHP-style template-with-code processing without external
#      template engines.
#
#   4. TABULAR PARADIGM AS FIRST-CLASS — row-oriented operations
#      on collections-of-records are language primitives, not
#      library features.
#
#   5. GIANCARLO-NICCOLAI 23-YEAR SUSTAINED DEVELOPMENT — single
#      author maintaining Falcon since 2003 through Falcon 1 +
#      Falcon 2 evolution.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/falconpl/falcon/blob/master/clt/falcon/options.cpp
# FalconOptions::usage() function + parse() switch table.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(-h -? -H)'{-h,-\?}'[brief help]' \
    '(-h -? -H)-H[detailed help]' \
    '(- *)-v[print version and exit]' \
    '(-c -i -S -t -y -x)-c[compile-only (produce .fam module)]' \
    '(-c -i -S -t -y -x)-i[interactive Falcon REPL listener]' \
    '(-c -i -S -t -y -x)-S[produce assembly output (debug)]' \
    '(-c -i -S -t -y -x)-t[produce syntactic tree output (debug)]' \
    '(-c -i -S -t -y -x)-y[write string translation table]' \
    '(-c -i -S -t -y -x)-x[execute pre-compiled .fam binary]' \
    '--cgi[CGI execution mode]' \
    '*-d+[set compilation directive (<directive>=<value>)]:directive:_default' \
    '*-D+[set constant (<constant>=<value>)]:constant:_default' \
    '-E+[source file encoding (overrides -e)]:encoding:_default' \
    '-f[force recompile (ignore .fam cache)]' \
    '-m[do NOT compile in memory (use temp files)]' \
    '-T[treat module as .ftd template document]' \
    '-C[check memory allocation correctness]' \
    '-e+[VM I/O encoding]:encoding:_default' \
    '-F+[output TRACE debug to file (debug build)]:file:_files' \
    '-l+[preferential module language]:language:_default' \
    '-L+[add load path (\;-separated; lead-\; removes std)]:path:_default' \
    '-M[do NOT save compiled .fam modules]' \
    '*-p+[preload (pump in) module]:module:_default' \
    '-P[ignore system PATH + FALCON_LOAD_PATH envvar]' \
    '-r[do NOT recompile (ignore sources)]' \
    '-o+[output file (- for stdout)]:output:_files' \
    '-s[send errors to stdout instead of stderr]' \
    '-w[wait for console after program exit]' \
    '1:Falcon module (.fal/.fam/.ftd) or - for stdin:_files -g "*.{fal,fam,ftd}"' \
    '*::script argument:_default' \
    && ret=0

return ret
