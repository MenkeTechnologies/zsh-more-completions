#compdef pbmtocis
# Documentation: man pbmtocis (Netpbm)
# Source: convert a PBM image to CompuServe RLE (CIS) format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[invert black/white]' \
    '-w[wide-image mode]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
