#compdef realesrgan-ncnn-vulkan rembg
# Documentation: upstream READMEs at github.com/{xinntao/Real-ESRGAN,danielgatis/rembg}
# Reference accessed: 2026-05-30
# Image-processing R31 — Real-ESRGAN portable upscaler binary + rembg
# background-remover CLI.

local curcontext="$curcontext" state line ret=1

case $service in

  realesrgan-ncnn-vulkan)
    # xinntao/Real-ESRGAN — portable image upscaler (NCNN+Vulkan).
    local -a _models _formats
    _models=(
      realesr-animevideov3
      realesrgan-x4plus
      realesrgan-x4plus-anime
      realesrnet-x4plus
    )
    _formats=(jpg png webp)
    _arguments -s -S \
      '-h[show help]' \
      '-i+[input image or directory (jpg/png/webp)]:input:_files' \
      '-o+[output image or directory (jpg/png/webp)]:output:_files' \
      '-s+[upscale ratio (default 4)]:scale:(2 3 4)' \
      '-t+[tile size (>=32, 0=auto; default 0)]:N:' \
      '-m+[model directory (default models)]:directory:_directories' \
      '-n+[model name (default realesr-animevideov3)]:model:($_models)' \
      '-g+[GPU device (default auto)]:gpu:' \
      '-j+[thread count load:proc:save (default 1:2:2)]:threads:' \
      '-x[enable TTA mode]' \
      '-f+[output format (default ext/png)]:format:($_formats)' \
      '-v[verbose output]' \
      && ret=0
    ;;

  rembg)
    # danielgatis/rembg — CLI background remover (CPU/CUDA/ROCm).
    local -a _subcmds
    _subcmds=(
      'i:process single file'
      'p:batch process a folder'
      's:start an HTTP server'
      'b:handle RGB24 pixel binary stream (e.g. from FFmpeg)'
    )
    local -a _models
    _models=(
      u2net
      u2netp
      u2net_human_seg
      u2net_cloth_seg
      silueta
      isnet-general-use
      isnet-anime
      sam
      birefnet-general
      birefnet-general-lite
      birefnet-portrait
      birefnet-dis
      birefnet-hrsod
      birefnet-cod
      birefnet-massive
      bria-rmbg
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'rembg subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          i)
            _arguments \
              '-m+[model name]:model:($_models)' \
              '-om[return only the mask]' \
              '-a[apply alpha matting]' \
              '-x+[extra parameters (JSON format)]:json:' \
              '1:input file:_files' \
              '2:output file:_files' && ret=0
            ;;
          p)
            _arguments \
              '-m+[model name]:model:($_models)' \
              '-om[return only the mask]' \
              '-a[apply alpha matting]' \
              '-x+[extra parameters (JSON format)]:json:' \
              '-w[watch mode (auto-process new/changed files)]' \
              '1:input folder:_directories' \
              '2:output folder:_directories' && ret=0
            ;;
          s)
            _arguments \
              '--host=[listen address]:host:' \
              '--port=[port number]:port:' \
              '--log_level=[logging verbosity]:level:(critical error warning info debug)' \
              '--no-ui[disable Gradio interface]' && ret=0
            ;;
          b)
            _arguments \
              '-m+[model name]:model:($_models)' \
              '-o+[printf-style output filename]:pattern:' \
              '1:width:' \
              '2:height:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
