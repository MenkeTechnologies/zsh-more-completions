#compdef fswatch-cli
# _fswatch-cli — Enrico M. Crisostomo fswatch cross-platform file change monitor CLI alias (emcrisostomo team, C++); custom argparse
# upstream: https://github.com/emcrisostomo/fswatch

_fswatch-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-0[NUL as record separator]' \
        '--print0[NUL as record separator]' \
        '-1[exit after first set of events]' \
        '--one-event[exit after first set of events]' \
        '-a[ignore overflow events]' \
        '--allow-overflow[ignore overflow events]' \
        '-b+[batch marker]:str:' \
        '--batch-marker=+[batch marker]:str:' \
        '-d[directory only]' \
        '--directories[directory only]' \
        '-e+[regex exclude]:str:' \
        '--exclude=+[regex exclude]:str:' \
        '-E[extended regex]' \
        '--extended[extended regex]' \
        '-f+[format]:str:' \
        '--format=+[format]:str:' \
        '--format-time=+[format]:str:' \
        '-i+[regex include]:str:' \
        '--include=+[regex include]:str:' \
        '-I[insensitive case]' \
        '--insensitive[insensitive case]' \
        '-l+[latency seconds]:str:' \
        '--latency=+[latency seconds]:str:' \
        '-L[follow symlinks]' \
        '--follow-links[follow symlinks]' \
        '-m+[monitor name]:m:(inotify fsevents kqueue windows poll fen)' \
        '--monitor=+[monitor name]:m:(inotify fsevents kqueue windows poll fen)' \
        '-M[show monitors list]' \
        '--list-monitors[show monitors list]' \
        '-n+[event name]:str:' \
        '--event=+[event name]:str:' \
        '--event-flag-separator=+[separator]:str:' \
        '--event-flags[show event flags]' \
        '-o[print only events count]' \
        '--one-per-batch[print only events count]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-t[show timestamp]' \
        '--timestamp[show timestamp]' \
        '-u[utf8 timestamp]' \
        '--utf-time[utf8 timestamp]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-x[event type]' \
        '--event-flags[event type]' \
        '*:files:_files'
}

_fswatch-cli "$@"
