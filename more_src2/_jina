#compdef jina
# Documentation: https://github.com/jina-ai/cli
# Reference accessed: 2026-05-23
# Verified: upstream README command table and flags.

# Zsh completion for jina - Jina AI APIs as Unix commands

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'read:extract markdown from URL'
  'search:web search'
  'embed:generate embeddings'
  'rerank:rerank stdin by query'
  'classify:classify text'
  'dedup:deduplicate stdin'
  'screenshot:capture URL screenshot'
  'bibtex:search citations'
  'expand:expand query'
  'pdf:extract PDF content'
  'datetime:guess URL dates'
  'primer:context info'
  'grep:semantic grep'
  'config:manage settings'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--json[JSON output]' \
  '--local[use local Ollama/MLX]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'jina command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (read)
        _arguments \
          '--links[include links]' \
          '--images[include images]' \
          ':url:_urls' && ret=0
        ;;
      (search)
        _arguments \
          '--arxiv[arXiv search]' \
          '--ssrn[SSRN search]' \
          '--images[image search]' \
          '--blog[blog search]' \
          '(-n --num)'{-n+,--num=}'[number of results]:n:' \
          '--time[time filter]:t:(d w m y)' \
          '--gl[geo location]:code:' \
          '--hl[language]:lang:' \
          ':query:' && ret=0
        ;;
      (embed|classify|expand|bibtex)
        _arguments '*:text:' && ret=0
        ;;
      (rerank|dedup)
        _arguments ':query:' && ret=0
        ;;
      (screenshot|pdf|datetime)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          ':url:_urls' && ret=0
        ;;
      (config)
        _arguments '1:sub:(set get list path)' && ret=0
        ;;
      (grep)
        _arguments \
          '(-r --recursive)'{-r,--recursive}'[recursive]' \
          '--threshold[similarity threshold]:n:' \
          '--top-k[top matches]:n:' \
          ':pattern:' && ret=0
        ;;
    esac
    ;;
esac

return ret
