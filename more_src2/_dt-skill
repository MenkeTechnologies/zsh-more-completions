_dt_skill_dt_skill() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _dt_cmds=(
                'gen:generate an image from a text prompt'
                'config:manage skill configuration'
                'doctor:run diagnostics to verify paths and server status'
                'models:list available models and upscalers'
                'server:manage the Draw Things gRPC server process'
            )
            _describe -t commands 'dt-skill command' _dt_cmds && ret=0
            ;;
        args)
            case $words[1] in
                gen)
                    _arguments \
                        '--prompt=[text prompt for image generation]:text:' \
                        '--negative-prompt=[negative prompt to exclude elements]:text:' \
                        '--width=[image width (default 1024)]:n:' \
                        '--height=[image height (default 576)]:n:' \
                        '--steps=[number of sampling steps (default 8)]:n:' \
                        '--seed=[random seed (0 for random)]:n:' \
                        '--guidance=[guidance scale (default 1.0)]:f:' \
                        '--sampler=[sampler name (default unicpc-trailing)]:name:' \
                        '--model=[model filename]:file:' \
                        '*--lora=[add LoRA NAME\:WEIGHT (repeatable)]:lora:' \
                        '--upscale=[upscale factor (default 1)]:n:(1 2 4)' \
                        '--output=[output image path]:path:_files -g "*.png *.jpg *.jpeg"' \
                        '--image=[input image for Img2Img]:path:_files -g "*.png *.jpg *.jpeg"' \
                        '--strength=[denoising strength for Img2Img 0.0-1.0 (default 0.7)]:f:' && ret=0
                    ;;
                config)
                    _arguments \
                        '--server-path=[path to Draw Things gRPC server binary]:path:_files' \
                        '--models-path=[path to models directory]:dir:_files -/' \
                        '--addr=[gRPC server address (default localhost:7859)]:addr:' \
                        '--tls=[enable/disable TLS (default true)]:bool:(true false)' \
                        '--show[show current configuration]' && ret=0
                    ;;
                server)
                    if (( CURRENT == 2 )); then
                        local -a _sv=(
                            'start:start the server in background'
                            'stop:stop the running server'
                            'restart:restart the server (apply configuration changes)'
                            'status:check if the server is healthy and responsive'
                        )
                        _describe -t sub 'server sub' _sv && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_dt_skill_dt_mcp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

case "${service:-${words[1]}}" in
    dt-mcp)        _dt_skill_dt_mcp "$@" ;;
    dt-skill|*)    _dt_skill_dt_skill "$@" ;;
esac
