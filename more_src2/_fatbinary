#compdef fatbinary
# Documentation: https://docs.nvidia.com/cuda/cuda-binary-utilities/
# Reference accessed: 2026-05-16
# Verified: NVIDIA CUDA Binary Utilities manual. Internal tool;
# authoritative source is `fatbinary --help`.
# Removed from prior file: bogus man.archlinux.org search URL.

# fatbinary: NVIDIA fat binary builder/extractor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--create=[output fatbin file]:file:_files' \
  '*--image=[add image spec]:spec:' \
  '--cuda[CUDA mode]' \
  '(--32)--64[64-bit mode]' \
  '(--64)--32[32-bit mode]' \
  '--key=[fatbin key string]:key:' \
  '--ident=[fatbin ident string]:ident:' \
  '--compress-all[compress all images]' \
  '*:input:_files' && ret=0
return ret
