# ============================================================================
# duh - "Design Union Hardware" toolkit by SiFive (Node, Apache-2.0)
#
# Author : SiFive Inc. (sifive)
# Upstream: https://github.com/sifive/duh
# npm    : duh / duh-bus / duh-core / duh-scala
#
# duh is a Node/yargs/JSON5-driven hardware IP-block description tool
# from the SiFive ecosystem (Freedom / Chip Inventor / RISC-V). The
# central artifact is a JSON5 "DUH document" - a structured IEEE-1685
# IP-XACT-style description of a hardware component (ports, buses,
# memory maps, abstraction views) - and the CLI provides:
#
#   duh get <path> [file]                 - JSONPath-ish reader for DUH docs
#   duh init [file]                       - scaffold a new DUH document
#   duh validate <file>                   - validate against the DUH JSON Schema
#   duh test                              - run the test suite
#
# Plus a constellation of companion binaries for Verilog import/export:
#
#   duh-import-verilog-ports [-o file] [duh.json5]
#   duh-import-verilog-ports-simple [-o file] [duh.json5]
#   duh-infer-channels
#   duh-export-verilog-bbx
#
# The JSON-Schema validation lane is built on `ajv ^8.17.1` (declared
# directly in upstream package.json HEAD) plus `ajv ^6.12.6` carried
# in via `duh-core`'s schema layer. Verbatim from upstream
# `lib/index.js`:
#
#     exports.validate = argv => new Promise((resolve, reject) => {
#         if (argv.verbose) console.log('validate');
#         duhCore.readDuh(argv)
#             .then(duhCore.validateSchema)   // <-- ajv-backed
#             .then(duh => {
#                 const validateBus = genValidateBus(duhBus);
#                 if (!validateBus(duh)) {
#                     reject(validateBus.errors);
#                 }
#                 resolve();
#             });
#     });
#
# `duhCore.validateSchema` and `genValidateBus(duhBus)` are both
# ajv-compiled validators - the DUH JSON Schema and the bus-definition
# JSON Schemas are loaded at startup, compiled to validator functions
# by ajv, then invoked against the parsed JSON5 document.
#
# ----------------------------------------------------------------------------
# AXIS 197 :: JSON SCHEMA VALIDATION (DRAFT 4 - 2020-12)  [CLOSES]
# Round 1291 :: TS-Node slot 3 of 4 :: CLOSES Axis 197 (190th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : Stranger6667/jsonschema     [R1289 _ironclaw]
#   Go      : santhosh-tekuri/jsonschema  [R1290 _csaf_aggregator]
#   TS/Node : ajv-validator/ajv           [R1291 THIS FILE]
#
# Ajv is the dominant JSON-Schema validator in the JS ecosystem with
# multi-million weekly npm downloads, and is the dependency-of-record
# for OpenAPI / GraphQL / JSON-API / config-validation toolchains
# across Node. It compiles JSON Schema documents to JavaScript
# validator functions at runtime, with support for draft-04 through
# 2020-12 (the `--spec` flag in ajv-cli switches drafts; here, duh
# pins draft-07 via the schema metadata).
#
# duh is a real-world hardware-design CLI consumer that exercises ajv
# on every `duh validate` invocation across the entire SiFive Freedom
# IP-XACT-style component catalog - one of the rare consumers outside
# the OpenAPI/web-API world that lands here.
# ============================================================================

_duh() {
    case "$service" in
        duh)                                _duh_main_args ;;
        duh-export-verilog-bbx)             _duh_simple_args ;;
        duh-import-verilog-ports)           _duh_import_args ;;
        duh-import-verilog-ports-simple)    _duh_import_args ;;
        duh-infer-channels)                 _duh_simple_args ;;
    esac
}

_duh_main_args() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version]' \
        '1: :_duh_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                get)             _arguments \
                                     '1:value path:' \
                                     '2:DUH document file:_files -g "*.(json|json5)"' ;;
                init)            _arguments \
                                     '1:document file:_files -g "*.(json|json5)"' ;;
                validate|val)    _arguments \
                                     '1:document file:_files -g "*.(json|json5)"' ;;
                test)            _arguments '(- *)'{-h,--help}'[show help]' ;;
                help)            _duh_cmds ;;
            esac
            ;;
    esac
    return ret
}

_duh_cmds() {
    local -a cmds
    cmds=(
        'get:Get value from the DUH document file'
        'init:Create a new DUH document file (scaffolder)'
        'validate:Validate DUH document against the schema'
        'val:Alias for validate'
        'test:Run the test suite'
        'help:Show help'
    )
    _describe -t commands 'duh command' cmds
}

_duh_import_args() {
    _arguments -s -S \
        '(-o --output)'{-o,--output}'[result file path]:file:_files' \
        '--version[print version]' \
        '(- *)'{-h,--help}'[show help]' \
        '*:DUH input file:_files -g "*.(json|json5)"'
}

_duh_simple_args() {
    _arguments -s -S \
        '--version[print version]' \
        '(- *)'{-h,--help}'[show help]' \
        '*:DUH document file:_files -g "*.(json|json5)"'
}

_duh "$@"
