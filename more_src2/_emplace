#compdef emplace
# emplace - Synchronize installed packages on multiple machines

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'init:initialize emplace in this directory'
  'mirror:create a mirror of currently installed packages'
  'install:install packages from mirror'
  'clean:remove packages not in mirror'
  'catch:catch a newly installed package'
  'history:show package installation history'
  'config:manage configuration'
  'help:show help for a command'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'emplace command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      init)
        _arguments \
          '1:repository directory:_files -/' \
          && ret=0
        ;;
      catch)
        _arguments \
          '*:package name:' \
          && ret=0
        ;;
      config)
        _arguments \
          '1:key:' \
          '2:value:' \
          && ret=0
        ;;
      install|mirror|clean|history)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
