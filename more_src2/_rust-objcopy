#compdef rust-objcopy
# Documentation: https://llvm.org/docs/CommandGuide/llvm-objcopy.html
# Reference accessed: 2026-05-21
# Verified: cargo-binutils (rust-embedded/cargo-binutils) wrapper invoking
# llvm-objcopy from the Rust toolchain sysroot; same flag surface as
# llvm-objcopy upstream.

local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '(-O --output-target)'{-O+,--output-target=}'[output format]:format:' \
  '(-I --input-target)'{-I+,--input-target=}'[input format]:format:' \
  '(-F --target)'{-F+,--target=}'[input and output format]:format:' \
  '--strip-all[remove all symbols and non-allocatable sections]' \
  '--strip-debug[remove debug sections only]' \
  '--strip-unneeded[remove symbols not needed for relocations]' \
  '--strip-sections[remove all section headers]' \
  '*--strip-symbol=[remove specific named symbol]:symbol:' \
  '*--keep-symbol=[preserve specific named symbol]:symbol:' \
  '*--localize-symbol=[mark symbol as local]:symbol:' \
  '*--globalize-symbol=[mark symbol as global]:symbol:' \
  '*--weaken-symbol=[mark symbol as weak]:symbol:' \
  '*--redefine-sym=[rename symbol old=new]:old=new:' \
  '--redefine-syms=[rename symbols from file]:file:_files' \
  '*--add-section=[add named section from file]:name=file:' \
  '*--remove-section=[remove named section]:section:' \
  '*--only-section=[keep only named section]:section:' \
  '*--dump-section=[dump section contents to file]:section=file:' \
  '--compress-debug-sections=[compress DWARF debug sections]:type:(zlib zstd)' \
  '--decompress-debug-sections[decompress debug sections]' \
  '*--add-symbol=[add new symbol name=value]:spec:' \
  '--split-dwo=[separate DWARF debug info to file]:file:_files' \
  '*--set-section-flags=[modify section properties]:spec:' \
  '*--rename-section=[rename section old=new]:old=new:' \
  '*:object file:_files' && ret=0
return ret
