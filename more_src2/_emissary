#compdef emissary emissary-cli ambassador-cli
# _emissary — Ambassador Labs Emissary-ingress / Ambassador Edge Stack CLI alias (Ambassador Labs, Go); spf13/cobra
# upstream: https://github.com/emissary-ingress/emissary

_emissary() {
    local -a sub=(
        'config:configuration commands'
        'connect:connect to ambassador cloud'
        'develop:run dev tools'
        'edge-stack:edge-stack commands'
        'install:install Edge Stack/Emissary'
        'uninstall:uninstall'
        'license:license commands'
        'login:login to Ambassador Cloud'
        'logout:logout'
        'sync:sync config to cloud'
        'tunnel:tunnel traffic'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--kubeconfig=+[kubeconfig]:file:_files' \
        '--namespace=+[namespace]:str:' \
        '-n+[namespace]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'emissary subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--license=+[license key]:str:' \
                    '--quick-start[quick start]' \
                    '--no-license-prompt[no license prompt]' \
                    '--registry=+[image registry]:str:' \
                    '--version=+[version]:str:' \
                    '--namespace=+[namespace]:str:' ;;
                config) _arguments \
                    '1:cmd:(generate validate)' \
                    '*:arg:' ;;
                develop) _arguments \
                    '1:cmd:(intercept preview ambassador-config-watch)' \
                    '*:arg:' ;;
                edge-stack) _arguments \
                    '1:cmd:(dashboard activate auth)' \
                    '*:arg:' ;;
                license) _arguments \
                    '1:cmd:(activate show update)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_emissary "$@"
