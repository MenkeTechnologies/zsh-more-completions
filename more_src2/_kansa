#compdef kansa kansa.ps1
# ============================================================================
#  _kansa — Kansa: Powershell-based incident response framework
#
#  Source-direct extraction from
#    https://github.com/davehull/Kansa/blob/master/kansa.ps1
#    (PowerShell language `param()` block syntax — built into the
#     PowerShell language itself, not a separate library)
#
#  Authored by Dave Hull (davehull/Kansa).  1654 GH stars.  Kansa is a
#  MODULAR PowerShell-based incident response framework for Windows
#  environments with Windows Remote Management (WinRM) enabled.  Spins
#  up parallel jobs against multiple targets, runs Kansa modules
#  (PowerShell scripts that produce structured data), and aggregates
#  output as CSV/JSON/TSV/XML or sends to Splunk/Graylog (ELK stack).
#  Sister tools: Velociraptor (DFIR endpoint platform, in corpus),
#  GRR Rapid Response (Python DFIR, in corpus), CarbonBlack Response
#  (commercial), CrowdStrike Falcon Endpoint (commercial).
#
#  CLI library taxonomy update: 1st PowerShell entry — PowerShell
#  `param()` block.  PowerShell is a FIRST-TIME addition to the
#  cross-language CLI library taxonomy.
#
#  PowerShell's `param()` block is FUNDAMENTALLY DIFFERENT from every
#  other CLI library documented — it is a LANGUAGE FEATURE of
#  PowerShell itself, NOT a separate library.  The PowerShell
#  RUNTIME PARSES the script's `param()` block AT INVOCATION TIME
#  and BINDS command-line args to PowerShell VARIABLES in the
#  script's scope using POWERSHELL'S TYPE COERCION engine.
#
#  PowerShell `param()` block API:
#    #!/usr/bin/env pwsh
#    [CmdletBinding()]    # enables advanced function features
#    Param(
#      [Parameter(Mandatory=$True, Position=0)]
#        [String]$Name,
#      [Parameter(Mandatory=$False, Position=1)]
#        [Int]$Count=10,
#      [Parameter(Mandatory=$False)]
#        [ValidateSet("a", "b", "c")]
#        [String]$Mode="a",
#      [Parameter(Mandatory=$False)]
#        [ValidateRange(0, 65535)]
#        [uint16]$Port=5985,
#      [Parameter(Mandatory=$False)]
#        [Switch]$Force,
#      [Parameter(Mandatory=$False)]
#        [String[]]$Targets=@()
#    )
#
#    # Script body — $Name, $Count, $Mode, $Port, $Force, $Targets are
#    # now bound to user-provided values
#    Write-Host "Name: $Name, Count: $Count"
#
#  PowerShell `param()` distinctive features:
#    - LANGUAGE FEATURE — `param()` is a PowerShell built-in block,
#      not an imported library
#    - `[CmdletBinding()]` attribute on the script enables ADVANCED
#      FUNCTION FEATURES — auto-adds common parameters like `-Verbose`,
#      `-Debug`, `-ErrorAction`, `-WarningAction`, `-OutVariable`,
#      `-OutBuffer`, `-PipelineVariable`, `-InformationAction`,
#      `-InformationVariable`, `-WhatIf`, `-Confirm` (when SupportsShouldProcess)
#    - `[Parameter(Mandatory=$true|$false, Position=N, ParameterSetName="X",
#       ValueFromPipeline=$true, ValueFromPipelineByPropertyName=$true,
#       ValueFromRemainingArguments=$true, HelpMessage="X")]` attribute
#       per parameter with rich metadata
#    - `[ValidateSet("a", "b")]` attribute for CHOICES validation
#    - `[ValidateRange(MIN, MAX)]` for NUMERIC RANGE validation
#    - `[ValidatePattern("regex")]` for REGEX validation
#    - `[ValidateLength(MIN, MAX)]` for STRING LENGTH validation
#    - `[ValidateScript({...})]` for ARBITRARY POWERSHELL VALIDATION
#    - `[ValidateNotNull()]`/`[ValidateNotNullOrEmpty()]` for null checks
#    - TYPE ANNOTATIONS — `[String]`/`[Int]`/`[Switch]`/`[String[]]`/
#       `[uint16]`/`[hashtable]`/`[System.Management.Automation.PSCredential]`
#       — PowerShell COERCES values to the declared type at parse time
#    - `[Switch]` type for BOOLEAN FLAGS (PowerShell-specific) —
#      `-Switch` to enable, no value needed
#    - `[String[]]` for ARRAY parameters (caller passes comma-separated
#      or multiple `-Name X -Name Y`)
#    - `[hashtable]` for KEY=VALUE map parameters (caller passes
#      `-Args @{key="value"; key2=42}`)
#    - DEFAULT VALUES via `=$Value` after type annotation
#    - PARAMETER SETS via `ParameterSetName="X"` — mutually exclusive
#      groups of parameters
#  Distinct from EVERY other CLI library in this taxonomy — PowerShell's
#  `param()` is a LANGUAGE FEATURE not a library, with VALIDATION
#  ATTRIBUTES, TYPE COERCION, and PARAMETER SETS BUILT INTO THE
#  LANGUAGE.  Closest analog might be R275 Rust clap-derive (struct +
#  attributes) but PowerShell's `param()` has NO LIBRARY DEPENDENCY —
#  it's just PowerShell scripting syntax.  Brings cross-language CLI
#  library taxonomy variant count to 107; PowerShell added to the
#  documented-CLI-language set.
#
#  Surface (verbatim from kansa.ps1 `Param( ... )` block):
#
#  Parameters (all `-ParameterName Value` style — PowerShell convention):
#    -ModulePath PATH               Module collector path
#                                   (default: Modules\)
#    -TargetList FILE               File containing list of targets
#    -Target HOST                   Single target host
#    -TargetCount N                 Max number of targets
#    -Credential CRED               PSCredential object
#    -OutputFormat FMT              CSV | JSON | TSV | XML | GL | SPLUNK
#                                   (default: CSV; validated via ValidateSet)
#    -Pushbin                       Switch: push required binaries
#    -Rmbin                         Switch: remove pushed binaries
#    -ThrottleLimit N               Max concurrent jobs (default 200)
#    -Encoding ENC                  Output encoding (Ascii/BigEndianUnicode/
#                                   Byte/Default/Oem/String/Unicode/Unknown/
#                                   UTF32/UTF7/UTF8; default Unicode)
#    -UpdatePath                    Switch: add Analysis paths to user path
#    -ListModules                   Switch: list available modules
#    -ListAnalysis                  Switch: list available analysis scripts
#    -Analysis                      Switch: run analysis scripts after collection
#    -Transcribe                    Switch: enable transcript logging
#    -Quiet                         Switch: suppress non-essential output
#    -UseSSL                        Switch: use SSL for WinRM connections
#    -Port PORT                     WinRM port (0-65535; default 5985)
#    -Authentication AUTH           Auth method: Basic/CredSSP/Default/Digest/
#                                   Kerberos/Negotiate/NegotiateWithImplicitCredential
#                                   (default Kerberos)
#    -JSONDepth N                   JSON depth (default 20)
#    -AutoParse                     Switch: auto-parse module output
#    -ElkAlert ALERTS               String array of ELK alert names
#    -JobTimeout SEC                Per-job timeout seconds (default 900)
#    -ElkPort PORTS                 ELK ingest ports array (default 1337)
#    -FireForget                    Switch: fire-and-forget mode
#    -FFwrapper PATH                FireForget wrapper script path
#    -FFArgs HASH                   FireForget arguments hashtable
#    -FFStagePath PATH              FireForget staging path
#    -SafeWord WORD                 Safe word for kill switch
#
#  Auto-added via [CmdletBinding()]:
#    -Verbose                       Show verbose output
#    -Debug                         Show debug output
#    -ErrorAction VAL               Error action preference
#    -WarningAction VAL             Warning action preference
#    -OutVariable VAR               Output variable name
#    -InformationAction VAL         Information stream action
#
#  Dup-skipped neighbors during hunt (smaller surface or in corpus):
#    - PSReadLine (PowerShell module — not a standalone CLI, NO
#      param() block at script root)
#    - Pester (PowerShell test framework — IN CORPUS via _pester)
#    - Invoke-Build (PS task runner — module not standalone)
#    - posh-git (PowerShell git module — IN CORPUS)
# ============================================================================

_kansa() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-ModulePath[module collector path]:path:_directories' \
    '-TargetList[file with target list]:file:_files' \
    '-Target[single target host]:host' \
    '-TargetCount[max number of targets]:count' \
    '-Credential[PSCredential object]:credential' \
    '-OutputFormat[output format]:format:(CSV JSON TSV XML GL SPLUNK)' \
    '-Pushbin[push required binaries to targets]' \
    '-Rmbin[remove pushed binaries from targets]' \
    '-ThrottleLimit[max concurrent jobs (default 200)]:limit' \
    '-Encoding[output encoding]:encoding:(Ascii BigEndianUnicode Byte Default Oem String Unicode Unknown UTF32 UTF7 UTF8)' \
    '-UpdatePath[add analysis paths to user path]' \
    '-ListModules[list available modules]' \
    '-ListAnalysis[list available analysis scripts]' \
    '-Analysis[run analysis scripts after collection]' \
    '-Transcribe[enable transcript logging]' \
    '-Quiet[suppress non-essential output]' \
    '-UseSSL[use SSL for WinRM connections]' \
    '-Port[WinRM port (default 5985)]:port' \
    '-Authentication[auth method]:auth:(Basic CredSSP Default Digest Kerberos Negotiate NegotiateWithImplicitCredential)' \
    '-JSONDepth[JSON depth (default 20)]:depth' \
    '-AutoParse[auto-parse module output]' \
    '-ElkAlert[ELK alert names]:alerts' \
    '-JobTimeout[per-job timeout seconds (default 900)]:seconds' \
    '-ElkPort[ELK ingest ports (default 1337)]:ports' \
    '-FireForget[fire-and-forget mode]' \
    '-FFwrapper[FireForget wrapper script path]:file:_files' \
    '-FFArgs[FireForget arguments hashtable]:hashtable' \
    '-FFStagePath[FireForget staging path]:path:_directories' \
    '-SafeWord[safe word for kill switch]:word' \
    '-Verbose[show verbose output]' \
    '-Debug[show debug output]' \
    '-ErrorAction[error action]:action:(SilentlyContinue Stop Continue Inquire Ignore Suspend)' \
    '-WarningAction[warning action]:action:(SilentlyContinue Stop Continue Inquire Ignore Suspend)'
}

_kansa "$@"
