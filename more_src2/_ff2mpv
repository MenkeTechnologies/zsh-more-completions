#compdef ff2mpv
# Documentation: https://github.com/woodruffw/ff2mpv
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ff2mpv: browser native-messaging host that forwards URLs to mpv.
# No standardized CLI flags are documented upstream; the helper script
# typically reads a JSON message from stdin and launches mpv with the URL.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*:media URL:_urls' && return 0
