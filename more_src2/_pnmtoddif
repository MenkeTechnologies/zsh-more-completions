#compdef pnmtoddif
# Documentation: man pnmtoddif (Netpbm)
# Source: convert a Netpbm image to DEC DDIF (Document Description Interchange Format).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-resolution[x y resolution in dpi]:x:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:ddif output:_files -g "*.ddif"' \
    && ret=0

return ret
