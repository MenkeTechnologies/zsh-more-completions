#compdef meld
# _meld — visual diff / merge tool (GNOME/meld)
# upstream: https://github.com/GNOME/meld
# Flags from meld/meldapp.py (custom GLib option parser).

_meld() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show version]'
        '*'{-L+,--label=}'[set a custom label for the next file (repeatable)]:label:'
        '(-n --newtab)'{-n,--newtab}'[open in a new tab in the existing instance]'
        '(-a --auto-compare)'{-a,--auto-compare}'[recursively auto-compare directories]'
        '(-u --unified)'{-u,--unified}'[ignored (legacy GNU diff flag)]'
        '(-o --output)'{-o+,--output=}'[output file when merging two/three files]:file:_files'
        '--auto-merge[automatically merge conflicting changes]'
        '--comparison-file=[load a saved comparison file (.meldcmp)]:file:_files -g "*.meldcmp"'
        '*--diff=[non-interactive diff of two/three files]:file:_files'
        '*:file or directory:_files'
    )
    _arguments -s $args
}

_meld "$@"
