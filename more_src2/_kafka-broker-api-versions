#compdef kafka-broker-api-versions
# Documentation: https://github.com/apache/kafka/blob/trunk/tools/src/main/java/org/apache/kafka/tools/BrokerApiVersionsCommand.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kafka-broker-api-versions: show Kafka broker API versions
local curcontext="$curcontext" ret=1
_arguments -C \
  '--bootstrap-server[REQUIRED: comma-separated broker list]:host\:port,...:' \
  '--command-config[property file for Admin Client config]:file:_files' \
  '--help[show usage]' \
  '--version[show version]' && ret=0
return ret
