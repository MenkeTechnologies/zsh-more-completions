#compdef docsify
# Documentation: https://github.com/docsifyjs/docsify-cli
# Reference accessed: 2026-05-17
# Verified: docsifyjs/docsify-cli upstream npm package. Subcommands:
# init [path], serve [path], generate <path>, start [path] alias.
# Init flags: -l/--local, --rc/--rcMode, -t/--theme vue|buble|dark|
# pure, -p/--plugins. Serve flags: -o/--open, -p/--port,
# -P/--livereload-port, -H/--hostname, -i/--index. Generate flags:
# --sidebar.
# Removed from prior file: bogus man.archlinux.org search URL.

# Zsh completion for docsify - documentation site generator CLI

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:Create a new docs directory'
      'serve:Run a local server to preview site'
      'start:Run a local server to preview site'
      'generate:Generate a sidebar file'
    )
    _describe -t commands 'docsify command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      init)
        _arguments -s -S \
          '--local[use local files instead of CDN]' \
          '--theme[choose a theme]:theme:(vue buble dark pure)' \
          '--plugins[install recommended plugins]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
      serve|start)
        _arguments -s -S \
          '(-o --open)'{-o,--open}'[open in browser on server start]' \
          '(-p --port)'{-p,--port}'[port to listen on]:port' \
          '--livereload-port[port for livereload]:port' \
          '(-P --indexName)'{-P,--indexName}'[index file name]:name' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
      generate)
        _arguments -s -S \
          '--sidebar[sidebar file to generate]:file:_files' \
          '(-h --help)'{-h,--help}'[show help]' \
          '1:path:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
