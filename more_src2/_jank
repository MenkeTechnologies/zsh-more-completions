#compdef jank
# Documentation: https://github.com/jank-lang/jank/blob/main/compiler%2Bruntime/src/cpp/jank/util/cli.cpp
# Reference accessed: 2026-05-19
# Verified: jank-lang/jank util/cli.cpp subcommands + options.
# Removed invented --class-path/--ee-pic/--profile-output(file)
# and corrected -O/-I/-L/-D flag forms.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:load and run a file'
  'run-main:load and execute -main'
  'repl:start up a terminal REPL client and server'
  'cpp-repl:start up a terminal C++ REPL client'
  'compile:ahead of time compile project with entrypoint module'
  'compile-module:ahead of time compile a module and its dependencies'
  'check-health:provide a status report on the jank installation'
)

_arguments -C \
  '(- *)'{-h,--help}'[print help message and exit]' \
  '--module-path=[colon separated list of dirs/JAR/ZIP files]:path:' \
  '--profile[enable compiler and runtime profiling]' \
  '--profile-output=[file to write profile entries]:file:_files' \
  '--perf[enable Linux perf event sampling]' \
  '--gc-incremental[enable incremental GC collection]' \
  '--debug[enable debug symbol generation]' \
  '--direct-call[elides dereferencing of vars for performance]' \
  '(-O --optimization)'{-O,--optimization}'=[optimization level (0-3) for AOT compilation]:level:(0 1 2 3)' \
  '--eagerness=[how eagerly to JIT compile functions]:mode:(lazy eager)' \
  '*'{-I,--include-dir}'=[directory for includes resolution]:dir:_files -/' \
  '*'{-D,--define-macro}'=[define a macro]:macro:' \
  '*'{-L,--library-dir}'=[directory to search dynamic libraries]:dir:_files -/' \
  '*-l+[library identifier]:lib:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'jank command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (run|run-main|compile-module)
        _arguments '*::file:_files -g "*.{clj,jank}"' && ret=0 ;;
      (compile)
        _arguments \
          '(-o --output)'{-o,--output}'=[output file name]:file:_files' \
          '--output-dir=[prefix for object files]:dir:_files -/' \
          '--output-target=[target of compiled module artifact]:target:(cpp llvm-ir object)' \
          '--runtime=[runtime specification]:runtime:' \
          '*::module:' && ret=0 ;;
    esac ;;
esac

return ret
