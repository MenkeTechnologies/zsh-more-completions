#compdef glib-compile-schemas
# Documentation: glib-compile-schemas --help (GLib)
# Source: GLib glib-compile-schemas — compile GSettings schema files into a schema cache.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(- *)--version[show version and exit]' \
    '--targetdir=[where to store gschemas.compiled]:dir:_files -/' \
    '--strict[abort on any errors in schemas]' \
    '--dry-run[do not write the gschemas.compiled file]' \
    '--allow-any-name[do not enforce key-name restrictions]' \
    '*:directory containing *.gschema.xml:_files -/' \
    && ret=0

return ret
