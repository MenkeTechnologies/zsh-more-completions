#compdef gmtgravmag3d
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/gmtgravmag3d.html
# Source: GenericMappingTools/gmt supplements/potential — gravity/magnetic anomaly from prism/sphere/cylinder/cone/ellipsoid/pyramid/bell or triangle-surface body.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[body density (SI)]:density:_default' \
    '-H+[magnetic params (f_dec/f_dip/m_int/m_dec/m_dip)]:opts:_default' \
    '-F+[xy locations for anomaly]:file:_files' \
    '-G+[output grid file]:file:_files' \
    '-M+[create geometric body (prism/sphere/cylinder/cone/ellipsoid/pyramid/bell)]:opts:_default' \
    '-T+[triangle-surface definition (+v or +r/+s)]:opts:_default' \
    '-E+[non-closed surface thickness (m)]:m:_default' \
    '-L+[observation height level]:level:_default' \
    '-Q[1-based indexing (default 0-based)]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[search radius]:radius:_default' \
    '-Z+[reference plane level]:level:_default' \
    '*-V[verbose (stackable)]' \
    '-fg[geo coords → meters]' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    && ret=0

return ret
