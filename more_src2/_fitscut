#compdef fitscut
# Documentation: https://github.com/spacetelescope/fitscut
# Source: spacetelescope/fitscut fitscut.c — cut a region from FITS files (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '(-f --force)'{-f,--force}'[overwrite output without prompting]' \
    '(-p --png)'{-p,--png}'[write PNG output]' \
    '(-j --jpg)'{-j,--jpg}'[write JPEG output]' \
    '--jquality=[JPEG quality]:q:_default' \
    '(-x)'{-x+,--x=}'[X center pixel]:n:_default' \
    '(-y)'{-y+,--y=}'[Y center pixel]:n:_default' \
    '--wcs[use WCS coordinates for center]' \
    '(-r --rows)'{-r+,--rows=}'[rows]:n:_default' \
    '(-c --columns)'{-c+,--columns=}'[columns]:n:_default' \
    '(-a --autoscale)'{-a+,--autoscale=}'[autoscale percentile]:pct:_default' \
    '--autoscale-min=[autoscale min percent]:pct:_default' \
    '--autoscale-max=[autoscale max percent]:pct:_default' \
    '--full-scale[use full image scaling]' \
    '(-l --log-scale)'{-l,--log-scale}'[logarithmic scaling]' \
    '(-s --sqrt-scale)'{-s,--sqrt-scale}'[square-root scaling]' \
    '(-e --histeq-scale)'{-e,--histeq-scale}'[histogram-equalized scaling]' \
    '--asinh-scale[asinh scaling]' \
    '--linear-scale[linear scaling]' \
    '(-t --palette)'{-t+,--palette=}'[palette name or file]:palette:_default' \
    '--min=[manual min value]:n:_default' \
    '--max=[manual max value]:n:_default' \
    '--x0=[X corner pixel]:n:_default' \
    '--y0=[Y corner pixel]:n:_default' \
    '--align[align north]' \
    '--compass[draw compass arrow]' \
    '--rate[print processing rate]' \
    '--factor=[zoom factor]:n:_default' \
    '--red=[red channel input file]:file:_files' \
    '--green=[green channel input file]:file:_files' \
    '--blue=[blue channel input file]:file:_files' \
    '--all[output all channels]' \
    '--zoom=[zoom amount]:n:_default' \
    '--output-size=[output size]:size:_default' \
    '(-i --invert)'{-i,--invert}'[invert output]' \
    '--add_blurb=[add caption text]:text:_default' \
    '--qext=[FITS extension to use]:ext:_default' \
    '--badpix[mark bad pixels]' \
    '--json[emit metadata as JSON]' \
    '--marker[draw marker]' \
    '--range[print pixel range]' \
    '--badvalue=[bad-pixel value]:n:_default' \
    '--nobsoften[do not soften]' \
    '--reference=[reference FITS file for WCS]:file:_files -g "*.{fits,fit,fts}"' \
    '*:FITS file:_files -g "*.{fits,fit,fts}"' \
    && ret=0

return ret
