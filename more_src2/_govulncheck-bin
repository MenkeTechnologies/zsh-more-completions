#compdef govulncheck
# _govulncheck-bin — Go vulnerability scanner (Go team); analyses code for known Go vulnerabilities from vuln.go.dev
# upstream: https://pkg.go.dev/golang.org/x/vuln/cmd/govulncheck

_govulncheck-bin() {
    _arguments \
        '-C+[change to dir before running]:dir:_files -/' \
        '-db+[vuln DB URL]:url:_urls' \
        '-format+[output format]:fmt:(text json sarif openvex)' \
        '-mode+[mode]:mode:(source binary extract query)' \
        '-scan+[scan level]:level:(module package symbol)' \
        '-show+[show categories]:cats:(traces color verbose version)' \
        '-tags+[build tags]:tags:' \
        '-test[include tests]' \
        '-version[show version]' \
        '*:packages or binary:_files'
}

_govulncheck-bin "$@"
