#compdef geeqie
# Documentation: https://www.geeqie.org/help/GuideReferenceCommandLine.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help options]' \
  '--help-all[show all help options]' \
  '--help-gapplication[show GApplication options]' \
  '--help-gtk[show GTK options]' \
  '(-v --version)'{-v,--version}'[print version info]' \
  '(-b --back)'{-b,--back}'[previous image]' \
  '(-n --next)'{-n,--next}'[next image]' \
  '--first[first image]' \
  '--last[last image]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start/toggle fullscreen]' \
  '--geometry=[set window location and geometry]:WxH:' \
  '--new-window[open new window]' \
  '--close-window[close window]' \
  '--raise[raise window to top]' \
  '--id=[window id]:id:' \
  '--file=[open file or URL]:file:_files' \
  '--File=[open file or URL without raising window]:file:_files' \
  '--view=[open file in new window]:file:_files' \
  '--get-collection=[get collection content]:collection:' \
  '--get-collection-list[list collections]' \
  '--selection-add=[add to selection]:file:_files' \
  '--selection-clear[clear selection]' \
  '--selection-remove=[remove from selection]:file:_files' \
  '--get-selection[get selected files]' \
  '--cache-metadata[clean metadata cache]' \
  '--cache-render=[render thumbnails]:folder:_files -/' \
  '--cache-render-recurse=[render thumbnails recursive]:folder:_files -/' \
  '--cache-render-shared=[render shared thumbnails]:folder:_files -/' \
  '--cache-render-shared-recurse=[render shared thumbnails recursive]:folder:_files -/' \
  '--cache-shared=[clear|clean shared cache]:op:(clear clean)' \
  '--cache-thumbs=[clear|clean thumbnail cache]:op:(clear clean)' \
  '(-s --slideshow)'{-s,--slideshow}'[toggle slideshow]' \
  '(-d --delay)'{-d+,--delay=}'[slideshow delay]:delay:' \
  '--slideshow-recurse=[start recursive slideshow]:folder:_files -/' \
  '--file-extensions[list known file extensions]' \
  '--get-file-info[get file info]' \
  '--get-filelist=[list files and class]:folder:_files -/' \
  '--get-filelist-recurse=[recursive file list]:folder:_files -/' \
  '--get-sidecars=[get sidecar files]:file:_files' \
  '--get-destination=[get destination path]:file:_files' \
  '--tell[print current filename or collection]' \
  '--pixel-info[print pixel info at mouse pointer]' \
  '--dupes=[find duplicates]:folder:_files -/' \
  '--dupes-recurse=[find duplicates recursively]:folder:_files -/' \
  '--dupes-export[export duplicate results]' \
  '--get-render-intent[get render intent]' \
  '--get-rectangle[get rectangle coordinates]' \
  '--get-window-list[list windows]' \
  '--config-load=[load configuration file]:file:_files' \
  '--action=[execute keyboard action]:action:' \
  '--action-list[list available actions]' \
  '--lua=[run Lua script]:script:' \
  '(-o --log-file)'{-o+,--log-file=}'[save log data to file]:file:_files' \
  '(-w --show-log-window)'{-w,--show-log-window}'[show log window]' \
  '(-g --grep)'{-g+,--grep=}'[filter debug output]:regexp:' \
  '--debug=[set debug level]:level:(0 1 2 3 4)' \
  '(-q --quit)'{-q,--quit}'[quit application]' \
  '(-t --tools)'{-t,--tools}'[toggle tools]' \
  '--print0[terminate output with null character]' \
  '--display=[set X display]:display:' \
  '*:path:_files' && ret=0

return ret
