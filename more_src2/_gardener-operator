#compdef gardener-operator
# _gardener-operator — Gardener garden cluster operator
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-operator/app/options.go on tip.

_gardener-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[gardener-operator config file]:file:_files -g "*.(yaml|yml)"' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardener-operator "$@"
