#compdef kubeval
# _kubeval-bin — Garethr/Instrumenta kubeval k8s manifest validator (Gareth Rushgrove, Go); validates yaml/json against k8s OpenAPI schemas
# upstream: https://github.com/instrumenta/kubeval

_kubeval-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--exit-on-error[exit on first error]' \
        '--filename+[filename for output]:str:' \
        '-f+[filename for output]:str:' \
        '--force-color[force color]' \
        '--ignore-helm-source[ignore helm source]' \
        '--ignore-missing-schemas[ignore missing schemas]' \
        '--ignored-filename-patterns+[ignored filename patterns]:patterns:' \
        '--ignored-path-patterns+[ignored path patterns]:patterns:' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--kubernetes-version+[k8s version]:v:' \
        '--no-color[no color]' \
        '--openapi-schema-cache-dir+[openapi schema cache dir]:dir:_files -/' \
        '--output+[output format]:fmt:(stdout json tap junit)' \
        '-o+[output format]:fmt:' \
        '--quiet[only failures]' \
        '--reject+[reject kinds]:kinds:' \
        '--schema-location+[schema location]:url:_urls' \
        '--strict[strict]' \
        '*:file or dir:_files'
}

_kubeval-bin "$@"
