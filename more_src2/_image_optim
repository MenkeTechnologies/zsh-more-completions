#compdef image_optim
# _image_optim — command-line tool to optimize images (toy/image_optim)
# upstream: https://github.com/toy/image_optim
# Flags from lib/image_optim/runner/option_parser.rb.

_image_optim() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(- *)--info[show environment info and exit]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '--config-paths=[comma-separated config paths]:paths:' \
        '(-r -R --recursive)'{-r,-R,--recursive}'[recursively scan directories]' \
        '--exclude-dir=[glob for excluding directories]:glob:' \
        '--exclude-file=[glob for excluding files]:glob:' \
        '--exclude=[glob for excluding both]:glob:' \
        '--no-progress[disable progress display]' \
        '--threads=[number of threads]:n:' \
        '--no-threads[disable threading]' \
        '--nice=[nice priority (-20..19)]:n:' \
        '--no-nice[disable nice]' \
        '--pack[require image_optim_pack]' \
        '--no-pack[disable image_optim_pack]' \
        '--benchmark=[run benchmarks]:type:(isolated)' \
        '--cache-dir=[cache optimized images directory]:dir:_files -/' \
        '--cache-worker-digests[cache worker digests]' \
        '--skip-missing-workers[skip workers with missing binaries]' \
        '--no-skip-missing-workers[do not skip missing workers]' \
        '--allow-lossy[allow lossy workers and optimizations]' \
        '--timeout=[max seconds per image]:seconds:' \
        '--no-advpng[disable advpng worker]' \
        '--no-gifsicle[disable gifsicle worker]' \
        '--no-jhead[disable jhead worker]' \
        '--no-jpegoptim[disable jpegoptim worker]' \
        '--no-jpegrecompress[disable jpeg-recompress worker]' \
        '--no-jpegtran[disable jpegtran worker]' \
        '--no-optipng[disable optipng worker]' \
        '--no-oxipng[disable oxipng worker]' \
        '--no-pngcrush[disable pngcrush worker]' \
        '--no-pngout[disable pngout worker]' \
        '--no-pngquant[disable pngquant worker]' \
        '--no-svgo[disable svgo worker]' \
        '*:image file:_files -g "*.{png,jpg,jpeg,gif,svg,webp}"'
}

_image_optim "$@"
