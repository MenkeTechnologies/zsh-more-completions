#compdef qkeyword
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qkeyword.c — query packages by KEYWORDS metadata.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-p --matchpkg)'{-p+,--matchpkg=}'[match pkgname]:pkg:_default' \
    '(-c --matchcat)'{-c+,--matchcat=}'[match catname]:cat:_default' \
    '(-m --matchmaint)'{-m+,--matchmaint=}'[match maintainer email]:email:_default' \
    '(-a --showarch)'{-a,--showarch}'[show arch from profile]' \
    '(-i --imlate)'{-i+,--imlate=}'[list pkgs marketable stable for arch]:arch:_default' \
    '(-d --dropped)'{-d+,--dropped=}'[list pkgs with dropped keywords for arch]:arch:_default' \
    '(-n --needsstable)'{-n+,--needsstable=}'[list pkgs needing stabilisation for arch]:arch:_default' \
    '(-S --stats)'{-S,--stats}'[portage tree statistics]' \
    '(-A --all)'{-A+,--all=}'[list pkgs with ≥1 keyworded version for arch]:arch:_default' \
    '(-N --not)'{-N+,--not=}'[list pkgs NOT keyworded for arch]:arch:_default' \
    '(-T --testing)'{-T+,--testing=}'[list latest testing version per pkg for arch]:arch:_default' \
    '(-s --stable)'{-s+,--stable=}'[list latest stable version per pkg for arch]:arch:_default' \
    '(-F --format)'{-F+,--format=}'[output format string]:fmt:_default' \
    && ret=0

return ret
