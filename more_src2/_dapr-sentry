#compdef dapr-sentry
# _dapr-sentry — Dapr Sentry certificate authority service (dapr/dapr)
# upstream: https://github.com/dapr/dapr
# Flags from cmd/sentry/options/options.go on tip.

_dapr-sentry() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[Dapr Configuration object name or YAML file]:name:' \
        '--issuer-credentials=[issuer credentials directory]:dir:_files -/' \
        '--issuer-ca-filename=[issuer CA cert filename]:name:' \
        '--issuer-certificate-filename=[issuer certificate filename]:name:' \
        '--issuer-key-filename=[issuer private key filename]:name:' \
        '--trust-domain=[CA trust domain]:domain:' \
        '--port=[Sentry gRPC bind port]:port:' \
        '--listen-address=[Sentry gRPC bind address]:ip:' \
        '--healthz-port=[healthz bind port]:port:' \
        '--healthz-listen-address=[healthz bind address]:ip:' \
        '--mode=[runtime mode]:mode:(kubernetes standalone)' \
        '--jwt-enabled[enable JWT token issuance]' \
        '--jwt-key-filename=[JWT signing key filename]:name:' \
        '--jwks-filename=[JWKS file name]:name:' \
        '--jwt-issuer=[JWT issuer]:iss:' \
        '--jwt-signing-algorithm=[JWT signing algorithm]:alg:(RS256 RS384 RS512 ES256 ES384 ES512 EdDSA)' \
        '--jwt-key-id=[JWT key ID (kid)]:id:' \
        '--jwt-ttl=[JWT TTL]:dur:' \
        '--oidc-enabled[enable OIDC HTTP server]' \
        '--oidc-server-listen-port=[OIDC HTTP server port]:port:' \
        '--oidc-server-listen-address=[OIDC HTTP server bind address]:ip:' \
        '--oidc-server-tls-enabled=[serve OIDC over TLS]:bool:(true false)' \
        '--oidc-server-tls-cert-file=[OIDC TLS cert file]:file:_files' \
        '--oidc-server-tls-key-file=[OIDC TLS key file]:file:_files' \
        '--oidc-jwks-uri=[external JWKS URI]:uri:_urls' \
        '--oidc-path-prefix=[OIDC HTTP path prefix]:prefix:' \
        '*--oidc-allowed-hosts=[allowed host for OIDC HTTP]:host:_hosts' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--log-level=[log level]:level:(debug info warn error fatal panic)' \
        '--log-as-json[log as JSON]' \
        '--enable-metrics[enable Prometheus metrics endpoint]' \
        '--metrics-port=[Prometheus metrics bind port]:port:'
}

_dapr-sentry "$@"
