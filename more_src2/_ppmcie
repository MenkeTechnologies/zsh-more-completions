#compdef ppmcie
# Documentation: man ppmcie (Netpbm)
# Source: generate a CIE-1931 chromaticity-diagram PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-rec709 -cie -ebu -hdtv -ntsc -smpte)-rec709[Rec.709 primaries]' \
    '(-rec709 -cie -ebu -hdtv -ntsc -smpte)-cie[CIE primaries]' \
    '(-rec709 -cie -ebu -hdtv -ntsc -smpte)-ebu[EBU primaries]' \
    '(-rec709 -cie -ebu -hdtv -ntsc -smpte)-hdtv[HDTV primaries]' \
    '(-rec709 -cie -ebu -hdtv -ntsc -smpte)-ntsc[NTSC primaries]' \
    '(-rec709 -cie -ebu -hdtv -ntsc -smpte)-smpte[SMPTE primaries]' \
    '(-xy -upvp)-xy[xy chromaticity coordinates (default)]' \
    '(-xy -upvp)-upvp[u'\''v'\'' chromaticity coordinates]' \
    '*-red+[red primary rx ry]:rx:' \
    '*-green+[green primary gx gy]:gx:' \
    '*-blue+[blue primary bx by]:bx:' \
    '*-white+[white point wx wy]:wx:' \
    '-size=[image edge size in pixels]:edge:' \
    '(-xsize -width)-xsize=[image width]:width:' \
    '(-xsize -width)-width=[image width]:width:' \
    '(-ysize -height)-ysize=[image height]:height:' \
    '(-ysize -height)-height=[image height]:height:' \
    '-noblack[suppress black region]' \
    '-nowpoint[suppress white-point marker]' \
    '-nolabel[suppress axis labels]' \
    '-noaxes[suppress axes]' \
    '-full[draw full chromaticity region]' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
