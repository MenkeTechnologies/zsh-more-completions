_dosr() {
    case "$service" in
        dosr) _dosr_main ;;
        chsr) _chsr_main ;;
    esac
}

# `dosr [OPTIONS] [COMMAND]...` — execute privileged command via RBAC
_dosr_main() {
    _arguments -s -S \
        '(-r --role)'{-r,--role=}'[select a specific role to use]:role:' \
        '(-t --task)'{-t,--task=}'[select a task within the role (requires --role)]:task:' \
        '(-E --preserve-env)'{-E,--preserve-env}'[preserve environment variables if matching task allows]' \
        '(-p --prompt)'{-p,--prompt=}'[override the default password prompt (default "Password: ")]:prompt:' \
        '(-u --user)'{-u,--user=}'[user to execute the command as]:user:_users' \
        '(-g --group)'{-g,--group=}'[group(s) to execute the command as (comma-separated)]:groups:_groups' \
        '(-i --info)'{-i,--info}'[display rights of executor]' \
        '(- *)'{-v,--version}'[print dosr version]' \
        '(- *)'{-h,--help}'[print help]' \
        '*::command and args:_command_names -e'
}

# `chsr [command] [options]` — role manager admin tool
_chsr_main() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'list:list available items (alias: show, l)'
        'show:alias for list'
        'l:alias for list'
        'role:manage roles and related operations (alias: r) — chsr role [role] add|del|show|purge|grant|revoke ...'
        'r:alias for role'
        'options:manage options (path/env/root/bounding/timeout/authentication/execinfo/umask)'
        'convert:convert policy format (-r/--reconfigure /etc/security/rootasrole.json) supports json|cbor with --from'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help for commands and options]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'chsr command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                role|r)
                    local -a rops
                    rops=(
                        'add:add a new role (alias: create)'
                        'create:alias for add'
                        'del:delete a specified role (aliases: delete, unset, d, rm)'
                        'delete:alias for del'
                        'unset:alias for del'
                        'd:alias for del'
                        'rm:alias for del'
                        'show:show details (alias: list, l) — show actors|tasks|all'
                        'list:alias for show'
                        'l:alias for show'
                        'purge:remove all items from a role (actors|tasks|all)'
                        'grant:grant permissions to a user or group (--user / --group)'
                        'revoke:revoke permissions from a user or group'
                        'task:enter task subgrammar — chsr role [role] task [task] show|purge|add|del|...'
                        'options:enter options subgrammar — chsr role [role] options [option] [op]'
                    )
                    _describe -t commands 'chsr role operation' rops && ret=0
                    ;;
                options)
                    local -a oops
                    oops=(
                        'path:manage path settings (setpolicy delete-all|keep-safe|keep-unsafe|inherit / set / whitelist|wl / blacklist|bl)'
                        'env:manage env settings (setpolicy delete-all|keep-all|inherit / set k=v,.. / keep-only / delete-only / whitelist / blacklist / checklist / setlist)'
                        'root:defines when root user gets default privs (unset|privileged|user|inherit)'
                        'bounding:defines when dropped caps are permanently removed (unset|strict|ignore|inherit)'
                        'timeout:manage timeout settings (set --type tty|ppid|uid --duration HH:MM:SS --max-usage N / unset)'
                        'authentication:defines if user needs to authenticate (unset|skip|perform|inherit)'
                        'execinfo:defines if user sees exec settings (unset|display|hide|inherit)'
                        'umask:defines umask for executed command (unset or 022)'
                        'mask:alias for umask'
                    )
                    _describe -t commands 'chsr options' oops && ret=0
                    ;;
                convert)
                    _arguments \
                        '(-r --reconfigure)'{-r,--reconfigure}'[reconfigure /etc/security/rootasrole.json to specify the new location]' \
                        '--from=[specify the source format]:type:(json cbor)' \
                        '*:to_type to_file (json|cbor):' && ret=0
                    ;;
                list|show|l)
                    ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_dosr "$@"
