#compdef kubectl-rabbitmq
# Documentation: upstream kubectl-rabbitmq/*.go at
# github.com/rabbitmq/cluster-operator
# Reference accessed: 2026-05-30 via gh api inspection of every
# cobra.Command Use:/AddCommand call and StringVar/BoolVar/Int32Var/
# Int64Var/StringSliceVar/StringToStringVar flag declaration.
# RabbitMQ kubectl-rabbitmq R71 — kubectl plugin for RabbitMQ Cluster
# Operator. 17 top-level subcommands.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'install-cluster-operator:install the latest released RabbitMQ Cluster Operator'
  'list:list all RabbitMQ clusters'
  'create:create a RabbitMQ cluster'
  'delete:delete one or more RabbitMQ clusters'
  'get:get a RabbitMQ cluster and dependent objects'
  'debug:set log level to debug on all nodes'
  'tail:tail logs from all nodes (requires kubectl tail plugin)'
  'observe:run rabbitmq-diagnostics observer on a specific node'
  'secrets:show secrets for the cluster'
  'enable-all-feature-flags:automatically enable all feature flags'
  'pause-reconciliation:pause the operator reconciliation for this cluster'
  'resume-reconciliation:resume the operator reconciliation for this cluster'
  'list-pause-reconciliation-instances:list paused-reconciliation instances'
  'manage:open the RabbitMQ management UI in a browser'
  'perf-test:run perf-test against the cluster'
  'stream-perf-test:run stream-perf-test against the cluster'
  'version:show the plugin version'
)

_arguments -C \
  '(-n --namespace)'{-n,--namespace}'=[kubernetes namespace]:namespace:' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[list resources across all namespaces]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'kubectl-rabbitmq subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      create)
        _arguments \
          '1:cluster name:' \
          '--replicas=[number of replicas]:N:' \
          '--image=[RabbitMQ container image]:image:' \
          '*--image-pull-secret=[image pull secret (repeatable)]:secret:' \
          '--service=[Service type]:type:(ClusterIP LoadBalancer NodePort)' \
          '*--service-annotation=[service annotation key=value (repeatable)]:annotation:' \
          '--storage-class=[storage class name]:class:' \
          '--storage-size=[storage size (default 10Gi)]:size:' \
          '--unlimited[set unlimited resources (empty requests and limits)]' \
          '--memory-limit=[memory limit (e.g. 2Gi)]:size:' \
          '--memory-request=[memory request (e.g. 2Gi)]:size:' \
          '--cpu-limit=[CPU limit (e.g. 2000m)]:cpu:' \
          '--cpu-request=[CPU request (e.g. 1000m)]:cpu:' \
          '--tls-secret=[TLS secret name]:secret:' \
          '--tls-ca-secret=[TLS CA secret name]:secret:' \
          '--disable-non-tls-listeners[disable non-TLS listeners]' \
          '*--plugin=[additional plugin to enable (repeatable)]:plugin:' \
          '*--env-conf=[environment configuration key=value (repeatable)]:kv:' \
          '--additional-config-file=[path to additional config file]:file:_files' \
          '--advanced-config-file=[path to advanced config file]:file:_files' \
          '--termination-grace-period=[termination grace period in seconds]:N:' \
          '--delay-start=[delay start in seconds]:N:' \
          '--skip-post-deploy-steps[skip post deploy steps]' \
          '--auto-enable-all-feature-flags[automatically enable all feature flags]' \
          && ret=0
        ;;
      delete)
        _arguments '*:cluster name:' && ret=0
        ;;
      get|debug|tail|secrets|enable-all-feature-flags|pause-reconciliation|resume-reconciliation|manage)
        _arguments '1:cluster name:' && ret=0
        ;;
      observe)
        _arguments \
          '1:cluster name:' \
          '2:node:' && ret=0
        ;;
      perf-test|stream-perf-test)
        _arguments \
          '1:cluster name:' \
          '*::perf-test arg:' && ret=0
        ;;
      install-cluster-operator)
        _arguments \
          '--version=[operator version to install]:version:' && ret=0
        ;;
    esac
    ;;
esac

return ret
