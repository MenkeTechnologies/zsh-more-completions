#compdef graph
# Documentation: https://www.npmjs.com/package/@graphprotocol/graph-cli
# Reference accessed: 2026-05-23
# Verified: npx graph --help.

# Zsh completion for graph - The Graph subgraph CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add a new datasource to a subgraph'
  'auth:set deploy key for Graph node'
  'autocomplete:display autocomplete install instructions'
  'build:build subgraph and optionally upload to IPFS'
  'clean:clean cache and generated files'
  'codegen:generate AssemblyScript types'
  'create:register a subgraph name'
  'deploy:deploy subgraph to a Graph node'
  'init:create a new subgraph with scaffolding'
  'local:run local tests against Graph Node'
  'node:manage Graph node operations'
  'publish:publish to the Graph Network'
  'remove:unregister a subgraph name'
  'test:run subgraph tests'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'graph command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
