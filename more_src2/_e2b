#compdef e2b
# Documentation: https://e2b.dev/docs/cli
# Reference accessed: 2026-05-17
# Verified: e2b.dev CLI docs (e2b-dev/E2B sandbox CLI).
# Removed from prior file: bogus man.archlinux.org search URL;
# generic _default arg handler missing all subcommands.

# e2b: E2B sandbox CLI
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'auth:authentication subcommands'
  'create:create a new sandbox'
  'connect:connect to a sandbox'
  'list:list sandboxes'
  'shutdown:shut down a sandbox'
  'exec:execute a command in a sandbox'
  'template:template subcommands (build/list/init)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'e2b command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (template) _values 'template subcommand' 'build' 'list' 'init' && ret=0 ;;
      (auth) _values 'auth subcommand' 'login' 'logout' 'info' && ret=0 ;;
    esac
    ;;
esac
return ret
