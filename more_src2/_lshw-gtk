#compdef lshw-gtk
# Documentation: https://www.unix.com/man-page/debian/1/LSHW-GTK/
# Reference accessed: 2026-05-19
# Verified: Debian lshw-gtk(1) manpage. STUB — the upstream manpage
# does not document any lshw-gtk CLI flags beyond standard GTK
# argument passthrough; the program is a GTK frontend driven by the
# GUI Refresh button rather than CLI options.

# lshw-gtk: GTK frontend to lshw hardware lister
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '*::gtk-args:_files' && ret=0
return ret
