#compdef etcd-druid druid
# _etcd-druid — Gardener etcd-druid operator for etcd clusters on Kubernetes
# upstream: https://github.com/gardener/etcd-druid
# Flags from cmd/opts/options.go on tip.

_etcd-druid() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[etcd-druid configuration file]:file:_files -g "*.(yaml|yml)"' \
        '--version[show version and exit]' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_etcd-druid "$@"
