#compdef idevicebtlogger
# _idevicebtlogger — capture Bluetooth HCI logs from an iOS device (libimobiledevice/libimobiledevice)
# upstream: https://github.com/libimobiledevice/libimobiledevice
# Flags from tools/idevicebtlogger.c.

_idevicebtlogger() {
    local -a args
    args=(
        '(-u --udid)'{-u+,--udid=}'[target the specific device by UDID]:udid:'
        '(-n --network)'{-n,--network}'[connect to a network-attached device]'
        '(-f --format)'{-f+,--format=}'[output capture format]:format:(packetlogger pcap)'
        '(-x --exit)'{-x,--exit}'[exit when the device disconnects]'
        '(-d --debug)'{-d,--debug}'[enable communication debugging]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '1:output file (default stdout):_files'
    )
    _arguments -s -S $args
}

_idevicebtlogger "$@"
