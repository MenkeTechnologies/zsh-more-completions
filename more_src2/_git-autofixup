#compdef git-autofixup
# Documentation: https://github.com/torbiak/git-autofixup
# Reference accessed: 2026-05-16
# Verified: upstream torbiak/git-autofixup README OPTIONS section.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h/--hierarchical-search (real -h is short for --help);
# fabricated --target ref option (does not exist); missing -c/--context
# and -g/--gitopt flags.

# git-autofixup: create fixup commits from staged changes
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show usage]' \
  '--help[show manpage]' \
  '--version[show version]' \
  '*'{-v,--verbose}'[increase verbosity (up to 2x)]' \
  '(-c --context)'{-c+,--context=}'[diff context lines (default 3)]:n:' \
  '(-s --strict)'{-s+,--strict=}'[strictness level (default 0)]:level:(0 1 2)' \
  '(-g --gitopt)'{-g+,--gitopt=}'[pass option to git (repeatable)]:opt:' \
  '(-e --exit-code)'{-e,--exit-code}'[use detailed exit codes]' \
  '1:upstream revision:__git_references' \
  '*:path:_files' && ret=0

(( $+functions[__git_references] )) || __git_references() {
  _alternative \
    'branches:branch:compadd $(git branch --format="%(refname:short)" 2>/dev/null)' \
    'tags:tag:compadd $(git tag -l 2>/dev/null)' \
    'commits:recent commit:compadd $(git log --oneline -20 --format="%h" 2>/dev/null)'
}

return ret
