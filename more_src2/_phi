#compdef phi
# Documentation: https://github.com/agno-agi/phidata
# Reference accessed: 2026-05-22
# Verified: phi/cli/entrypoint.py and phi/cli/ws/ws_cli.py Typer commands.

# Zsh completion for phi - Phidata workspace and agent toolkit CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[print debug logs]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'phi command' \
      'init[initialize phidata]' \
      'reset[reset phidata installation]' \
      'auth[authenticate with phidata.com]' \
      'login[log in from the CLI]' \
      'ping[ping phidata servers]' \
      'config[print phi config]' \
      'set[set current directory as active workspace]' \
      'start[start resources from resources.py]' \
      'stop[stop resources from resources.py]' \
      'update[update resources from resources.py]' \
      'restart[restart resources from resources.py]' \
      'ws[workspace commands]' && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '(-r --reset)'{-r,--reset}'[reset phidata]' \
          '(-l --login)'{-l,--login}'[login with phidata.com]' && ret=0
        ;;
      ws)
        _values 'ws command' \
          'create[create a new workspace]' \
          'setup[setup workspace from directory]' \
          'up[start workspace resources]' \
          'down[stop workspace resources]' \
          'patch[update workspace resources]' \
          'restart[restart workspace resources]' \
          'config[print active workspace config]' \
          'delete[delete workspace record]' && ret=0
        ;;
      auth|login|ping|config|set|start|stop|update|restart|reset)
        ret=0
        ;;
    esac
    ;;
esac

return ret
