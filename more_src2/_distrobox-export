#compdef distrobox-export
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/distrobox-export.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Flags taken from docs/usage/distrobox-export.md.
# Note: --service is not a documented flag; --sudo is short -S (not -s).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --app)'{-a,--app}'[application to export]:application' \
  '(-b --bin)'{-b,--bin}'[binary to export]:binary:_files' \
  '(-d --delete)'{-d,--delete}'[delete exported entry]' \
  '(-el --export-label)'{-el,--export-label}'[label for exported app]:label' \
  '(-ep --export-path)'{-ep,--export-path}'[export destination path]:directory:_directories' \
  '(-ef --extra-flags)'{-ef,--extra-flags}'[extra flags for exported app]:flags' \
  '(-nf --enter-flags)'{-nf,--enter-flags}'[distrobox-enter flags]:flags' \
  '(-S --sudo)'{-S,--sudo}'[export with sudo prefix]' \
  '--list-apps[list exported applications]' \
  '--list-binaries[list exported binaries]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0

return ret
