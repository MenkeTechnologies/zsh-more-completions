# Zsh completion for jsonpp pretty-printer (jmhodges/jsonpp)

local ret=1

_arguments -s -S \
  '-s[parse already-formatted JSON, treating each input stream as a single JSON object]' \
  '-help[show usage]' \
  '*:json file:_files' && ret=0

return ret
