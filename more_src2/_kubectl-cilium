#compdef kubectl-cilium
# Documentation: https://github.com/bmcustodio/kubectl-cilium
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (internal/cmd source).

# kubectl-cilium (bmcustodio/kubectl-cilium): one subcommand `exec`.
# Persistent flags are the standard genericclioptions ConfigFlags set.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[print version]' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '1:command:(exec)' \
  '*::arg:_default' && ret=0

return ret
