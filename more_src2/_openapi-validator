#compdef openapi-validator ibm-openapi-validator lint-openapi
# _openapi-validator — IBM OpenAPI Validator linter CLI (IBM, Node.js); yargs
# upstream: https://github.com/IBM/openapi-validator

_openapi-validator() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g ".openapi-validator-config*"' \
        '-c+[config file]:file:_files -g ".openapi-validator-config*"' \
        '--no-config[ignore config]' \
        '-n[ignore config]' \
        '--ruleset=+[ruleset file]:file:_files' \
        '-r+[ruleset file]:file:_files' \
        '--errors-only[errors only]' \
        '-e[errors only]' \
        '--summary-only[summary only]' \
        '-s[summary only]' \
        '--no-summary[no summary]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--warnings-limit=+[warnings limit]:n:' \
        '-w+[warnings limit]:n:' \
        '--impact-score[show impact score]' \
        '-i[show impact score]' \
        '--json[json output]' \
        '-j[json output]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--print-validator-modules[print validator modules]' \
        '-p[print validator modules]' \
        '*:spec:_files -g "*.yaml *.yml *.json"'
}

_openapi-validator "$@"
