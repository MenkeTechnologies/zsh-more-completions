#compdef gpu-burn gpu_burn
# _gpu-burn — Ville Timonen gpu-burn CUDA matrix-multiply stress test for stability and thermals (wilicc team, C++); custom argparse
# upstream: https://github.com/wilicc/gpu-burn

_gpu-burn() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-d[use double precision]' \
        '--double[use double precision]' \
        '-t[run tensor cores benchmark]' \
        '--tensor[run tensor cores benchmark]' \
        '-tc[run tensor cores benchmark]' \
        '-i+[gpu index csv]:str:' \
        '--gpus=+[gpu index csv]:str:' \
        '-m+[matrix size]:str:' \
        '--matrix-size=+[matrix size]:str:' \
        '-c+[compare CRC]:str:' \
        '--compare=+[compare CRC]:str:' \
        '-l[list available GPUs and exit]' \
        '--list[list available GPUs and exit]' \
        '-r[no result CRC checks]' \
        '--no-checks[no result CRC checks]' \
        '*:seconds:'
}

_gpu-burn "$@"
