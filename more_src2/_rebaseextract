#compdef rebaseextract
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/rebaseextract.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS rebaseextract: process REBASE flat files for EMBOSS restriction enzyme apps
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-infile=[REBASE database withrefm file]:file:_files' \
  '-protofile=[REBASE database proto file]:file:_files' \
  '-equivalences[create embossre.equ equivalence file]' \
  '-noequivalences[skip embossre.equ generation]' \
  '*:REBASE file:_files' && ret=0
return ret
