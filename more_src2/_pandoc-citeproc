#compdef pandoc-citeproc
# Documentation: https://github.com/jgm/pandoc-citeproc
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above. pandoc-citeproc is now archived
# in favor of pandoc --citeproc but the legacy CLI is still shipped.

_arguments -s \
  '(-y --bib2yaml)'{-y,--bib2yaml}'[convert bibliography to YAML]' \
  '(-j --bib2json)'{-j,--bib2json}'[convert bibliography to CSL JSON]' \
  '(-f --format)'{-f,--format}'=[input format]:format:(biblatex bibtex ris endnote endnotexml isi medline copac mods nbib json)' \
  '(-c --columns)'{-c,--columns}'=[wrap column]:n:' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--man[print groff man page]' \
  '--license[print license]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:bibliography:_files'
