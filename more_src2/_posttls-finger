#compdef posttls-finger
# _posttls-finger — Postfix TLS probe (unsupported test tool that connects to a remote SMTP/LMTP server, performs STARTTLS, and reports TLS protocol/cipher/certificate details; supports DANE)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/posttls-finger.1 on tip.

_posttls-finger() {
    _arguments \
        '-S[connect over LMTP (unix:pathname for unix sockets)]' \
        '-a+[address family]:family:(any inet inet6)' \
        '-A[no auth]' \
        '-c+[config directory]:dir:_files -/' \
        '-C+[client cert + key (cert,key)]:certkey:' \
        '-d+[MD5/SHA digest algorithm for hex fingerprints]:alg:(none md5 sha1 sha256 sha512)' \
        '-F+[CA bundle file (smtp_tls_CAfile)]:file:_files' \
        '-g+[grade list]:grades:' \
        '-h+[helo/EHLO name to send]:host:_hosts' \
        '-k+[client key file]:file:_files' \
        '-l+[TLS security level]:level:(none may encrypt fingerprint verify secure dane dane-only)' \
        '-L+[logging mask]:mask:(routine summary cache verbose)' \
        '-m+[client cert/key chain mode (openssl|nss)]:mode:' \
        '-M+[match SMTPUTF8 (yes/no)]:mode:(yes no)' \
        '-o+[SMTP timeout (sec)]:sec:' \
        '-p+[SSL/TLS protocol list]:proto:' \
        '-P+[CA directory]:dir:_files -/' \
        '-r+[port (default 25 SMTP / 24 LMTP)]:port:' \
        '-s+[Server Name Indication]:sni:' \
        '-t+[connect timeout (sec)]:sec:' \
        '-T+[session reuse timeout (sec)]:sec:' \
        '*-v[verbose logging (repeat for more)]' \
        '-w[STARTTLS via wrappermode]' \
        '-X+[match Postfix SMTP per-site policy]:setting:' \
        '1:destination:_hosts' \
        '*:match:'
}

_posttls-finger "$@"
