#compdef marimo-cli
# Documentation: https://github.com/marimo-team/marimo
# Reference accessed: 2026-05-27
# Verified: upstream marimo/_cli/cli.py @main.command decorators and the
# main.add_command(...) calls (export, config, development, pair, convert).
# Note: the installed binary is `marimo` (covered by the sibling _marimo
# file). This file targets the alternate `marimo-cli` name reserved in the
# parent project's plan.
# Deviations from spec: dropped `recover`-only listing and added the real
# subcommand set including `check`, `env`, `shell_completion`, `pair`,
# `development`.

local curcontext="$curcontext" state line ret=1

local -a _marimo_subcommands
_marimo_subcommands=(
  'edit:start the marimo editor for a notebook'
  'new:create a new marimo notebook'
  'run:run a marimo notebook as a read-only app'
  'recover:recover unsaved cell changes from a JSON recovery file'
  'tutorial:open a built-in marimo tutorial notebook'
  'env:print marimo environment and system info'
  'shell-completion:emit a shell completion script'
  'check:lint and format marimo files'
  'export:export a marimo notebook (html, html-wasm, ipynb, md, script, pdf)'
  'config:read or modify marimo configuration'
  'convert:convert a Jupyter notebook or script to marimo'
  'pair:pair marimo with a Jupyter kernel'
  'development:internal marimo development commands'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-V,--version}'[show marimo version]' \
  '(- *)'{-y,--yes}'[automatically answer yes to prompts]' \
  '(- *)'{-d,--development-mode}'[enable development mode]' \
  '(- *)'{-q,--quiet}'[suppress non-essential output]' \
  '(- *)--log-level=[set log level]:level:(DEBUG INFO WARN WARNING ERROR CRITICAL)' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'marimo-cli subcommand' _marimo_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      edit|run)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port to run server on]:port:' \
          '--host=[host to run server on]:host:' \
          '--headless[do not open a browser window]' \
          '--no-token[disable auth token]' \
          '--token-password=[password to use for auth token]:password:' \
          '--proxy=[proxy address]:url:' \
          '--base-url=[base URL for the server]:url:' \
          '--allow-origins=[comma separated list of allowed CORS origins]:origins:' \
          '--watch[reload notebook on disk changes]' \
          '--sandbox[run notebook in a uv-managed sandbox]' \
          '--no-sandbox[disable sandbox auto-detection]' \
          '*:notebook:_files -g "*.py"' && ret=0
        ;;
      new)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port to run server on]:port:' \
          '--host=[host to run server on]:host:' \
          '--headless[do not open a browser window]' \
          '--sandbox[create notebook inside a uv-managed sandbox]' \
          '*:notebook:_files -g "*.py"' && ret=0
        ;;
      tutorial)
        _arguments \
          '*:tutorial:(intro dataflow ui markdown plots layout fileformat for-jupyter-users)' && ret=0
        ;;
      export)
        local -a _marimo_export
        _marimo_export=(
          'html:export a notebook to a static HTML file'
          'html-wasm:export to HTML running marimo via Pyodide'
          'ipynb:export to a Jupyter ipynb file'
          'md:export to markdown'
          'script:export to a runnable Python script'
        )
        _describe -t commands 'marimo export format' _marimo_export && ret=0
        ;;
      config)
        local -a _marimo_config
        _marimo_config=(
          'show:print the current configuration'
          'describe:show all configuration options'
        )
        _describe -t commands 'marimo config subcommand' _marimo_config && ret=0
        ;;
      convert)
        _arguments \
          '(-o --output)'{-o+,--output=}'[output marimo file]:file:_files' \
          '*:input notebook:_files -g "*.{ipynb,py}"' && ret=0
        ;;
      check)
        _arguments \
          '--fix[apply autofixable lint suggestions]' \
          '--unsafe-fixes[apply unsafe autofixes]' \
          '*:notebook:_files -g "*.py"' && ret=0
        ;;
      pair)
        local -a _marimo_pair
        _marimo_pair=(
          'jupyter:pair a marimo notebook with a Jupyter kernel'
        )
        _describe -t commands 'marimo pair subcommand' _marimo_pair && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
