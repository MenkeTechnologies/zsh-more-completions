#compdef fulla
# Documentation: https://wiki.panotools.org/Fulla
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Hugin fulla: lens defect correction (radial distortion, TCA, vignetting)
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-g+[radial distortion params (db|a:b:c:d)]:params:' \
  '-b+[blue channel TCA params (db|a:b:c:d)]:params:' \
  '-r+[red channel TCA params (db|a:b:c:d)]:params:' \
  '-m+[camera maker]:maker:' \
  '-n+[camera model]:model:' \
  '-l+[lens name]:lens:' \
  '-d+[focal length (mm)]:mm:' \
  '-a+[aperture value]:aperture:' \
  '-s[do not rescale image to avoid black borders]' \
  '-f+[flatfield image for vignetting correction]:file:_files' \
  '-c+[vignetting correction params (db|a:b:c:d)]:params:' \
  '--linear[apply vignetting correction in linear color space]' \
  '-i+[input data gamma]:gamma:' \
  '-o+[output filename or suffix]:file:_files' \
  '-e+[compression for output files]:compression:' \
  '-x+[horizontal/vertical shift (X:Y)]:offset:' \
  '-v[verbose output]' \
  '*:image:_files' && ret=0

return ret
