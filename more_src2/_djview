#compdef djview djview4
# Documentation: https://man.archlinux.org/man/djview.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Completion for djview - DjVu document viewer

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[show help]' \
  '-verbose[print informational messages to console]' \
  '(-fullscreen -fs)'{-fullscreen,-fs}'[start in full screen mode]' \
  '-slideshow=[start in slide show mode]::seconds' \
  '-style=[GUI style]:style:(cde motif plastique)' \
  '-display=[X display]:display:_x_display' \
  '-geometry=[window geometry WxH+X+Y]:geometry' \
  '-name=[application name]:name' \
  '-title=[window title]:title' \
  '-fn=[default font]:font' \
  '-font=[default font]:font' \
  '-bg=[background color]:color' \
  '-background=[background color]:color' \
  '-fg=[foreground color]:color' \
  '-foreground=[foreground color]:color' \
  '-page=[display specific page]:page name' \
  '-pageno=[display page by ordinal]:page number' \
  '-zoom=[zoom factor]:zoom:(one2one width page stretch 50 75 100 150 200 300)' \
  '-showposition=[center px,py in window]:px,py' \
  '-mode=[display mode]:mode:(color bw fore back text)' \
  '-hor_align=[horizontal alignment]:align:(left center right)' \
  '-ver_align=[vertical alignment]:align:(top center bottom)' \
  '-cache=[enable page caching]:on:(yes no)' \
  '-continuous=[continuous layout]:on:(yes no)' \
  '-sidebyside=[side-by-side layout]:on:(yes no)' \
  '-coverpage=[show cover page alone]:on:(yes no)' \
  '-righttoleft=[arrange pages right-to-left]:on:(yes no)' \
  '-layout=[layout keywords (comma-separated)]:keywords' \
  '-scrollbars=[show scroll bars]:on:(yes no)' \
  '-frame=[show frame around images]:on:(yes no)' \
  '-toolbar=[toolbar appearance]:keywords' \
  '-menubar=[show menu bar]:on:(yes no)' \
  '-statusbar=[show status bar]:on:(yes no)' \
  '-sidebar=[dockable panels]:keywords' \
  '-thumbnails=[sidebar alias]:keywords' \
  '-outline=[sidebar alias]:keywords' \
  '-menu=[enable pop-up menu]:on:(yes no)' \
  '-keyboard=[enable keyboard shortcuts]:on:(yes no)' \
  '-mouse=[enable mouse interaction]:on:(yes no)' \
  '-links=[enable hyperlinks]:on:(yes no)' \
  '-highlight=[highlight rectangle x,y,w,h[,color]]:rect' \
  '-find=[highlight text occurrences]:text' \
  '-rotate=[rotate image]:degrees:(0 90 180 270)' \
  '-print=[enable printing]:on:(yes no)' \
  '-save=[enable saving]:on:(yes no)' \
  '-passive[fit-page passive viewer]' \
  '-passivestretch[stretch-fit passive viewer]' \
  '1:file:_files -g "*.{djvu,djv}"' && ret=0

return ret
