#compdef openhands
# Documentation: https://docs.openhands.dev/openhands/usage/cli/command-reference
# Reference accessed: 2026-05-20
# Verified: OpenHands CLI command reference - subcommands serve, web, cloud,
# acp, mcp (add/list/get/remove/enable/disable), login, logout.

local curcontext="$curcontext" state line ret=1

_openhands_commands() {
  local -a commands=(
    'acp:start the ACP server for IDE integration'
    'cloud:run tasks on OpenHands Cloud'
    'login:authenticate with OpenHands Cloud'
    'logout:sign out from OpenHands Cloud'
    'mcp:manage MCP servers'
    'serve:start the GUI server'
    'web:start the browser-based interface'
  )
  _describe -t commands 'openhands command' commands
}

_openhands_mcp_commands() {
  local -a commands=(
    'add:add an MCP server'
    'list:list configured MCP servers'
    'get:show an MCP server configuration'
    'remove:remove an MCP server'
    'enable:enable an MCP server'
    'disable:disable an MCP server'
  )
  _describe -t commands 'mcp command' commands
}

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--headless[run without the interactive terminal UI]' \
  '(-t --task)'{-t,--task}'[task to run]:task' \
  '(-f --file)'{-f,--file}'[read instructions from file]:file:_files' \
  '--json[emit JSON output in headless mode]' \
  '--resume[resume a conversation]' \
  '--last[resume the most recent conversation]' \
  '--always-approve[auto-approve all actions]' \
  '--llm-approve[use the LLM-based security analyzer for approvals]' \
  '--override-with-envs[apply environment variables to override stored settings]' \
  '--exp[use textual-based UI]' \
  '--exit-without-confirmation[exit without showing confirmation dialog]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _openhands_commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (cloud)
        _arguments -s -S \
          '(-t --task)'{-t,--task}'[task to run on OpenHands Cloud]:task' \
          '(-f --file)'{-f,--file}'[read instructions from file]:file:_files' \
          '--json[emit JSON output]' \
          '--resume[resume a cloud conversation]' \
          '--last[resume the most recent cloud conversation]' \
          '*:prompt' && ret=0
        ;;
      (mcp)
        _arguments -C -s -S \
          '1:mcp command:->mcp_command' \
          '*::arg:->mcp_args' && ret=0
        case $state in
          (mcp_command)
            _openhands_mcp_commands && ret=0
            ;;
          (mcp_args)
            case ${line[2]} in
              (add)
                _arguments -s -S \
                  '1:server name:' \
                  '--transport[transport type]:transport:(stdio sse http)' \
                  '*:command:_command_names -e' && ret=0
                ;;
              (enable|disable|get|remove)
                _arguments '1:server name:' && ret=0
                ;;
              (list)
                _arguments && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      (acp|login|logout)
        _arguments && ret=0
        ;;
      (serve|web)
        _arguments -s -S \
          '(-p --port)'{-p,--port}'[port to listen on]:port' \
          '(-H --host)'{-H,--host}'[host to bind]:host' && ret=0
        ;;
      (*)
        _arguments '*:prompt' && ret=0
        ;;
    esac
    ;;
esac

return ret
