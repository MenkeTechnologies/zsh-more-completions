# ============================================================================

_fut() {
    _arguments -s \
        '(- *)--help[display help information]' \
        '(- *)--version[display version information]' \
        '*-l+[translate to target language]:target:(c cpp cs d java js py swift ts d.ts cl)' \
        '-o+[write output to specified file (multi-target ext list ok: out.c,cpp,cs,…)]:file:_files' \
        '-n+[C++/C# namespace, Java package, or C name prefix]:name:' \
        '*-D+[define a conditional compilation symbol]:symbol:' \
        '*-r+[read the specified source file but do not emit code]:fusion source:_files -g "*.fu"' \
        '*-I+[add directory to resource search path]:dir:_files -/' \
        '*:Fusion source file:_files -g "*.fu"'
}

_fut "$@"
