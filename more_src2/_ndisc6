# Documentation: https://manpages.debian.org/testing/ndisc6/ndisc6.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-1 --single)'{-1,--single}'[exit on first reply]' \
  '(-m --multiple)'{-m,--multiple}'[wait for all replies]' \
  '(-n --numeric)'{-n,--numeric}'[no DNS resolution]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-r --retry)'{-r,--retry}'=[retry count]:n:' \
  '(-s --source)'{-s,--source}'=[source IPv6]:addr:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-w --wait)'{-w,--wait}'=[wait ms]:ms:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]'
