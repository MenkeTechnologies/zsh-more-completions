#compdef esl-alimanip
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-alimanip.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-alimanip: manipulate multiple alignments (subset/edit columns)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-o[output file]:file:_files' \
  '--informat=[input alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip phylips selex)' \
  '--outformat=[output alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip phylips)' \
  '--devhelp[show developer help]' \
  '--lnfract=[remove sequences below fraction of median length]:x' \
  '--lxfract=[remove sequences above fraction of median length]:x' \
  '--lmin=[remove sequences shorter than N residues]:n' \
  '--lmax=[remove sequences longer than N residues]:n' \
  '--rfnfract=[remove sequences below fraction of nongap RF length]:x' \
  '--detrunc=[remove sequences with all gaps in first/last N RF columns]:n' \
  '--xambig=[remove sequences with more than N ambiguous residues]:n' \
  '--seq-r=[remove sequences named in file]:file:_files' \
  '--seq-k=[keep only sequences named in file]:file:_files' \
  '--small[low-memory mode]' \
  '--k-reorder[reorder kept sequences to match list file]' \
  '--seq-ins=[keep sequences with >=1 insert after nongap RF position N]:n' \
  '--seq-ni=[require at least N inserted residues]:n' \
  '--seq-xi=[allow at most N inserted residues]:n' \
  '--trim=[trim sequences to match unaligned FASTA file]:file:_files' \
  '--t-keeprf[preserve RF annotation with --trim]' \
  '--minpp=[replace residues below posterior probability with gaps]:x' \
  '--tree=[reorder by single-linkage tree, output Newick to file]:file:_files' \
  '--reorder=[reorder sequences by name list file]:file:_files' \
  '--mask2rf=[define new RF from mask file]:file:_files' \
  '--m-keeprf[preserve nongap RF chars with --mask2rf]' \
  '--num-all[annotate numbering of all columns]' \
  '--num-rf[annotate numbering of nongap RF columns]' \
  '--rm-gc=[remove given #=GC annotation]:type:(RF SS_cons SA_cons PP_cons)' \
  '--sindi[annotate individual SS from consensus]' \
  '--post2pp[convert cmalign POST annotation to PP]' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '*:alignment file:_files' && ret=0
return ret
