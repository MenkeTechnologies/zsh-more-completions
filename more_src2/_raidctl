#compdef raidctl
# Documentation: man raidctl(8)
# Source: netbsd/src sbin/raidctl — RAIDframe disk driver configuration (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[set auto-configuration]:mode:(yes no forceroot softroot)' \
    '-a+[add component as hot spare]:component:_files' \
    '-C+[force RAID configuration from file]:config file:_files' \
    '-c+[configure RAID from file]:config file:_files' \
    '-F+[fail component and reconstruct]:component:_files' \
    '-f+[mark component as failed]:component:_files' \
    '-G[generate configuration in output format]' \
    '-g+[display component label]:component:_files' \
    '-I+[initialize component labels]:serial number:_default' \
    '-i[initialize/rewrite parity]' \
    '-L[rescan for auto-configurable RAID sets]' \
    '-M+[set parity map]:mode:(yes no set)' \
    '-m[display parity map status]' \
    '-P[check and rebuild parity if needed]' \
    '-p[check parity status]' \
    '-R+[fail and reconstruct onto component]:component:_files' \
    '-r+[remove component from RAID]:component:_files' \
    '-S[check reconstruction/parity progress]' \
    '-s[display RAID device status]' \
    '-t+[test/parse configuration file]:config file:_files' \
    '-U+[set last_unit for autoconfiguration]:unit:_default' \
    '-u[unconfigure RAID device]' \
    '-v[verbose output with progress]' \
    '1::raid device:_default' \
    && ret=0

return ret
