#compdef DenoiseImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/DenoiseImage.cxx — patch-based non-local denoiser (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-i --input-image)'{-i+,--input-image=}'[input image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-n --noise-model)'{-n+,--noise-model=}'[noise model]:model:(Gaussian Rician)' \
    '(-x --mask-image)'{-x+,--mask-image=}'[mask image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-s --shrink-factor)'{-s+,--shrink-factor=}'[shrink factor (default 1)]:n:_default' \
    '(-p --patch-radius)'{-p+,--patch-radius=}'[patch radius (default 1x1x1)]:radius:_default' \
    '(-r --search-radius)'{-r+,--search-radius=}'[search radius (default 2x2x2)]:radius:_default' \
    '(-o --output)'{-o+,--output=}'[output image]:file:_files' \
    '(- *)'{-v,--version}'[print version]' \
    '--verbose=[verbosity level]:n:(0 1 2)' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
