#compdef grenchmark
# ============================================================================
# _grenchmark — zsh completion for Granule's synthesis-feature benchmark tool
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/granule-project/granule
#   Authors    : Dominic Orchard, Vilem-Benjamin Liepelt, Harley Eades III,
#                Jack Hughes, Preston Keel, Danielle Marshall, Michael Vollmer
#   License    : BSD-3-Clause
#   Stars      : 717
#   Language   : Haskell (compiler) / Granule (.gr source files)
#   Cabal      : granule v0.9.7.0  (executable grenchmark in granule.cabal)
#   Binary     : grenchmark  (from benchmark/src/Main.hs)
#   Last push  : 2026-04-20
#
# WHAT IT IS
#   Granule is "a research language based on graded modal types" — Dominic
#   Orchard et al.'s statically-typed, linear functional programming language
#   from University of Kent / Augusta University, designed to express
#   fine-grained program reasoning via graded modal types (effects, coeffects,
#   liveness, multiplicity, etc.).  Granule's `.gr` programs are checked
#   and run by `gr` (the interpreter, already in this corpus) and compiled
#   by `grc`;  this completion targets `grenchmark`, the quantitative-
#   evaluation benchmark runner that drives the `--synthesis` feature of
#   the type-driven program synthesizer.  It runs each `.gr` benchmark file
#   under three synthesis modes (`Graded`, `Cartesian`, `Cartesian (No
#   Retries)`), captures SMT-solver call counts, synthesis time, prover
#   time, solver time, mean theorem size, program / context size, examples
#   used, and success / timeout flags, then renders the results as a
#   LaTeX-formatted comparison table for the Granule synthesis papers.
#
# CLI ARGUMENT GRAMMAR  (verbatim from benchmark/src/Main.hs processArgs)
#   grenchmark [OPTIONS]
#
#   Options  (single-dash short / double-dash long pairs, custom arg parser):
#     -c, --categories <CAT>...   Benchmark categories to run (repeatable
#                                 positional list after the flag, stops at
#                                 the next `-`/`--` token)
#     -f, --files <FILE>...       Specific .gr benchmark files to run
#                                 (repeatable positional list)
#     -p, --per-mode              Files-per-mode reporting layout (one
#                                 LaTeX row per file × mode rather than
#                                 the default per-mode-summary)
#     -n, --repeats <N>           Number of repeat trials per benchmark
#                                                       [default: 10]
#
#   Notes (from benchmark/src/Main.hs):
#     - `fileArgs` collects bare positional values until it sees a token
#       starting with `-` or `--`, so flags can be interleaved freely.
#     - Three synthesis modes are hard-coded in the `modes` table:
#         Graded                     (no extra flags)
#         Cartesian                  (--cart-synth 1)
#         Cartesian (No Retries)     (--cart-synth 2)
#     - Each run produces a Measurement record with smtCalls, synthTime,
#       proverTime, solverTime, meanTheoremSize, success, timeout,
#       pathsExplored, programSize, contextSize, examplesUsed, cartesian,
#       cartAttempts fields, then aggregates across `--repeats` trials.
#
# LANGUAGE-CORPUS POSITION
#   Granule is the 141st programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R833 (_tempcol/
#   tokio-modbus Rust=116 opens Axis 61) and continued through R834
#   (_modbus_exporter/goburrow/modbus Go=116) and R835 (_jsmodbus/jsmodbus
#   TS-Node=116 CLOSES Axis 61 Modbus Industrial Fieldbus Library at 1/1/1
#   + triple-116 landmark + 54 axes at 1/1/1).  Granule joins the roster
#   of exotic languages already in the corpus including Sixten (R832
#   140th — round-number language milestone), Imba (R828 139th), Tao
#   (R824 138th), Dada (R820 137th), Acton (R816 136th), Stanza (R812
#   135th), Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth,
#   Lawvere/bill, Cognac/Cognate, and Scrapscript.
#
#   No completion for `grenchmark` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_grenchmark() {
    _arguments -s \
        '*'{-c+,--categories=}'[benchmark categories to run (repeatable)]:category:' \
        '*'{-f+,--files=}'[specific .gr benchmark files to run]:file:_files -g "*.gr"' \
        '(-p --per-mode)'{-p,--per-mode}'[files-per-mode reporting layout]' \
        '(-n --repeats)'{-n+,--repeats=}'[number of repeat trials per benchmark (default 10)]:N:' \
        '(- *)'{-h,--help}'[show help]' \
        '*:.gr benchmark file:_files -g "*.gr"'
}

_grenchmark "$@"
