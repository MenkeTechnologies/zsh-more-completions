#compdef lightmapviewer
# Documentation: lightmapviewer --help (Qt baked lightmap viewer, shipped with Qt tools)
# Reference accessed: 2026-05-19
# Verified: local `lightmapviewer --help` output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--print[print the content of the lightmap]' \
  '--extract[extract lightmap contents to current dir]' \
  '*:input lightmap file:_files' && ret=0

return ret
