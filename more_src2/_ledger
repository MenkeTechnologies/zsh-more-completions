#compdef ledger
# Documentation: https://ledger-cli.org/doc/ledger.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# completions for ledger double-entry accounting CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --file)'{-f+,--file=}'[read journal from file]:journal file:_files' \
  '(-o --output)'{-o+,--output=}'[write output to file]:output file:_files' \
  '(-i --init-file)'{-i+,--init-file=}'[read init file]:init file:_files' \
  '--account=[prepend account expression]:account:' \
  '(-b --begin)'{-b+,--begin=}'[start date]:date:' \
  '(-e --end)'{-e+,--end=}'[end date]:date:' \
  '(-p --period)'{-p+,--period=}'[report period]:period:' \
  '(-c --current)'{-c,--current}'[show transactions on or before today]' \
  '(-C --cleared)'{-C,--cleared}'[show only cleared transactions]' \
  '(-U --uncleared)'{-U,--uncleared}'[show only uncleared transactions]' \
  '--pending[show only pending transactions]' \
  '(-R --real)'{-R,--real}'[show only real transactions]' \
  '--budget[show budget report]' \
  '--add-budget[add budgeted transactions]' \
  '--unbudgeted[show only unbudgeted transactions]' \
  '--forecast-while=[forecast while expression true]:expression:' \
  '(-l --limit)'{-l+,--limit=}'[limit which postings are used]:expression:' \
  '(-t --amount)'{-t+,--amount=}'[set amount expression]:expression:' \
  '(-T --total)'{-T+,--total=}'[set total expression]:expression:' \
  '(-d --display)'{-d+,--display=}'[limit which postings are displayed]:expression:' \
  '(-j --amount-data)'{-j,--amount-data}'[print only dates and amounts]' \
  '(-J --total-data)'{-J,--total-data}'[print only dates and totals]' \
  '(-S --sort)'{-S+,--sort=}'[sort by expression]:expression:' \
  '--sort-xacts=[sort postings within transactions]:expression:' \
  '(-w --wide)'{-w,--wide}'[assume 132-column terminal]' \
  '--head=[show first N entries]:count:' \
  '--tail=[show last N entries]:count:' \
  '--pager=[pager command]:pager:' \
  '--no-pager[do not use pager]' \
  '--color[use color output]' \
  '--no-color[disable color output]' \
  '--force-color[force color output]' \
  '--force-pager[force pager usage]' \
  '(-E --empty)'{-E,--empty}'[include empty accounts]' \
  '(-n --collapse)'{-n,--collapse}'[collapse top-level accounts]' \
  '(-V --market)'{-V,--market}'[show market value]' \
  '(-X --exchange)'{-X+,--exchange=}'[display values in commodity]:commodity:' \
  '--flat[do not indent accounts]' \
  '--depth=[limit account depth]:depth:' \
  '--group-by=[group postings by expression]:expression:' \
  '--group-title-format=[format for group titles]:format:' \
  '(-y --date-format)'{-y+,--date-format=}'[format for dates]:date format:' \
  '--input-date-format=[format for input dates]:date format:' \
  '--strict[warn on undeclared accounts/tags/commodities]' \
  '--pedantic[error on undeclared accounts/tags/commodities]' \
  '--permissive[quiet balance assertions]' \
  '--price-db=[price database file]:file:_files' \
  '--master-account=[prepend master account name]:account:' \
  '--day-break[break entries spanning midnight]' \
  '--no-revalued[hide revalued postings]' \
  '--immediate[evaluate calculations immediately]' \
  '1:command:(balance bal register reg print accounts payees commodities tags xml csv emacs equity budget cleared select)' \
  '*:query:' && ret=0

return ret
