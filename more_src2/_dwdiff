#compdef dwdiff
# Documentation: https://os.ghalkes.nl/dwdiff.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dwdiff (word-level diff program)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-1 --no-deleted)'{-1,--no-deleted}'[suppress words deleted from first file]' \
  '(-2 --no-inserted)'{-2,--no-inserted}'[suppress words inserted in second file]' \
  '(-3 --no-common)'{-3,--no-common}'[suppress words common to both files]' \
  '--aggregate-changes[treat close changes as a single change]' \
  '(-A --algorithm)'{-A+,--algorithm=}'[diff algorithm]:algo:(best normal fast)' \
  '(-c --color)'{-c,--color=-}'[use color output]::spec:' \
  '(-C --context)'{-C+,--context=}'[show context lines]:number of lines:' \
  '(-d --delimiters)'{-d+,--delimiters=}'[specify delimiter characters]:chars:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --ignore-case)'{-i,--ignore-case}'[ignore case differences]' \
  '(-I --ignore-formatting)'{-I,--ignore-formatting}'[ignore character formatting]' \
  '(-l --less-mode)'{-l,--less-mode}'[overstrike formatting for less]' \
  '(-L --line-numbers)'{-L,--line-numbers=-}'[show line numbers]::width:' \
  '(-m --match-context)'{-m+,--match-context=}'[words used for matching context]:n:' \
  '(-p --printer)'{-p,--printer}'[underscore and bold overstriking]' \
  '(-P --punctuation)'{-P,--punctuation}'[treat punctuation as delimiters]' \
  '(-R --repeat-markers)'{-R,--repeat-markers}'[repeat markers at line boundaries]' \
  '(-s --statistics)'{-s,--statistics}'[show statistics at end]' \
  '(-S --paragraph-separator)'{-S,--paragraph-separator=-}'[mark whitespace-only blocks]::marker:' \
  '(-u --diff-input)'{-u,--diff-input}'[read unified diff input]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-w --start-delete)'{-w+,--start-delete=}'[start-of-deletion marker]:string:' \
  '(-W --white-space)'{-W+,--white-space=}'[whitespace characters]:chars:' \
  '(-x --stop-delete)'{-x+,--stop-delete=}'[end-of-deletion marker]:string:' \
  '(-y --start-insert)'{-y+,--start-insert=}'[start-of-insertion marker]:string:' \
  '(-z --stop-insert)'{-z+,--stop-insert=}'[end-of-insertion marker]:string:' \
  '--wdiff-output[produce wdiff-compatible output]' \
  '--profile=[load named profile from .dwdiffrc]:name:' \
  '--no-profile[disable profile loading]' \
  '1:first file:_files' \
  '2:second file:_files' && ret=0

return ret
