#compdef prove6-j prove6-js
# Documentation: https://docs.raku.org/programs/prove6
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-v[verbose]' \
  '-q[quiet]' \
  '-r[recursive]' \
  '-e+[interpreter]:interpreter:_command_names -e' \
  '-l[lib mode]' \
  '*:test file or directory:_files' && ret=0

return ret
