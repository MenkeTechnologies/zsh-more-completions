#compdef denon
# ============================================================================
#  _denon ‚Äî denon: Deno-native file-watcher / autoreloader (nodemon for Deno)
#
#  Source-direct extraction from
#    https://github.com/denosaurs/denon/blob/main/denon.ts
#    https://github.com/denosaurs/denon/blob/main/src/args.ts
#    https://github.com/denosaurs/denon/blob/main/src/cli.ts
#    https://jsr.io/@std/cli (Deno std/cli library documentation)
#
#  Maintained by Denosaurs (denosaurs/denon).  1109 GH stars.  denon
#  is the Deno equivalent of Node.js's nodemon ‚Äî watches files for
#  changes and automatically restarts your Deno script on save.
#  Supports config files (denon.json/yaml/ts), multiple scripts per
#  project, daemon-mode, custom watcher rules, and granular permission
#  grants.  Sister tools: nodemon (Node.js, IN CORPUS via _nodemon),
#  watchexec (in corpus, language-agnostic file watcher), entr (in
#  corpus, file watcher), pm2 (Node.js process manager, IN CORPUS).
#
#  CLI library taxonomy update: 1st Deno entry ‚Äî Deno's stdlib
#  **@std/cli/parse-args** module (jsr:@std/cli).  Deno is a
#  FIRST-TIME addition to the cross-language CLI library taxonomy
#  (separate ecosystem from R340/R341/R343 Node.js CLI libs).
#
#  Deno @std/cli/parse-args is the Deno standard library's argument
#  parsing module ‚Äî distributed via JSR as `jsr:@std/cli/parse-args`
#  (formerly via `deno.land/std`).  Deno (Ryan Dahl's modern TypeScript
#  runtime alternative to Node.js) has a fundamentally different
#  CLI ecosystem from Node.js ‚Äî Deno tools import std modules via
#  URL/JSR-based imports, distribute as single TypeScript files, and
#  install globally via `deno install -g jsr:@scope/name`.  Used by
#  Deno itself (`denoland/deno` tools/release/npm/build.ts), Fresh
#  (Deno's flagship web framework, denoland/fresh init.ts), pkgxdev/
#  dev (pkgx development environment manager by Max Howell / Homebrew
#  creator), Floorp browser dev tooling, react-native-asset, mender
#  server frontend, MyakuMyakuJS, climpt, traceability-ids, vapi-utils,
#  individual-sandbox, Open-MBEE flexo-graphql, AAO-announce-workspace,
#  b1naryth1ef/pkg, dinghy-dev engine, hyperledger-iroha-javascript,
#  PAIR-code/tiny-transformers, asozialesnetzwerk, eser/stack,
#  pnsk-lab, ryuapp/pindeps, and many Deno-native tools.  denon
#  (1109 stars) is the most-installed Deno tool and follows Deno-
#  native CLI conventions (Deno.args, Deno.exit, JSR imports,
#  permission grants) using its own thin wrapper around the std/cli
#  patterns documented here.
#
#  Deno @std/cli/parse-args API:
#    import { parseArgs } from "jsr:@std/cli/parse-args";
#    // or via deno.land/std (legacy):
#    // import { parseArgs } from "https://deno.land/std/cli/parse_args.ts";
#
#    const flags = parseArgs(Deno.args, {
#      // Boolean flags (no value)
#      boolean: ["help", "version", "verbose", "force"],
#
#      // String flags (take one value)
#      string: ["output", "config", "input"],
#
#      // Default values
#      default: {
#        config: "./denon.json",
#        verbose: false,
#      },
#
#      // Short-to-long name aliases
#      alias: {
#        h: "help",
#        v: "version",
#        o: "output",
#        c: "config",
#        i: "input",
#      },
#
#      // Repeatable flags (collect into array)
#      collect: ["include", "exclude"],
#
#      // Negatable flags (--no-FLAG form)
#      negatable: ["color", "cache"],
#
#      // Stop parsing at first non-option arg
#      stopEarly: false,
#
#      // Unknown flag handler
#      unknown: (arg, key, value) => {
#        console.error(`Unknown option: ${arg}`);
#        return false;
#      },
#    });
#
#    // flags.help, flags.version, etc.
#    // flags._ ‚Äî positional args (Deno convention: underscore)
#    // flags["--"] ‚Äî args after `--` (when stopEarly behavior)
#
#  Deno @std/cli/parse-args distinctive features:
#    - JSR-DISTRIBUTED ‚Äî `import { parseArgs } from "jsr:@std/cli/parse-args"`
#      via JSR (JavaScript Registry, jsr.io) ‚Äî Deno's official package
#      registry; LEGACY `deno.land/std` URL imports still supported
#    - SCHEMA-DRIVEN ‚Äî single options object describes all flag
#      semantics: `boolean: string[]` / `string: string[]` / `default:
#      object` / `alias: object` / `collect: string[]` / `negatable:
#      string[]` / `stopEarly: boolean` / `unknown: callback`
#    - `boolean: ["flag1", "flag2"]` ‚Äî flags that take NO value
#      (boolean toggle)
#    - `string: ["opt1", "opt2"]` ‚Äî flags that REQUIRE a value
#    - `default: { opt: "value" }` ‚Äî default values keyed by flag name
#    - `alias: { h: "help", v: "version" }` ‚Äî short-to-long name
#      mapping (single-char short names)
#    - `collect: ["include"]` ‚Äî flags that COLLECT multiple values into
#      array (repeatable; e.g. `--include a --include b` ‚Üí ["a","b"])
#    - `negatable: ["color"]` ‚Äî flags that allow `--no-NAME` form to
#      set FALSE (Deno-distinct feature; Node.js commander doesn't
#      have this)
#    - `stopEarly: true` ‚Äî stop parsing at FIRST non-option (pass
#      remaining as positionals)
#    - `unknown: callback` ‚Äî handler for unknown flags; return false
#      to abort, true to continue (e.g. for forward-compat)
#    - `--` SEPARATOR support ‚Äî args after `--` are accessible via
#      `flags["--"]` (when stopEarly behavior)
#    - POSITIONAL via `flags._` ‚Äî underscore-prefixed key holds
#      positional arguments as `Array<string|number>` (Deno
#      convention)
#    - TYPE COERCION ‚Äî values to `string` flags are kept as string;
#      values to `boolean` flags become boolean; numeric-looking
#      positional args become `number` type automatically
#    - TYPESCRIPT TYPE-SAFETY ‚Äî `parseArgs<T>` generic accepts type
#      param for inferring result type from options object
#    - NO process exit on errors ‚Äî caller decides via `Deno.exit(N)`
#    - NO automatic --help generation ‚Äî caller writes help manually
#      (denon implements its own `printHelp()` function)
#    - WORKS in browser/runtime-agnostic via Deno KV runtime
#  Distinct from R340 TypeScript-Node oclif (Salesforce's CLI
#  framework with `--flag=value` builder pattern + plugin system),
#  R341 TypeScript-Node yargs (Node.js fluent builder via `.option()`/
#  `.command()` chains), R343 TypeScript-Node tj/commander.js (Node.js
#  fluent builder by TJ Holowaychuk ‚Äî closest concept analog but
#  Node.js ecosystem with different package distribution), R277 click
#  (Python decorator-driven), R275 Rust clap-derive (Rust struct +
#  macros), R357 Go mitchellh/cli (Go Cmd interface).  Deno @std/cli's
#  approach: JSR-DISTRIBUTED Deno STDLIB MODULE + SCHEMA-DRIVEN single
#  options object + `boolean`/`string`/`default`/`alias`/`collect`/
#  `negatable`/`stopEarly`/`unknown` SCHEMA KEYS + UNDERSCORE-PREFIXED
#  POSITIONAL `flags._` + `flags["--"]` for after-`--` args +
#  TYPESCRIPT TYPE-SAFETY via generic + NO process exit + NO automatic
#  --help (caller writes) ‚Äî corpus's **first documented JSR-distributed-
#  schema-driven-Deno-stdlib CLI library**.  Brings cross-language
#  CLI library taxonomy variant count to 128; Deno added to the
#  documented-CLI-language set (separate ecosystem from Node.js).
#
#  Surface (verbatim from `src/args.ts` `parseArgs` function):
#
#  Options:
#    -h, --help                     Show help and quit
#    -v, --version                  Show version and quit
#    -c, --config FILE              Path to config file
#                                   (default: ./denon.json)
#    -i, --init [TYPE]              Initialize config file (TYPE:
#                                   json | yaml | ts; default: json)
#    -u, --upgrade [VERSION]        Upgrade denon to VERSION
#                                   (default: latest; accepts vX.Y.Z
#                                   semver format)
#
#  Positional:
#    CMD [ARGS...]                  Script command + args to run and
#                                   watch (e.g. `denon run --allow-net
#                                   server.ts`)
#
#  Example usage:
#    denon --version                Show denon version
#    denon --init yaml              Create denon.yaml template
#    denon --upgrade latest         Upgrade to latest denon
#    denon --upgrade v2.5.0         Pin to specific version
#    denon -c custom.json start     Run with custom config
#    denon run server.ts            Watch server.ts and restart
#                                   on changes (passes `run server.ts`
#                                   to deno)
#    denon start                    Run "start" script from config
#
#  Config file (denon.json/yaml/ts):
#    {
#      "scripts": {
#        "start": {
#          "cmd": "deno run --allow-net app.ts",
#          "desc": "Run server"
#        }
#      },
#      "watcher": {
#        "interval": 350,
#        "exts": ["js", "ts"],
#        "match": ["**/*.*"],
#        "skip": ["**/.git/**"]
#      }
#    }
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also Deno @std/cli users):
#    - fresh (IN CORPUS via _fresh ‚Äî Deno's flagship web framework;
#      uses Deno @std/cli in its init.ts but Fresh itself is a server
#      runtime not a flag-rich CLI)
#    - pkgx / dev (pkgxdev/dev 49 stars ‚Äî pkgx development manager
#      by Max Howell; uses @std/cli directly with rich `parseArgs`
#      schema; FUTURE candidate with binary name `dev` that's too
#      generic to safely add)
#    - oxide console (oxidecomputer/console 222 stars ‚Äî Oxide Web
#      Console; uses @std/cli in dev tools but main console is a
#      web app not CLI binary)
#    - kview (kitsonk/kview 100 stars ‚Äî Deno KV web app; uses
#      @std/cli in upgrade.ts utility script)
#    - mcpc (mcpc-tech/mcpc 97 stars ‚Äî MCP server composer;
#      minimal CLI surface)
#    - Floorp dev tools (Firefox fork, internal use only)
#    - denoland/deno tools (release/npm/build.ts uses @std/cli
#      but they're internal deno-team release scripts)
# ============================================================================

_denon() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and quit]' \
    '(-v --version)'{-v,--version}'[show version and quit]' \
    '(-c --config)'{-c,--config}'=[config file path (default: ./denon.json)]:file:_files -g "*.(json|yaml|yml|ts)"' \
    '(-i --init)'{-i,--init}'=-[initialize config file]::format:(json yaml ts)' \
    '(-u --upgrade)'{-u,--upgrade}'=-[upgrade denon to VERSION]::version' \
    '*::deno command and args:_files'
}

_denon "$@"
