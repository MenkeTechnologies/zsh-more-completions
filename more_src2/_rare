#compdef rare
# Documentation: https://github.com/zix99/rare
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'filter:output extracted keys (grep-like)'
      'histo:build histogram from matched data'
      'bargraph:build bar graph from matched data'
      'table:count keys in two dimensions'
      'heatmap:display color-coded cell strength'
      'sparkline:draw rows of sparkline visualizations'
      'analyze:compute statistics (mean/median/percentiles)'
      'reduce:evaluate data using expressions with grouping/sorting'
      'docs:access embedded documentation'
      'help:show help for a command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    local -a common_args=(
      '-m+[regex match expression]:expression:'
      '-d+[use dissect tokenizer]:expression:'
      '-e+[manipulate results with handlebars-like expressions]:expression:'
      '-i+[ignore lines matching an expression]:expression:'
      '-R[enable recursion]'
      '-z[optional gzip decompression]'
      '-f[follow files]'
      '-F[re-open following files]'
      '--poll[poll for changes]'
      '--tail[tail files]'
      '--csv[CSV formatting]'
      '--profile=[enable profiling for benchmarking]:file:_files'
      '-n+[limit number of matches]:count:'
      '*:file:_files'
    )
    case ${words[1]} in
      (filter|histo|bargraph|table|heatmap|sparkline|analyze|reduce)
        _arguments $common_args && ret=0
        ;;
    esac
    ;;
esac

return ret
