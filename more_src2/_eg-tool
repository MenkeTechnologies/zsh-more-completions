#compdef eg
# _eg-tool — Go x/tools example-based refactoring (Alan Donovan); template-driven AST refactor
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/eg

_eg-tool() {
    _arguments \
        '-t+[template package or file]:file:_files' \
        '-w[overwrite files in place]' \
        '-transitive[apply transitively]' \
        '-v[verbose]' \
        '-tags+[build tags]:tags:' \
        '*:packages:'
}

_eg-tool "$@"
