#compdef pkg-info pkg_info
# _pkg-info — OpenBSD/FreeBSD pkg_info package info CLI alias (BSD project, C); custom argparse
# upstream: https://github.com/openbsd/src/tree/master/usr.sbin/pkg_info

_pkg-info() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[show all]' \
        '-A[all packages]' \
        '-c[short comment]' \
        '-C[long comment]' \
        '-d[long description]' \
        '-D[short description]' \
        '-e+[search]:str:' \
        '-E[search exact]' \
        '-f[file list]' \
        '-g[show signature]' \
        '-I[index]' \
        '-K[keep extracted]' \
        '-l+[prefix]:str:' \
        '-L[show files]' \
        '-m[show maintainer]' \
        '-M[show message]' \
        '-N[only names]' \
        '-P[show prereq]' \
        '-Q+[query]:str:' \
        '-r[print repo info]' \
        '-R[reverse deps]' \
        '-s[show size]' \
        '-S[show url]' \
        '-t+[topdir]:dir:_files -/' \
        '-u[unique]' \
        '-U[print update info]' \
        '-v[verbose]' \
        '-vv[more verbose]' \
        '-w[wantlib info]' \
        '-W+[which]:str:' \
        '-x[allow regex]' \
        '-X[exclusively local]' \
        '-z[interactive]' \
        '*:package:'
}

_pkg-info "$@"
