#compdef kit-clj
# _kit-clj — Yogthos Kit Clojure framework CLI alias (kit-clj team, Clojure); custom argparse
# upstream: https://github.com/kit-clj/kit

_kit-clj() {
    local -a sub=(
        'new:create new kit project'
        'help:show help'
        'list:list templates'
        'modules:list:list available modules'
        'modules:sync:sync modules from kit-modules repo'
        'modules:install:install module'
        'modules:remove:remove module'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kit subcommand' sub ;;
        args)
            case $words[1] in
                new) _arguments \
                    '1:template:(kit-clj io.github.kit-clj/kit-undertow io.github.kit-clj/kit-jetty io.github.kit-clj/kit-postgres io.github.kit-clj/kit-sqlite io.github.kit-clj/kit-xtdb io.github.kit-clj/kit-redis io.github.kit-clj/kit-nrepl)' \
                    '2:project name:' \
                    '--main-ns=+[main ns]:str:' \
                    '--target-dir=+[target dir]:dir:_files -/' \
                    '--features=+[features csv]:str:' ;;
                modules:install|modules:remove) _arguments '*:module:' ;;
            esac
            ;;
    esac
}

_kit-clj "$@"
