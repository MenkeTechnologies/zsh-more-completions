#compdef nemiver
# Documentation: https://www.mankier.com/1/nemiver
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nemiver - GNOME graphical debugger frontend for GDB.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help options]' \
  '(- *)'{-v,--version}'[show program version]' \
  '--env=[set environment variables]:vars:' \
  '--attach=[attach to a process by PID or name]:process:_pids' \
  '--listsessions[list saved debugging sessions]' \
  '--purgesessions[erase saved debugging sessions]' \
  '--executesession=[debug program from session number N]:N:' \
  '--log-domains=[enable logging domains]:domains:' \
  '--logdebuggeroutput[log debugger output]' \
  '*:program:_files' && ret=0

return ret
