#compdef furl
# _furl — Matrix federation URL request tool (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/furl/main.go.

_furl() {
    _arguments \
        '-from=[originating server name]:name:' \
        '-key=[private key file for signing]:file:_files -g "*.{pem,key}"' \
        '-post[send POST request instead of GET]' \
        '1:matrix federation URL:'
}

_furl "$@"
