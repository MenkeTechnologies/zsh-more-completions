#compdef mfsdirinfo
# Documentation: https://moosefs.com/manpages/mfsdirinfo
# Reference accessed: 2026-05-19
# Verified: upstream MooseFS man page at the URL above.
# mfsdirinfo: extended MooseFS-specific `du -s` for files/directories.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-?[display short usage message]' \
  '(-h -H -k -m -g)-n[print exact numbers]' \
  '(-n -H -k -m -g)-h[use binary prefixes (Ki, Mi, Gi)]' \
  '(-n -h -k -m -g)-H[use SI prefixes (k, M, G)]' \
  '(-n -h -H -m -g)-k[print sizes in kibis]' \
  '(-n -h -H -k -g)-m[print sizes in mebis]' \
  '(-n -h -H -k -m)-g[print sizes in gibis]' \
  '-i[display inodes count]' \
  '-d[display directories count]' \
  '-f[display files count]' \
  '-c[display chunks count]' \
  '-l[display total file length]' \
  '-s[display total chunks size]' \
  '-r[display real size (estimated disk usage)]' \
  '-p[slow precise recursive mode]' \
  '*:object:_files' && ret=0
return ret
