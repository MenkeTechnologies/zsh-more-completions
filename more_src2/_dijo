#compdef dijo
# Documentation: https://github.com/NerdyPepper/dijo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# NerdyPepper/dijo — scriptable terminal habit tracker.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --command)'{-c,--command}'=[run non-interactive command]:cmd' \
  '(-l --list)'{-l,--list}'[list tracked habits]'
