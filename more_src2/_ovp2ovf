#compdef ovp2ovf
# Documentation: ovp2ovf --help (TeX Live 2026 Omega)
# Source: translate Omega Virtual Property List into OVF virtual font + companion OFM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '-omit-ofm[do not output OFMFILE]' \
    '1:ovp input:_files -g "*.ovp"' \
    '2:ovf output:_files -g "*.ovf"' \
    '3:ofm output:_files -g "*.ofm"' \
    && ret=0

return ret
