#compdef git-pages
# Documentation: https://github.com/kensho/git-pages
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Self-hosted GitHub static pages server (kensho/git-pages)

_arguments -s -S \
  '--repo[git repository URL to pull and serve]:repo url:' \
  '--page[file to serve]:page:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::arguments:_default'
