#compdef lit-cli
# _lit-cli — Google Lit web-components dev toolkit CLI alias (Google, TypeScript); command-line-args
# upstream: https://github.com/lit/lit

_lit-cli() {
    local -a sub=(
        'init:scaffold project'
        'localize:run localize subcommand'
        'labs:experimental commands'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lit subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '1:template:(element starter-kit ts-element starter-kit-ts vanilla-ts)' \
                    '--name=+[name]:str:' \
                    '--dir=+[output dir]:dir:_files -/' ;;
                localize) _arguments \
                    '1:cmd:(build extract)' \
                    '--config=+[config file]:file:_files -g "lit-localize.json"' ;;
                labs) _arguments \
                    '1:cmd:(gen)' \
                    '--package=+[package]:list:' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_lit-cli "$@"
