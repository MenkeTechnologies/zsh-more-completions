#compdef pamhomography
# Documentation: man pamhomography (Netpbm)
# Source: apply a perspective (homography) transformation to a PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-from=[source quad coordinates]:coords:' \
    '-to=[destination quad coordinates]:coords:' \
    '-mapfile=[map file]:file:_files' \
    '-view=[output view coordinates]:coords:' \
    '-fill=[fill color for exposed area]:color:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
