if [ -L "${BASH_SOURCE[0]}" ]; then
    # Symlinked (Homebrew) - resolve to actual script location
    SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
else
    # Direct execution
    SCRIPT_PATH="${BASH_SOURCE[0]}"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
if [ -d "$SCRIPT_DIR/lib" ]; then
    LIB_DIR="$SCRIPT_DIR/lib"
elif [ -d "$SCRIPT_DIR/../lib" ]; then
    LIB_DIR="$SCRIPT_DIR/../lib"
elif [ -L "$SCRIPT_DIR/core.sh" ]; then
    # Homebrew installation - libraries are symlinked in bin directory
    LIB_DIR="$SCRIPT_DIR/../libexec"
elif [ -f "$SCRIPT_DIR/core.sh" ]; then
    # Libraries in same directory as script
    LIB_DIR="$SCRIPT_DIR"
elif [ -f "./lib/core.sh" ]; then
    # Libraries in lib subdirectory of current directory
    LIB_DIR="./lib"
elif [ -f "./core.sh" ]; then
    # Libraries in current directory
    LIB_DIR="."
else
    echo "Error: Could not find dcutil library files" >&2
    echo "Searched locations:" >&2
    echo "  - $SCRIPT_DIR/lib" >&2
    echo "  - $SCRIPT_DIR/../lib" >&2
    echo "  - $SCRIPT_DIR/../libexec" >&2
    echo "  - $SCRIPT_DIR" >&2
    echo "  - ./lib" >&2
    echo "  - ." >&2
    exit 1
fi

# Verify core.sh exists before sourcing
