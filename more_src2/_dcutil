    echo "Error: core.sh not found at $LIB_DIR/core.sh" >&2
    echo "LIB_DIR resolved to: $LIB_DIR" >&2
    echo "SCRIPT_DIR is: $SCRIPT_DIR" >&2
    echo "Contents of LIB_DIR:" >&2
    ls -la "$LIB_DIR" 2>&1 || echo "  (directory does not exist)" >&2
    exit 1
fi

