# Parse --quiet/-q flags from the entire argument list early so quiet mode is respected
DCUTIL_QUIET="${DCUTIL_QUIET:-0}"
filtered_args=()
while [ $# -gt 0 ]; do
    case "$1" in
        --quiet|-q)
            DCUTIL_QUIET=1
            export DCUTIL_QUIET
            shift
            ;;
        --)
            shift
            filtered_args+=("--")
            while [ $# -gt 0 ]; do
                filtered_args+=("$1")
                shift
            done
            ;;
        *)
            filtered_args+=("$1")
            shift
            ;;
    esac
done
set -- "${filtered_args[@]:-}"

