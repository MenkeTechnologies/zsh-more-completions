                continue
            else
                error_exit "Configuration is invalid for devcontainer CLI (non-interactive)" "$EXIT_CONFIG_ERROR"
            fi
        fi

        # Persist valid changes back to the original file (create backup)
        cp "$cfg" "$cfg.backup" 2>/dev/null || true
        if ! cp "$tmpfile" "$cfg"; then
            error_exit "Failed to write changes back to $cfg" "$EXIT_CONFIG_ERROR"
