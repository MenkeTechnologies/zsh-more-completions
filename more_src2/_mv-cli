#compdef mv-cli
# _mv-cli — GNU coreutils mv move/rename files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_mv-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--backup[backup]' \
        '--backup=+[control]:c:(none off numbered t existing nil simple never)' \
        '-b[backup]' \
        '-f[force]' \
        '--force[force]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-n[no clobber]' \
        '--no-clobber[no clobber]' \
        '--strip-trailing-slashes[strip trailing slashes from source]' \
        '-S+[suffix]:str:' \
        '--suffix=+[suffix]:str:' \
        '-t+[target dir]:dir:_files -/' \
        '--target-directory=+[target dir]:dir:_files -/' \
        '-T[treat dest as normal file]' \
        '--no-target-directory[treat dest as normal file]' \
        '-u[update]' \
        '--update[update]' \
        '--update=+[mode]:m:(none all older none-fail)' \
        '--no-copy[no copy if rename fails]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-Z[set SELinux context to default]' \
        '--context=+[ctx]:str:' \
        '--debug[debug]' \
        '--exchange[atomically exchange source and dest]' \
        '*:source dest:_files'
}

_mv-cli "$@"
