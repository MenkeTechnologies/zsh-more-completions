#compdef dhall-bash
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-bash
# Source: dhall-lang/dhall-haskell dhall-bash/exec/Main.hs — compile Dhall to Bash.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--explain[explain error messages in detail]' \
    '--declare=[declare the given variable as a statement instead of an expression]:name:_default' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
