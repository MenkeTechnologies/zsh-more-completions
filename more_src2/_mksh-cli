#compdef mksh-cli mksh2
# _mksh-cli — Thorsten Glaser MirBSD mksh-cli CLI command-line frontend wrapping the MirBSD Korn Shell mksh open-source successor of pdksh focused on POSIX correctness portability low memory footprint and small size written in C originally pdksh now MirBSD Project Thorsten Glaser mksh derived from public-domain ksh used as default shell in Android AOSP since 2.2 OpenWrt embedded systems busybox-replacement statically-linked-portable busybox-replacement OpenBSD distribution lowmem POSIX-conformant ARC-architecture-cross-platform-compile -c -i -l -r -s -T -X -V option set posix sh emacs vi (Thorsten Glaser MirBSD pdksh team, C); custom argparse
# upstream: http://www.mirbsd.org/mksh.htm

_mksh-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[command]:str:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '-s[stdin command]' \
        '-r[restricted shell]' \
        '-T+[arg]:str:' \
        '-X[allow exec]' \
        '-A+[arr=( )]:str:' \
        '-a[allexport]' \
        '-b[notify]' \
        '-C[noclobber]' \
        '-D[disable parameter expansion]' \
        '-e[errexit]' \
        '-f[noglob]' \
        '-h[hash]' \
        '-k[keyword]' \
        '-m[monitor]' \
        '-n[noexec]' \
        '-p[privileged]' \
        '-t[onecmd]' \
        '-u[nounset]' \
        '-v[verbose]' \
        '-x[xtrace]' \
        '-o+[option]:o:(allexport bgnice braceexpand emacs errexit gmacs ignoreeof inherit-errexit interactive keyword login markdirs monitor noclobber noexec noglob nohup nolog notify nounset physical pipefail posix posix-aliases posix-builtins privileged restricted-shell stdin-shell trackall utf8-mode verbose vi vi-esccomplete vi-show8 vi-tabcomplete xtrace)' \
        '+o+[option]:o:(allexport bgnice braceexpand emacs errexit gmacs ignoreeof inherit-errexit interactive keyword login markdirs monitor noclobber noexec noglob nohup nolog notify nounset physical pipefail posix posix-aliases posix-builtins privileged restricted-shell stdin-shell trackall utf8-mode verbose vi vi-esccomplete vi-show8 vi-tabcomplete xtrace)' \
        '*:mksh script:_files -g "*.ksh *.sh *.mksh"'
}

_mksh-cli "$@"
