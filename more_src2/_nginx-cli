#compdef nginx-cli
# _nginx-cli — Igor Sysoev NGINX HTTP/reverse-proxy/load-balancer server CLI alias (nginx team, C); custom argparse
# upstream: https://github.com/nginx/nginx

_nginx-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-V[show version with config]' \
        '-t[test config]' \
        '-T[test config and dump it]' \
        '-q[suppress non-error messages]' \
        '-s+[signal]:s:(stop quit reload reopen)' \
        '-p+[prefix path]:dir:_files -/' \
        '-e+[error log file]:file:_files' \
        '-c+[config file]:file:_files -g "nginx.conf"' \
        '-g+[directives]:str:' \
        '*:arg:'
}

_nginx-cli "$@"
