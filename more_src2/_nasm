#compdef nasm
# Documentation: nasm -h
# Source: NASM — Netwide Assembler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-v[print NASM version and exit]' \
    '(- *)--v[print NASM version and exit]' \
    '-@+[response file]:file:_files' \
    '(- *)-h[list options]' \
    '(- *)--help[list options]' \
    '-o+[output file]:file:_files' \
    '--keep-all[do not delete output on error]' \
    '-X-[error reporting format]:format:' \
    '-s[redirect messages to stdout]' \
    '-Z+[redirect messages to file]:file:_files' \
    '--info=[informational messages level]:level:' \
    '--debug=[NASM internal debug level]:level:' \
    '*-M-[make-dependency option]:option:' \
    '-f+[output format]:format:(bin obj coff elf elf32 elf64 elfx32 win32 win64 macho macho32 macho64 aout aoutb a.out as86 ieee rdf dbg)' \
    '-g[generate debug info]' \
    '-F+[debug format]:format:' \
    '-l+[listing file]:file:_files' \
    '*-L-[list-file info flags]:flag:' \
    '*-O-[optimization flags]:flags:' \
    '-t[SciTech TASM compatible mode]' \
    '(-E -e -a)-E[preprocess only to stdout]' \
    '(-E -e -a)-e[preprocess only (alias)]' \
    '(-E -e -a)-a[do not preprocess]' \
    '*-I-[add include path]:dir:_files -/' \
    '*-P+[pre-include file]:file:_files' \
    '*--include=[pre-include file]:file:_files' \
    '*-D-[pre-define macro]:NAME[=VALUE]:' \
    '*-U-[undefine macro]:name:' \
    '*-w+-[enable warning class]:warning:' \
    '*-W-[GCC-style warning option]:option:' \
    '*--pragma=[pre-execute pragma]:pragma:' \
    '*--before=[insert line before input]:text:' \
    '--bits=[set BITS]:n:(16 32 64)' \
    '--no-line[ignore %line directives]' \
    '--gprefix=[prepend prefix to extern/common/global names]:string:' \
    '--prefix=[alias for --gprefix]:string:' \
    '--gpostfix=[append postfix to extern/common/global names]:string:' \
    '--postfix=[alias for --gpostfix]:string:' \
    '--lprefix=[prepend prefix to local symbols]:string:' \
    '--lpostfix=[append postfix to local symbols]:string:' \
    '--reproducible[run-to-run identical output]' \
    '*--limit-=[set execution limit]:limit-X val:' \
    '*:source file:_files -g "*.{asm,s,S}"' \
    && ret=0

return ret
