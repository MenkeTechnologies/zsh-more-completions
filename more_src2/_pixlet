#compdef pixlet
# Documentation: https://github.com/tidbyt/pixlet
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Tidbyt pixlet — render/push apps.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'render:render a Starlark script to WebP/GIF'
  'serve:run pixlet as a local dev server'
  'push:push a rendered WebP to a Tidbyt device'
  'encrypt:encrypt sensitive values'
  'login:authenticate with Tidbyt'
  'logout:remove cached Tidbyt credentials'
  'devices:list devices available to your account'
  'profile:profile a Starlark script'
  'check:check whether an app is ready to publish'
  'create:create a new pixlet app from template'
  'community:community submission helpers'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'pixlet' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
