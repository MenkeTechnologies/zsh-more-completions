_goldwarden() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'vault:manage the vault (unlock/lock/purge/status/login)'
        'logins:commands for managing logins (get/list)'
        'pin:manage the vault PIN (set/status)'
        'ssh:commands for managing SSH keys (add/list/import)'
        'send:commands for managing Bitwarden Sends (create)'
        'run:run a command with vault-resolved environment variables'
        'config:manage configuration (set-api-url/set-identity-url/set-notifications-url)'
        'session:start a new session'
        'pinentry:register as a GPG pinentry program'
        'authenticate-session:authenticate an existing session'
        'daemonize:start the agent as a daemon'
        'autotype:autotype credentials into the focused window'
        'setup_linux:install systemd user service + browser biometric manifests'
        'version:show goldwarden version'
        'help:help about any command'
    )

    local -a vault_subs
    vault_subs=(
        'unlock:unlock the vault'
        'lock:lock the vault'
        'purge:wipe the vault (force re-sync from server)'
        'status:show vault status'
        'login:start the login process for Bitwarden'
    )

    local -a logins_subs
    logins_subs=(
        'get:get a login (prints credentials)'
        'list:list all logins in your vault'
    )

    local -a pin_subs
    pin_subs=(
        'set:set a new PIN'
        'status:check if a PIN is set'
    )

    local -a ssh_subs
    ssh_subs=(
        'add:create a new SSH key and add it to the SSH Agent'
        'list:list all SSH keys in your vault'
        'import:import an SSH key into your vault'
    )

    local -a send_subs
    send_subs=(
        'create:upload a Bitwarden send'
    )

    local -a config_subs
    config_subs=(
        'set-api-url:set the Bitwarden API URL (for self-hosted Vaultwarden)'
        'set-identity-url:set the identity URL'
        'set-notifications-url:set the notifications URL'
    )

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-): :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        cmd)
            _describe -t commands 'goldwarden subcommand' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                vault)
                    _arguments -C \
                        '(-): :->vsub' \
                        '*::varg:->varg' && ret=0
                    case $state in
                        vsub)
                            _describe -t commands 'vault subcommand' vault_subs && ret=0
                            ;;
                        varg)
                            case $line[1] in
                                login)
                                    _arguments \
                                        '--email=[email address]:email:' \
                                        '--passwordless[use passwordless login (FIDO/SSO)]' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                logins)
                    _describe -t commands 'logins subcommand' logins_subs && ret=0
                    ;;
                pin)
                    _describe -t commands 'pin subcommand' pin_subs && ret=0
                    ;;
                ssh)
                    _arguments -C \
                        '(-): :->ssub' \
                        '*::sarg:->sarg' && ret=0
                    case $state in
                        ssub)
                            _describe -t commands 'ssh subcommand' ssh_subs && ret=0
                            ;;
                        sarg)
                            case $line[1] in
                                add)
                                    _arguments \
                                        '--name=[SSH key friendly name]:name:' \
                                        '--clipboard[copy public key to clipboard]' && ret=0
                                    ;;
                                import)
                                    _arguments '--name=[SSH key friendly name]:name:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                send)
                    _arguments -C \
                        '(-): :->sndsub' \
                        '*::sndarg:->sndarg' && ret=0
                    case $state in
                        sndsub)
                            _describe -t commands 'send subcommand' send_subs && ret=0
                            ;;
                        sndarg)
                            case $line[1] in
                                create)
                                    _arguments \
                                        '(-n --name)'{-n+,--name=}'[name of the send]:name:' \
                                        '(-t --text)'{-t+,--text=}'[text of the send]:text:' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                config)
                    _describe -t commands 'config subcommand' config_subs && ret=0
                    ;;
                run)
                    _arguments '*::command and args:_command_names -e' && ret=0
                    ;;
                version|autotype|setup_linux|daemonize|pinentry|authenticate-session|session|help)
                    ret=0
                    ;;
            esac
            ;;
    esac
    return ret
}

_goldwarden "$@"
