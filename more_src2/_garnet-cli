#compdef garnet-cli garnet GarnetServer
# Documentation: https://microsoft.github.io/garnet/docs/getting-started/configuration
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Microsoft Garnet: Redis-compatible cache server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--port=[port to run server on]:port:' \
  '--bind=[IP address to bind server to]:host:_hosts' \
  '--cluster[enable cluster mode]' \
  '--auth=[authentication mode]:mode:(NoAuth Password Aad ACL)' \
  '--password=[auth password]:pass:' \
  '--tls[enable TLS]' \
  '--cert-file-name=[TLS cert file]:file:_files' \
  '--cert-password=[TLS cert password]:pass:' \
  '--logger-level=[log level]:level:(Trace Debug Information Warning Error Critical None)' \
  '--disable-console-logger[disable console logger]' \
  '--file-logger=[log to file]:file:_files' \
  '--checkpointdir=[storage directory for checkpoints]:dir:_files -/' \
  '--config-import-path=[import configuration file]:file:_files' \
  '--config-export-path=[export configuration file]:file:_files' \
  '--storage-tier[enable tiering of records to storage]' \
  '*::garnet args:_files' && ret=0
return ret
