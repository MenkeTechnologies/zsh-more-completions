#compdef gpiofind
# _gpiofind — Bartosz Golaszewski libgpiod gpiofind CLI for finding the chip and offset of a named GPIO line by user-friendly name across all registered GPIO chips printing chip name and offset (linux team, C); getopt
# upstream: https://git.kernel.org/pub/scm/libs/libgpiod/libgpiod.git

_gpiofind() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '*:line name:'
}

_gpiofind "$@"
