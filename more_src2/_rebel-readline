#compdef rebel-readline
# Documentation: https://github.com/bhauman/rebel-readline
# Reference accessed: 2026-05-16
# Verified: upstream bhauman/rebel-readline. Invoked via
# `clojure -M -m rebel-readline.main`.
# Removed from prior file: bogus man.archlinux.org search URL.

# rebel-readline: Clojure readline wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-k --key-map)'{-k+,--key-map=}'[key map style]:map:(:viins :emacs)' \
  '(-t --color-theme)'{-t+,--color-theme=}'[color theme]:theme:(:light-screen-theme :dark-screen-theme :neutral-screen-theme)' \
  '--no-highlight[disable syntax highlighting]' \
  '--no-completion[disable code completion]' \
  '--no-eldoc[disable function documentation display]' \
  '--no-indent[disable auto indentation]' \
  '--no-redirect-output[disable output redirection]' \
  '(-b --key-bindings)'{-b+,--key-bindings=}'[custom key bindings]:bindings:' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' && ret=0
return ret
