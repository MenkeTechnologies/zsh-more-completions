#compdef fyne-cross
# Documentation: https://github.com/fyne-io/fyne-cross
# Source: https://github.com/fyne-io/fyne-cross/tree/main/internal/command
# Reference accessed: 2026-06-01
# Docker-based cross-compiler for Fyne apps.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _fc_cmds
_fc_cmds=(
    'darwin:build and package for macOS'
    'linux:build and package for Linux'
    'windows:build and package for Windows'
    'android:build and package for Android'
    'ios:build and package for iOS'
    'freebsd:build and package for FreeBSD'
    'version:show version information'
    'darwin-sdk-extract:extract macOS SDK from Xcode CLI tools'
)

_arguments -C \
    '(- *)-h[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'fyne-cross command' _fc_cmds && ret=0
        ;;
esac

return ret
