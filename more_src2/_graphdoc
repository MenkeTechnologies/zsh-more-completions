#compdef graphdoc
# ============================================================================
# graphdoc - Static page generator for GraphQL schema docs (Node, MIT)
#
# Author : Fede Ramirez (2fd)
# Upstream: https://github.com/2fd/graphdoc
# npm    : @2fd/graphdoc
#
# graphdoc renders a static HTML documentation site from a GraphQL
# schema source: SDL (.graphql), JSON introspection result, or a
# live HTTP endpoint that responds to the introspection query.
# Output is a self-contained directory of HTML pages (one per
# type / scalar / enum / union / interface / mutation field /
# subscription) using a Salesforce-Lightning-Design-System-style
# template (the default `graphdoc/template/slds`) or any user-
# supplied Mustache template directory. The renderer is plugin-
# extensible via `--plugin` and accepts arbitrary user-supplied
# `--data` injection for template variables.
#
# The GraphQL lane is built on `graphql ^15.4.0` (declared verbatim
# at upstream package.json HEAD), the canonical Node GraphQL
# library by the GraphQL Foundation (`graphql/graphql-js`, 20000+
# stars on github.com/graphql/graphql-js). graphql-js is the
# *reference implementation* of the GraphQL spec - the spec text
# itself was bootstrapped on top of the graphql-js parser by
# Facebook in 2015, and every other language's GraphQL library
# implements behavior compatible with what graphql-js does.
# graphdoc uses it for the introspection-query execution + result
# typing + schema-shape walking when generating the per-type doc
# pages.
#
# ----------------------------------------------------------------------------
# AXIS 206 :: GRAPHQL (SPEC: WORKING DRAFT - OCT 2021)  [CLOSES]
# Round 1318 :: TS-Node slot 3 of 4 :: CLOSES Axis 206 (199th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : async-graphql/async-graphql       [R1316 _music-player]
#   Go      : 99designs/gqlgen                  [R1317 _bramble]
#   TS/Node : graphql/graphql-js                [R1318 THIS FILE]
#
# Closes Axis 206 with the spec's reference implementation, which
# is the rare case where the canonical library predates the spec
# text - graphql-js was written in 2012-2014 internally at Facebook,
# released as open source in 2015 alongside the spec draft, and
# the spec text continues to cite graphql-js behavior as
# normative for ambiguous cases. async-graphql + gqlgen are both
# tested against graphql-js as the reference. 199th axis closed
# in the corpus.
# ============================================================================

_graphdoc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-c --config)'{-c,--config}'[graphdoc config file (default ./package.json)]:file:_files -g "*.json"' \
        '(-e --endpoint)'{-e,--endpoint}'[GraphQL HTTP introspection endpoint]:url:' \
        '*'{-x,--header}'[HTTP request header (repeatable)]:header:' \
        '*'{-q,--query}'[HTTP querystring (repeatable; use with --endpoint)]:query:' \
        '(-s --schema --schema-file)'{-s,--schema,--schema-file}'[GraphQL schema file (.json or .graphql)]:file:_files -g "*.(json|graphql)"' \
        '*'{-p,--plugin}'[plugin to use (repeatable)]:plugin:' \
        '(-t --template)'{-t,--template}'[Mustache template directory]:template dir:_files -/' \
        '(-o --output)'{-o,--output}'[output directory]:directory:_files -/' \
        '(-d --data)'{-d,--data}'[inject custom JSON data into templates]:json:' \
        '(-b --base-url)'{-b,--base-url}'[base URL prefix for template assets]:url:' \
        '(-f --force)'{-f,--force}'[delete output directory if it exists]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(- *)'{-V,--version}'[show graphdoc version]' \
        '(- *)'{-h,--help}'[print help]'
}

_graphdoc "$@"
