#compdef marker marker_single marker_chunk_convert marker_server marker_gui marker_extract
# Documentation: https://github.com/datalab-to/marker
# Reference accessed: 2026-05-27
# Verified: upstream pyproject.toml [tool.poetry.scripts] and
# marker/scripts/{convert,convert_single,chunk_convert,server}.py plus
# marker/config/parser.py ConfigParser.common_options.
# Deviations from spec: dropped --max_pages, --languages, --paginate_output (not
# explicit click options; surfaced dynamically through CustomClickPrinter from the
# class-config crawler). There is no marker_grpc binary; replaced with marker_gui,
# marker_extract from the real scripts table. Real flags only below.

local curcontext="$curcontext" state line ret=1

# ConfigParser.common_options shared by marker and marker_single.
local -a _marker_common
_marker_common=(
  '--output_dir=[directory to save output]:dir:_files -/'
  '(-d --debug)'{-d,--debug}'[enable debug mode]'
  '--output_format=[output format]:format:(markdown json html chunks)'
  '--processors=[comma separated list of processor class paths]:list:'
  '--config_json=[path to JSON file with additional configuration]:file:_files'
  '--disable_multiprocessing[disable multiprocessing]'
  '--disable_image_extraction[disable image extraction]'
  '--page_range=[page range, e.g. 0,5-10,20]:range:'
  '--converter_cls=[converter class path]:class:'
  '--llm_service=[LLM service import path]:class:'
  '(- *)--help[show help message and exit]'
)

case $service in
  marker)
    # marker = convert.py (folder of PDFs).
    _arguments -s -S \
      '--chunk_idx=[chunk index to convert]:idx:' \
      '--num_chunks=[number of chunks being processed in parallel]:n:' \
      '--max_files=[maximum number of pdfs to convert]:n:' \
      '--skip_existing[skip existing converted files]' \
      '--debug_print[print debug information]' \
      '--max_tasks_per_worker=[max tasks per worker before recycling]:n:' \
      '--workers=[number of worker processes]:n:' \
      $_marker_common \
      '1:input folder:_files -/' && ret=0
    ;;
  marker_single)
    _arguments -s -S \
      $_marker_common \
      '1:pdf file:_files -g "*.pdf"' && ret=0
    ;;
  marker_chunk_convert)
    # argparse-based: two positional args, no flags.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help message and exit]' \
      '1:input folder:_files -/' \
      '2:output folder:_files -/' && ret=0
    ;;
  marker_server)
    _arguments -s -S \
      '(- *)--help[show help message and exit]' \
      '*:file:_files' && ret=0
    ;;
  marker_gui|marker_extract)
    # Streamlit launchers.
    _arguments -s -S \
      '(- *)--help[show help message and exit]' \
      '*:file:_files' && ret=0
    ;;
  *)
    _arguments -s -S $_marker_common '*:file:_files' && ret=0
    ;;
esac

return ret
