#compdef runsvchdir
# Documentation: https://smarden.org/runit/runsvchdir.8.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above. runsvchdir takes a single
# required directory argument; no flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:directory:_files -/' && ret=0

return ret
