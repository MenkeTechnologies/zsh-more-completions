#compdef prysmctl
# _prysmctl — admin tool for the Prysm Ethereum consensus client (OffchainLabs/prysm)
# upstream: https://github.com/prysmaticlabs/prysm
# Subcommands assembled from cmd/prysmctl/main.go.

_prysmctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_prysmctl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                checkpoint-sync)
                    _arguments \
                        '1: :(download save-state save-blob)' \
                        '--beacon-node-host=[beacon-node REST API endpoint]:url:' \
                        '--genesis-beacon-api-url=[genesis-state beacon REST endpoint]:url:' && ret=0 ;;
                db)
                    _arguments \
                        '1: :(bucket-stats migrate restore restore-blobs)' \
                        '--datadir=[Prysm data directory]:dir:_files -/' \
                        '--target-bucket=[bucket name to inspect / restore]:bucket:' && ret=0 ;;
                p2p)
                    _arguments \
                        '1: :(send-request)' \
                        '--peer=[peer multiaddr]:multiaddr:' \
                        '--client-version=[client version string]:version:' \
                        '--protocol=[libp2p protocol]:protocol:' && ret=0 ;;
                testnet)
                    _arguments \
                        '1: :(generate-genesis)' \
                        '--num-validators=[number of initial validators]:n:' \
                        '--genesis-time=[genesis time (unix epoch)]:t:' \
                        '--mainnet-config[use mainnet beacon-chain config]' \
                        '--chain-config-file=[YAML chain config]:file:_files -g "*.(yaml|yml)"' \
                        '--output-ssz=[output beacon state file]:file:_files' \
                        '--output-yaml=[output YAML beacon state]:file:_files' \
                        '--output-json=[output JSON beacon state]:file:_files' && ret=0 ;;
                weak-subjectivity)
                    _arguments \
                        '1: :(compute-state-id)' \
                        '--beacon-node-host=[beacon-node REST API endpoint]:url:' && ret=0 ;;
                validator)
                    _arguments \
                        '1: :(withdraw bls-to-execution generate-deposit-data)' \
                        '*:validator arg:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_prysmctl_commands] )) ||
_prysmctl_commands() {
    local -a commands
    commands=(
        'checkpoint-sync:bootstrap a beacon node from a checkpoint sync source'
        'db:inspect / migrate / restore the Prysm beacon-node database'
        'p2p:libp2p debug helpers (send-request etc.)'
        'testnet:create test beacon-chain configurations and genesis states'
        'weak-subjectivity:compute weak-subjectivity checkpoints'
        'validator:validator-side helpers (withdraw, BLS-to-execution, deposits)'
    )
    _describe -t commands 'prysmctl command' commands
}

_prysmctl "$@"
