#compdef nvidia-modprobe
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/nvidia-modprobe.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --create-nvidia-device-file)'{-c+,--create-nvidia-device-file=}'[create nvidia device file]:minor:' \
  '(-u --unified-memory)'{-u,--unified-memory}'[load NVIDIA UVM kernel module]' \
  '(-m --modeset)'{-m,--modeset}'[load NVIDIA modeset module]' \
  '(-s --nvswitch)'{-s+,--nvswitch=}'[create NVSwitch device files]:minor:' \
  '(-l --nvlink)'{-l,--nvlink}'[create NVLink control device]' \
  '(-f --nvidia-capability-device-file)'{-f+,--nvidia-capability-device-file=}'[create NVIDIA capability device file]:path:_files' \
  '(-a --auto-online-movable)'{-a,--auto-online-movable}'[enable online_movable auto-onlining]' && ret=0

return ret
