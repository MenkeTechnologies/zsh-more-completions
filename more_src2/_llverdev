#compdef llverdev
# Documentation: https://github.com/lustre/lustre-release/blob/master/lustre/utils/llverdev.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# llverdev: Lustre offline block-device verifier
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-c+[IO chunk size in MB (default 1)]:n:' \
  '--chunksize=[IO chunk size in MB (default 1)]:n:' \
  '-f[run without confirmation prompt]' \
  '--force[run without confirmation prompt]' \
  '-l[run complete device verification]' \
  '--long[run complete device verification]' \
  '--full[run complete device verification]' \
  '-o+[offset in kB from start of device]:kB:' \
  '--offset=[offset in kB from start of device]:kB:' \
  '-p[partial check at 1GB intervals]' \
  '--partial[partial check at 1GB intervals]' \
  '-q[suppress verbose output]' \
  '--quiet[suppress verbose output]' \
  '-r[run in verify (read) mode]' \
  '--read[run in verify (read) mode]' \
  '-s+[device size in MB to read/write]:MB:' \
  '--size=[device size in MB to read/write]:MB:' \
  '-t+[verification timestamp]:time:' \
  '--timestamp=[verification timestamp]:time:' \
  '-w[run in test-pattern write mode]' \
  '--write[run in test-pattern write mode]' \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '*:device:_files' && ret=0
return ret
