#compdef dirtop dirtop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/dirtop.py argparse)
# Reference accessed: 2026-05-29
# dirtop — top-like display of file reads/writes by directory (BCC/eBPF). Requires --root-directories.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-C --noclear)'{-C,--noclear}'[do not clear the screen]' \
  '(-r --maxrows)'{-r,--maxrows=}'[maximum rows to print (default 20)]:N:' \
  '(-s --sort)'{-s,--sort=}'[sort column (default all)]:col:(all reads writes rbytes wbytes)' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-d --root-directories)'{-d,--root-directories=}'[REQUIRED: comma-separated directories to observe]:dirs:_directories' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default 1):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
