#compdef mocp
# Documentation: https://manpages.debian.org/bookworm/moc/mocp.1.en.html
# Reference accessed: 2026-05-19
# Verified: Debian bookworm mocp(1) man page.

# Zsh completion for mocp - music on console player

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-S --server)'{-S,--server}'[run only the server]' \
  '(-F --foreground)'{-F,--foreground}'[run the server in foreground (debug)]' \
  '(-R --sound-driver)'{-R,--sound-driver}'[use specified sound driver(s)]:driver:(jack alsa oss sndio)' \
  '(-m --music-dir)'{-m,--music-dir}'[start in configured music directory]' \
  '(-a --append)'{-a,--append}'[append files/dirs/playlists to playlist]' \
  '(-q --enqueue)'{-q,--enqueue}'[add files to the queue]' \
  '(-c --clear)'{-c,--clear}'[clear the playlist and exit]' \
  '(-p --play)'{-p,--play}'[start playing from the first item]' \
  '(-l --playit)'{-l,--playit}'[play files without modifying client playlists]' \
  '(-s --stop)'{-s,--stop}'[stop playing]' \
  '(-f --next)'{-f,--next}'[play next file]' \
  '(-r --previous)'{-r,--previous}'[play previous file]' \
  '(-x --exit)'{-x,--exit}'[shutdown the server]' \
  '(-P --pause)'{-P,--pause}'[pause]' \
  '(-U --unpause)'{-U,--unpause}'[unpause]' \
  '(-G --toggle-pause)'{-G,--toggle-pause}'[toggle play/pause]' \
  '(-k --seek)'{-k,--seek}'[seek by N seconds]:seconds:' \
  '(-j --jump)'{-j,--jump}'[jump to position in current track]:position (Ns or N%):' \
  '(-v --volume)'{-v,--volume}'[adjust mixer volume]:volume (+/-N):' \
  '(-y --sync)'{-y,--sync}'[synchronize playlist with the server]' \
  '(-n --nosync)'{-n,--nosync}'[do not synchronize playlist with the server]' \
  '(-T --theme)'{-T,--theme}'[load theme file]:theme:_files' \
  '(-C --config)'{-C,--config}'[use specified config file]:config:_files' \
  '--no-config[skip configuration file, use defaults]' \
  '(-O --set-option)'{-O,--set-option}'[override config option (NAME[+]=VALUE)]:option:' \
  '(-M --moc-dir)'{-M,--moc-dir}'[use specified MOC directory]:dir:_files -/' \
  '(-D --debug)'{-D,--debug}'[turn on logging to a file]' \
  '(-A --ascii)'{-A,--ascii}'[use ASCII characters to draw lines]' \
  '(-i --info)'{-i,--info}'[print info about currently playing file]' \
  '(-Q --format)'{-Q,--format}'[print formatted information]:format string:' \
  '(-e --recursively)'{-e,--recursively}'[legacy alias for -a]' \
  '(-o --on)'{-o,--on}'[turn on a control]:control:(shuffle autonext repeat)' \
  '(-u --off)'{-u,--off}'[turn off a control]:control:(shuffle autonext repeat)' \
  '(-t --toggle)'{-t,--toggle}'[toggle a control]:control:(shuffle autonext repeat)' \
  '--usage[show command synopsis]' \
  '--echo-args[print interpreted command arguments]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '*:file or directory:_files' && ret=0

return ret
