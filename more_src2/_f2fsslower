#compdef f2fsslower f2fsslower-bpfcc
# _f2fsslower — trace slow F2FS operations (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/f2fsslower.py (argparse).

_f2fsslower() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-s --csv)'{-s,--csv}'[CSV output]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '1:min latency (ms, default 10):'
    )
    _arguments $args
}

_f2fsslower "$@"
