#compdef gen-cpp-header
# _gen-cpp-header — generate C++ header definitions from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/cppgen/cppgen.py (click).

_gen-cpp-header() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output header file (default stdout)]:file:_files -g "*.(h|hpp|hxx)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(cpp)'
        '--namespace=[C++ namespace for generated declarations]:namespace:'
        '--alphabetical-sort[sort generated declarations alphabetically]'
        '--no-alphabetical-sort[preserve schema order]'
        '--use-optional[wrap optional fields in std::optional<T>]'
        '--no-use-optional[use pointer / sentinel values for optional fields]'
        '--gen-string-conversions[emit string conversion helpers (to/from)]'
        '--no-gen-string-conversions[skip string conversion helpers]'
        '--template-dir=[Jinja2 template directory]:dir:_files -/'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-cpp-header "$@"
