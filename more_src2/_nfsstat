#compdef nfsstat
# _nfsstat — OpenBSD nfsstat (display NFS client/server statistics; -c client-only, -s server-only, -w periodic snapshot, -M/-N use core+symbols for postmortem inspection)
# upstream: https://github.com/openbsd/src (usr.bin/nfsstat)
# Flags from usr.bin/nfsstat/nfsstat.1 on tip.

_nfsstat() {
    _arguments \
        '-c[client statistics only]' \
        '-s[server statistics only]' \
        '-M+[core file]:file:_files' \
        '-N+[kernel symbol file]:file:_files' \
        '-w+[wait interval seconds]:seconds:'
}

_nfsstat "$@"
