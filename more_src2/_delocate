#compdef delocate delocate-wheel delocate-fuse delocate-listdeps delocate-path delocate-addplat delocate-patch
# _delocate — macOS wheel postprocessor for vendored libraries (Matthew Brett, Python); argparse
# upstream: https://github.com/matthew-brett/delocate

_delocate() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--lib-sdir=+[lib subdir in wheel]:str:' \
        '-L+[lib subdir in wheel]:str:' \
        '--check-archs[check arches]' \
        '--require-archs=+[require arches]:list:(x86_64 arm64 universal2 i386)' \
        '--require-target-macos-version=+[require target macos version]:str:' \
        '-w+[output dir]:dir:_files -/' \
        '--wheel-dir=+[output dir]:dir:_files -/' \
        '--ignore-missing-dependencies[ignore missing dependencies]' \
        '--exclude=+[exclude pattern]:list:' \
        '-e+[exclude pattern]:list:' \
        '--executable-path=+[executable path]:str:' \
        '--no-lipo[no lipo]' \
        '--exclude-cross[exclude cross]' \
        '--macos-deployment-target=+[macos deployment target]:str:' \
        '--sanitize-rpaths[sanitize rpaths]' \
        '--clobber=+[clobber existing files]:b:(true false)' \
        '--keep-libs[keep delocated libs]' \
        '-k[keep delocated libs]' \
        '--no-arch[no arch]' \
        '--out-wheel=+[output wheel]:file:_files' \
        '--ignore-stamp-suffix[ignore stamp suffix]' \
        '--platform=+[platform]:list:' \
        '-p+[platform]:list:' \
        '--rm-orig[remove original]' \
        '*:file:_files'
}

_delocate "$@"
