#compdef moproxy
# _moproxy — transparent TCP-to-proxy redirector (sorz/moproxy)
# upstream: https://github.com/sorz/moproxy
# Flags from src/cli.rs (clap).

_moproxy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-b --host)'{-b+,--host=}'[bind address]:ip:' \
        '(-p --port)'{-p+,--port=}'[bind port(s), comma separated]:ports:' \
        '(-s --socks5)'{-s+,--socks5=}'[SOCKS5 upstream list]:servers:' \
        '(-t --http)'{-t+,--http=}'[HTTP upstream list]:servers:' \
        '(-l --list)'{-l+,--list=}'[INI proxy list file]:file:_files -g "*.ini"' \
        '--policy=[policy rule file]:file:_files' \
        '(-i --probe)'{-i+,--probe=}'[probe period (seconds)]:secs:' \
        '--test-dns=[DNS server for delay probing]:addr:' \
        '--stats-bind=[stats web bind addr]:addr:' \
        '--remote-dns[get SNI & forward to remote proxy]' \
        '--n-parallel=[connect to N proxies in parallel]:n:' \
        '--congestion-local=[local TCP congestion algorithm]:alg:' \
        '--allow-direct[fall back to direct on failure]' \
        '--graphite=[graphite carbon daemon addr]:addr:' \
        '--log-level=[log level]:level:(off error warn info debug trace)' \
        '--score-script=[Lua script for proxy score]:file:_files -g "*.lua"' \
        '--max-wait=[connection timeout seconds]:secs:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'check:load & validate config and exit'
                'policy:policy ruleset commands'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                check) _arguments '--no-bind[do not bind socket]' ;;
                policy) _arguments '1:subcmd:(get)' '--listen-port=[port]:port:' '--dst-ip=[dst IP]:ip:' '--dst-domain=[dst domain]:domain:' ;;
            esac
            ;;
    esac
}

_moproxy "$@"
