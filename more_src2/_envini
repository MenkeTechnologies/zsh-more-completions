#compdef envini
# _envini — daemontools-encore envini (set environment variables from an INI file ([section]/key=value), then exec child; INI-style alternative to envdir(8))
# upstream: https://github.com/schmonz/daemontools-encore
# Flags from envini.8 on tip.

_envini() {
    _arguments \
        '-p+[prefix all variable names]:prefix:' \
        '1:ini-file:_files' \
        '*::child:_command_names -e'
}

_envini "$@"
