#compdef jdupes
# Documentation: https://codeberg.org/jbruchon/jdupes/raw/branch/master/README.md
# Reference accessed: 2026-05-19
# Verified: jbruchon/jdupes upstream README option table.
# Zsh completion for jdupes - duplicate file finder and manager
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-@ --loud)'{-@,--loud}'[output annoying low-level debug info while running]' \
  '(-0 --print-null)'{-0,--print-null}'[output nulls instead of CR/LF]' \
  '(-1 --one-file-system)'{-1,--one-file-system}'[do not match files on different filesystems]' \
  '(-A --no-hidden)'{-A,--no-hidden}'[exclude hidden files from consideration]' \
  '(-B --dedupe)'{-B,--dedupe}'[do a filesystem block-level dedupe]' \
  '(-C --chunk-size)'{-C,--chunk-size}'[set I/O chunk size in KiB]:size:' \
  '(-d --delete)'{-d,--delete}'[prompt user for files to preserve and delete the rest]' \
  '(-D --debug)'{-D,--debug}'[output debug statistics after completion]' \
  '(-e --error-on-dupe)'{-e,--error-on-dupe}'[exit on any duplicate found with status 1]' \
  '(-f --omit-first)'{-f,--omit-first}'[omit the first match in each set of matches]' \
  '(-H --hard-links)'{-H,--hard-links}'[treat hard-linked files as duplicate files]' \
  '(-i --reverse)'{-i,--reverse}'[reverse the sort order of results]' \
  '(-I --isolate)'{-I,--isolate}'[files in the same specified directory wont match]' \
  '(-j --json)'{-j,--json}'[produce JSON (machine-readable) output]' \
  '(-l --link-soft)'{-l,--link-soft}'[make relative symlinks for duplicates without prompting]' \
  '(-L --link-hard)'{-L,--link-hard}'[hard link all duplicate files without prompting]' \
  '(-m --summarize)'{-m,--summarize}'[summarize dupe information]' \
  '(-M --print-summarize)'{-M,--print-summarize}'[print matches and summarize the dupe information]' \
  '(-N --no-prompt)'{-N,--no-prompt}'[together with --delete, preserve the first file in each set]' \
  '(-o --order)'{-o,--order}'[select sort order for output and deletion]:order:(name time)' \
  '(-O --param-order)'{-O,--param-order}'[sort by command-line parameter order]' \
  '(-p --permissions)'{-p,--permissions}'[do not match files with different owner/group or permissions]' \
  '(-P --print)'{-P,--print}'[print extra information]:type:(early fullhash partial)' \
  '(-q --quiet)'{-q,--quiet}'[hide progress indicator]' \
  '(-Q --quick)'{-Q,--quick}'[skip byte-by-byte confirmation for identical files]' \
  '(-r --recurse)'{-r,--recurse}'[for every directory, process its subdirectories too]' \
  '(-R --recurse:)'{-R,--recurse:}'[for each directory given after this option follow subdirectories]' \
  '(-s --symlinks)'{-s,--symlinks}'[follow symlinks]' \
  '(-S --size)'{-S,--size}'[show size of duplicate files]' \
  '(-t --no-change-check)'{-t,--no-change-check}'[disable security check for file changes]' \
  '(-T --partial-only)'{-T,--partial-only}'[match based on partial hashes only]' \
  '(-u --print-unique)'{-u,--print-unique}'[print only a list of unique (non-matched) files]' \
  '(-U --no-trav-check)'{-U,--no-trav-check}'[disable double-traversal safety check]' \
  '(-X --ext-filter)'{-X,--ext-filter}'[filter files based on specified criteria]:spec:' \
  '(-y --hash-db)'{-y,--hash-db}'[use a hash database for faster repeat runs]:file:_files' \
  '(-Y --hash-db-populate)'{-Y,--hash-db-populate}'[only build the hash database, do not match files]' \
  '(-z --zero-match)'{-z,--zero-match}'[consider zero-length files to be duplicates]' \
  '(-Z --soft-abort)'{-Z,--soft-abort}'[if interrupted, finish processing files found so far]' \
  '(- *)'{-h,--help}'[show help text and exit]' \
  '(- *)'{-v,--version}'[display jdupes version and compilation info]' \
  '*:directory:_directories' && ret=0
return ret
