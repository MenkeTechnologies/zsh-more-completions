#compdef drake
# _drake — Ropensci drake R workflow manager / Compass Lab Drake JavaScript task automation CLI (multiple); custom argparse
# upstream: https://github.com/ropensci/drake

_drake() {
    local -a sub=(
        'make:build all targets'
        'plan:show plan'
        'progress:show progress'
        'config:show config'
        'session:show session'
        'sessioninfo:show session info'
        'clean:clean cache'
        'cache:cache helpers'
        'graph:plot graph'
        'visnetwork:plot network'
        'failed:show failed targets'
        'history:show history'
        'recoverable:show recoverable targets'
        'outdated:show outdated targets'
        'history-summary:summarize history'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose=+[verbosity]:n:(0 1 2)' \
        '-v+[verbosity]:n:(0 1 2)' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--parallelism=+[parallelism]:p:(loop future clustermq future_lapply)' \
        '-p+[parallelism]:p:(loop future clustermq future_lapply)' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '-c+[cache path]:dir:_files -/' \
        '--no-build[no build]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drake subcommand' sub ;;
        args)
            case $words[1] in
                make|outdated|failed|recoverable) _arguments \
                    '*:target:' ;;
                clean) _arguments \
                    '--destroy[destroy cache]' \
                    '--garbage-collection[garbage collection]' \
                    '*:target:' ;;
                graph|visnetwork) _arguments \
                    '--file=+[output file]:file:_files' \
                    '*:target:' ;;
            esac
            ;;
    esac
}

_drake "$@"
