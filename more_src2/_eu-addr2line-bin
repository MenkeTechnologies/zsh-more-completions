#compdef eu-addr2line
# _eu-addr2line-bin — elfutils addr2line (Ulrich Drepper, Red Hat); convert addresses to function:file:line
# upstream: https://sourceware.org/elfutils

_eu-addr2line-bin() {
    _arguments \
        '(-b --target)'{-b,--target}'+[target arch]:target:' \
        '(-C --demangle)'{-C,--demangle}'+[demangle]:style:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '(-e --exe)'{-e,--exe}'+[executable]:file:_files' \
        '(-f --functions)'{-f,--functions}'[show function names]' \
        '(-s --basenames)'{-s,--basenames}'[strip dir]' \
        '(-i --inlines)'{-i,--inlines}'[show inline frames]' \
        '(-j --section)'{-j,--section}'+[section]:section:' \
        '(-p --pretty-print)'{-p,--pretty-print}'[pretty]' \
        '(-a --addresses)'{-a,--addresses}'[show addresses]' \
        '--flags+[output flags]:str:' \
        '--no-inlines[do not show inlines]' \
        '--core+[core file]:file:_files' \
        '--debuginfo-path+[debuginfo path]:path:_files -/' \
        '--symbols[only symbol]' \
        '--symbols-sections[symbols with sections]' \
        '--absolute[absolute path]' \
        '--relative[relative path]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:address:'
}

_eu-addr2line-bin "$@"
