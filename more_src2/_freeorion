#compdef freeorion
# Documentation: https://github.com/freeorion/freeorion/blob/master/client/human/chmain.cpp
# Reference accessed: 2026-05-16
# Verified: client/human/chmain.cpp + camain.cpp via grep db.AddFlag / db.AddOption
# Removed from prior file: --connect (not in source), --default-pause-game-on-start
# (invented), --full-screen (real is the dotted key video.fullscreen.enabled or -f),
# --load (invented; real is --load-or-quickstart or use config file),
# --multiplayer-on (invented), --resource.path (invented), --save.path (invented),
# --server.python.AI.disable (invented), --video.fullscreen.height/width.windowed
# (invented), --ai-pause (invented).

# FreeOrion: 4X turn-based space empire strategy
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-g[generate default config xml]' \
  '--generate-config-xml[generate default config xml]' \
  '-f[fullscreen]' \
  '--video.fullscreen.enabled[fullscreen]' \
  '-r[render simple (low-spec)]' \
  '--render-simple[render simple (low-spec)]' \
  '--continue[continue last save]' \
  '--auto-quit[quit after autoplay finishes]' \
  '--hostless[run hostless server]' \
  '--load-or-quickstart[load last save or quickstart]' \
  '--network.server.external.force[force external server]' \
  '--quickstart[quick-start a single-player game]' \
  '--singleplayer[force singleplayer]' \
  '--skip-checksum[skip data checksum verification]' \
  '--testing[testing mode (AI client)]' \
  '--window-reset[reset window position/size]' \
  '*::extra args (FreeOrion config keys not enumerated):_files' && ret=0
return ret
