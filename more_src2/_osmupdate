#compdef osmupdate
# Documentation: https://manpages.debian.org/bookworm/osmctools/osmupdate.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm osmupdate(1) manpage.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# osmupdate: incrementally update an OpenStreetMap planet file
local curcontext="$curcontext" ret=1
_arguments -C \
  '--max-days=[max days back to fetch updates]:days:' \
  '--minute[use minute-granularity diffs]' \
  '--hour[use hour-granularity diffs]' \
  '--day[use day-granularity diffs]' \
  '--sporadic[use sporadic update servers]' \
  '--max-merge=[max diffs to merge in one step]:n:' \
  '(-t --tempfiles)'{-t+=,--tempfiles=}'[temporary file prefix]:prefix:' \
  '--keep-tempfiles[do not delete tempfiles]' \
  '--trust-tempfiles[reuse existing tempfiles]' \
  '--compression-level=[gzip compression level]:level:' \
  '--base-url=[diff source URL]:url:' \
  '--base-url-suffix=[diff URL suffix]:suffix:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:OSM file:_files -g "*.(osm|pbf|o5m)(-.)"' && ret=0
return ret
