#compdef pnpm-cli
# _pnpm-cli — pnpm fast efficient JavaScript package manager CLI alias (Zoltan Kochan / pnpm team, TypeScript); custom argparse
# upstream: https://github.com/pnpm/pnpm

_pnpm-cli() {
    local -a sub=(
        'add:add packages'
        'audit:run audit'
        'bin:print bin dir'
        'cat-file:cat content of file in package'
        'cat-index:cat index file of package'
        'config:configuration commands'
        'create:scaffold a project'
        'dedupe:dedupe packages'
        'deploy:deploy a workspace package'
        'doctor:diagnose project'
        'dlx:run a one-off command'
        'env:manage node versions'
        'exec:execute a binary'
        'fetch:fetch packages'
        'help:show help'
        'import:import lockfile from another tool'
        'init:scaffold package.json'
        'install:install dependencies'
        'install-test:install + test'
        'licenses:list licenses'
        'link:symlink local package'
        'list:list installed packages'
        'ls:list installed packages (alias)'
        'outdated:show outdated packages'
        'pack:create npm tarball'
        'patch:create patch file'
        'patch-commit:commit patch file'
        'patch-remove:remove patch file'
        'prune:remove unused packages'
        'publish:publish package'
        'rebuild:rebuild packages'
        'recursive:recursive operations'
        'remove:remove a package'
        'rm:remove a package (alias)'
        'restart:restart packaged commands'
        'root:print root dir'
        'run:run a script'
        'serve:serve a package'
        'setup:setup pnpm shell'
        'start:run start script'
        'store:store commands'
        'test:run tests'
        'unlink:unlink linked packages'
        'update:update dependencies'
        'up:update dependencies (alias)'
        'why:show why a package is installed'
        'workspace:workspace commands'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dir=+[change to dir]:dir:_files -/' \
        '-C+[change to dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '--filter=+[filter]:str:' \
        '-F+[filter]:str:' \
        '--silent[silent]' \
        '-s[silent]' \
        '--reporter=+[reporter]:r:(default append-only ndjson silent)' \
        '--loglevel=+[loglevel]:level:(error warn info debug trace)' \
        '--prod[production]' \
        '-P[production]' \
        '--dev[only dev deps]' \
        '-D[only dev deps]' \
        '--no-optional[skip optional]' \
        '--global[global]' \
        '-g[global]' \
        '--global-dir=+[global dir]:dir:_files -/' \
        '--no-frozen-lockfile[no frozen lockfile]' \
        '--frozen-lockfile[frozen lockfile]' \
        '--no-strict-peer-dependencies[no strict peer deps]' \
        '--strict-peer-dependencies[strict peer deps]' \
        '--ignore-scripts[ignore scripts]' \
        '--store-dir=+[store dir]:dir:_files -/' \
        '--virtual-store-dir=+[virtual store dir]:dir:_files -/' \
        '--shamefully-hoist[shamefully hoist]' \
        '--hoist-pattern=+[hoist pattern]:str:' \
        '--public-hoist-pattern=+[public hoist pattern]:str:' \
        '--lockfile-only[lockfile only]' \
        '--prefer-offline[prefer offline]' \
        '--prefer-frozen-lockfile[prefer frozen lockfile]' \
        '--workspace-root[workspace root]' \
        '-w[workspace root]' \
        '--recursive[recursive]' \
        '-r[recursive]' \
        '--registry=+[registry url]:url:_urls' \
        '--workspace[workspace install]' \
        '--save-dev[save dev]' \
        '--save-peer[save peer]' \
        '--save-optional[save optional]' \
        '--no-save[no save]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pnpm subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--save-dev[save dev]' \
                    '-D[save dev]' \
                    '--save-peer[save peer]' \
                    '--save-optional[save optional]' \
                    '--global[global]' \
                    '-g[global]' \
                    '--workspace[workspace install]' \
                    '*:package:' ;;
                remove|rm) _arguments '*:package:' ;;
                update|up) _arguments \
                    '--latest[latest]' \
                    '-L[latest]' \
                    '--interactive[interactive]' \
                    '-i[interactive]' \
                    '--workspace[workspace]' \
                    '--recursive[recursive]' \
                    '-r[recursive]' \
                    '*:package:' ;;
                run|exec|dlx|test) _arguments '*:script-or-cmd:' ;;
                config) _arguments \
                    '1:cmd:(get set delete list)' \
                    '*:arg:' ;;
                store) _arguments \
                    '1:cmd:(prune status path)' \
                    '*:arg:' ;;
                workspace) _arguments \
                    '1:cmd:(run exec list)' \
                    '*:arg:' ;;
                env) _arguments \
                    '1:cmd:(use list remove)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_pnpm-cli "$@"
