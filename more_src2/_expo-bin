#compdef expo
# _expo-bin — Expo SDK CLI (expo-cli/v3, Expo); local dev server, run on device, install + prebuild for React Native apps
# upstream: https://github.com/expo/expo

_expo-bin() {
    local -a sub=(
        'start:run dev server (default)'
        'config:show resolved app.config.js'
        'export:export bundles for production'
        'install:install matching SDK package'
        'prebuild:generate native android/ios projects'
        'run\:android:run on Android'
        'run\:ios:run on iOS Simulator'
        'lint:run ESLint'
        'login:authenticate to Expo'
        'logout:logout'
        'whoami:print current user'
        'register:create Expo account'
        'init:create new project (deprecated, use create-expo-app)'
        'metro:metro bundler commands'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--non-interactive[no prompts]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'expo subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--port+[port]:port:' \
                    '--clear[clear cache]' \
                    '(-c --clear)'{-c,--clear}'[clear cache]' \
                    '--host+[host]:host:(lan tunnel localhost)' \
                    '--lan[LAN URL]' \
                    '--tunnel[tunnel URL]' \
                    '--localhost[localhost URL]' \
                    '(-a --android)'{-a,--android}'[run on Android]' \
                    '(-i --ios)'{-i,--ios}'[run on iOS]' \
                    '(-w --web)'{-w,--web}'[run on web]' \
                    '--dev[dev mode]' \
                    '--no-dev[disable dev mode]' \
                    '--scheme+[deep link scheme]:scheme:' \
                    '--max-workers+[max workers]:n:' \
                    '--https[serve over HTTPS]' \
                    '--offline[offline mode]' ;;
                install) _arguments \
                    '--check[check installed versions]' \
                    '--fix[fix incompatible versions]' \
                    '*:package:' ;;
                prebuild) _arguments \
                    '--clean[clean before prebuild]' \
                    '--platform+[platform]:platform:(ios android all)' \
                    '--no-install[skip install]' \
                    '--template+[template]:template:' ;;
                export) _arguments \
                    '--dump-assetmap[write assetmap.json]' \
                    '--dump-sourcemap[generate sourcemaps]' \
                    '--source-maps[generate sourcemaps]' \
                    '--platform+[platform]:platform:(android ios all)' \
                    '--output-dir+[output dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_expo-bin "$@"
