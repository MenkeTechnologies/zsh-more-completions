#compdef pamu2fcfg
# Documentation: https://manpages.debian.org/bookworm/pamu2fcfg/pamu2fcfg.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm pamu2fcfg(1) manpage OPTIONS.
# Removed from prior file: fabricated -V flag (uses --version only) and
# bogus man.archlinux.org search URL.

# pamu2fcfg: U2F/FIDO2 credential registration helper for pam-u2f
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '--version[show version]' \
  '(-o --origin)'{-o+,--origin=}'[origin string (default pam\://hostname)]:origin:' \
  '(-i --appid)'{-i+,--appid=}'[application ID (default origin)]:appid:' \
  '(-r --resident)'{-r,--resident}'[generate a resident credential]' \
  '(-t --type)'{-t+,--type=}'[key algorithm]:type:(ES256 RS256)' \
  '(-P --no-user-presence)'{-P,--no-user-presence}'[disable user presence check]' \
  '(-N --pin-verification)'{-N,--pin-verification}'[require PIN verification]' \
  '(-V --user-verification)'{-V,--user-verification}'[require user verification]' \
  '(-u --username)'{-u+,--username=}'[username (default current user)]:user:_users' \
  '(-n --nouser)'{-n,--nouser}'[print only registration info (keyHandle + pubkey)]' && ret=0
return ret
