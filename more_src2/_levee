#compdef levee
# Documentation: https://manpages.debian.org/bookworm/levee/levee.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for levee - tiny vi clone editor.
# Usage: levee [+address] [file ...]
# levee has no traditional -flag options; only a +address jump form and file args.

local ret=1

_arguments -C \
  '*:file:_files' && ret=0

return ret
