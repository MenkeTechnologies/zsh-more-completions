#compdef PrintHeader
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/PrintHeader.cxx — print header information of an image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:image.ext:_files -g "*.{nii,nii.gz,mha,nrrd,hdr,img}"' \
    '2::whatInformation:(0 1 2 3 4 5 6 7)' \
    && ret=0

return ret
