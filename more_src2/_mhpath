#compdef mhpath
# Documentation: man mhpath(1)
# Source: nmh uip/mhpath.c (master) — print full pathnames of nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
