#compdef mrstats
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrstats.html
# Source: MRtrix3/mrtrix3 cmd/mrstats.cpp + core/stats.cpp — image intensity statistics (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-output+[print statistic field]:field:(mean median std std_rv min max count)' \
    '-mask+[restrict to mask voxels]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-ignorezero[ignore zero-valued voxels]' \
    '-allvolumes[stats across all volumes (not per-volume)]' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
