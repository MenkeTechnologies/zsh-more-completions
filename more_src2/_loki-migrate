#compdef loki-migrate
# _loki-migrate — Grafana Loki tenant/data migration tool
# upstream: https://github.com/grafana/loki
# Flags from cmd/migrate/main.go on tip.

_loki-migrate() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-from=[start time (RFC3339Nano)]:time:' \
        '-to=[end time (RFC3339Nano)]:time:' \
        '-source.config.file=[source Loki config file]:file:_files' \
        '-dest.config.file=[destination Loki config file]:file:_files' \
        '-source.tenant=[source tenant ID]:id:' \
        '-dest.tenant=[destination tenant ID]:id:' \
        '-match=[optional LogQL label match]:expr:' \
        '-batchLen=[chunks per batch]:n:' \
        '-shardBy=[shard interval (e.g. 6h)]:dur:' \
        '-parallel=[parallel worker threads per shard]:n:' \
        '-metrics.namespace=[Prometheus metric namespace]:name:'
}

_loki-migrate "$@"
