#compdef gtp
# _gtp — Linux libgtpnl gtp-link / gtp-tunnel CLI (control wrapper over the kernel GTP-U module used to run cellular PGW/SGW data planes on Linux; subcommands: link add/del, tunnel add/del/list, with per-tunnel arguments TID, MS IP, SGSN/PGW IP, version v0|v1; -v verbose, -h help)
# upstream: https://git.osmocom.org/libgtpnl
# Subcommands from libgtpnl tools/gtp-* on tip.

_gtp() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gtp command' '(link tunnel)' ;;
        args)
            case $line[1] in
                link) _describe -t commands 'link subcommand' '(add del list)' ;;
                tunnel) _describe -t commands 'tunnel subcommand' '(add del list flush)' ;;
            esac
            ;;
    esac
}

_gtp "$@"
