#compdef gitlabform
# Documentation: https://gitlabform.github.io/gitlabform/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-V --version)'{-V,--version}'[show version and exit]' \
  '(-k --skip-version-check)'{-k,--skip-version-check}'[skip latest-version check]' \
  '(-c --config)'{-c,--config}'=[YAML config file]:config file:_files -g "*.yml *.yaml"' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug output (prints secrets sent to API)]' \
  '(-s --strict)'{-s,--strict}'[stop on missing branches or tags]' \
  '(-n --noop)'{-n,--noop}'[dry-run mode]' \
  '(-doc --diff-only-changed)'{-doc,--diff-only-changed}'[diff only changed keys]' \
  '(-o --output-file)'{-o,--output-file}'=[write effective config to file]:file:_files' \
  '(-a --include-archived-projects)'{-a,--include-archived-projects}'[include archived projects]' \
  '--include-projects-scheduled-for-deletion[include projects pending deletion]' \
  '(-t --terminate)'{-t,--terminate}'[stop after first processing error]' \
  '(-sf --start-from)'{-sf,--start-from}'=[start at project index]:n:' \
  '(-sfg --start-from-group)'{-sfg,--start-from-group}'=[start at group index]:n:' \
  '(-os --only-sections)'{-os,--only-sections}'=[comma sections or all]:sections:' \
  '(-es --exclude-sections)'{-es,--exclude-sections}'=[comma sections or none]:sections:' \
  '(-r --recurse-subgroups)'{-r,--recurse-subgroups}'[recurse subgroups]' \
  '1::target (group/project, ALL, ALL_DEFINED, ...): _default'
