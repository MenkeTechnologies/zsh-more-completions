#compdef llvm-undname
# _llvm-undname — LLVM Microsoft ABI name demangler (LLVM project, C++); demangle Visual C++ symbols
# upstream: https://github.com/llvm/llvm-project

_llvm-undname() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--no-access-specifier[no access specifier]' \
        '--no-calling-convention[no calling convention]' \
        '--no-cv-qualifiers[no cv qualifiers]' \
        '--no-leading-underscores[no leading underscores]' \
        '--no-ms-keywords[no MS keywords]' \
        '--no-class-recursion[no class recursion]' \
        '--no-return-type[no return type]' \
        '--no-thisType[no this type]' \
        '--no-throw-signatures[no throw signatures]' \
        '--no-arguments[no arguments]' \
        '--no-variable-type[no variable type]' \
        '--name-only[name only]' \
        '--no-ms-thiscall[no MS thiscall]' \
        '--no-access[no access]' \
        '--type-only[type only]' \
        '--full[full]' \
        '--raw-file=+[raw file]:file:_files' \
        '*:symbol:'
}

_llvm-undname "$@"
