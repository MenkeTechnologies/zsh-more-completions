#compdef kleopatra
# Documentation: https://invent.kde.org/pim/kleopatra/-/blob/master/src/kleopatra_options.h
# Reference accessed: 2026-05-19
# Verified: upstream src/kleopatra_options.h QCommandLineOption list.
# Corrected from prior file: --import-certificate and -q/--query are
# value-less flags (files are positional), not option-args; replaced
# 404 docs.kde.org URL with the verified upstream source.

# kleopatra: KDE certificate manager (OpenPGP + S/MIME)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-p --openpgp)'{-p,--openpgp}'[use OpenPGP for the following operation]' \
  '(-c --cms)'{-c,--cms}'[use CMS (X.509/S\:MIME) for the following operation]' \
  '--uiserver-socket=[location of the UI server socket]:socket:' \
  '--daemon[run UI server only, hide main window]' \
  '(-i --import-certificate)'{-i,--import-certificate}'[import certificate file(s)]' \
  '(-e --encrypt)'{-e,--encrypt}'[encrypt file(s)]' \
  '(-s --sign)'{-s,--sign}'[sign file(s)]' \
  '(-E --sign-encrypt --encrypt-sign)'{-E,--sign-encrypt,--encrypt-sign}'[sign and/or encrypt file(s)]' \
  '(-d --decrypt)'{-d,--decrypt}'[decrypt file(s)]' \
  '(-V --verify)'{-V,--verify}'[verify file/signature]' \
  '(-D --decrypt-verify)'{-D,--decrypt-verify}'[decrypt and/or verify file(s)]' \
  '(-q --query)'{-q,--query}'[display certificate details or search by fingerprint]' \
  '--search[search for a certificate on a keyserver]' \
  '--gen-key[create a new key pair or certificate signing request]' \
  '--checksum[create or check a checksum file]' \
  '--parent-windowid=[parent window id for dialogs]:windowid:' \
  '--config[open the config dialog]' \
  '--standalone[run as standalone app without system tray icon]' \
  '*:file:_files' && ret=0
return ret
