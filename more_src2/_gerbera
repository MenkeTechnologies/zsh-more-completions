#compdef gerbera
# _gerbera — UPnP/DLNA media server (gerbera/gerbera)
# upstream: https://github.com/gerbera/gerbera
# Flags from gerbera(1) man page.

_gerbera() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(- *)--compile-info[print compile config and exit]' \
        '(-i --ip)'{-i+,--ip=}'[bind IP address]:ip:' \
        '(-e --interface)'{-e+,--interface=}'[bind network interface]:iface:_net_interfaces' \
        '(-p --port)'{-p+,--port=}'[server port (>= 49152)]:port:' \
        '(-c --config)'{-c+,--config=}'[config file (absolute path)]:file:_files -g "*.xml"' \
        '(-m --home)'{-m+,--home=}'[alternative home dir]:dir:_files -/' \
        '(-f --cfgdir)'{-f+,--cfgdir=}'[config directory name]:dir:_files -/' \
        '(-P --pidfile)'{-P+,--pidfile=}'[pidfile (absolute path)]:file:_files' \
        '(-a --add)'{-a+,--add=}'[add path to DB without UI interaction]:path:_files' \
        '(-l --logfile)'{-l+,--logfile=}'[redirect log to file]:file:_files' \
        '(-D --debug)'{-D,--debug}'[enable debug logging]' \
        '--close[close after import (with -a)]'
}

_gerbera "$@"
