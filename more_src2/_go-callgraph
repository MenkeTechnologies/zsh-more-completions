#compdef go-callgraph
# _go-callgraph — go-callgraph utility (community); wrapper around x/tools callgraph to render Graphviz output
# upstream: community Go callgraph wrapper

_go-callgraph() {
    _arguments \
        '-algo+[algorithm]:algo:(static cha rta vta pta)' \
        '-format+[output format]:fmt:(dot graphviz svg png)' \
        '-output+[output file]:file:_files' \
        '-tags+[build tags]:tags:' \
        '-test[include tests]' \
        '-ptalog+[pta log file]:file:_files' \
        '*:packages:'
}

_go-callgraph "$@"
