#compdef cwebp dwebp webpinfo webpmux gif2webp img2webp vwebp webpsearch libwebp
# _libwebp — Google libwebp WebP cwebp dwebp webpinfo webpmux suite for WebP image format (Google team, C); custom argparse
# upstream: https://github.com/webmproject/libwebp

_libwebp() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-V[show version]' \
        '-q+[quality 0-100]:n:' \
        '-z+[lossless preset 0-9]:n:' \
        '-m+[compression method 0-6]:n:' \
        '-segments+[N]:n:' \
        '-size+[bytes]:n:' \
        '-psnr+[F]:f:' \
        '-s+[width height]:str:' \
        '-sns+[N]:n:' \
        '-f+[filter strength]:n:' \
        '-sharpness+[N]:n:' \
        '-strong[strong filter]' \
        '-nostrong[no strong filter]' \
        '-sharp_yuv[sharp YUV]' \
        '-partition_limit+[N]:n:' \
        '-pass+[N]:n:' \
        '-qrange+[min max]:str:' \
        '-crop+[x y w h]:str:' \
        '-resize+[width height]:str:' \
        '-mt[multi-threading]' \
        '-low_memory[low memory]' \
        '-map+[N]:n:' \
        '-near_lossless+[level]:n:' \
        '-pre+[N]:n:' \
        '-noalpha[discard alpha]' \
        '-lossless[lossless mode]' \
        '-blend_alpha+[color]:str:' \
        '-noasm[disable asm]' \
        '-v[verbose]' \
        '-version[show version]' \
        '-progress[show progress]' \
        '-quiet[quiet]' \
        '-print_ssim[print SSIM]' \
        '-print_psnr[print PSNR]' \
        '-print_lsim[print LSIM]' \
        '-d[output file is dump]' \
        '-alpha_q+[N]:n:' \
        '-jpeg_like[JPEG-like compression]' \
        '-af[auto filter]' \
        '-exact[exact]' \
        '-hint+[hint]:h:(photo picture graph)' \
        '-metadata+[mode]:m:(all none exif icc xmp)' \
        '-noasm[no asm]' \
        '-bgcolor+[ARGB]:str:' \
        '-loop+[N]:n:' \
        '-min_size[min size]' \
        '-kmin+[N]:n:' \
        '-kmax+[N]:n:' \
        '-mixed[mixed lossy/lossless]' \
        '-o+[output]:file:_files -g "*.webp *.png *.pam *.ppm *.pgm *.bmp *.tiff *.tif *.yuv"' \
        '*:input file:_files -g "*.png *.jpg *.jpeg *.tiff *.tif *.bmp *.gif *.webp *.yuv *.pam *.ppm *.pgm"'
}

_libwebp "$@"
