#compdef geesefs
# _geesefs — high-performance S3 FUSE filesystem (yandex-cloud/geesefs)
# upstream: https://github.com/yandex-cloud/geesefs
# Flags from core/cfg/flags.go (urfave/cli).

_geesefs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '-o+[mount options (comma-separated)]:options:' \
        '--cache=[cache directory]:dir:_files -/' \
        '--dir-mode=[directory permissions]:mode:' \
        '--file-mode=[file permissions]:mode:' \
        '--cache-file-mode=[cache file permissions]:mode:' \
        '--uid=[POSIX uid]:n:' \
        '--gid=[POSIX gid]:n:' \
        '--setuid=[drop to UID after mount]:n:' \
        '--setgid=[drop to GID after mount]:n:' \
        '--endpoint=[S3 endpoint URL]:url:' \
        '--region=[AWS region]:region:' \
        '--profile=[AWS credentials profile]:profile:' \
        '--shared-config=[shared config file]:file:_files' \
        '--storage-class=[storage class]:class:(STANDARD STANDARD_IA INTELLIGENT_TIERING GLACIER GLACIER_IR DEEP_ARCHIVE ONEZONE_IA REDUCED_REDUNDANCY COLD)' \
        '--cold-min-size=[minimum object size for cold class (bytes)]:n:' \
        '--requester-pays[set x-amz-request-payer: requester]' \
        '--use-content-type[infer Content-Type from extension]' \
        '--sse=[server-side encryption (SSE-S3)]:bool:' \
        '--sse-kms=[KMS key id for SSE-KMS]:key:' \
        '--sse-c=[base64 encryption key for SSE-C]:key:' \
        '--no-checksum[disable client-side checksums]' \
        '--list-type=[ListObjects API version]:n:(1 2)' \
        '--no-detect[skip S3 capability detection]' \
        '--no-expire-multipart[do not expire stale multipart uploads]' \
        '--multipart-age=[multipart upload max age]:duration:' \
        '--multipart-copy-threshold=[multipart copy threshold]:bytes:' \
        '--acl=[canned ACL]:acl:(private public-read public-read-write authenticated-read bucket-owner-read bucket-owner-full-control)' \
        '--subdomain[use bucket as subdomain instead of path-style]' \
        '--iam[fetch credentials via IAM role]' \
        '--iam-header=[IAM credentials header name]:header:' \
        '--iam-flavor=[IAM credentials flavor]:flavor:(gcp aws)' \
        '--iam-url=[IAM credentials metadata URL]:url:' \
        '--project-id=[GCS project ID]:id:' \
        '--refresh-dirs[refresh dir listings on access]' \
        '--ignore-setting-attrs-for-root-dir-erros[ignore setattr errors on root dir]' \
        '--sdk-max-retries=[max SDK retries]:n:' \
        '--sdk-min-retry-delay=[min SDK retry delay]:duration:' \
        '--sdk-max-retry-delay=[max SDK retry delay]:duration:' \
        '--sdk-min-throttle-delay=[min throttle delay]:duration:' \
        '--sdk-max-throttle-delay=[max throttle delay]:duration:' \
        '1:bucket[:prefix]:' \
        '2:mountpoint:_files -/'
}

_geesefs "$@"
