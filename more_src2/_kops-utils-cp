#compdef kops-utils-cp
# _kops-utils-cp — kOps multi-target file copy helper used by nodeup for assets staging (copies / symlinks one or more sources into one or more target directories)
# upstream: https://github.com/kubernetes/kops
# Flags from cmd/kops-utils-cp/main.go on tip.

_kops-utils-cp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--symlink[make a symbolic link instead of copying]' \
        '*--target-dir=[destination directory (may be repeated)]:dir:_files -/' \
        '*--src=[source file (may be repeated)]:file:_files'
}

_kops-utils-cp "$@"
