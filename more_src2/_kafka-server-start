#compdef kafka-server-start
# Documentation: https://github.com/apache/kafka/blob/4.2/bin/kafka-server-start.sh
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# USAGE: kafka-server-start [-daemon] server.properties [--override property=value]*

local -a arguments

arguments=(
    '-daemon[Run as a daemon]'
    '--override[Optional property that should override values set in server.properties]:property:'
    '--version[Print version information and exit]'
    '*:config file:_files -g "*.properties"'
)

_arguments -s -S $arguments
