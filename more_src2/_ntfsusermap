#compdef ntfsusermap
# _ntfsusermap — Tuxera ntfs-3g ntfsusermap CLI for managing Windows-Linux user-account ID mapping on NTFS volumes producing UserMapping file translating SID UID GID for NTFS ACL preservation file-ownership inheritance (tuxera team, C); getopt
# upstream: https://github.com/tuxera/ntfs-3g

_ntfsusermap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-d[debug]' \
        '-f[force]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-a[append]' \
        '--append[append]' \
        '-u+[uid]:n:' \
        '--uid=+[uid]:n:' \
        '-g+[gid]:n:' \
        '--gid=+[gid]:n:' \
        '*:device or path:_files'
}

_ntfsusermap "$@"
