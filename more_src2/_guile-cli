#compdef guile-cli guile2
# _guile-cli — GNU Guile guile-cli CLI command-line frontend wrapping the GNU Guile open-source extension language preferred extension language for the GNU Project written in C and Scheme originally Aubrey Jaffer Free Software Foundation now GNU Project Andy Wingo R5RS R6RS R7RS Scheme implementation with native compilation extension scripting embeddable language designed to help programmers create flexible applications GNU Lilypond GnuCash Lepton EDA TeXmacs Snd guile-2.0 guile-3.0 native-code-generation REPL Guile-VM call/cc continuations modules srfi --version --no-debug --debug --listen --auto-compile --no-auto-compile --fresh-auto-compile -L --use-srfi --no-init-file -e -ds (Aubrey Jaffer FSF Andy Wingo GNU Guile team, C/Scheme); custom argparse
# upstream: https://www.gnu.org/software/guile/

_guile-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[expression]:str:' \
        '*-c+[expression]:str:' \
        '-e+[function]:str:' \
        '*-e+[function]:str:' \
        '-l+[file]:file:_files -g "*.scm *.sld *.sls"' \
        '*-l+[file]:file:_files -g "*.scm *.sld *.sls"' \
        '-L+[load path]:dir:_files -/' \
        '*-L+[load path]:dir:_files -/' \
        '-C+[compiled load path]:dir:_files -/' \
        '*-C+[compiled load path]:dir:_files -/' \
        '-x+[ext]:str:' \
        '*-x+[ext]:str:' \
        '-s+[script]:file:_files -g "*.scm"' \
        '--no-debug[no debug]' \
        '--debug[debug]' \
        '--no-auto-compile[no auto compile]' \
        '--auto-compile[auto compile]' \
        '--fresh-auto-compile[fresh auto compile]' \
        '--no-init-file[no init file]' \
        '--use-srfi=+[list]:str:' \
        '--listen=+[port]:n:' \
        '--no-warnings[no warnings]' \
        '-r[r6rs syntax]' \
        '-r7[r7rs syntax]' \
        '-ds[load -s after this]' \
        '-w+[warnings]:str:' \
        '-O+[opt level]:n:(0 1 2 3)' \
        '-On[no optimize]' \
        '-Wunused-variable[warn unused]' \
        '-Wunbound-variable[warn unbound]' \
        '-Warity-mismatch[warn arity]' \
        '-Wduplicate-case-datum[warn duplicate case]' \
        '-Wbad-case-datum[warn bad case]' \
        '-Wformat[warn format]' \
        '-Wmacro-use-before-definition[warn macro use]' \
        '-Wunsupported-warning[warn unsupported]' \
        '-Wuse-before-definition[warn use before]' \
        '-Wunused-toplevel[warn unused toplevel]' \
        '-Wnon-idempotent-definition[warn non-idem def]' \
        '-Wshadowed-toplevel[warn shadowed toplevel]' \
        '-Werror=+[w]:str:' \
        '-d+[deferred warnings]' \
        '--language=+[lang]:l:(scheme elisp ecmascript brainfuck)' \
        '-D+[debug warning]:str:' \
        '--debug=+[name]:str:' \
        '*:scheme file:_files -g "*.scm *.sld *.sls *.go"'
}

_guile-cli "$@"
