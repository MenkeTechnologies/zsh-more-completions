#compdef mmls
# Documentation: https://www.sleuthkit.org/sleuthkit/man/mmls.html
# Source: sleuthkit/sleuthkit man/mmls.1 — displays partition tables in a volume system.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-t[specify the media management type]:mmtype:(dos mac bsd sun gpt)' \
    '-o[offset into image where volume containing partition system starts]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-B[include column with partition sizes in bytes]' \
    '-r[recurse into DOS partitions and look for other partition tables]' \
    '(-a -A)-a[show allocated volumes]' \
    '(-a -A)-A[show unallocated volumes]' \
    '(-m -M)-m[show metadata volumes]' \
    '(-m -M)-M[hide metadata volumes]' \
    '-v[verbose output of debugging statements to stderr]' \
    '-V[display version]' \
    '*:image file:_files' \
    && ret=0

return ret
