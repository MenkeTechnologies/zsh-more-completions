#compdef libvirtd
# _libvirtd — libvirt libvirtd (monolithic libvirt daemon; -d daemonize, -l listen on TCP/TLS, -f config file, -p pidfile, -t timeout seconds, -v verbose, --version; on modern distros split per-driver daemons (virtqemud/virtnetworkd/...) replace it)
# upstream: https://gitlab.com/libvirt/libvirt (src/remote/remote_daemon.c)
# Flags from libvirt src/remote/remote_daemon.c on tip.

_libvirtd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[daemonize]' \
        '--daemon[daemonize]' \
        '-l[listen on TCP/TLS]' \
        '--listen[listen on TCP/TLS]' \
        '-f+[config file]:file:_files -g "*.conf"' \
        '--config+[config file]:file:_files -g "*.conf"' \
        '-p+[pidfile]:file:_files' \
        '--pid-file+[pidfile]:file:_files' \
        '-t+[timeout seconds]:seconds:' \
        '--timeout+[timeout seconds]:seconds:'
}

_libvirtd "$@"
