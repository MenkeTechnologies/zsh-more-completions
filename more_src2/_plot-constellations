#compdef plot-constellations
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/plot-constellations.1 — annotate images with constellations/stars/Messier/NGC/HD (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-w+[WCS input file]:file:_files -g "*.{wcs,fits}"' \
    '-L[just list the items in the field]' \
    '-o+[image output file ("-" for stdout)]:file:_files' \
    '-p[write PPM output (default PNG)]' \
    '-i+[PPM input file]:file:_files -g "*.ppm"' \
    '-W+[output width]:n:_default' \
    '-H+[output height]:n:_default' \
    '-s+[scale image coordinates]:n:_default' \
    '-N[plot NGC objects]' \
    '-F+[minimum NGC size relative to image (default 0.02)]:n:_default' \
    '-C[plot constellations]' \
    '-B[plot named bright stars]' \
    '-D[plot HD objects]' \
    '-d+[path to HD catalog]:path:_files' \
    '-b+[plot only the N brightest stars]:n:_default' \
    '-c[only plot bright stars with common names]' \
    '-j[if a star has a common name, only print that]' \
    '-v[verbose]' \
    '-n+[NGC circle width (default 2)]:n:_default' \
    '-f+[font size]:n:_default' \
    '-M[show only NGC/IC and Messier numbers]' \
    '-G+[plot RA/Dec grid (spacing in arcmin)]:arcmin:_default' \
    '-g+[grid color r:g:b]:color:_default' \
    '-J[print JSON output to stderr]' \
    '-V+[label vertical alignment]:align:(C T B)' \
    '-O+[label horizontal alignment]:align:(L C R)' \
    && ret=0

return ret
