#compdef go-oas3
# ============================================================================
# go-oas3 - OpenAPI v3 -> Go server code generator (Go, MIT)
#
# Author : Mike Konan (mikekonan)
# Upstream: https://github.com/mikekonan/go-oas3
#
# `go-oas3` is a Go codegen tool that reads an OpenAPI 3.x
# specification (YAML or JSON) and emits the matching Go
# server scaffolding: route registrations, request/response
# DTOs (with JSON tags + validation tags), per-endpoint
# handler interfaces, and middleware glue. The output is
# framework-agnostic at the routing layer (you wire it into
# net/http or any chi/gin/echo router), with optional
# components for request validation + response shaping.
#
# Usage:
#   go-oas3 -swagger-addr <spec> -package <name> -path <dir> [options]
#
# Flags (heetch/confita CLI backend):
#   -swagger-addr <file|url>      - OpenAPI spec file path or HTTP URL
#                                   (REQUIRED; default swagger.yaml)
#   -package <name>               - Go package name for generated code
#                                   (REQUIRED)
#   -path <dir>                   - output directory for generated
#                                   code (REQUIRED)
#   -componentsPackage <name>     - separate package for components
#                                   (default: same as --package)
#   -componentsPath <dir>         - separate directory for components
#                                   (default: same as --path)
#   -authorization <K:V,K2:V2>    - extra HTTP headers for fetching
#                                   the spec (comma-separated
#                                   key:value pairs)
#   -a <K:V,K2:V2>                - alias for -authorization
#   -pass-raw-request             - pass *http.Request to handlers
#                                   (otherwise only parsed DTOs)
#   -prioritize-x-go-type         - prefer the `x-go-type` OpenAPI
#                                   extension over the schema-derived
#                                   type when both are declared
#   -version | --version          - print version + build info
#   -h | --help                   - print help
#
# The kin-openapi lane is built on `github.com/getkin/kin-
# openapi` (declared as a direct dep at upstream go.mod HEAD),
# the canonical Go OpenAPI 3.x library by getkin
# (github.com/getkin/kin-openapi, 3000+ stars). kin-openapi
# is the *uncontested* Go OpenAPI library - it implements
# the OpenAPI 3.0 + 3.1 spec models as Go structs with full
# JSON/YAML parse + serialize support, runtime request +
# response validation against a loaded spec, and codegen
# helpers. Every Go OpenAPI-adjacent project (deepmap/
# oapi-codegen, getkin/kin-openapi itself, danielgtaylor/
# huma, kataras/iris-openapi, ...) depends on it for the
# spec parsing + validation layer. go-oas3 uses it as the
# OpenAPI parser - the spec is loaded into kin-openapi's
# `openapi3.T` struct, then the codegen walks the parsed
# AST to emit Go code.
#
# ----------------------------------------------------------------------------
# AXIS 238 :: OpenAPI codegen + spec emission (OpenAPI 3.x JSON Schema)
# Round 1413 :: Go slot 2 of 4 :: continues Axis 238
#
# Cross-language canonical library family for this axis:
#   Rust    : juhaku/utoipa                [R1412 _martin]
#   Go      : getkin/kin-openapi           [R1413 THIS FILE]
#   TS/Node : drwpow/openapi-typescript    [R1414 closing]
#
# kin-openapi is the *parser + validator* foundation that
# the Go OpenAPI tooling ecosystem stands on. Unlike the
# Rust slot (utoipa) which generates the spec *from* code,
# kin-openapi consumes a spec and exposes it as a typed Go
# struct + a runtime validator. go-oas3 sits on top of
# kin-openapi as a *spec-to-code-generator* - the spec is
# the source of truth, kin-openapi parses it, and go-oas3
# walks the parsed model to emit Go server code.
#
# This is the opposite-direction OpenAPI workflow from
# utoipa: code-first (Rust) vs spec-first (Go). The two
# workflows are complementary - many teams use spec-first
# for public APIs (where the spec is the contract managed
# in version control) and code-first for internal services
# (where the implementation is the source of truth).
#
# The closing TS/Node slot (openapi-typescript) is also
# spec-first but targets *client-side type generation*
# rather than server-side scaffolding - reflecting JS's
# typical role as a consumer of REST APIs rather than a
# producer.
# ============================================================================

_go-oas3() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '-swagger-addr[OpenAPI spec file path or HTTP URL]:spec:_files -g "*.(yaml|yml|json)"' \
        '-package[Go package name for generated code]:name:' \
        '-path[output directory for generated code]:dir:_files -/' \
        '-componentsPackage[separate package for components]:name:' \
        '-componentsPath[separate directory for components]:dir:_files -/' \
        '(-a -authorization)'{-a,-authorization}'[extra HTTP headers for spec fetch (K:V,K2:V2)]:headers:' \
        '-pass-raw-request[pass *http.Request to handlers]' \
        '-prioritize-x-go-type[prefer x-go-type extension over schema-derived type]' \
        '(- *)-version[print version + build info]' \
        '(- *)'{-h,--help}'[print help]'
}

_go-oas3 "$@"
