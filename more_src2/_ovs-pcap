#compdef ovs-pcap
# Documentation: https://man7.org/linux/man-pages/man1/ovs-pcap.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: ovs-tcpundump removed — it is a separate binary with different
# semantics (text hex → pcap), not an alias of ovs-pcap.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*: :_files -g "*.pcap *.cap"' && ret=0

return ret
