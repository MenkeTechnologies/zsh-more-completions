#compdef datapane-cli datapane
# _datapane-cli — Datapane datapane-cli CLI command-line frontend wrapping the Datapane open-source Python library for building interactive reports and dashboards managing apps reports auth signup login logout token cloud-deploy hello-world template generate save preview upload assets pin server (Datapane team, Python); click
# upstream: https://datapane.com/

_datapane-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'signup:create an account'
        'auth:authenticate'
        'app:app operations'
        'report:report operations'
        'template:template operations'
        'asset:asset operations'
        'environment:environment operations'
        'cloud:cloud operations'
        'server:run local preview server'
        'hello-world:create a sample report'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--token=+[token]:str:' \
        '--server=+[url]:str:' \
        '--email=+[address]:str:' \
        '--name=+[name]:str:' \
        '--description=+[text]:str:' \
        '--public[public]' \
        '--private[private]' \
        '--org=+[name]:str:' \
        '--workspace=+[name]:str:' \
        '--tags=+[list]:str:' \
        '--open[open in browser]' \
        '--no-open[no open]' \
        '--use-cache[use cache]' \
        '-c+[config file]:file:_files -g "datapane.toml *.toml *.yaml *.yml"' \
        '--config=+[file]:file:_files -g "datapane.toml *.toml *.yaml *.yml"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datapane-cli subcommand' sub ;;
        args)
            case $words[1] in
                app|report|template|asset|environment|cloud) _arguments '1:op:(list create update delete deploy run download upload preview)' '*:name:' ;;
                server) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:_hosts' \
                    '--debug[debug]' \
                    '--reload[reload on change]' ;;
            esac
            ;;
    esac
}

_datapane-cli "$@"
