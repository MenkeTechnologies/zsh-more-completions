#compdef longbridge
# ---------------------------------------------------------------------------
# longbridge — AI-native CLI for the Longbridge trading platform with
#              real-time market data, portfolio, and trading (Rust, 858★)
#
# upstream: https://github.com/longbridge/longbridge-terminal
# author : the Longbridge engineering team (港交所跨境券商 Longbridge Whale
#          Tech / 长桥) — Hong Kong cross-border brokerage with a public
#          OpenAPI surface
# license: MIT
#
# Source-direct completion: every top-level subcommand below is verbatim
# from src/cli/mod.rs on the longbridge/longbridge-terminal v0.22.3 tip
# — clap-derive `Commands` Subcommand enum with 79 top-level variants.
# Per-subcommand flag detail is deferred to `longbridge <subcommand>
# --help` (the upstream `after_help` documents that each command has
# two help levels: `-h` for brief summary, `--help` for full detail).
#
# Direct deps from Cargo.toml (selected):
#   rust_decimal      1.32     ← canonical Rust arbitrary-precision
#                                decimal arithmetic for finance (this
#                                axis) — by Paul Mason (paupino/rust-
#                                decimal); 128-bit fixed-point decimal
#                                type that avoids IEEE-754 float
#                                rounding pitfalls when handling money.
#                                Used throughout longbridge-terminal
#                                for prices / quantities / P&L
#                                calculations.  THE Rust answer to
#                                "I'm dealing with money and can't
#                                tolerate float imprecision."
#   rust_decimal_macros  1.32  (macros for compile-time Decimal literals)
#   longbridge                  (Longbridge OpenAPI Rust SDK; pulled
#                                from git as it tracks the same release
#                                cadence as this CLI)
#   ratatui + crossterm + termimad + tui-markdown + tui-input
#                              (TUI rendering for the `tui` subcommand)
#   bevy_app + bevy_ecs        (the only known production use of Bevy
#                              ECS *outside* game engines — used here
#                              to manage TUI state mutations as ECS
#                              system queries, since TUI hot reloads
#                              and reactive subscriptions map cleanly
#                              onto an entity-component architecture)
#   cli-candlestick-chart      (ASCII candlestick chart renderer —
#                              the K-line view in `longbridge kline`)
#   reqwest (rustls) + tokio + tokio-stream + futures (async stack)
#   prost                      (Protocol Buffers — Longbridge WebSocket
#                              protocol uses protobuf framing)
#   aes-gcm + hkdf + sha2 + machine-uid (auth + token encryption at
#                                        rest at ~/.longbridge/openapi/
#                                        tokens/<client_id>)
#   rust-i18n                  (i18n with zh-CN + en locale files in
#                              `locales/` — `--lang zh-CN | en`)
#   tabled                     (tabular output for `--format table`)
#   serde + serde_json         (JSON output for `--format json`)
#
# longbridge-terminal speaks the Longbridge OpenAPI (the same public
# OpenAPI offered to algorithmic traders) and surfaces every read +
# trading operation as a CLI subcommand or via the interactive TUI.
# Authentication via OAuth (`longbridge auth login` once; token cached
# under `~/.longbridge/openapi/tokens/<client_id>`) or via environment
# variables (`LONGBRIDGE_APP_KEY` + `LONGBRIDGE_APP_SECRET` +
# `LONGBRIDGE_ACCESS_TOKEN`).  Every command supports both human-readable
# `--format table` (default) and machine-readable `--format json` output
# for AI-agent piping — the AI-native design tagline.
#
# Symbol format is `<CODE>.<MARKET>`:
#   TSLA.US      United States (US)
#   700.HK       Hong Kong (HK)
#   D05.SG       Singapore (SG)
#   600519.SH    China A-share Shanghai (SH)
#   000568.SZ    China A-share Shenzhen (SZ)
#   .VIX.US      Index (US)
#   BTCUSD.HAS   Crypto — Longbridge-specific suffix (.HAS)
#   ETHBTC.HAS   Crypto pair
#
# === AXIS 181 OPENER — arbitrary-precision decimal arithmetic for finance =
# Axis position: Rust=236 OPENS Axis 181 at slot 1/0/0.  Canonical Rust
# arbitrary-precision decimal arithmetic library is `rust_decimal` by
# Paul Mason (paupino/rust-decimal) — a 128-bit fixed-point decimal
# type with 28-29 significant digits, supporting addition, subtraction,
# multiplication, division, rounding modes, and serde + diesel + sqlx
# integration.  Avoids IEEE-754 float rounding errors that bite every
# `0.1 + 0.2 = 0.30000000000000004` style bug in money/finance code.
# THE Rust answer to "I'm dealing with money and can't tolerate float
# imprecision" — used by longbridge-terminal, polygon-rs (Polygon.io
# market data SDK), tradingview-rs, every Rust trading bot, and most
# accounting/billing/invoicing Rust codebases.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=236     ← THIS FILE              (axis 181 OPENS, slot 1/0/0)
#   Go=236       ← next round              (axis 181 continues, slot 2/0/0)
#   TS-Node=236  ← round after             (axis 181 CLOSES at triple-236, slot 1/1/1)
# ---------------------------------------------------------------------------

_longbridge() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[brief summary (options only)]' \
        '(- *)--version[print version]' \
        '(-v --verbose)'{-v,--verbose}'[print verbose request info (host, elapsed) to stderr, prefixed with `*` like curl -v]' \
        '--format=[output format: pretty/table for humans, json for AI agents and scripting (default pretty)]:format:(pretty table json)' \
        '--lang=[content language for longbridge.com (defaults to system LANG env var, else en)]:language:(en zh-CN)' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'auth:authenticate or clear credentials (subcommand: login / logout / status)'
                'init:set an invite code for affiliate tracking (e.g. KOL-ABC123)'
                'check:check token validity and API connectivity (shows token status, cached region, latency to Global + CN endpoints)'
                'update:update longbridge to the latest version (downloads + runs official install script; --release-notes to view notes only)'
                'tui:launch the interactive full-screen TUI — watchlist, candlestick charts, portfolio, search, vim keybindings'
                'completion:generate shell completion script for bash/zsh/fish/elvish/powershell'
                'quote:real-time quotes for one or more symbols (last_done, prev_close, open, high, low, volume, turnover, trade_status; US has extended-hours)'
                'depth:level-2 order book depth (bid/ask ladder up to 10 price levels)'
                'brokers:broker queue at each price level (HK market) — institutional order flow signal'
                'trades:recent tick-by-tick trades with timestamp, price, volume, direction'
                'intraday:minute-by-minute price + volume lines (today or --date YYYYMMDD); --session all for pre/post-market'
                'kline:OHLCV candlestick K-line data; periods 1m/5m/15m/30m/1h/day/week/month/year; `history` subcommand for date ranges'
                'static:static reference info for symbols (name, exchange, currency, lot_size, total_shares, EPS, BPS, dividend)'
                'calc-index:calculated financial indexes (PE/PB/DPS/turnover/options Greeks delta/gamma/theta/vega/rho/iv)'
                'capital:intraday capital distribution snapshot (--flow for time series)'
                'market-temp:market sentiment temperature 0-100 (--history for time series)'
                'trading:trading session schedule and calendar (subcommand: session / days)'
                'security-list:overnight-eligible securities by market US/HK/CN/SG (--page, --count)'
                'participants:market maker (participant) broker IDs and names (use with `brokers`)'
                'subscriptions:active real-time WebSocket subscriptions for this session'
                'option:option chain, quote, and volume statistics (subcommand: chain / quote / volume)'
                'warrant:warrant data (HK warrants market)'
                'financial-report:income/balance-sheet/cash-flow statements'
                'business-segments:revenue breakdown by business segment'
                'industry-rank:industry rank within sector'
                'industry-peers:industry peer comparison'
                'institution-rating:institutional analyst ratings'
                'dividend:dividend history + upcoming ex-dividend dates'
                'forecast-eps:analyst EPS forecasts'
                'consensus:analyst consensus estimates'
                'finance-calendar:upcoming earnings/dividend/IPO/conference calls calendar'
                'valuation:valuation metrics over time'
                'news:related news for a symbol or topic'
                'filing:SEC/HKEX/CSRC regulatory filings'
                'topic:Longbridge community topic threads (subcommand: detail / search / create / replies / create-reply)'
                'watchlist:manage personal watchlists (subcommand)'
                'statement:account statements'
                'order:active + historical orders (subcommand: detail / executions / buy / sell / cancel / replace)'
                'assets:total assets across cash + securities'
                'cash-flow:account cash flow history'
                'portfolio:portfolio overview'
                'positions:current stock positions'
                'fund-positions:current fund holdings'
                'margin-ratio:initial/maintenance margin ratios per symbol'
                'max-qty:max-buyable / max-sellable quantity per symbol given current account state'
                'exchange-rate:FX rates between supported currencies (USD/HKD/SGD/CNY/JPY/EUR/GBP)'
                'shareholder:major shareholder ownership disclosures'
                'company:company profile + executives + address'
                'executive:executive (officer/director) details'
                'industry-valuation:industry-level valuation aggregates'
                'operating:operating data (deliveries, subscribers, store count, etc.)'
                'corp-action:corporate actions (splits, mergers, spin-offs, name changes)'
                'invest-relation:IR contact and event calendar'
                'constituent:index constituents (e.g. S&P 500, HSI, NIFTY)'
                'market-status:current market open/closed/pre-market/after-hours status per market'
                'broker-holding:broker holding disclosures'
                'ah-premium:A-share vs H-share premium for dual-listed companies'
                'trade-stats:trade statistics for a symbol'
                'anomaly:price/volume anomaly detection'
                'top-movers:top gainers/losers/volume by market'
                'screener:stock screener with multi-criteria filters'
                'rank:ranked lists by various metrics'
                'compare:side-by-side multi-symbol comparison'
                'alert:price/event alerts (subcommand)'
                'profit-analysis:profitability analysis'
                'fund-holder:fund holder breakdown (institutional ownership)'
                'insider-trades:Form 4 insider trading filings'
                'investors:major investor profiles'
                'dca:dollar-cost-averaging position simulator'
                'short-positions:short interest positions'
                'short-trades:short selling trade history'
                'sharelist:saved share lists (subcommand: mine / detail / search)'
                'quant:quant-render of strategy backtests + scripts (subcommand)'
                'financial-statement:detailed financial statement line items'
                'valuation-rank:valuation rank vs peers'
                'bank-cards:linked bank cards (for deposits/withdrawals)'
                'withdrawals:withdrawal history + initiate new withdrawal'
                'deposits:deposit history + initiate new deposit'
                'ipo:upcoming IPO calendar + subscribe to IPO'
            )
            _describe -t commands 'longbridge command' subcmds && ret=0
            ;;
        args)
            # Most subcommands take 1+ positional symbol(s) in <CODE>.<MARKET> format.
            # Symbols are too dynamic to enumerate (depends on user watchlist/positions);
            # the shell falls through to default file completion which is generally a no-op
            # but lets the user paste a symbol freely.
            case $words[1] in
                quote|static|brokers|depth|trades|intraday|kline|capital|calc-index|news|filing|dividend|forecast-eps|consensus|valuation|operating|company|executive|insider-trades|fund-holder|trade-stats|anomaly|broker-holding|ah-premium|short-positions|short-trades|margin-ratio|max-qty|business-segments|industry-rank|industry-peers|institution-rating|constituent|profit-analysis|financial-report|financial-statement|valuation-rank)
                    _arguments \
                        '*:symbol (e.g. TSLA.US 700.HK D05.SG 600519.SH 000568.SZ .VIX.US BTCUSD.HAS):' && ret=0
                    ;;
                market-temp|market-status|security-list|top-movers|exchange-rate|trading|ipo)
                    _arguments \
                        '1:market:(US HK CN SG SH SZ HAS)' \
                        '*: :_files' && ret=0
                    ;;
                completion)
                    _arguments \
                        '1:shell:(bash zsh fish elvish powershell)' && ret=0
                    ;;
                auth)
                    _arguments \
                        '1: :(login logout status)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_longbridge "$@"
