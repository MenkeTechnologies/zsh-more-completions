#compdef gpt-engineer gpte
# Documentation: https://github.com/AntonOsika/gpt-engineer
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_gpt-engineer() {
    local -a args
    args=(
        '(-m --model)'{-m,--model}'[Specify the model ID]:model:(gpt-4o gpt-4-turbo gpt-4 gpt-3.5-turbo)'
        '(-t --temperature)'{-t,--temperature}'[Controls randomness (0.0 to 1.0)]:temperature'
        '(-i --improve)'{-i,--improve}'[Improve Mode: Modifies existing files in the project directory]'
        '(-l --lite)'{-l,--lite}'[Lite Mode: Runs generation using only the main prompt]'
        '(-c --clarify)'{-c,--clarify}'[Clarify Mode: Discusses the specification with the AI before implementation]'
        '(-sh --self-heal)'{-sh,--self-heal}'[Self-heal Mode: Automatically attempts to fix code if it fails to run]'
        '(-a --azure)'{-a,--azure}'[Endpoint for Azure OpenAI Service]:endpoint'
        '--image_directory[Path to a directory containing images for vision-capable models]:directory:_directories'
        '--help[Displays the full help message]'
        '*:project directory:_directories'
    )

    _arguments -s -S $args
}

_gpt-engineer "$@"
