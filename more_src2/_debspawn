#compdef debspawn
# _debspawn — Debian package builder using systemd-nspawn (lkhq/debspawn)
# upstream: https://github.com/lkhq/debspawn
# Subcommands from debspawn/cli.py (argparse).

_debspawn() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--verbose[enable debug messages]' \
        '--config=[config file]:file:_files' \
        '--owner=[run as user]:user:_users' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'create:create new container image'
                'delete:remove a container image'
                'update:update a container image'
                'list:list available container images'
                'ls:alias for list'
                'exists:check whether a container image exists'
                'build:build a Debian package in a container'
                'login:open interactive session in a container'
                'run:run arbitrary command in the nspawn container'
                'maintain:execute various maintenance actions'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                build) _arguments '--sign[sign the resulting package]' '*:dsc file:_files -g "*.dsc"' ;;
                create|delete|update|exists|login|run) _arguments '1:suite:' ;;
            esac
            ;;
    esac
}

_debspawn "$@"
