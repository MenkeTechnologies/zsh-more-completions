#compdef license_finder
# _license_finder — track open-source licenses against your policy (pivotal-legacy/LicenseFinder)
# upstream: https://github.com/pivotal-legacy/LicenseFinder
# Subcommands & flags from lib/license_finder/cli/main.rb (thor).

_license_finder() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--format=[output format]:fmt:(text html markdown csv xml json junit)' \
        '(-d --debug)'{-d,--debug}'[emit detailed info]' \
        '(-p --prepare)'{-p,--prepare}'[prepare project before scanning]' \
        '--prepare-no-fail[prepare project (continue on failure)]' \
        '(-r --recursive)'{-r,--recursive}'[recurse into sub-projects]' \
        '--project-path=[project root to scan]:dir:_files -/' \
        '--save=[save report to file]:file:_files' \
        '--columns=[comma-separated CSV columns]:cols:' \
        '--quiet[suppress non-error logging]' \
        '--strict-matching[require strict subproject match]' \
        '--use-spdx-id[output SPDX licence IDs]' \
        '--write-headers[include headers in CSV/MD output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'project_roots:list project directories to be scanned'
                'action_items:list unapproved dependencies (default)'
                'report:print dependencies report to stdout'
                'diff:diff two generated CSV reports'
                'version:print version'
                'dependencies:add/remove manual dependencies'
                'licenses:override detected licences'
                'approvals:approve individual dependencies'
                'ignored_groups:exclude test/dev groups'
                'ignored_dependencies:exclude individual dependencies'
                'permitted_licenses:auto-approve permitted licences'
                'restricted_licenses:forbid restricted licences'
                'project_name:set project name in reports'
                'inherited_decisions:inherit decisions from other files'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                diff) _arguments '1:OLDFILE:_files' '2:NEWFILE:_files' ;;
                dependencies|licenses|approvals|ignored_groups|ignored_dependencies|permitted_licenses|restricted_licenses|inherited_decisions)
                    _arguments '1:sub:(add remove list)'
                    ;;
            esac
            ;;
    esac
}

_license_finder "$@"
