#compdef flyctl2 fly2
# _flyctl2 — Fly.io flyctl2 CLI command-line frontend wrapping the Fly.io flyctl official command-line interface for the Fly.io platform-as-a-service that runs Docker containers and Firecracker-microVMs in 30+ regions worldwide using BGP-anycast network and Firecracker-edge open-source written in Go apps machines volumes orgs builds deploy launch destroy scale postgres redis nats vector mpg upstash storage tigris launch-app secrets agent api wireguard ssh auth bg images json status migrate-to-v2 console logs ips proxy services scope (Fly.io team Kurt Mackey Jerome Petazzoni Thomas Ptacek, Go); cobra
# upstream: https://fly.io/

_flyctl2() {
    local -a sub=(
        'agent:wireguard agent'
        'apps:app operations'
        'auth:auth operations'
        'builds:build operations'
        'certs:certificate ops'
        'checks:health check ops'
        'completion:generate shell completion'
        'config:config operations'
        'console:open a console'
        'curl:curl through proxy'
        'dashboard:open dashboard'
        'deploy:deploy app'
        'destroy:destroy an app'
        'dig:dig DNS'
        'docs:open docs'
        'doctor:run preflight checks'
        'extensions:extension operations'
        'history:show deploy history'
        'image:image operations'
        'ips:IP operations'
        'jobs:job operations'
        'launch:launch a new app'
        'litefs:LiteFS operations'
        'logs:tail app logs'
        'machine:machine operations'
        'metrics:metrics operations'
        'migrate-to-v2:migrate apps v2'
        'mpg:MPG operations'
        'mysql:MySQL operations'
        'nats:NATS operations'
        'open:open app'
        'orgs:org operations'
        'platform:platform info'
        'ping:ping'
        'postgres:Postgres operations'
        'proxy:port-forward'
        'redis:Redis operations'
        'releases:release operations'
        'restart:restart app'
        'scale:scale operations'
        'secrets:secret operations'
        'services:show services'
        'settings:account settings'
        'ssh:SSH ops'
        'status:show app status'
        'storage:storage operations'
        'tokens:token operations'
        'turboku:Turboku ops'
        'update:update flyctl'
        'version:show version'
        'vm:VM operations'
        'volumes:volume operations'
        'wireguard:WireGuard operations'
        'wormhole:wormhole ops'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--access-token=+[token]:str:' \
        '-t+[token]:str:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--config=+[file]:file:_files -g "fly.toml *.toml"' \
        '-c+[config]:file:_files -g "fly.toml *.toml"' \
        '-a+[app]:str:' \
        '--app=+[name]:str:' \
        '-o+[org]:str:' \
        '--org=+[name]:str:' \
        '-r+[region]:str:' \
        '--region=+[code]:str:' \
        '*-r+[region]:str:' \
        '--primary-region=+[code]:str:' \
        '--vm-cpus=+[N]:n:' \
        '--vm-memory=+[MB]:n:' \
        '--vm-size=+[s]:s:(shared-cpu-1x shared-cpu-2x shared-cpu-4x shared-cpu-8x performance-1x performance-2x performance-4x performance-8x performance-16x)' \
        '--json[JSON output]' \
        '--no-color[no color]' \
        '--yes[yes]' \
        '-y[yes]' \
        '--auto-confirm[auto confirm]' \
        '--build-secret=+[k=v]:str:' \
        '*--build-secret=+[k=v]:str:' \
        '--build-target=+[name]:str:' \
        '--dockerfile=+[file]:file:_files -g "Dockerfile *.Dockerfile"' \
        '--build-arg=+[k=v]:str:' \
        '*--build-arg=+[k=v]:str:' \
        '--push[push image]' \
        '--remote-only[remote-only build]' \
        '--local-only[local-only build]' \
        '--no-cache[no cache]' \
        '--image=+[image]:str:' \
        '--strategy=+[s]:s:(canary rolling bluegreen immediate)' \
        '--max-unavailable=+[N]:str:' \
        '--ha[HA mode]' \
        '--auto-stop=+[mode]:m:(off suspend stop)' \
        '--auto-start[auto start]' \
        '--min-machines-running=+[N]:n:' \
        '--update-only[update only]' \
        '--no-deploy[no deploy]' \
        '--vm-arch=+[a]:a:(amd64 arm64)' \
        '--env=+[k=v]:str:' \
        '*--env=+[k=v]:str:' \
        '--no-public-ips[no public IPs]' \
        '--internal-port=+[port]:n:' \
        '--port=+[port]:n:' \
        '--volume=+[name:path]:str:' \
        '*--volume=+[name:path]:str:' \
        '--container-image=+[image]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fly subcommand' sub ;;
        args)
            case $words[1] in
                apps|orgs|secrets|certs|volumes|machine|releases|ips|tokens|wireguard|services) _arguments '1:op:(list create destroy delete show update list-all suspend resume open clone)' '*:name:' ;;
                postgres|redis|nats|mysql|mpg|storage) _arguments '1:op:(list create attach detach connect db restart)' '*:arg:' ;;
                ssh) _arguments '1:op:(console issue log establish sftp)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_flyctl2 "$@"
