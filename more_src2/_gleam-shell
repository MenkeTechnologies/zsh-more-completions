#compdef gleam-shell
# _gleam-shell — Gleam interactive shell alias (Gleam team / Louis Pilfold, Rust); clap-rs
# upstream: https://github.com/gleam-lang/gleam

_gleam-shell() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--target=+[target]:t:(erlang javascript)' \
        '-t+[target]:t:(erlang javascript)' \
        '--no-print-progress[no print progress]' \
        '--no-types[no types]' \
        '--manifest=+[manifest file]:file:_files -g "manifest.toml"' \
        '--target-dir=+[target dir]:dir:_files -/' \
        '*:arg:'
}

_gleam-shell "$@"
