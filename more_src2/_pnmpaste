#compdef pnmpaste
# Documentation: man pnmpaste (Netpbm)
# Source: paste one Netpbm image into another at a given offset.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-replace -or -and -xor -nor -nand -nxor)-replace[overwrite destination pixels (default)]' \
    '(-replace -or -and -xor -nor -nand -nxor)-or[bitwise OR with destination]' \
    '(-replace -or -and -xor -nor -nand -nxor)-and[bitwise AND]' \
    '(-replace -or -and -xor -nor -nand -nxor)-xor[bitwise XOR]' \
    '(-replace -or -and -xor -nor -nand -nxor)-nor[bitwise NOR]' \
    '(-replace -or -and -xor -nor -nand -nxor)-nand[bitwise NAND]' \
    '(-replace -or -and -xor -nor -nand -nxor)-nxor[bitwise NXOR]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:from pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:x offset:' \
    '3:y offset:' \
    '4:into pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
