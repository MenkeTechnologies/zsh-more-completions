#compdef plzip
# _plzip-bin — plzip multi-threaded lzip (Antonio Diaz Diaz); lzip-compatible parallel implementation
# upstream: https://www.nongnu.org/lzip/plzip.html

_plzip-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-B --data-size)'{-B,--data-size}'+[data block size]:bytes:' \
        '(-c --stdout)'{-c,--stdout}'[stdout]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-F --recompress)'{-F,--recompress}'[force recompress]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-l --list)'{-l,--list}'[list]' \
        '(-n --threads)'{-n,--threads}'+[threads]:n:' \
        '(-o --output)'{-o,--output}'+[output]:file:_files' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-s --dictionary-size)'{-s,--dictionary-size}'+[dict size]:bytes:' \
        '(-t --test)'{-t,--test}'[test]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-0)-0[lvl 0]' \
        '(-1)-1[lvl 1]' \
        '(-2)-2[lvl 2]' \
        '(-3)-3[lvl 3]' \
        '(-4)-4[lvl 4]' \
        '(-5)-5[lvl 5]' \
        '(-6)-6[lvl 6 default]' \
        '(-7)-7[lvl 7]' \
        '(-8)-8[lvl 8]' \
        '(-9)-9[best]' \
        '*:file:_files'
}

_plzip-bin "$@"
