#compdef fixhead
# _fixhead — clean up / fix a FITS file header (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from fixhead.c (single-letter getopt-style).

_fixhead() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-b+[blank header lines to keep]:n:' \
        '-d+[root directory for input files]:dir:_files -/' \
        '-h[group HISTORY keywords at end of header]' \
        '-v[verbose output]' \
        '*:FITS file:_files -g "*.(fits|fit|fts)"'
}

_fixhead "$@"
