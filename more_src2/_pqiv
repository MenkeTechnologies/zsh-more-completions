#compdef pqiv
# Documentation: https://manpages.debian.org/testing/pqiv/pqiv.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[start fullscreen]' \
  '(-c --transparent-background)'{-c,--transparent-background}'[borderless transparent window]' \
  '(-i --hide-info-box)'{-i,--hide-info-box}'[hide info box]' \
  '(-d --slideshow-interval)'{-d+,--slideshow-interval=}'[slideshow seconds]:secs:' \
  '(-F --fade)'{-F,--fade}'[fade between images]' \
  '--fade-duration=[fade duration ms]:ms:' \
  '(-l --lazy-load)'{-l,--lazy-load}'[show window once first image loaded]' \
  '(-n --sort)'{-n,--sort}'[sort files]' \
  '--sort-key=[sort key]:key:(NAME MTIME)' \
  '--shuffle[shuffle file list]' \
  '(-r --additional-from-stdin)'{-r,--additional-from-stdin}'[read additional filenames from stdin]' \
  '--low-memory[minimise memory use]' \
  '(-s --slideshow)'{-s,--slideshow}'[start in slideshow mode]' \
  '(-t --scale-images-up)'{-t,--scale-images-up}'[scale images up to window size]' \
  '(-T --window-title)'{-T+,--window-title=}'[window title format]:fmt:' \
  '(-P --window-position)'{-P+,--window-position=}'[window x,y]:pos:' \
  '(-z --zoom-level)'{-z+,--zoom-level=}'[initial zoom level]:zoom:' \
  '--browse[load all images in directory of first arg]' \
  '--show-bindings[print key bindings and exit]' \
  '--actions-from-stdin[read actions from stdin]' \
  '--allow-empty-window[allow running without images]' \
  '--auto-montage-mode[start in montage mode]' \
  '--disable-backends=[disable image backends]:list:' \
  '--watch-directories[watch source directories for changes]' \
  '--font=[font specification]:font:' \
  '*:image file:_files' && ret=0

return ret
