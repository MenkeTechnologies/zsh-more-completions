#compdef natron Natron NatronRenderer
# Documentation: https://natron.readthedocs.io/en/rb-2.5/devel/natronexecution.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --background)'{-b,--background}'[background render mode]' \
  '*'{-w,--writer}'+[writer node and optional filename/frame range]:writer:' \
  '*'{-i,--reader}'+[override reader node input file]:reader:' \
  '(-l --onload)'{-l,--onload}'+[python script run after project load]:file:_files -g "*.py"' \
  '*'{-c,--cmd}'+[python command run before script]:cmd:' \
  '(-t --interpreter)'{-t,--interpreter}'[python interpreter mode]' \
  '*'{-o,--output}'+[replace Output node with Write]:opts:' \
  '(-s --render-stats)'{-s,--render-stats}'[generate render statistics file per frame]' \
  '*:project:_files -g "*.ntp"' && ret=0

return ret
