#compdef pnmtojbig
# Documentation: man pnmtojbig (Netpbm)
# Source: convert a Netpbm image to JBIG (Joint Bi-level Image) format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-q[encode in one resolution layer (sequential mode)]' \
    '-x+[max horizontal size of lowest layer]:number:' \
    '-y+[max vertical size of lowest layer]:number:' \
    '-l+[lowest resolution layer to write]:number:' \
    '-h+[highest resolution layer to write]:number:' \
    '-b[use binary instead of Gray-code values]' \
    '-d+[number of differential layers]:number:' \
    '-s+[stripe height]:number:' \
    '-m+[max adaptive template move]:number:' \
    '-o+[order byte (encoding flags)]:byte:' \
    '-p+[options byte]:byte:' \
    '-T+[template size]:number:' \
    '-Y+[lowest YH layer]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:jbig output:_files -g "*.jbg"' \
    && ret=0

return ret
