#compdef rebar
# Documentation: https://github.com/rebar/rebar/wiki/Home
# Source: rebar/rebar src/rebar.erl — legacy Rebar (v2) build tool for Erlang/OTP (Erlang).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show program options]' \
    {-c,--commands}'[show available commands]' \
    '*'{-v,--verbose}'[verbosity level (stackable)]' \
    {-q,--quiet}'[quiet mode]' \
    {-V,--version}'[show version]' \
    {-f,--force}'[force]' \
    '*-D+[define compiler macro]:macro:_default' \
    {-j+,--jobs=}'[number of concurrent workers]:n:_default' \
    {-C+,--config=}'[rebar config file]:file:_files -g "*.config"' \
    {-p,--profile}'[profile this run (fprof|eflame)]' \
    {-k,--keep-going}'[keep running after a command fails]' \
    {-r,--recursive}'[apply commands to dependencies recursively]' \
    '*:commands and var=value:_default' \
    && ret=0

return ret
