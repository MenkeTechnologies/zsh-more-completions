#compdef flwm
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/flwm.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flwm: Fast Light Window Manager (FLTK)

local curcontext="$curcontext" ret=1

_arguments -C \
  '-display[X display host:n.n]:display:' \
  '-visual[visual number]:n:' \
  '-geometry[managed area WxH+X+Y]:geom:' \
  '-maximum[max window size WxH]:size:' \
  '-x[menu shows Exit instead of Logout]' \
  '-fg[foreground/label color]:color:' \
  '-bg[background/frame color]:color:' \
  '-cursor[desktop cursor number]:n:' \
  '-cfg[cursor foreground color]:color:' \
  '-cbg[cursor background color]:color:' && ret=0

return ret
