#compdef oxker
# Documentation: https://github.com/mrjackwills/oxker
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-d+[minimum update interval in milliseconds (default 1000)]:ms:' \
  '(-r -c)-r[show unformatted logs (strip ANSI codes)]' \
  '(-r -c)-c[colorize logs]' \
  '-t[omit timestamps from log entries]' \
  '-s[show the oxker container itself when running via Docker]' \
  '-g[run in non-TUI (gui) debug mode]' \
  '--config-file=[location of config.toml, config.json or config.jsonc]:file:_files' \
  '--host=[Docker hostname (default /var/run/docker.sock)]:host' \
  '--no-stderr[exclude stderr output from logs]' \
  '--save-dir=[directory used for exporting logs]:dir:_directories' \
  '--timezone=[timezone for displayed timestamps]:tz' \
  '--use-cli[use Docker CLI instead of Docker API]' && ret=0

return ret
