#compdef nvlc
# Documentation: https://wiki.videolan.org/VLC_command-line_help/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. nvlc is the ncurses front-end
# of vlc and accepts the same playback flags.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(--verbose)'{-v,--verbose}'[increase verbosity]' \
  '--loop[loop playlist]' \
  '--repeat[repeat]' \
  '--random[random playback]' \
  '--play-and-exit[exit after playback]' \
  '--start-time=[start sec]:sec:' \
  '--stop-time=[stop sec]:sec:' \
  '--aout=[audio output]:mod:(pulse alsa jack file dummy)' \
  '--no-color[disable colors]' \
  '*:input:_files' && ret=0

return ret
