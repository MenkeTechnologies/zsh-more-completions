#compdef pcregrep
# Documentation: pcregrep --help (legacy PCRE)
# Source: grep-like regex search using PCRE.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-A --after-context)'{-A+,--after-context=}'[lines of trailing context]:n:' \
    '(-a --text)'{-a,--text}'[treat binary as text]' \
    '(-B --before-context)'{-B+,--before-context=}'[lines of leading context]:n:' \
    '--binary-files=[binary file treatment]:word:(binary without-match text)' \
    '--buffer-size=[processing buffer size]:n:' \
    '--color=[color mode]:opt:(never auto always)' \
    '--colour=[color mode]:opt:(never auto always)' \
    '(-C --context)'{-C+,--context=}'[lines of context before+after]:n:' \
    '(-c --count)'{-c,--count}'[count matching lines]' \
    '(-D --devices)'{-D+,--devices=}'[device-handling]:action:(read skip)' \
    '(-d --directories)'{-d+,--directories=}'[directory-handling]:action:(read skip recurse)' \
    '*'{-e+,--regex=,--regexp=}'[specify pattern]:pattern:' \
    '(-F --fixed-strings)'{-F,--fixed-strings}'[patterns are fixed strings]' \
    '(-f --file)'{-f+,--file=}'[read patterns from file]:file:_files' \
    '--file-list=[read filenames from file]:file:_files' \
    '--file-offsets[output file offsets, not text]' \
    '(-H --with-filename)'{-H,--with-filename}'[force filename prefix]' \
    '(-h --no-filename)'{-h,--no-filename}'[suppress filename prefix]' \
    '-I[skip binary files]' \
    '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive matching]' \
    '--no-jit[ignored (no JIT)]' \
    '(-l --files-with-matches)'{-l,--files-with-matches}'[print only filenames with matches]' \
    '(-L --files-without-match)'{-L,--files-without-match}'[print only filenames without matches]' \
    '--label=[name for stdin]:name:' \
    '--line-buffered[line-buffered output]' \
    '--line-offsets[output line numbers/offsets]' \
    '--locale=[locale]:locale:' \
    '--match-limit=[PCRE match limit]:n:' \
    '--recursion-limit=[PCRE recursion limit]:n:' \
    '(-M --multiline)'{-M,--multiline}'[multiline mode]' \
    '(-N --newline)'{-N+,--newline=}'[newline type]:type:(CR LF CRLF ANYCRLF ANY)' \
    '(-n --line-number)'{-n,--line-number}'[print line numbers]' \
    '(-o --only-matching)'{-o+,--only-matching=}'[print only matched part]:n:' \
    '--om-separator=[separator for multiple -o]:text:' \
    '(-q --quiet)'{-q,--quiet}'[suppress output, only exit code]' \
    '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
    '*--exclude=[exclude files matching pattern]:pattern:' \
    '*--include=[include only files matching pattern]:pattern:' \
    '*--exclude-dir=[exclude directories matching pattern]:pattern:' \
    '*--include-dir=[include only directories matching pattern]:pattern:' \
    '--exclude-from=[exclude list file]:file:_files' \
    '--include-from=[include list file]:file:_files' \
    '(-s --no-messages)'{-s,--no-messages}'[suppress error messages]' \
    '(-u --utf-8)'{-u,--utf-8}'[UTF-8 mode]' \
    '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
    '(-w --word-regex --word-regexp)'{-w,--word-regex,--word-regexp}'[match whole words]' \
    '(-x --line-regex --line-regexp)'{-x,--line-regex,--line-regexp}'[match whole lines]' \
    '*:pattern or file:_files' \
    && ret=0

return ret
