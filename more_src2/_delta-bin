#compdef delta
# _delta-bin — delta git/diff syntax-highlighting pager (Dan Davison, Rust); used as core.pager and difftool for git
# upstream: https://github.com/dandavison/delta

_delta-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-n --line-numbers)'{-n,--line-numbers}'[show line numbers]' \
        '(-s --side-by-side)'{-s,--side-by-side}'[side-by-side view]' \
        '--diff-so-fancy[emulate diff-so-fancy]' \
        '--navigate[regex-based hunk navigation]' \
        '--keep-plus-minus-markers[keep +/- markers]' \
        '--features+[feature set name]:str:' \
        '--syntax-theme+[bat syntax theme]:theme:' \
        '--commit-style+[commit style]:str:(raw plain box omit)' \
        '--commit-decoration-style+[commit decoration]:str:' \
        '--file-style+[file style]:str:(raw plain box omit)' \
        '--file-decoration-style+[file decoration]:str:' \
        '--hunk-header-style+[hunk header style]:str:(raw plain box omit)' \
        '--hunk-header-decoration-style+[hunk header decoration]:str:' \
        '--minus-style+[minus line style]:str:' \
        '--minus-emph-style+[minus emph style]:str:' \
        '--plus-style+[plus line style]:str:' \
        '--plus-emph-style+[plus emph style]:str:' \
        '--zero-style+[zero (context) line style]:str:' \
        '--whitespace-error-style+[whitespace error style]:str:' \
        '--word-diff-regex+[word diff regex]:regex:' \
        '--max-line-length+[max line length]:n:' \
        '--paging+[paging mode]:mode:(always never auto)' \
        '--color-only[color-only]' \
        '--width+[width]:n:' \
        '--tabs+[tabs]:n:' \
        '--true-color+[truecolor]:mode:(always auto never)' \
        '--show-config[print config]' \
        '--show-syntax-themes[list syntax themes]' \
        '--show-themes[list bundled themes]' \
        '--show-colors[list colors]' \
        '--list-languages[list bat languages]' \
        '--list-syntax-themes[list bat syntax themes]' \
        '--parse-ansi[parse already-colorized input]' \
        '--default-language+[default lang]:lang:' \
        '--detect-dark-light+[detect bg]:mode:(auto always never)' \
        '--light[force light bg]' \
        '--dark[force dark bg]' \
        '--diff-stat-align-width+[diff stat align]:n:' \
        '*:file:_files'
}

_delta-bin "$@"
