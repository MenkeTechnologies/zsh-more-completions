#compdef lmms-cli
# _lmms-cli — LMMS Linux MultiMedia Studio DAW CLI alias (LMMS team, C++); custom argparse
# upstream: https://github.com/LMMS/lmms

_lmms-cli() {
    local -a sub=(
        'render:render project to audio'
        'rendertracks:render each track separately'
        'upgrade:upgrade old project file'
        'dump:dump project as XML'
        'compress:compress project as MMPZ'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--allowroot[allow running as root]' \
        '--config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--geometry=+[geometry]:str:' \
        '-geometry+[geometry]:str:' \
        '--nommx[disable mmx]' \
        '--nosse[disable sse]' \
        '--no-mmx[disable mmx]' \
        '--no-sse[disable sse]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lmms subcommand' sub ;;
        args)
            case $words[1] in
                render|rendertracks) _arguments \
                    '1:project file:_files -g "*.{mmp,mmpz,xml}"' \
                    '-o+[output file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '-f+[format]:f:(wav ogg mp3 flac)' \
                    '--format=+[format]:f:(wav ogg mp3 flac)' \
                    '-s+[samplerate hz]:n:' \
                    '--samplerate=+[samplerate hz]:n:' \
                    '-b+[bitrate kbps]:n:' \
                    '--bitrate=+[bitrate kbps]:n:' \
                    '-i+[interpolation]:m:(none linear sincfastest sincmedium sincbest)' \
                    '--interpolation=+[interpolation]:m:(none linear sincfastest sincmedium sincbest)' \
                    '-x+[oversampling]:m:(1 2 4 8)' \
                    '--oversampling=+[oversampling]:m:(1 2 4 8)' \
                    '-d+[bit depth]:m:(16 24 32)' \
                    '--bitdepth=+[bit depth]:m:(16 24 32)' \
                    '-l[loop]' \
                    '--loop[loop]' \
                    '--profile=+[profile dir]:dir:_files -/' ;;
                upgrade|dump|compress) _arguments \
                    '1:project file:_files -g "*.{mmp,mmpz,xml}"' \
                    '-o+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_lmms-cli "$@"
