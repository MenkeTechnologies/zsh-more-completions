#compdef pnmtoxwd
# Documentation: man pnmtoxwd (Netpbm)
# Source: convert a Netpbm image to an X11 window-dump (XWD) file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-pseudodepth+[pseudo-color depth in bits]:n:' \
    '-directcolor[force DirectColor output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
