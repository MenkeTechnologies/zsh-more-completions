#compdef gws
# Documentation: https://github.com/StreakyCobra/gws
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Git workspaces manager (StreakyCobra/gws)

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'init:detect existing repositories and create .projects.gws'
  'update:clone missing repositories from the projects list'
  'clone:clone a specified selection of missing repositories'
  'status:monitor all listed repositories (default)'
  'fetch:fetch modifications from origin for all repositories'
  'ff:pull modifications from origin (fast-forward only)'
  'check:check the workspace for all repositories'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--only-changes[show only repositories with changes]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'gws' subcmds && ret=0
    ;;
  rest)
    _files
    ;;
esac

return ret
