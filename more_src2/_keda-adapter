#compdef keda-adapter keda-metrics-apiserver
# _keda-adapter — KEDA external/custom metrics adapter
# upstream: https://github.com/kedacore/keda
# Flags from cmd/adapter/main.go cmd.Flags on tip.

_keda-adapter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--msg=[startup message]:msg:' \
        '--port=[metrics API server port]:port:' \
        '--metrics-service-address=[KEDA gRPC Metrics Service address]:host\:port:' \
        '--metrics-service-grpc-authority=[gRPC Host Authority override]:authority:' \
        '--profiling-bind-address=[profiling bind host\:port]:host\:port:' \
        '--kube-api-burst=[K8s API burst]:n:' \
        '--disable-compression=[disable client-go response compression]:bool:(true false)' \
        '-v[verbosity (DEPRECATED)]:n:' \
        '--logtostderr=[log to stderr (DEPRECATED)]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold (DEPRECATED)]:level:(INFO WARNING ERROR FATAL)' \
        '--secure-port=[secure-serving bind port]:port:' \
        '--cert-dir=[secure-serving cert directory]:dir:_files -/' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS private key file]:file:_files' \
        '--authentication-kubeconfig=[delegated authn kubeconfig]:file:_files' \
        '--authorization-kubeconfig=[delegated authz kubeconfig]:file:_files' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--zap-devel[enable development zap logging]' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)'
}

_keda-adapter "$@"
