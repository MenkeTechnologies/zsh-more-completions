#compdef ghc-events
# _ghc-events — inspect/merge GHC RTS eventlog (.eventlog) files (haskell/ghc-events)
# upstream: https://github.com/haskell/ghc-events
# Subcommands from GhcEvents.hs.

_ghc-events() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'inc:print events incrementally from file'
                'show:pretty-print eventlog (with optional threads/caps view)'
                'merge:merge two eventlogs into one'
                'validate:run a state-machine validator on the eventlog'
                'simulate:simulate a state-machine on the eventlog'
                'profile:profile sparks or threads from an eventlog'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                show)
                    _arguments '--pretty-time[render timestamps pretty]' \
                               '1:sub:(threads caps)' \
                               '2:eventlog:_files -g "*.eventlog"'
                    ;;
                inc) _arguments '1:sub:(force)' '2:eventlog:_files -g "*.eventlog"' ;;
                merge) _arguments '1:output:_files' '2:in1:_files -g "*.eventlog"' '3:in2:_files -g "*.eventlog"' ;;
                validate|simulate|profile)
                    _arguments '1:sub:(threads threadpool threadrun taskpool tasks sparks)' \
                               '2:eventlog:_files -g "*.eventlog"'
                    ;;
            esac
            ;;
    esac
}

_ghc-events "$@"
