_onetun() {
    _arguments -s -S \
        '--private-key=[this peer private key (env ONETUN_PRIVATE_KEY)]:key:' \
        '--private-key-file=[file containing private key (env ONETUN_PRIVATE_KEY_FILE)]:file:_files' \
        '--endpoint-public-key=[REMOTE WireGuard endpoint public key (REQUIRED; env ONETUN_ENDPOINT_PUBLIC_KEY)]:key:' \
        '--preshared-key=[PSK (env ONETUN_PRESHARED_KEY)]:key:' \
        '--endpoint-addr=[REMOTE endpoint IP:PORT (REQUIRED; env ONETUN_ENDPOINT_ADDR)]:addr:' \
        '--endpoint-bind-addr=[local UDP socket bind IP:PORT (env ONETUN_ENDPOINT_BIND_ADDR)]:addr:' \
        '--source-peer-ip=[local source IP for this peer (REQUIRED; env ONETUN_SOURCE_PEER_IP)]:ip:' \
        '--keep-alive=[persistent keepalive seconds (env ONETUN_KEEP_ALIVE)]:sec:' \
        '--max-transmission-unit=[MTU (default 1420; env ONETUN_MTU)]:bytes:' \
        '--log=[log level (default info)]:level:(trace debug info warn error)' \
        '--pcap=[decrypt + capture IP packets to PCAP file (env ONETUN_PCAP)]:file:_files -g "*.pcap"' \
        '*'{-r,--remote}'=[remote port-forward (src_port:dst_host:dst_port[:TCP,UDP])]:remote-port-forward:' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:port-forward (src_host:src_port:dst_host:dst_port[:TCP,UDP]):'
}

