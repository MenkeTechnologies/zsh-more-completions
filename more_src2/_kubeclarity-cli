#compdef kubeclarity-cli
# Documentation: https://github.com/openclarity/kubeclarity/tree/main/cli/cmd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[config file (default is $HOME/.kubeclarity.yaml)]:file:_files' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'analyze:analyze a source and generate an SBOM'
      'scan:scan an SBOM or source for vulnerabilities'
      'convert:convert an SBOM between formats'
    )
    _describe -t commands 'kubeclarity-cli command' commands && ret=0
    ;;
  args)
    case $line[1] in
      analyze)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
          '(-i --input-type)'{-i+,--input-type=}'[set input type]:type:' \
          '--application-id=[the relevant application ID]:id:' \
          '(-e --export)'{-e,--export}'[export results to the KubeClarity backend]' \
          '--merge-sbom=[merge an input SBOM file]:file:_files' \
          '*:source:_files' && ret=0
        ;;
      scan)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-o --output)'{-o+,--output=}'[report output formatter]:format:' \
          '(-f --file)'{-f+,--file=}'[file to write the report output to]:file:_files' \
          '(-i --input-type)'{-i+,--input-type=}'[set input type]:type:' \
          '--application-id=[the relevant application ID]:id:' \
          '(-e --export)'{-e,--export}'[export results to the KubeClarity backend]' \
          '--cis-docker-benchmark-scan[run a CIS Docker benchmark scan]' \
          '--ignore-no-fix[ignore vulnerabilities that have no fix available]' \
          '*--ignore-vul=[ignore list of vulnerabilities]:vuln:' \
          '*:source:_files' && ret=0
        ;;
      convert)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-i --input-sboms)'{-i+,--input-sboms=}'[input filename]:file:_files' \
          '(-o --output-sbom)'{-o+,--output-sbom=}'[output filename]:file:_files' \
          '--output-format=[output format]:format:' && ret=0
        ;;
    esac
    ;;
esac

return ret
