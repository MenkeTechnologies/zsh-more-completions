#compdef pbmtoxbm
# Documentation: man pbmtoxbm (Netpbm)
# Source: convert a PBM image to an X11 (or X10) bitmap.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-x10 -x11)-x10[X10-format output]' \
    '(-x10 -x11)-x11[X11-format output (default)]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
