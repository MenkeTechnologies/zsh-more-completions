#compdef rocksdb_ldb ldb
# Documentation: https://github.com/facebook/rocksdb/wiki/Administration-and-Data-Access-Tool
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (and tools/ldb_cmd.cc).

# rocksdb_ldb: RocksDB administration / debugging tool
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'get:get a key'
  'put:put a key/value'
  'delete:delete a key'
  'single_delete:single-delete a key'
  'delete_range:delete a key range'
  'multiget:get multiple keys'
  'get_entity:get a wide-column entity'
  'multiget_entity:get multiple entities'
  'put_entity:put a wide-column entity'
  'batchput:batch put many key/value pairs'
  'scan:scan keys'
  'query:interactive query mode'
  'approxsize:approximate size of key range'
  'compact:compact key range'
  'wal_dump:dump WAL files (alias of dump_wal)'
  'dump_wal:dump a WAL file'
  'dump:dump database to hex'
  'idump:internal dump'
  'load:load data from dump'
  'reduce_levels:reduce LSM levels'
  'change_compaction_style:change compaction style'
  'manifest_dump:dump MANIFEST'
  'file_checksum_dump:dump file checksums'
  'get_property:get a database property'
  'list_column_families:list column families'
  'create_column_family:create a column family'
  'drop_column_family:drop a column family'
  'db_files_dump:dump live SST file metadata'
  'db_live_files_metadata_dump:dump live files metadata'
  'checkconsistency:check database consistency'
  'checkpoint:create a checkpoint'
  'repair:repair a corrupted database'
  'backup:create a backup'
  'restore:restore from backup'
  'write_external_sst:write external SST'
  'ingest_external_sst:ingest external SST'
  'list_file_range_deletes:list range tombstones'
  'unsafe_remove_sst_file:remove SST file (unsafe)'
  'update_manifest:update manifest'
  'dump_compaction_progress:dump compaction progress'
)
_arguments -C \
  '(- *)--help[show help]' \
  '--db=[database directory]:dir:_files -/' \
  '--column_family=[column family]:cf:' \
  '--cf_name=[column family]:cf:' \
  '--secondary_path=[secondary path]:dir:_files -/' \
  '--hex[interpret keys/values as hex]' \
  '--key_hex[hex keys]' \
  '--value_hex[hex values]' \
  '--try_load_options[load options from db]' \
  '--ignore_unknown_options[ignore unknown options]' \
  '--bloom_bits=[bloom bits]:n:' \
  '--compression_type=[compression type]:type:(snappy lz4 zlib zstd none bzip2 lz4hc xpress)' \
  '--block_size=[block size]:bytes:' \
  '--auto_compaction=[auto compaction]:bool:(true false)' \
  '--ttl[treat data as TTL]' \
  '--timestamp[print timestamps]' \
  '--from=[start key]:key:' \
  '--to=[end key]:key:' \
  '--max_keys=[max keys]:n:' \
  '--write_buffer_size=[write buffer size]:bytes:' \
  '--file_size=[file size]:bytes:' \
  '--create_if_missing[create DB if missing]' \
  '--no_value[only show keys]' \
  '--fix_prefix_len=[fix prefix length]:n:' \
  '--decode_blob_index[decode blob index]' \
  '--dump_uncompressed_blobs[dump uncompressed blobs]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'rocksdb_ldb command' commands && ret=0 ;;
esac
return ret
