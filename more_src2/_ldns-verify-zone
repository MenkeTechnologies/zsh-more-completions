#compdef ldns-verify-zone
# _ldns-verify-zone — NLnet Labs ldns-verify-zone (DNSSEC zone verifier; checks NSEC(3) chain + signatures + ZONEMD on a signed zonefile)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-verify-zone.c usage on tip.

_ldns-verify-zone() {
    _arguments \
        '-h[show help]' \
        '-a[apex only — check the zone apex only]' \
        '-e+[signatures may not expire within this period]:period:' \
        '-i+[signatures must have been valid at least this long]:period:' \
        '*-k+[trusted DNSKEY/DS file (repeatable)]:file:_files' \
        '-p+[only check this percentage of the zone (0-100)]:pct:' \
        '-s[check all signatures, not just one per RRset]' \
        '-S[chase signatures to a known key (network access)]' \
        '-t+[allowed time-jitter when chasing]:sec:' \
        '-V+[verbosity level]:n:(0 1 2 3 4 5)' \
        '-Z[require ZONEMD match (one of)]' \
        '-v[show version and exit]' \
        '1:zonefile:_files'
}

_ldns-verify-zone "$@"
