#compdef mount_lfs
# Documentation: man mount_lfs(8)
# Source: netbsd/src sbin/mount_lfs — mount a log-structured file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[count bytes written rather than segments read]' \
    '-d[run the cleaner in debug mode]' \
    '-i[use filesystem idle time for aggressive cleaning]' \
    '-N+[segments (or bytes with -b) to clean at once]:nsegs:_default' \
    '-n[do not start the cleaner]' \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '-s[read data in small chunks when cleaning]' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
