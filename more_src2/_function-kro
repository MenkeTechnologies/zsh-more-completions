#compdef function-kro
# _function-kro — Crossplane composition function that runs ResourceGroupDefinitions (kro.run RGDs) inside a Crossplane composition pipeline (gRPC server consumed by crossplane)
# upstream: https://github.com/crossplane-contrib/function-kro
# Flags from main.go on tip (alecthomas/kong).

_function-kro() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[emit debug logs in addition to info logs]' \
        '--network=[network on which to listen for gRPC connections]:net:(tcp unix)' \
        '--address=[address on which to listen for gRPC connections]:addr:' \
        '--tls-server-certs-dir=[directory containing server tls.key + tls.crt + ca.crt]:dir:_files -/' \
        '--insecure[run without mTLS credentials (--tls-server-certs-dir is ignored)]' \
        '--max-recv-message-size=[max received message size (MB)]:n:' \
        '--feature-gates=[csv of feature gates (e.g. CELOmitFunction=true)]:gates:' \
        '--rgd-max-collection-size=[max resources in a single collection]:n:' \
        '--rgd-max-collection-dim-size=[max dimensions in a forEach]:n:'
}

_function-kro "$@"
