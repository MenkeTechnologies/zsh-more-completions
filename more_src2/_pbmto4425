#compdef pbmto4425
# Documentation: man pbmto4425 (Netpbm)
# Source: convert a PBM image to AT&T DataPhone 4425 escape sequences.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
