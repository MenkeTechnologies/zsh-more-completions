#compdef opensc-tool
# Documentation: https://github.com/OpenSC/OpenSC/blob/master/src/tools/opensc-tool.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for opensc-tool - OpenSC utility

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --atr)'{-a,--atr}'[print ATR of inserted card]' \
  '(-n --name)'{-n,--name}'[print name of inserted card]' \
  '(-l --list-readers)'{-l,--list-readers}'[list configured readers]' \
  '(-D --list-drivers)'{-D,--list-drivers}'[list available card drivers]' \
  '--list-algorithms[list algorithms supported by card]' \
  '(-f --list-files)'{-f,--list-files}'[recursively list all files on card]' \
  '(-i --info)'{-i,--info}'[print OpenSC info]' \
  '*'{-s+,--send-apdu=}'[send APDU command]:APDU' \
  '(-r --reader)'{-r+,--reader=}'[select reader number or ATR]:reader' \
  '(-c --card-driver)'{-c+,--card-driver=}'[force card driver]:driver' \
  '(-G --get-conf-entry)'{-G+,--get-conf-entry=}'[read config entry section:name:key]:entry' \
  '(-S --set-conf-entry)'{-S+,--set-conf-entry=}'[write config entry section:name:key:value]:entry' \
  '--reset[reset the card (cold|warm)]::mode:(cold warm)' \
  '(-w --wait)'{-w,--wait}'[wait for card insertion]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--serial[print card serial number]' && ret=0

return ret
