#compdef deep
# Documentation: https://github.com/deepchecks/deepchecks
# Reference accessed: 2026-05-23
# Verified: deep --help (deepchecks PyPI console script).

# Zsh completion for deep - Deepchecks CLI utilities

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'deep command' \
      'diff[deep diff command line]' \
      'extract[deep extract command line]' \
      'grep[deep grep command line]' \
      'patch[deep patch command line]' && ret=0
    ;;
esac

return ret
