#compdef icetime
# Documentation: https://github.com/YosysHQ/icestorm/blob/master/icetime/icetime.cc
# Reference accessed: 2026-05-27
# Verified: upstream getopt string "p:P:g:o:r:j:d:mitT:Nvc:C:" in icetime/icetime.cc

# icetime: Project IceStorm static timing analyzer for Lattice iCE40 FPGAs.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-p+[read PCF file for pin configuration]:pcf file:_files -g "*.pcf"' \
  '-P+[chip package selection]:package:' \
  '-g+[write graphviz interconnect tree for net index]:net index:' \
  '-o+[write verilog netlist (use - for stdout)]:output file:_files' \
  '-r+[write timing report to file]:report file:_files' \
  '-j+[write timing report in JSON format]:json file:_files' \
  '-d+[select device variant]:device:(lp384 lp1k lp4k lp8k hx1k hx4k hx8k up3k up5k u1k u2k u4k)' \
  '-m[use conservative timing estimates]' \
  '-i[restrict analysis to interior timing paths only]' \
  '-t[generate timing report using topological analysis]' \
  '-T+[generate report for specific net name]:net name:' \
  '-N[list valid net names for use with -T]' \
  '-v[verbose output]' \
  '-c+[validate timing against clock constraint in MHz]:max clock MHz:' \
  '-C+[read chip database from file]:chipdb file:_files' \
  '*:asc file:_files -g "*.asc"' && ret=0

return ret
