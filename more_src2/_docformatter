#compdef docformatter
# Documentation: https://docformatter.readthedocs.io/en/latest/usage.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# docformatter — formats Python docstrings to PEP 257.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-r --recursive)'{-r,--recursive}'[process directories recursively]' \
  '*'{-e,--exclude}'[exclude files/directories matching glob]:glob:' \
  '-d[show diff output]' \
  '(-c --check)'{-c,--check}'[return error code if changes needed]' \
  '(-i --in-place)'{-i,--in-place}'[modify files in-place]' \
  '--config=[configuration file path]:file:_files' \
  '*'{-n,--non-cap}'[words to exclude from capitalization]:word:' \
  '(-s --style)'{-s,--style}'=[docstring style]:style:(epytext sphinx)' \
  '--rest-section-adorns=[regex for reST section markers]:regex:' \
  '--black[align with black formatter standards]' \
  '--wrap-summaries=[wrap summary lines at given length]:length:' \
  '--wrap-descriptions=[wrap description lines at given length]:length:' \
  '--force-wrap[force wrapping aggressively]' \
  '--tab-width=[spaces per tab]:width:' \
  '--blank[insert blank line after descriptions]' \
  '--pre-summary-newline[add newline before summary]' \
  '--pre-summary-space[add space after opening quotes]' \
  '--make-summary-multi-line[convert single-line to multi-line]' \
  '--close-quotes-on-newline[place closing quotes on separate line]' \
  '--range=[format docstrings within line range]:range:' \
  '--docstring-length=[target docstrings of length range]:range:' \
  '--non-strict[relax reST syntax requirements]' \
  '*:files:_files -g "*.py"'
