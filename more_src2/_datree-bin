#compdef datree
# _datree-bin — Datree k8s manifest policy checker (Datree.io, Go); detect misconfigs in k8s/helm/kustomize manifests
# upstream: https://github.com/datreeio/datree

_datree-bin() {
    local -a sub=(
        'completion:print shell completion'
        'config:configure Datree'
        'help:show help'
        'kustomize:run on kustomize'
        'publish:publish policy yaml'
        'test:test manifests against policies'
        'validate:validate datree config'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datree subcommand' sub ;;
        args)
            case $words[1] in
                test) _arguments \
                    '--ignore-missing-schemas[ignore missing CRD schemas]' \
                    '--no-record[do not record results]' \
                    '--only-k8s-files[only k8s manifest files]' \
                    '--output+[output format]:fmt:(simple yaml json xml junit sarif jsonc)' \
                    '-o+[output format]:fmt:' \
                    '--policy+[policy name]:str:' \
                    '-p+[policy name]:str:' \
                    '--schema-location+[schema location]:url:_urls' \
                    '--schema-version+[k8s version]:v:' \
                    '-s+[k8s version]:v:' \
                    '--verbose[verbose]' \
                    '*:file:_files' ;;
                config) _arguments '1:config cmd:(get set update)' '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_datree-bin "$@"
