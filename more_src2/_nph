#compdef nph
# Documentation: https://arnetheduck.github.io/nph/usage.html
# Documentation: https://github.com/arnetheduck/nph
# Reference accessed: 2026-05-27
# Verified: upstream nph usage.html flag table and README.

# nph - opinionated Nim source code formatter

_arguments \
  '--check[verify files are formatted, exit 1 if changes needed]' \
  '--diff[show unified diff of formatting changes without modifying files]' \
  '--outdir=[write output to specified directory instead of in place]:dir:_directories' \
  '*--exclude=[replace default exclusion regex patterns (repeatable)]:pattern:' \
  '*--extend-exclude=[append regex pattern to default exclusions (repeatable)]:pattern:' \
  '*--include=[only format files matching regex pattern (repeatable)]:pattern:' \
  '--color[enable colored diff output]' \
  '--no-color[disable colored diff output (default)]' \
  '--config=[custom config file path (default .nph.toml)]:file:_files' \
  '--version[display version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:file:_files -g "*.nim"'
