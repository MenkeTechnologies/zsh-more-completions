#compdef gdcminfo
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcminfo.cxx — display meta info about DICOM files (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input DICOM file or directory]:file:_files' \
    '(-r --recursive)'{-r,--recursive}'[recursive]' \
    '(-d --check-deflated)'{-d,--check-deflated}'[check if file uses proper deflated syntax]' \
    '--resources-path=[Resources path]:dir:_files -/' \
    '--md5sum[compute md5sum of Pixel Data]' \
    '--check-compression[check encapsulated stream compression]' \
    '--force-rescale[force rescale]' \
    '--force-spacing[force spacing]' \
    '--mosaic[dump image info of MOSAIC]' \
    '--scipm[include Image Plane Module for Secondary Capture]' \
    '(-V --verbose)'{-V,--verbose}'[verbose (warning+error)]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '*:DICOM file:_files -g "*.{dcm,DCM,dicom}"' \
    && ret=0

return ret
