#compdef great-expectations great_expectations great-expectations-cli ge-cli great_expectations-cli ge
# _great-expectations — Great Expectations great-expectations CLI command-line frontend wrapping the Great Expectations data quality validation framework managing data context expectation suites checkpoints datasource validation profiler-build-docs-suite-edit-suite-demo-build-docs-suite-init-init-project-suite-list-store-list-store-cli (Great Expectations team, Python); click
# upstream: https://greatexpectations.io/

_great-expectations() {
    local -a sub=(
        'init:initialize a Great Expectations project'
        'datasource:datasource management'
        'suite:expectation suite management'
        'checkpoint:checkpoint management'
        'docs:data docs operations'
        'store:store management'
        'project:project operations'
        'tap:run tap'
        'plugin:plugin management'
        'profile:profile data'
        'validation-result:validation result operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "great_expectations.yml *.yml"' \
        '-c+[context dir]:dir:_files -/' \
        '--context-root-dir=+[dir]:dir:_files -/' \
        '--profile=+[name]:str:' \
        '--yes[assume yes]' \
        '-y[assume yes]' \
        '--no-prompt[no prompt]' \
        '--assume-yes[assume yes]' \
        '--no-color[disable color]' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'great-expectations subcommand' sub ;;
        args)
            case $words[1] in
                datasource) _arguments '1:op:(list new delete profile)' '*:name:' ;;
                suite) _arguments '1:op:(list new edit delete demo)' '*:name:' ;;
                checkpoint) _arguments '1:op:(list new run delete script)' '*:name:' ;;
                docs) _arguments '1:op:(list build clean)' ;;
                store) _arguments '1:op:(list)' ;;
                validation-result) _arguments '1:op:(list)' ;;
            esac
            ;;
    esac
}

_great-expectations "$@"
