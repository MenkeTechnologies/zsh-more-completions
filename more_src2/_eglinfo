#compdef eglinfo
# _eglinfo — print EGL/GLES/OpenGL/OpenVG configuration info (dv1/eglinfo)
# upstream: https://github.com/dv1/eglinfo
# Flags from src/main.cpp (getopt).

_eglinfo() {
    _arguments \
        '(- *)-h[show help]' \
        '-w+[output format]:writer:(json text)' \
        '-d+[native display name]:display:' \
        '-r[raw JSON output (no pretty print)]'
}

_eglinfo "$@"
