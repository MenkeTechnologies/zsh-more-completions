#compdef pm-powersave
# Documentation: man pm-powersave(8)
# Source: openSUSE/pm-utils src/pm-powersave.in (master) — enable/disable powersave hooks (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:mode:(false ac true battery help)' \
    '--help[show help with variable docs]' \
    && ret=0

return ret
