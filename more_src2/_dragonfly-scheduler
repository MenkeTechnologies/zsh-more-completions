#compdef dragonfly-scheduler d7y-scheduler
# _dragonfly-scheduler — Dragonfly P2P task scheduler (dragonflyoss/dragonfly)
# upstream: https://github.com/dragonflyoss/dragonfly
# Subcommands from cmd/dependency/dependency.go (cobra).

_dragonfly-scheduler() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[YAML config file path]:file:_files -g "*.(yml|yaml)"' \
        '--console[log to stdout in addition to file]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'version:print version'
                'plugin:manage scheduler plugins'
                'doc:generate docs from cobra commands'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_dragonfly-scheduler "$@"
