#compdef mpost pmpost
# Documentation: mpost --help (MetaPost 3.00)
# Source: TeX MetaPost — picture description language for technical illustrations.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-debug[print debugging info; leave temp files in place]' \
    '-mem=[macro preload file]:string:' \
    '-numbersystem=[number system mode]:mode:(scaled double binary interval decimal)' \
    '-restricted[disable tex/makempx/editor commands]' \
    '-tex=[TeX program for text labels]:tex:_command_names -e' \
    '(-troff -T)-troff[set prologues:=1 and treat TEXPROGRAM as troff]' \
    '(-troff -T)-T[alias for -troff]' \
    '*-s+[set internal INTERNAL]:name=value:' \
    '(-file-line-error -no-file-line-error)-file-line-error[file\:line\:error style messages]' \
    '(-file-line-error -no-file-line-error)-no-file-line-error[do not use file\:line\:error style]' \
    '-halt-on-error[stop at first error]' \
    '(- *)-help[show help]' \
    '-ini[do not load preload file]' \
    '-interaction=[interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
    '-jobname=[job name]:string:' \
    '-kpathsea-debug=[kpathsea debug bitmask]:n:' \
    '-no-kpathsea[do not use kpathsea for file lookup]' \
    '-output-directory=[output directory]:dir:_files -/' \
    '-progname=[program name]:string:' \
    '-recorder[enable filename recorder]' \
    '(--shell-escape --no-shell-escape --shell-restricted)-shell-escape[enable system commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)-no-shell-escape[disable system commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)-shell-restricted[restrict system commands]' \
    '-synctex=[enable SyncTeX (bitmask)]:n:' \
    '(- *)-version[show version]' \
    '(- *)-dvitomp[act as DVI-to-MPX converter only]' \
    '*:MetaPost or DVI source:_files -g "*.{mp,dvi,mem,mpx}"' \
    && ret=0

return ret
