#compdef pnpm-dlx
# Documentation: https://pnpm.io/cli/dlx
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*--package=[package to install before running command]:package' \
  '--allow-build=[packages allowed to run postinstall scripts]:packages' \
  {-c,--shell-mode}'[execute as shell command]' \
  {-s,--silent}'[only show output from executed command]' \
  '*::command:_command_names -e' && ret=0

return ret
