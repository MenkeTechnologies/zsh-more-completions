#compdef iocextract
# _iocextract — extract IoCs from text (InQuest/python-iocextract)
# upstream: https://github.com/InQuest/python-iocextract
# Flags from iocextract.py (argparse).

_iocextract() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
        '(-ee --extract-emails)'{-ee,--extract-emails}'[extract emails]' \
        '(-ip --extract-ips)'{-ip,--extract-ips}'[extract IPs]' \
        '-ip4[extract IPv4 only]' \
        '-ip6[extract IPv6 only]' \
        '(-u --extract-urls)'{-u,--extract-urls}'[extract URLs]' \
        '(-y --extract-yara-rules)'{-y,--extract-yara-rules}'[extract YARA rules]' \
        '(-ha --extract-hashes)'{-ha,--extract-hashes}'[extract hashes]' \
        '(-cr --custom-regex)'{-cr+,--custom-regex=}'[custom regex file]:file:_files' \
        '(-r --refang)'{-r,--refang}'[refang extracted IoCs]' \
        '(-su --strip-urls)'{-su,--strip-urls}'[strip URL paths]' \
        '-ri[remove IoC duplicates]' \
        '-rm[remove non-printable chars]' \
        '(-j --json)'{-j,--json}'[output as JSON]' \
        '(-d --dir)'{-d+,--dir=}'[input directory]:dir:_files -/' \
        '(-dn --dirname)'{-dn,--dirname}'[include dir name in output]' \
        '--url=[URL to scan]:url:' \
        '--open[open extracted URLs]' \
        '--wide[wide output format]'
}

_iocextract "$@"
