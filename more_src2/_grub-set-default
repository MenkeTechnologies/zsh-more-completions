#compdef grub-set-default grub2-set-default
# _grub-set-default — GRUB grub-set-default (set the default OS entry GRUB boots into; --boot-directory points at /boot/grub when not at default location; positional arg is either a numeric index or the literal entry title)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-set-default.in on tip.

_grub-set-default() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--boot-directory+[/boot/grub directory]:dir:_files -/' \
        '1:entry index or title:'
}

_grub-set-default "$@"
