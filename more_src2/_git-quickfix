#compdef git-quickfix
# Documentation: https://github.com/siedentop/git-quickfix
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Quickly fix a single commit on a separate branch

_git_quickfix_branches() {
  local -a branches
  branches=(${(f)"$(_call_program branches git branch --format='%(refname:short)' 2>/dev/null)"})
  _describe -t branches 'branch' branches
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--onto[branch to base the new branch off of]:branch:_git_quickfix_branches' \
  '--push[push the new branch to origin after creation]' \
  '--remove[delete the last commit from the original branch]' \
  '--autostash[stash local changes before quickfix]' \
  '1:target branch:'
