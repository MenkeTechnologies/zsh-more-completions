#compdef dbslower dbslower-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/dbslower.py argparse)
# Reference accessed: 2026-05-29
# dbslower — trace slow MySQL/PostgreSQL queries via USDT probes (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[print the BPF program]' \
  '(-p --pid)'{-p,--pid=}'[the PID(s) to trace (repeatable)]:*pids:' \
  '(-x --exe)'{-x,--exe=}'[path to binary]:path:_files' \
  '(-m --threshold)'{-m,--threshold=}'[trace queries slower than this threshold (ms, default 1)]:ms:' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:db (database engine):(mysql postgres)' \
  && ret=0

return ret
