#compdef efivarfs-test
# Documentation: https://github.com/torvalds/linux/tree/master/tools/testing/selftests/efivarfs
# Reference accessed: 2026-05-17
# Verified: upstream kernel selftest at the URL above (efivarfs-test is a kernel selftest
# harness with no documented user-facing options).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::efivarfs-test args:_files' && ret=0
return ret
