#compdef network-device-injector
# _network-device-injector — containerd NRI sample plugin: injects host network interfaces into a container's net-namespace per annotation
# upstream: https://github.com/containerd/nri
# Flags from plugins/network-device-injector/network-device-injector.go on tip.

_network-device-injector() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket=[path to NRI socket]:socket:_files' \
        '--verbose[enable verbose logging]'
}

_network-device-injector "$@"
