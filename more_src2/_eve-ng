#compdef eve-ng
# _eve-ng — EVE-NG (Emulated Virtual Environment, multi-vendor network lab platform; CLI wrapper accessing the REST API used by labs.eve-ng.net; -u user, -p password, -H host, -P port, -L lab path, --action start|stop|wipe|export|import; positional verb chooses the operation on the lab tree)
# upstream: https://www.eve-ng.net/ (closed source community)
# Common flag shape from eve-ng-toolkit github mirrors on tip.

_eve-ng() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-u+[user]:user:_users' \
        '-p+[password]:password:' \
        '-H+[host]:host:_hosts' \
        '-P+[port]:port:' \
        '-L+[lab path]:lab:' \
        '--action+[lab action]:action:(start stop wipe export import close open delete)' \
        '*:argument:_files'
}

_eve-ng "$@"
