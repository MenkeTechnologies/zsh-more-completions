#compdef rtpengine
# Documentation: https://github.com/sipwise/rtpengine
# Source: sipwise/rtpengine daemon/main.c GOptionEntry[] — RTP relay/transcoding proxy.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--table=[kernel table to use]:n:_default' \
    '--no-fallback[only start when kernel module is available]' \
    '--nftables-chain=[nftables chain to manage]:chain:_default' \
    '--nftables-base-chain=[nftables base chain to use]:chain:_default' \
    '--nftables-append[append created rules]' \
    '--nftables-family=[address families to manage]:family:(ip ip6 ip,ip6)' \
    '--xtables[use legacy xtables instead of nftables]' \
    '--nftables-start[just add nftables rules and exit]' \
    '--nftables-stop[just remove nftables rules and exit]' \
    '--nftables-status[check nftables rules, print and exit]' \
    '*--interface=[local interface for RTP]:if:_default' \
    '--interfaces-config=[config section prefix for interfaces]:section:_default' \
    '--templates=[config section for signalling templates]:section:_default' \
    '--save-interface-ports[bind ports only on first available interface]' \
    '--listen-ng=[UDP ports to listen on (NG protocol)]:addr:_default' \
    '--listen-tcp-ng=[TCP ports (NG protocol)]:addr:_default' \
    '--listen-cli=[TCP CLI port]:addr:_default' \
    '--listen-tcp=[TCP ports (legacy)]:addr:_default' \
    '--listen-udp=[UDP ports (legacy)]:addr:_default' \
    '--listen-http=[HTTP/WS interface]:addr:_default' \
    '--listen-https=[HTTPS/WSS interface]:addr:_default' \
    '--graphite=[graphite server address]:addr:_default' \
    '--graphite-interval=[graphite send interval (s)]:seconds:_default' \
    '--graphite-prefix=[prefix for graphite line]:prefix:_default' \
    '--tos=[default TOS for streams]:n:_default' \
    '--control-tos=[default TOS for control-ng]:n:_default' \
    '--timeout=[RTP timeout]:seconds:_default' \
    '--silent-timeout=[RTP timeout for muted]:seconds:_default' \
    '--final-timeout=[call timeout]:seconds:_default' \
    '--port-min=[lowest port for RTP]:port:_default' \
    '--port-max=[highest port for RTP]:port:_default' \
    '--redis=[connect to Redis]:addr:_default' \
    '--redis-write=[Redis write database]:addr:_default' \
    '--redis-subscribe=[Redis subscribe database]:addr:_default' \
    '--num-threads=[worker threads]:n:_default' \
    '--media-num-threads=[media playback threads]:n:_default' \
    '--kernel-num-threads=[kernel RTP threads]:n:_default' \
    '--codec-num-threads=[transcoding threads]:n:_default' \
    '--max-sessions=[maximum number of sessions]:n:_default' \
    '--max-load=[reject if load avg exceeds]:value:_default' \
    '--max-cpu=[reject if CPU%% exceeds]:percent:_default' \
    '--max-bandwidth=[reject if bandwidth (B/s) exceeds]:bps:_default' \
    '--recording-dir=[directory for pcap and metadata]:dir:_directories' \
    '--recording-method=[call recording strategy]:method:_default' \
    '--recording-format=[pcap file format]:format:_default' \
    '--homer=[Homer server address for RTCP stats]:addr:_default' \
    '--homer-protocol=[Homer transport]:proto:(udp tcp tls)' \
    '--codecs[print supported codecs and exit]' \
    '--sip-source[use SIP source address by default]' \
    '--dtls-passive[prefer DTLS passive role]' \
    '--log-format=[log prefix format]:format:_default' \
    '--log-facility-cdr=[syslog facility for CDRs]:facility:_default' \
    '--log-facility-rtcp=[syslog facility for RTCP]:facility:_default' \
    '--log-facility-dtmf=[syslog facility for DTMF]:facility:_default' \
    '--iptables-chain=[iptables firewall chain]:chain:_default' \
    '--scheduling=[thread scheduling policy]:policy:(other batch idle fifo rr)' \
    '--priority=[thread scheduling priority]:n:_default' \
    '--software-id=[software ID presented to peers]:id:_default' \
    && ret=0

return ret
