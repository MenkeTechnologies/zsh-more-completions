#compdef qgrep
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qgrep.c — grep through ebuilds and eclasses.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --invert-match)'{-v,--invert-match}'[select non-matching lines]' \
    '(-i --ignore-case)'{-i,--ignore-case}'[ignore case]' \
    '(-N --atom-name)'{-N,--atom-name}'[print atom instead of filename]' \
    '(-c --count)'{-c,--count}'[only print match count per file]' \
    '(-l --list)'{-l,--list}'[only print FILE names containing matches]' \
    '(-L --invert-list)'{-L,--invert-list}'[only print FILE names with NO match]' \
    '(-x --regexp)'{-x,--regexp}'[treat PATTERN as regex]' \
    '(-E --extended)'{-E,--extended}'[treat PATTERN as extended regex]' \
    '(-J --installed)'{-J,--installed}'[search installed ebuilds (not tree)]' \
    '(-e --eclass)'{-e,--eclass}'[search eclasses instead of ebuilds]' \
    '(-H --skip-comments)'{-H,--skip-comments}'[skip comment lines]' \
    '(-R --repo)'{-R,--repo}'[print source repo (implies -N)]' \
    '(-s --skip)'{-s+,--skip=}'[skip lines matching arg]:arg:_default' \
    '(-B --before)'{-B+,--before=}'[lines of leading context]:n:_default' \
    '(-A --after)'{-A+,--after=}'[lines of trailing context]:n:_default' \
    '*:pattern:_default' \
    && ret=0

return ret
