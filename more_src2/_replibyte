#compdef replibyte
# Documentation: source-direct extraction from upstream
# Qovery/replibyte replibyte/src/cli.rs (**clap v3.1**;
# NOT v4 derive nor v4 builder — first documented clap v3
# CLI in the corpus):
#   src/cli.rs lines 9-18 (CLI Parser struct: --config/-c
#     required PathBuf via v3 `parse(from_os_str)`,
#     subcommand, --no-telemetry/-n; uses `propagate_version
#     = true`)
#   src/cli.rs lines 22-32 (SubCommand enum: Dump / Source /
#     Transformer — each nested with their own subcommand)
#   src/cli.rs lines 36-46 (DumpCommand: List / Create
#     (DumpCreateArgs) / Restore (RestoreCommand) / Delete
#     (DumpDeleteArgs))
#   src/cli.rs lines 50-53 (TransformerCommand: just List)
#   src/cli.rs lines 57-62 (RestoreCommand: Local / Remote)
#   src/cli.rs lines 66-73 (RestoreArgs: --value/-v +
#     --output/-o)
#   src/cli.rs lines 77-96 (RestoreLocalArgs: 6 fields
#     including Docker container config)
#   src/cli.rs lines 100-113 (DumpCreateArgs:
#     `requires = "input"` + `requires = "source_type"`
#     MUTUAL requires; v3 `possible_values = &[...]`)
#   src/cli.rs lines 116-127 (DumpDeleteArgs:
#     `#[clap(group = clap::ArgGroup::new("delete-mode")
#     .multiple(false))]` — v3 BUILDER-API ArgGroup
#     inside a derive attribute; 3 fields all
#     `group = "delete-mode"`)
#   src/cli.rs lines 131-134 (SourceCommand: just Schema)
# Reference accessed: 2026-05-30 via gh api.
#
# replibyte is the **production-data-anonymization tool**
# from Qovery — dumps production databases (Postgres /
# MySQL / MongoDB) while transforming sensitive fields
# (PII, secrets) into safe synthetic data, then restores
# the anonymized dump into dev/staging environments.
# Pivots from filesystem analysis (R260 dua) into the
# **database tooling cluster**.  Sister to litestream
# (in corpus), pgcli (in corpus).
#
# Critical extraction note: replibyte uses **clap 3.1**
# (NOT v4) at Cargo.toml.  This is the **corpus's first
# documented clap v3 CLI** — every prior round R247-R260
# used clap v4 (derive or builder).  **MAJOR PATTERN
# MILESTONE**.  Key v3-vs-v4 syntax differences observed:
#   1. **`parse(from_os_str)`** at cli.rs:11 + 107 — v3
#      attribute for OsString-to-T conversion.  v4 replaced
#      this with `value_parser` (which accepts any
#      `Fn(&str) -> Result<T, E>` or a built-in
#      ValueParser type like `clap::value_parser!()`).
#      v3 `parse(from_os_str)` syntax: `#[clap(parse(from_os_str))]`
#      v4 equivalent: `#[clap(value_parser)]` (clap auto-
#      infers the parser from the field type).
#   2. **`possible_values = &["a", "b", "c"]`** at
#      cli.rs:101 + 94 — v3 attribute for restricted-
#      string ValueParser.  v4 deprecated this in favor
#      of `value_parser = ["a", "b", "c"]` (slice without
#      `&`) or ValueEnum-derive.  v3 syntax: `#[clap(
#      possible_values = &["postgresql", "mysql", "mongodb"])]`
#      v4 equivalent: `#[clap(value_parser = ["postgresql",
#      "mysql", "mongodb"])]`.
#   3. **`clap::ArgGroup::new("delete-mode").multiple(false)`**
#      at cli.rs:116 — v3 BUILDER-API ArgGroup construction
#      INSIDE a derive attribute.  v4 added the
#      `#[group(name = "delete-mode", multiple = false)]`
#      derive attribute as a shorthand.  Documents the
#      **mixed builder-API-inside-derive** pattern — v3
#      didn't have all derive shortcuts so it required
#      builder constructions for ArgGroup, Command::group,
#      etc.
# Documents the **clap v3-to-v4 migration matrix**:
# corpus's first reference for understanding what changes
# when porting CLIs from clap v3 to v4.
#
# Critical extraction note: replibyte uses **MUTUAL
# requires** at cli.rs:101 + 105 on `--source-type`
# requires `input` AND `--input` requires `source_type`.
# This means BOTH flags must be specified together — you
# can't use one without the other.  Documents the
# **bidirectional-requires mutex** — distinct from R248
# cairo-coverage's `requires = "unstable"` (unidirectional:
# 2 flags require 1 flag).  Plus the `--source-type`
# value `[postgresql | mysql | mongodb]` matches the
# `possible_values` restriction.  Useful for "either both
# present or both absent" semantics.
#
# Critical extraction note: replibyte uses
# **`#[clap(group = clap::ArgGroup::new("delete-mode")
# .multiple(false))]`** at cli.rs:116 + 3 fields tagged
# `#[clap(group = "delete-mode")]` at lines 119, 122, 125
# — declarative mutex for 3 flags (`dump` positional /
# `--older-than` / `--keep-last`).  v3-style: the ArgGroup
# is constructed via builder syntax (`clap::ArgGroup::new(...)
# .multiple(false)`) INSIDE the derive attribute.  v4
# equivalent: `#[group(name = "delete-mode", multiple =
# false)]` shorthand.  Continues the corpus's mutex-
# pattern documentation (R250 sozo `#[group(multiple =
# false)]`, R258 bevy `conflicts_with_all = [..]`, R255
# fuel-core single-pair `conflicts_with`).  Documents the
# **builder-inside-derive ArgGroup** pattern.
#
# Critical extraction note: replibyte uses
# **`propagate_version = true`** at cli.rs:8 — every
# subcommand also gets `--version` automatically.  Without
# this, only the top-level `replibyte --version` works;
# `replibyte dump --version` would fail.  Documents the
# **`propagate_version` attribute** — corpus's first
# documented occurrence.  Useful for CLIs where users
# may forget the version is at the top level.

local curcontext="$curcontext" state line ret=1

# 3 top-level subcommands decoded source-direct from
# SubCommand enum at cli.rs lines 22-32.
local -a subcommands=(
  'dump:dump operations (sub: list / create / restore / delete)'
  'source:source database commands (sub: schema)'
  'transformer:transformer operations (sub: list)'
)

local -a dump_subs=(
  'list:list available dumps'
  'create:launch dump'
  'restore:restore commands (sub: local / remote)'
  'delete:delete a dump from the defined datastore'
)

local -a dump_restore_subs=(
  'local:restore dump inside a local Docker container'
  'remote:restore dump inside the configured destination'
)

local -a transformer_subs=(
  'list:list available transformers'
)

local -a source_subs=(
  'schema:show database schema (MongoDB: probabilistic JSON)'
)

local -a db_types=(postgresql mysql mongodb)

# Global flags decoded source-direct from CLI Parser
# struct at cli.rs lines 9-18.
local -a global_flags=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version (propagated to subcommands via `propagate_version = true`)]'
  '(-c --config)'{-c+,--config=}'[replibyte configuration file (REQUIRED)]:file:_files -g "*.yaml"'
  '(-n --no-telemetry)'{-n,--no-telemetry}'[disable telemetry]'
)

_arguments -C \
  $global_flags \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'replibyte subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      dump)
        if (( CURRENT == 2 )); then
          _describe -t dump-subs 'dump verb' dump_subs && ret=0
        else
          case $words[2] in
            list)
              _arguments $global_flags && ret=0
              ;;
            create)
              # MUTUAL requires: --source-type requires
              # --input AND --input requires --source-type.
              _arguments \
                $global_flags \
                '(-s --source-type)'{-s+,--source-type=}'[database source type (postgresql/mysql/mongodb; REQUIRES --input)]:db:($db_types)' \
                '(-i --input)'{-i,--input}'[import dump from stdin (REQUIRES --source-type)]' \
                '(-f --file)'{-f+,--file=}'[dump file (alternative to --input stdin)]:file:_files' \
                '(-n --name)'{-n+,--name=}'[dump name]:name:' && ret=0
              ;;
            restore)
              if (( CURRENT == 3 )); then
                _describe -t restore-subs 'restore target' dump_restore_subs && ret=0
              else
                case $words[3] in
                  local)
                    _arguments \
                      $global_flags \
                      '(-v --value)'{-v+,--value=}'[dump name or `latest`]:value:' \
                      '(-o --output)'{-o,--output}'[stream output on stdout]' \
                      '(-t --tag)'{-t+,--tag=}'[Docker image tag for container]:tag:' \
                      '(-p --port)'{-p+,--port=}'[Docker container port to map on host]:port:' \
                      '(-r --remove)'{-r,--remove}'[remove Docker container on Ctrl-C]' \
                      '(-i --image)'{-i+,--image=}'[Docker image type]:image:($db_types)' && ret=0
                    ;;
                  remote)
                    _arguments \
                      $global_flags \
                      '(-v --value)'{-v+,--value=}'[dump name or `latest`]:value:' \
                      '(-o --output)'{-o,--output}'[stream output on stdout]' && ret=0
                    ;;
                esac
              fi
              ;;
            delete)
              # 3-way mutex via ArgGroup("delete-mode",
              # multiple = false): dump positional / --older-than
              # / --keep-last.
              _arguments \
                $global_flags \
                '(--older-than --keep-last)1:dump name (mutex with --older-than/--keep-last):' \
                '(--keep-last 1)--older-than=[remove all dumps older than N days (format: `14d`)]:duration:' \
                '(--older-than 1)--keep-last=[keep only the last N dumps]:n:' && ret=0
              ;;
          esac
        fi
        ;;
      source)
        if (( CURRENT == 2 )); then
          _describe -t source-subs 'source verb' source_subs && ret=0
        else
          _arguments $global_flags && ret=0
        fi
        ;;
      transformer)
        if (( CURRENT == 2 )); then
          _describe -t transformer-subs 'transformer verb' transformer_subs && ret=0
        else
          _arguments $global_flags && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
