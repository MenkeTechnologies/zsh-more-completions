#compdef kea-ctrl-agent
# Documentation: https://kea.readthedocs.io/en/kea-2.6.1/man/kea-ctrl-agent.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kea-ctrl-agent: Kea REST/JSON control agent. Corrected from prior
# file: removed invented -X flag and undocumented -h per upstream.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[display the Kea version]' \
  '-V[display the extended Kea version]' \
  '-W[display the configuration report]' \
  '-d[set logging level to debug with extra verbosity]' \
  '-c[configuration file]:file:_files -g "*.(conf|json)"' \
  '-t[check the configuration file syntax and report the first error]:file:_files -g "*.(conf|json)"' \
  '*::kea-ctrl-agent args:_files' && ret=0
return ret
