_ecschedule() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ec_cmds=(
                'apply:apply declared config to AWS EventBridge'
                'dump:dump AWS EventBridge state to YAML'
                'run:execute rule immediately'
                'diff:diff declared config vs live AWS state'
            )
            _describe -t commands 'ecschedule command' _ec_cmds && ret=0
            ;;
        args)
            case $words[1] in
                apply)
                    _arguments \
                        '-conf=[config file path]:yaml:_files -g "*.(yaml|yml)"' \
                        '-rule=[apply only this rule]:rule:' \
                        '-dry-run[dry run (no AWS changes)]' \
                        '-all[apply all rules]' \
                        '-prune[prune orphaned rules after apply]' \
                        '-u[output diff in unified git-style format]' \
                        '-no-color[disable colored diff output]' \
                        '-parallel=[parallel workers for dry-run (default 1; recommended 1-10)]:n:' && ret=0
                    ;;
                dump)
                    _arguments \
                        '-conf=[config file path]:yaml:_files -g "*.(yaml|yml)"' \
                        '-region=[AWS region override]:region:' \
                        '-cluster=[ECS cluster name]:cluster:' \
                        '-role=[IAM role ARN]:arn:' && ret=0
                    ;;
                run)
                    _arguments \
                        '-conf=[config file path]:yaml:_files -g "*.(yaml|yml)"' \
                        '-rule=[rule to run]:rule:' \
                        '-dry-run[dry run]' && ret=0
                    ;;
                diff)
                    _arguments \
                        '-conf=[config file path]:yaml:_files -g "*.(yaml|yml)"' \
                        '-rule=[diff only this rule]:rule:' \
                        '-all[diff all rules]' \
                        '-u[unified git-style diff]' \
                        '-no-color[disable colored output]' \
                        '-prune[detect orphaned rules for deletion]' \
                        '-validate[perform validation (env/tfstate/ssm/task definition)]' \
                        '-parallel=[parallel workers (default 1)]:n:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_ecschedule "$@"
