#compdef jsonformat
# ============================================================================
#  _jsonformat — jsonformat: render JSON input from stdin into
#                CSV/HTML/XML/custom-template output using
#                user-supplied format templates
#                (voxelbrain — also creator of the goptions
#                CLI library this binary demonstrates)
#
#  Source-direct extraction from
#    https://github.com/voxelbrain/jsonformat/blob/master/jsonformat.go
#    https://github.com/voxelbrain/goptions (the voxelbrain/
#    goptions library by Surma Sourdrille — Google engineer,
#    Web Performance team)
#
#  Maintained by Surma "voxelbrain" Sourdrille (Google engineer
#  on the Web Performance / DevRel team; author of many Go and
#  TypeScript ecosystem crates including ImageBitmap-loader,
#  comlink, lerna-pages, esbuild-explorer).  voxelbrain/
#  jsonformat: 7 GH stars (small but author's own goptions demo
#  binary).  jsonformat reads JSON from stdin and renders each
#  record through a user-provided FORMAT TEMPLATE (Go
#  text/template syntax) to produce CSV/XML/HTML/custom output.
#  Useful for converting JSON log streams into spreadsheet rows,
#  HTML reports, or any other text format that can be expressed
#  via Go templates.  Sister tools: jq (in corpus + STOCK — the
#  industry-standard JSON processor; jq's `@csv`/`@html`/`@uri`
#  filters cover similar ground but with a steeper learning
#  curve), gojq (Go port of jq — in corpus via _gojq), yq (in
#  corpus + STOCK; YAML version), miller / mlr (in corpus +
#  STOCK; CSV/TSV/JSON Swiss army knife), csvkit (in corpus +
#  STOCK Debian/Ubuntu via _csvkit; CSV manipulation), gron (in
#  corpus + STOCK; greppable JSON).
#
#  CLI library taxonomy update: 19th Go CLI library — Surma
#  Sourdrille's **goptions** (voxelbrain/goptions).  Go ecosystem
#  now has 19 documented CLI libraries — TYING WITH RUST at the
#  top of the cross-language taxonomy ahead of TypeScript-Node
#  (18).  🎉 Go RE-TIES with Rust at 19.
#
#  goptions (voxelbrain/goptions, 180 GH stars) is "A flexible
#  parser for command line options" by Surma Sourdrille.
#  Distinguishing philosophy: STRUCT-TAG-BASED with INLINE
#  DESCRIPTION/MUTEX-GROUP/REMAINDER metadata in a SINGLE
#  COMMA-SEPARATED STRUCT TAG STRING.  Unlike jessevdk/go-flags
#  (which uses MULTIPLE struct tags: `short:"x" long:"name"
#  description:"..."`), goptions packs ALL flag metadata into
#  ONE tag: `goptions:"-x, --name, description='Help', obligatory,
#  mutexgroup='input', remainder"`.  Used by joinmytalk/satsuma
#  (talk-sharing platform), surma/s3put (S3 bulk uploader 33
#  stars — IN CORPUS via _s3put), voxelbrain/jsonformat (this
#  binary, 7 stars), wayneeseguin/graft (YAML grafting tool 2
#  stars — by RVM author Wayne E. Seguin), prasmussen/gandi
#  (Gandi.net DNS CLI 11 stars), drk1wi/Modlishka (offensive-
#  security phishing simulator 5326 stars — used by red teamers
#  in AUTHORIZED engagements), zmap/zgrab2 (ZMap Internet-wide
#  banner grabber 2122 stars — IN CORPUS via _zgrab2 + _zmap;
#  legitimate Internet-measurement research tool by Censys/
#  University of Michigan), lotusdblabs/lotusdb (embedded DB
#  2253 stars; tests only), mjpclab/go-http-file-server (HTTP
#  file server 479 stars), and many other Go binaries that
#  prefer goptions's compact single-tag struct definitions over
#  jessevdk/go-flags's multi-tag style.
#
#  goptions API:
#    import "github.com/voxelbrain/goptions"
#
#    // Struct defines all flags via INLINE struct-tag metadata
#    // packed into ONE comma-separated `goptions:"..."` string
#    var options = struct {
#      // Short + long flag with description and "continue on error"
#      // semantics (just a bool)
#      Continue     bool   `goptions:"-c, --continue, description='Continue on error'"`
#
#      // OBLIGATORY = required flag; MUTEXGROUP = at-most-one
#      // of the named group; description = help text
#      FormatFile   string `goptions:"-r, --format-file, description='Read format from file', mutexgroup='input', obligatory"`
#      FormatString string `goptions:"-s, --format-string, description='Format string', mutexgroup='input', obligatory"`
#
#      // OBLIGATORY without mutexgroup; default value via Go
#      // struct initialization
#      Format       string `goptions:"-f, --format, obligatory, description='Name for the formatter'"`
#
#      // EMBEDDED goptions.Help — registers --help/-h
#      // automatically
#      goptions.Help     `goptions:"-h, --help, description='Show this help'"`
#    }{
#      Format: "csv",                       // default for --format
#    }
#
#    func main() {
#      err := goptions.Parse(&options)
#      if err != nil {
#        if err != goptions.ErrHelpRequest {
#          fmt.Printf("Error: %s\n", err)
#        }
#        goptions.PrintHelp()                // manual help dispatch
#        return
#      }
#      // options.Continue, options.FormatFile, ...
#    }
#
#    // Alternative entry: ParseAndFail() auto-prints help and
#    // exits on error — convenience wrapper
#    goptions.ParseAndFail(&options)
#
#  goptions distinctive features:
#    - SINGLE-TAG INLINE METADATA — `goptions:"-x, --name,
#      description='Help', obligatory, mutexgroup='input',
#      remainder"` packs ALL flag metadata into one comma-
#      separated string per field (CONTRAST jessevdk/go-flags
#      which uses MULTIPLE separate tags: `short:"x" long:"name"
#      description:"..." required:"true"`)
#    - TAG GRAMMAR:
#      * `-X` — short flag form
#      * `--name` — long flag form (both -X and --name can be
#        present in the same tag)
#      * `description='text'` — help text (single-quoted with
#        backslash escapes; the description= prefix is literal)
#      * `obligatory` — required flag (boolean tag, no value)
#      * `mutexgroup='groupName'` — flag belongs to a mutex
#        group; AT MOST ONE flag in the group can be specified
#      * `remainder` — flag captures all remaining positional
#        args (used for catching `--` separated args at the
#        end)
#    - EMBEDDED goptions.Help — `goptions.Help` is a type that
#      can be EMBEDDED in the options struct via Go's anonymous
#      field syntax; auto-registers --help/-h
#    - DEFAULT VALUES from Go struct initialization (e.g. `var
#      options = struct{...}{ Format: "csv" }` sets default
#      "csv" for --format)
#    - TYPE INFERENCE from struct field type — bool/int/string/
#      []string (REPEATABLE) / time.Duration / net.URL / etc.
#    - SUBCOMMANDS via nested anonymous struct fields with
#      `goptions:"command='subcommandName'"` tag — each
#      subcommand has its own embedded struct with its own
#      flags
#    - VERBS via `Verbs` map syntax (older API style)
#    - `goptions.Parse(&options)` — main entry; returns error
#      on parse failure or `goptions.ErrHelpRequest` on -h/
#      --help
#    - `goptions.ParseAndFail(&options)` — convenience wrapper
#      that auto-prints help + os.Exit on error
#    - `goptions.PrintHelp()` — manual help rendering from
#      the registered options
#    - INSPIRED BY Python's argparse + jessevdk/go-flags but
#      with COMPACT single-tag syntax that voxelbrain found
#      more readable for terse flag definitions
#  Distinct from R237 Go spf13/cobra (subcommand-TREE with
#  Command structs), R237 Go spf13/pflag, R237 Go urfave/cli,
#  R237 Go alecthomas/kingpin, R237 Go jessevdk/go-flags
#  (CLOSEST RIVAL — both struct-tag based; jessevdk uses
#  MULTIPLE separate tags while goptions packs ALL metadata
#  into ONE comma-separated tag string), R237 Go mitchellh/cli,
#  R262 Go stdlib `flag`, R363 Go peterbourgon/ff, R367 Go
#  akamensky/argparse, R408 Go pborman/getopt, R411 Go integrii/
#  flaggy, R414 Go alecthomas/kong (modern struct-tag with
#  per-attribute tags like jessevdk — CONTRAST goptions's
#  single-tag), R417 Go google/subcommands, R421 Go namsral/
#  flag, R426 Go octago/sflags (META-flag-generator), R431 Go
#  peterbourgon/ff/v3/ffcli, R435 Go posener/complete (completion-
#  first).  Go documented libraries so far: stdlib flag, pflag,
#  cobra, urfave-cli, kingpin, jessevdk/go-flags, mitchellh/cli,
#  ff, akamensky/argparse, pborman/getopt, flaggy, kong, google/
#  subcommands, namsral/flag, sflags, ffcli, complete, goptions
#  (this round)... 19 total.  goptions's distinguishing feature
#  vs all other Go libs: goptions is the ONLY Go CLI library in
#  the corpus that packs ALL flag metadata (short, long,
#  description, obligatory, mutexgroup, remainder) into a SINGLE
#  COMMA-SEPARATED struct-tag string.  Every other struct-tag
#  Go lib (jessevdk/go-flags/kong/sflags) uses MULTIPLE separate
#  tags.  goptions's approach: SINGLE-TAG INLINE METADATA with
#  `goptions:"short, long, description='...', obligatory,
#  mutexgroup='...', remainder"` packed comma-separated tag +
#  EMBEDDED goptions.Help for auto -h/--help registration +
#  default values from Go struct initialization + TYPE
#  INFERENCE from field types (bool/int/string/[]string/time.
#  Duration/net.URL) + MUTEX GROUPS via mutexgroup='name' for
#  at-most-one-in-group semantics + REMAINDER tag for capturing
#  trailing positional args + SUBCOMMANDS via nested struct
#  fields + `Parse(&options)` main entry returning error or
#  `ErrHelpRequest` + `ParseAndFail()` convenience wrapper +
#  `PrintHelp()` manual renderer + INSPIRED BY Python argparse
#  + jessevdk/go-flags but compact single-tag — corpus's
#  **first documented single-tag-inline-metadata Go CLI library**.
#  Brings cross-language CLI library taxonomy variant count to
#  177; Go ecosystem now has 19 documented CLI libraries —
#  TYING WITH RUST at the top of the cross-language taxonomy
#  ahead of TypeScript-Node (18).
#
#  Surface (verbatim from `jsonformat.go` goptions struct tags):
#
#  Usage:
#    jsonformat -f FORMAT [-c] [-r FILE | -s STRING]
#    cat data.json | jsonformat -f csv -s '{{.field1}},{{.field2}}'
#
#  Options:
#    -c, --continue                 Continue on error (when a
#                                   JSON record fails to apply
#                                   to the template, log it and
#                                   keep processing the next
#                                   record; default: stop on
#                                   first error)
#    -f, --format <NAME>            Name for the formatter
#                                   (OBLIGATORY).  Built-in
#                                   formatters: csv (CSV
#                                   output), xml (XML output),
#                                   html (HTML output);
#                                   discoverable from --help.
#                                   Default: csv.
#    -r, --format-file <FILE>       Read format template from
#                                   FILE (Go text/template
#                                   syntax).  MUTEX GROUP
#                                   'input' — exactly ONE of
#                                   -r/--format-file or
#                                   -s/--format-string must be
#                                   provided.
#    -s, --format-string <STR>      Inline format template
#                                   string (Go text/template
#                                   syntax).  MUTEX GROUP
#                                   'input' — exactly ONE of
#                                   -r/--format-file or
#                                   -s/--format-string must be
#                                   provided.
#    -h, --help                     Show this help (auto from
#                                   embedded goptions.Help)
#
#  Examples:
#    echo '{"name": "alice", "age": 30}' | jsonformat -f csv -s '{{.name}},{{.age}}'
#    cat data.json | jsonformat -f csv -r template.tmpl > output.csv
#    cat logs.json | jsonformat -f xml -s '<entry name="{{.name}}">{{.message}}</entry>'
#    cat logs.json | jsonformat -c -f csv -s '{{.timestamp}},{{.level}},{{.msg}}'    # Continue on err
#    cat data.json | jsonformat -f html -r report.tmpl                                # HTML report
#    jsonformat --help                                                                # Show help + version
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also voxelbrain/goptions users):
#    - s3put (IN CORPUS via _s3put — Surma's S3 bulk uploader
#      33 stars; same author as goptions; previously documented
#      but goptions library not formally entered into taxonomy)
#    - zgrab2 (IN CORPUS via _zgrab2 — ZMap banner grabber
#      2122 stars; uses goptions; previously documented)
#    - zmap (IN CORPUS via _zmap — ZMap Internet-wide scanner)
#    - graft (wayneeseguin/graft 2 stars — RVM author's YAML
#      grafting; too niche)
#    - pdfd (joinmytalk/satsuma/pdfd — PDF daemon 6 stars; too
#      niche)
#    - gandi (prasmussen/gandi 11 stars — Gandi.net DNS CLI;
#      FUTURE candidate)
#    - modlishka (drk1wi/Modlishka 5326 stars — phishing
#      simulator for AUTHORIZED red-team engagements; dual-use
#      offensive-security tool; SKIPPED to avoid potential
#      misuse signaling)
#    - lotusdb (lotusdblabs/lotusdb 2253 stars — embedded DB
#      library; goptions only in tests)
#    - go-http-file-server (mjpclab 479 stars — uses its own
#      goNixArgParser not goptions in current version)
#    - voxelbrain/goptions repo itself (180 stars library not CLI)
# ============================================================================

_jsonformat() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-c --continue)'{-c,--continue}'[continue on error]' \
    '(-f --format)'{-f,--format}'[name for the formatter (OBLIGATORY)]:formatter:(csv xml html)' \
    '(-r --format-file -s --format-string)'{-r,--format-file}'[read format template from file]:file:_files' \
    '(-r --format-file -s --format-string)'{-s,--format-string}'[inline format template string]:template:'
}

_jsonformat "$@"
