#compdef mapproject
# Documentation: https://docs.generic-mapping-tools.org/latest/mapproject.html
# Source: GenericMappingTools/gmt classic-mode mapproject — coordinate conversion (lon,lat ↔ x,y).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A+[azimuth along track or to fixed point]:opts:_default' \
    '-C+[center of projected coords + offsets]:opts:_default' \
    '-D+[length unit override]:unit:(c i p)' \
    '-E+[geodetic↔ECEF conversion]:opts:_default' \
    '-F+[force 1:1 + output units]:opts:_default' \
    '-G+[distance along track or to fixed point]:opts:_default' \
    '-I[inverse (x,y → lon,lat)]' \
    '-L+[shortest distance to line segments]:opts:_default' \
    '-N+[geodetic → auxiliary latitude type]:type:_default' \
    '-Q+[list projection params / datums / ellipsoids]:what:_default' \
    '-S[suppress points outside region]' \
    '-T+[datum-to-datum coordinate conversion]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[report plot dimensions or map region]:opts:_default' \
    '-Z+[travel times along track]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
