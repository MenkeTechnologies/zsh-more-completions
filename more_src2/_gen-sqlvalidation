#compdef gen-sqlvalidation
# _gen-sqlvalidation — emit SQL validation queries from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/sqlvalidationgen.py (click).

_gen-sqlvalidation() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.sql"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(sql)'
        '--dialect=[SQL dialect]:dialect:(sqlite postgresql mysql mariadb oracle mssql)'
        '--check-required[emit checks for required slots]'
        '--no-check-required[skip required-slot checks]'
        '--check-ranges[emit type / range checks]'
        '--no-check-ranges[skip type / range checks]'
        '--check-patterns[emit regex pattern checks]'
        '--no-check-patterns[skip regex pattern checks]'
        '--check-enums[emit enum permissible-value checks]'
        '--no-check-enums[skip enum checks]'
        '--check-unique-keys[emit unique-key constraint checks]'
        '--no-check-unique-keys[skip unique-key checks]'
        '--include-comments[include SQL comments in the generated queries]'
        '--no-include-comments[strip SQL comments]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-sqlvalidation "$@"
