#compdef rush rushx
# _rush-bin — Microsoft Rush scalable monorepo manager (Microsoft); orchestrates 100+ packages over npm/pnpm/yarn with strict policy enforcement
# upstream: https://github.com/microsoft/rushstack

_rush-bin() {
    local -a sub=(
        'add:add a dependency'
        'build:rebuild changed projects (incremental)'
        'change:create a changefile entry'
        'check:detect inconsistent versions'
        'deploy:create a self-contained deployment'
        'init:initialize a new rush.json repo'
        'init-autoinstaller:initialize an autoinstaller'
        'init-deploy-scenario:initialize a deploy scenario'
        'install:install all packages'
        'link:create symlinks (legacy)'
        'list:list rush projects'
        'publish:publish bumped packages'
        'purge:purge install state'
        'rebuild:full rebuild'
        'remove:remove a dependency'
        'scan:scan a single project'
        'setup:run rush setup wizard'
        'tab-complete:print shell completion'
        'unlink:remove symlinks'
        'update:update all dependencies'
        'update-autoinstaller:update autoinstaller'
        'update-cloud-credentials:update cloud cred'
        'upgrade-interactive:interactive package upgrade'
        'version:apply version policies'
        'write-build-cache:write incremental cache entry'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--debug[debug log]' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rush subcommand' sub ;;
        args)
            case $words[1] in
                build|rebuild) _arguments \
                    '--parallelism+[parallel jobs]:n:' \
                    '--to+[build up to project]:project:' \
                    '--to-except+[build up to but exclude]:project:' \
                    '--from+[build from project]:project:' \
                    '--only+[only project]:project:' \
                    '--impacted-by+[impacted by]:project:' \
                    '--impacted-by-except+[impacted by excluding]:project:' \
                    '--changed-projects-only[only changed projects]' \
                    '--ignore-hooks[ignore hooks]' \
                    '--ignore-git-hooks[ignore git hooks]' \
                    '--no-build-cache[disable build cache]' \
                    '--timeline[show timeline summary]' \
                    '--watch[watch and rebuild]' ;;
                install|update) _arguments \
                    '--purge[purge before install]' \
                    '--bypass-policy[bypass policies]' \
                    '--no-link[skip linking]' \
                    '--network-concurrency+[network concurrency]:n:' \
                    '--full[full update]' \
                    '--recheck[force recheck]' ;;
                add) _arguments \
                    '--package+[package]:pkg:' \
                    '--exact[exact version]' \
                    '--caret[caret range]' \
                    '--dev[devDep]' \
                    '--make-consistent[make consistent across repo]' \
                    '--skip-update[skip update]' ;;
                publish) _arguments \
                    '--apply[apply version changes]' \
                    '--prerelease-name+[prerelease tag]:tag:' \
                    '--target-branch+[branch]:branch:' \
                    '--registry+[npm registry]:url:_urls' \
                    '--include-all[include all]' \
                    '--release-folder+[release folder]:dir:_files -/' \
                    '--commit+[git commit message]:msg:' ;;
                deploy) _arguments \
                    '--scenario+[deploy scenario]:scenario:' \
                    '--overwrite[overwrite existing]' \
                    '--target-folder+[target folder]:dir:_files -/' \
                    '--create-archive+[archive file]:file:_files' \
                    '--create-archive-only[only archive]' ;;
                change) _arguments \
                    '--target-branch+[target branch]:branch:' \
                    '--message+[message]:msg:' \
                    '--bulk[bulk mode]' \
                    '--bump-type+[bump type]:type:(major minor patch none)' ;;
            esac
            ;;
    esac
}

_rush-bin "$@"
