#compdef gpustack
# Documentation: https://github.com/gpustack/gpustack (gpustack/main.py + gpustack/cmd/start.py)
# Reference accessed: 2026-05-29
# GPUStack — open LLM serving + management framework with GPU clusters.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'start:start the GPUStack service (server and/or worker)'
  'reload-config:reload configuration without restarting'
  'list-images:list available container images'
  'save-images:save images to storage'
  'copy-images:copy images between locations'
  'load-images:load images from storage'
  'reset-admin-password:reset administrator credentials'
  'version:show version information'
  'help:show help for a subcommand'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'gpustack subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments \
          '(-d --debug)'{-d,--debug}'[enable debug mode]' \
          '--config-file=[YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
          '--advertise-address=[IP for external access (auto-detected if unset)]:ip:_hosts' \
          '--port=[server binding port]:port:' \
          '--tls-port=[TLS server binding port]:port:' \
          '--api-port=[GPUStack API server port]:port:' \
          '--proxy-port=[HTTP/HTTPS proxy port for tunnel mode]:port:' \
          '--data-dir=[data storage directory]:dir:_directories' \
          '--cache-dir=[model files cache storage]:dir:_directories' \
          '--bin-dir=[binary storage for versioned backends]:dir:_directories' \
          '--pipx-path=[path to pipx executable]:file:_files' \
          '--huggingface-token=[Hugging Face Hub authentication token]:token:' \
          '--system-default-container-registry=[default container registry]:registry:' \
          '--image-name-override=[override container image name]:name:' \
          '--image-repo=[override gpustack image repository]:repo:' \
          '--benchmark-image-repo=[override benchmark image repository]:repo:' \
          '--gateway-mode=[gateway mode]:mode:(embedded in-cluster external disabled auto)' \
          '--gateway-kubeconfig=[kubeconfig for external gateway]:file:_files' \
          '--gateway-namespace=[gateway deployment namespace]:namespace:' \
          '--service-discovery-name=[DNS service discovery name]:name:' \
          '--namespace=[Kubernetes namespace for deployments]:namespace:' \
          '--database-port=[database port]:port:' \
          '--metrics-port=[server metrics port]:port:' \
          '--database-url=[database connection URL]:url:' \
          '(--disable-worker --enable-worker)--disable-worker[disable embedded worker]' \
          '(--disable-worker --enable-worker)--enable-worker[enable embedded worker]' \
          '--disable-metrics[disable server metrics]' \
          '--bootstrap-password=[initial admin password]:password:' \
          '--ssl-keyfile=[SSL key file path]:file:_files' \
          '--ssl-certfile=[SSL certificate file path]:file:_files' \
          '--disable-update-check[disable update checks]' \
          '--disable-openapi-docs[disable Swagger/ReDoc endpoints]' \
          '--model-catalog-file=[model catalog path or URL]:path_or_url:' \
          '--server-external-url=[server URL behind reverse proxy]:url:_urls' \
          '--gateway-concurrency=[concurrent connections (default 16)]:n:' \
          '--enable-cors[enable CORS]' \
          '--allow-credentials[allow cross-origin credentials]' \
          '*--allow-origins=[allowed origins (repeatable)]:origin:' \
          '*--allow-methods=[allowed HTTP methods (repeatable)]:method:(GET POST PUT DELETE PATCH OPTIONS HEAD)' \
          '*--allow-headers=[allowed headers (repeatable)]:header:' \
          '--oidc-issuer=[OIDC provider issuer URL]:url:_urls' \
          '--oidc-client-id=[OIDC client ID]:id:' \
          '--oidc-client-secret=[OIDC client secret]:secret:' \
          '--oidc-redirect-uri=[OIDC callback URI]:url:_urls' \
          '--oidc-skip-userinfo[use ID token instead of UserInfo endpoint]' \
          '--saml-idp-server-url=[SAML IdP server URL]:url:_urls' \
          '--saml-idp-logout-url=[SAML logout endpoint]:url:_urls' \
          '--saml-idp-entity-id=[SAML IdP entity ID]:id:' \
          '--saml-idp-x509-cert=[SAML IdP certificate]:cert:' \
          '--saml-sp-entity-id=[SAML SP entity ID]:id:' \
          '--saml-sp-acs-url=[SAML ACS callback URL]:url:_urls' \
          '--saml-sp-slo-url=[SAML logout service URL]:url:_urls' \
          '--saml-sp-x509-cert=[SAML SP certificate]:cert:' \
          '--saml-sp-private-key=[SAML SP private key]:key:' \
          '--saml-sp-attribute-prefix=[SAML attribute prefix]:prefix:' \
          '--saml-security=[SAML security settings JSON]:json:' \
          '--external-auth-name=[username attribute mapping]:attr:' \
          '--external-auth-full-name=[full name attribute mapping]:attr:' \
          '--external-auth-avatar-url=[avatar URL attribute mapping]:attr:' \
          '--external-auth-default-inactive[new users inactive by default]' \
          '--external-auth-post-logout-redirect-key=[post-logout redirect key]:key:' \
          '--disable-builtin-observability[disable built-in Grafana/Prometheus]' \
          '--builtin-prometheus-port=[Prometheus port (default 19090)]:port:' \
          '--builtin-grafana-port=[Grafana port (default 13000)]:port:' \
          '--grafana-url=[external Grafana base URL]:url:_urls' \
          '--grafana-worker-dashboard-uid=[Grafana worker dashboard UID]:uid:' \
          '--grafana-model-dashboard-uid=[Grafana model dashboard UID]:uid:' \
          '(-t --token)'{-t,--token=}'[shared secret for worker registration]:token:' \
          '(-s --server-url)'{-s,--server-url=}'[server connection URL]:url:_urls' \
          '--worker-ip=[worker node IP (auto-detected)]:ip:' \
          '--worker-ifname=[network interface name (auto-detected)]:iface:_net_interfaces' \
          '--worker-name=[worker node name (hostname default)]:name:' \
          '--worker-port=[worker binding port]:port:' \
          '--service-port-range=[inference service ports (e.g. 40000-40063)]:range:' \
          '--ray-port-range=[Ray service ports (e.g. 41000-41999)]:range:' \
          '--benchmark-max-duration-seconds=[benchmark timeout]:seconds:' \
          '--disable-worker-metrics[disable worker metrics]' \
          '--worker-metrics-port=[worker metrics port]:port:' \
          '--log-dir=[log storage directory]:dir:_directories' \
          '--benchmark-dir=[benchmark results directory]:dir:_directories' \
          '--system-reserved=[reserved resources (RAM/VRAM in GiB)]:resources:' \
          '--proxy-mode=[access mode]:mode:(direct worker)' && ret=0
        ;;
      reset-admin-password)
        _arguments \
          '--data-dir=[data directory]:dir:_directories' \
          '--password=[new admin password]:password:' && ret=0
        ;;
      list-images|save-images|copy-images|load-images)
        _arguments \
          '--data-dir=[data directory]:dir:_directories' \
          '--config-file=[YAML configuration file]:file:_files -g "*.(yaml|yml)"' \
          '*:image:' && ret=0
        ;;
      reload-config)
        _arguments \
          '--data-dir=[data directory]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
