#compdef psevents
# Documentation: https://docs.generic-mapping-tools.org/latest/psevents.html
# Source: GenericMappingTools/gmt src/psevents.c — plot event symbols with time-dependent visibility for movie frames (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[map projection]:projection:_default' \
    '-R+[region]:region:_default' \
    '-T+[current time]:now:_default' \
    '-Ar+[render as raster]:dpu:_default' \
    '-As[render as symbols]' \
    '-C+[color palette table]:cpt:_files' \
    '-D+[label offset]:dxdy:_default' \
    '-E+[event/track timing modifiers]:opts:_default' \
    '-F+[text/label modifiers]:opts:_default' \
    '-H+[box modifiers]:opts:_default' \
    '-K[allow more PS later]' \
    '-L+[duration mode]:length:_default' \
    '-M+[intensity/size/transparency modifier]:opts:_default' \
    '-N+[no-clip mode]:mode:(c r)' \
    '-O[append PostScript]' \
    '-P[portrait]' \
    '-Q+[script prefix to keep temp files]:prefix:_default' \
    '-S+[symbol type]:symbol:_default' \
    '-U+[plot timestamp]:opts:_default' \
    '-Z+[external command]:command:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[x shift]:shift:_default' \
    '-a+[aspatial column mapping]:cols:_default' \
    '-bi+[binary input format]:format:_default' \
    '-c+[subplot panel]:panel:_default' \
    '-di+[input nodata↔NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-l+[legend setting]:opts:_default' \
    '-p+[3D perspective]:view:_default' \
    '-qi+[record selection]:cols:_default' \
    '-w+[wraparound (cyclic)]:opts:_default' \
    '*:input event table:_files' \
    && ret=0

return ret
