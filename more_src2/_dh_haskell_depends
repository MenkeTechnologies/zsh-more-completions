#compdef dh_haskell_depends dh_haskell_provides dh_haskell_shlibdeps dh_haskell_extra_depends
# _dh_haskell_depends — debhelper for Haskell libraries (Debian/haskell-devscripts)
# upstream: https://salsa.debian.org/haskell-team/haskell-devscripts
# Flags from dh_haskell_depends.pod plus debhelper standard options.

_dh_haskell_depends() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '*-X+[exclude package]:pattern:' \
        '*--exclude=[exclude package]:pattern:' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-O+[option passed to the helper]:opt:' \
        '*:file:_files'
}

_dh_haskell_depends "$@"
