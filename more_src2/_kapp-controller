#compdef kapp-controller
# Documentation: https://github.com/carvel-dev/kapp-controller/blob/develop/cmd/controller/main.go
# Reference accessed: 2026-05-19
# Verified: upstream source (flag.*Var calls) at the URL above. Prior file
# invented --enable-leader-election --api-port --ca-cert-paths
# --dangerous-stop-on-error --max-concurrent-reconciles --*-min-resync-time;
# real flags are the std-library flags below (single dash also accepted).

# kapp-controller: Carvel package management controller for Kubernetes
local curcontext="$curcontext" ret=1
_arguments -C \
  '--concurrency=[max concurrent reconciles]:n:' \
  '--namespace=[namespace to watch]:ns:' \
  '--packaging-global-namespace=[namespace for global packaging resources]:ns:' \
  '--metrics-bind-address=[address for metrics server]:addr:' \
  '--dangerous-enable-pprof[enable pprof]' \
  '--api-request-timeout=[HTTP timeout for Kubernetes API requests]:duration:' \
  '--enable-api-priority-and-fairness=[enable APIPriorityAndFairness feature gate]:b:(true false)' \
  '--sidecarexec[run sidecarexec]' \
  '--start-api-server=[start apiserver]:b:(true false)' \
  '--tls-cipher-suites=[comma separated list of acceptable cipher suites]:list:' \
  '*::kapp-controller args:_files' && ret=0
return ret
