#compdef dhcpleased
# _dhcpleased — OpenBSD dhcpleased (DHCPv4 client daemon; watches interfaces with the AUTOCONF4 flag and configures them from leases; controlled at runtime by dhcpleasectl(8))
# upstream: https://github.com/openbsd/src (sbin/dhcpleased)
# Flags from sbin/dhcpleased/dhcpleased.8 on tip.

_dhcpleased() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-v[verbose]' \
        '-f+[config file (default /etc/dhcpleased.conf)]:file:_files' \
        '-s+[control socket (default /dev/dhcpleased.sock)]:file:_files'
}

_dhcpleased "$@"
