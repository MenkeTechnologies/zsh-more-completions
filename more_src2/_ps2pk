#compdef ps2pk
# Documentation: ps2pk usage (ps2pk version 1.8 TeX Live 2026)
# Source: convert a PostScript Type 1 font to PK bitmap format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug]' \
    '-v[verbose]' \
    '-e+[encoding (.enc)]:encoding:_files -g "*.enc"' \
    '-X+[horizontal resolution dpi]:xres:' \
    '-Y+[vertical resolution dpi]:yres:' \
    '-E+[character expansion factor]:expansion:' \
    '-S+[slant]:slant:' \
    '-O[use octal in output]' \
    '-P+[design point size]:pointsize:' \
    '-a+[AFM metric file]:afm:_files -g "*.afm"' \
    '-R+[base resolution dpi]:baseres:' \
    '1:type1 font:_files -g "*.(pfa|pfb)"' \
    '2:pk output:_files -g "*.pk"' \
    && ret=0

return ret
