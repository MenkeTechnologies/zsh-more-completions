#compdef realsr-ncnn realsr-ncnn-vulkan
# _realsr-ncnn — Tencent ncnn RealSR Vulkan image upscaler CLI alias (nihui / Tencent ncnn, C++); custom argparse
# upstream: https://github.com/nihui/realsr-ncnn-vulkan

_realsr-ncnn() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i+[input file or dir]:file:_files' \
        '-o+[output file or dir]:file:_files' \
        '-s+[upscale ratio]:n:(2 3 4 8 16)' \
        '-t+[tile size]:n:' \
        '-m+[model path]:dir:_files -/' \
        '-g+[gpu id]:n:' \
        '-j+[thread count load:proc:save]:str:' \
        '-x[enable tta mode]' \
        '-f+[output format]:fmt:(png webp jpg)' \
        '-v[verbose]' \
        '*:arg:'
}

_realsr-ncnn "$@"
