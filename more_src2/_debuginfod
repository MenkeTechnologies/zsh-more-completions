#compdef debuginfod
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '*-F[scan directory for ELF/DWARF files]:directory:_directories' \
  '*-R[scan directory for RPMs]:directory:_directories' \
  '*-U[scan directory for deb packages]:directory:_directories' \
  '*-Z[archive handler (ext=cmd)]:extension=command' \
  '-p[HTTP port to listen on]:port' \
  '-d[database path]:database file:_files' \
  '-t[number of threads]:thread count' \
  '*-v[increase verbosity]' \
  '-L[follow symbolic links]' \
  '-c[max cache size in MB]:cache size (MB)' \
  '-g[groom interval in seconds]:interval (seconds)' \
  '--fdcache-fds=[max file descriptors in cache]:count' \
  '--fdcache-mbs=[max cache size in MB]:size (MB)' \
  '--fdcache-prefetch=[prefetch count]:count' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && ret=0
return ret
