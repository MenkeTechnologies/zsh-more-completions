#compdef mongoldap
# Documentation: https://www.mongodb.com/docs/manual/reference/program/mongoldap/
# Reference accessed: 2026-05-19
# Verified: upstream mongoldap reference page.

# mongoldap: LDAP configuration validator for MongoDB
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-f --config)'{-f+,--config=}'[mongod config file]:file:_files' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '--user=[test user]:user:_users' \
  '--password=[test password]:pass:' \
  '--ldapServers=[LDAP server list]:hosts:' \
  '--ldapBindMethod=[bind method]:method:(simple sasl)' \
  '--ldapBindSaslMechanisms=[SASL mechanisms]:list:' \
  '--ldapBindWithOSDefaults=[Windows: bind with OS defaults]:bool:(true false)' \
  '--ldapTransportSecurity=[transport security]:val:(tls none)' \
  '--ldapTimeoutMS=[timeout ms]:ms:' \
  '--ldapQueryUser=[query user DN]:dn:' \
  '--ldapQueryPassword=[query password]:pass:' \
  '--ldapUserToDNMapping=[user-to-DN mapping]:json:' \
  '--ldapAuthzQueryTemplate=[authz query template]:template:' \
  '*::mongoldap args:_files' && ret=0
return ret
