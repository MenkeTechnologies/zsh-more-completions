#compdef devika
# _devika — stitionai Devika agentic AI software engineer with autonomous coding research and execution (stitionai team, Python); argparse
# upstream: https://github.com/stitionai/devika

_devika() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--port=+[port]:port:_ports' \
        '-p+[port]:port:_ports' \
        '--host=+[host]:host:_hosts' \
        '--config=+[config file]:file:_files -g "config.toml *.toml *.json"' \
        '-c+[config file]:file:_files -g "config.toml *.toml *.json"' \
        '--workspace-dir=+[workspace dir]:dir:_files -/' \
        '--api-key=+[provider:key]:str:' \
        '--no-browser[no browser]' \
        '--debug[debug logging]' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--log-file=+[log file]:file:_files' \
        '--db=+[sqlite db]:file:_files -g "*.db *.sqlite"' \
        '--reset[reset workspace]' \
        '--ollama-host=+[ollama url]:url:_urls' \
        '--lm-studio-host=+[lm studio url]:url:_urls' \
        '--ngrok=+[bool]:b:(true false)' \
        '--ngrok-auth=+[ngrok token]:str:'
}

_devika "$@"
