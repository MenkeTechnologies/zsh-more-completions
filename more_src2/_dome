#        if (STRINGS_EQUAL(argv[i], "fuse"))      run_fuse(argc, argv);
#        if (STRINGS_EQUAL(argv[i], "help"))      run_help(argc, argv);
#        if (STRINGS_EQUAL(argv[i], "nest"))      run_nest(argc, argv);
#        // Option flags with = embedded value:
#        if (strncmp(argv[i], "--buffer=", 9) == 0) {
#          AUDIO_BUFFER_SIZE = parse_buffer(argv[i] + 9);
#        }
#        if (strncmp(argv[i], "--screen=", 9) == 0) {
#          SCREEN = parse_int(argv[i] + 9);
#        }
#        if (STRINGS_EQUAL(argv[i], "-b") ||
#            STRINGS_EQUAL(argv[i], "--buffer")) {
#          AUDIO_BUFFER_SIZE = parse_buffer(argv[++i]);
#        }
#        if (STRINGS_EQUAL(argv[i], "-s") ||
#            STRINGS_EQUAL(argv[i], "--screen")) {
#          SCREEN = parse_int(argv[++i]);
#        }
#        if (STRINGS_EQUAL(argv[i], "-d") ||
#            STRINGS_EQUAL(argv[i], "--debug")) {
#          DEBUG_MODE = true;
#        }
#        // Remaining arg = entry path (game.egg or main.wren)
#      }
#    }
#  This pattern is COMMON for SMALL game engines and INDIE
#  TOOLS where the CLI surface is small enough that pulling
#  in a library would be over-engineering for a one-developer
#  hobby/indie project.  Shared with R424 Picat, R425 BQN, R436
#  Lobster — all hand-rolled C/C++ parsers in single-developer
#  language/engine projects.  DOME extends the basic pattern
#  with subcommand dispatch via `STRINGS_EQUAL(argv[i],
#  "subcmd")` matched against the first non-flag positional.
#  Wren is the FIRST DOCUMENTED Wren CLI library in the
#  corpus's cross-language taxonomy.  Wren joins the 39 other
#  documented languages as the 40th represented language.
#  Brings cross-language CLI library taxonomy variant count to
#  187 (186 + hand-rolled-DOME = 187).
#
#  Surface (verbatim from `src/main.c` print_usage() function
#  + STRINGS_EQUAL strcmp dispatch):
#
#  Usage:
#    dome [options] [<command>]
#    dome [options] [--] <entry_path> [<argument>...]
#    dome -h | --help
#    dome -v | --version
#
#  Available Commands:
#    embed                          Convert a Wren source file
#                                   to a C include file for
#                                   plugin development (lets
#                                   game devs bundle Wren scripts
#                                   directly into custom plugin
#                                   .so/.dll files for
#                                   distribution alongside their
#                                   .egg)
#    fuse                           Merge a .egg bundle with the
#                                   DOME binary to make a
#                                   STANDALONE executable that
#                                   contains both the engine
#                                   and the game (for shipping
#                                   single-file game builds)
#    help                           Display information on how
#                                   to use each command (run
#                                   `dome help embed` for embed-
#                                   specific docs)
#    nest                           Bundle a project directory
#                                   (Wren source + assets) into
#                                   a single .egg file that DOME
#                                   can load at runtime
#
#  Options:
#    -b, --buffer=<BUF>             Set the audio buffer size
#                                   (Default: 11 = 2048 samples
#                                   = ~46ms latency at 44.1kHz)
#    -s, --screen=<NUM>             Set the display screen which
#                                   window will be opened on
#                                   (Default: 0 = primary
#                                   display; useful for
#                                   multi-monitor dev setups)
#    -c, --console                  (Windows MinGW build only)
#                                   Open a console window for
#                                   development (allows seeing
#                                   stdout from `System.print`
#                                   in Wren code on Windows
#                                   where games normally have
#                                   no terminal)
#    -d, --debug                    Enable debug mode (compile-
#                                   time `DEBUG` build flag
#                                   defaults this to true;
#                                   explicit flag overrides for
#                                   release builds)
#    -h, --help                     Show usage screen and exit
#    -v, --version                  Show DOME version and exit
#
#  Positional:
#    <entry_path>                   Path to a .egg file (DOME
#                                   bundle), a directory
#                                   containing main.wren, or a
#                                   single .wren file.  When
#                                   absent, DOME looks for
#                                   game.egg in current
#                                   directory, then main.wren,
#                                   then errors out.
#    <argument>...                  Arguments to pass to the
#                                   Wren program (accessible
#                                   from Wren code via
#                                   `Process.allArguments` or
#                                   the `--` argv slot)
#    --                             Separator — anything after
#                                   becomes the Wren program's
#                                   argv (POSIX convention)
#
#  Examples:
#    dome                                           # Auto-find game.egg or main.wren
#    dome game.egg                                  # Run specific .egg bundle
#    dome main.wren                                 # Run specific .wren file
#    dome ./my-game/                                # Run from directory (loads main.wren)
#    dome -d main.wren                              # Run with debug mode
#    dome -b 14 main.wren                           # Larger audio buffer (less audio underrun)
#    dome --screen=1 main.wren                      # Open on second monitor
#    dome embed sprite.wren > sprite_embedded.c     # Convert Wren script to C include
#    dome fuse game.egg                             # Make standalone DOME+game binary
#    dome nest ./my-game/ -o game.egg               # Bundle project into .egg
#    dome help embed                                # Per-command help
#    dome -- arg1 arg2                              # Pass arg1/arg2 to Wren code
#    dome main.wren -- player-name=Alice            # User args after --
#    dome --version                                 # Print "dome 1.x.x"
#    dome --help                                    # Print usage screen
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  similar Wren / game-engine binaries):
#    - wren_cli (IN CORPUS via _wren_cli — the canonical Wren
#      interpreter binary; minimal CLI surface (--help/--version
#      + file path); previously documented but Wren language not
#      formally entered into taxonomy until R448)
#    - tic80 (IN CORPUS + STOCK via _tic80 — TIC-80 fantasy
#      console; supports multiple languages including Wren)
#    - love (IN CORPUS via _love — LOVE2D Lua game framework;
#      sister tool)
#    - lobster (IN CORPUS via _lobster — R436 documented; closest
#      related compiled game-scripting language)
#    - pico8 (commercial Pico-8 fantasy console — closest
#      spiritual sibling; not in corpus since commercial)
#    - godot (IN CORPUS + STOCK — uses GDScript not Wren)
#    - defold (commercial Defold engine — not in corpus)
# ============================================================================

_dome() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '(-h --help)'{-h,--help}'[show usage screen and exit]' \
    '(-v --version)'{-v,--version}'[show DOME version and exit]' \
    '(-b --buffer)'{-b,--buffer=}'[set the audio buffer size]:buffer:' \
    '(-s --screen)'{-s,--screen=}'[set the display screen number]:screen:' \
    '(-c --console)'{-c,--console}'[(Windows) open a console window for development]' \
    '(-d --debug)'{-d,--debug}'[enable debug mode]' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'embed:convert Wren source to C include for plugin development'
        'fuse:merge .egg bundle with DOME binary for standalone executable'
        'help:display info on how to use each command'
        'nest:bundle project into a single .egg file'
      )
      _describe -t subcommands 'dome subcommand' subcmds
      _files -g "*.(egg|wren)"
      ;;
    args)
      case "${words[1]}" in
        embed)
          _arguments -s -S '*:file:_files -g "*.wren"'
          ;;
        fuse)
          _arguments -s -S '*:file:_files -g "*.egg"'
          ;;
        nest)
          _arguments -s -S '*:dir:_directories'
          ;;
        help)
          local -a helpcmds
          helpcmds=('embed' 'fuse' 'nest')
          _describe -t subcommands 'command' helpcmds
          ;;
      esac
      ;;
  esac
}

_dome "$@"
