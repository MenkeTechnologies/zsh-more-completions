#compdef feedr
# ============================================================================
# feedr - terminal-based RSS/Atom feed reader
#          with TUI + categorization +
#          full-text extraction
#          (Rust, MIT)
#
# Author : Gokul (bahdotsh)
# Upstream: https://github.com/bahdotsh/feedr
#
# `feedr` is a modern terminal-based RSS +
# Atom feed reader built with Rust + ratatui.
# Provides:
#   - **Multi-feed subscriptions** (managed
#     via OPML import or interactive add)
#   - **Categorization** (tag feeds + filter
#     by category in the TUI)
#   - **Full-text extraction** (when a feed
#     entry's summary is truncated, fetch
#     the full article HTML + extract via
#     readability + dom_smoothie)
#   - **Search** (full-text search across
#     stored entries)
#   - **OPML import/export** (standard feed
#     subscription portability format)
#   - **Compressed HTTP** (gzip + deflate +
#     brotli encoding negotiation for
#     bandwidth-efficient feed polling)
#   - **TUI configuration editor**
#     (interactive theme + UI settings via
#     feedr config --tui)
#   - **CLI configuration management**
#     (get/set/list via feedr config sub-
#     commands)
#
# Distinguishing features vs alternatives
# (newsboat + tt-rss + miniflux + FreshRSS):
#   - **Terminal-only** (no browser; no
#     daemon; runs locally)
#   - **Rust performance** (low memory +
#     fast feed parsing via feed-rs)
#   - **Full-text extraction built-in**
#     (most TUI readers require external
#     readability service)
#   - **Modern ratatui interface**
#     (responsive layout + mouse support +
#     ANSI styling)
#   - **TOML config + dot-notation
#     getters** (feedr config get ui.theme
#     style)
#
# Use cases:
#   - Personal RSS reader for the terminal
#     (newsboat alternative with Rust
#     performance)
#   - Following technical blogs + project
#     announcement feeds + GitHub release
#     RSS
#   - Reading long-form articles offline
#     (full-text extraction caches the
#     article body locally)
#   - Migrating from another RSS reader
#     (OPML import)
#   - Server-side feed aggregation that
#     pushes summaries to a terminal
#     dashboard
#
# Usage:
#   feedr                          - launch
#                                     the
#                                     TUI
#                                     interface
#                                     (default
#                                     action)
#   feedr -i <opml>                - import
#                                     OPML file
#                                     + exit
#   feedr config [subcommand]      - manage
#                                     configuration
#
# Top-level flags:
#   -i, --import <opml file>       - OPML
#                                     subscription
#                                     list to
#                                     import
#                                     into
#                                     feedr's
#                                     feed
#                                     database
#   -h, --help                     - show
#                                     help
#   -V, --version                  - show
#                                     version
#
# Subcommands:
#   config                         - manage
#                                     configuration
#                                     (TOML
#                                     file at
#                                     ~/.config
#                                     /feedr/
#                                     config
#                                     .toml on
#                                     Linux
#                                     +
#                                     equivalent
#                                     elsewhere)
#
# `config` flags + subcommands:
#       --tui                      - open
#                                     interactive
#                                     TUI
#                                     config
#                                     editor
#   config get <key>               - get a
#                                     config
#                                     value
#                                     by
#                                     dot-
#                                     notation
#                                     key
#                                     (e.g.
#                                     ui.theme
#                                     +
#                                     feeds
#                                     .auto-
#                                     refresh-
#                                     interval)
#   config set <key> <value>       - set a
#                                     config
#                                     value
#   config list                    - list
#                                     all
#                                     config
#                                     keys
#                                     and
#                                     values
#                                     (default
#                                     if no
#                                     subcommand)
#
# Example invocations:
#   # Launch TUI reader
#   feedr
#
#   # Import an OPML subscription list
#   feedr --import feeds.opml
#
#   # List all configuration keys + values
#   feedr config list
#
#   # Get a single config value
#   feedr config get ui.theme
#
#   # Set a config value
#   feedr config set ui.theme dark
#   feedr config set feeds.auto-refresh-interval 3600
#
#   # Open interactive TUI config editor
#   feedr config --tui
#
# TUI key bindings (default, customizable
# in config):
#   q                              - quit
#   j / Down                       - next
#                                     entry
#   k / Up                         - prev
#                                     entry
#   r                              - refresh
#                                     all
#                                     feeds
#   /                              - search
#   c                              - filter
#                                     by
#                                     category
#   o                              - open
#                                     entry
#                                     URL in
#                                     browser
#   Enter                          - open
#                                     entry
#                                     in
#                                     reader
#                                     pane
#   Tab                            - switch
#                                     pane
#                                     focus
#
# The scraper lane is built on `scraper =
# "0.18"` (declared verbatim at upstream
# Cargo.toml HEAD as a direct dep, imported
# by the full-text extraction module for
# parsing fetched article HTML + applying
# readability heuristics to extract the main
# article body), the canonical Rust HTML
# parsing + CSS-selector library by Charles
# Edward Pax (causal-agent / charlespax) -
# github.com/causal-agent/scraper.
#
# scraper is the de-facto canonical Rust
# HTML scraping library:
#   - **Built on html5ever** (Mozilla
#     Servo's spec-compliant HTML5 parser;
#     part of the Servo browser engine
#     research project; the most rigorous
#     pure-Rust HTML parser)
#   - **CSS3 selector engine** (via
#     selectors crate; the same selector
#     library Servo uses)
#   - **jQuery-style API** (select() +
#     attr() + text() + html() methods on
#     parsed documents)
#   - **HTML serialization** (round-trip
#     parsing + serialization preserves
#     document fidelity)
#   - **Pure-Rust implementation** (no C
#     dependencies)
#   - 2,800+ stars on github.com/
#     causal-agent/scraper
#   - ~4,500 reverse-deps on crates.io
#
# scraper's distinguishing position vs Rust
# HTML parsing alternatives:
#   - causal-agent/scraper (Pax):
#     canonical; html5ever-backed; CSS
#     selectors; THIS AXIS
#   - kuchikiki (kuchikiki/kuchikiki):
#     html5ever-backed with tree traversal
#     API; smaller adoption
#   - html5ever (servo/html5ever): the
#     underlying low-level parser; not a
#     scraping API; scraper builds on it
#   - select (utkarshkukreti/select.rs):
#     older alternative; less actively
#     maintained
#   - htmlescape: HTML escaping only
#     (no parsing)
#
# Charles Edward Pax (causal-agent) is the
# original author + maintainer of scraper.
# Pax's focus is on practical web scraping
# tooling - scraper bridges the gap between
# the low-level html5ever parser (which is
# part of the Servo project) and the
# high-level developer needs of selecting
# + extracting page content via familiar
# CSS selectors.
#
# scraper's foundational dependencies are
# the Mozilla Servo project libraries:
#   - **html5ever** (HTML5 parser; Servo
#     team; canonical Rust HTML parsing)
#   - **selectors** (CSS3 selector
#     engine; Servo team; canonical Rust
#     CSS selector matching)
#   - **string_cache** (interned string
#     storage; Servo team; canonical
#     Rust atom-style strings)
#
# These Servo libraries are the *de-facto
# canonical Rust HTML + CSS infrastructure*
# in the ecosystem. The Servo project
# itself paused active browser
# development in 2024 but its parsing
# libraries continue as foundational
# infrastructure used by scraper +
# kuchikiki + many other downstream
# tools.
#
# Multi-axis canonical-Rust author/org
# cohort extension (now spanning even more
# distinct authors):
#   - + Charles Edward Pax + Mozilla
#     Servo project (causal-agent/scraper
#     + servo/html5ever + servo/selectors
#     + servo/string_cache; THIS AXIS;
#     canonical Rust HTML scraping +
#     foundational HTML5 parsing
#     infrastructure from the Servo
#     browser engine project)
#
# Pax + Servo joining the canonical-Rust
# cohort at the *browser-engine-derived
# canonical infrastructure* level is
# structurally distinctive. The Servo
# project's parsing libraries are the
# *production-extracted from a major
# browser project* pattern - similar to:
#   - Cloudflare's quiche (extracted
#     from CF edge production)
#   - Buoyant's linkerd-tcp (extracted
#     from linkerd2 data plane)
#   - tokio-rs's hyper + h2 (extracted
#     from Node Buffer-style I/O
#     primitives)
#   - Mozilla Servo's html5ever +
#     selectors (extracted from the
#     Servo browser engine; THIS AXIS)
#
# The *extracted-from-production-browser*
# pattern is one of the canonical paths to
# library canonical-status in Rust.
#
# feedr uses scraper for:
#   - Parsing the full-text article HTML
#     fetched from feed entry URLs
#   - Applying CSS selectors to identify
#     the main article body element
#     (used as input to the readability
#     extraction via dom_smoothie)
#   - Extracting image URLs + alt text
#     for the reader pane display
#   - Cleaning up navigation + advertising
#     + footer elements before
#     readability extraction
#
# This is the canonical use case for
# scraper in production: full-text
# extraction pipelines where article
# content needs to be isolated from
# surrounding page chrome (navigation +
# ads + comments + related posts).
#
# ----------------------------------------------------------------------------
# AXIS 285 :: HTML parsing + scraping
#              libraries
#              (HTML5 spec-compliant
#              parsers + CSS selector
#              engines for web scraping +
#              full-text extraction + DOM
#              manipulation)
# Round 1553 :: Rust slot 1 of 4 :: OPENS Axis 285
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : causal-agent/scraper       - Charles
#                                          Edward
#                                          Pax
#                                          (canonical
#                                          Rust HTML
#                                          scraping +
#                                          built on
#                                          Mozilla
#                                          Servo
#                                          html5ever
#                                          + selectors)
#   Go      : PuerkitoBio/goquery        - Martin
#                                          Angers
#                                          (canonical
#                                          Go HTML
#                                          scraping +
#                                          jQuery-style
#                                          API)
#   TS/Node : cheeriojs/cheerio          - Felix
#                                          Böhm +
#                                          maintainers
#                                          (canonical
#                                          Node HTML
#                                          scraping +
#                                          jQuery-style
#                                          API)
#
# HTML parsing + CSS-selector-based
# scraping is the *foundational web data
# extraction primitive* across modern
# web tooling:
#   - **WHATWG HTML spec** (the canonical
#     HTML parsing spec at html.spec.whatwg
#     .org; replaces the older W3C HTML
#     specs)
#   - **CSS Selectors Level 4** (the
#     canonical CSS selector spec at
#     drafts.csswg.org/selectors-4)
#   - **Used in**: web scraping pipelines
#     + full-text extraction + content
#     migration + HTML-to-PDF/EPUB
#     conversion + RSS feed enrichment +
#     web archive analysis
#
# Each canonical library provides:
#   - WHATWG HTML5 spec-compliant
#     parsing (tolerant of malformed
#     HTML in the wild)
#   - CSS selector matching against
#     parsed documents
#   - jQuery-style API for DOM
#     traversal + extraction
#   - HTML serialization (round-trip
#     fidelity)
#
# Notable: ALL THREE canonical libraries
# adopt the *jQuery-style API* pattern
# (popularized by jQuery's $ in
# JavaScript). This is one of the
# clearest examples of API design
# convention propagating across
# languages - jQuery's CSS-selector +
# chained-method API became the de-facto
# pattern for HTML scraping across
# Rust + Go + Node despite all three
# being independent implementations.
#
# Use-case spectrum for this axis (so far):
#   - feedr (Rust, scraper): RSS reader
#     full-text extraction pipeline
#     (parsing fetched article HTML for
#     main-content isolation via
#     readability heuristics)
# ============================================================================

_feedr() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-i --import)'{-i+,--import=}'[OPML file to import]:file:_files -g "*.opml"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_feedr_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                config)
                    _arguments \
                        '--tui[open interactive TUI config editor]' \
                        '1: :(get set list)' \
                        '*::config-arg:'
                    ;;
            esac
            ;;
    esac

    return ret
}

_feedr_cmds() {
    local -a cmds
    cmds=(
        'config:manage configuration'
    )
    _describe -t commands 'feedr command' cmds
}

_feedr "$@"
