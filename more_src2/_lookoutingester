#compdef lookoutingester armada-lookout-ingester
# _lookoutingester — Armada Lookout Ingester (consumes job events from Pulsar and writes them to the Lookout Postgres store)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/lookoutingester/main.go on tip; everything else lives in the YAML config (./config/lookoutingester or --config).

_lookoutingester() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"' \
        '--benchmark[run Lookout Ingester benchmarks instead of the application]'
}

_lookoutingester "$@"
