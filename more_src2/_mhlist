#compdef mhlist
# Documentation: man mhlist(1)
# Source: nmh uip/mhlist.c (master) — list parts of a MIME message (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-check -nocheck)-check[check MIME structure]' \
    '(-check -nocheck)-nocheck[no check]' \
    '(-headers -noheaders)-headers[show headers]' \
    '(-headers -noheaders)-noheaders[no headers]' \
    '(-realsize -norealsize)-realsize[show real size]' \
    '(-realsize -norealsize)-norealsize[no real size]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-disposition -nodisposition)-disposition[show Content-Disposition]' \
    '(-disposition -nodisposition)-nodisposition[no Content-Disposition]' \
    '-file+[message file]:file:_files' \
    '*-part+[part number]:N:_default' \
    '*-type+[content type filter]:type:_default' \
    '-rcache+[read cache policy]:policy:(public private never ask)' \
    '-wcache+[write cache policy]:policy:(public private never ask)' \
    '(-changecur -nochangecur)-changecur[change current message]' \
    '(-changecur -nochangecur)-nochangecur[do not change current]' \
    '-version[show version]' \
    '-help[show help]' \
    '-debug[debug output]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
