#compdef diffusers diffusers-cli
# _diffusers — Hugging Face Diffusers library CLI alias (Hugging Face, Python); custom argparse
# upstream: https://github.com/huggingface/diffusers

_diffusers() {
    local -a sub=(
        'env:show environment info'
        'fp16_safetensors:convert FP16 safetensors'
        'login:login to Hugging Face'
        'whoami:show current user'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'diffusers subcommand' sub ;;
        args)
            case $words[1] in
                fp16_safetensors) _arguments \
                    '--ckpt_path=+[checkpoint path]:file:_files' \
                    '--repo_id=+[repo id]:str:' \
                    '--filename=+[filename]:str:' \
                    '--use-auth-token[use auth token]' \
                    '--fp16[fp16]' \
                    '--variant=+[variant]:str:' \
                    '--output_dir=+[output dir]:dir:_files -/' \
                    '--commit_message=+[commit message]:str:' ;;
                login) _arguments \
                    '--token=+[token]:str:' \
                    '--add-to-git-credential[add to git credential]' ;;
            esac
            ;;
    esac
}

_diffusers "$@"
