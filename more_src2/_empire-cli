#compdef empire-cli starkiller-cli
# _empire-cli — BC-Security empire-cli CLI text-based Empire 5 client connecting to the empire server REST API providing prompt-toolkit interactive shell for managing listeners agents stagers modules credentials chats reporting for authorized red-team operations (BC-Security team, Python); argparse
# upstream: https://github.com/BC-SECURITY/Empire

_empire-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--server=+[name]:str:' \
        '--port=+[port]:n:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--use-server=+[name]:str:' \
        '--restport=+[port]:n:' \
        '--no-banner[no banner]' \
        '*::'
}

_empire-cli "$@"
