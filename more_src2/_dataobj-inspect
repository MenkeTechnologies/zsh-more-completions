#compdef dataobj-inspect
# _dataobj-inspect — inspect Loki dataobj v2 files (grafana/loki)
# upstream: https://github.com/grafana/loki
# Subcommands from cmd/dataobj-inspect/ (kingpin/v2).

_dataobj-inspect() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                dump:'dump the contents of the data object'
                stats:'print stats for the data object'
                list-streams:'list all streams in the data object'
                print-streams:'print streams in the data object'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                dump)
                    _arguments \
                        '--print-lines[print lines of each column]' \
                        '--tenant=[tenant to dump]:tenant:' \
                        '--stream=[stream id to dump]:id:' \
                        '*:file:_files' ;;
                list-streams)
                    _arguments \
                        '--tenant=[filter to specific tenant]:tenant:' \
                        '*:file:_files' ;;
                print-streams)
                    _arguments \
                        '*--stream-id=[stream id to print lines for]:id:' \
                        '*:file:_files' ;;
                stats)
                    _arguments \
                        '*:file:_files' ;;
            esac
            ;;
    esac
}

_dataobj-inspect "$@"
