#compdef powerstat
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/powerstat.8.html
# Reference accessed: 2026-05-30
# powerstat — Canonical's power consumption + thermal + CPU C-state monitor.
# Reads from battery discharge rate by default; -R switches to RAPL for AC-power
# instantaneous draw. Positional args: delay (seconds, default depends on source)
# and samples count.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-a[enable all: equivalent to -c -f -t -H]' \
  '-b[redo sample if system is busy (<98% CPU idle)]' \
  '-c[gather CPU C-state activity (% time + count per state)]' \
  '-d+[delay seconds before starting (default 180 on battery, 0 on RAPL)]:seconds:' \
  '-D[show all power-domain readings (extra power stats)]' \
  '-f[show average frequency across all on-line CPU cores]' \
  '-g[show GPU power readings (Intel i915 only)]' \
  '-H[show histogram of power measurements]' \
  '-i+[idle-threshold % to force re-sample]:percent:' \
  '-n[no column headings]' \
  '-p[redo sample if any process fork/exec/exit]' \
  '-r[redo if not idle AND any process fork/exec/exit]' \
  '-R[read from RAPL (Running Average Power Limit) domains]' \
  '-s[dump log of process fork/exec/exit activity on completion]' \
  '-S[use standard averaging instead of rolling average]' \
  '-t[gather temperatures from all thermal zones]' \
  '-z[ignore zero power-rate readings from battery]' \
  '1:delay (seconds between samples):' \
  '2:number of samples:' \
  && ret=0

return ret
