#compdef jekyll-cli
# _jekyll-cli — Jekyll Ruby static site generator CLI alias (Jekyll team, Ruby); mercenary
# upstream: https://github.com/jekyll/jekyll

_jekyll-cli() {
    local -a sub=(
        'build:build the site'
        'b:build the site (alias)'
        'clean:remove generated files'
        'doctor:diagnose site'
        'help:show help'
        'new:scaffold new site'
        'new-theme:scaffold theme'
        'serve:run dev server'
        'server:run dev server (alias)'
        's:run dev server (alias)'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--source=+[source dir]:dir:_files -/' \
        '-s+[source dir]:dir:_files -/' \
        '--destination=+[destination dir]:dir:_files -/' \
        '-d+[destination dir]:dir:_files -/' \
        '--safe[safe mode]' \
        '--plugins=+[plugins dir]:list:_files -/' \
        '-p+[plugins dir]:list:_files -/' \
        '--layouts=+[layouts dir]:dir:_files -/' \
        '--config=+[config file]:list:_files -g "*.yml *.yaml"' \
        '--profile[profile liquid renderings]' \
        '--trace[show stack trace]' \
        '-t[show stack trace]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'jekyll subcommand' sub ;;
        args)
            case $words[1] in
                serve|server|s) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '-P+[port]:port:' \
                    '--baseurl=+[baseurl]:str:' \
                    '-b+[baseurl]:str:' \
                    '--detach[detach from terminal]' \
                    '-B[detach from terminal]' \
                    '--skip-initial-build[skip initial build]' \
                    '--show-dir-listing[show dir listing]' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--no-watch[no watch]' \
                    '--unpublished[include unpublished]' \
                    '--drafts[include drafts]' \
                    '-D[include drafts]' \
                    '--future[include future]' \
                    '--lsi[lsi]' \
                    '--limit-posts=+[limit posts]:n:' \
                    '--livereload[livereload]' \
                    '-l[livereload]' \
                    '--livereload-ignore=+[livereload ignore]:list:' \
                    '--livereload-min-delay=+[livereload min delay]:n:' \
                    '--livereload-max-delay=+[livereload max delay]:n:' \
                    '--livereload-port=+[livereload port]:port:' \
                    '--ssl-cert=+[ssl cert]:file:_files' \
                    '--ssl-key=+[ssl key]:file:_files' \
                    '--show-drafts[show drafts]' \
                    '--incremental[incremental build]' \
                    '-I[incremental build]' \
                    '--open-url[open browser]' \
                    '-o[open browser]' ;;
                build|b) _arguments \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--no-watch[no watch]' \
                    '--drafts[include drafts]' \
                    '-D[include drafts]' \
                    '--future[include future]' \
                    '--unpublished[include unpublished]' \
                    '--lsi[lsi]' \
                    '--limit-posts=+[limit posts]:n:' \
                    '--incremental[incremental build]' \
                    '-I[incremental build]' \
                    '--baseurl=+[baseurl]:str:' \
                    '-b+[baseurl]:str:' ;;
                new) _arguments \
                    '1:project-name:' \
                    '--blank[blank]' \
                    '--force[force]' \
                    '--skip-bundle[skip bundle]' ;;
                new-theme) _arguments \
                    '1:theme-name:' \
                    '--code-of-conduct[include code of conduct]' \
                    '-c[include code of conduct]' \
                    '--force[force]' ;;
                doctor|hyde) _arguments '*:arg:' ;;
                clean) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_jekyll-cli "$@"
