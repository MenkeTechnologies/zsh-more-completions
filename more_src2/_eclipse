#compdef eclipse
# _eclipse — Eclipse IDE launcher (Eclipse Foundation, Java); custom argparse
# upstream: https://github.com/eclipse-platform/eclipse.platform

_eclipse() {
    _arguments \
        '--help[show help]' \
        '-help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-clean[wipe cached info]' \
        '-data+[workspace location]:dir:_files -/' \
        '-configuration+[configuration dir]:dir:_files -/' \
        '-dev[development mode classpath]' \
        '-arch+[architecture]:arch:(x86 x86_64 aarch64 arm)' \
        '-application+[application id]:id:' \
        '-product+[product id]:id:' \
        '-debug+[debug options file]:file:_files' \
        '-console+[OSGi console port]:port:' \
        '-consoleLog[log to console]' \
        '-noExit[do not exit after running app]' \
        '-noLazyRegistryCacheLoading[no lazy registry cache loading]' \
        '-noregistrycache[no registry cache]' \
        '-noSplash[no splash]' \
        '-os+[OS]:os:(linux macosx win32 aix solaris)' \
        '-pluginCustomization+[plugin customization file]:file:_files' \
        '-refresh[refresh on startup]' \
        '-showLocation+[show location label]:str:' \
        '-shutdownTimeout+[shutdown timeout secs]:n:' \
        '-startup+[startup jar]:file:_files' \
        '-vm+[JVM path]:file:_files' \
        '-vmargs[JVM args sentinel]:*::jvm-args:' \
        '-ws+[window system]:ws:(gtk cocoa win32)' \
        '-perspective+[perspective id]:id:' \
        '-showsplash+[splash bitmap]:file:_files' \
        '-stdout+[stdout redirect]:file:_files' \
        '-stderr+[stderr redirect]:file:_files' \
        '-eclipse.consoleLog[log to console]' \
        '-keyring+[secure storage file]:file:_files' \
        '-password+[password file]:file:_files' \
        '*:file:_files'
}

_eclipse "$@"
