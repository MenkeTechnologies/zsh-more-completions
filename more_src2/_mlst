#compdef mlst
# _mlst — Torsten Seemann tseemann mlst CLI rapid Multi-Locus Sequence Typing scanner for bacterial pathogen genome assemblies querying PubMLST.org schemes for Staphylococcus aureus E. coli Salmonella Streptococcus Klebsiella Mycobacterium Pseudomonas allele-call ST profile assignment (Torsten Seemann team, Perl); getopt
# upstream: https://github.com/tseemann/mlst

_mlst() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--check[check installation]' \
        '--scheme=+[scheme]:str:' \
        '--list[list available schemes]' \
        '--longlist[list with details]' \
        '--exclude=+[s]:str:' \
        '--minid=+[N]:n:' \
        '--mincov=+[N]:n:' \
        '--minscore=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--datadir=+[dir]:dir:_files -/' \
        '--blastdb=+[file]:file:_files' \
        '--legacy[legacy output]' \
        '--label=+[label]:str:' \
        '--nopath[do not show path]' \
        '--novel=+[file]:file:_files -g "*.fasta *.fa"' \
        '--csv[CSV output]' \
        '--json[JSON output]' \
        '*:fasta file:_files -g "*.fa *.fasta *.fna *.fas *.gz"'
}

_mlst "$@"
