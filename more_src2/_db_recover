#compdef db_recover
# Documentation: db_recover usage (Berkeley DB 18.1.40)
# Source: run Berkeley DB transaction recovery.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-c[catastrophic recovery]' \
    '-e[retain env after recovery]' \
    '-f[fatal recovery]' \
    '-v[verbose]' \
    '-b+[blob directory]:dir:_files -/' \
    '-h+[environment home]:dir:_files -/' \
    '-P+[password]:password:' \
    '-r+[region directory]:dir:_files -/' \
    '-t+[time-based recovery [[CC]YY]MMDDhhmm[.SS]]:date:' \
    && ret=0

return ret
