#compdef notmuch-addrlookup
# _notmuch-addrlookup — find email addresses indexed by notmuch (aperezdc/notmuch-addrlookup-c)
# upstream: https://github.com/aperezdc/notmuch-addrlookup-c
# Flags from notmuch-addrlookup.c (GOptionEntry).

_notmuch-addrlookup() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-f --format)'{-f+,--format=}'[output format]:fmt:(default mutt aerc)' \
        '(-m --mutt)'{-m,--mutt}'[deprecated: format for mutt]' \
        '(-c --config)'{-c+,--config=}'[notmuch config file]:file:_files' \
        '*:search term:'
}

_notmuch-addrlookup "$@"
