#compdef lance
# Documentation: https://github.com/lancedb/lance
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. STUB: no first-party `lance`
# CLI binary exists in lancedb/lance upstream as of 2026-05; project provides
# Python (pylance), TypeScript, and Rust SDKs instead. Completion file kept
# as a minimal stub for third-party wrappers that may install a `lance`
# entry-point.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*:: :_files' && ret=0
return ret
