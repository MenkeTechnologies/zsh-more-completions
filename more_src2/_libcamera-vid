#compdef libcamera-vid rpicam-vid
# Documentation: https://www.raspberrypi.com/documentation/computers/camera_software.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Note: rpicam-apps replaced libcamera-* on Raspberry Pi OS Bookworm (2023);
# legacy libcamera-vid name retained for compatibility with older systems.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'=[verbosity level]:level:(0 1 2)' \
  '--list-cameras[list available cameras]' \
  '--camera=[camera index]:index:' \
  '(-t --timeout)'{-t,--timeout}'=[recording duration in ms (0=infinite)]:milliseconds:' \
  '(-o --output)'{-o+,--output=}'[output file or URL]:file:_files' \
  '--width=[capture width]:width:' \
  '--height=[capture height]:height:' \
  '--viewfinder-width=[viewfinder width]:width:' \
  '--viewfinder-height=[viewfinder height]:height:' \
  '(-n --nopreview)'{-n,--nopreview}'[do not show preview]' \
  '(-p --preview)'{-p+,--preview=}'[preview window x,y,w,h]:geom:' \
  '--qt-preview[use Qt preview window]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen preview]' \
  '--info-text=[info text overlay format]:text:' \
  '--codec=[video codec]:codec:(h264 mjpeg yuv420 libav)' \
  '--libav-format=[libav container format]:format:' \
  '--libav-audio[record audio with libav]' \
  '--save-pts=[save timestamps to file]:file:_files' \
  '(-q --quality)'{-q+,--quality=}'[JPEG quality for MJPEG]:quality:' \
  '(-b --bitrate)'{-b+,--bitrate=}'[H.264 bitrate (bits/s)]:bitrate:' \
  '--profile=[H.264 profile]:profile:(baseline main high)' \
  '--level=[H.264 level]:level:(4 4.1 4.2)' \
  '--intra=[intra-frame period]:period:' \
  '--inline[insert inline H.264 headers]' \
  '--listen[listen for TCP connections]' \
  '--segment=[segment output files (ms)]:milliseconds:' \
  '--circular=[circular buffer size]:size:' \
  '--frames=[number of frames to capture]:frames:' \
  '--flush[flush output after every frame]' \
  '--low-latency[low-latency encoding (Pi 5)]' \
  '--sync=[camera sync mode]:mode:(off server client)' \
  '--metadata=[embed metadata in output]:file:_files' \
  '--metadata-format=[metadata format]:format:' \
  '--hdr=[HDR mode]:mode:(off auto sensor single-exp)' \
  '--hflip[horizontal flip]' \
  '--vflip[vertical flip]' \
  '--rotation=[image rotation degrees]:degrees:(0 90 180 270)' \
  '--roi=[region of interest (x,y,w,h normalised)]:roi:' \
  '--shutter=[shutter time in microseconds]:us:' \
  '--gain=[analogue gain]:gain:' \
  '--metering=[metering mode]:mode:(centre spot average matrix custom)' \
  '--exposure=[exposure mode]:mode:(normal sport short long custom)' \
  '--ev=[EV compensation]:ev:' \
  '--awb=[AWB mode]:mode:(auto incandescent tungsten fluorescent indoor daylight cloudy custom)' \
  '--awbgains=[AWB gains red,blue]:gains:' \
  '--brightness=[brightness -1.0..1.0]:value:' \
  '--contrast=[contrast 0..]:value:' \
  '--saturation=[saturation 0..]:value:' \
  '--sharpness=[sharpness 0..]:value:' \
  '--denoise=[denoise mode]:mode:(auto off cdn_off cdn_fast cdn_hq)' \
  '--framerate=[framerate (fps)]:fps:' \
  '--tuning-file=[camera tuning file]:file:_files' \
  '--mode=[sensor mode WxH:bits:packed]:mode:' \
  '--buffer-count=[number of buffers]:n:' \
  '--autofocus-mode=[AF mode]:mode:(default manual auto continuous)' \
  '--autofocus-range=[AF range]:range:(normal macro full)' \
  '--autofocus-speed=[AF speed]:speed:(normal fast)' \
  '--autofocus-window=[AF window x,y,w,h]:window:' \
  '--lens-position=[manual lens position]:dioptre:' \
  '*:file:_files' && ret=0

return ret
