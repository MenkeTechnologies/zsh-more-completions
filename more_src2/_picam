#compdef picam
# _picam — iizukanao picam CLI for the Raspberry Pi continuous H.264 HLS live-streaming recorder with audio mixing post-buffer pre-buffer subtitles preview overlay snapshot-on-recordings hooks (iizukanao team, C); getopt
# upstream: https://github.com/iizukanao/picam

_picam() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--width=+[N]:n:' \
        '--height=+[N]:n:' \
        '--fps=+[F]:f:' \
        '--videobitrate=+[bps]:n:' \
        '--keyframeinterval=+[N]:n:' \
        '--avcprofile=+[p]:p:(baseline main high)' \
        '--avclevel=+[level]:l:(3.1 3.2 4.0 4.1 4.2 5.0 5.1 5.2)' \
        '--qpmin=+[N]:n:' \
        '--qpmax=+[N]:n:' \
        '--qpinitial=+[N]:n:' \
        '--qmaxhsmpd=+[N]:n:' \
        '--audio_format=+[f]:f:(aac mp3)' \
        '--audio_bitrate=+[bps]:n:' \
        '--audio_channels=+[N]:n:(1 2)' \
        '--audio_volume=+[F]:f:' \
        '--alsadev=+[dev]:str:' \
        '--audiopreview[audio preview]' \
        '--audiopreviewdev=+[dev]:str:' \
        '--rotation=+[deg]:n:(0 90 180 270)' \
        '--hflip[horizontal flip]' \
        '--vflip[vertical flip]' \
        '--brightness=+[F]:f:' \
        '--contrast=+[F]:f:' \
        '--saturation=+[F]:f:' \
        '--sharpness=+[F]:f:' \
        '--awb=+[mode]:m:(off auto sun cloud shade tungsten fluorescent incandescent flash horizon)' \
        '--exposurecontrol=+[mode]:m:(off auto night nightpreview backlight spotlight sports snow beach verylong fixedfps)' \
        '--metering=+[mode]:m:(average spot backlit matrix)' \
        '--shutter=+[us]:n:' \
        '--iso=+[N]:n:' \
        '--preview[show preview]' \
        '--previewrect=+[x,y,w,h]:str:' \
        '--state-dir=+[dir]:dir:_files -/' \
        '--hooks-dir=+[dir]:dir:_files -/' \
        '--rec-dir=+[dir]:dir:_files -/' \
        '--rec-tmp-dir=+[dir]:dir:_files -/' \
        '--rec-archive-dir=+[dir]:dir:_files -/' \
        '--recording-buffer-keyframes=+[N]:n:' \
        '--minlatency[min latency]'
}

_picam "$@"
