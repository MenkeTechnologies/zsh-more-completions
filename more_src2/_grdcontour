#compdef grdcontour
# Documentation: https://docs.generic-mapping-tools.org/latest/grdcontour.html
# Source: GenericMappingTools/gmt classic-mode grdcontour — contour-line plot of a grid.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A+[annotation interval / format]:opts:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[contour levels (interval/file/CPT)]:spec:_default' \
    '-D+[dump contours to file (no plot)]:opts:_default' \
    '-F+[dump orientation (higher value left or right)]:dir:_default' \
    '-G+[contour-label placement]:opts:_default' \
    '-L+[restrict contour range (min/max)]:range:_default' \
    '-N+[fill between contours via CPT]:fill:_default' \
    '-Q+[skip short contours]:opts:_default' \
    '-S+[resample contour interval]:n:_default' \
    '-T+[tick closed contours]:opts:_default' \
    '-W+[contour pen]:pen:_default' \
    '-Z+[scale/offset before contouring]:opts:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-l+[legend entry]:label:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
