#compdef gobuster
# _gobuster-bin — gobuster brute-force directory/DNS/VHost/S3 scanner (OJ Reeves, Go); authorized recon tool
# upstream: https://github.com/OJ/gobuster

_gobuster-bin() {
    local -a sub=(
        'dir:directory enumeration'
        'dns:DNS subdomain enumeration'
        'fuzz:web app fuzzer'
        'gcs:Google Cloud Storage buckets enum'
        's3:Amazon S3 buckets enum'
        'tftp:TFTP file enum'
        'vhost:VHost enumeration'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gobuster subcommand' sub ;;
        args)
            case $words[1] in
                dir|fuzz|vhost) _arguments \
                    '(-u --url)'{-u,--url}'+[target URL]:url:_urls' \
                    '(-w --wordlist)'{-w,--wordlist}'+[wordlist]:file:_files' \
                    '(-c --cookies)'{-c,--cookies}'+[cookies]:str:' \
                    '(-x --extensions)'{-x,--extensions}'+[file extensions]:exts:' \
                    '(-X --method)'{-X,--method}'+[HTTP method]:method:(GET POST HEAD OPTIONS PATCH PUT DELETE)' \
                    '(-r --follow-redirect)'{-r,--follow-redirect}'[follow redirects]' \
                    '(-k --no-tls-validation)'{-k,--no-tls-validation}'[skip TLS verify]' \
                    '(-a --useragent)'{-a,--useragent}'+[User-Agent]:str:' \
                    '(-H --headers)'{-H,--headers}'+[header]:str:' \
                    '(-U --username)'{-U,--username}'+[basic auth user]:str:' \
                    '(-P --password)'{-P,--password}'+[basic auth pass]:str:' \
                    '--exclude-length+[exclude lengths]:lengths:' \
                    '--proxy+[proxy URL]:url:_urls' \
                    '--random-agent[random user-agent]' \
                    '--retry+[retry on timeout]' \
                    '--retry-attempts+[retry attempts]:n:' \
                    '--status-codes+[allowed status]:codes:' \
                    '--status-codes-blacklist+[disallowed status]:codes:' \
                    '--timeout+[HTTP timeout]:duration:' \
                    '-s+[status codes]:codes:' \
                    '-b+[blacklisted status]:codes:' \
                    '-e[print full URLs]' \
                    '-d[discover backup files]' \
                    '-f[append trailing slash]' \
                    '-l[show length]' ;;
                dns) _arguments \
                    '(-d --domain)'{-d,--domain}'+[domain]:domain:' \
                    '(-w --wordlist)'{-w,--wordlist}'+[wordlist]:file:_files' \
                    '(-r --resolver)'{-r,--resolver}'+[resolver]:resolver:' \
                    '(-c --show-cname)'{-c,--show-cname}'[show CNAME]' \
                    '(-i --show-ips)'{-i,--show-ips}'[show IPs]' \
                    '--no-fqdn[no fqdn]' \
                    '--timeout+[DNS timeout]:duration:' \
                    '--wildcard[allow wildcard]' ;;
                s3|gcs) _arguments \
                    '(-w --wordlist)'{-w,--wordlist}'+[wordlist]:file:_files' \
                    '(-k --no-tls-validation)'{-k,--no-tls-validation}'[skip TLS verify]' \
                    '-i[show files inside]' \
                    '--maxfiles+[max files to show]:n:' ;;
            esac
            ;;
    esac
}

_gobuster-bin "$@"
