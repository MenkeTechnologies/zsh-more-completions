#compdef grin-server
# _grin-server — Mimblewimble Grin grin-server CLI for the privacy-focused Mimblewimble cryptocurrency full node serving block headers chain syncing peer discovery txhashset Pibd compaction stratum mining transaction propagation (mimblewimble team, Rust); clap
# upstream: https://github.com/mimblewimble/grin

_grin-server() {
    local -a sub=(
        'start:start the server'
        'stop:stop the server'
        'restart:restart the server'
        'config:print or edit config'
        'run:run the server'
        'clean:clean local data'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.toml grin-server.toml"' \
        '--config=+[config file]:file:_files -g "*.toml grin-server.toml"' \
        '-l+[log level]:l:(error warn info debug trace)' \
        '--loglevel=+[log level]:l:(error warn info debug trace)' \
        '--testnet[use testnet]' \
        '--mainnet[use mainnet]' \
        '--floonet[use floonet legacy]' \
        '--usernet[use usernet]' \
        '--api-secret-file=+[file]:file:_files' \
        '--no-api[disable API]' \
        '--api-port=+[port]:n:' \
        '--no-stratum[disable stratum]' \
        '--stratum-port=+[port]:n:' \
        '--bootstrap-peer=+[host:port]:str:' \
        '--data-dir=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grin-server subcommand' sub ;;
        args) ;;
    esac
}

_grin-server "$@"
