#compdef mpirun mpiexec
# Documentation: man mpirun (Open MPI 5.0.9)
# Source: launch MPI parallel programs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--allow-run-as-root[permit running as root]' \
    '--am=[application manager file]:file:_files' \
    '--app=[application context file]:file:_files' \
    '--bind-to=[process binding target]:target:(none hwthread core l1cache l2cache l3cache package numa board node)' \
    '--bind-to-core[bind processes to cores]' \
    '--bind-to-socket[bind processes to sockets]' \
    '--bycore[deprecated map-by core]' \
    '--bynode[deprecated map-by node]' \
    '--byslot[deprecated map-by slot]' \
    '--continuous[continuous (no PMIx fence) launch]' \
    '--cpu-list=[restrict to CPU list]:list:' \
    '--cpu-set=[set of CPUs to use]:list:' \
    '--cpus-per-proc=[CPUs per process]:n:' \
    '--cpus-per-rank=[CPUs per rank]:n:' \
    '--debug-daemons[debug PRTE daemons]' \
    '--debug-daemons-file[write daemon debug to file]' \
    '--default-hostfile=[default hostfile]:file:_files' \
    '--disable-recovery[disable PMIx recovery]' \
    '--enable-recovery[enable PMIx recovery]' \
    '--display-allocation[show node allocation]' \
    '--display-devel-map[show developer mapping]' \
    '--display-map[show process map]' \
    '--display-topo[show topology]' \
    '--do-not-launch[show map but do not launch]' \
    '--dvm=[connect to DVM]:dvm:' \
    '--get-stack-traces[get stack traces on hang]' \
    '*--gmca=[global MCA parameter]:param=value:' \
    '*--mca=[MCA parameter]:param=value:' \
    '(-host --host)'{-host+,--host=}'[host list]:hosts:_hosts' \
    '(-hostfile --hostfile --machinefile)'{-hostfile+,--hostfile=,--machinefile=}'[hostfile]:file:_files' \
    '--launch-agent=[remote launch agent]:agent:_command_names -e' \
    '--leave-session-attached[do not detach from session]' \
    '--map-by=[mapping policy]:policy:(slot hwthread core l1cache l2cache l3cache package numa node board ppr dist)' \
    '--max-restarts=[max process restarts]:n:' \
    '--max-vm-size=[max VM size]:n:' \
    '--merge-stderr-to-stdout[merge stderr into stdout]' \
    '--nolocal[do not run any process on the local node]' \
    '--nooversubscribe[do not oversubscribe nodes]' \
    '--noprefix[do not auto-set --prefix]' \
    '(-np --np)'{-np+,--np=}'[number of processes]:n:' \
    '--npernode=[processes per node]:n:' \
    '(-npersocket --npersocket)'{-npersocket+,--npersocket=}'[processes per socket]:n:' \
    '--output-filename=[redirect output to filename]:file:_files' \
    '--output-proctable[print process table]' \
    '--oversubscribe[allow oversubscription]' \
    '--path=[append path for app discovery]:path:' \
    '--pernode[one process per node]' \
    '--personality=[runtime personality]:name:' \
    '*--pmixmca=[PMIx MCA parameter]:param=value:' \
    '--ppr=[processes-per-resource pattern]:N:R:' \
    '--prefix=[Open MPI install prefix]:dir:_files -/' \
    '--preload-binary[preload binary to all nodes]' \
    '*--preload-files=[preload files to all nodes]:file:_files' \
    '*--prtemca=[PRTE MCA parameter]:param=value:' \
    '--quiet[reduce output]' \
    '--rank-by=[ranking policy]:policy:(slot hwthread core l1cache l2cache l3cache package numa node board fill span)' \
    '--rankfile=[rankfile]:file:_files' \
    '--report-bindings[print process bindings]' \
    '--report-child-jobs-separately[report child jobs separately]' \
    '--report-events=[event report endpoint]:uri:' \
    '--report-pid=[file to write pid]:file:_files' \
    '--report-state-on-timeout[report state on timeout]' \
    '--report-uri=[write URI to file]:file:_files' \
    '--set-cwd-to-session-dir[set CWD to session dir]' \
    '--show-progress[show launch progress]' \
    '--stdin=[stdin source rank]:rank:' \
    '--tag-output[tag each output line with rank]' \
    '--terminate[terminate the DVM]' \
    '--timeout=[job timeout seconds]:seconds:' \
    '--timestamp-output[timestamp each output line]' \
    '--tune=[tuning file]:file:_files' \
    '--use-hwthread-cpus[treat hwthreads as CPUs]' \
    '--verbose[verbose output]' \
    '(-wdir --wdir --wd)'{-wdir=,--wdir=,--wd=}'[set working directory]:dir:_files -/' \
    '--xml[XML output]' \
    '--xml-file=[XML output to file]:file:_files' \
    '--xterm=[launch ranks in xterm]:ranks:' \
    '*:program and args:_command_names -e' \
    && ret=0

return ret
