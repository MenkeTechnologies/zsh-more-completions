#compdef isaset
# Documentation: man isaset(8)
# Source: lm-sensors/lm-sensors prog/dump/isaset.c (master) — write to ISA Super-I/O register (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[flat address space mode]' \
    '-y[assume yes to all prompts]' \
    '(-W -L)-W[write a word (16-bit) value]' \
    '(-W -L)-L[write a long (32-bit) value]' \
    '*::ADDRREG DATAREG ADDRESS VALUE [MASK]:_default' \
    && ret=0

return ret
