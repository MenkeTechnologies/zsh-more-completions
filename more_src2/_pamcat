#compdef pamcat pnmcat
# Documentation: man pamcat (Netpbm 11.00+)
# Source: concatenate Netpbm images horizontally or vertically.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-leftright -lr -topbottom -tb)'{-leftright,-lr}'[left-to-right concatenation]' \
    '(-leftright -lr -topbottom -tb)'{-topbottom,-tb}'[top-to-bottom concatenation]' \
    '(-white -black)-white[pad with white]' \
    '(-white -black)-black[pad with black]' \
    '(-jtop -jbottom -jcenter)-jtop[vertical-justify to top]' \
    '(-jtop -jbottom -jcenter)-jbottom[vertical-justify to bottom]' \
    '(-jtop -jbottom -jcenter)-jcenter[centre alignment]' \
    '(-jleft -jright -jcenter)-jleft[horizontal-justify to left]' \
    '(-jleft -jright -jcenter)-jright[horizontal-justify to right]' \
    '-listfile=[file of newline-separated filenames]:file:_files' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
