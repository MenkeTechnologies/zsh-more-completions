#compdef ffprobe
# Documentation: https://manpages.debian.org/ffprobe.1
# Source: FFmpeg — multimedia inspector.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[input URL]:input:_files' \
    '(-of -output_format -print_format)-of[output format]:fmt:(default csv ini json compact flat xml)' \
    '(-of -output_format -print_format)-output_format[output format]:fmt:(default csv ini json compact flat xml)' \
    '(-of -output_format -print_format)-print_format[output format]:fmt:(default csv ini json compact flat xml)' \
    '-show_format[show container format info]' \
    '-show_streams[show per-stream info]' \
    '-show_packets[show per-packet info]' \
    '-show_frames[show per-frame info]' \
    '-show_entries[entries to show (section_entries syntax)]:spec:' \
    '-show_chapters[show chapters]' \
    '-show_programs[show programs and their streams]' \
    '-show_error[show probe error]' \
    '-show_data[show payload hex+ASCII]' \
    '-show_data_hash[show payload hash]:algo:(MD5 SHA1 SHA256 CRC32 adler32)' \
    '-show_log[show decoder logs per frame]:loglevel:(quiet panic fatal error warning info verbose debug trace)' \
    '-count_frames[count frames per stream]' \
    '-count_packets[count packets per stream]' \
    '-select_streams[filter to streams]:specifier:' \
    '-read_intervals[restrict reading to intervals]:intervals:' \
    '-bitexact[bit-exact output]' \
    '-hide_banner[suppress banner]' \
    '(-loglevel -v)-loglevel[set logging level]:level:(quiet panic fatal error warning info verbose debug trace)' \
    '(-loglevel -v)-v[set logging level (alias)]:level:(quiet panic fatal error warning info verbose debug trace)' \
    '-pretty[pretty-print numeric values]' \
    '-sections[print sections structure and exit]' \
    '*:input file:_files' \
    && ret=0

return ret
