#compdef ftbench
# _ftbench — FreeType ftbench microbenchmark CLI measuring per-operation timings for FreeType font face creation glyph loading rendering hinting raster on a target TTF/OTF/PFA font (freetype team, C); getopt
# upstream: https://github.com/freetype/freetype

_ftbench() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[N iterations]:n:' \
        '-C[CFF engine]:e:(freetype adobe)' \
        '-e+[encoding]:e:(unicode latin1 ascii other)' \
        '-f+[face load flags]:str:' \
        '-H+[hinter]:h:(none light normal mono)' \
        '-i+[start index]:n:' \
        '-j+[end index]:n:' \
        '-l+[size px]:n:' \
        '-m+[max ops]:n:' \
        '-p+[passes]:n:' \
        '-r+[resolution dpi]:n:' \
        '-s+[size pt]:f:' \
        '-t+[time seconds]:n:' \
        '-w[print timing per operation]' \
        '-x+[exec mode]:m:(load render outline bbox metrics charmap)' \
        '-y+[type]:t:(monochrome aa lcd lcd-v lcd-bgr lcd-vbgr)' \
        '*:font file:_files -g "*.ttf *.otf *.pfa *.pfb *.bdf *.pcf *.woff *.woff2 *.t1 *.cff"'
}

_ftbench "$@"
