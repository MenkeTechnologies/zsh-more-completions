#compdef pimpleFoam
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/bin/pimpleFoam
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/applications/solvers/foamRun/foamRun.C
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/src/OpenFOAM/global/argList/argList.C
# Reference accessed: 2026-05-27
# Verified: upstream bin/pimpleFoam exec's "foamRun -solver incompressibleFluid";
# options come from foamRun.C and argList.C addOption / addBoolOption calls.

# pimpleFoam: PIMPLE algorithm transient solver (wrapper for foamRun).
local curcontext="$curcontext" ret=1
_arguments -s \
  '-case[specify alternate case directory (default cwd)]:dir:_files -/' \
  '-solver[solver name (default incompressibleFluid)]:name:' \
  '-parallel[run in parallel]' \
  '-roots[slave root directories for distributed running]:list:' \
  '-hostRoots[slave root directories per host for distributed running]:list:' \
  '-noFunctionObjects[do not execute functionObjects]' \
  '-fileHandler[override the file handler]:handler:(uncollated collated masterUncollated)' \
  '-libs[pre-load shared libraries]:libs:' \
  '-help[display help]' \
  '-doc[display application documentation in browser]' \
  '-srcDoc[display source documentation in browser]' \
  '*::args:_files' && ret=0
return ret
