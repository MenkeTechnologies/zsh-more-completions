#compdef farm-cli farmfe
# _farm-cli — Farm Rust-based bundler CLI alias (Farm team / Brightwu, TypeScript/Rust); commander
# upstream: https://github.com/farm-fe/farm

_farm-cli() {
    local -a sub=(
        'start:start dev server'
        'build:production build'
        'watch:watch and rebuild'
        'preview:preview production build'
        'serve:serve production build'
        'clean:clean cache'
        'create:scaffold a Farm project'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "farm.config.*"' \
        '--config=+[config file]:file:_files -g "farm.config.*"' \
        '--root=+[project root]:dir:_files -/' \
        '-r+[project root]:dir:_files -/' \
        '--mode=+[build mode]:m:(development production)' \
        '-m+[build mode]:m:(development production)' \
        '--clearScreen=+[clear screen]:b:(true false)' \
        '--no-clear-screen[no clear screen]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'farm subcommand' sub ;;
        args)
            case $words[1] in
                start|preview|serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--https[https]' \
                    '--open[open browser]' \
                    '--no-open[no open]' \
                    '--strict-port[strict port]' ;;
                build) _arguments \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--out-dir=+[output dir]:dir:_files -/' \
                    '--minify[minify]' \
                    '--no-minify[no minify]' \
                    '--sourcemap[sourcemap]' \
                    '--target-env=+[target env]:e:(browser node browser-esnext browser-legacy library library-browser library-node)' \
                    '--treeshake[treeshake]' \
                    '--no-treeshake[no treeshake]' ;;
                create) _arguments \
                    '--template=+[template]:t:(react vue solid svelte preact lit vanilla react-ts vue-ts solid-ts svelte-ts preact-ts lit-ts vanilla-ts)' \
                    '-t+[template]:t:(react vue solid svelte preact lit vanilla react-ts vue-ts solid-ts svelte-ts preact-ts lit-ts vanilla-ts)' \
                    '*:name:' ;;
                clean) _arguments \
                    '--recursive[recursive]' \
                    '-r[recursive]' ;;
            esac
            ;;
    esac
}

_farm-cli "$@"
