#compdef pycodestyle
# Documentation: pycodestyle --help (pycodestyle.pycqa.org)
# Source: pycodestyle — Python PEP-8 style checker (former pep8).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*'{-v,--verbose}'[print status messages (use -vv for debug)]' \
    '*'{-q,--quiet}'[report only file names (-qq for minimal)]' \
    '--first[show first occurrence of each error]' \
    '*--exclude=[skip files / dirs (comma-separated patterns)]:patterns:' \
    '*--filename=[scan only matching filenames in dirs]:patterns:' \
    '--select=[errors / warnings to report]:errors:' \
    '--ignore=[errors / warnings to skip]:errors:' \
    '--show-source[show source for each issue]' \
    '--show-pep8[show PEP 8 text for each error (implies --first)]' \
    '--statistics[count and display error/warning frequency]' \
    '--count[print total errors to stderr; exit 1 if any]' \
    '--max-line-length=[max line length (default 79)]:n:' \
    '--max-doc-length=[max docstring line length]:n:' \
    '--indent-size=[spaces per indent (default 4)]:n:' \
    '--hang-closing[position closing bracket differently than opening]' \
    '--format=[output format]:format:(default pylint)' \
    '--diff[only lines changed per unified diff on stdin]' \
    '--benchmark[measure processing speed]' \
    '--config=[configuration file]:file:_files' \
    '*:Python file or directory:_files -g "*.py"' \
    && ret=0

return ret
