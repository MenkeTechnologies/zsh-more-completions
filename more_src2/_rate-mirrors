#compdef rate-mirrors
# Documentation: https://github.com/westandskif/rate-mirrors
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rate-mirrors - find the fastest mirrors for your Linux distro

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'arch:rate Arch Linux mirrors'
  'arch4edu:rate Arch4edu mirrors'
  'archarm:rate Arch Linux ARM mirrors'
  'archlinuxcn:rate Arch Linux CN mirrors'
  'arcolinux:rate ArcoLinux mirrors'
  'artix:rate Artix Linux mirrors'
  'blackarch:rate BlackArch Linux mirrors'
  'cachyos:rate CachyOS mirrors'
  'chaotic-aur:rate Chaotic-AUR mirrors'
  'endeavouros:rate EndeavourOS mirrors'
  'manjaro:rate Manjaro mirrors'
  'openbsd:rate OpenBSD mirrors'
  'rebornos:rate RebornOS mirrors'
  'stdin:rate mirrors from stdin'
)

_arguments -s -S \
  '1:command:->command' \
  '--allow-root[permit root execution]' \
  '--concurrency=[simultaneous speed tests]:number' \
  '--disable-comments[suppress comment output]' \
  '--disable-untested-fallback[exit on test failure]' \
  '--entry-country=[starting country code]:country code' \
  '--exclude-countries=[exclude specific countries]:countries' \
  '--max-jumps=[maximum country hops]:jumps' \
  '--max-mirrors-to-output=[limit output mirrors]:number' \
  '--protocol=[test only http or https]:protocol:(http https)' \
  '--save=[write results to file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'rate-mirrors command' commands && ret=0
    ;;
  (args)
    _arguments -s -S \
      '--completion=[minimum sync completion threshold]:value' \
      '--sort-mirrors-by=[order results by]:mode:(score delay)' && ret=0
    ;;
esac

return ret
