#compdef mako-utils makoctl
# Documentation: https://man.archlinux.org/man/makoctl.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. The mako-utils package provides
# makoctl(1).

# makoctl: control mako notification daemon
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'dismiss:dismiss notifications'
  'restore:restore most recently dismissed notification'
  'invoke:invoke action on a notification'
  'menu:use a program to select an action'
  'list:list current notifications'
  'history:show notification history'
  'reload:reload configuration file'
  'mode:set notification mode'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'makoctl command' commands && ret=0 ;;
  args)
    case $line[1] in
      dismiss)
        _arguments \
          '(-a --all)'{-a,--all}'[dismiss all]' \
          '(-g --group)'{-g,--group}'[dismiss group of given notification]' \
          '(-h --no-history)'{-h,--no-history}'[do not place in history]' \
          '-n[notification ID]:id:' && ret=0 ;;
      invoke)
        _arguments \
          '-n[notification ID]:id:' '*::action:' && ret=0 ;;
      menu)
        _arguments \
          '-n[notification ID]:id:' '*::program and args:_files' && ret=0 ;;
      list|history)
        _arguments \
          '-j[output as JSON]' && ret=0 ;;
      mode)
        _arguments \
          '*'{-s,--set}'[set mode(s)]:mode:' \
          '*'{-a,--add}'[add mode(s)]:mode:' \
          '*'{-r,--remove}'[remove mode(s)]:mode:' \
          '*'{-t,--toggle}'[toggle mode(s)]:mode:' && ret=0 ;;
    esac ;;
esac
return ret
