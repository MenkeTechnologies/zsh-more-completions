#compdef numaflow
# _numaflow — Numaproj streaming dataflow CLI (numaproj/numaflow)
# upstream: https://github.com/numaproj/numaflow
# Subcommands from cmd/commands/root.go (cobra).

_numaflow() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'controller:run the Numaflow controller'
                'isbsvc-create:create an InterStepBufferService'
                'isbsvc-delete:delete an InterStepBufferService'
                'isbsvc-validate:validate an InterStepBufferService'
                'daemon-server:run the Numaflow daemon-server sidecar'
                'mvtx-daemon-server:run the MonoVertex daemon-server sidecar'
                'server:run the Numaflow UI/API server'
                'server-init:initialize the Numaflow server'
                'server-secrets-init:initialize Numaflow server secrets'
                'webhook:run the admission-webhook'
                'dex-server-init:initialize the Dex SSO server'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_numaflow "$@"
