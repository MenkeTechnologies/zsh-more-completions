#compdef otbcli_ComputeImagesStatistics
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ComputeImagesStatistics.html
# Source: orfeotoolbox/OTB ComputeImagesStatistics — global mean/min/max/stddev across image list (for classifier normalization).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-il+[input image list]:images:_files' \
    '-bv+[background value to ignore]:value:_default' \
    '-out.xml+[stats XML output]:file:_files -g "*.xml(-.)"' \
    '-out.mean+[mean output (string)]:value:_default' \
    '-out.min+[min output (string)]:value:_default' \
    '-out.max+[max output (string)]:value:_default' \
    '-out.std+[stddev output (string)]:value:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
