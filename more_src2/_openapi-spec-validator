#compdef openapi-spec-validator
# Documentation: https://github.com/python-openapi/openapi-spec-validator
# Reference accessed: 2026-05-23
# Verified: openapi-spec-validator --help.

# Zsh completion for openapi-spec-validator - OpenAPI specification validator

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--errors[error reporting mode]:(best-match all)' \
  '--schema[OpenAPI schema version]:(detect 2.0 3.0 3.1)' \
  '*:file:spec file:_files' && ret=0

return ret
