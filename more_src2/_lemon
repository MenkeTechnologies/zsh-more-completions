#compdef lemon
# Documentation: https://sqlite.org/src/doc/trunk/doc/lemon.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for Lemon LALR(1) parser generator (SQLite).

local curcontext="$curcontext" ret=1

_arguments -C \
  '-\\?[show available options]' \
  '-b[show only basis for each parser state in report file]' \
  '-c[do not compress generated action tables]' \
  '-d+[write all output files into directory]:dir:_files -/' \
  '-D+[define C preprocessor macro]:name:' \
  '-E[run %if preprocessor only and print revised grammar]' \
  '-g[write input grammar to stdout (no parser generated)]' \
  '-l[omit #line directives in generated parser]' \
  '-m[generate output compatible with makeheaders]' \
  '-p[display conflicts resolved by precedence rules]' \
  '-q[suppress report file generation]' \
  '-r[do not sort or renumber parser states]' \
  '-s[show parser statistics before exiting]' \
  '-T+[template file for generated parser]:file:_files' \
  '-x[print Lemon version number]' \
  '*:grammar file:_files -g "*.y *.yacc *.lemon"' && ret=0

return ret
