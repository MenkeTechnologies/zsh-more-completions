#compdef gh-actions-importer
# _gh-actions-importer — GitHub CLI extension for importing CI/CD (github/gh-actions-importer)
# upstream: https://github.com/github/gh-actions-importer

_gh-actions-importer() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_gh_actions_importer_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                audit|dry-run|migrate)
                    _arguments \
                        '--source-url=[source CI/CD server URL]:url:' \
                        '--target-url=[target GitHub URL]:url:' \
                        '--github-access-token=[GitHub access token]:token:' \
                        '--output-dir=[output directory]:dir:_directories' \
                        '--source-file-path=[source file path]:file:_files' \
                        '--config-file-path=[config file path]:file:_files' \
                        '*:args:' && ret=0 ;;
                forecast)
                    _arguments \
                        '--source-url=[source CI/CD server URL]:url:' \
                        '--github-access-token=[GitHub access token]:token:' \
                        '--config-file-path=[config file path]:file:_files' \
                        '*:args:' && ret=0 ;;
                configure)
                    _arguments '*:args:' && ret=0 ;;
                update|version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_gh_actions_importer_commands] )) ||
_gh_actions_importer_commands() {
    local -a commands
    commands=(
        'audit:audit a CI/CD instance'
        'dry-run:dry-run a migration'
        'migrate:migrate a CI/CD pipeline'
        'forecast:forecast migration effort'
        'configure:configure credentials'
        'update:update the importer'
        'version:show version'
    )
    _describe -t commands 'gh-actions-importer command' commands
}

_gh-actions-importer "$@"
