#compdef forcetypeassert gomoddirectives interfacebloat loggercheck mirror nestif nilnil rowserrcheck
# Documentation: upstream READMEs at github.com/{gostaticanalysis/forcetypeassert,ldez/gomoddirectives,sashamelentyev/interfacebloat,timonwong/loggercheck,butuzov/mirror,nakabonne/nestif,Antonboom/nilnil,jingyugao/rowserrcheck}
# Reference accessed: 2026-05-30
# Continuation of Go linter sweep R24 — 8 more single-purpose linters
# wrapping the analysis/passes framework. Most are also runnable via
# `go vet -vettool=$(which TOOL) PKG/...` and through golangci-lint.

local curcontext="$curcontext" state line ret=1

case $service in

  forcetypeassert)
    # gostaticanalysis/forcetypeassert — flag unchecked type assertions.
    # Enforces 2-return form `value, ok := a.(int)`.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  gomoddirectives)
    # ldez/gomoddirectives — enforce policies on go.mod directives
    # (retract, replace, exclude, ignore, tool, toolchain, godebug, go, module).
    _arguments -s -S \
      '-local[allow local replacements]' \
      '-exclude[forbid exclude directives]' \
      '-goversion=[Go version regex pattern]:pattern:' \
      '*:Go module file:_files -g "go.mod"' \
      && ret=0
    ;;

  interfacebloat)
    # sashamelentyev/interfacebloat — flag interfaces with too many methods
    # (Interface Segregation Principle).
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  loggercheck)
    # timonwong/loggercheck — detect odd-arity key-value pairs in structured
    # logging (kitlog, klog, logr, log/slog, zap).
    local -a _loggers
    _loggers=(kitlog klog logr slog zap)
    _arguments -s -S \
      '-requirestringkey[enforce logging keys as inlined constant strings]' \
      '-disable=[loggers to skip (comma-separated)]:loggers:_values -s , "logger" $_loggers' \
      '-fix[apply suggested fixes automatically]' \
      '-rulefile=[custom checking rules file]:file:_files' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  mirror)
    # butuzov/mirror — suggest mirror stdlib functions to avoid
    # []byte/string conversions.
    _arguments -s -S \
      '--with-tests[analyze test files]' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  nestif)
    # nakabonne/nestif — cognitive-complexity-of-nested-if linter.
    _arguments -s -S \
      '--min=[minimum complexity threshold (default 1)]:N:' \
      '--top=[display only top N results (default 10)]:N:' \
      '--json[output in JSON format]' \
      '--exclude-dirs=[comma-separated directories to skip]:dirs:_directories' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  nilnil)
    # Antonboom/nilnil — flag functions returning both nil error
    # and invalid value (`return nil, nil`).
    local -a _types
    _types=(chan func iface map ptr uintptr unsafeptr)
    _arguments -s -S \
      '--checked-types=[types to validate (comma-separated)]:types:_values -s , "type" $_types' \
      '--detect-opposite[also flag non-nil errors with valid values]' \
      '--only-two=[restrict to 2-return functions (default true)]:bool:(true false)' \
      '*:Go package or file:_files' \
      && ret=0
    ;;

  rowserrcheck)
    # jingyugao/rowserrcheck — check sql.Rows.Err() after iteration.
    _arguments -s -S \
      '*:Go package or file:_files' \
      && ret=0
    ;;

esac

return ret
