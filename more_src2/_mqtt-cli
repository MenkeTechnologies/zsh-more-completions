#compdef mqtt mqtt-cli
# Documentation: https://github.com/hivemq/mqtt-cli
# Documentation: https://hivemq.github.io/mqtt-cli/docs/
# Reference accessed: 2026-05-27
# Verified: upstream src/main/java/com/hivemq/cli/commands/ (MqttCLICommand,
# cli/PublishCommand, cli/SubscribeCommand, cli/TestBrokerCommand,
# options/{Connect,Publish,Subscribe,Disconnect}Options, swarm/SwarmCLICommand).
# Coverage: top-level subcommands (pub, sub, sh, test, version, swarm, hivemq)
# plus the most-used options for pub/sub/test/dis. The 'hivemq' broker-management
# subtree (behavior-policy, data-policy, schema, script, export) is acknowledged
# as a subcommand surface but its nested flags are not enumerated here.

local curcontext="$curcontext" state line ret=1

local -a _mqtt_subcommands
_mqtt_subcommands=(
  'pub:publish a message to one or more topics'
  'sub:subscribe to one or more topics and print received messages'
  'sh:enter interactive shell mode'
  'shell:enter interactive shell mode (alias for sh)'
  'test:run feature/limitation tests against a broker'
  'version:print mqtt-cli version'
  'swarm:run distributed load tests via HiveMQ Swarm'
  'hivemq:HiveMQ broker management (policies, schemas, scripts, exports)'
)

local -a _mqtt_swarm_subcommands
_mqtt_swarm_subcommands=(
  'status:query swarm commander status'
  'run:start a swarm scenario run'
)

local -a _mqtt_hivemq_subcommands
_mqtt_hivemq_subcommands=(
  'behavior-policy:manage HiveMQ behavior policies'
  'behavior-state:inspect HiveMQ behavior state'
  'data-policy:manage HiveMQ data policies'
  'schema:manage HiveMQ schemas'
  'script:manage HiveMQ scripts'
  'export:export HiveMQ data'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(- *)'{-V,--version}'[print version and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'mqtt-cli subcommand' _mqtt_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      pub)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-V+[MQTT version (3 or 5)]:version:(3 5)' \
          '--mqttVersion=[MQTT version (3 or 5)]:version:(3 5)' \
          '-h+[broker host]:host:_hosts' \
          '--host=[broker host]:host:_hosts' \
          '-p+[broker port]:port:' \
          '--port=[broker port]:port:' \
          '-i+[client identifier]:id:' \
          '--identifier=[client identifier]:id:' \
          '-ip+[client identifier prefix]:prefix:' \
          '--identifierPrefix=[client identifier prefix]:prefix:' \
          '-k+[keep alive in seconds]:seconds:' \
          '--keepAlive=[keep alive in seconds]:seconds:' \
          '--no-cleanStart[disable clean start]' \
          '-se+[session expiry interval]:seconds:' \
          '--sessionExpiryInterval=[session expiry interval]:seconds:' \
          '*-Cup+[connect user property KEY=VALUE]:property:' \
          '*--connectUserProperty=[connect user property KEY=VALUE]:property:' \
          '-ws[use WebSocket transport]' \
          '-ws:path=[WebSocket path]:path:' \
          '*-t+[topic to publish to]:topic:' \
          '*--topic=[topic to publish to]:topic:' \
          '*-q+[QoS (0/1/2) per topic]:qos:(0 1 2)' \
          '*--qos=[QoS (0/1/2) per topic]:qos:(0 1 2)' \
          '-m+[message payload]:message:' \
          '--message=[message payload]:message:' \
          '-r[mark message as retained]' \
          '--retain[mark message as retained]' \
          '-e+[message expiry interval (seconds)]:seconds:' \
          '--messageExpiryInterval=[message expiry interval (seconds)]:seconds:' \
          '-pf+[payload format indicator]:value:(UNSPECIFIED UTF_8)' \
          '--payloadFormatIndicator=[payload format indicator]:value:(UNSPECIFIED UTF_8)' \
          '-ct+[content type]:type:' \
          '--contentType=[content type]:type:' \
          '-rt+[response topic]:topic:' \
          '--responseTopic=[response topic]:topic:' \
          '-cd+[correlation data]:data:' \
          '--correlationData=[correlation data]:data:' \
          '*-up+[user property KEY=VALUE]:property:' \
          '*--userProperty=[user property KEY=VALUE]:property:' \
          '-l[log to ~/.mqtt-cli/logs]' && ret=0
        ;;
      sub)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-V+[MQTT version (3 or 5)]:version:(3 5)' \
          '--mqttVersion=[MQTT version (3 or 5)]:version:(3 5)' \
          '-h+[broker host]:host:_hosts' \
          '--host=[broker host]:host:_hosts' \
          '-p+[broker port]:port:' \
          '--port=[broker port]:port:' \
          '-i+[client identifier]:id:' \
          '--identifier=[client identifier]:id:' \
          '-k+[keep alive in seconds]:seconds:' \
          '--keepAlive=[keep alive in seconds]:seconds:' \
          '*-t+[topic to subscribe to]:topic:' \
          '*--topic=[topic to subscribe to]:topic:' \
          '*-q+[QoS (0/1/2) per topic]:qos:(0 1 2)' \
          '*--qos=[QoS (0/1/2) per topic]:qos:(0 1 2)' \
          '*--user-property=[subscribe user property KEY=VALUE]:property:' \
          '--output-to-file=[write received publishes to file]:file:_files' \
          '--base64[decode received messages as base64]' \
          '-J[print received publishes as pretty JSON]' \
          '--json-output[print received publishes as pretty JSON]' \
          '-T[prepend topic name to each received publish]' \
          '--show-topics[prepend topic name to each received publish]' \
          '--no-outputToConsole[suppress console output of received messages]' \
          '-l[log to ~/.mqtt-cli/logs]' && ret=0
        ;;
      test)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-h+[broker host]:host:_hosts' \
          '--host=[broker host]:host:_hosts' \
          '-p+[broker port]:port:' \
          '--port=[broker port]:port:' \
          '-V+[MQTT version to test (default both)]:version:(3 5)' \
          '--mqttVersion=[MQTT version to test (default both)]:version:(3 5)' \
          '-a[perform all tests for all MQTT versions]' \
          '--all[perform all tests for all MQTT versions]' \
          '-t+[broker response timeout]:seconds:' \
          '--timeOut=[broker response timeout]:seconds:' \
          '-q+[publishes to send per QoS level]:count:' \
          '--qosTries=[publishes to send per QoS level]:count:' \
          '-l[log to ~/.mqtt-cli/logs]' && ret=0
        ;;
      dis)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-h+[broker host]:host:_hosts' \
          '--host=[broker host]:host:_hosts' \
          '-i+[client identifier]:id:' \
          '--identifier=[client identifier]:id:' \
          '-a[disconnect all connected clients]' \
          '--all[disconnect all connected clients]' \
          '-e+[session expiry on disconnect]:seconds:' \
          '--sessionExpiryInterval=[session expiry on disconnect]:seconds:' \
          '-r+[disconnect reason string]:reason:' \
          '--reason=[disconnect reason string]:reason:' \
          '*-up+[user property KEY=VALUE]:property:' \
          '*--userProperty=[user property KEY=VALUE]:property:' && ret=0
        ;;
      sh|shell)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '-l[log to ~/.mqtt-cli/logs]' && ret=0
        ;;
      swarm)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '1: :->swarmcmd' \
          '*:: :->swarmargs' && ret=0
        case $state in
          swarmcmd)
            _describe -t commands 'swarm subcommand' _mqtt_swarm_subcommands && ret=0
            ;;
          swarmargs)
            _message 'swarm options' && ret=0
            ;;
        esac
        ;;
      hivemq)
        _arguments -C \
          '(-h --help)'{-h,--help}'[show help]' \
          '1: :->hivemqcmd' \
          '*:: :->hivemqargs' && ret=0
        case $state in
          hivemqcmd)
            _describe -t commands 'hivemq subcommand' _mqtt_hivemq_subcommands && ret=0
            ;;
          hivemqargs)
            _message 'hivemq broker-management options' && ret=0
            ;;
        esac
        ;;
      version)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
