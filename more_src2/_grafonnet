#compdef grafonnet grafonnet-lib
# _grafonnet — Grafana Labs grafonnet CLI for generating Grafana dashboards programmatically using Jsonnet library composing panels rows variables templates queries data-sources alerts for Prometheus Loki MySQL InfluxDB Elasticsearch CloudWatch (grafana team, Jsonnet); custom argparse
# upstream: https://github.com/grafana/grafonnet-lib

_grafonnet() {
    local -a sub=(
        'render:render a Jsonnet dashboard file'
        'fmt:format Jsonnet'
        'lint:lint Jsonnet'
        'eval:evaluate Jsonnet expression'
        'upload:upload dashboard to Grafana'
        'show:show rendered dashboard JSON'
        'init:init new grafonnet project'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--jpath=+[csv]:str:' \
        '-J+[csv]:str:' \
        '--ext-code=+[name=expr]:str:' \
        '--ext-str=+[name=val]:str:' \
        '--tla-code=+[name=expr]:str:' \
        '--tla-str=+[name=val]:str:' \
        '--no-color[no color]' \
        '--output=+[file]:file:_files -g "*.json"' \
        '-o+[file]:file:_files -g "*.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grafonnet subcommand' sub ;;
        args)
            case $words[1] in
                render|show|eval) _arguments \
                    '*:Jsonnet file:_files -g "*.jsonnet *.libsonnet *.json"' ;;
                upload) _arguments \
                    '--server=+[url]:str:' \
                    '--api-key=+[key]:str:' \
                    '--folder=+[id]:n:' \
                    '--overwrite[overwrite]' \
                    '*:dashboard json:_files -g "*.json"' ;;
                init) _arguments \
                    '--name=+[name]:str:' \
                    '--use-vendir[use vendir]' ;;
            esac
            ;;
    esac
}

_grafonnet "$@"
