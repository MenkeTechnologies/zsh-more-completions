#compdef otc-tool otc2otf otf2otc
# _otc-tool — Adobe afdko otc2otf and otf2otc CLI for splitting and merging OpenType Collection .ttc/.otc files into and from individual TTF/OTF font resources (adobe-type-tools team, Python); argparse
# upstream: https://github.com/adobe-type-tools/afdko

_otc-tool() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output file]:file:_files -g "*.ttc *.otc *.ttf *.otf"' \
        '--output=+[output file]:file:_files -g "*.ttc *.otc *.ttf *.otf"' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--prefix=+[prefix]:str:' \
        '--suffix=+[suffix]:str:' \
        '--share-tables[share tables]' \
        '--no-share-tables[no share tables]' \
        '--force[overwrite]' \
        '-f[overwrite]' \
        '--report=+[file]:file:_files -g "*.txt *.json"' \
        '*:font file:_files -g "*.ttc *.otc *.ttf *.otf"'
}

_otc-tool "$@"
