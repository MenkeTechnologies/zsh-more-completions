#compdef lldpd
# Documentation: https://manpages.debian.org/testing/lldpd/lldpd.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '*-d[do not daemonize (repeat for stderr-only log)]' \
  '*-D+[debug token to allow (repeatable)]:class:' \
  '-r[receive only mode]' \
  '*-c[enable CDP (repeat to force CDP transmit)]' \
  '*-f[enable FDP (repeat to force FDP transmit)]' \
  '*-s[enable SONMP (repeat to force SONMP transmit)]' \
  '*-e[enable EDP (repeat to force EDP transmit)]' \
  '-l[force LLDP transmission when foreign peer detected]' \
  '-M+[LLDP-MED device class]:class:(1 2 3 4)' \
  '-i[disable LLDP-MED inventory TLV transmission]' \
  '-k[disable kernel release/version/machine advertising]' \
  '-S+[override system description]:descr:' \
  '-P+[override CDP platform name]:platform:' \
  '-x[enable SNMP subagent]' \
  '-X+[SNMP AgentX socket]:socket:_files' \
  '-u+[Unix-domain socket for lldpctl]:file:_files' \
  '-m+[management addresses]:addr:' \
  '-I+[interfaces to listen/transmit on]:iface:_net_interfaces' \
  '-C+[interfaces used for chassis ID]:iface:_net_interfaces' \
  '-L+[alternate lldpcli path]:file:_files' \
  '-O+[override default configuration locations]:file:_files' && ret=0

return ret
