#compdef llvm-strip
# _llvm-strip — LLVM strip (LLVM project, C++); strip symbols from object files, GNU strip-compatible
# upstream: https://github.com/llvm/llvm-project

_llvm-strip() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-R+[remove section]:section:' \
        '--remove-section=+[remove section]:section:' \
        '-N+[strip symbol]:symbol:' \
        '--strip-symbol=+[strip symbol]:symbol:' \
        '-K+[keep symbol]:symbol:' \
        '--keep-symbol=+[keep symbol]:symbol:' \
        '-x[discard all locals]' \
        '--discard-all[discard all locals]' \
        '-X[discard compiler locals]' \
        '--discard-locals[discard compiler locals]' \
        '-d[strip debug info]' \
        '-g[strip debug info]' \
        '-S[strip debug info]' \
        '--strip-debug[strip debug info]' \
        '--strip-dwo[strip DWO sections]' \
        '--only-keep-debug[only keep debug info]' \
        '-s[strip all]' \
        '--strip-all[strip all]' \
        '--strip-all-gnu[strip all GNU]' \
        '--strip-unneeded[strip unneeded symbols]' \
        '--strip-unneeded-symbol=+[strip unneeded symbol]:symbol:' \
        '-p[preserve dates]' \
        '--preserve-dates[preserve dates]' \
        '-w[wildcard]' \
        '--wildcard[wildcard]' \
        '--regex[regex matching]' \
        '*:file:_files'
}

_llvm-strip "$@"
