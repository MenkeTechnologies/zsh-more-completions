#compdef osv-scanner
# _osv-scanner-bin — Google OSV-Scanner vulnerability scanner (Google, Go); scan local manifests and Git history against osv.dev
# upstream: https://github.com/google/osv-scanner

_osv-scanner-bin() {
    local -a sub=(
        'scan:scan a project (default)'
        'fix:apply fixes (experimental)'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-r --recursive)'{-r,--recursive}'[recurse subdirs]' \
        '--skip-git[skip git history]' \
        '--no-ignore[disable .gitignore-like rules]' \
        '--include-git-root[include git root]' \
        '--call-analysis+[language for call analysis]:lang:(go rust python)' \
        '--no-call-analysis+[disable call analysis]:lang:(go rust python)' \
        '--config+[config file]:file:_files' \
        '--format+[output format]:fmt:(table vertical json sarif gh-annotations markdown cyclonedx-1-4 cyclonedx-1-5)' \
        '--output+[output file]:file:_files' \
        '--lockfile+[lockfile path]:file:_files' \
        '--sbom+[SBOM file]:file:_files' \
        '--docker+[image]:image:' \
        '-D+[image]:image:' \
        '--experimental-licenses+[license filter]:license:' \
        '--experimental-licenses-summary[license summary]' \
        '--experimental-offline-vulnerabilities[offline mode]' \
        '--experimental-download-offline-databases[download offline db]' \
        '--experimental-no-resolve[no resolution]' \
        '--experimental-local-db-path+[local db path]:dir:_files -/' \
        '--experimental-only-packages[only show packages]' \
        '--experimental-all-packages[all packages]' \
        '--verbosity+[verbosity]:level:(error warn info debug)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'osv-scanner subcommand' sub ;;
        args)
            _arguments '*:path:_files'
            ;;
    esac
}

_osv-scanner-bin "$@"
