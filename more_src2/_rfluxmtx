#compdef rfluxmtx
# Documentation: https://floyd.lbl.gov/radiance/man_html/rfluxmtx.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Radiance rfluxmtx: compute flux transfer matrix.
# Per the man page: -f -e -p -b -bn -m -M are controlled by rfluxmtx and may
# NOT be set by the user; -x -y -ld are ignored unless in pass-through mode;
# all remaining options are forwarded to rcontrib(1).
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose: report sample counts and the executed rcontrib command]' \
  '-c[ray sample count (default 10000; 1 in pass-through mode)]:count:' \
  '-h[turn headers off in output files]' \
  '-i[append receivers to existing system octree]:octree:_files -g "*.oct"' \
  '-o[output file or command for matrix data]:output:_files' \
  '*:file:_files' && ret=0
return ret
