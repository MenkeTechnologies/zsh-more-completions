#compdef gomoku
# Documentation: man gomoku(6)
# Source: openbsd/src games/gomoku/main.c — five-in-a-row (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-b[background mode]' \
    '-d[debug]' \
    '-D+[log debug to file]:file:_files' \
    '(-c -u)-u[user vs user testing]' \
    '(-c -u)-c[computer vs computer testing]' \
    '1::input file:_files' \
    && ret=0

return ret
