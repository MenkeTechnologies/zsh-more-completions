#compdef edialign
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/edialign.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS edialign: local multiple alignment using DIALIGN method
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[stdout]' \
  '-filter[stdin/stdout]' \
  '-options[prompts]' \
  '-debug[debug]' \
  '-verbose[verbose]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal]' \
  '-die[dying]' \
  '-version[version]' \
  '-sequences=[input sequence set filename]:sequence USA:_files' \
  '-nucmode=[nucleic acid alignment mode]:mode:(n nt ma)' \
  '-revcomp[consider reverse complement sequences]' \
  '-overlapw[apply overlap weights based on sequence count]' \
  '-linkage=[clustering linkage method]:method:(upgma max min)' \
  '-maxfragl=[maximum fragment length]:n:' \
  '-fragmat[require N-fragment pairs to start with two matches]' \
  '-fragsim=[minimum similarity score for P-fragment pairs]:score:' \
  '-itscore[enable iterative scoring]' \
  '-threshold=[diagonal weight threshold]:score:' \
  '-mask[replace unaligned characters with asterisks]' \
  '-dostars[write stars instead of numbers for conservation]' \
  '-starnum=[number of stars to display]:n:' \
  '-outseq=[output alignment file]:file:_files' \
  '-outfile=[diagonals output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
