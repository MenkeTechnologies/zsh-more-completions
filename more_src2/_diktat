# ============================================================================
#  _diktat — Diktat: Strict coding standard for Kotlin with custom rules
#            for code smells, style issues, and bugs
#
#  Source-direct extraction from
#    https://github.com/saveourtool/diktat/blob/master/diktat-cli/src/main/kotlin/com/saveourtool/diktat/cli/DiktatProperties.kt
#    https://github.com/Kotlin/kotlinx.cli (the kotlinx.cli library)
#
#  Maintained by SaveOurTool (saveourtool/diktat).  571 GH stars.
#  Diktat is a STRICT Kotlin coding standard linter — applies a custom
#  rule set to detect code smells, style issues, and bugs.  Integrates
#  as a standalone CLI, Gradle plugin, Maven plugin.  Sister tools:
#  ktlint (Kotlin linter, in corpus), detekt (Kotlin static analyzer,
#  in corpus), checkstyle (Java, in corpus).
#
#  CLI library taxonomy update: 2nd Kotlin CLI library — JetBrains'
#  official kotlinx.cli.  Kotlin ecosystem now has 2 documented CLI
#  libraries (R277 ajalt/clikt + R366 Kotlin/kotlinx.cli) joining the
#  multi-library leaders.
#
#  kotlinx.cli (Kotlin/kotlinx.cli; ~500 GH stars on Kotlin/kotlinx.cli)
#  is JetBrains' OFFICIAL Kotlin CLI library — designed for KOTLIN/JVM,
#  KOTLIN/NATIVE, and KOTLIN/JS multiplatform projects (whereas clikt
#  R277 is JVM-only).  Uses Kotlin's DELEGATED PROPERTIES (`by`) for
#  type-safe argument access — similar style to clikt but with
#  JetBrains-native types.
#
#  kotlinx.cli API:
#    import kotlinx.cli.ArgParser
#    import kotlinx.cli.ArgType
#    import kotlinx.cli.default
#    import kotlinx.cli.vararg
#
#    fun main(args: Array<String>) {
#      val parser = ArgParser("toolname")
#
#      val config: String? by parser.option(
#        type = ArgType.String,
#        fullName = "config",
#        shortName = "c",
#        description = "Config file path"
#      )
#
#      val mode: Mode by parser.option(
#        type = ArgType.Choice<Mode>(),
#        fullName = "mode",
#        shortName = "m",
#        description = "Mode"
#      ).default(Mode.CHECK)
#
#      val verbose: Boolean by parser.option(
#        type = ArgType.Boolean,
#        fullName = "verbose",
#        shortName = "v",
#        description = "Verbose output"
#      ).default(false)
#
#      val files: List<String> by parser.argument(
#        type = ArgType.String,
#        description = "Files to process"
#      ).vararg()
#
#      parser.parse(args)
#    }
#
#  kotlinx.cli distinctive features:
#    - KOTLIN MULTIPLATFORM — works on JVM, Native, and JS targets
#      (clikt R277 is JVM-only)
#    - KOTLIN `by` DELEGATED PROPERTIES — `val foo: T by parser.option(...)`
#      uses Kotlin's `by` keyword to wire up the typed accessor
#    - `ArgParser("name")` constructor for the parser
#    - `parser.option(type = T, fullName = "long", shortName = "s",
#       description = "X")` for FLAG with type-checking via `ArgType.X`
#    - `parser.argument(type = T, description = "X")` for POSITIONAL
#    - `ArgType.String` / `ArgType.Int` / `ArgType.Boolean` /
#      `ArgType.Double` / `ArgType.Choice<EnumType>()` / `ArgType.Choice(
#       choices, toVariant, variantToString)` for typed args
#    - `.default(V)` chained method for default value
#    - `.multiple()` chained for repeatable
#    - `.vararg()` chained for variadic positional (catches all remaining)
#    - `parser.parse(args)` invokes parse — throws on failure
#    - SUBCOMMANDS via `parser.subcommands(Subcommand1, Subcommand2, ...)`
#      where Subcommand is a CLASS extending kotlinx.cli.Subcommand
#  Distinct from R277 Kotlin clikt (uses similar `by` delegation but
#  CLIKT-SPECIFIC types + JVM-only), R275 Rust clap-derive (struct +
#  proc-macro), R344 argh (similar Rust), R322 Java JCommander (Java
#  annotations + reflection), R275 picocli (Java annotations — works
#  from Kotlin but doesn't use Kotlin's by-delegation), R359 System.
#  CommandLine (typed Argument<T>/Option<T>), R346 Scala mainargs
#  (method annotations).  kotlinx.cli's approach: KOTLIN MULTIPLATFORM
#  + Kotlin `by` DELEGATED PROPERTIES + `ArgType.X` typed args +
#  chained `.default()`/`.multiple()`/`.vararg()` — corpus's **first
#  documented Kotlin-multiplatform-with-by-delegation-and-ArgType-
#  typed-args CLI pattern**.  Brings cross-language CLI library
#  taxonomy variant count to 105; Kotlin ecosystem now has 2
#  documented CLI libraries.
#
#  Surface (verbatim from diktat-cli/src/main/kotlin/com/saveourtool/diktat/cli/DiktatProperties.kt):
#
#  Options:
#    -c, --config FILE          YAML config file
#                               (default: diktat-analysis.yml in cwd)
#    -m, --mode MODE            Mode: check | fix (default: check)
#    -r, --reporter TYPE        Reporter type (plain/json/html/sarif/checkstyle)
#    -o, --output FILE          Redirect reporter output to file
#                               (REQUIRED if --reporter is given)
#        --group-by-file        Group found errors by files
#        --color NAME           Colorize the output (color name)
#    -l, --log-level LEVEL      Log level: error | warn | info | debug | trace
#                               (default: info)
#    -V, --version              Output version information and exit
#        --license              Display license and exit
#
#  Positional:
#    <patterns>...              Files to process (variadic)
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - maestro (mobile-dev-inc/Maestro 14280 stars mobile E2E — IN
#      CORPUS via _maestro; uses picocli from Kotlin which is R276
#      picocli already)
#    - simplify (CalebFenton/simplify 4642 stars Android deobfuscator
#      — uses picocli from Kotlin, R276 already)
#    - corda-runtime-os (corda/corda-runtime-os 81 stars — uses picocli
#      from Kotlin, R276 already)
#    - codecharta (MaibornWolff/codecharta 456 stars — uses picocli)
# ============================================================================

_diktat() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-c --config)'{-c,--config}'=[YAML config file]:file:_files -g "*.{yml,yaml}"' \
    '(-m --mode)'{-m,--mode}'=[diktat mode]:mode:(check fix)' \
    '(-r --reporter)'{-r,--reporter}'=[reporter type]:type:(plain json html sarif checkstyle)' \
    '(-o --output)'{-o,--output}'=[redirect reporter output to file]:file:_files' \
    '--group-by-file=[group errors by files]:value:(true false)' \
    '--color=[colorize output (color name)]:color' \
    '(-l --log-level)'{-l,--log-level}'=[log level]:level:(ERROR WARN INFO DEBUG TRACE)' \
    '(-V --version)'{-V,--version}'[show version and exit]' \
    '--license[display license and exit]' \
    '*:Kotlin source file or pattern:_files -g "*.{kt,kts}"'
}

_diktat "$@"
