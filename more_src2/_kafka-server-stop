#compdef kafka-server-stop
# Documentation: https://github.com/apache/kafka/blob/4.2/bin/kafka-server-stop.sh
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kafka-server-stop.sh accepts --node-id= and --process-role= to target a
# specific broker; the kill signal is taken from the SIGNAL env var (default TERM).

local -a arguments

arguments=(
    '--node-id=[Node id of the broker to stop (takes precedence over --process-role)]:node id:'
    '--process-role=[Process role of the broker to stop]:role:(broker controller)'
)

_arguments -s -S $arguments
