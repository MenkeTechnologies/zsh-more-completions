#compdef nix-fast-build
# _nix-fast-build — parallel Nix build pipeline w/ caching (Mic92/nix-fast-build)
# upstream: https://github.com/Mic92/nix-fast-build
# Flags from nix_fast_build/__init__.py (argparse).

_nix-fast-build() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--flake=[flake reference to build]:flake:' \
        '--file=[Nix file to build]:file:_files -g "*.nix"' \
        '--expr=[Nix expression to evaluate]:expr:' \
        '--attr=[attribute to build]:attr:' \
        '--include=[hostname/system to include]:item:' \
        '--from=[copy-from store URI]:uri:' \
        '--copy-to=[copy-to store URI]:uri:' \
        '*--option=[Nix option key value]:opt:' \
        '--max-jobs=[max parallel build jobs]:n:' \
        '--max-memory-size=[max memory per build (MB)]:size:' \
        '--eval-max-memory-size=[max memory per eval worker (MB)]:size:' \
        '--eval-workers=[number of eval workers]:n:' \
        '--retries=[number of build retries]:n:' \
        '--keep-going[continue after a build fails]' \
        '--check-cache-status[show cache hit status]' \
        '--skip-cached[skip already-cached derivations]' \
        '--no-nom[disable nix-output-monitor]' \
        '--no-download[do not download from substituters]' \
        '--no-link[do not create result symlink]' \
        '--out-link=[result symlink prefix]:prefix:' \
        '--no-check-sigs[skip signature verification on copy]' \
        '--cachix-cache=[push to Cachix cache]:cache:' \
        '--attic-cache=[push to Attic cache]:cache:' \
        '--attic-push-build-closure[push entire build closure to Attic]' \
        '--attic-ignore-upstream-cache-filter[disable upstream cache filter]' \
        '--ignore-upstream-cache-filter[ignore upstream cache filter]' \
        '--always-upload-source[always upload source paths]' \
        '--remote=[remote ssh build host]:host:_hosts' \
        '*--remote-ssh-option=[ssh option for remote builder]:opt:' \
        '--nix=[nix binary]:file:_files' \
        '--nix-build=[nix-build binary]:file:_files' \
        '--nix-eval-jobs=[nix-eval-jobs binary]:file:_files' \
        '--gc-roots-dir=[GC roots directory]:dir:_files -/' \
        '--result-file=[machine-readable result file]:file:_files' \
        '--result-format=[result format]:fmt:(json junit)' \
        '--log-format=[log format]:fmt:(internal-json raw bar bar-with-logs)' \
        '--reference-lock-file=[reference flake lock]:file:_files' \
        '*--override-input=[flake input override]:name=ref:' \
        '--impure[allow impure expressions]' \
        '--pure[force pure evaluation]' \
        '--force-recurse[force recursion (ignore recurseIntoAttrs)]' \
        '--include-outputs[include outputs in queries]' \
        '--no-closure[do not include closure]' \
        '--requisites[include requisites]' \
        '--json[emit JSON output]' \
        '--debug[enable debug output]' \
        '--experimental-features=[nix experimental-features]:feats:' \
        '--query=[Nix store query]:expr:' \
        '--select=[select expression]:expr:'
}

_nix-fast-build "$@"
