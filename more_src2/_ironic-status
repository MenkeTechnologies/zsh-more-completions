#compdef ironic-status
# Documentation: https://docs.openstack.org/ironic/latest/cli/ironic-status.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# ironic-status: upgrade readiness checks
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'upgrade:upgrade-related checks'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'ironic-status command' commands && ret=0
    ;;
  args)
    case $line[1] in
      upgrade)
        local -a sub=('check:perform a release-specific readiness check')
        _describe -t sub 'upgrade subcommand' sub && ret=0
        ;;
    esac
    ;;
esac
return ret
