#compdef esc
# Documentation: https://www.pulumi.com/docs/esc/cli/
# Reference accessed: 2026-05-22
# Verified: pulumi/esc cmd/esc/cli/esc.go and env.go cobra definitions.

# Zsh completion for esc - Pulumi ESC secrets and environments CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'esc command' \
      'login[log in to Pulumi Cloud]' \
      'logout[log out of Pulumi Cloud]' \
      'open[open environment and access contents]' \
      'run[open environment and run a command]' \
      'env[manage environments]' \
      'version[print esc version]' && ret=0
    ;;
  args)
    case $line[1] in
      login)
        _arguments \
          '(-c --cloud-url)'{-c,--cloud-url}'[cloud URL to log in to]:url:' \
          '--default-org[default organization for login]:org:' \
          '--insecure[allow insecure server connections]' \
          '--shared[use account from pulumi CLI]' \
          '--oidc-token[OIDC token or file:// path for exchange]:token:' \
          '--oidc-org[OIDC token exchange organization]:org:' \
          '--oidc-team[OIDC exchange team token]:team:' \
          '--oidc-user[OIDC exchange personal token]:user:' \
          '--oidc-expiration[cloud access token expiration duration]:duration:' \
          '1:cloud URL:' && ret=0
        ;;
      open)
        _arguments \
          '--env[environment name to operate on]:environment:' \
          '--draft[open environment draft]:change-request-id:' && ret=0
        ;;
      run)
        _arguments \
          '--env[environment name to operate on]:environment:' \
          '--draft[open environment draft]:change-request-id:' \
          '(-i --interactive)'{-i,--interactive}'[interactive command - disable secret filtering]' \
          '(-l --lifetime)'{-l,--lifetime}'[opened environment lifetime]:duration:' \
          '--' && ret=0
        ;;
      env)
        if (( CURRENT == 3 )); then
          _values 'env command' \
            'init[create empty environment]' \
            'clone[clone environment]' \
            'edit[edit environment definition]' \
            'get[get value in environment]' \
            'diff[show environment diff]' \
            'set[set value in environment]' \
            'ls[list environments]' \
            'rm[remove environment or value]' \
            'open[open environment]' \
            'run[run command with environment]' \
            'version[manage environment versions]' \
            'tag[manage environment tags]' \
            'settings[manage environment settings]' \
            'provider[cloud provider login helpers]' \
            'rotate[rotate secrets]' \
            'schedule[manage schedules]' \
            'webhook[manage webhooks]' \
            'referrer[list environment referrers]' && ret=0
        else
          _arguments '--env[environment name]:environment:' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
