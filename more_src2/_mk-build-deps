#compdef mk-build-deps
# Documentation: https://manpages.debian.org/mk-build-deps
# Source: debian/devscripts scripts/mk-build-deps.pl — generate a fake package to satisfy build-deps (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-i --install)'{-i,--install}'[install the generated package]' \
    '(-r --remove)'{-r,--remove}'[remove the generated package after install]' \
    '(-t --tool)'{-t+,--tool=}'[install tool]:tool:(apt apt-get aptitude gdebi)' \
    '(-a --arch)'{-a+,--arch=}'[architecture]:arch:_default' \
    '--host-arch=-[host architecture]:arch:_default' \
    '--build-arch=-[build architecture]:arch:_default' \
    '(-B --build-dep)'{-B,--build-dep}'[only Build-Depends + Build-Depends-Arch]' \
    '(-A --build-indep)'{-A,--build-indep}'[only Build-Depends-Indep]' \
    '(-P --build-profiles)'{-P+,--build-profiles=}'[build profiles list]:profiles:_default' \
    '(-s --root-cmd)'{-s+,--root-cmd=}'[gain-root command]:cmd:_command_names' \
    '*:package or control file:_default' \
    && ret=0

return ret
