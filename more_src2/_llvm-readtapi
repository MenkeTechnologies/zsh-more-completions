#compdef llvm-readtapi
# _llvm-readtapi — LLVM TAPI text-based stub reader (LLVM project, C++); read/write/diff Apple TBD files
# upstream: https://github.com/llvm/llvm-project

_llvm-readtapi() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--compare[compare two tbd files]' \
        '--merge[merge tbd files]' \
        '--extract=+[extract arch slice]:arch:' \
        '--remove=+[remove arch slice]:arch:' \
        '--stubify[stubify dylib]' \
        '-o+[output file]:file:_files' \
        '--filetype=+[output filetype]:type:(tbd-v3 tbd-v4 tbd-v5)' \
        '--arch=+[arch]:arch:' \
        '*:file:_files'
}

_llvm-readtapi "$@"
