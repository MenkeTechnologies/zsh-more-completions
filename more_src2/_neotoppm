#compdef neotoppm
# Documentation: man neotoppm (Netpbm)
# Source: convert an Atari Neochrome NEO file to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:neo file:_files' \
    && ret=0

return ret
