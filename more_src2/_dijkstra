#compdef dijkstra
# Documentation: man dijkstra(1) (graphviz)
# Source: GraphViz dijkstra — single-source shortest path on a DOT graph.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[set prev attribute (previous node on shortest path) on each reachable node]' \
    '-d[treat graph as directed (use forward edges only)]' \
    '-a[unreachable nodes get large distance, max dist confined to source component]' \
    '(- *)-?[show usage]' \
    '1:source node:' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
