#compdef kubeval2
# _kubeval2 — Gareth Rushgrove Snyk kubeval2 CLI command-line frontend wrapping the Kubeval tool for validating a Kubernetes YAML or JSON configuration files open-source written in Go now deprecated in favor of Kubeconform offline-validation-of-Kubernetes-objects-against-OpenAPI-schemas validates JSON YAML manifests no-cluster-needed multi-doc batch parallel ignored-filename-pattern ignored-path-pattern ignore-missing-schemas openshift quiet strict reject-kinds schema-location version filename version-mode (Gareth Rushgrove garethr Snyk team, Go); flag
# upstream: https://github.com/instrumenta/kubeval

_kubeval2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--exit-on-error[exit on first error]' \
        '--filename=+[filename]:str:' \
        '--force-color[force color]' \
        '--ignore-missing-schemas[ignore missing schemas]' \
        '--ignored-filename-patterns=+[regex]:str:' \
        '*--ignored-filename-patterns=+[regex]:str:' \
        '--ignored-kinds=+[kinds]:str:' \
        '*--ignored-kinds=+[kinds]:str:' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--kubernetes-version=+[v]:str:' \
        '-v+[k8s version]:str:' \
        '--openshift[OpenShift]' \
        '--output=+[fmt]:f:(stdout json tap)' \
        '-o+[output]:f:(stdout json tap)' \
        '--quiet[quiet]' \
        '--reject=+[kinds]:str:' \
        '--schema-location=+[url]:str:' \
        '--strict[strict]' \
        '*:files:_files -g "*.yaml *.yml *.json"'
}

_kubeval2 "$@"
