#compdef protoc-c
# _protoc-c — Protocol Buffers C compiler (protobuf-c/protobuf-c)
# upstream: https://github.com/protobuf-c/protobuf-c
# protoc-c is a thin wrapper that forwards most flags to upstream protoc.

_protoc-c() {
    local -a args
    args=(
        '*'{-I+,--proto_path=}'[add directory to the .proto search path]:dir:_files -/'
        '--version[show version]'
        '(- *)'{-h,--help}'[show help]'
        '--encode=[encode an instance of MESSAGE from stdin to stdout]:message:'
        '--decode=[decode an instance of MESSAGE from stdin to stdout]:message:'
        '--decode_raw[decode raw protobuf bytes (no .proto)]'
        '--descriptor_set_in=[colon-separated FileDescriptorSet files to use as input]:files:_files'
        '(-o --descriptor_set_out)'{-o+,--descriptor_set_out=}'[write a FileDescriptorSet to FILE]:file:_files'
        '--include_imports[include imports in the descriptor set]'
        '--include_source_info[include source-info (comments, locations) in descriptors]'
        '--print_free_field_numbers[print field numbers not yet used in each MESSAGE]'
        '--c_out=[generate C source files in DIR]:dir:_files -/'
        '--cpp_out=[generate C++ source files in DIR]:dir:_files -/'
        '--java_out=[generate Java source files in DIR]:dir:_files -/'
        '--python_out=[generate Python source files in DIR]:dir:_files -/'
        '--ruby_out=[generate Ruby source files in DIR]:dir:_files -/'
        '--csharp_out=[generate C# source files in DIR]:dir:_files -/'
        '--objc_out=[generate Objective-C source files in DIR]:dir:_files -/'
        '--php_out=[generate PHP source files in DIR]:dir:_files -/'
        '--js_out=[generate JavaScript source files in DIR]:dir:_files -/'
        '--plugin=[load a code generator plugin from FILE]:plugin:_files'
        '--proto_path=[add directory to the .proto search path]:dir:_files -/'
        '*:proto file:_files -g "*.proto"'
    )
    _arguments -s -S $args
}

_protoc-c "$@"
