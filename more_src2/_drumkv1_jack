#compdef drumkv1_jack
# _drumkv1_jack — drumkv1 sample-based drum-kit synth, JACK client (rncbc/drumkv1)
# upstream: https://github.com/rncbc/drumkv1
# Flags from src/drumkv1_jack.cpp (QCommandLineParser).

_drumkv1_jack() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-g --no-gui)'{-g,--no-gui}'[disable the GUI]' \
        '(-n --client-name)'{-n+,--client-name=}'[JACK client name]:name:' \
        '*:preset file:_files -g "*.{drumkv1,xml}"'
}

_drumkv1_jack "$@"
