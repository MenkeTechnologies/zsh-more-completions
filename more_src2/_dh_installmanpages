#compdef dh_installmanpages
# _dh_installmanpages — deprecated: install man pages by scanning (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_installmanpages script.

_dh_installmanpages() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-a[arch-dep packages only]' \
        '-i[arch-indep packages only]' \
        '-O+[option passed to the helper]:opt:' \
        '*:file to exclude:_files'
}

_dh_installmanpages "$@"
