#compdef derb opencc
# Documentation: source-direct extraction from upstream
# unicode-org/icu
#   icu4c/source/tools/genrb/derb.cpp: UOption options[] table
#   with 12 rows + UOPTION shared macros (UOPTION_HELP_H,
#   UOPTION_HELP_QUESTION_MARK, UOPTION_ENCODING, UOPTION_VERBOSE,
#   UOPTION_DESTDIR, UOPTION_SOURCEDIR, UOPTION_ICUDATADIR,
#   UOPTION_VERSION) + the unique "to-stdout" (-c), "truncate"
#   (-t UOPT_OPTIONAL_ARG), "bom" (long-only short=0), and
#   "suppressAliases" (-A) entries decoded source-direct.
# BYVoid/OpenCC
#   src/tools/CommandLineMain.cpp: TCLAP::ValueArg/SwitchArg/
#   MultiArg declarations.  9 args total + 1 in-source mutex
#   pair (--segmentation XOR --inspect) decoded source-direct.
# OpenCC config-file enum decoded source-direct from
# data/config/*.json directory listing (15 entries excluding
# the schema file).
# Reference accessed: 2026-05-30 via gh api.
# R177 — pivot to ICU resource-bundle dumping + Chinese-script
# conversion after R176's hunt-skip on derb.  Sister tools to
# R176's icupkg+icuswap+genbrk+gencfu+gennorm2+gencmn+gensprep
# ICU data-builder suite and the heavily-covered Unicode /
# charset / locale family (uconv, recode, iconvconfig, fc-*)
# already in the corpus.

case $service in

  derb)
    # ICU resource-bundle dumper: reads a binary .res file and
    # emits the .txt source it was compiled from.
    _arguments -s -S \
      '(-h --help -?)'{-h,--help,-\\?}'[print help and exit]' \
      '(-V --version)'{-V,--version}'[print version and exit]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '(-e --encoding)'{-e+,--encoding=}'[output encoding name (e.g. UTF-8, UTF-16LE)]:encoding:' \
      '(-c --to-stdout)'{-c,--to-stdout}'[write to stdout instead of -d destdir]' \
      '(-t --truncate)'{-t-,--truncate=-}'[truncate strings (optional max length in chars)]::n:' \
      '(-d --destdir)'{-d+,--destdir=}'[output destination directory]:dir:_files -/' \
      '(-s --sourcedir)'{-s+,--sourcedir=}'[input source directory]:dir:_files -/' \
      '--bom[prepend a UTF Byte-Order-Mark to the output]' \
      '(-i --icudatadir)'{-i+,--icudatadir=}'[icudatadir override]:dir:_files -/' \
      '(-A --suppressAliases)'{-A,--suppressAliases}'[suppress emission of alias resources]' \
      '*:resource bundle file:_files -g "*.res"'
    ;;

  opencc)
    # 15-entry OpenCC config-file enum: each .json file in
    # data/config/ implements one Simplified <-> Traditional
    # script-direction (s=Simplified, t=Traditional, tw=Taiwan,
    # hk=Hong Kong, jp=Japan-kanji, "p" suffix = with-phrase-
    # lookup).  Schema file excluded.
    local -a configs=(
      hk2s.json hk2t.json jp2t.json
      s2hk.json s2t.json s2tw.json s2twp.json
      t2hk.json t2jp.json t2s.json t2tw.json
      tw2s.json tw2sp.json tw2t.json
    )
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[print help and exit]' \
      '--version[print version and exit]' \
      '(-c --config)'{-c+,--config=}'[configuration file (default s2t.json)]:config:->config' \
      '(-i --input)'{-i+,--input=}'[read original text from FILE (default stdin)]:file:_files' \
      '(-o --output)'{-o+,--output=}'[write converted text to FILE (default stdout)]:file:_files' \
      '--noflush=[disable flush on every line (default false)]:bool:(true false)' \
      '--in-place[overwrite the input file (only when input==output)]' \
      '*--path=[additional path to locate config and dictionary files (repeatable)]:dir:_files -/' \
      '--measured_result=[write measured timing results as JSON to FILE]:file:_files -g "*.json"' \
      '(--inspect)--segmentation[output segmentation result as JSON instead of converted text]' \
      '(--segmentation)--inspect[output full inspection result (segmentation + per-stage + final) as JSON]'
    case $state in
      config)
        local p
        local -a deslist
        for p in $configs; do
          deslist+=("${p}:OpenCC config ${p%.json}")
        done
        _describe -t configs 'OpenCC config' deslist
        _files -g "*.json"
        ;;
    esac
    ;;

esac
