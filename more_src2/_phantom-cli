#compdef phantom-cli phantomctl
# _phantom-cli — Splunk Phantom phantom-cli CLI command-line frontend wrapping the Splunk Phantom SOAR Security Orchestration Automation and Response platform formerly Phantom Cyber acquired by Splunk providing login logout whoami container artifact action playbook investigation user role asset role notification system-info workflow tag note action-run playbook-run vault-files report run-playbook close-investigation update-container event search visual-workflow case (Splunk Phantom team Oliver Friedrichs, Python); custom argparse
# upstream: https://www.splunk.com/en_us/products/splunk-soar.html

_phantom-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'container:container operations'
        'artifact:artifact operations'
        'action:action operations'
        'playbook:playbook operations'
        'workflow:workflow operations'
        'investigation:investigation operations'
        'user:user operations'
        'role:role operations'
        'asset:asset operations'
        'tag:tag operations'
        'note:note operations'
        'action-run:action run operations'
        'playbook-run:playbook run operations'
        'vault:vault file operations'
        'report:report operations'
        'event:event operations'
        'system-info:system info'
        'case:case operations'
        'sla:SLA operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--auth-token=+[token]:str:' \
        '--ph-auth-token=+[token]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--phantom-url=+[url]:str:' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.ini"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.ini"' \
        '-o+[format]:f:(json yaml table csv)' \
        '--output=+[format]:f:(json yaml table csv)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'phantom subcommand' sub ;;
        args)
            case $words[1] in
                container|artifact|action|playbook|workflow|investigation|user|role|asset|tag|note|action-run|playbook-run|vault|report|event|case|sla) _arguments '1:op:(list get create update delete close open run pause resume cancel)' '*:id:' ;;
            esac
            ;;
    esac
}

_phantom-cli "$@"
