#compdef dbclient
# Documentation: https://manpages.debian.org/bookworm/dropbear-bin/dbclient.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Dropbear SSH client

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-p+[remote port]:port:' \
  '-i+[identity key file]:key file:_files' \
  '-L+[local port forward]:listen_port\:host\:port:' \
  '-R+[remote port forward]:listen_port\:host\:port:' \
  '-l+[login name]:user:_users' \
  '-t[allocate PTY]' \
  '-T[do not allocate PTY]' \
  '-N[do not run a shell/command]' \
  '-f[fork into background after authentication]' \
  '-g[allow non-local hosts to connect to forwarded ports]' \
  '-y[always accept unknown host keys]' \
  '-A[forward agent connections to remote host]' \
  '-W+[per-channel receive window buffer size]:size:' \
  '-K+[keepalive interval seconds]:seconds:' \
  '-I+[idle timeout seconds]:seconds:' \
  '-z[disable QoS (AF21) traffic class]' \
  '-B+[endhost\:endport for -J netcat-alike mode]:host\:port:' \
  '-J+[use proxy command for stdio]:proxy command:' \
  '-c+[ciphers (comma-separated)]:ciphers:' \
  '-m+[MAC list (comma-separated)]:MACs:' \
  '-o+[OpenSSH-format option]:option:' \
  '-s[request remote command as subsystem (e.g. sftp)]' \
  '-V[show version]' \
  '-b+[bind to local address]:address:_hosts' \
  '(-):host:_hosts' \
  '*:command:' && ret=0

return ret
