#compdef pi-hole pi-hole-cli
# _pi-hole — Pi-hole network-wide DNS/ad blocker CLI alias (Pi-hole LLC, Bash); custom argparse
# upstream: https://github.com/pi-hole/pi-hole

_pi-hole() {
    local -a sub=(
        'a:allowlist commands (alias)'
        'allow:add domain to allowlist'
        'allowlist:manage allowlist'
        'arpflush:flush arp cache'
        'b:blocklist commands (alias)'
        'block:add domain to blocklist'
        'blocklist:manage blocklist'
        'checkout:switch branch'
        'chronometer:show metrics'
        'debug:create debug log'
        'disable:disable DNS blocking'
        'enable:enable DNS blocking'
        'flush:flush logs'
        'logging:enable/disable query logging'
        'logs:tail logs'
        'q:query commands (alias)'
        'query:lookup domain'
        'r:reload list (alias)'
        'regex:manage regex list'
        'reloaddns:reload DNS service'
        'reloadlists:reload lists'
        'restartdns:restart DNS service'
        'setpassword:set/clear web ui password'
        'status:show status'
        'tail:tail dnsmasq log'
        'updateGravity:update gravity lists'
        'g:update gravity lists (alias)'
        'updateweb:update web interface'
        'uninstall:uninstall Pi-hole'
        'version:show version'
        'wildcard:manage wildcard list'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pi-hole subcommand' sub ;;
        args)
            case $words[1] in
                disable) _arguments \
                    '*:duration:' ;;
                allow|a|allowlist|block|b|blocklist|regex|wildcard) _arguments \
                    '--list[list current entries]' \
                    '-l[list current entries]' \
                    '--delete[delete entries]' \
                    '-d[delete entries]' \
                    '--nuke[remove all entries]' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--noreload[no reload]' \
                    '*:domain:' ;;
                query|q) _arguments \
                    '--exact[exact match]' \
                    '--all[show all matches]' \
                    '*:domain:' ;;
                logs|tail) _arguments \
                    '--last=+[last n lines]:n:' \
                    '-n+[last n lines]:n:' ;;
                chronometer) _arguments \
                    '--refresh=+[refresh interval]:n:' \
                    '-r+[refresh interval]:n:' \
                    '--json[json output]' \
                    '-j[json output]' \
                    '--exit[exit after one output]' \
                    '-e[exit after one output]' ;;
                logging) _arguments \
                    '1:state:(on off)' ;;
                status) _arguments \
                    '--web[web format]' ;;
                checkout) _arguments \
                    '1:repo:(core web ftl)' \
                    '*:branch:' ;;
                updateGravity|g) _arguments \
                    '--full[full]' ;;
                debug) _arguments \
                    '--auto[auto upload]' \
                    '-a[auto upload]' ;;
            esac
            ;;
    esac
}

_pi-hole "$@"
