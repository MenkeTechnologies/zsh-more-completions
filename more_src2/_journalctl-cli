#compdef journalctl-cli
# _journalctl-cli — systemd journalctl query the systemd journal CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_journalctl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--system[show system logs]' \
        '--user[show user logs]' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '-S+[since]:str:' \
        '--since=+[since]:str:' \
        '-U+[until]:str:' \
        '--until=+[until]:str:' \
        '-c+[cursor]:str:' \
        '--cursor=+[cursor]:str:' \
        '--after-cursor=+[cursor]:str:' \
        '--cursor-file=+[file]:file:_files' \
        '--show-cursor[show cursor]' \
        '-b+[boot id]:str:' \
        '--boot=+[boot id]:str:' \
        '--list-boots[list boots]' \
        '-k[kernel messages only]' \
        '--dmesg[kernel messages only]' \
        '-u+[unit]:str:' \
        '--unit=+[unit]:str:' \
        '--user-unit=+[unit]:str:' \
        '-t+[identifier]:str:' \
        '--identifier=+[identifier]:str:' \
        '-T+[exclude identifier]:str:' \
        '--exclude-identifier=+[exclude identifier]:str:' \
        '-p+[priority]:str:' \
        '--priority=+[priority]:str:' \
        '--facility=+[facility]:str:' \
        '-g+[grep pattern]:str:' \
        '--grep=+[grep pattern]:str:' \
        '--case-sensitive=+[bool]:b:(yes no)' \
        '-e[end of journal]' \
        '--pager-end[end of journal]' \
        '-f[follow]' \
        '--follow[follow]' \
        '-n+[lines]:str:' \
        '--lines=+[lines]:str:' \
        '--no-tail[no tail]' \
        '-r[reverse]' \
        '--reverse[reverse]' \
        '-o+[output format]:f:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse json-seq cat with-unit)' \
        '--output=+[output format]:f:(short short-precise short-iso short-iso-precise short-full short-monotonic short-unix verbose export json json-pretty json-sse json-seq cat with-unit)' \
        '--output-fields=+[fields csv]:str:' \
        '--truncate-newline[truncate newlines]' \
        '--utc[UTC]' \
        '-x[show explanations]' \
        '--catalog[show explanations]' \
        '--no-full[no full]' \
        '--full[full]' \
        '-l[full output]' \
        '-a[show all printable chars]' \
        '--all[show all printable chars]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-pager[no pager]' \
        '--no-hostname[no hostname]' \
        '--merge[merge from all journals]' \
        '-m[merge from all journals]' \
        '-D+[directory]:dir:_files -/' \
        '--directory=+[directory]:dir:_files -/' \
        '--file=+[file]:file:_files' \
        '--root=+[root]:dir:_files -/' \
        '--image=+[image]:file:_files' \
        '--namespace=+[namespace]:str:' \
        '--header[show journal header]' \
        '--disk-usage[show disk usage]' \
        '--vacuum-size=+[size]:str:' \
        '--vacuum-time=+[time]:str:' \
        '--vacuum-files=+[count]:n:' \
        '--list-namespaces[list namespaces]' \
        '--list-catalog[list catalog]' \
        '--update-catalog[update catalog]' \
        '--dump-catalog[dump catalog]' \
        '--list-fields=+[field]:str:' \
        '-N+[field]:str:' \
        '--fields[list field names]' \
        '--new-id128[generate id128]' \
        '--verify[verify journal]' \
        '--verify-key=+[key]:str:' \
        '--setup-keys[generate FSS keys]' \
        '--force[force]' \
        '--interval=+[time]:str:' \
        '--sync[sync to disk]' \
        '--rotate[rotate]' \
        '--flush[flush]' \
        '--relinquish-var[relinquish var]' \
        '--smart-relinquish-var[smart relinquish var]' \
        '*:matches:'
}

_journalctl-cli "$@"
