#compdef glib-config gmodule-config gobject-config gthread-config
# _glib-config — GNOME Project glib-config legacy GLib 1.x build configuration helper superseded by pkg-config (gnome team, C); custom argparse
# upstream: https://gitlab.gnome.org/GNOME/glib

_glib-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show GLib version]' \
        '--prefix[show install prefix]' \
        '--exec-prefix[show exec prefix]' \
        '--cflags[show preprocessor and compile flags]' \
        '--libs[show link flags]' \
        '--gthread[include thread support]' \
        '--gmodule[include module support]' \
        '--gmodule-no-export[include module support without export]' \
        '--prefix=+[override prefix]:dir:_files -/' \
        '--exec-prefix=+[override exec prefix]:dir:_files -/'
}

_glib-config "$@"
