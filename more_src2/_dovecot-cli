#compdef dovecot-cli doveadm
# _dovecot-cli — Timo Sirainen Dovecot IMAP/POP3 server administration tool CLI alias (dovecot team, C); custom argparse
# upstream: https://github.com/dovecot/core

_dovecot-cli() {
    local -a sub=(
        'help:show help'
        'service:status:show service status'
        'service:stop:stop service'
        'reload:reload config'
        'stop:stop dovecot'
        'log:reopen:reopen log files'
        'log:errors:show recent errors'
        'log:find:find log entries'
        'log:test:test logging'
        'config:show config'
        'config -a:show all configs'
        'mailbox:list:list mailboxes'
        'mailbox:create:create mailbox'
        'mailbox:delete:delete mailbox'
        'mailbox:rename:rename mailbox'
        'mailbox:status:show mailbox status'
        'mailbox:subscribe:subscribe to mailbox'
        'mailbox:unsubscribe:unsubscribe'
        'mailbox:metadata:get:get metadata'
        'mailbox:metadata:set:set metadata'
        'mailbox:metadata:list:list metadata'
        'mailbox:update:update mailbox'
        'user:show user info'
        'user:list:list users'
        'who:show logged in users'
        'kick:kick users'
        'penalty:show penalty list'
        'pw:generate password'
        'auth:authenticate test'
        'auth:cache:flush:flush auth cache'
        'auth:cache:remove:remove auth cache entry'
        'auth:test:test auth'
        'auth:login:test login'
        'auth:lookup:lookup auth'
        'fetch:fetch mail'
        'expunge:expunge messages'
        'flags:add:add flags'
        'flags:remove:remove flags'
        'flags:replace:replace flags'
        'search:search messages'
        'mailbox-cryptokey:list:list crypt keys'
        'mailbox-cryptokey:export:export crypt keys'
        'mailbox-cryptokey:generate:generate crypt keys'
        'mailbox-cryptokey:password:change crypt password'
        'sieve:list:list sieve scripts'
        'sieve:get:get sieve script'
        'sieve:put:put sieve script'
        'sieve:rename:rename script'
        'sieve:delete:delete script'
        'sieve:activate:activate script'
        'sieve:deactivate:deactivate script'
        'index:run index updates'
        'replicator:add:add user'
        'replicator:remove:remove user'
        'replicator:replicate:replicate user'
        'replicator:status:show status'
        'force-resync:force resync'
        'fts:rescan:rescan FTS'
        'fts:optimize:optimize FTS'
        'instance:list:list instances'
        'instance:remove:remove instance'
        'oauth2:create:create token'
        'oauth2:refresh:refresh token'
        'oauth2:tokeninfo:show token info'
        'oauth2:passdb:lookup:passdb lookup'
        'quota:get:get quota'
        'quota:set:set quota'
        'quota:recalc:recalculate quota'
        'sync:dsync sync'
        'mirror:dsync mirror'
        'backup:dsync backup'
        'mail crypt key list:list crypt keys'
        'pop3:migrate:migrate POP3 UIDLs'
        'proxy:list:list proxy connections'
        'proxy:kick:kick proxy connections'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-D[debug]' \
        '-f+[formatter]:f:(flow pager tab table json)' \
        '-c+[config file]:file:_files -g "dovecot.conf"' \
        '-i[init script mode]' \
        '-o+[option=value]:str:' \
        '-s+[socket]:file:_files' \
        '-u+[user]:_users' \
        '-A+[all users]' \
        '-S+[mail location]:str:' \
        '-N[disable name resolution]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doveadm subcommand' sub ;;
        args)
            case $words[1] in
                user|kick|penalty|fetch|expunge|search|quota:get|quota:recalc|sync|mirror|backup|mailbox:list|mailbox:status) _arguments '*:user/query:' ;;
                pw) _arguments \
                    '-s+[scheme]:s:(PLAIN MD5 MD5-CRYPT SHA SHA1 SHA256 SHA256-CRYPT SHA512 SHA512-CRYPT SSHA SSHA256 SSHA512 SMD5 PLAIN-MD4 PLAIN-MD5 LDAP-MD5 LANMAN NTLM OTP SKEY RPA HMAC-MD5 DIGEST-MD5 CRYPT BLF-CRYPT)' \
                    '-p+[password]:str:' \
                    '-r+[rounds]:n:' \
                    '-u+[user]:_users' \
                    '-V[verify]' ;;
            esac
            ;;
    esac
}

_dovecot-cli "$@"
