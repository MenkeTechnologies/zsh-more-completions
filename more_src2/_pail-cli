#compdef pail-cli
# _pail-cli — Nuno Maduro Laravel Pail real-time log tail CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/pail

_pail-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '--filter=+[filter]:str:' \
        '--message=+[message]:str:' \
        '--level=+[level]:l:(debug info notice warning error critical alert emergency)' \
        '--user=+[user id]:n:' \
        '--auth=+[auth name]:str:' \
        '--timeout=+[idle timeout s]:n:' \
        '*:arg:'
}

_pail-cli "$@"
