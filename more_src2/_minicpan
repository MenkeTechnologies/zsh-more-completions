#compdef minicpan
# Documentation: minicpan POD
# Source: rjbs/CPAN-Mini bin/minicpan (master) — create/update local CPAN mirror (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-l+[local mirror path]:dir:_files -/' \
    '-r+[remote CPAN mirror URL]:url:_default' \
    '-d+[directory creation permissions (octal)]:perm:_default' \
    '-f[check all directories, even if indices unchanged]' \
    '-p[mirror perl/ponie/parrot distributions]' \
    '--debug[debug mode]' \
    '(-q -qq)-q[quiet mode]' \
    '(-q -qq)-qq[silent mode]' \
    '-c+[mirror class]:class:_default' \
    '-C+[config file]:file:_files' \
    '-h[show help]' \
    '-v[show version]' \
    '-x[build exact mirror (even disallowed files)]' \
    '-t+[timeout in seconds]:seconds:_default' \
    '--offline[offline mode]' \
    '--log-level=[log level]:level:(critical error warning info debug)' \
    '--remote-from=[remote source]:type:(cpan cpanplus)' \
    && ret=0

return ret
