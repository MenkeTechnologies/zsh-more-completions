#compdef realesrgan realesrgan-ncnn-vulkan
# _realesrgan — xinntao Real-ESRGAN ncnn Vulkan image super-resolution CLI alias (nihui / xinntao, C++); custom argparse
# upstream: https://github.com/xinntao/Real-ESRGAN-ncnn-vulkan

_realesrgan() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i+[input file or dir]:file:_files' \
        '-o+[output file or dir]:file:_files' \
        '-s+[upscale ratio]:n:(2 3 4 8 16)' \
        '-t+[tile size]:n:' \
        '-m+[model path]:dir:_files -/' \
        '-n+[model name]:n:(realesr-animevideov3 realesrgan-x4plus realesrgan-x4plus-anime realesrnet-x4plus)' \
        '-g+[gpu id]:n:' \
        '-j+[thread count load:proc:save]:str:' \
        '-x[enable tta mode]' \
        '-f+[output format]:fmt:(png webp jpg)' \
        '-v[verbose]' \
        '*:arg:'
}

_realesrgan "$@"
