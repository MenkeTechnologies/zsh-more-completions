#compdef pazi
# Documentation: https://github.com/euank/pazi
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_pazi_commands() {
  local -a commands=(
    'init:Print shell initialization script'
    'jump:Select a directory to jump to'
    'view:View the frecency database'
    'edit:Edit the frecency database'
    'import:Import from another autojump program'
    'visit:Add or visit a directory in the frecency database'
    'complete:Shell completion helper'
  )
  _describe 'command' commands
}

_pazi() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--debug[print debug info to stderr]' \
    '1:command:_pazi_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        init)
          _arguments \
            '1:shell:(bash zsh fish)'
          ;;
        jump)
          _arguments \
            '(-i --interactive)'{-i,--interactive}'[interactive search]' \
            '--pipe=[program for filtering]:program:_command_names -e' \
            '*:dir_target'
          ;;
        view)
          _arguments \
            '*:dir_target'
          ;;
        edit)
          _arguments \
            '*:filter'
          ;;
        import)
          _arguments \
            '1:autojumper:(fasd)'
          ;;
        visit)
          _arguments \
            '1:dir_target:_directories'
          ;;
        complete)
          _arguments \
            '1:shell:(bash zsh fish)'
          ;;
      esac
      ;;
  esac
}

_pazi "$@"
