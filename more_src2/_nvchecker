#compdef nvchecker
# Documentation: https://github.com/lilydjwg/nvchecker (nvchecker/__main__.py + nvchecker/core.py add_common_arguments)
# Reference accessed: 2026-05-29
# nvchecker — new version checker for software (TOML config, async checks, configurable sources).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-V,--version}'[show version and exit]' \
  '(-k --keyfile)'{-k,--keyfile=}'[use specified keyfile (override config file)]:file:_files' \
  '(-t --tries)'{-t,--tries=}'[try N times when network errors occur]:N:' \
  '--failures[exit with code 3 if failures/errors happen during checking]' \
  '(-e --entry)'{-e,--entry=}'[only execute on specified entry (debugging)]:entry:' \
  '(-l --logging)'{-l,--logging=}'[logging level]:level:(debug info warning error)' \
  '--logger=[select logger]:logger:(pretty json both)' \
  '--json-log-fd=[fd to send JSON logs to (stdout by default)]:fd:' \
  '(-c --file)'{-c,--file=}'[software version configuration file (TOML)]:file:_files -g "*.(toml|TOML)"' \
  && ret=0

return ret
