#compdef greenclip
# _greenclip-bin — greenclip simple clipboard manager (erebe, Haskell); rofi-integrated clipboard history
# upstream: https://github.com/erebe/greenclip

_greenclip-bin() {
    local -a sub=(
        'daemon:start the daemon'
        'print:print history'
        'clear:clear history'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'greenclip subcommand' sub ;;
    esac
}

_greenclip-bin "$@"
