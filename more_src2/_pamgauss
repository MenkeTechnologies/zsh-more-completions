#compdef pamgauss
# Documentation: man pamgauss (Netpbm)
# Source: generate a PAM image of a 2-D Gaussian function (convolution kernel).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-sigma=[Gaussian sigma]:number:' \
    '-maxval=[max sample value]:number:' \
    '-tupletype=[output tuple type]:string:(BLACKANDWHITE GRAYSCALE GRAYSCALE_ALPHA RGB RGB_ALPHA CMYK)' \
    '-maximize[scale peak to maxval]' \
    '-oversample=[oversample factor]:number:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    && ret=0

return ret
