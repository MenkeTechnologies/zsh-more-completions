#compdef edje_recc
# Documentation: https://manpages.debian.org/testing/libedje-bin/edje_cc.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# edje_recc: recompile a previously-decompiled .edc tree
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-id[image dir]:dir:_files -/' \
  '-sd[sound dir]:dir:_files -/' \
  '-fd[font dir]:dir:_files -/' \
  '-vd[vector dir]:dir:_files -/' \
  '-md[model dir]:dir:_files -/' \
  '-o[output .edj]:file:_files -g "*.edj"' \
  '*:.edc file:_files -g "*.edc"' && ret=0
return ret
