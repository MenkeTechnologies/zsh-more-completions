#compdef fslstats
# fslstats — report statistics on neuroimaging volumes

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-t[produce separate output for each time point]' \
  '-K[use mask image for segmented stats]:mask image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '-R[display min and max intensity]' \
  '-r[display robust min and max intensity (2nd/98th percentile)]' \
  '-a[use absolute values of all image intensities]' \
  '-s[display standard deviation]' \
  '-v[display volume in mm^3 and voxels]' \
  '-V[display volume in voxels and mm^3]' \
  '-m[display mean]' \
  '-M[display mean of nonzero voxels]' \
  '-S[display standard deviation of nonzero voxels]' \
  '-w[display smallest ROI containing nonzero voxels]' \
  '-e[display mean entropy]' \
  '-E[display mean entropy of nonzero voxels]' \
  '-h[display histogram (number of bins)]:number of bins' \
  '-H[display histogram with specified nbins min max]:nbins min max' \
  '-p[display nth percentile]:percentile (0-100)' \
  '-P[display robust nth percentile]:percentile (0-100)' \
  '1:input volume:_files -g "*.{nii,nii.gz,img,hdr}"'
