#compdef kamel
# Documentation: https://github.com/apache/camel-k/blob/main/pkg/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream pkg/cmd/root.go at the URL above.

# Apache Camel K CLI. Command list corrected from prior file against
# root.go AddCommand calls: added builder/version/help, removed invented
# create. Persistent flags: --kube-config, -n/--namespace, -V/--verbose.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'version:display client version'
  'run:run an integration from source'
  'deploy:deploy an integration'
  'get:fetch integrations'
  'delete:delete integrations'
  'log:print integration logs'
  'kit:manage integration kits'
  'reset:reset Camel K CRs and state'
  'rebuild:rebuild integration images'
  'operator:install/upgrade the Camel K operator'
  'builder:run the Camel K builder'
  'debug:debug an integration'
  'dump:dump Camel K resources'
  'bind:bind Kubernetes resources'
  'promote:promote integrations across environments'
  'undeploy:undeploy integrations'
  'help:help for any command'
)

_arguments -s -S \
  '--kube-config=[path to the kube config file]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace to use for all operations]:namespace:' \
  '(-V --verbose)'{-V,--verbose}'[verbose logging]' \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'kamel command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
