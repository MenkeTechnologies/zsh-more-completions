#compdef gin
# _gin — Go live-reload utility
# upstream: https://github.com/codegangsta/gin

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-p --port)'{-p,--port=}'[port for the proxy server]:port:' \
    '(-a --appPort)'{-a,--appPort=}'[port for the Go app]:port:' \
    '(-b --bin)'{-b,--bin=}'[path to generated binary]:file:_files' \
    '(-t --path)'{-t,--path=}'[path to watch]:directory:_directories' \
    '(-d --build)'{-d,--build=}'[path to build]:directory:_directories' \
    '--buildArgs=[additional go build arguments]:args:' \
    '--certFile=[TLS certificate file]:file:_files' \
    '--keyFile=[TLS key file]:file:_files' \
    '--logPrefix=[log prefix]:prefix:' \
    '--notifications[enable desktop notifications]' \
    '-i[immediate start before first build]' \
    '--immediate[immediate start before first build]' \
    '--all[build with all files not just .go]' \
    '--godep[use godep for dependency management]' \
    '--excludeDir=[directories to exclude from watch]:directories:' \
    '*:extra arguments:' \
    && return 0
