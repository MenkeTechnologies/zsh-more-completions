#compdef paraview pvpython pvbatch pvserver
# Documentation: https://docs.paraview.org/en/latest/UsersGuide/commandLineArguments.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--data=[load data file(s) on startup]:file:_files' \
  '--state=[load state file (.pvsm or .py)]:file:_files -g "*.(pvsm|py)"' \
  '--script=[Python script to execute on startup]:script:_files -g "*.py"' \
  '(-s --server)'{-s+,--server=}'[server resource name for client connection]:resource:' \
  '--connect-id=[connection ID for client-server matching]:id:' \
  '--client-host=[client host for reverse connection]:host:_hosts' \
  '--hostname=[server hostname]:host:_hosts' \
  '--reverse-connection[server connects to client]' \
  '--test-directory=[test output directory]:dir:_files -/' \
  '--test-script=[test script]:script:_files -g "*.py"' \
  '--test-baseline=[test baseline]:file:_files' \
  '--test-threshold=[test image threshold]:threshold:' \
  '--exit[exit after loading]' \
  '--multi-servers[enable multi-server mode]' \
  '--live=[Catalyst Live port]:port:' \
  '--disable-registry[disable settings registry]' \
  '--force-offscreen-rendering[force offscreen rendering]' \
  '--force-onscreen-rendering[force onscreen rendering]' \
  '*:file:_files' && ret=0

return ret
