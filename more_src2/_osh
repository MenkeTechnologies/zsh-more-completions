#compdef osh
# Documentation: https://oils.pub/release/latest/doc/ref/chap-front-end.html
# Reference accessed: 2026-05-20
# Verified: Oils Reference, Front End chapter (osh-usage, shell-flags, config).
# Removed from prior file: bogus man.archlinux.org search URL;
# bogus `--tool` enum (`cat`, `fmt`) and undocumented `--headless` flag.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '-c+[execute command string]:command:' \
  '-i[interactive mode]' \
  '-l[login shell]' \
  '-n[parse but do not execute, print AST]' \
  '-o+[set shell option]:option:(errexit nounset pipefail xtrace verbose noexec noglob)' \
  '+o+[unset shell option]:option:' \
  '-O+[set Oils option]:option:' \
  '+O+[unset Oils option]:option:' \
  '-x[print commands before execution]' \
  '-v[print input as read]' \
  '-e[exit on error]' \
  '-u[error on unset variables]' \
  '-s[read from stdin]' \
  '--rcfile=[use alternate rc file]:file:_files' \
  '--rcdir=[rc directory]:dir:_files -/' \
  '--norc[do not read rc files or rc directory]' \
  '--eval=[evaluate file like source]:file:_files' \
  '--eval-pure=[evaluate file in pure mode]:file:_files' \
  '--location-str=[location string for errors]:string:' \
  '--location-start-line=[line offset for errors]:line:' \
  '--tool=[run built-in tool]:tool:(cat-em syntax-tree)' \
  '--ast-format=[AST format]:format:(text text-abbrev)' \
  '--debug-file=[debug log file]:file:_files' \
  '--xtrace-to-debug-file[send xtrace to debug file]' \
  '*:script:_files' && ret=0

return ret
