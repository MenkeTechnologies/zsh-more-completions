#compdef otbcli_ConcatenateImages
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ConcatenateImages.html
# Source: orfeotoolbox/OTB ConcatenateImages — stack same-size rasters into multi-channel image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-il+[input image list (same size)]:images:_files' \
    '-out+[concatenated output image]:image:_files' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
