#compdef goodls
# Documentation: https://github.com/tanaikech/goodls
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# tanaikech/goodls — download files from Google Drive shared URLs.

local ret=1
_arguments -s -S \
  '--help[show help]' \
  '-u+[Drive shared URL]:url:_urls' \
  '-e+[export extension (default pdf; ms = Microsoft format)]:ext:' \
  '-f+[output filename]:filename:' \
  '-key+[Google Drive API key]:key:' \
  '-m+[MIME types filter]:mime types:' \
  '-d+[output directory]:dir:_files -/' \
  '(-ntd --notcreatetopdirectory)'{-ntd,--notcreatetopdirectory}'[do not create top-level folder]' \
  '--overwrite[replace existing files]' \
  '--skip[skip existing files]' \
  '(-np --NoProgress)'{-np,--NoProgress}'[silent mode without progress]' \
  '--skiperror[continue downloading on errors]' \
  '-r+[enable resumable download with size (e.g. 100m)]:size:' \
  '-i[retrieve file or folder metadata]' \
  '-c+[service account JSON]:file:_files' && ret=0
return ret
