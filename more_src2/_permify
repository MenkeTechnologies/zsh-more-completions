#compdef permify
# Documentation: https://github.com/Permify/permify
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Permify — open-source authorization service; CLI (`permify --help`) covers serve/migrate/version/etc.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'serve:run API server'
  'validate:validate schema bundle'
  'coverage:test coverage helpers'
  'ast:generate AST from schema'
  'migrate:database migrations'
  'version:print build info'
  'config:show configuration'
  'repair:run repair operations'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'permify' subcmds && ret=0
    ;;
  rest)
    _normal && ret=0
    ;;
esac

return ret
