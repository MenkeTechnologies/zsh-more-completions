#compdef fleek
# _fleek — Nix home-manager wrapper for easy configuration
# upstream: https://github.com/ublue-os/fleek

_fleek() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--verbose[enable verbose output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:initialize fleek configuration'
                'add:add a package to the configuration'
                'remove:remove a package from the configuration'
                'apply:apply the current configuration'
                'update:update flake inputs'
                'eject:eject from fleek to raw home-manager'
                'search:search for packages'
                'show:show current configuration'
                'join:join an existing fleek configuration'
                'generate:generate configuration files'
                'version:print version information'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                add|remove)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '*:package name:'
                    ;;
                apply)
                    _arguments \
                        '(-d --dry-run)'{-d,--dry-run}'[show what would be applied]' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                init)
                    _arguments \
                        '(-f --force)'{-f,--force}'[force initialization]' \
                        '(-l --level)'{-l,--level=}'[bling level]:level:(none low default high)' \
                        '(- *)'{-h,--help}'[show help]'
                    ;;
                search)
                    _arguments \
                        '(- *)'{-h,--help}'[show help]' \
                        '1:search term:'
                    ;;
            esac
            ;;
    esac
}

_fleek "$@"
