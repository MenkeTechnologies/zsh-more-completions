#compdef psql
# Documentation: psql --help (PostgreSQL)
# Source: PostgreSQL interactive terminal.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help=-}'[show help]::topic:(options commands variables)' \
    '(- *)'{-V,--version}'[show version]' \
    '*'{-c+,--command=}'[run single SQL/internal command and exit]:command:' \
    {-d+,--dbname=}'[database name]:db:' \
    {-f+,--file=}'[execute commands from file]:file:_files -g "*.sql"' \
    {-l,--list}'[list available databases and exit]' \
    '*'{-v+,--set=,--variable=}'[set psql variable NAME=VALUE]:assignment:' \
    {-X,--no-psqlrc}'[do not read ~/.psqlrc]' \
    {-1,--single-transaction}'[execute as single transaction]' \
    {-a,--echo-all}'[echo all input from script]' \
    {-b,--echo-errors}'[echo failed commands]' \
    {-e,--echo-queries}'[echo commands sent to server]' \
    {-E,--echo-hidden}'[display queries internal commands generate]' \
    {-L+,--log-file=}'[session log file]:file:_files' \
    {-n,--no-readline}'[disable readline editing]' \
    {-o+,--output=}'[query results file or pipe]:file:_files' \
    {-q,--quiet}'[run quietly]' \
    {-s,--single-step}'[confirm each query]' \
    {-S,--single-line}'[EOL terminates SQL command]' \
    {-A,--no-align}'[unaligned table output]' \
    '--csv[CSV table output]' \
    {-F+,--field-separator=}'[unaligned field separator]:sep:' \
    {-H,--html}'[HTML table output]' \
    '*'{-P+,--pset=}'[printing option VAR[=ARG]]:pset:' \
    {-R+,--record-separator=}'[unaligned record separator]:sep:' \
    {-t,--tuples-only}'[print rows only]' \
    {-T+,--table-attr=}'[HTML table tag attributes]:text:' \
    {-x,--expanded}'[expanded table output]' \
    {-z,--field-separator-zero}'[field separator zero byte]' \
    {-0,--record-separator-zero}'[record separator zero byte]' \
    {-h+,--host=}'[server host/socket]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_ports' \
    {-U+,--username=}'[database user]:user:_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    ':dbname:' \
    ':username:_users' \
    && ret=0

return ret
