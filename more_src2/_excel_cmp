#compdef excel_cmp
# Documentation: https://github.com/na-ka-na/ExcelCompare
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# excel_cmp is the shell wrapper for ExcelCompare (Java diff tool for .xls/.xlsx).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--diff_numeric_precision=[numeric precision (e.g. 0.0001)]:precision:' \
  '--diff_ignore_formulas[compare evaluated values instead of formulas]' \
  '--diff_format=[output format]:format:(excel_cmp unified)' \
  '*--ignore1=[ignore spec for file1: sheet:row:col:cell]:spec:' \
  '*--ignore2=[ignore spec for file2: sheet:row:col:cell]:spec:' \
  '*:workbook:_files -g "*.(xls|xlsx)"' && ret=0

return ret
