#compdef pass-extension pass-otp pass-import pass-update pass-tomb pass-audit
# _pass-extension — Jason Donenfeld pass command-line password manager extensions CLI alias (Jason Donenfeld / pass community, Bash); custom argparse
# upstream: https://www.passwordstore.org

_pass-extension() {
    local -a sub=(
        'otp:OTP token management'
        'import:import from another manager'
        'update:update entries with new passwords'
        'tomb:encrypted Tomb container'
        'audit:audit password strength'
        'qrcode:show QR code for an entry'
        'cleanup:cleanup orphaned files'
        'showqr:show QR for an entry'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pass-extension subcommand' sub ;;
        args)
            case $words[1] in
                otp) _arguments \
                    '1:cmd:(insert append code uri validate)' \
                    '--force[force]' \
                    '-f[force]' \
                    '--clip[clip]' \
                    '-c[clip]' \
                    '*:entry:' ;;
                import) _arguments \
                    '1:manager:(1password bitwarden chrome dashlane enpass firefox keepass keepassx keepassxc kwallet lastpass passpack pwsafe roboform 1password4)' \
                    '--path=+[output path]:str:' \
                    '-p+[output path]:str:' \
                    '--all[import all]' \
                    '-a[import all]' \
                    '--force[force]' \
                    '-f[force]' \
                    '*:file:_files' ;;
                tomb) _arguments \
                    '1:cmd:(create open close resize hide)' \
                    '*:arg:' ;;
                audit) _arguments \
                    '--breach[check breach db]' \
                    '-b[check breach db]' \
                    '*:entry:' ;;
                update) _arguments \
                    '--all[all entries]' \
                    '-a[all entries]' \
                    '*:entry:' ;;
                qrcode|showqr) _arguments '*:entry:' ;;
            esac
            ;;
    esac
}

_pass-extension "$@"
