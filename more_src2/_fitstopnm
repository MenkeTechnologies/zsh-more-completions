#compdef fitstopnm
# Documentation: man fitstopnm (Netpbm)
# Source: convert a NASA FITS astronomical image to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-image=[image number in multi-image FITS]:N:' \
    '-scanmax[scan for actual min/max sample values]' \
    '-printmax[print min/max sample values]' \
    '-min=[treat min sample value as f]:f:' \
    '-max=[treat max sample value as f]:f:' \
    '-omaxval=[output maxval]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:FITS file:_files -g "*.(fits|fit|fts)"' \
    && ret=0

return ret
