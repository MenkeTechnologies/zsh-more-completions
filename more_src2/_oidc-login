#compdef oidc-login kubectl-oidc_login
# Documentation: https://github.com/int128/kubelogin
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/get_token.go
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/authentication.go
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/tokencache.go
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/tls.go
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/pkce.go
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/setup.go
# Documentation: https://github.com/int128/kubelogin/blob/master/pkg/cmd/clean.go
# Reference accessed: 2026-05-27
# Verified: upstream pkg/cmd/{get_token,authentication,tokencache,tls,pkce,setup,clean}.go
#   pflag.*Var definitions
# Note: the installed binary is typically `kubectl-oidc_login`, invoked as
# `kubectl oidc-login` per kubectl plugin convention. Both names are wired.

local curcontext="$curcontext" state line ret=1

local -a _oidclogin_subcommands
_oidclogin_subcommands=(
  'get-token:run as a kubectl credential plugin'
  'setup:show setup instructions for the OIDC provider'
  'clean:delete the cached tokens'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'oidc-login subcommand' _oidclogin_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      get-token|setup)
        _arguments -s \
          '--oidc-issuer-url=[issuer URL of the provider (mandatory)]:url:' \
          '--oidc-client-id=[client ID of the provider (mandatory)]:id:' \
          '--oidc-client-secret=[client secret of the provider]:secret:' \
          '--oidc-redirect-url=[redirect URL (authcode, authcode-keyboard)]:url:' \
          '*--oidc-extra-scope=[scopes to request to the provider]:scope:' \
          '--oidc-use-access-token[use access_token instead of id_token]' \
          '*--oidc-request-header=[HTTP headers to send with the authentication request]:header:' \
          '*--oidc-auth-request-extra-params=[extra query parameters for the authentication request]:k=v:' \
          '--oidc-use-pkce[force PKCE S256 (deprecated; use --oidc-pkce-method)]' \
          '--oidc-pkce-method=[PKCE code challenge method]:method:(auto no S256)' \
          '--grant-type=[authorization grant type]:type:(auto authcode authcode-keyboard password device-code client-credentials)' \
          '*--listen-address=[address to bind the local server (authcode)]:host\:port:' \
          '--skip-open-browser[do not open the browser automatically (authcode)]' \
          '--browser-command=[command to open the browser (authcode)]:command:_command_names -e' \
          '--authentication-timeout-sec=[timeout of authentication in seconds (authcode)]:seconds:' \
          '--local-server-cert=[certificate path for the local server (authcode)]:file:_files' \
          '--local-server-key=[certificate key path for the local server (authcode)]:file:_files' \
          '--open-url-after-authentication=[URL to open in the browser after authentication (authcode)]:url:' \
          '--username=[username for password grant]:user:' \
          '--password=[password for password grant]:password:' \
          '--token-cache-dir=[path to a directory of the token cache]:dir:_files -/' \
          '--token-cache-storage=[storage for the token cache]:storage:(disk keyring none)' \
          '*--certificate-authority=[path to a CA cert file]:file:_files' \
          '*--certificate-authority-data=[base64 encoded CA cert]:data:' \
          '--insecure-skip-tls-verify[do not verify the server certificate (security risk)]' \
          '--tls-renegotiation-once[allow remote server to request renegotiation once]' \
          '--tls-renegotiation-freely[allow remote server to repeatedly request renegotiation]' \
          '--force-refresh[refresh the ID token regardless of expiration]' && ret=0
        ;;
      clean)
        _arguments \
          '--token-cache-dir=[path to a directory of the token cache]:dir:_files -/' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
