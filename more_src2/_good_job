#compdef good_job
# _good_job — GoodJob multithreaded Postgres-backed ActiveJob worker (Ruby on Rails)
# upstream: https://github.com/bensheldon/good_job

_good_job() {
    local -a sub=(
        'start:start workers (default)'
        'cleanup_preserved_jobs:purge old preserved jobs'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--max-threads+[max threads]:n:' \
        '--queues+[queue list]:queues:' \
        '--poll-interval+[poll seconds]:n:' \
        '--cleanup-discarded-jobs[delete discarded]' \
        '--cleanup-interval-jobs+[cleanup interval]:n:' \
        '--cleanup-interval-seconds+[cleanup interval sec]:n:' \
        '--max-cache+[advisory lock cache]:n:' \
        '--shutdown-timeout+[shutdown timeout]:n:' \
        '--enable-cron[enable cron scheduler]' \
        '--probe-port+[probe http port]:port:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'good_job subcommand' sub ;;
    esac
}

_good_job "$@"
