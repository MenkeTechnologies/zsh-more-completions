#compdef menulibre
# _menulibre — bluesabre/menulibre (cross-DE app menu editor reading freedesktop .desktop entries from XDG menu paths; --debug enables verbose logging, positional argument opens to a specific .desktop file path)
# upstream: https://github.com/bluesabre/menulibre
# Flags from menulibre menulibre/__init__.py on tip.

_menulibre() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug output]' \
        '1:desktop file:_files -g "*.desktop"'
}

_menulibre "$@"
