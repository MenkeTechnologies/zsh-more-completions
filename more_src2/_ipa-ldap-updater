#compdef ipa-ldap-updater
# Documentation: https://github.com/freeipa/freeipa/blob/master/install/tools/man/ipa-ldap-updater.1
# Reference accessed: 2026-05-16
# Verified: upstream install/tools/man/ipa-ldap-updater.1.

# ipa-ldap-updater: update IPA LDAP server schema and definitions
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-u --upgrade)'{-u,--upgrade}'[upgrade installed server in offline mode]' \
  '*'{-S,--schema-file=}'[schema file (repeatable)]:file:_files -g "*.ldif"' \
  '*:input file:_files -g "*.ldif"' && ret=0
return ret
