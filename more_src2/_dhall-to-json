#compdef dhall-to-json
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-json
# Source: dhall-lang/dhall-haskell dhall-json/dhall-to-json/Main.hs — compile Dhall to JSON.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--explain[explain error messages in detail]' \
    '--pretty[deprecated, formatting is now the default]' \
    '--compact[render JSON on one line]' \
    '--approximate-special-doubles[approximate special Double values as null/Infinity if not representable]' \
    '--file=[read Dhall expression from FILE instead of stdin]:file:_files' \
    '--output=[write JSON to FILE instead of stdout]:file:_files' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
