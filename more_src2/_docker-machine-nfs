#compdef docker-machine-nfs
# Documentation: https://github.com/adlogix/docker-machine-nfs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Activates NFS on docker-machine.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-f --force)'{-f,--force}'[force reconfiguration of NFS]' \
  '(-s --shared-folder)'{-s,--shared-folder}'=[folder to share via NFS \(repeatable\)]:directory:_files -/' \
  '(-m --mount-opts)'{-m,--mount-opts}'=[NFS mount options]:options' \
  '(-n --nfs-config)'{-n,--nfs-config}'=[NFS export config]:config' \
  '--ip=[host machine IP address]:ip' \
  '*:docker-machine name:' && ret=0

return ret
