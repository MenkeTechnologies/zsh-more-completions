#compdef figlist
# Documentation: https://www.figlet.org/figlet-man.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# figlist replaces `figlet -F` (removed in figlet 2.1). Accepts only -d <dir>.

local curcontext="$curcontext" state line ret=1

_arguments \
  '-d+[font directory]:dir:_files -/' && ret=0

return ret
