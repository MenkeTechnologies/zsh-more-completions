#compdef dtls_client
# Documentation: https://github.com/Mbed-TLS/mbedtls/blob/development/programs/ssl/dtls_client.c
# Reference accessed: 2026-05-17
# Verified: Mbed-TLS dtls_client example program — uses key=value
# parameter style (server_addr, server_port, server_name,
# debug_level, ca_file, crt_file, key_file, force_ciphersuite).
# Removed from prior file: bogus man.archlinux.org search URL.
# NOTE: example/test program, not a packaged tool. Similar
# `dtls_client` exists in contiki-ng/tinydtls (different flag set).

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'server_addr=:server address'
  'server_port=:server port'
  'server_name=:server name'
  'debug_level=:debug level'
  'ca_file=:trusted CA file'
  'crt_file=:client certificate'
  'key_file=:client key'
  'force_ciphersuite=:force a single ciphersuite'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P '(ca_file|crt_file|key_file)='; then
      _files && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
