#compdef phobius phobius.pl
# _phobius — Lukas Käll phobius CLI combined transmembrane topology and signal peptide predictor for protein sequences using HMM hidden-Markov-model trained on Pfam Uniprot SwissProt benchmarking-validated TM helices N-terminal signal peptide cleavage site cytoplasmic non-cytoplasmic location (Lukas Käll team, Perl); getopt
# upstream: https://phobius.sbc.su.se/

_phobius() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-short[short output format]' \
        '-long[long output format]' \
        '-plp[plp output format]' \
        '-png[PNG plot]' \
        '-gif[GIF plot]' \
        '-eps[EPS plot]' \
        '-poly[polyprotein mode]' \
        '-omp[omp barrel mode]' \
        '*:fasta file:_files -g "*.fa *.fasta *.faa *.gz"'
}

_phobius "$@"
