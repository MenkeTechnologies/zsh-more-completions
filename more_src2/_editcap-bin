#compdef editcap
# _editcap-bin — Wireshark capture-file editor (Wireshark Foundation); modify/filter/convert pcap/pcapng
# upstream: https://gitlab.com/wireshark/wireshark

_editcap-bin() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-a+[frame:comment]:str:' \
        '-A+[start time]:str:' \
        '-B+[end time]:str:' \
        '-c+[split after N packets]:n:' \
        '-C+[chop bytes]:n:' \
        '-D+[duplicate window]:n:' \
        '-E+[error percent]:f:' \
        '-F+[output file format]:fmt:' \
        '-i+[seconds per file]:n:' \
        '-I+[bytes per file]:n:' \
        '-L+[label]:str:' \
        '-o+[change preferences]:str:' \
        '-r[invert selection]' \
        '-s+[truncate snaplen]:n:' \
        '-S+[strict time adjust]:str:' \
        '-t+[time adjustment seconds]:n:' \
        '-T+[force packet type]:type:' \
        '-w+[duplicate detection window]:str:' \
        '*:file:_files'
}

_editcap-bin "$@"
