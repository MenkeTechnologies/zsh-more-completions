#compdef darktable-chart
# Documentation: https://docs.darktable.org/usermanual/4.6/en/special-topics/program-invocation/darktable-chart/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# darktable-chart: builds .dtstyle from IT8/ColorChecker reference + measurements
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--csv[CSV CLI mode: csv-file num-patches output-dtstyle]' \
  '*:chart files:_files -g "*.(it8|cht|cie|csv|dtstyle|pfm|tiff|tif|jpg|jpeg|png|cr2|nef|raf|arw|orf|dng)"' && ret=0
return ret
