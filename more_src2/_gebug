#compdef gebug
# Documentation: https://github.com/moshebe/gebug
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gebug - Go debugging tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --workdir)'{-w,--workdir}'+[Go application root directory]:dir:_files -/' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds=(
      'init:set up a gebug project'
      'start:launch gebug services'
      'clean:remove gebug stack'
      'destroy:remove the gebug project'
      'ui:open the web-based interface'
      'version:show version'
      'help:show help'
    )
    _describe -t cmds 'gebug command' cmds && ret=0
    ;;
esac

return ret
