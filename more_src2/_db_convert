#compdef db_convert
# Documentation: https://docs.oracle.com/database/bdb181/html/api_reference/C/db_convert.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Berkeley DB db_convert: convert database files to a specified byte order

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-b[convert files/databases to big endian byte order]' \
  '-l[convert files/databases to little endian byte order]' \
  '-V[write library version number and exit]' \
  '-v[run in verbose mode]' \
  '-h+[database environment home directory]:dir:_files -/' \
  '-P+[environment password]:password:' \
  '-S+[verify before conversion]:mode:((o\:"skip btree/dup sort and hash checks" v\:"perform standard verification"))' \
  '*:database file:_files' && ret=0

return ret
