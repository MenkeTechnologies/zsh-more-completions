#compdef roxctl
# Documentation: https://docs.redhat.com/en/documentation/red_hat_advanced_cluster_security_for_kubernetes/4.4/html/roxctl_cli/roxctl-cli-command-reference
# Reference accessed: 2026-05-21
# Verified: upstream Red Hat ACS roxctl command reference + stackrox/stackrox
# roxctl source tree subdirs (central, cluster, collector, completion,
# declarativeconfig, deployment, helm, image, logconvert, netpol,
# sbom, scanner, sensor, summaries).

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'central:commands related to the Central service'
  'cluster:commands related to secured clusters'
  'collector:commands related to the Collector service'
  'completion:generate shell completion scripts'
  'declarative-config:commands for declarative configuration'
  'deployment:check deployments for policy violations'
  'generate:generate YAML/Helm configurations'
  'helm:commands related to RHACS Helm Charts'
  'image:scan images and check for policy violations'
  'log-convert:convert log files'
  'netpol:work with network policies'
  'sbom:generate / work with SBOM data'
  'scanner:commands related to Scanner / Scanner V4'
  'sensor:commands related to Sensor service'
  'summary:print summaries'
  'version:print roxctl version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-e[set Central API endpoint host:port]:endpoint' \
  '--endpoint=[set Central API endpoint host:port]:endpoint' \
  '--ca=[custom CA cert file]:file:_files' \
  '--insecure[allow insecure connections]' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '--token-file=[Central API token file]:file:_files' \
  '--password=[Central admin password]:password' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'roxctl command' commands && ret=0 ;;
esac

return ret
