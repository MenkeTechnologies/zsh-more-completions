#compdef kubeflow kfctl
# _kubeflow — Google Kubeflow kfctl CLI for managing Kubeflow ML platform deployments on Kubernetes generating apply build delete configurations across AWS GCP Azure on-prem with Kustomize overlays YAML kfdef manifests (kubeflow team, Go); cobra
# upstream: https://github.com/kubeflow/kfctl

_kubeflow() {
    local -a sub=(
        'apply:apply Kubeflow components'
        'build:build manifests'
        'delete:delete Kubeflow deployment'
        'generate:generate config'
        'init:initialize new deployment'
        'show:show config'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-f+[config file]:file:_files -g "*.yaml *.yml"' \
        '--file=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-V+[verbosity]:n:(0 1 2 3 4 5)' \
        '--verbosity=+[verbosity]:n:(0 1 2 3 4 5)' \
        '--use-basic-auth[use basic auth]' \
        '--use-istio[use Istio]' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubeflow subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--namespace=+[ns]:str:' \
                    '--project=+[project]:str:' \
                    '--platform=+[p]:p:(gcp aws azure existing_arrikto k8s minikube docker_for_desktop)' \
                    '--version=+[v]:str:' \
                    '--use-istio[use Istio]' \
                    '--package-manager=+[pm]:p:(kustomize ksonnet)' \
                    '*:project name:' ;;
                apply|delete|build) _arguments \
                    '-V+[verbosity]:n:(0 1 2 3 4 5)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kubeflow "$@"
