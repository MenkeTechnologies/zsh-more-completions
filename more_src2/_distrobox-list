#compdef distrobox-list
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/distrobox-list.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for distrobox-list

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--no-color[disable color output]' \
  '(-r --root)'{-r,--root}'[run podman/docker/lilipod as root]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0

return ret
