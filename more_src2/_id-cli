#compdef id-cli
# _id-cli — GNU coreutils id print real and effective user/group IDs CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_id-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[ignored (POSIX compat)]' \
        '-Z[print security context]' \
        '--context[print security context]' \
        '-g[print only effective gid]' \
        '--group[print only effective gid]' \
        '-G[print all gids]' \
        '--groups[print all gids]' \
        '-n[print name instead of number]' \
        '--name[print name instead of number]' \
        '-r[print real id instead of effective]' \
        '--real[print real id instead of effective]' \
        '-u[print only effective uid]' \
        '--user[print only effective uid]' \
        '-z[NUL terminator]' \
        '--zero[NUL terminator]' \
        '*:user:_users'
}

_id-cli "$@"
