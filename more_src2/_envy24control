#compdef envy24control
# Documentation: https://manpages.debian.org/testing/alsa-tools-gui/envy24control.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-c+[ALSA card number]:card-number:' \
  '-D+[ALSA control device]:control-name:' \
  '-f+[profiles file path]:file:_files' \
  '-o+[limit analog line outputs displayed (max 8)]:outputs:' \
  '-i+[limit analog line inputs displayed (max 8)]:inputs:' \
  '-p+[limit PCM outputs to display]:pcm-outputs:' \
  '-s+[limit SPDIF channels]:spdif:' \
  '-v[view SPDIF playback channels in mixer]' \
  '-m+[enable MIDI controller on channel]:midi-channel:' \
  '-M[use enhanced MIDI-to-dB mapping]' \
  '-w+[initial window width]:width:' \
  '-t+[mixer channel heights (0-9)]:tall-equal:' \
  '*:profile:' && ret=0

return ret
