#compdef kubectl-autons
# Documentation: https://github.com/ragrag/kubectl-autons
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-autons (ragrag/kubectl-autons): automatic namespace detection.
# Wraps a kubectl subcommand + args and resolves the namespace itself, so
# it has no own flags beyond -h/--help.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:(describe logs port-forward exec get edit delete)' \
  '*::arg:_default'
