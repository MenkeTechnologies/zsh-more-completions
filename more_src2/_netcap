#compdef netcap
# Documentation: man netcap(8)
# Source: stevegrubb/libcap-ng utils/netcap.c (master) — show capabilities of network connections (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--advanced[advanced output with more details]' \
    '--interface=[restrict to network interface]:iface:_net_interfaces' \
    '--list-interfaces[list available interfaces]' \
    '--json[JSON output]' \
    '--no-color[disable color output]' \
    && ret=0

return ret
