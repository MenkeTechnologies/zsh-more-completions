#compdef pidstat
# _pidstat — sysstat pidstat per-task statistics CLI (Sebastien Godard / sysstat team, C); custom argparse
# upstream: https://github.com/sysstat/sysstat

_pidstat() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d[I/O statistics]' \
        '-H[show timestamps as epoch]' \
        '-I[force iso 8601 output]' \
        '-l[show full command line and args]' \
        '-R[show real-time priority]' \
        '-r[memory usage stats]' \
        '-s[stack utilization stats]' \
        '-t[also include children tasks]' \
        '-T+[task selection]:t:(TASK CHILD ALL)' \
        '-u[CPU utilization stats]' \
        '-U+[show owner]:user:_users' \
        '-v[show kernel resources]' \
        '-w[show context switch stats]' \
        '-C+[command filter regex]:str:' \
        '-G+[process name filter regex]:str:' \
        '-p+[PIDs to monitor]:list:_pids' \
        '*:arg:'
}

_pidstat "$@"
