#compdef llvm-stress
# _llvm-stress — LLVM random IR generator (LLVM project, C++); generate random LLVM IR for stress testing
# upstream: https://github.com/llvm/llvm-project

_llvm-stress() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--size=+[function size]:n:' \
        '-size=+[function size]:n:' \
        '--seed=+[random seed]:n:' \
        '-seed=+[random seed]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--llvm-input[treat input as LLVM IR (no-op)]'
}

_llvm-stress "$@"
