#compdef payload-dumper-go
# Documentation: https://github.com/ssut/payload-dumper-go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# payload-dumper-go: Android OTA payload.bin dumper (Go implementation)

_arguments -s -S \
  '(-c -concurrency)'{-c+,-concurrency=}'[number of multiple workers to extract]:n:' \
  '(-l -list)'{-l,-list}'[show list of partitions in payload.bin]' \
  '(-o -output)'{-o+,-output=}'[set output directory]:dir:_files -/' \
  '(-p -partitions)'{-p+,-partitions=}'[dump only selected partitions (comma-separated)]:list:' \
  '*:payload.bin or zip:_files -g "*.(bin|zip)"' && return 0
