#compdef eu-nm
# _eu-nm-bin — elfutils nm (Ulrich Drepper, Red Hat); list ELF symbol table contents
# upstream: https://sourceware.org/elfutils

_eu-nm-bin() {
    _arguments \
        '(-a --debug-syms)'{-a,--debug-syms}'[include debug symbols]' \
        '(-A --print-file-name -o)'{-A,--print-file-name,-o}'[print file name]' \
        '(-B --format=bsd)'{-B,--format=bsd}'[BSD format]' \
        '(-C --demangle)'{-C,--demangle}'[demangle]' \
        '(-D --dynamic)'{-D,--dynamic}'[dynamic symbols]' \
        '--defined-only[only defined]' \
        '(-e)-e[ignored]' \
        '(-f --format)'{-f,--format}'+[format]:fmt:(bsd sysv posix)' \
        '(-g --extern-only)'{-g,--extern-only}'[only external]' \
        '(-l --line-numbers)'{-l,--line-numbers}'[print line numbers]' \
        '(-n -v --numeric-sort)'{-n,-v,--numeric-sort}'[sort numeric]' \
        '(-P --portability)'{-P,--portability}'[POSIX]' \
        '(-p --no-sort)'{-p,--no-sort}'[do not sort]' \
        '(-r --reverse-sort)'{-r,--reverse-sort}'[reverse sort]' \
        '(-S --print-size)'{-S,--print-size}'[print size]' \
        '(-s --print-armap)'{-s,--print-armap}'[print archive index]' \
        '--size-sort[sort by size]' \
        '(-t --radix)'{-t,--radix}'+[radix]:base:(d o x)' \
        '(-u --undefined-only)'{-u,--undefined-only}'[only undefined]' \
        '--mark-special[mark special syms]' \
        '--mark-weak[mark weak syms]' \
        '(-W --no-weak)'{-W,--no-weak}'[hide weak]' \
        '(-w --weak)'{-w,--weak}'[show weak]' \
        '--demangle+[demangle style]:style:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-nm-bin "$@"
