#compdef dotenv-vault
# Documentation: https://github.com/dotenv-org/dotenv-vault
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dotenv-vault (Node.js CLI, dotenv-org/dotenv-vault).

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'new:create your project at Dotenv Vault'
  'login:log in to dotenv-vault'
  'logout:log out of dotenv-vault'
  'push:push .env securely'
  'pull:pull .env securely'
  'open:open project page'
  'whoami:display the currently logged-in user'
  'build:build .env.vault file'
  'keys:list .env.vault decryption keys'
  'rotatekey:rotate DOTENV_KEY'
  'decrypt:decrypt .env.vault locally'
  'versions:list version history'
  'help:display help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--yes[automatically answer yes to prompts]' \
  '1: :->subcommand' \
  '*:: :->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotenv-vault subcommand' subcmds && ret=0
    ;;
  (args)
    case $line[1] in
      (push|pull)
        _arguments \
          '1:environment:(development ci staging production)' \
          '2::dotenv file:_files -g "*.env*"' \
          '--dotenvMe=[your DOTENV_ME credential]:credential:' && ret=0
        ;;
      (build|keys|rotatekey|decrypt)
        _arguments \
          '--dotenvMe=[your DOTENV_ME credential]:credential:' && ret=0
        ;;
      (versions)
        _arguments \
          '1::environment:(development ci staging production)' \
          '--dotenvMe=[your DOTENV_ME credential]:credential:' && ret=0
        ;;
    esac
    ;;
esac

return ret
