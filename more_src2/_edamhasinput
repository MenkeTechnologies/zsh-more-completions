#compdef edamhasinput
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/edamhasinput.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS edamhasinput: find EDAM ontology terms by has_input relation
local curcontext="$curcontext" ret=1

_arguments -C \
  '-help[show help message and exit]' \
  '-auto[turn off all prompts and use defaults]' \
  '-stdout[write standard output instead of file]' \
  '-filter[read from stdin, write to stdout]' \
  '-options[prompt for standard qualifiers]' \
  '-debug[write debug output to program.dbg]' \
  '-verbose[report verbose informational messages]' \
  '-warning[report warnings]' \
  '-error[report errors]' \
  '-fatal[report fatal errors]' \
  '-die[report dying program messages]' \
  '-version[report current EMBOSS version number]' \
  '-outfile=[output filename]:file:_files' \
  '-namespace=[restrict to EDAM namespace]:ns:(data entity format identifier operation resource topic)' \
  '-sensitive[match keywords against definitions and synonyms]' \
  '-subclasses[include EDAM sub-class specialisations]' \
  '-obsolete[include obsolete terms]' \
  '-oformat2=[ontology term output format]:format:(obo brief list html xml json excel)' \
  '-odirectory2=[output directory]:dir:_directories' \
  '*:input term query:' && ret=0

return ret
