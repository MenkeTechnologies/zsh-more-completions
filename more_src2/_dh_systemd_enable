#compdef dh_systemd_enable
# _dh_systemd_enable — debhelper to enable systemd units (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_systemd_enable(1) man page.

_dh_systemd_enable() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '--no-enable[disable on purge but do not enable on install]' \
        '--name=[install file as NAME.service]:name:' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-O+[option passed to the helper]:opt:' \
        '*:unit file:_files -g "*.service"'
}

_dh_systemd_enable "$@"
