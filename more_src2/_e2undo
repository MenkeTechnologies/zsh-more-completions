#compdef e2undo
# _e2undo — replay an e2undo undo log onto an ext2/3/4 filesystem (e2fsprogs); reverts last write batch by e2fsprogs tools
# upstream: https://github.com/tytso/e2fsprogs

_e2undo() {
    _arguments \
        '-f[force]' \
        '-h[show help]' \
        '-n[dry run]' \
        '-o+[offset]:n:' \
        '-v[verbose]' \
        '-V[show version]' \
        '-z+[new undo log]:file:_files' \
        '1:undo log:_files' \
        '2:device:_files'
}

_e2undo "$@"
