#compdef kube-bench
# Documentation: https://github.com/aquasecurity/kube-bench/blob/main/cmd/root.go
# Reference accessed: 2026-05-19
# Verified: upstream cmd/root.go persistent flags + cmd/run.go run flag.
# Removed from prior file: fake "master"/"node"/"help" subcommands (only
# run and version exist; master/node are --targets values), invented
# --no-exit-code, -v/--verbosity; corrected --targets to run-only with
# short -s; added real --config, --scored, --unscored, --pgsql,
# --exit-code, --logtostderr; replaced bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a persistent_opts

persistent_opts=(
  '--config=[config file path]:file:_files'
  '(-D --config-dir)'{-D+,--config-dir=}'[config directory]:dir:_directories'
  '--version=[manually specify Kubernetes version]:version:'
  '--benchmark=[manually specify CIS benchmark version]:version:'
  '(-c --check)'{-c+,--check=}'[comma-delimited list of checks to run]:checks:'
  '(-g --group)'{-g+,--group=}'[comma-delimited list of groups to run]:groups:'
  '--skip=[comma-separated list of checks to skip]:checks:'
  '--scored[run scored CIS checks]'
  '--unscored[run unscored CIS checks]'
  '--json[output results as JSON]'
  '--junit[output results as JUnit]'
  '--pgsql[save results to PostgreSQL]'
  '--asff[send results to AWS Security Hub]'
  '--noresults[disable printing of results section]'
  '--nosummary[disable printing of summary section]'
  '--noremediations[disable printing of remediations section]'
  '--nototals[disable printing of totals for failed/passed/etc]'
  '--include-test-output[include actual test output when tests fail]'
  '--outputfile=[write results to file]:file:_files'
  '--exit-code=[exit code to use when failed checks are found]:code:'
  '--logtostderr[log output to stderr]'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[help for kube-bench]' \
  ${persistent_opts[@]} \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands
    commands=(
      'run:run benchmark checks for one or more targets'
      'version:print the version of kube-bench'
    )
    _describe -t commands 'kube-bench command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (run)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[help for run]' \
          '(-s --targets)'{-s+,--targets=}'[targets to run (filenames in cfg/<version>)]:targets:_values -s , target master node etcd controlplane policies managedservices' \
          ${persistent_opts[@]} && ret=0
        ;;
      (*)
        _arguments -s -S '(-h --help)'{-h,--help}'[help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
