#compdef mcporter
# Documentation: https://github.com/steipete/mcporter/blob/main/docs/cli-reference.md
# Reference accessed: 2026-05-22
# Verified: upstream docs/cli-reference.md and src/cli.ts help output.

# Zsh completion for mcporter - Model Context Protocol CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--config[path to mcporter.json]:file:_files' \
  '--root[working directory for stdio servers]:directory:_directories' \
  '--log-level[CLI logging level]:level:(error warn info debug audit)' \
  '--oauth-timeout[OAuth browser wait in ms]:ms:' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'mcporter command' \
      'list[list configured MCP servers]' \
      'call[invoke an MCP tool]' \
      'auth[complete OAuth for a server]' \
      'resource[list or read MCP resources]' \
      'serve[expose daemon servers as one MCP server]' \
      'generate-cli[emit a standalone CLI for a server]' \
      'inspect-cli[show metadata for a generated CLI]' \
      'emit-ts[generate TypeScript client/types]' \
      'config[inspect or edit mcporter config]' \
      'daemon[manage keep-alive daemon]' && ret=0
    ;;
  args)
    case $line[1] in
      list)
        _arguments \
          '--brief[compact single-server output]' \
          '--signatures[alias for --brief]' \
          '--all-parameters[show every schema field]' \
          '--schema[pretty-print JSON schema]' \
          '--status[check server status only]' \
          '--exit-code[exit 1 if any server unhealthy]' \
          '--quiet[suppress output and exit 1 if unhealthy]' \
          '--timeout[per-server timeout in ms]:ms:' \
          '--json[emit JSON summaries]' && ret=0
        ;;
      call)
        _arguments \
          '--server[server name]:server:' \
          '--tool[tool name]:tool:' \
          '--timeout[call timeout in ms]:ms:' \
          '--output[render format]:format:(text markdown json raw)' \
          '--save-images[directory for image blocks]:directory:_directories' \
          '--raw-strings[disable numeric coercion]' \
          '--no-coerce[disable all value coercion]' \
          '--tail-log[stream tail of log handles]' \
          '--' && ret=0
        ;;
      auth)
        _arguments \
          '--reset[clear cached credentials]' \
          '--json[emit JSON envelope on failure]' \
          '--http-url[ad-hoc HTTP MCP URL]:url:' \
          '--allow-http[permit plain HTTP URLs]' \
          '--stdio[ad-hoc stdio MCP command]:command:_default' \
          '--env[env var for stdio (repeatable) KEY=value]:env:' \
          '--cwd[working directory for stdio]:directory:_directories' \
          '--name[display name for ad-hoc server]:name:' \
          '--persist[write ad-hoc definition to config]' \
          '--yes[skip persist confirmation]' && ret=0
        ;;
      resource)
        _arguments \
          '--output[render format]:format:(auto text markdown json raw)' \
          '--json[shortcut for --output json]' \
          '--raw[shortcut for --output raw]' && ret=0
        ;;
      serve)
        _arguments \
          '--stdio[serve MCP over stdio]' \
          '--http[serve Streamable HTTP on /mcp]:port:' \
          '--host[HTTP bind host]:host:' \
          '--servers[comma-separated keep-alive server names]:names:' && ret=0
        ;;
      generate-cli)
        _arguments \
          '--server[configured server name]:server:' \
          '--command[ad-hoc HTTP URL or stdio command]:target:' \
          '--output[write TypeScript template]:file:_files' \
          '--bundle[emit Node/Bun bundle]:file:_files' \
          '--bundler[bundler implementation]:bundler:(rolldown bun)' \
          '--compile[compile with Bun to binary]:file:_files' \
          '--include-tools[only these tools]:tools:' \
          '--exclude-tools[exclude these tools]:tools:' \
          '--timeout[timeout in ms]:ms:' \
          '--runtime[runtime]:runtime:(node bun)' \
          '--from[regenerate from existing CLI artifact]:path:_files' \
          '--dry-run[print resolved command without executing]' && ret=0
        ;;
      inspect-cli)
        _arguments '--json[emit JSON metadata]' && ret=0
        ;;
      emit-ts)
        _arguments \
          '--mode[output mode]:mode:(types client)' \
          '--out[output path]:file:_files' \
          '--include-optional[show every optional field]' \
          '--types-out[override .d.ts path]:file:_files' && ret=0
        ;;
      daemon)
        _values 'daemon action' start status stop restart && ret=0
        ;;
    esac
    ;;
esac

return ret
