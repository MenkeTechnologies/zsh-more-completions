#compdef mdirs
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mdirs.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mdirs: list maildir folders, recursively (courier-mta / maildrop)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-0[separate folders with NUL]' \
  '-a[traverse into all subfolders ignoring maildir++ conventions]' \
  '*:maildir:_files -/' && ret=0

return ret
