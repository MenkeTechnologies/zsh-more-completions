#compdef goobook
# goobook — access Google contacts from the command line

local -a subcommands=(
  'authenticate:authenticate with Google'
  'reload:reload cached contacts'
  'query:search contacts'
  'add:add a contact from an email'
  'config-template:print a configuration template'
  'dump_contacts:dump all contacts'
  'dump_groups:dump all contact groups'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)--version[show version]' \
  '-c[configuration file]:config file:_files' \
  '-v[increase verbosity]' \
  '1:command:->command' \
  '*::arguments:->args'

case $state in
  (command)
    _describe -t commands 'goobook command' subcommands
    ;;
  (args)
    case ${words[1]} in
      query)
        _message 'search query'
        ;;
      add)
        _message 'email message on stdin'
        ;;
    esac
    ;;
esac
