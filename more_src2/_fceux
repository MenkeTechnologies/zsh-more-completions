#compdef fceux fceux-sdl
# Documentation: https://fceux.com/web/help/CommandLineOptions.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-playmovie+[play movie]:file:_files -g "*.fm2"' \
  '-readonly+[movie read-only mode]:b:(0 1)' \
  '-stopframe+[stop movie at frame]:n:' \
  '-loadstate+[autoload savestate at startup]:file:_files' \
  '-stopmovie+[pause after movie playback]:b:(0 1)' \
  '-framedisplay+[toggle frame counter display]:b:(0 1)' \
  '-inputdisplay+[toggle movie input display]:b:(0 1)' \
  '-allowUDLR+[allow simultaneous L+R/U+D inputs]:b:(0 1)' \
  '-bginput+[toggle background input]:b:(0 1)' \
  '-gg+[enable Game Genie]:b:(0 1)' \
  '-pal+[enable PAL region]:b:(0 1)' \
  '-dendy+[enable Dendy region (overrides PAL)]:b:(0 1)' \
  '-noicon+[toggle status icon display]:b:(0 1)' \
  '-clipsides+[clip left/right edges]:b:(0 1)' \
  '-no8lim+[allow more than 8 sprites per scanline]:b:(0 1)' \
  '-nothrottle+[disable throttle when sound is off]:b:(0 1)' \
  '-turbo+[turbo mode]:b:(0 1)' \
  '-cfg+[load custom config file]:file:_files' \
  '-lua+[load lua script on startup]:file:_files -g "*.lua"' \
  '*: :_files -g "*.(nes|fds|unf|zip|gz)"' && ret=0

return ret
