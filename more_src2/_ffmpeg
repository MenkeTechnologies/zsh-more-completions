#compdef ffmpeg
# Documentation: https://manpages.debian.org/ffmpeg.1
# Source: FFmpeg — universal multimedia converter / streaming engine.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-i[input file or URL]:input:_files' \
    '*-f[force file format]:fmt:(mp4 mov mkv webm avi flv mp3 wav flac aac ogg gif image2 mpegts hls dash null pipe rawvideo s16le yuv4mpegpipe concat)' \
    '(-y -n)-y[overwrite output without asking]' \
    '(-y -n)-n[do not overwrite output (exit if exists)]' \
    '*-c[codec for next streams]:codec:' \
    '*-codec[codec for next streams]:codec:' \
    '*-c:v[video codec]:codec:(libx264 libx265 libvpx libvpx-vp9 libsvtav1 mpeg4 hevc_videotoolbox h264_videotoolbox copy)' \
    '*-c:a[audio codec]:codec:(aac libmp3lame libopus libvorbis flac alac pcm_s16le pcm_s24le copy)' \
    '*-c:s[subtitle codec]:codec:(srt webvtt mov_text dvd_subtitle dvb_subtitle ass copy)' \
    '*-map[stream mapping (input:stream)]:map:' \
    '*-filter:v[video filtergraph]:graph:' \
    '*-vf[video filtergraph (alias)]:graph:' \
    '*-filter:a[audio filtergraph]:graph:' \
    '*-af[audio filtergraph (alias)]:graph:' \
    '*-filter_complex[complex filtergraph]:graph:' \
    '*-ss[seek to position (HH:MM:SS or seconds)]:position:' \
    '*-t[duration to read or write]:duration:' \
    '*-to[stop reading/writing at position]:position:' \
    '*-b:v[video bitrate]:rate:' \
    '*-b:a[audio bitrate]:rate:' \
    '*-r[frame rate]:fps:' \
    '*-s[frame size (WxH)]:size:' \
    '*-aspect[display aspect ratio]:ratio:(4:3 16:9 21:9 1:1)' \
    '*-pix_fmt[pixel format]:fmt:(yuv420p yuv420p10le yuv422p yuv444p rgb24 rgba bgr24 gray nv12 nv21)' \
    '*-ar[audio sampling rate (Hz)]:hz:(8000 16000 22050 32000 44100 48000 88200 96000 176400 192000)' \
    '*-ac[audio channels]:n:(1 2 4 5 6 7 8)' \
    '-an[disable audio]' \
    '-vn[disable video]' \
    '-sn[disable subtitles]' \
    '-dn[disable data streams]' \
    '-stats[show progress/statistics]' \
    '-nostats[hide statistics]' \
    '-hide_banner[suppress banner]' \
    '*-loglevel[log level]:level:(quiet panic fatal error warning info verbose debug trace)' \
    '*-v[log level (alias)]:level:(quiet panic fatal error warning info verbose debug trace)' \
    '-threads[number of threads]:n:' \
    '*-hwaccel[hardware acceleration]:type:(auto vaapi vdpau cuda nvdec videotoolbox d3d11va dxva2 qsv)' \
    '*-preset[encoder preset]:preset:(ultrafast superfast veryfast faster fast medium slow slower veryslow placebo)' \
    '*-crf[constant rate factor 0-51 (libx264/x265)]:value:' \
    '*-tune[encoder tuning]:tune:(film animation grain stillimage psnr ssim fastdecode zerolatency)' \
    '-re[read input at native frame rate]' \
    '-progress[write progress info to file]:file:_files' \
    '-copyts[copy timestamps]' \
    '-shortest[finish encoding when shortest input ends]' \
    '-movflags[mp4/mov muxer flags]:flags:(faststart +faststart frag_keyframe empty_moov disable_chpl)' \
    '*:output:_files' \
    && ret=0

return ret
