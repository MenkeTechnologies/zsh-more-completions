#compdef random
# Documentation: man random(6)
# Source: openbsd/src games/random/random.c — random lines from stdin (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-e[exit with random value]' \
    '-r[unbuffer output]' \
    '1::denominator (1/N keep probability):_default' \
    && ret=0

return ret
