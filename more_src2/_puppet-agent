#compdef puppet-agent
# _puppet-agent — Puppet puppet-agent CLI for the Puppet configuration management agent process applying catalogs reporting facts handling certificate signing run-once or daemon mode noop log-level verbose tags (puppetlabs team, Ruby); getopt
# upstream: https://github.com/puppetlabs/puppet

_puppet-agent() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-t[test mode]' \
        '--test[test mode]' \
        '--no-daemonize[no daemonize]' \
        '--daemonize[daemonize]' \
        '-D[no daemonize]' \
        '--detailed-exitcodes[detailed exit codes]' \
        '--onetime[run once]' \
        '-o[run once]' \
        '--no-onetime[no run once]' \
        '--no-noop[no noop]' \
        '--noop[noop]' \
        '-n[noop]' \
        '--noop-mode[noop mode]' \
        '--server=+[host]:h:_hosts' \
        '--ca_server=+[host]:h:_hosts' \
        '--server_list=+[csv]:str:' \
        '--certname=+[name]:str:' \
        '--report=+[b]:b:(true false)' \
        '--no-report[no report]' \
        '--show_diff[show diff]' \
        '--no-show_diff[no show diff]' \
        '--no-splay[no splay]' \
        '--splay[splay]' \
        '--splaylimit=+[d]:str:' \
        '--no-usecacheonfailure[no cache on failure]' \
        '--usecacheonfailure[use cache on failure]' \
        '--logdest=+[dest]:str:' \
        '-l+[dest]:str:' \
        '--logger=+[backend]:b:(file syslog console eventlog stdout)' \
        '--evaltrace[eval trace]' \
        '--summarize[summarize]' \
        '-s[summarize]' \
        '--graph[graph]' \
        '--graphdir=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '--color=+[mode]:m:(auto on off)' \
        '--tags=+[csv]:str:' \
        '--skip_tags=+[csv]:str:' \
        '--ignoreschedules[ignore schedules]' \
        '--no-ignoreschedules[no ignore schedules]' \
        '--no-disable_warnings[no disable warnings]' \
        '--disable_warnings=+[csv]:str:' \
        '--http_debug[http debug]' \
        '--certificate_revocation=+[mode]:m:(true false leaf chain)' \
        '--runinterval=+[d]:str:' \
        '--no-trusted_server_facts[no trusted server facts]' \
        '--fingerprint=+[hex]:str:' \
        '--waitforcert=+[seconds]:n:' \
        '-w+[seconds]:n:' \
        '--waitforlock=+[seconds]:n:'
}

_puppet-agent "$@"
