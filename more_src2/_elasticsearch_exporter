#compdef elasticsearch_exporter
# Documentation: https://github.com/prometheus-community/elasticsearch_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--es.uri=[address of the Elasticsearch node]:uri:' \
  '--es.all[export stats for all nodes in the cluster]' \
  '--es.cluster_settings[export stats for cluster settings]' \
  '--es.indices[export stats for indices in the cluster]' \
  '--es.indices_settings[export stats for index settings]' \
  '--es.indices_mappings[export stats for index mappings]' \
  '--es.aliases[export information for aliases]' \
  '--es.shards[export stats for shards in the cluster]' \
  '--es.snapshots[export stats for snapshots]' \
  '--es.slm[export stats for SLM policies]' \
  '--es.data_stream[export stats for data streams]' \
  '--es.timeout=[timeout for Elasticsearch requests]:duration:' \
  '--es.ca=[path to PEM file with trusted CAs]:file:_files' \
  '--es.client-private-key=[path to PEM file with the client private key]:file:_files' \
  '--es.client-cert=[path to PEM file with the client certificate]:file:_files' \
  '--es.clusterinfo.interval=[cluster info update interval]:duration:' \
  '--es.ssl-skip-verify[skip SSL verification when connecting to Elasticsearch]' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
