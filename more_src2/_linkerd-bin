#compdef linkerd
# _linkerd-bin — Linkerd service mesh CLI (Buoyant + Linkerd team, Go); install/manage Linkerd control plane + meshes
# upstream: https://github.com/linkerd/linkerd2

_linkerd-bin() {
    local -a sub=(
        'authz:list authorization policies'
        'check:run cluster + Linkerd checks'
        'completion:print shell completion'
        'diagnostics:diagnose Linkerd installation'
        'edges:show edges between meshed workloads'
        'help:show help'
        'identity:print identity status of workload'
        'inject:inject Linkerd proxy into manifests'
        'install:install Linkerd control plane'
        'install-cni:install Linkerd CNI plugin'
        'jaeger:Jaeger extension subcommand'
        'multicluster:multicluster extension subcommand'
        'profile:generate a service profile'
        'prune:prune unused Linkerd resources'
        'repair:repair cluster Linkerd state'
        'top:display top traffic for resources'
        'tap:tap live traffic'
        'uninject:uninject Linkerd proxy'
        'uninstall:uninstall Linkerd'
        'upgrade:upgrade Linkerd'
        'version:show version'
        'viz:Viz extension subcommand'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--as+[impersonate user]:user:' \
        '--as-group+[impersonate group]:group:' \
        '--cni-namespace+[CNI namespace]:ns:' \
        '--context+[kube context]:context:' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '-L+[Linkerd namespace]:ns:' \
        '--linkerd-namespace+[Linkerd namespace]:ns:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'linkerd subcommand' sub ;;
        args)
            case $words[1] in
                check) _arguments \
                    '--cli-version-override+[CLI version override]:str:' \
                    '-n+[namespace]:ns:' \
                    '--namespace+[namespace]:ns:' \
                    '--pre[run pre-install checks]' \
                    '--proxy[run only proxy checks]' \
                    '--linkerd-cni-enabled[run CNI checks]' \
                    '--expected-version+[expected version]:str:' \
                    '-o+[output format]:fmt:(short table json)' \
                    '--output+[output format]:fmt:' \
                    '--wait+[wait duration]:duration:' ;;
                inject|uninject) _arguments \
                    '--manual[do not auto-inject]' \
                    '--enable-debug-sidecar[enable debug sidecar]' \
                    '--ignore-inbound-ports+[ignore inbound]:ports:' \
                    '--ignore-outbound-ports+[ignore outbound]:ports:' \
                    '-o+[output format]:fmt:(yaml json)' \
                    '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_linkerd-bin "$@"
