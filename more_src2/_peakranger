#compdef peakranger PeakRanger
# _peakranger — Xin Feng Robert Grossman PeakRanger multi-purpose ChIP-seq peak caller with broad histone narrow factor modes (xfeng team, C++); custom argparse
# upstream: https://github.com/xfeng-ccgi/PeakRanger

_peakranger() {
    local -a sub=(
        'ranger:default narrow peak caller'
        'ccat:Cancer Cell Atlas wide peak caller'
        'bcp:broad peak caller'
        'lc:library complexity'
        'wrapper:run multiple callers'
        'nr:non-redundant reads'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'peakranger subcommand' sub ;;
        args)
            case $words[1] in
                ranger|ccat|bcp) _arguments \
                    '-d+[input file]:file:_files -g "*.bam *.sam *.bed"' \
                    '--data=+[input file]:file:_files -g "*.bam *.sam *.bed"' \
                    '-c+[control file]:file:_files -g "*.bam *.sam *.bed"' \
                    '--control=+[control file]:file:_files -g "*.bam *.sam *.bed"' \
                    '-o+[output prefix]:str:' \
                    '--output=+[output prefix]:str:' \
                    '-l+[extension length]:n:' \
                    '--ext_length=+[extension length]:n:' \
                    '-r+[read length]:n:' \
                    '--read_length=+[read length]:n:' \
                    '-q+[p-value cutoff]:f:' \
                    '--pval=+[p-value cutoff]:f:' \
                    '-Q+[fdr cutoff]:f:' \
                    '--fdr=+[fdr cutoff]:f:' \
                    '-b+[delta]:n:' \
                    '--delta=+[delta]:n:' \
                    '-t+[threads]:n:' \
                    '--threads=+[threads]:n:' \
                    '--format=+[format]:f:(bam bed sam bowtie eland)' \
                    '--win_size=+[N]:n:' \
                    '--gene_annot_file=+[file]:file:_files -g "*.gtf *.gff *.bed"' \
                    '--report[generate report]' \
                    '-s+[sensitivity]:s:(high medium low)' \
                    '--sensitivity=+[sensitivity]:s:(high medium low)' \
                    '-p[paired]' \
                    '--paired[paired]' \
                    '--gsize=+[genome size]:str:' \
                    '--mode=+[mode]:m:(broad narrow)' ;;
                lc|nr) _arguments \
                    '-d+[input file]:file:_files' \
                    '-o+[output prefix]:str:' \
                    '--format=+[format]:f:(bam bed sam)' ;;
                wrapper) _arguments \
                    '*:command args:' ;;
            esac
            ;;
    esac
}

_peakranger "$@"
