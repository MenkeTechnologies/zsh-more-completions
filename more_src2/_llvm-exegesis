#compdef llvm-exegesis
# _llvm-exegesis — LLVM machine instruction benchmark (LLVM project, C++); measure latency/uops for instructions
# upstream: https://github.com/llvm/llvm-project

_llvm-exegesis() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-mode=+[measurement mode]:mode:(latency uops inverse_throughput analysis)' \
        '-mtriple=+[triple]:triple:' \
        '-mcpu=+[cpu]:cpu:' \
        '-mattr=+[mattr]:str:' \
        '-num-repetitions=+[num repetitions]:n:' \
        '-snippets-file=+[snippets file]:file:_files' \
        '-opcode-index=+[opcode index]:n:' \
        '-opcode-name=+[opcode name]:str:' \
        '-output-file=+[output file]:file:_files' \
        '-benchmarks-file=+[benchmarks file]:file:_files' \
        '-analysis-clusters-output-file=+[analysis clusters output]:file:_files' \
        '-analysis-inconsistencies-output-file=+[analysis inconsistencies output]:file:_files' \
        '-analysis-numpoints=+[analysis num points]:n:' \
        '-analysis-clustering-epsilon=+[clustering epsilon]:f:' \
        '-dump-object-to-disk[dump object to disk]' \
        '-ignore-invalid-sched-class[ignore invalid sched class]' \
        '-repetition-mode=+[repetition mode]:mode:(Duplicate Loop AggregateMin)' \
        '-snippet-execution-mode=+[execution mode]:mode:(InProcess SubProcess)' \
        '-validation-counters=+[validation counters]:str:' \
        '-benchmark-phase=+[benchmark phase]:phase:' \
        '-skip-measurements[skip measurements]' \
        '*::args:'
}

_llvm-exegesis "$@"
