#compdef dtplite
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/dtplite.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '-o[Output directory or file]:output:_files'
    '-ext[File extension]:extension:'
    '-style[CSS stylesheet]:stylesheet:_files -g "*.css"'
    '-header[Header file]:header:_files'
    '-footer[Footer file]:footer:_files'
    '-nav[Navigation label and URL]:label and url:'
    '-merge[Merge output into single file]'
    '1:format:(html nroff tmml latex text wiki dtp)'
    '*:input files:_files'
)

_arguments -s -S $arguments
