#compdef go-enum
# Documentation: https://github.com/abice/go-enum
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# go-enum: enum generator for Go (abice/go-enum).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-v --version)'{-v,--version}'[Show version]' \
  '(-f --file)'{-f,--file}'=[Input Go file]:file:_files -g "*.go(-.)"' \
  '--noprefix[do not prefix constants with type name]' \
  '--prefix=[Enum name prefix]:prefix:' \
  '--names[Generate Names() []string function]' \
  '--nocase[Case-insensitive lookup]' \
  '--nocamel[disable snake_case to CamelCase conversion]' \
  '--forcelower[force lowercase names]' \
  '--forceupper[force uppercase names]' \
  '--marshal[Generate text/JSON marshal helpers]' \
  '--sql[Generate SQL scan/value helpers]' \
  '--sqlnullint[add nullable int SQL support]' \
  '--sqlnullstr[add nullable string SQL support]' \
  '--ptr[Return pointers from MustParse]' \
  '--lower[add lowercase variants for lookup]' \
  '--output-suffix=[output filename suffix]:suffix:' \
  '--no-iota[disable iota usage]' \
  '(-b --buildtag)'{-b,--buildtag}'=[build tag]:tag:' \
  '*:go files:_files -g "*.go(-.)"'
