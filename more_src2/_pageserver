#compdef pageserver
# _pageserver — Neon serverless Postgres pageserver (materializes WAL into versioned pages + serves them to the compute Postgres process)
# upstream: https://github.com/neondatabase/neon
# Flags from pageserver/src/bin/pageserver.rs on tip (clap-builder); rest of config lives in <workdir>/pageserver.toml + identity.toml.

_pageserver() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-D --workdir)'{-D+,--workdir=}'[working directory containing pageserver.toml + identity.toml]:dir:_files -/' \
        '--enabled-features[show enabled compile-time features and exit]'
}

_pageserver "$@"
