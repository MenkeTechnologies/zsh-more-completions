#compdef distrobox
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/usage.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Distrobox - use any Linux distro in terminal via containers.
# Subcommand list from the project README and docs/usage/*.md files.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'assemble:Create and configure containers from a manifest file'
  'create:Create a new distrobox container'
  'enter:Enter a distrobox container'
  'ephemeral:Create a temporary container that is removed on exit'
  'export:Export apps, binaries, or services from the container'
  'generate-entry:Generate a desktop entry for a container'
  'list:List existing distrobox containers'
  'rm:Remove a distrobox container'
  'stop:Stop a running distrobox container'
  'upgrade:Upgrade one or more distrobox containers'
  'help:Show help'
)

_distrobox_containers() {
  local -a containers
  containers=(${(f)"$(distrobox list --no-color 2>/dev/null | tail -n +2 | awk '{print $3}')"})
  compadd -a containers
}

_distrobox_images() {
  local -a images
  images=(${(f)"$(podman images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null || docker images --format '{{.Repository}}:{{.Tag}}' 2>/dev/null)"})
  compadd -a images
}

_arguments -s -S -C \
  '--help[Show help]' \
  '--version[Show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'distrobox command' commands && ret=0
    ;;
  args)
    case $words[1] in
      assemble)
        _arguments -s -S \
          '1:subcommand:(create rm)' \
          '--file[Manifest file path]:manifest file:_files' \
          '(-n --name)'{-n,--name}'[Run against a single entry]:entry name' \
          '(-R --replace)'{-R,--replace}'[Replace existing distroboxes]' \
          '(-d --dry-run)'{-d,--dry-run}'[Only print container manager command]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '--help[Show help]' && ret=0
        ;;
      create)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:name' \
          '(-i --image)'{-i,--image}'[Image to use]:image:_distrobox_images' \
          '--hostname[Hostname for the container]:hostname' \
          '(-c --clone)'{-c,--clone}'[Clone an existing container]:container:_distrobox_containers' \
          '(-H --home)'{-H,--home}'[Custom home directory]:directory:_files -/' \
          '--volume[Additional volume to mount]:volume' \
          '(-a --additional-flags)'{-a,--additional-flags}'[Extra container manager flags]:flags' \
          '(-ap --additional-packages)'{-ap,--additional-packages}'[Additional packages to install]:packages' \
          '--init-hooks[Commands during initialization]:hooks' \
          '--pre-init-hooks[Commands before initialization]:hooks' \
          '(-I --init)'{-I,--init}'[Use container init system]' \
          '--nvidia[Enable NVIDIA GPU integration]' \
          '--platform[Platform architecture]:platform' \
          '(-r --root)'{-r,--root}'[Launch container as root]' \
          '(-p --pull)'{-p,--pull}'[Pull image even if local]' \
          '(-Y --yes)'{-Y,--yes}'[Non-interactive mode]' \
          '--unshare-all[Unshare all namespaces]' \
          '--unshare-devsys[Do not share host /dev and /sys]' \
          '--unshare-groups[Do not share host user groups]' \
          '--unshare-ipc[Do not share host IPC namespace]' \
          '--unshare-netns[Do not share host network namespace]' \
          '--unshare-process[Do not share host PID namespace]' \
          '(-C --compatibility)'{-C,--compatibility}'[List compatible images]' \
          '--no-entry[Do not generate menu entry]' \
          '(-d --dry-run)'{-d,--dry-run}'[Only print container manager command]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-h --help)'{-h,--help}'[Show help]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '--absolutely-disable-root-password-i-am-really-positively-sure[Remove root password]' && ret=0
        ;;
      enter)
        _arguments -s -S \
          '(-n --name)'{-n,--name}'[Container name]:container:_distrobox_containers' \
          '--no-workdir[Do not change to host working directory]' \
          '--additional-flags[Additional container manager flags]:flags' \
          '(-e --exec)'{-e,--exec}'[Command to execute]:command:_command_names' \
          '--dry-run[Only print container manager command]' \
          '--help[Show help]' \
          ':container:_distrobox_containers' \
          '*:command' && ret=0
        ;;
      ephemeral)
        _arguments -s -S \
          '(-i --image)'{-i,--image}'[Image to use]:image:_distrobox_images' \
          '(-n --name)'{-n,--name}'[Container name]:name' \
          '(-r --root)'{-r,--root}'[Launch container as root]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' \
          '*:command' && ret=0
        ;;
      export)
        _arguments -s -S \
          '(-a --app)'{-a,--app}'[Export an application]:application' \
          '(-b --bin)'{-b,--bin}'[Export a binary]:binary:_files' \
          '(-d --delete)'{-d,--delete}'[Delete an exported entry]' \
          '(-el --export-label)'{-el,--export-label}'[Label for exported app]:label' \
          '(-ep --export-path)'{-ep,--export-path}'[Export path for binaries]:path:_files -/' \
          '(-ef --extra-flags)'{-ef,--extra-flags}'[Extra flags for exported app]:flags' \
          '(-nf --enter-flags)'{-nf,--enter-flags}'[distrobox-enter flags]:flags' \
          '(-S --sudo)'{-S,--sudo}'[Export with sudo prefix]' \
          '--list-apps[List exported applications]' \
          '--list-binaries[List exported binaries]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' && ret=0
        ;;
      generate-entry)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[Perform for all distroboxes]' \
          '(-d --delete)'{-d,--delete}'[Delete the generated entry]' \
          '(-i --icon)'{-i,--icon}'[Custom icon path]:icon file:_files' \
          '(-r --root)'{-r,--root}'[Perform on rootful distroboxes]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
      list|ls)
        _arguments -s -S \
          '--no-color[Disable color output]' \
          '(-r --root)'{-r,--root}'[Run podman/docker as root]' \
          '(-v --verbose)'{-v,--verbose}'[Show more information]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' && ret=0
        ;;
      rm)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[Remove all containers]' \
          '(-f --force)'{-f,--force}'[Force removal]' \
          '--rm-home[Remove mounted home if different from host home]' \
          '(-r --root)'{-r,--root}'[Run podman/docker as root]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
      stop)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[Stop all containers]' \
          '(-Y --yes)'{-Y,--yes}'[Non-interactive mode]' \
          '(-r --root)'{-r,--root}'[Run podman/docker as root]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
      upgrade)
        _arguments -s -S \
          '(-a --all)'{-a,--all}'[Upgrade all containers]' \
          '--running[Upgrade only running containers]' \
          '(-r --root)'{-r,--root}'[Run podman/docker as root]' \
          '(-v --verbose)'{-v,--verbose}'[Show more verbosity]' \
          '(-V --version)'{-V,--version}'[Show version]' \
          '(-h --help)'{-h,--help}'[Show help]' \
          '*:container:_distrobox_containers' && ret=0
        ;;
    esac
    ;;
esac

return ret
