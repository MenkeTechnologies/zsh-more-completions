#compdef dot2tex
# Documentation: https://dot2tex.readthedocs.io/en/latest/usage_guide.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --format)'{-f,--format}'+[output format]:fmt:(pgf pst tikz)' \
  '(-t --texmode)'{-t,--texmode}'+[TeX mode]:mode:(math verbatim raw)' \
  '(-d --duplicate)'{-d,--duplicate}'[duplicate label as caption]' \
  '(-s --straightedges)'{-s,--straightedges}'[straight edges]' \
  '(-T --usepdflatex)'{-T,--usepdflatex}'[use pdflatex]' \
  '(-p --preproc)'{-p,--preproc}'[preprocess only]' \
  '(-n --nominsize)'{-n,--nominsize}'[ignore min size]' \
  '(-w --switchdraworder)'{-w,--switchdraworder}'[switch draw order]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-e --encoding)'{-e,--encoding}'+[encoding]:enc:' \
  '(-V --debug)'{-V,--debug}'[verbose debug]' \
  '--graphstyle=[graph style]:style:' \
  '--nodeoptions=[node options]:opts:' \
  '--edgeoptions=[edge options]:opts:' \
  '--prog=[Graphviz program]:prog:(dot neato circo twopi fdp sfdp)' \
  '--figonly[output only the figure]' \
  '--codeonly[output only code]' \
  '--margin=[margin]:val:' \
  '--crop[crop]' \
  '--autosize[auto size]' \
  '--cache[use cache]' \
  '*:file:_files -g "*.{dot,gv}"' && ret=0

return ret
