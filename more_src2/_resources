#compdef resources
# _resources — GNOME Resources system monitor (resources binary that shows CPU/memory/GPU/disks/network/swap/processes; --reset reset settings, --version print version; otherwise opens the Resources GTK4 UI)
# upstream: https://github.com/nokyan/resources
# Flags from resources main.rs on tip.

_resources() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--reset[reset settings]'
}

_resources "$@"
