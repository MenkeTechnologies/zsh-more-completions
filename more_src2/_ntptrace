#compdef ntptrace
# _ntptrace — ntp-project ntptrace (Perl helper that walks the NTP synchronization chain from a starting server back to a stratum-1 source, hop by hop)
# upstream: https://github.com/ntp-project/ntp
# Flags from scripts/ntptrace/ntptrace-opts.def on tip (AutoOpts).

_ntptrace() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-n --numeric)'{-n,--numeric}'[show numeric host addresses]' \
        '(-m --max)'{-m+,--max=}'[maximum number of levels to trace]:n:' \
        '(-r --host)'{-r+,--host=}'[starting host (default: localhost)]:host:_hosts' \
        '*:host:_hosts'
}

_ntptrace "$@"
