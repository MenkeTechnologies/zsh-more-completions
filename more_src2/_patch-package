#compdef patch-package
# Documentation: https://github.com/ds300/patch-package
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--patch-dir=[directory for patch files]:directory:_directories' \
  '--error-on-fail[exit with error if patch fails]' \
  '--error-on-warn[exit with error on warnings]' \
  '--reverse[un-apply all patches]' \
  '--create-issue[open browser with a draft GitHub issue]' \
  '--use-yarn[force yarn usage instead of npm]' \
  '--exclude=[ignore paths matching the regexp]:pattern:' \
  '--include=[only consider matching paths]:pattern:' \
  '--case-sensitive-path-filtering[make include/exclude filters case-sensitive]' \
  '--append=[create additional patches for the same package]:name:' \
  '--rebase=[un-apply successive patches for updating sequenced patches]:path:' \
  '--partial[apply as many changes as possible]' \
  '*:package name:' && ret=0

return ret
