#compdef mode2
# Documentation: https://manpages.debian.org/bookworm/lirc/mode2.1.en.html
# Reference accessed: 2026-05-19
# Verified: Debian bookworm mode2(1) manpage OPTIONS section.

# mode2: dump LIRC pulse/space data from device
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --device)'{-d,--device=}'[device to read from]:device:_files' \
  '(-H --driver)'{-H,--driver=}'[driver to use]:driver:' \
  '(-m --mode)'{-m,--mode}'[write pulse/space as raw config]' \
  '(-s --scope)'{-s,--scope=}'[scope-like display with time us/char]:time:' \
  '(-k --keep-root)'{-k,--keep-root}'[do not drop root privileges]' \
  '(-l --list-devices)'{-l,--list-devices}'[list devices for driver]' \
  '(-g --gap)'{-g,--gap=}'[gap threshold (microseconds)]:time:' \
  '(-r --raw)'{-r,--raw}'[access device directly]' \
  '(-A --driver-options)'{-A,--driver-options=}'[driver options]:key\:value:' \
  '(-U --plugindir)'{-U,--plugindir=}'[plugin directory]:dir:_files -/' \
  '(-O --options-file)'{-O,--options-file=}'[default options file]:file:_files' \
  '(-D --loglevel)'{-D,--loglevel=}'[log level]:level:(error warning info notice debug trace trace1 trace2)' && ret=0
return ret
