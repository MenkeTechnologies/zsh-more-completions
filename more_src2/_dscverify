#compdef dscverify
# Documentation: https://manpages.debian.org/dscverify
# Source: debian/devscripts scripts/dscverify.pl — verify GPG signatures on Debian .dsc/.changes/.buildinfo files (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(-u --no-sig-check --nosigcheck)--sig-check[verify signatures (default)]' \
    '(-u --sig-check --sigcheck)--no-sig-check[do not verify signatures]' \
    '-u[do not verify signatures (alias)]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '(--no-default-keyrings)--default-keyrings[use default keyrings (default)]' \
    '--no-default-keyrings[do not use default keyrings]' \
    '*--keyring=-[add keyring file]:file:_files -g "*.{gpg,asc}"' \
    '--verbose[verbose output]' \
    '*:dsc/changes/buildinfo file:_files -g "*.{dsc,changes,buildinfo}"' \
    && ret=0

return ret
