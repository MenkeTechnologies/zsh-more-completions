#compdef digital-ocean
# _digital-ocean — DigitalOcean CLI dispatcher (community wrapper around doctl); convenience alias for DigitalOcean CLI
# upstream: https://github.com/digitalocean/doctl

_digital-ocean() {
    local -a sub=(
        'auth:authenticate'
        'apps:platform apps'
        'compute:compute resources'
        'databases:managed databases'
        'kubernetes:k8s clusters'
        'projects:projects'
        'registry:container registry'
        'tags:tag management'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-t+[API token]:str:' \
        '--access-token+[API token]:str:' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '--context+[auth context]:str:' \
        '-o+[output format]:fmt:(json text)' \
        '--output+[output format]:fmt:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'digital-ocean subcommand' sub ;;
    esac
}

_digital-ocean "$@"
