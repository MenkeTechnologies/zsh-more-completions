#compdef growthbook
# Documentation: https://docs.growthbook.io/tools/cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authentication management (login/logout)'
  'datasources:data source operations'
  'dimensions:dimension management'
  'experiments:experiment operations'
  'features:feature flag management'
  'metrics:metric operations'
  'projects:project management'
  'savedgroups:saved group operations'
  'sdkconnections:SDK connection management'
  'segments:segment operations'
  'vcs:visual changeset operations'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-p --profile)'{-p+,--profile=}'[profile name]:profile:' \
  '(-u --apiBaseUrl)'{-u+,--apiBaseUrl=}'[API base URL]:url:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'growthbook command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments \
          '*::sub:(login logout)' \
          '--apiKey=[GrowthBook API key]:key:' && ret=0 ;;
      (features)
        local -a feat_subs=(
          'get:get a feature'
          'list:list features'
          'toggle:toggle a feature on/off'
          'generate-types:generate TypeScript types'
        )
        _describe -t fcmds 'features subcommand' feat_subs && ret=0
        _arguments \
          '--limit=[result limit]:n:' \
          '--offset=[result offset]:n:' \
          '--project=[filter by project]:project:' \
          '--projectId=[filter by project id]:id:' && ret=0 ;;
      (experiments)
        local -a exp_subs=(
          'get:get an experiment'
          'list:list experiments'
          'results:get experiment results'
        )
        _describe -t ecmds 'experiments subcommand' exp_subs && ret=0
        _arguments \
          '--limit=[result limit]:n:' \
          '--offset=[result offset]:n:' \
          '--project=[filter by project]:project:' \
          '--datasource=[filter by datasource]:datasource:' \
          '--experiment=[filter by experiment id]:id:' \
          '--dimension=[filter by dimension]:dimension:' \
          '--phase=[filter by phase]:phase:' && ret=0 ;;
      (datasources)
        _arguments \
          '*::sub:(get list)' \
          '--limit=[result limit]:n:' \
          '--offset=[result offset]:n:' \
          '--project=[filter by project]:project:' && ret=0 ;;
      (dimensions)
        _arguments \
          '*::sub:(get list)' \
          '--dataSourceId=[filter by data source id]:id:' && ret=0 ;;
      (metrics)
        _arguments '*::sub:(get list create)' && ret=0 ;;
      (projects)
        _arguments '*::sub:(get list)' && ret=0 ;;
      (savedgroups)
        _arguments '*::sub:(get list create update delete)' && ret=0 ;;
      (sdkconnections)
        _arguments \
          '*::sub:(get list)' \
          '--projectId=[filter by project id]:id:' \
          '--limit=[result limit]:n:' \
          '--offset=[result offset]:n:' && ret=0 ;;
      (segments|vcs)
        _arguments '*::sub:(get list)' && ret=0 ;;
    esac ;;
esac

return ret
