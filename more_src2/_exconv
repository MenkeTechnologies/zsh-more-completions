#compdef exconv
# Documentation: https://github.com/sindrel/excalidraw-converter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exconv is the binary name for sindrel/excalidraw-converter.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
cmd)
  local expl
  _wanted commands expl 'exconv command' compadd -- gliffy mermaid version
  ;;
args)
  case $line[1] in
    gliffy)
      _arguments -s \
        '(-i)'{-i+,--input=}'[.excalidraw file]:file:_files' \
        '(-o)'{-o+,--output=}'[.gliffy file]:file:_files' && ret=0
      ;;
    mermaid)
      _arguments -s \
        '(-d)'{-d+,--direction=}'[flow direction]:direction:(default top-down left-right right-left bottom-top)' \
        '(-i)'{-i+,--input=}'[.excalidraw file]:file:_files' \
        '(-o)'{-o+,--output=}'[.mermaid file]:file:_files' \
        '(-p)'{-p,--print-to-stdout}'[print to stdout]' && ret=0
      ;;
    version)
      _arguments -s '--no-check[disable GitHub latest-version check]' && ret=0
      ;;
    *)
      _default && ret=0
      ;;
  esac
  ;;
esac

return ret
