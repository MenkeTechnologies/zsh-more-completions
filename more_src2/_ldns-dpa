#compdef ldns-dpa
# _ldns-dpa — NLnet Labs ldns-dpa (DNS packet analyzer; reads a pcap file and counts/filters/dumps packets that match expressive match expressions)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-dpa.c usage on tip.

_ldns-dpa() {
    _arguments \
        '-h[show help]' \
        '-c+[count occurrences matching exprlist]:exprlist:' \
        '-f+[filter expression]:expr:' \
        '-p[show percentage of -u/-c against the filter set]' \
        '-of+[write packets matching -f to pcap file]:file:_files' \
        '-ofh+[write packets matching -f to file as drill-format hex]:file:_files' \
        '-s+[show possible match operators for matchname (or list names with no arg)]:matchname:' \
        '-sf[print packets that match -f (or all DNS packets if no -f)]' \
        '-u+[count all occurrences for matchnamelist]:matchnamelist:' \
        '-ua[show average value of each -u matchname]' \
        '-uac[show average count of each -u matchname]' \
        '-um+[only show -u results occurring more than N times]:n:' \
        '-v+[verbosity level]:n:' \
        '-notip+[dump non-IP packets to file]:file:_files' \
        '1:pcap-file:_files'
}

_ldns-dpa "$@"
