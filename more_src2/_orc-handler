#compdef orc-handler
# _orc-handler — Percona Server for MySQL operator Orchestrator handler (manages topology failover state)
# upstream: https://github.com/percona/percona-server-mysql-operator
# Flags from cmd/orc-handler/main.go on tip + controller-runtime zap.Options.

_orc-handler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-primary=[primary hostname]:host:_hosts' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)'
}

_orc-handler "$@"
