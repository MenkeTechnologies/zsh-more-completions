#compdef pnmtopng
# Documentation: man pnmtopng (Netpbm)
# Source: convert a Netpbm image to PNG, with full PNG chunk support.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-downscale[downscale maxval to fit PNG]' \
    '-interlace[write interlaced PNG]' \
    '-alpha=[external alpha-channel PGM file]:file:_files -g "*.(pgm|pnm|pam)"' \
    '-transparent=[transparent color]:color:' \
    '-background=[background color (bKGD chunk)]:color:' \
    '-palette=[palette file]:file:_files -g "*.(ppm|pnm|pam)"' \
    '-gamma=[output gamma]:value:' \
    '-hist[write hIST chunk]' \
    '-text=[file with tEXt chunks]:file:_files' \
    '-ztxt=[file with zTXt (compressed) chunks]:file:_files' \
    '-rgb=[primary chromaticities (wx wy rx ry gx gy bx by)]:rgb:' \
    '-size=[physical size (x y unit)]:size:' \
    '-srgbintent=[sRGB rendering intent]:intent:(perceptual relative-colorimetric saturation absolute-colorimetric)' \
    '-modtime=[modification time yyyy-mm-dd hh\:mm\:ss]:time:' \
    '(-nofilter -sub -up -avg -paeth)-nofilter[no filtering]' \
    '(-nofilter -sub -up -avg -paeth)-sub[sub filter]' \
    '(-nofilter -sub -up -avg -paeth)-up[up filter]' \
    '(-nofilter -sub -up -avg -paeth)-avg[average filter]' \
    '(-nofilter -sub -up -avg -paeth)-paeth[Paeth filter]' \
    '-compression=[zlib compression level 0..9]:n:' \
    '-comp_mem_level=[zlib memory level 1..9]:n:' \
    '-comp_strategy=[zlib strategy]:strategy:(huffman_only filtered)' \
    '-comp_method=[zlib method]:method:(deflated)' \
    '-comp_window_bits=[zlib window bits]:n:' \
    '-comp_buffer_size=[zlib output buffer size]:n:' \
    '-force[force overwrite]' \
    '-libversion[print libpng/zlib versions and exit]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
