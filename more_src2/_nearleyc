_nearleyc() {
    case "$service" in
        nearleyc)         _nearleyc_compile  ;;
        nearley-test)     _nearleyc_test     ;;
        nearley-unparse)  _nearleyc_unparse  ;;
        nearley-railroad) _nearleyc_railroad ;;
    esac
}

# `nearleyc <file.ne>` — compile a grammar to a JS parser
_nearleyc_compile() {
    _arguments -s -S \
        '(-o --out)'{-o,--out=}'[file to output to (default stdout)]:output file:_files -g "*.(js|mjs|cjs)"' \
        '(-e --export)'{-e,--export=}'[variable to set parser to (default "grammar")]:export name:' \
        '(-q --quiet)'{-q,--quiet}'[suppress linter]' \
        '--nojs[do not compile postprocessors]' \
        '(- *)'{-v,--version}'[print version]' \
        '(- *)-h[print help]' \
        '1:grammar file (.ne, or stdin if omitted):_files -g "*.ne"'
}

# `nearley-test <file.js> [--input ...]` — run a compiled parser
_nearleyc_test() {
    _arguments -s -S \
        '(-i --input)'{-i,--input=}'[input string to parse (else read from stdin)]:input string:' \
        '(-s --start)'{-s,--start=}'[start symbol (else use parser default)]:symbol:' \
        '(-o --out)'{-o,--out=}'[output file (default stdout)]:output file:_files' \
        '(-q --quiet)'{-q,--quiet}'[output parse results only (hide Earley table)]' \
        '(- *)'{-v,--version}'[print version]' \
        '(- *)-h[print help]' \
        '1:compiled grammar JS file:_files -g "*.(js|mjs|cjs)"'
}

# `nearley-unparse <file.js>` — generate samples from a grammar (fuzzer)
_nearleyc_unparse() {
    _arguments -s -S \
        '(-s --start)'{-s,--start=}'[optional start symbol (else use parser default)]:start symbol:' \
        '(-n --count)'{-n,--count=}'[number of samples to generate (newline-separated, default 1)]:count:' \
        '(-d --depth)'{-d,--depth=}'[depth bound of each sample (default -1 = unbounded)]:depth:' \
        '(-o --out)'{-o,--out=}'[output file (default stdout)]:output file:_files' \
        '(- *)'{-v,--version}'[print version]' \
        '(- *)-h[print help]' \
        '1:compiled grammar JS file:_files -g "*.(js|mjs|cjs)"'
}

# `nearley-railroad <file.ne>` — render an SVG railroad diagram
_nearleyc_railroad() {
    _arguments -s -S \
        '(-o --out)'{-o,--out=}'[file to output to (default stdout) - typically *.svg]:svg file:_files -g "*.svg"' \
        '(- *)'{-v,--version}'[print version]' \
        '(- *)-h[print help]' \
        '1:grammar file (.ne, or stdin if omitted):_files -g "*.ne"'
}

_nearleyc "$@"
