#compdef kubectl-modify-secret
# Documentation: https://github.com/rajatjindal/kubectl-modify-secret
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-modify-secret (rajatjindal/kubectl-modify-secret). No subcommands;
# usage: kubectl modify-secret <secret-name> [-n namespace].

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '1:secret name: _default'
