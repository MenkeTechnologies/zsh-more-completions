#compdef docker-machine-driver-hyperkit
# _docker-machine-driver-hyperkit — Docker Machine HyperKit driver (out-of-tree plugin enabling docker-machine on macOS with HyperKit; plugin binary only; --version prints driver version, --debug logs to stderr, --hyperkit-version prints expected hyperkit binary version, --driver-version prints driver version)
# upstream: https://github.com/machine-drivers/docker-machine-driver-hyperkit
# Flags from machine-drivers/docker-machine-driver-hyperkit main.go on tip.

_docker-machine-driver-hyperkit() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--driver-version[print driver version]' \
        '--hyperkit-version[print expected hyperkit version]' \
        '--debug[debug to stderr]'
}

_docker-machine-driver-hyperkit "$@"
