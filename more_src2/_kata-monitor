#compdef kata-monitor
# Documentation: https://github.com/kata-containers/kata-containers/blob/main/src/runtime/cmd/kata-monitor/main.go
# Reference accessed: 2026-05-19
# Verified: upstream kata-monitor main.go flag definitions.

# kata-monitor: Kata Containers monitor (sandbox metrics)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[show version]' \
  '--listen-address=[address to listen on for HTTP requests]:addr:' \
  '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
  '--runtime-endpoint=[endpoint of CRI container runtime service]:endpoint:_files' \
  '*::kata-monitor args:_files' && ret=0
return ret
