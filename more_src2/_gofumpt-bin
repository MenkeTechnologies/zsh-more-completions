#compdef gofumpt
# _gofumpt-bin — gofumpt stricter Go formatter (Daniel Martí, Go); superset of gofmt with extra style rules
# upstream: https://github.com/mvdan/gofumpt

_gofumpt-bin() {
    _arguments \
        '-d[display diffs]' \
        '-e[show all errors]' \
        '-l[list non-formatted files]' \
        '-w[write to file]' \
        '-extra[enable extra optional rules]' \
        '-lang+[Go language version]:ver:' \
        '-modpath+[module path]:path:' \
        '-version[show version]' \
        '*:file or dir:_files'
}

_gofumpt-bin "$@"
