#compdef pbs_server pbs_mom pbs_sched pbs
# _pbs — PBS Professional / OpenPBS daemons (pbs_server queue + history daemon, pbs_mom per-node mother-superior daemon, pbs_sched primary scheduler; -A alternate $PBS_HOME, -d alternate config dir, -f foreground, -p override port, -L log file; user-facing CLI is qsub/qstat/qdel)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/server + src/mom + src/scheduler on tip.

_pbs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[config dir]:dir:_files -/' \
        '-A+[PBS_HOME]:dir:_files -/' \
        '-f[foreground]' \
        '-p+[port]:port:' \
        '-L+[log file]:file:_files'
}

_pbs "$@"
