#compdef fc-pattern
# Documentation: fc-pattern --help (fontconfig)
# Source: fontconfig fc-pattern — parse pattern and apply optional config/default substitution.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --config)'{-c,--config}'[perform config substitution on pattern]' \
    '(-d --default)'{-d,--default}'[perform default substitution on pattern]' \
    '(-f --format)'{-f,--format=}'[output format string]:format:' \
    '(- *)'{-V,--version}'[display fontconfig version and exit]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '*:pattern or element:' \
    && ret=0

return ret
