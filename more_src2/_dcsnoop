#compdef dcsnoop dcsnoop-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/dcsnoop.py argparse)
# Reference accessed: 2026-05-29
# dcsnoop — trace directory entry (dcache) lookups (BCC/eBPF). Defaults to failed lookups only.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-a --all)'{-a,--all}'[trace all lookups (default is fails only)]' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
