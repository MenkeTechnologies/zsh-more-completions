#compdef get-all
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config=[ketall config file]:file:_files' \
  '--use-cache[use cached API discovery output]' \
  '--allow-incomplete[show partial output when discovery fails]' \
  '--only-scope=[limit results by scope]:(cluster namespace)' \
  '--since=[only resources newer than duration]:duration:' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector:' \
  '--field-selector=[field selector]:selector:' \
  '--exclude+[resource kinds to skip]:kind:' \
  '--max-inflight=[parallel request limit]:count:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--all-namespaces[list in every namespace]' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kube context]:context' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(wide yaml json jsonpath name custom-columns go-template(go-template-file))' \
  '--chunk-size=[list pagination size]:size:' \
  '*: :'
