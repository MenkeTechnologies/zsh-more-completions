#compdef deluge-web
# Documentation: https://manpages.debian.org/bookworm/deluge-web/deluge-web.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm deluge-web(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL.

# deluge-web: Deluge web UI server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration directory]:dir:_files -/' \
  '(-i --interface)'{-i+,--interface=}'[bind IP]:ip:' \
  '(-p --port)'{-p+,--port=}'[port]:port:' \
  '(-b --base)'{-b+,--base=}'[base path for proxying]:path:' \
  '(--no-ssl)--ssl[force SSL]' \
  '(--ssl)--no-ssl[disable SSL]' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '(-L --loglevel)'{-L+,--loglevel=}'[log level]:level:(none info warning error debug)' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--logrotate=-[log rotation max size]:size:' \
  '--profile=-[profile output file]:file:_files' \
  '(-P --pidfile)'{-P+,--pidfile=}'[PID file]:file:_files' \
  '(-d --do-not-daemonize)'{-d,--do-not-daemonize}'[run in foreground]' \
  '(-U --user)'{-U+,--user=}'[run as user]:user:_users' \
  '(-g --group)'{-g+,--group=}'[run as group]:group:_groups' && ret=0
return ret
