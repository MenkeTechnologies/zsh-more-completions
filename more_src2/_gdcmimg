#compdef gdcmimg
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmimg.cxx — DICOM image converter/anonymizer (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '--endian=[endianness]:endian:(LSB MSB)' \
    '(-d --depth)'{-d+,--depth=}'[bit depth (8/16/32 or BitsAllocated)]:n:_default' \
    '--sign=[pixel sign]:sign:(0 1)' \
    '--spp=[samples per pixel]:n:(1 3 4)' \
    '--pc=[planar configuration]:n:(0 1)' \
    '--pi=[photometric interpretation]:pi:(MONOCHROME1 MONOCHROME2 PALETTE\ COLOR RGB YBR_FULL YBR_FULL_422 YBR_PARTIAL_422 YBR_PARTIAL_420 YBR_ICT YBR_RCT)' \
    '--pf=[pixel format BA,BS,HB]:bs:_default' \
    '(-s --size)'{-s+,--size=}'[image size W,H,D]:size:_default' \
    '--offset=[start offset (uint64)]:n:_default' \
    '(-C --sop-class-uid)'{-C+,--sop-class-uid=}'[SOP Class UID (name or value)]:uid:_default' \
    '(-T --study-uid)'{-T+,--study-uid=}'[Study UID]:uid:_default' \
    '(-S --series-uid)'{-S+,--series-uid=}'[Series UID]:uid:_default' \
    '--template=[DICOM template file]:file:_files' \
    '--keep-meta[keep meta info from template]' \
    '--root-uid=[Root UID]:uid:_default' \
    '(-R --region)'{-R+,--region=}'[fill region X,Y,W,H]:region:_default' \
    '(-F --fill)'{-F+,--fill=}'[fill pixel value]:n:_default' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:image file:_files' \
    && ret=0

return ret
