#compdef perlbal
# Documentation: https://github.com/perlbal/Perlbal
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--config=[config file]:file:_files -g "*.conf"' \
  '--daemon[run as daemon]' && ret=0

return ret
