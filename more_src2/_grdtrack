#compdef grdtrack
# Documentation: https://docs.generic-mapping-tools.org/latest/grdtrack.html
# Source: GenericMappingTools/gmt classic-mode grdtrack — sample one or more grids at (x,y) points or along profiles.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-G+[grid file to sample]:grid:_files -g "*.(grd|nc|tif|tiff|cdf)(-.)"' \
    '-A+[track resampling method]:method:_default' \
    '-C+[cross-profile spec]:spec:_default' \
    '-D+[save resampled input lines to file]:file:_files' \
    '-E+[define profiles via origin/coords]:spec:_default' \
    '-F+[find peaks/troughs along cross profiles]:opts:_default' \
    '-N[include points outside grid domain]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[stack profiles via reducer (mean/median/mode)]:reducer:_default' \
    '-T+[search for nearest non-NaN within radius]:radius:_default' \
    '*-V[verbose (stackable)]' \
    '-Z[output sampled z-values only]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata replacement]:value:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-j+[geodesic vs flat (Cartesian) computation]:mode:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '*:input track file:_files' \
    && ret=0

return ret
