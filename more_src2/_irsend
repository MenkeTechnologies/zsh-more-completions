#compdef irsend
# Documentation: https://manpages.debian.org/bookworm/lirc/irsend.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# irsend: send commands to lircd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-d --device)'{-d,--device=}'[lircd socket]:socket:_files' \
  '(-a --address)'{-a,--address=}'[lircd at host\:port]:host:_hosts' \
  '(-\# --count)'{-\#,--count=}'[send command N times]:n:' \
  '1:directive:(send_once send_start send_stop list set_transmitters simulate)' \
  '*:remote args:' && ret=0
return ret
