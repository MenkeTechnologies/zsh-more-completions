#compdef flyte
# Documentation: https://github.com/flyteorg/flytectl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[path to kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace' \
  '--all-namespaces[operate across every namespace]' \
  '(-s --show-source)'{-s,--show-source}'[show source locations for errors]' \
  '1:command:(compile create delete get visualize config)' \
  '*:args:_default'
