#compdef pg_view
# _pg_view — postgres activity monitor with curses UI (zalando/pg_view)
# upstream: https://github.com/zalando/pg_view
# Flags from pg_view/__init__.py (optparse).

_pg_view() {
    _arguments \
        '(- *)'{-H,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
        '(-i --instance)'{-i+,--instance=}'[instance name to monitor]:name:' \
        '(-s --use-service)'{-s,--use-service}'[query service file for instance]' \
        '(-t --tick)'{-t+,--tick=}'[tick length in seconds]:seconds:' \
        '(-o --output-method)'{-o+,--output-method=}'[output method]:method:(curses console json)' \
        '(-V --use-version)'{-V+,--use-version=}'[postgres version to monitor]:version:' \
        '(-l --log-file)'{-l+,--log-file=}'[log file]:file:_files' \
        '(-R --reset-output)'{-R,--reset-output}'[clear screen each tick]' \
        '(-c --configuration-file)'{-c+,--configuration-file=}'[Postgres connections config file]:file:_files' \
        '*'{-P+,--pid=}'[always track this PID (repeatable)]:pid:_pids' \
        '(-U --username)'{-U+,--username=}'[database user]:user:' \
        '(-d --dbname)'{-d+,--dbname=}'[database name]:dbname:' \
        '(-h --host)'{-h+,--host=}'[database host or UNIX socket dir]:host:_hosts' \
        '(-p --port)'{-p+,--port=}'[database port]:port:'
}

_pg_view "$@"
