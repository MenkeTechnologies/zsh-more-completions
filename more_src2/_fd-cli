#compdef fd-cli
# _fd-cli — David Peter fd simple, fast, user-friendly find alternative CLI alias (sharkdp team, Rust); clap-rs
# upstream: https://github.com/sharkdp/fd

_fd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-H[show hidden files]' \
        '--hidden[show hidden files]' \
        '-I[no ignore files]' \
        '--no-ignore[no ignore files]' \
        '--no-ignore-vcs[no ignore vcs]' \
        '--no-require-git[no require git]' \
        '--no-ignore-parent[no ignore parent]' \
        '-u[show hidden + no ignore]' \
        '--unrestricted[show hidden + no ignore]' \
        '-s[case sensitive]' \
        '--case-sensitive[case sensitive]' \
        '-i[ignore case]' \
        '--ignore-case[ignore case]' \
        '-g[glob mode]' \
        '--glob[glob mode]' \
        '--regex[regex mode]' \
        '-F[fixed strings]' \
        '--fixed-strings[fixed strings]' \
        '-a[absolute paths]' \
        '--absolute-path[absolute paths]' \
        '-l[long format like ls -l]' \
        '--list-details[long format like ls -l]' \
        '-L[follow symlinks]' \
        '--follow[follow symlinks]' \
        '-p[match against full path]' \
        '--full-path[match against full path]' \
        '-0[NUL terminator]' \
        '--print0[NUL terminator]' \
        '--max-results=+[n]:n:' \
        '-1[max 1 result]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--show-errors[show errors]' \
        '--strip-cwd-prefix=+[when]:w:(auto always never)' \
        '--one-file-system[stay on one fs]' \
        '-x+[command]:str:' \
        '--exec=+[command]:str:' \
        '-X+[command]:str:' \
        '--exec-batch=+[command]:str:' \
        '--batch-size=+[n]:n:' \
        '-d+[depth]:n:' \
        '--max-depth=+[depth]:n:' \
        '--min-depth=+[depth]:n:' \
        '--exact-depth=+[depth]:n:' \
        '-E+[exclude pattern]:str:' \
        '--exclude=+[exclude pattern]:str:' \
        '--prune[prune dirs]' \
        '-t+[type]:t:(file f directory d symlink l block-device b char-device c executable x empty e socket s pipe p)' \
        '--type=+[type]:t:(file f directory d symlink l block-device b char-device c executable x empty e socket s pipe p)' \
        '-e+[extension]:str:' \
        '--extension=+[extension]:str:' \
        '--size=+[size]:str:' \
        '-S+[size]:str:' \
        '--changed-within=+[duration]:str:' \
        '--changed-before=+[duration]:str:' \
        '--newer=+[duration]:str:' \
        '--older=+[duration]:str:' \
        '-o+[owner]:_users' \
        '--owner=+[owner]:_users' \
        '--color=+[when]:w:(auto always never)' \
        '-c+[when]:w:(auto always never)' \
        '-j+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '--ignore-file=+[file]:file:_files' \
        '--no-ignore-files[no ignore-files]' \
        '--hyperlink=+[when]:w:(auto always never)' \
        '--format=+[fmt]:str:' \
        '*:pattern path:_files'
}

_fd-cli "$@"
