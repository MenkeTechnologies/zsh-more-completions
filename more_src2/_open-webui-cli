#compdef open-webui-cli
# Documentation: https://github.com/mitchty/open-webui-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for open-webui-cli (mitchty/open-webui-cli)
local curcontext="$curcontext" state line ret=1

local -a commands=(
  'list:list resources (e.g. models)'
  'pull:pull a model'
  'chat:interact with an LLM'
  'new:create a new resource'
  'upload:upload a file'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'open-webui-cli command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (list)
        _arguments -s -S '1:resource:(models)' && ret=0
        ;;
      (pull)
        _arguments -s -S '1:resource:(model)' '2:name:' && ret=0
        ;;
      (chat)
        _arguments -s -S \
          '--model=[model name]:model:' \
          '--prompt=[query text]:prompt:' \
          '--file=[uploaded file ID]:file id:' \
          '--collection=[knowledge collection ID]:collection id:' && ret=0
        ;;
      (new)
        _arguments -s -S \
          '1:resource:(collection)' \
          '--name=[collection name]:name:' \
          '--description=[collection description]:description:' && ret=0
        ;;
      (upload)
        _arguments -s -S \
          '1:type:(file)' \
          '2:path:_files' \
          '--collection=[collection ID]:collection id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
