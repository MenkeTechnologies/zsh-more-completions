#compdef frizbee
# Documentation: https://github.com/stacklok/frizbee
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for frizbee — OCI referrers / supply chain

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:(list lint pull trace version)' \
  '*::args:{ _message "registry ref or options" }' && ret=0

return ret
