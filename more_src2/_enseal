(( $+functions[_enseal_commands] )) ||
_enseal_commands() {
    local commands; commands=(
'share:Send a .env file, piped input, or inline secret' \
'receive:Receive secrets via wormhole code or encrypted file' \
'inject:Receive secrets and inject into a child process (no file on disk)' \
'check:Verify .env has all vars from .env.example' \
'diff:Show missing/extra vars between two .env files (keys only)' \
'redact:Output .env with values replaced by <REDACTED>' \
'validate:Validate .env against schema rules in .enseal.toml' \
'template:Generate .env.example from a real .env with type hints' \
'encrypt:Encrypt a .env file for safe storage (age-based)' \
'decrypt:Decrypt an at-rest encrypted .env file' \
'keys:Manage identity keys, aliases, and trusted keys' \
'serve:Run the enseal relay server' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'enseal commands' commands "$@"
}
(( $+functions[_enseal__check_commands] )) ||
_enseal__check_commands() {
    local commands; commands=()
    _describe -t commands 'enseal check commands' commands "$@"
}
