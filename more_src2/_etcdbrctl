#compdef etcdbrctl
# _etcdbrctl — Gardener etcd-backup-restore CLI
# upstream: https://github.com/gardener/etcd-backup-restore
# Subcommands + flags from cmd/root.go, options.go on tip.

_etcdbrctl() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[print version and exit]' \
        '--config-file=[etcd-backup-restore config file]:file:_files' \
        '--log-level=[log verbosity]:n:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'snapshot:start periodic snapshot of etcd to a snapstore'
                'restore:restore etcd data dir from a snapshot in a snapstore'
                'compact:compact a snapshot in a snapstore'
                'initialize:validate (and optionally restore) the etcd data dir'
                'server:run the etcd-backup-restore HTTP server (snapshot + initialize + admin)'
                'copy:copy snapshots from one snapstore to another'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $line[1] in
                initialize)
                    _arguments \
                        '--validation-mode=[validation mode]:mode:(full sanity)'
                    ;;
                copy)
                    _arguments \
                        '--max-backups-to-copy=[copy latest N backups (-1 = all)]:n:' \
                        '--max-backup-age=[copy only backups newer than N days (-1 = all)]:n:' \
                        '--max-parallel-copy-operations=[parallel copy worker count]:n:' \
                        '--wait-for-final-snapshot=[wait for final full snapshot]:bool:(true false)' \
                        '--wait-for-final-snapshot-timeout=[final-snapshot wait timeout]:dur:'
                    ;;
                snapshot|server)
                    _arguments \
                        '--defragmentation-schedule=[etcd defrag cron schedule]:cron:'
                    ;;
            esac
            ;;
    esac
}

_etcdbrctl "$@"
