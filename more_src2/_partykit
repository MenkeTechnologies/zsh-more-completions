_partykit() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_partykit_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '(-y --yes)'{-y,--yes}'[skip prompts]' \
                        '--dry-run[skip writing files + installing deps]' \
                        '*:name:'
                    ;;
                dev)
                    _arguments \
                        '(-p --port)'{-p+,--port=}'[port to run server on]:port:' \
                        '--serve=[serve static assets directory]:dir:_files -/' \
                        '--https[enable HTTPS]' \
                        '--https-key-path=[HTTPS key file]:file:_files' \
                        '--https-cert-path=[HTTPS cert file]:file:_files' \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"' \
                        '--compatibility-date=[Cloudflare compatibility date]:date:' \
                        '*--compatibility-flags=[Cloudflare compatibility flags]:flags:' \
                        '--minify[minify the script]' \
                        '--live[enable live reload]' \
                        '--with-env[define all variables in deployment]' \
                        '--disable-request-cf-fetch[disable populating request.cf]' \
                        '--verbose[verbose debugging output]' \
                        '--no-hotkeys[disable hot keys]' \
                        '*:script:_files'
                    ;;
                deploy)
                    _arguments \
                        '--serve=[serve static assets directory]:dir:_files -/' \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"' \
                        '--compatibility-date=[Cloudflare compatibility date]:date:' \
                        '*--compatibility-flags=[Cloudflare compatibility flags]:flags:' \
                        '--minify[minify the script]' \
                        '--with-vars[include all variables in deployment]' \
                        '--with-env[define all variables in deployment]' \
                        '(-n --name)'{-n+,--name=}'[name of the project]:name:' \
                        '--preview=[deploy to preview environment]:name:' \
                        '--domain=[custom domain]:domain:' \
                        '*:script:_files'
                    ;;
                list)
                    _arguments \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"'
                    ;;
                delete)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[name of the project]:name:' \
                        '(-f --force)'{-f,--force}'[force delete without confirmation]' \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"' \
                        '--preview=[delete preview]:name:'
                    ;;
                info)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[name of the project]:name:' \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"' \
                        '--preview=[get info about preview]:name:'
                    ;;
                tail)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[name of the project]:name:' \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"' \
                        '--preview=[tail logs from preview]::name:' \
                        '--debug[show debug logs]' \
                        '--header[filter by HTTP header]' \
                        '--method=[filter by HTTP method(s)]:methods:' \
                        '--sampling-rate=[sampling rate of logs]:n:' \
                        '--search=[search for a string in the logs]:string:'
                    ;;
                env)
                    _arguments \
                        '1: :(list pull push add remove)' \
                        '(-n --name)'{-n+,--name=}'[name of the project]:name:' \
                        '(-c --config)'{-c+,--config=}'[path to config file]:file:_files -g "*.(json|toml)"' \
                        '--preview=[operate on preview]::name:' \
                        '*::env-arg:'
                    ;;
                ai)
                    _arguments \
                        '1: :(models)'
                    ;;
                vectorize)
                    _arguments \
                        '1: :(create delete get list insert)' \
                        '*::vec-arg:'
                    ;;
                login)
                    _arguments \
                        '1: :(cloudflare partykit)'
                    ;;
                token)
                    _arguments \
                        '1: :(generate)'
                    ;;
            esac
            ;;
    esac

    return ret
}

_partykit_cmds() {
    local -a cmds
    cmds=(
        'init:scaffold a new PartyKit project'
        'dev:run a PartyKit project locally'
        'deploy:deploy a PartyKit project to Cloudflare'
        'list:list deployed PartyKit projects'
        'delete:delete a PartyKit project'
        'info:show project info'
        'tail:tail real-time logs from a project'
        'login:login (PartyKit or Cloudflare auth)'
        'logout:logout from PartyKit'
        'whoami:show current login identity'
        'token:generate a token for CI/CD deployments'
        'env:manage project environment variables'
        'ai:list available Cloudflare Workers AI models'
        'vectorize:manage Cloudflare Vectorize vector DB indexes'
    )
    _describe -t commands 'partykit command' cmds
}

_partykit "$@"
