#                                     preview
#       --debug                    - show
#                                     debug
#                                     logs
#       --header                   - filter
#                                     by HTTP
#                                     header
#       --method <methods>         - filter
#                                     by HTTP
#                                     method(s)
#       --sampling-rate <n>        - sampling
#                                     rate of
#                                     logs
#       --search <string>          - search
#                                     for a
#                                     string
