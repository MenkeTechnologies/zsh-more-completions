#
# Standard:
#   -h, --help                     - show
#                                     help
#   -V, --version                  - show
#                                     version
#
# Example invocations:
#   # Scaffold a new project
#   partykit init my-chat-app
#
#   # Run locally on port 1999
#   partykit dev --port 1999
#
#   # Deploy to production
#   partykit deploy --name my-chat-app
#
#   # Deploy to a preview environment
#   partykit deploy \
#     --preview pr-42 \
#     --name my-chat-app
#
#   # Tail real-time logs
#   partykit tail --name my-chat-app
#
#   # List deployed projects
#   partykit list
#
#   # Add an environment variable
#   partykit env add OPENAI_API_KEY \
#     --name my-chat-app
#
#   # Push all environment variables
#   partykit env push --name my-chat-app
#
#   # Manage Vectorize index
#   partykit vectorize create my-embeddings
#   partykit vectorize insert my-embeddings
#
#   # List Workers AI models
#   partykit ai models
#
#   # Generate CI/CD token
#   partykit token generate
#
# Configuration file (partykit.json or
# partykit.toml):
#   ```toml
#   name = "my-chat-app"
#   main = "src/server.ts"
#   compatibility_date = "2026-06-01"
#
