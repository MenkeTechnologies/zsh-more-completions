#compdef kubectl-split-yaml
# Documentation: https://github.com/nathforge/kubectl-split-yaml
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-split-yaml splits multi-document YAML into one file per resource.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-f+[input file (- for stdin)]:file:_files' \
  '-p+[output directory]:directory:_directories' \
  '-t+[filename template]:template:' \
  '*:args:_default'
