#compdef reflector
# Documentation: https://xyne.dev/projects/reflector/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Added short-form flags (-a -c -f -i -x -l -n -p) and dropped
# unverified `rsync` from --protocol enum.

# Zsh completion for reflector - Arch Linux mirror list manager

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --age)'{-a+,--age=}'[max mirror age in hours]:hours' \
  '--cache-timeout=[cache timeout in seconds]:seconds' \
  '--completion-percent=[min completion percent]:percent' \
  '--connection-timeout=[connection timeout in seconds]:seconds' \
  '(-c --country)'{-c+,--country=}'[filter by country]:country' \
  '--delay=[max sync delay in hours]:hours' \
  '--download-timeout=[download timeout in seconds]:seconds' \
  '(-f --fastest)'{-f+,--fastest=}'[return N fastest mirrors]:count' \
  '(-i --include)'{-i+,--include=}'[include mirrors matching regex]:regex' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude mirrors matching regex]:regex' \
  '--info[print mirror information]' \
  '--isos[only mirrors hosting ISOs]' \
  '--ipv4[only IPv4 mirrors]' \
  '--ipv6[only IPv6 mirrors]' \
  '(-l --latest)'{-l+,--latest=}'[limit to N most recently synced]:count' \
  '--list-countries[list available countries]' \
  '(-n --number)'{-n+,--number=}'[limit to N mirrors]:count' \
  '(-p --protocol)'{-p+,--protocol=}'[filter by protocol]:protocol:(http https ftp)' \
  '--save=[save output to file]:file:_files' \
  '--score=[limit to N top scored mirrors]:count' \
  '--sort=[sort key]:key:(age rate country score delay)' \
  '--threads=[number of threads for rating]:threads' \
  '--url=[custom mirror data source URL]:URL' \
  '--verbose[enable verbose output]'
