#compdef dts-bundle-generator
# _dts-bundle-generator — generate single .d.ts file (timocov/dts-bundle-generator)
# upstream: https://github.com/timocov/dts-bundle-generator
# Flags from src/bin/dts-bundle-generator.ts (yargs).

_dts-bundle-generator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*-o+[output file name]:file:_files' \
        '*--out-file=[output file name]:file:_files' \
        '--verbose[verbose logging]' \
        '--silent[silent mode]' \
        '--no-check[do not type-check after generation]' \
        '--fail-on-class[fail if class is encountered]' \
        '*--external-inlines=[external inlines packages]:pkg:' \
        '*--external-imports=[external imports packages]:pkg:' \
        '*--external-types=[external types packages]:pkg:' \
        '--umd-module-name=[UMD module name]:name:' \
        '--project=[tsconfig.json path]:file:_files -g "tsconfig*.json"' \
        '--sort[sort the output]' \
        '--inline-declare-global[inline declare global statements]' \
        '--inline-declare-externals[inline declare externals]' \
        '--disable-symlinks-following[disable symlink resolution]' \
        '--respect-preserve-const-enum[respect preserveConstEnums]' \
        '--export-referenced-types[export referenced types]' \
        '--config=[config file path]:file:_files' \
        '--no-banner[skip the generation banner]' \
        '*:input file:_files -g "*.{ts,tsx,mts,cts}"'
}

_dts-bundle-generator "$@"
