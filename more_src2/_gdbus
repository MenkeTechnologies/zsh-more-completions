#compdef gdbus
# _gdbus — GLib gdbus (D-Bus tool: introspect/call/monitor/emit/wait against system/session buses or peer addresses; introspect --xml prints raw XML, call invokes methods, monitor streams signals, wait sleeps until name appears)
# upstream: https://gitlab.gnome.org/GNOME/glib (gio/gdbus-tool.c)
# Subcommands from glib gio/gdbus-tool.c on tip.

_gdbus() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gdbus command' '(introspect monitor call emit wait)' ;;
        args)
            _arguments \
                '--system[system bus]' \
                '--session[session bus]' \
                '--address+[peer address]:address:' \
                '--dest+[D-Bus name]:name:' \
                '--object-path+[object path]:path:' \
                '--method+[method name]:name:' \
                '--signal+[signal name]:name:' \
                '--signature+[type signature]:sig:' \
                '--xml[introspect: print raw XML]' \
                '--only-properties[introspect: properties only]' \
                '--recurse[introspect: recurse]' \
                '--timeout+[ms timeout]:ms:' \
                '--interactive-authorization[allow polkit]' \
                '*:argument:'
            ;;
    esac
}

_gdbus "$@"
