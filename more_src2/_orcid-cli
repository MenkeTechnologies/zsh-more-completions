#compdef orcid-cli orcid
# _orcid-cli — ORCID orcid-cli CLI client to the ORCID iD public REST API querying author records by ORCID iD email name affiliation listing works employment education funding peer-review memberships invited-positions reading per-section JSON-LD bulk-export Crossref-DataCite-linked metadata (ORCID team, Python); custom argparse
# upstream: https://orcid.org/

_orcid-cli() {
    local -a sub=(
        'search:search ORCID records'
        'get:fetch an ORCID record'
        'works:list a record works'
        'employment:list employment'
        'education:list education'
        'funding:list funding'
        'peer-review:list peer-reviews'
        'invited-positions:list invited positions'
        'memberships:list memberships'
        'qualifications:list qualifications'
        'distinctions:list distinctions'
        'services:list services'
        'export:export full record'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--access-token=+[token]:str:' \
        '--api=+[a]:a:(public member sandbox)' \
        '--rows=+[N]:n:' \
        '--start=+[N]:n:' \
        '-f+[format]:f:(json xml jsonld bibtex csv yaml table)' \
        '--format=+[format]:f:(json xml jsonld bibtex csv yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'orcid-cli subcommand' sub ;;
        args)
            case $words[1] in
                search) _arguments '*:query:' ;;
                get|works|employment|education|funding|peer-review|invited-positions|memberships|qualifications|distinctions|services|export) _arguments '*:orcid:' ;;
            esac
            ;;
    esac
}

_orcid-cli "$@"
