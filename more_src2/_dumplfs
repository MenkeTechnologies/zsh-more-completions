#compdef dumplfs
# Documentation: man dumplfs(8)
# Source: netbsd/src usr.sbin/dumplfs — dump LFS file system information (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[dump all superblocks, not just the first]' \
    '-b+[block to use as superblock]:blkno:_default' \
    '-d[check partial segment data checksums]' \
    '-I+[block to use as inode block]:blkno:_default' \
    '-i[dump inode free list]' \
    '-S[dump segment table]' \
    '*-s+[add segment number to dump list]:segno:_default' \
    '1:filesystem or device:_files' \
    && ret=0

return ret
