#compdef kerbrute
# Documentation: https://github.com/ropnop/kerbrute
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'bruteforce:read user:password combos from file or stdin'
  'bruteuser:bruteforce single user from password wordlist'
  'passwordspray:test single password against user list'
  'userenum:enumerate valid usernames'
  'help:show help'
  'version:display version'
)

_arguments -C \
  '--dc=[domain controller]:host:_hosts' \
  '--delay=[delay milliseconds]:ms:' \
  '(-d --domain)'{-d,--domain}'=[full domain]:domain:' \
  '--downgrade[force downgraded encryption]' \
  '--hash-file=[AS-REP hash output]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o,--output}'=[log file]:file:_files' \
  '--safe[abort on lockout]' \
  '(-t --threads)'{-t,--threads}'=[threads]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'kerbrute subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (bruteforce) _arguments '*:combo file:_files' && ret=0 ;;
      (bruteuser) _arguments '1:wordlist:_files' '2:user:' && ret=0 ;;
      (passwordspray) _arguments '1:userlist:_files' '2:password:' && ret=0 ;;
      (userenum) _arguments '*:userlist:_files' && ret=0 ;;
    esac
    ;;
esac

return ret
