#compdef mas-cli
# _mas-cli — Matrix Authentication Service CLI (element-hq/matrix-authentication-service)
# upstream: https://github.com/element-hq/matrix-authentication-service
# Subcommands from crates/cli/src/commands/mod.rs (clap).

_mas-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*'{-c+,--config=}'[config file (repeatable)]:file:_files -g "*.{yml,yaml}"' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'config:configuration-related commands'
                'database:manage the database'
                'server:run the web server'
                'worker:run the worker'
                'manage:manage the instance (users, sessions, ...)'
                'templates:templates-related commands'
                'doctor:run diagnostics on the deployment'
                'syn2mas:migrate from Synapse built-in auth to MAS'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                config) _arguments '1:subcommand:(dump check generate sync)' ;;
                database) _arguments '1:subcommand:(migrate)' ;;
                manage) _arguments '1:subcommand:(add-email issue-compatibility-token kill-sessions list-users provision-all register-user set-password)' ;;
                templates) _arguments '1:subcommand:(check save)' ;;
            esac
            ;;
    esac
}

_mas-cli "$@"
