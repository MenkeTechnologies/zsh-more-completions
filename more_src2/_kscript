#compdef kscript
# _kscript — scripting enhancements for Kotlin (kscripting/kscript)
# upstream: https://github.com/kscripting/kscript
# Flags from src/main/kotlin/io/github/kscripting/kscript/util/OptionsUtils.kt.

_kscript() {
    local -a args
    args=(
        '(-i --interactive)'{-i,--interactive}'[start an interactive shell with the script dependencies]'
        '(-t --text)'{-t,--text}'[enable stdin-friendly text-processing API]'
        '(-e --idea)'{-e,--idea}'[open the script in a temporary IntelliJ project]'
        '(-s --silent)'{-s,--silent}'[suppress status logging]'
        '(-d --development)'{-d,--development}'[print extra log messages and stack traces]'
        '(-r --report)'{-r,--report}'[print deprecated-feature report for the script]'
        '(-p --package)'{-p,--package}'[package the script and dependencies into a self-contained binary]'
        '(-a --add-bootstrap-header)'{-a,--add-bootstrap-header}'[prepend a bash header that installs kscript if missing]'
        '(-c --clear-cache)'{-c,--clear-cache}'[wipe the script-jar / URL cache]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '*:kotlin script:_files -g "*.(kt|kts)"'
    )
    _arguments -s -S $args
}

_kscript "$@"
