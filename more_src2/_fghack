#compdef fghack pgrphack svok
# Documentation: source-direct extraction from upstream DJB
# daemontools daemontools/daemontools/src/{fghack,pgrphack,svok}.c
# USAGE strings (these are minimal positional-only tools from
# Bernstein's original 2001 daemontools; they predate getopt
# convention and just use `argv[1]` as the single positional).
# Reference accessed: 2026-05-30 via gh api.
# DJB daemontools R131b — 3-stem multi-binary harvest of the
# 3 daemontools binaries not previously covered (svc/svscan/
# svstat/supervise/multilog/readproctitle/setlock/setuidgid/
# envuidgid/softlimit were already in the corpus from older
# rounds). Sister tools to the Skarnet s6 family (R117-R129) which
# is a clean-room reimplementation of these primitives with
# extensions; the original DJB binaries remain in active use as
# the daemontools package in Debian/Void/Alpine.

case $service in

  fghack)
    # Foreground-detection hack: open many file descriptors all
    # writing to a single pipe, then spawn child. Daemontools'
    # supervise uses fghack to detect when a "foreground" service
    # mistakenly self-daemonizes - the pipe stays alive as long as
    # any of the open fds in any descendant remain open. The s6
    # equivalent is s6-fghack from R118.
    _arguments -s -S \
      '*:child program and arguments:_command_names -e'
    ;;

  pgrphack)
    # Process-group hack: setpgrp(0) then chain-load child. The
    # child becomes a process-group leader so that signals sent to
    # the parent's group don't reach the child. Useful for spawning
    # subprocesses that should outlive their supervisor.
    _arguments -s -S \
      '*:child program and arguments:_command_names -e'
    ;;

  svok)
    # Test whether a daemontools-supervised service is currently
    # running (exits 0 if up, 100 if not). Equivalent to s6-svok
    # in the Skarnet family.
    _arguments -s -S \
      '1:servicedir:_directories'
    ;;

esac
