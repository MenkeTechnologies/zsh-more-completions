#compdef lxqt-about
# Documentation: https://github.com/lxqt/lxqt-about
# Reference accessed: 2026-05-19
# Verified: upstream main.cpp uses QCommandLineParser with only
# addHelpOption()/addVersionOption() — no LXQt-specific CLI flags.

# lxqt-about: about dialog for LXQt
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '--style=[Qt GUI style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '--platform=[Qt platform plugin]:platform:' \
  '--platformpluginpath=[Qt plugin path]:dir:_files -/' \
  '--display=[X display]:display:' \
  '--reverse[reverse layout direction]' \
  '*::lxqt-about args:_files' && ret=0
return ret
