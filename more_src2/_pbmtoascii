#compdef pbmtoascii
# Documentation: man pbmtoascii (Netpbm)
# Source: render a PBM image as ASCII art.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-1x2 -2x4)-1x2[1x2-character resolution]' \
    '(-1x2 -2x4)-2x4[2x4-character resolution]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
