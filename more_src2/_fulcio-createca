#compdef fulcio-createca
# _fulcio-createca — Sigstore Fulcio root-CA bootstrap helper (createca subcommand)
# upstream: https://github.com/sigstore/fulcio
# Flags from cmd/app/createca.go on tip.

_fulcio-createca() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--org=[organization name for root CA]:name:' \
        '--country=[country name for root CA]:name:' \
        '--province=[province name for root CA]:name:' \
        '--locality=[locality name for root CA]:name:' \
        '--street-address=[street address for root CA]:addr:' \
        '--postal-code=[postal code for root CA]:code:' \
        '--out=[output root CA to file]:file:_files' \
        '--hsm=[HSM provider]:provider:(softhsm aws)' \
        '--pkcs11-config-path=[fulcio pkcs11 config file]:file:_files' \
        '--hsm-caroot-id=[HSM ID for root CA]:id:'
}

_fulcio-createca "$@"
