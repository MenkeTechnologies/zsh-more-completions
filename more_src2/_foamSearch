#compdef foamSearch
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamSearch — grep through OpenFOAM dictionaries to find keyword settings.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-count -c)'{-count,-c}'[prefix lines by the number of occurrences]' \
    '(-help -h)'{-help,-h}'[print usage]' \
    '*:dict or pattern:_files' \
    && ret=0

return ret
