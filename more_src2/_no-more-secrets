#compdef nms
# Documentation: https://github.com/bartobri/no-more-secrets
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Per README: nms reads from stdin (no positional file arg). Short flags
# only: -a, -s, -f <color>, -c, -v. cyan is a valid color choice; hex
# values like #FF1234 also work. There is no --help / --version long form.

local curcontext="$curcontext" ret=1

_arguments -s \
  '-v[show version]' \
  '-a[auto-decrypt after initial display]' \
  '-s[mask space characters]' \
  '-f+[foreground color]:color:(white yellow black magenta blue green red cyan)' \
  '-c[clear screen before printing]' && ret=0

return ret
