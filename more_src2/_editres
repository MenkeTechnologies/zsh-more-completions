#compdef editres
# Documentation: https://www.x.org/releases/current/doc/man/man1/editres.1.xhtml
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# editres accepts standard X Toolkit options only (see X(7))

local -a arguments

arguments=(
    '-display[X server to connect to]:display:'
    '-geometry[window geometry]:geometry:'
    '-name[application name]:name:'
    '-title[window title]:title:'
    '-xrm[X resource]:resource:'
    '-bg[background color]:color:'
    '-fg[foreground color]:color:'
    '-bd[border color]:color:'
    '-bw[border width]:width:'
    '-fn[font]:font:'
    '-iconic[start iconified]'
    '-rv[reverse video]'
    '-synchronous[synchronous X server mode]'
    '*:resource file:_files'
)

_arguments -s -S $arguments
