#compdef nextpnr-ice40
# _nextpnr-ice40 — YosysHQ nextpnr-ice40 CLI place-and-route portable open-source FPGA P&R tool targeting Lattice iCE40 LP/LX/UP/HX family chips packed JSON netlist from Yosys producing ASCII placement bitstream for icepack (David Shah team, C++); custom argparse
# upstream: https://github.com/YosysHQ/nextpnr

_nextpnr-ice40() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--log=+[log file]:file:_files' \
        '--json=+[json netlist]:file:_files -g "*.json"' \
        '--pcf=+[pcf file]:file:_files -g "*.pcf"' \
        '--asc=+[asc output]:file:_files -g "*.asc"' \
        '--write=+[json output]:file:_files -g "*.json"' \
        '--read=+[json input]:file:_files -g "*.json"' \
        '--package=+[p]:p:(tq144 cb132 cb121 vq100 cm225 cm121 cm81 cm49 cm36 sg48 qn84 cb81 ct256 cb284)' \
        '--lp384[iCE40 LP384]' \
        '--lp1k[iCE40 LP1K]' \
        '--lp4k[iCE40 LP4K]' \
        '--lp8k[iCE40 LP8K]' \
        '--hx1k[iCE40 HX1K]' \
        '--hx4k[iCE40 HX4K]' \
        '--hx8k[iCE40 HX8K]' \
        '--up3k[iCE40 UP3K]' \
        '--up5k[iCE40 UP5K]' \
        '--u1k[iCE40 U1K]' \
        '--u2k[iCE40 U2K]' \
        '--u4k[iCE40 U4K]' \
        '--freq=+[MHz]:n:' \
        '--seed=+[seed]:n:' \
        '--placer=+[p]:p:(heap sa)' \
        '--router=+[r]:r:(router1 router2)' \
        '--no-route[skip routing]' \
        '--no-place[skip placement]' \
        '--no-pack[skip packing]' \
        '--placer-heap-alpha=+[alpha]:n:' \
        '--placer-heap-beta=+[beta]:n:' \
        '--placer-heap-cell-placement-timeout=+[N]:n:' \
        '--placer-budgets[use placer budgets]' \
        '--placer-budgets-timeout=+[N]:n:' \
        '--report=+[file]:file:_files -g "*.json"' \
        '--detailed-timing-report[detailed timing report]' \
        '--threads=+[N]:n:' \
        '--pre-pack=+[script]:file:_files -g "*.py"' \
        '--pre-place=+[script]:file:_files -g "*.py"' \
        '--pre-route=+[script]:file:_files -g "*.py"' \
        '--post-route=+[script]:file:_files -g "*.py"' \
        '--gui[gui mode]' \
        '--no-tmdriv[disable timing-driven]' \
        '--randomize-seed[randomize seed]' \
        '*:json file:_files -g "*.json"'
}

_nextpnr-ice40 "$@"
