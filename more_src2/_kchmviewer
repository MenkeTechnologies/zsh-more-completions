#compdef kchmviewer
# _kchmviewer — KchmViewer (Qt-based CHM (Compiled HTML Help) and EPUB viewer; --search opens the search tab pre-filled, --autotest runs the bundled test suite, --shortcuts dumps shortcut list; positional argument is the .chm/.epub file)
# upstream: https://github.com/gyunaev/kchmviewer
# Flags from kchmviewer src/main.cpp on tip.

_kchmviewer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--search+[search text]:query:' \
        '--autotest[run test suite]' \
        '--shortcuts[dump shortcut list]' \
        '1:CHM or EPUB file:_files -g "*.(chm|epub)"'
}

_kchmviewer "$@"
