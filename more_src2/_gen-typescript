#compdef gen-typescript
# _gen-typescript — generate TypeScript interfaces from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/typescriptgen.py (click).

_gen-typescript() {
    local -a args
    args=(
        '(-u --gen-type-utils)'{-u,--gen-type-utils}'[generate runtime type-checking utilities]'
        '--include-induced-slots[include slots induced through inheritance]'
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.ts"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(typescript)'
        '--expand-subproperty-of[expand subPropertyOf into the generated interfaces]'
        '--no-expand-subproperty-of[do not expand subPropertyOf]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '--useuris[use URI references for terms]'
        '--metauris[use meta URI references]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into generated output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-typescript "$@"
