#compdef ghz
# Documentation: https://ghz.sh/docs/options
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config=[path to JSON/TOML config file]:file:_files' \
  '--proto=[path to protocol buffer file]:proto file:_files -g "*.proto"' \
  '--protoset=[compiled protoset file]:protoset file:_files' \
  '--call=[fully qualified gRPC method name]:method:' \
  '*'{-i,--import-paths=}'[comma-separated proto import paths]:import path:_directories' \
  '--cacert=[CA certificate for server verification]:ca cert:_files' \
  '--cert=[client TLS certificate]:cert file:_files' \
  '--key=[client TLS private key]:key file:_files' \
  '--cname=[server name override for TLS]:name:' \
  '--skipTLS[skip TLS client verification]' \
  '--insecure[use plaintext and insecure connection]' \
  '--authority=[value for :authority pseudo header]:authority:' \
  '--async[make requests asynchronously]' \
  '(-r --rps)'{-r,--rps}'=[rate limit in requests per second]:rps:' \
  '(-c --concurrency)'{-c,--concurrency}'=[number of concurrent workers]:workers:' \
  '(-n --total)'{-n,--total}'=[total number of requests]:count:' \
  '(-t --timeout)'{-t,--timeout}'=[per-request timeout]:timeout:' \
  '(-z --duration)'{-z,--duration}'=[duration of the test]:duration:' \
  '(-x --max-duration)'{-x,--max-duration}'=[maximum test duration]:duration:' \
  '(-d --data)'{-d,--data}'=[request data as JSON string]:data:' \
  '(-D --data-file)'{-D,--data-file}'=[path to data JSON file]:data file:_files' \
  '(-b --binary)'{-b,--binary}'[read binary protobuf message from stdin]' \
  '(-B --binary-file)'{-B,--binary-file}'=[path to serialized binary message]:file:_files' \
  '(-m --metadata)'{-m,--metadata}'=[request metadata as JSON]:metadata:' \
  '(-M --metadata-file)'{-M,--metadata-file}'=[path to metadata JSON file]:file:_files' \
  '(-o --output)'{-o,--output}'=[output file path]:file:_files' \
  '(-O --format)'{-O,--format}'=[output format]:format:(csv json pretty html influx-summary influx-details prometheus)' \
  '(-e --enable-compression)'{-e,--enable-compression}'[enable gzip compression]' \
  '--connections=[number of connections]:connections:' \
  '--cpus=[number of cpu cores to use]:cpus:' \
  '--rpc-timeout=[timeout for individual RPC calls]:timeout:' \
  '--connect-timeout=[connection dial timeout]:timeout:' \
  '--keepalive=[keepalive time]:duration:' \
  '--load-schedule=[load schedule pattern]:schedule:(const step line)' \
  '--load-start=[load schedule start]:value:' \
  '--load-step=[load schedule step]:value:' \
  '--load-end=[load schedule end]:value:' \
  '--load-step-duration=[load schedule step duration]:duration:' \
  '--load-max-duration=[load schedule max duration]:duration:' \
  '--concurrency-schedule=[concurrency change schedule]:schedule:' \
  '--concurrency-start=[concurrency schedule start]:value:' \
  '--concurrency-step=[concurrency schedule step]:value:' \
  '--concurrency-end=[concurrency schedule end]:value:' \
  '--debug=[debug log file path]:file:_files' \
  '--host=[host to connect to]:host:_hosts' \
  '1:host\:port:' && ret=0

return ret
