#compdef electron-mocha
# _electron-mocha — run Mocha tests inside an Electron renderer (jprichardson/electron-mocha)
# upstream: https://github.com/jprichardson/electron-mocha
# Flags from lib/run.js .options({}) (Electron-specific; passes other args to mocha).

_electron-mocha() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--renderer[run tests in renderer process]' \
        '*'{--require-main=,--main=}'[require module in main process]:module:_files' \
        '*--script=[load module in renderer via script tag]:file:_files -g "*.js"' \
        '--interactive[show renderer tests in persistent window]' \
        '--inspect=[enable debugger on port]:port:' \
        '--inspect-brk=[enable debugger and break]:port:' \
        '(--url --index)'{--url=,--index=}'[load custom URL in renderer]:url:' \
        '--preload=[load module during renderer preload]:file:_files' \
        '(-W --warnings)'{-W,--warnings}'[print renderer warnings to console]' \
        '--window-config=[custom Electron window options]:json:' \
        '--show-window[show window during tests]' \
        '*:mocha args / test file:_files'
}

_electron-mocha "$@"
