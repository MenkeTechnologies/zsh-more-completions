#compdef kile
# Documentation: https://manpages.debian.org/unstable/kile/kile.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--line[jump to the given line in the file that is opened]:line:' \
  '--new[start a new Kile main window]' \
  '*:tex file:_files -g "*.{tex,bib,sty,cls}"' && ret=0

return ret
