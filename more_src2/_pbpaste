#compdef pbpaste
# Documentation: pbpaste -help / man pbcopy
# Source: macOS pasteboard reader; writes pasteboard contents to stdout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '-pboard[pasteboard to read]:pasteboard:(general ruler find font)' \
    '-Prefer[preferred data type]:type:(txt rtf ps)' \
    && ret=0

return ret
