#compdef gtk-recordmydesktop recordmydesktop
# Documentation: https://manpages.debian.org/buster/recordmydesktop/recordmydesktop.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian buster recordmydesktop(1) manpage. GTK wrapper shares the
# same flag surface as the CLI binary plus GTK standard options.

# recordmydesktop / gtk-recordmydesktop: screencast recorder
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--print-config[show compile-time config]' \
  '--windowid=[capture given window ID]:id:' \
  '--display=[X display]:display:' \
  '-x[X offset]:n:' \
  '-y[Y offset]:n:' \
  '--width=[capture width]:n:' \
  '--height=[capture height]:n:' \
  '--dummy-cursor[draw dummy cursor]' \
  '--no-cursor[do not capture cursor]' \
  '--no-shared[disable shared memory]' \
  '--full-shots[full screen snapshots each frame]' \
  '--follow-mouse[follow mouse pointer]' \
  '--quick-subsampling[fast chroma subsampling]' \
  '--fps=[frames per second]:n:' \
  '--channels=[audio channels]:n:' \
  '--freq=[audio sample rate]:n:' \
  '--buffer-size=[audio buffer size]:n:' \
  '--ring-buffer-size=[audio ring buffer size]:n:' \
  '--device=[audio device]:device:' \
  '--use-jack[use JACK]:ports:' \
  '--no-sound[disable audio recording]' \
  '--on-the-fly-encoding[encode while capturing]' \
  '--v_quality=[video quality (0-63)]:n:' \
  '--v_bitrate=[video bitrate]:n:' \
  '--s_quality=[sound quality (-1 to 10)]:n:' \
  '--rescue[rescue cache directory]:dir:_files -/' \
  '--no-wm-check[do not check for compositing WM]' \
  '--no-frame[do not draw frame]' \
  '--pause-shortcut=[pause hotkey]:hotkey:' \
  '--stop-shortcut=[stop hotkey]:hotkey:' \
  '--compress-cache[compress cache files]' \
  '--workdir=[work directory]:dir:_files -/' \
  '--delay=[delay before recording]:seconds:' \
  '--overwrite[overwrite existing file]' \
  '-o[output file]:file:_files -g "*.ogv"' && ret=0
return ret
