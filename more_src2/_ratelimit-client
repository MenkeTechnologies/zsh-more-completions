#compdef ratelimit-client
# _ratelimit-client — Envoy rate-limit gRPC test client (issues ShouldRateLimit RPCs against a running ratelimit service)
# upstream: https://github.com/envoyproxy/ratelimit
# Flags from src/client_cmd/main.go on tip.

_ratelimit-client() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-dial_string=[host:port of the ratelimit gRPC service]:hostport:' \
        '-domain=[rate-limit configuration domain to query]:domain:' \
        '*-descriptors=[csv of key=value descriptor entries (repeatable)]:csv:' \
        '-oltp-protocol=[OTel exporter protocol (http/grpc/empty=disabled)]:proto:(http grpc)' \
        '-grpc-use-tls[use TLS for the connection to the ratelimit server]' \
        '-grpc-server-ca-file=[server CA file for TLS]:file:_files' \
        '-grpc-cert-file=[client TLS cert file]:file:_files' \
        '-grpc-key-file=[client TLS key file]:file:_files'
}

_ratelimit-client "$@"
