#compdef fsstat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/fsstat.html
# Source: sleuthkit/sleuthkit man/fsstat.1 — display file system statistical information.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-t[print file system type only]' \
    '-f[specify file system type]:fstype:(ext2 ext3 ext4 fat fat12 fat16 fat32 ntfs ufs ufs1 ufs2 iso9660 hfs ext yaffs2 list)' \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-o[sector offset where file system starts in image]:offset:' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-v[verbose output of debugging statements to stderr]' \
    '-V[display version]' \
    '*:image file:_files' \
    && ret=0

return ret
