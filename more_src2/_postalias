#compdef postalias
# _postalias — Postfix alias DB tool (create/update/query Sendmail-compatible alias databases used by local(8) for /etc/aliases mappings; supports btree/hash/lmdb/dbm + cdb)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/postalias.1 on tip.

_postalias() {
    _arguments \
        '-N[include trailing null in keys + values]' \
        '-f[fold the key to lower case (disable case-sensitivity)]' \
        '-i[incremental update (do not truncate)]' \
        '-j[JSON output for queries]' \
        '-n[do not include comments + empty lines in output]' \
        '-o[do not release exclusive lock during the rebuild]' \
        '-p[do not inherit source-file permissions]' \
        '-q+[query for one key]:key:' \
        '-d+[delete one key]:key:' \
        '-r[do not warn on duplicates; replace silently]' \
        '-s[print first line of each alias for diagnostics]' \
        '-u[do not fold to lower case (case-sensitive)]' \
        '*-v[verbose logging]' \
        '-w[do not warn on existing aliases]' \
        '-c+[config directory]:dir:_files -/' \
        '*:file:_files'
}

_postalias "$@"
