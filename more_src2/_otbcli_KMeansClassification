#compdef otbcli_KMeansClassification
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_KMeansClassification.html
# Source: orfeotoolbox/OTB KMeansClassification — unsupervised K-means image classification.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[classified output (labels)]:image:_files' \
    '-nc+[number of classes (default 5)]:n:_default' \
    '-ts+[training set size in pixels (default 100)]:n:_default' \
    '-maxit+[max iterations (0=until convergence, default 1000)]:n:_default' \
    '-centroids.in+[initial centroids file]:file:_files' \
    '-centroids.out+[final centroids file]:file:_files' \
    '-sampler+[sampling strategy]:strategy:(periodic random)' \
    '-sampler.periodic.jitter+[periodic-sampler jitter]:value:_default' \
    '-vm+[binary mask (analyze nonzero only)]:image:_files' \
    '-nodatalabel+[label for masked pixels (default 0)]:label:_default' \
    '-cleanup+[(true/false) clean temp files]:bool:(true false)' \
    '-rand+[random seed]:seed:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
