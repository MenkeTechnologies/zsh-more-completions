#compdef geolookup
# Documentation: https://raw.githubusercontent.com/phaag/nfdump/master/man/geolookup.1
# Reference accessed: 2026-05-30
# geolookup — GeoIP/ASN lookup helper for nfdump. Builds a binary DB from CSV or queries existing DB.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-d+[directory of CSV files to build binary lookup DB]:dir:_directories' \
  '-w+[output binary lookup DB file to create]:file:_files' \
  '-G+[use binary geoDB file for AS + location lookups]:file:_files' \
  '*:IP / AS query:' \
  && ret=0

return ret
