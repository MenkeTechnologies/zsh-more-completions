#compdef mptcpd
# Documentation: source-direct extraction from upstream
# multipath-tcp/mptcpd —
#   src/configuration.c lines 358-415 (the
#     `static struct argp_option const options[]` array)
#   src/configuration.c lines 84-91 (the get_log_set_function
#     destination enum: stderr | syslog | journal | null)
#   src/configuration.c lines 120-123 (the addr_flags enum:
#     subflow | signal | backup | fullmesh)
#   src/configuration.c lines 172-174 (the notify_flags enum:
#     existing | skip_link_local | skip_loopback)
# Reference accessed: 2026-05-30 via gh api.
#
# mptcpd is the Intel-origin Multipath TCP (MPTCP) path-
# manager daemon — runs in userspace, talks to the kernel via
# NETLINK_GENERIC's mptcp_pm family, and configures per-flow
# MPTCP subflow announcements + endpoints + address-family
# notifications.  Used to make MPTCP-aware applications
# transparently establish multi-link subflows over LTE + WiFi +
# Ethernet on a multi-homed host.  Plugin-driven architecture
# (sspi = single-subflow-per-interface; addr_adv = address
# advertisement; user-supplied plugins via --load-plugins).
#
# Critical extraction note: mptcpd uses **argp** (the
# argp_parse() API from <argp.h>), NOT getopt_long.  The
# options table at configuration.c:374-415 uses non-ASCII key
# values (>= 0x100) for long-only flags — this is the canonical
# argp idiom for "long option with no short alias".  5 of the 7
# flags use this pattern:
#   MPTCPD_PLUGIN_DIR_KEY   = 0x100 (--plugin-dir)
#   MPTCPD_PATH_MANAGER_KEY = 0x101 (--path-manager)
#   MPTCPD_ADDR_FLAGS_KEY   = 0x102 (--addr-flags)
#   MPTCPD_NOTIFY_FLAGS_KEY = 0x103 (--notify-flags)
#   MPTCPD_LOAD_PLUGINS_KEY = 0x104 (--load-plugins)
# Only `-d`/`--debug` and `-l`/`--log` have short aliases.
# Plus argp adds the standard `--help`, `-?`, `--usage`,
# `--version`, `-V` automatically.

local -a addr_flag_values=(subflow signal backup fullmesh)
local -a notify_flag_values=(existing skip_link_local skip_loopback)
local -a log_destinations=(stderr syslog journal null)

_arguments -s -S \
  '(-d --debug)'{-d,--debug}'[enable debug log messages]' \
  '(-l --log)'{-l+,--log=}'[log destination]:destination:(stderr syslog journal null)' \
  '--plugin-dir=[set plugin directory to DIR]:dir:_files -/' \
  '--path-manager=[default path manager plugin (e.g. sspi); overrides plugin priorities]:plugin:' \
  '--addr-flags=[flags for announced address (comma list: subflow|signal|backup|fullmesh)]:flags:_values -s , flags subflow signal backup fullmesh' \
  '--notify-flags=[address notification flags (comma list: existing|skip_link_local|skip_loopback)]:flags:_values -s , flags existing skip_link_local skip_loopback' \
  '--load-plugins=[plugins to load (comma list, e.g. addr_adv,sspi)]:plugins:' \
  '(-? --help)'{-\?,--help}'[give this help list (argp standard)]' \
  '--usage[give a short usage message (argp standard)]' \
  '(-V --version)'{-V,--version}'[print program version (argp standard)]'
