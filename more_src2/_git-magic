#compdef git-magic git-merge-repo git-missing git-obliterate git-pr git-rename-tag git-root git-scp git-setup
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 3. Companion to rounds 150 (_git-effort) and
# 151 (_git-abort) + the pre-existing _git-changelog / _git-info /
# _git-ignore standalone files.
# Hunt-skip log this round: git-undo collides with the pre-existing
# more_src/_ugit which already #compdefs the git-undo stem.

local curcontext="$curcontext" state line ret=1

case $service in

  git-magic)
    # man/git-magic.1 — quick commit-and-push helper.
    #   git-magic [-a] [-m msg] [-e] [-p] [-f]
    _arguments -s -S \
      '(- *)-h[show synopsis]' \
      '-a[add everything including untracked]' \
      '*-m+[commit message (repeatable; concatenated as paragraphs)]:msg:' \
      '-e[edit the auto-generated message before commit]' \
      '-p[run git push after commit]' \
      '-f[add -f to git push]' \
      && ret=0
    ;;

  git-merge-repo)
    # man/git-merge-repo.1 — merge an external repository into a subtree.
    #   git-merge-repo <repo> <branch> <directory> [--squash]
    _arguments -s -S \
      '--squash[skip history, generate a single merge commit]' \
      '1:source repo URL or path:' \
      '2:branch to merge:' \
      '3:destination directory:_files -/' \
      && ret=0
    ;;

  git-missing)
    # man/git-missing.1 — list commits in one branch not in another.
    #   git-missing [<first branch>] <second branch> [<git log options>]
    _arguments -s -S \
      '1:first branch (default current):__git_branch_names' \
      '2:second branch:__git_branch_names' \
      '*::git log option:' \
      && ret=0
    ;;

  git-obliterate)
    # man/git-obliterate.1 — erase files from the entire git history.
    #   git obliterate <files...> [-- <rev-list options...>]
    _arguments -s -S \
      '*:file to obliterate:_files' \
      '*::rev-list options after --:' \
      && ret=0
    ;;

  git-pr)
    # man/git-pr.1 — GitHub pull request checkout.
    #   git-pr [-m|--merge] <number> [<remote>]
    #   git-pr [-m|--merge] <[remote]:number>...
    #   git-pr [-m|--merge] <url>...
    #   git-pr clean
    _arguments -s -S \
      '(-m --merge)-m[checkout merge commit against target branch]' \
      '(-m --merge)--merge[checkout merge commit against target branch]' \
      '*:PR number / remote:number / URL / "clean":' \
      && ret=0
    ;;

  git-rename-tag)
    # man/git-rename-tag.1 — rename a git tag locally + remotely.
    #   git-rename-tag <old-tag-name> <new-tag-name>
    _arguments -s -S \
      '1:old tag name:__git_tags' \
      '2:new tag name:' \
      && ret=0
    ;;

  git-root)
    # man/git-root.1 — print the absolute or relative repo root path.
    _arguments -s -S \
      '(-r --relative)-r[show relative path from root to cwd]' \
      '(-r --relative)--relative[show relative path from root to cwd]' \
      && ret=0
    ;;

  git-scp)
    # man/git-scp.1 — secure-copy git changes via remote.
    #   git scp -h|help|?
    #   git scp <remote> [<commits>...|<path>...]
    # Note: companion `git rscp` swaps the direction (remote→local).
    _arguments -s -S \
      '(- *)-h[help]' \
      '1:remote:__git_remotes' \
      '*:commits or paths:_files' \
      && ret=0
    ;;

  git-setup)
    # man/git-setup.1 — initialize a new repo in DIR (default cwd).
    _arguments -s -S \
      '1:directory to initialize (default cwd):_files -/' \
      && ret=0
    ;;

esac

return ret
