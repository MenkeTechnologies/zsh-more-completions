#compdef pgagroal
# _pgagroal — high-performance PostgreSQL connection pool (agroal/pgagroal)
# upstream: https://github.com/agroal/pgagroal
# Flags from src/main.c (getopt_long).

_pgagroal() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[main config file]:file:_files -g "*.conf"' \
        '(-a --hba)'{-a+,--hba=}'[HBA config file]:file:_files -g "*.conf"' \
        '(-l --limit)'{-l+,--limit=}'[limit config file]:file:_files -g "*.conf"' \
        '(-u --users)'{-u+,--users=}'[users file]:file:_files -g "*.conf"' \
        '(-F --frontend)'{-F+,--frontend=}'[frontend users file]:file:_files -g "*.conf"' \
        '(-A --admins)'{-A+,--admins=}'[admins file]:file:_files -g "*.conf"' \
        '(-S --superuser)'{-S+,--superuser=}'[superuser file]:file:_files -g "*.conf"' \
        '(-D --directory)'{-D+,--directory=}'[base directory]:dir:_files -/' \
        '(-d --daemon)'{-d,--daemon}'[run as daemon]'
}

_pgagroal "$@"
