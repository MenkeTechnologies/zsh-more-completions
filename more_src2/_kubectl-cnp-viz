#compdef kubectl-cnp-viz
# Documentation: https://github.com/mostafahussein/kubectl-cnp-viz
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cmd/plugin/cli/root.go flags).

# kubectl-cnp-viz (mostafahussein/kubectl-cnp-viz): visualize Cilium Network
# Policies. Own flags below plus the standard genericclioptions set.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--scale=[scaling factor]:factor:' \
  '--x=[reposition the diagram along the horizontal axis]:x:' \
  '--y=[reposition the diagram along the vertical axis]:y:' \
  '--outputdir=[directory to store output files]:dir:_files -/' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--context=[kubeconfig context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '*:policy:_default'
