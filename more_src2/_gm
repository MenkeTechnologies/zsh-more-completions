#compdef gm
# Documentation: http://www.graphicsmagick.org/GraphicsMagick.html
# Source: manpages.debian.org/bookworm/graphicsmagick/gm.1.en.html
# Reference accessed: 2026-05-30
# gm — GraphicsMagick: single-binary image processing suite (ImageMagick fork).
# Dispatches to 14 sub-utilities. Per-subcmd flag sets are huge (200+ each);
# this completion covers the 30+ most common flags shared by the file-output
# utilities (convert/mogrify/composite/montage/etc).

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'animate:display an animation (e.g. GIF) on an X display'
  'batch:execute multiple gm utility commands as a linear batch script'
  'benchmark:run a subcommand N times and report perf metrics'
  'compare:compare two images and report difference statistics'
  'composite:blend/merge images to create new images'
  'conjure:interpret + execute MSL (Magick Scripting Language) scripts'
  'convert:convert input format to output format, applying transformations'
  'display:machine-architecture-independent image viewer (X server)'
  'help:show help for a subcommand'
  'identify:describe format + characteristics of one or more images'
  'import:read an image from a visible X server window'
  'mogrify:transform images in place (overwrites originals)'
  'montage:tile multiple images into a single composite'
  'time:run a subcommand and report CPU+wall time consumed'
  'version:show GraphicsMagick version, features, copyright'
)

# Shared format value table (subset of GraphicsMagick-supported formats).
local -a _formats
_formats=(JPEG JPG PNG GIF BMP TIFF TIF PDF PS EPS SVG WEBP HEIC HEIF \
          AVIF JP2 JXR PCX TGA XPM XBM PNM PPM PGM PBM ICO ICON \
          PSD DDS DPX EXR FITS HDR MAT MIFF MNG MPC SGI VIFF YUV \
          MVG WMF WPG XCF NETPBM RGB RGBA CMYK CMYKA HISTOGRAM \
          NULL TXT INFO MAP CLIPBOARD FAX X11)

# Common flags shared by convert/mogrify/composite/montage/etc.
local -a _common_flags
_common_flags=(
  '*-resize+[resize image]:geometry (e.g. 800x600 or 50%):'
  '*-quality+[output quality 0-100]:N:'
  '*-rotate+[rotate by degrees]:degrees:'
  '*-crop+[crop region]:geometry:'
  '*-format+[output image format]:fmt:_describe -t formats "format" _formats'
  '*-colorspace+[set colorspace]:cs:(RGB CMYK GRAY YUV YIQ XYZ Lab HSL HSV HCL OHTA CMY Rec601Luma Rec709Luma sRGB Transparent)'
  '*-density+[resolution]:dpi:'
  '*-background+[background color]:color:'
  '-flatten[flatten layered images to a single image]'
  '-strip[strip metadata profiles (EXIF, IPTC, XMP, color profile)]'
  '*-thumbnail+[fast resize for thumbnails]:geometry:'
  '*-gravity+[anchor for composition / cropping]:gravity:(NorthWest North NorthEast West Center East SouthWest South SouthEast)'
  '*-compose+[composite operator]:op:(Over In Out Atop Xor Plus Minus Add Subtract Difference Multiply Bumpmap Copy CopyRed CopyGreen CopyBlue CopyOpacity CopyCyan CopyMagenta CopyYellow CopyBlack Threshold)'
  '*-border+[add border]:geometry:'
  '*-depth+[bits per channel]:N:(1 4 8 16 32)'
  '*-extent+[set canvas size]:geometry:'
  '*-filter+[resize filter]:filter:(Point Hermite Cubic Box Gaussian Quadratic Triangle Mitchell Sinc Bessel Hanning Hamming Blackman Catrom Lanczos Bohman Parzen Kaiser Welsh Cosine)'
  '*-fuzz+[colour distance tolerance]:percent-or-value:'
  '*-gamma+[gamma correction]:value:'
  '-monochrome[reduce to black/white]'
  '-normalize[stretch range to full dynamic range]'
  '*-profile+[ICC/IPTC/EXIF profile to embed]:profile-file:_files'
  '*-sharpen+[sharpen by Gaussian]:radius{xsigma}:'
  '*-size+[size hint for raw images]:geometry:'
  '-trim[trim outer rows/cols of background colour]'
  '*-type+[image type]:type:(Bilevel Grayscale GrayscaleMatte Palette PaletteMatte TrueColor TrueColorMatte ColorSeparation ColorSeparationMatte Optimize)'
  '*-units+[resolution units]:units:(Undefined PixelsPerInch PixelsPerCentimeter)'
  '-verbose[print detailed information]'
  '*-compress+[compression algorithm]:c:(None BZip Fax Group4 JPEG JPEG2000 Lossless LZW RLE Zip)'
  '*-frame+[add ornamental border]:geometry:'
  '*-geometry+[size + offset]:geometry:'
  '*-interlace+[interlace scheme]:il:(None Line Plane Partition GIF JPEG PNG)'
  '*-modulate+[brightness/saturation/hue percent]:brightness{,saturation{,hue}}:'
  '-negate[replace each pixel with complementary colour]'
  '*-page+[page size + offset for PostScript/PDF]:geometry-or-name:'
  '*-roll+[roll image by offsets]:geometry:'
  '*-sample+[scale by sampling pixels]:geometry:'
  '*-scale+[scale image to size]:geometry:'
  '*-shave+[shave pixels off edges]:geometry:'
  '*-tile+[tile pattern for montage / convert]:tile-image:_files'
  '-version[show version and exit]'
)

# X11/display flags for display/animate/import.
local -a _x_flags
_x_flags=(
  '*-display+[X server]:display:'
  '*-window+[target window]:id-or-name:'
  '*-window-id+[X11 window id]:wid:'
  '*-window-group+[X11 window group]:wid:'
  '*-iconic[start in iconified state]'
  '*-name+[window manager hint name]:name:'
  '*-title+[window title]:title:'
  '*-update+[refresh image periodically]:seconds:'
  '*-visual+[X visual class]:visual:(StaticGray GrayScale StaticColor PseudoColor TrueColor DirectColor)'
  '*-colormap+[colormap type]:cm:(private shared)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,-version,--version}'[show version]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'gm subcommand' _subcmds && ret=0
    ;;
  args)
    curcontext="${curcontext%:*:*}:gm-$line[1]:"
    case $line[1] in
      convert|mogrify|composite|montage|compare)
        _arguments -s -S \
          $_common_flags \
          '*:image file:_files -g "*.(#i)(jp{,e}g|png|gif|bmp|tif{,f}|webp|heic|heif|avif|svg|pdf|psd|tga|xpm|xbm|pn{m,g,b}|p{p,g,b}m|ico|jp2|j{xr,xl}|dds|dpx|exr|hdr|miff|mng|sgi|yuv|xcf|wmf|mvg)"' \
          && ret=0
        ;;
      identify)
        _arguments -s -S \
          '-format+[output format string (escape sequence)]:fmt-string:' \
          '-verbose[detailed information]' \
          '-ping[only ping image, do not decode]' \
          '-regard-warnings[treat warnings as errors]' \
          '-size+[size hint]:geometry:' \
          '-density+[resolution]:dpi:' \
          '-depth+[bits per channel]:N:(1 4 8 16 32)' \
          '-debug+[debug categories]:cats:' \
          '*:image file:_files' \
          && ret=0
        ;;
      display|animate)
        _arguments -s -S \
          $_x_flags \
          '*-delay+[animation delay (1/100 sec)]:ticks:' \
          '*-pause+[seconds between images]:seconds:' \
          '*-loop+[repeat count for animation]:N:' \
          '*-rotate+[rotate image]:degrees:' \
          '*-resize+[resize image]:geometry:' \
          '*-quality+[quality 0-100]:N:' \
          '*-gamma+[gamma correction]:value:' \
          '*-magnify+[magnify factor]:N:' \
          '*-immutable[disable interactive editing]' \
          '*-treedepth+[colour reduction tree depth]:N:' \
          '*-verbose[detailed information]' \
          '*:image file:_files' \
          && ret=0
        ;;
      import)
        _arguments -s -S \
          $_x_flags \
          '*-crop+[crop region]:geometry:' \
          '*-frame[include WM frame]' \
          '*-border+[border geometry]:geometry:' \
          '*-delay+[delay before snap]:ms:' \
          '*-mosaic[combine multiple captures]' \
          '*-resize+[resize after capture]:geometry:' \
          '*-screen[capture from root window]' \
          '*-silent[suppress shutter beep]' \
          '*-snaps+[number of screen snapshots]:N:' \
          '1:output file:_files' \
          && ret=0
        ;;
      benchmark)
        _arguments -s -S \
          '-duration+[run for N seconds]:seconds:' \
          '-iterations+[run N iterations]:N:' \
          '-stepthreads+[step thread count]:N:' \
          '-rawcsv[output raw CSV]' \
          '*:: :->sub' \
          && ret=0
        [[ $state == sub ]] && _describe -t commands 'gm subcommand' _subcmds && ret=0
        ;;
      time)
        _arguments -C '*:: :->sub' && ret=0
        [[ $state == sub ]] && _describe -t commands 'gm subcommand' _subcmds && ret=0
        ;;
      conjure)
        _arguments -s -S \
          '*-set+[set MSL variable]:name=value:' \
          '-monitor[show progress monitor]' \
          '-verbose[detailed information]' \
          '-debug+[debug categories]:cats:' \
          '*:MSL script:_files -g "*.msl"' \
          && ret=0
        ;;
      batch)
        _arguments -s -S \
          '-echo+[echo command lines]:state:(on off)' \
          '-feedback+[print prompts]:state:(on off)' \
          '-pass+[exit success status]:state:(on off)' \
          '-fail+[exit failure status]:state:(on off)' \
          '-prompt+[prompt string]:string:' \
          '-escape+[escape syntax]:e:(none windows)' \
          '-stop-on-error+[abort on error]:state:(on off)' \
          '*:batch script:_files' \
          && ret=0
        ;;
      help)
        _describe -t commands 'gm subcommand' _subcmds && ret=0
        ;;
      version)
        _arguments '*:argument:' && ret=0
        ;;
      *)
        _arguments '*:image file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
