#compdef dumpimage
# Documentation: https://man.archlinux.org/man/extra/uboot-tools/dumpimage.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# U-Boot dumpimage(1) — list and extract data from U-Boot images

_arguments -s \
  '(- *)-h[print usage information and exit]' \
  '(- *)-V[print version information and exit]' \
  '-l[print header information and list components]' \
  '-o+[file to write dumped component to]:file:_files' \
  '-p+[component index to dump (default 0)]:position:' \
  '-T+[image type (auto-detected if omitted)]:type:' \
  ':image:_files'
