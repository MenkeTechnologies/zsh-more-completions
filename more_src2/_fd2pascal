#compdef fd2pascal
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/fd2pascal-3.2.2.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-altformat[emit global variables instead of a record type]' \
  '-compensate[emit fl_adjust_form_size after form creation]' \
  '-callback[generate a callback procedure for each widget]' \
  '-main[generate a program file instead of a unit]' \
  '*:input FD file:_files -g "*.fd"' && ret=0

return ret
