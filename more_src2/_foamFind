#compdef foamFind
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamFind — locate / grep / edit files across $FOAM_APP, $FOAM_MODULES, $FOAM_TUTORIALS.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a -applications -m -modules -t -tutorials -d -dir)'{-a,-applications}'[search from $FOAM_APP]' \
    '(-a -applications -m -modules -t -tutorials -d -dir)'{-m,-modules}'[search from $FOAM_MODULES]' \
    '(-a -applications -m -modules -t -tutorials -d -dir)'{-t,-tutorials}'[search from $FOAM_TUTORIALS]' \
    '(-a -applications -m -modules -t -tutorials -d -dir)'{-d,-dir}'[explicit search directory]:dir:_directories' \
    '(-c -coded)'{-c,-coded}'[insert entries to codeInclude/codeOptions/codeLibs of a coded input]:file:_files' \
    '(-e -edit)'{-e,-edit}'[open match in a file editor]' \
    '(-f -files)'{-f,-files}'[find wmake "files" associated with searched file]' \
    '(-h -help)'{-h,-help}'[print usage]' \
    '(-i -isearch -s -search)'{-i,-isearch}'[search files for <string> case-insensitive]:string:' \
    '(-i -isearch -s -search)'{-s,-search}'[search files for <string> case-sensitive]:string:' \
    '(-l -lnInclude)'{-l,-lnInclude}'[find lnInclude dir; print -I/-l for options file]' \
    '(-n -numbers)'{-n,-numbers}'[print line numbers with file output]' \
    '(-o -options)'{-o,-options}'[find wmake "options" associated with searched file]' \
    '(-p -print)'{-p,-print}'[print the file(s)]' \
    '*:file or pattern:' \
    && ret=0

return ret
