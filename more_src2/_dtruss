#compdef dtruss
# Documentation: https://www.unix.com/man-page/osx/1m/dtruss/
# Source: Apple macOS — DTrace-based strace(1)-like syscall tracer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[print all details]' \
    '-b[dynamic-variable buffer size (default 4m)]:size:' \
    '-c[print syscall counts]' \
    '-d[print relative timestamps (us)]' \
    '-e[print elapsed times (us)]' \
    '-f[follow forked children]' \
    '(-l -L)-l[force printing of pid/lwpid per line]' \
    '(-l -L)-L[do not print pid/lwpid per line]' \
    '-n[examine processes with this name]:name:' \
    '-o[print on-cpu times (us)]' \
    '-s[print stack backtraces]' \
    '-p[examine this PID]:pid:_pids' \
    '*-t[examine this syscall only]:syscall:' \
    '*:command and args:_command_names -e' \
    && ret=0

return ret
