#compdef git-tracker
# Documentation: https://github.com/stevenharman/git_tracker
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-tracker installs a prepare-commit-msg hook to prepend Pivotal Tracker
# story numbers to commit messages. Its only documented command is `init`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:(init)' && ret=0

return ret
