#compdef gnt-os
# _gnt-os — Google Ganeti gnt-os CLI for managing OS installation providers in the Ganeti virtualisation cluster listing variants modify parameters diagnose verify info debug-os checking image scripts (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-os() {
    local -a sub=(
        'diagnose:diagnose all OS providers'
        'info:show OS info'
        'list:list OS providers'
        'modify:modify OS parameters'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '--reason=+[text]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-os subcommand' sub ;;
        args)
            case $words[1] in
                modify) _arguments \
                    '--osparams=+[K=V csv]:str:' \
                    '--hidden=+[b]:b:(yes no)' \
                    '--blacklisted=+[b]:b:(yes no)' \
                    '*:OS name:' ;;
                info) _arguments '*:OS name:' ;;
                list) _arguments \
                    '--all[show all]' ;;
            esac
            ;;
    esac
}

_gnt-os "$@"
