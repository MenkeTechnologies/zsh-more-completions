#compdef dax
# Documentation: https://github.com/dsherret/dax
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-q[quiet output]' \
  '--quiet[quiet output]' \
  '*:script file:_files -g "*.{ts,js,mts,mjs}"' && ret=0

return ret
