#compdef python3.14
# Documentation: https://docs.python.org/3.14/using/cmdline.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above; matches `python3.14 --help`
# output on this system.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-b[issue warnings about bytes/bytearray to str conversion]' \
  '-B[do not write .pyc files on import]' \
  '*-c+[program passed in as string]:cmd:' \
  '-d[parser debugging output]' \
  '-E[ignore PYTHON* environment variables]' \
  '-h[show help]' \
  '-i[interactive after running script]' \
  '-I[isolate Python from user environment]' \
  '*-m+[run library module as script]:module:' \
  '-O[remove assert and __debug__ statements]' \
  '-OO[same as -O plus discard docstrings]' \
  '-P[do not prepend path to sys.path]' \
  '-q[quiet startup]' \
  '-s[do not add user site directory to sys.path]' \
  '-S[do not import site on initialization]' \
  '-u[unbuffered stdout/stderr]' \
  '*-v[verbose imports]' \
  '-V[print version]' \
  '*-W+[warning control]:arg:' \
  '-x[skip first line of source]' \
  '*-X+[implementation-specific option]:opt:' \
  '--check-hash-based-pycs=[hash-based .pyc invalidation]:flag:(always default never)' \
  '--help-env[help on environment variables]' \
  '--help-xoptions[help on -X options]' \
  '--help-all[full help]' \
  '*:script:_files -g "*.py"' && ret=0

return ret
