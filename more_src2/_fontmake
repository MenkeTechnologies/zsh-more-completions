#compdef fontmake
# Documentation: upstream Lib/fontmake/__main__.py at
# github.com/googlefonts/fontmake
# Reference accessed: 2026-05-30 via gh api inspection of every
# argparse add_argument call.
# fontmake R111 — Google Fonts builder that converts UFO/Glyphs/
# Designspace source files into OTF/TTF binary fonts.

local -a _output_formats _ufo_structures _overlap_backends _subroutinizer
_output_formats=( otf ttf otf-cff2 variable variable-cff2 )
_ufo_structures=( package zip json )
_overlap_backends=( booleanOperations pathops )
_subroutinizer=( cffsubr compreffor )

_arguments -s -S \
  '(-g --glyphs-path)'{-g,--glyphs-path}'=[input .glyphs source file]:file:_files -g "*.glyphs"' \
  '(-u --ufo-paths)*'{-u,--ufo-paths}'=[input UFO/UFOZ files (repeatable)]:file:_files' \
  '(-m --mm-designspace)'{-m,--mm-designspace}'=[input Designspace file]:file:_files -g "*.designspace"' \
  '--glyph-data=[Glyphs data file]:file:_files' \
  '(-o --output)*'{-o,--output}'=[output format(s)]:format:($_output_formats)' \
  '--output-path=[single binary output filename]:file:_files' \
  '--output-dir=[output directory]:dir:_directories' \
  '(-i --interpolate)'{-i,--interpolate}'[interpolate instances from defined exports]' \
  '--variable-fonts=[regex of variable-font names to build]:regex:' \
  '(-M --masters-as-instances)'{-M,--masters-as-instances}'[treat masters as instances]' \
  '--family-name=[override family name]:name:' \
  '--round-instances[round instance coordinates to nearest integer]' \
  '--designspace-path=[output Designspace file path]:file:_files' \
  '--master-dir=[output directory for master UFOs]:dir:_directories' \
  '--instance-dir=[output directory for instance UFOs]:dir:_directories' \
  '--no-write-skipexportglyphs[do not write skipExportGlyphs lib key]' \
  '--validate-ufo[validate UFOs while loading]' \
  '--check-compatibility[check master compatibility]' \
  '--no-check-compatibility[skip compatibility check]' \
  '--expand-features-to-instances[expand .fea features into per-instance UFO]' \
  '--fea-include-dir=[directory for .fea include lookups]:dir:_directories' \
  '--save-ufo-as-zip[save Glyphs sources as UFO zip format]' \
  '--ufo-structure=[UFO output structure]:structure:($_ufo_structures)' \
  '--indent-json[indent UFO JSON output]' \
  '--keep-overlaps[retain overlapping contours]' \
  '--overlaps-backend=[overlap removal backend]:backend:($_overlap_backends)' \
  '--keep-direction[preserve contour direction]' \
  '--ttf-curves=[TTF curve type]:curves:(cubic mixed quadratic)' \
  '(-e --conversion-error)'{-e,--conversion-error}'=[max acceptable cubic-to-quadratic conversion error]:f:' \
  '(-f --flatten-components)'{-f,--flatten-components}'[decompose nested components]' \
  '(-a --autohint)'{-a,--autohint}'=[autohint options string]:options:' \
  '(-A --no-autohint)'{-A,--no-autohint}'[disable autohinting]' \
  '--cff-round-tolerance=[CFF coordinate rounding tolerance]:f:' \
  '--optimize-cff=[CFF optimization mode]:mode:(NONE NO_SUBROUTINIZE SUBROUTINIZE)' \
  '--subroutinizer=[CFF subroutinizer backend]:backend:($_subroutinizer)' \
  '--no-optimize-gvar[do not optimize gvar table]' \
  '*--filter=[filter spec (repeatable)]:spec:' \
  '--no-auto-use-my-metrics[disable auto USE_MY_METRICS]' \
  '--auto-use-my-metrics[enable auto USE_MY_METRICS]' \
  '--drop-implied-oncurves[drop implied on-curve points]' \
  '--interpolate-binary-layout=[binary layout interpolation directory]:dir:_directories' \
  '*--feature-writer=[fontTools feature-writer class]:class:' \
  '--debug-feature-file=[write resolved feature file for debugging]:file:_files' \
  '--no-variable-features[disable variable feature processing]' \
  '--mti-source=[MTI source plist]:file:_files' \
  '--production-names[use glyph production names]' \
  '--no-production-names[use glyph development names]' \
  '--subset[apply OpenType subsetting]' \
  '--no-subset[do not apply OpenType subsetting]' \
  '(-s --subroutinize)'{-s,--subroutinize}'[run CFF subroutinization]' \
  '(-S --no-subroutinize)'{-S,--no-subroutinize}'[disable CFF subroutinization]' \
  '--timing[print elapsed time per step]' \
  '--verbose=[verbosity level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
  '(- *)--version[show version]' \
  '*:positional input file (UFO/Glyphs/Designspace):_files'
