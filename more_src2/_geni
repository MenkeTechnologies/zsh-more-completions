#compdef geni
# Documentation: https://github.com/emilpriver/geni
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for geni DB migrations (emilpriver/geni, clap 4)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--database-url[DATABASE_URL]:url' \
  '--ssh-host[SSH bastion host]:host' \
  '--ssh-user[SSH username]:user' \
  '--ssh-port[SSH port]:port' \
  '--ssh-identity-file[SSH private key]:file:_files' \
  '--ssh-local-port[tunnel local port]:port' \
  '--ssh-remote-host[remote DB host from bastion]:host' \
  '--ssh-remote-port[remote DB port]:port' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(new up down create drop status dump)
    _describe -t commands 'geni command' commands && ret=0
    ;;
  args)
    case $words[1] in
      new)
        _arguments '1:migration name:' && ret=0
        ;;
      down)
        _arguments '(-a --amount)'{-a,--amount}'+[migrations to roll back]:count' && ret=0
        ;;
      status)
        _arguments '(-v --verbose)'{-v,--verbose}'[print SQL for pending migrations]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
