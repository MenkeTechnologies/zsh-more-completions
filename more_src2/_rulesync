#compdef rulesync
# Documentation: https://github.com/dyoshikawa/rulesync
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for rulesync - AI coding agent rules sync utility

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:create necessary directories, sample rule files, and configuration file'
  'fetch:retrieve external skills/resources from a repo'
  'generate:generate unified configurations with all features'
  'import:import existing tool config files into .rulesync/'
  'convert:transform configuration between tools directly'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'rulesync command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate|import)
        _arguments \
          '*--targets=[target AI tools (or "*" for all)]:targets' \
          '*--features=[features to include (rules ignore mcp commands subagents skills hooks permissions or "*")]:features' && ret=0
        ;;
      convert)
        _arguments \
          '--from=[source AI tool format]:from' \
          '--to=[destination AI tool format(s)]:to' && ret=0
        ;;
      fetch)
        _arguments \
          '*--features=[features to fetch]:features' \
          '*:repo:' && ret=0
        ;;
    esac
    ;;
esac

return ret
