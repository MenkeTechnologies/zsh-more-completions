#compdef grpcfedctl
# =============================================================================
# grpcfedctl — mercari/grpc-federation's user-
#   facing Go CLI for managing the gRPC-
#   FEDERATION code-generation toolchain — a
#   Backend-for-Frontend (BFF) auto-generator
#   that aggregates microservice gRPC results
#   based on Protocol Buffer options.  Built
#   on direct `tetratelabs/wazero v1.10.1` —
#   the canonical pure-Go WebAssembly runtime
#   from Tetrate — which grpcfedctl uses to
#   PRE-COMPILE gRPC-Federation plugin .wasm
#   modules into wazero's on-disk compilation
#   cache so production startup avoids the
#   JIT-warmup cost.  Go=104 leader bump
#   continuing Axis 49 (WebAssembly Runtime)
#   at the Go pole, opened by R785
#   `_wassette` (Rust=104, wasmtime 36.0.5).
#
# AXIS 49 — WEBASSEMBLY RUNTIME — GO POLE
# ========================================
# `tetratelabs/wazero` (6.5k+ stars on GitHub,
# Apache-2.0) is the canonical PURE-GO Wasm
# runtime — zero cgo, zero dynamic linking,
# embeds inside any Go binary as a single
# Go-modulearable dependency.  Ships an
# INTERPRETER backend for portability and an
# OPTIMIZING COMPILER backend for performance.
# Supports WASI Preview 1 + a partial Preview 2
# shim through the goccy/wasi-go fork.
# Distinguishes from other corpus Wasm-runtime
# choices:
#   - WASMTIME (Axis 49 Rust)                  Cranelift
#                                              JIT + WASI
#                                              Preview 2 +
#                                              Component
#                                              Model.
#                                              Production
#                                              runtime
#                                              backed by
#                                              the
#                                              Bytecode
#                                              Alliance
#   - WAZERO (Axis 49 Go — THIS)               pure-Go,
#                                              zero-cgo,
#                                              embeddable.
#                                              No JIT (uses
#                                              its own
#                                              optimizing
#                                              compiler).
#                                              Designed for
#                                              the
#                                              embedded-
#                                              plugin
#                                              use-case
#   - WASMER (legacy)                          cgo wrapper
#                                              around the
#                                              wasmer-c
#                                              library.
#                                              Heavier
#                                              dependency
#                                              footprint
#                                              than wazero
#
# Other Axis 49 implementations across the corpus:
#   * Rust       (R785): wasmtime 36.0.5
#                — wassette runs WebAssembly
#                  Components via MCP
#   * Go         (R786, THIS ROUND): tetratelabs/
#                wazero v1.10.1 — grpcfedctl
#                pre-compiles Wasm plugins to
#                wazero's compilation cache
#   * TS-Node    (R787 will close): @bytecode
#                alliance/jco or @bytecode
#                alliance/preview2-shim
#
# Distinguishing grpc-federation from other
# corpus BFF / aggregation tools:
#   - PROTO-DRIVEN BFF GENERATION — instead of
#     writing the BFF Go code by hand,
#     grpc-federation reads `option (mercari.
#     grpc.federation.message)` annotations in
#     .proto files and generates a complete
#     gRPC BFF server that fans out to
#     upstream microservices.  No "service-
#     mesh", no manual aggregation
#   - CEL EXPRESSION LANGUAGE — uses
#     `google/cel-go v0.23.1` (Common
#     Expression Language) for in-proto
#     transformations.  CEL is Google's
#     embedded expression language with
#     static type checking; used here for
#     field mapping, conditional dependency
#     resolution, and validation
#   - DEPENDENCY GRAPH OPTIMISATION — the
#     generator extracts a DAG of method
#     calls from the proto options and emits
#     code that maximises PARALLEL fan-out
#     while respecting upstream dependencies.
#     No manual goroutine choreography
#   - DECLARATIVE RETRIES + TIMEOUTS — proto
#     options like `retry = {count: 3,
#     backoff: "1s"}` and `timeout = "5s"`
#     are baked into the generated client
#     calls.  Uses `cenkalti/backoff/v4`
#     under the hood
#   - WASM-PLUGIN EXTENSION POINT — custom
#     resolvers + transformations can be
#     written in any language that compiles
#     to Wasm.  At runtime the generated BFF
#     loads the .wasm module via wazero and
#     calls into it.  grpcfedctl's `plugin
#     cache create` PRE-COMPILES these
#     plugins to a wazero compilation cache
#     so cold-start avoids JIT compilation
#   - WASI-GO + WASI-GO-NET — uses
#     `goccy/wasi-go v0.3.2` (Yusuke Goccy's
#     fork of dispatchrun/wasi-go) for WASI
#     Preview 1+ implementation and
#     `goccy/wasi-go-net v0.3.0` for a
#     network layer that lets Wasm plugins
#     make outbound TCP / TLS / HTTP calls
#   - LSP-FRIENDLY DESIGN — the package ships
#     `grpc-federation-language-server`
#     (a separate binary) that speaks LSP
#     for proto-file editor integration.
#     Uses `go.lsp.dev/protocol v0.12.0`
#   - MCP TOOL FRONTEND — the package also
#     ships `grpc-federation-mcp-server`,
#     a Model Context Protocol server that
#     exposes the federation toolchain to
#     AI agents.  Uses `mark3labs/mcp-go
#     v0.32.0`
#
# PACKAGE BINARY MATRIX (all under cmd/):
#   * grpcfedctl                       — THIS binary;
#                                        user-facing
#                                        plugin/version
#                                        management
#   * grpc-federation-generator        — the codegen
#                                        engine that
#                                        emits the
#                                        Go BFF code
#                                        from proto
#                                        files
#   * protoc-gen-grpc-federation       — same engine
#                                        wrapped as a
#                                        protoc plugin
#   * grpc-federation-linter           — checks proto
#                                        files for
#                                        invalid
#                                        federation
#                                        annotations
#   * grpc-federation-language-server  — LSP for
#                                        proto-file
#                                        editing
#   * grpc-federation-mcp-server       — MCP server
#                                        exposing
#                                        federation
#                                        tooling to
#                                        AI agents
#
# WHAT GRPCFEDCTL ACTUALLY DOES:
#   `grpcfedctl plugin cache create --name
#   <PLUGIN> -o <DIR> <plugin.wasm>` calls into
#   wazero like so:
#       cache := wazero.NewCompilationCacheWith
#           Dir(<DIR>/grpc-federation/<PLUGIN>)
#       rt    := wazero.NewRuntimeWithConfig(
#           ctx,
#           wazero.NewRuntimeConfigCompiler().
#               WithCompilationCache(cache).
#               WithCloseOnContextDone(true))
#       rt.CompileModule(ctx, wasmBytes)
#   The resulting `<DIR>/grpc-federation/
#   <PLUGIN>/` directory contains wazero-
#   serialised pre-compiled code that the
#   production BFF reads at startup,
#   bypassing the optimising-compiler pass
#   for the plugin.  Critical for cold-start
#   latency in serverless / scale-to-zero
#   deployments
#
# CLI ARGUMENT PARSER:
# `jessevdk/go-flags v1.5.0` — struct-tag-
# driven CLI, similar to Rust's clap derive.
# Each command is a struct with `description:`
# + `command:` tags.  Flags get `description:`
# + `long:` / `short:` + `required:` tags.
#
# TOP-LEVEL SUBCOMMANDS (extracted from
# `cmd/grpcfedctl/main.go`):
#   * version  — print the grpc-federation
#                runtime version
#   * plugin   — manage Wasm plugins (cache
#                compilation only, for now)
#     ↳ cache  — manage compilation cache
#       ↳ create   — create a wazero
#                    compilation cache from
#                    a .wasm plugin file
#
# CRITICAL DIRECT DEPENDENCIES (from go.mod):
#   - github.com/tetratelabs/wazero v1.10.1
#                              — Wasm runtime
#                                [AXIS 49 LIBRARY]
#   - github.com/goccy/wasi-go v0.3.2
#                              — WASI Preview 1
#                                + partial
#                                Preview 2
#                                shim
#   - github.com/goccy/wasi-go-net v0.3.0
#                              — network layer
#                                for WASI Wasm
#                                modules
#   - github.com/google/cel-go v0.23.1
#                              — Common
#                                Expression
#                                Language
#                                engine
#   - github.com/jessevdk/go-flags v1.5.0
#                              — CLI parser
#   - github.com/bufbuild/protocompile v0.9.0
#                              — pure-Go .proto
#                                compiler (no
#                                protoc
#                                required)
#   - github.com/mark3labs/mcp-go v0.32.0
#                              — MCP server
#                                framework
#   - go.lsp.dev/protocol v0.12.0
#                              — LSP protocol
#                                types
#   - github.com/cenkalti/backoff/v4 v4.2.1
#                              — exponential
#                                backoff for
#                                generated
#                                retry logic
#   - go.opentelemetry.io/otel v1.24.0
#                              — OpenTelemetry
#                                tracing for
#                                the generated
#                                BFF
#   - github.com/fsnotify/fsnotify v1.7.0
#                              — file-watching
#                                for the
#                                language
#                                server
#
# Go 1.24.0+ MSRV per `go.mod` `go 1.24.0`.
#
# UPSTREAM:
#   * Source             : https://github.com/mercari/grpc-federation
#   * Docs (Buf)         : https://buf.build/mercari/grpc-federation
#   * wazero             : https://github.com/tetratelabs/wazero
#   * License            : MIT
#   * Maintainer         : Mercari (mercari.com)
#
# INSTALL:
#   # From source — installs all six binaries
#   # including grpcfedctl
#   go install github.com/mercari/grpc-federation/cmd/grpcfedctl@latest
#
#   # Pre-built binaries (per goreleaser)
#   curl -fsSL https://github.com/mercari/grpc-federation/releases/latest/download/grpcfedctl_$(uname -s)_$(uname -m).tar.gz | tar -xz
#
# USAGE EXAMPLES:
#
#   # Print the grpc-federation runtime version
#   grpcfedctl version
#
#   # Help for the top-level CLI
#   grpcfedctl --help
#   grpcfedctl -h
#
#   # Help for the plugin subcommand
#   grpcfedctl plugin --help
#   grpcfedctl plugin cache --help
#   grpcfedctl plugin cache create --help
#
#   # Pre-compile a Wasm plugin to wazero's
#   # cache (default --out is the current
#   # directory, so this writes ./grpc-
#   # federation/my-resolver/)
#   grpcfedctl plugin cache create \
#       --name my-resolver \
#       my-resolver.wasm
#
#   # Custom output directory
#   grpcfedctl plugin cache create \
#       --name my-resolver \
#       --out /opt/grpcfed/cache \
#       my-resolver.wasm
#
#   # Short flag for the output directory
#   grpcfedctl plugin cache create \
#       --name my-resolver \
#       -o /opt/grpcfed/cache \
#       my-resolver.wasm
#
# DEPLOYMENT FLOW:
#
#   # 1. Compile a plugin to Wasm (any language
#   #    that targets wasm32-wasi)
#   #    e.g. for TinyGo:
#   tinygo build -o my-resolver.wasm \
#       -target=wasi ./my-resolver
#
#   # 2. Pre-compile the .wasm to wazero cache
#   #    (do this in CI, ship the cache dir
#   #    in your container image)
#   grpcfedctl plugin cache create \
#       --name my-resolver \
#       --out ./build/cache \
#       my-resolver.wasm
#
#   # 3. At BFF startup, point the generated
#   #    BFF binary at the cache directory.
#   #    First-call latency drops from ~200ms
#   #    (cold compile) to <1ms (cache hit)
#   ./bff-server --plugin-cache ./build/cache
#
# OPTIONS (sourced directly from
# https://github.com/mercari/grpc-federation/blob/main/cmd/grpcfedctl/main.go +
# plugin.go + version.go):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _grpcfedctl_commands
_grpcfedctl_commands=(
    'version:Print the grpc-federation runtime version'
    'plugin:Manage Wasm plugins (compilation cache, etc.)'
    'help:Print help for a subcommand'
)

local -a _grpcfedctl_plugin_actions
_grpcfedctl_plugin_actions=(
    'cache:Manage the wazero compilation cache for plugin .wasm modules'
)

local -a _grpcfedctl_plugin_cache_actions
_grpcfedctl_plugin_cache_actions=(
    'create:Create a wazero compilation cache from a .wasm plugin file'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'grpcfedctl command' _grpcfedctl_commands && ret=0
        ;;
    args)
        case $line[1] in
            version)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for version]' \
                    && ret=0
                ;;
            plugin)
                _arguments -C \
                    '(- *)'{-h,--help}'[show help for plugin]' \
                    '(-): :->paction' \
                    '(-)*:: :->pargs' \
                    && ret=0
                case $state in
                    paction)
                        _describe -t actions 'plugin action' _grpcfedctl_plugin_actions && ret=0
                        ;;
                    pargs)
                        case $line[1] in
                            cache)
                                _arguments -C \
                                    '(- *)'{-h,--help}'[show help for plugin cache]' \
                                    '(-): :->caction' \
                                    '(-)*:: :->cargs' \
                                    && ret=0
                                case $state in
                                    caction)
                                        _describe -t actions 'plugin cache action' _grpcfedctl_plugin_cache_actions && ret=0
                                        ;;
                                    cargs)
                                        case $line[1] in
                                            create)
                                                _arguments \
                                                    '(- *)'{-h,--help}'[show help for plugin cache create]' \
                                                    '--name=[plugin name (required)]:name: ' \
                                                    '(-o --out)'{-o+,--out=}'[output directory (default ".")]:dir:_files -/' \
                                                    '1:plugin wasm file:_files -g "*.wasm"' \
                                                    && ret=0
                                                ;;
                                        esac
                                        ;;
                                esac
                                ;;
                        esac
                        ;;
                esac
                ;;
            help)
                _arguments \
                    '1:subcommand:(version plugin)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
