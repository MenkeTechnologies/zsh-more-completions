#compdef fail2ban-client
# Documentation: https://github.com/fail2ban/fail2ban/blob/master/man/fail2ban-client.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fail2ban-client (alias file)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start server and jails'
  'restart:restart server'
  'reload:reload configuration'
  'stop:stop all jails and server'
  'status:get current status'
  'ping:test if server is alive'
  'set:set property'
  'get:get property'
  'unban:unban IP address'
  'banned:list banned IPs'
  'flushlogs:flush server log files'
  'statistics:show statistics'
  'version:show version'
  'help:show help'
)

_arguments -s -S \
  {-c+,--conf=}'[config directory]:directory:_files -/' \
  '-d[dump config]' \
  '--dp[dump config (pretty)]' \
  '--dump-pretty[dump config (pretty)]' \
  {-p+,--pidfile=}'[PID file]:pid file:_files' \
  {-s+,--socket=}'[socket path]:socket file:_files' \
  '--pname=[process name]:name:' \
  '-x[force execution]' \
  '-v[increase verbosity]' \
  '-q[decrease verbosity]' \
  '-b[start in background]' \
  '-f[start in foreground]' \
  '-i[interactive mode]' \
  '--loglevel=[set log level]:level:(CRITICAL ERROR WARNING NOTICE INFO DEBUG TRACEDEBUG HEAVYDEBUG)' \
  '--logtarget=[set log target]:target:(STDOUT STDERR SYSLOG SYSOUT)' \
  '--syslogsocket=[set syslog socket]:socket:(auto)' \
  {-t,--test}'[test configuration]' \
  '--async[send commands asynchronously]' \
  '--timeout=[timeout for server response]:seconds:' \
  '--str2sec=[convert time to seconds]:string:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'fail2ban-client command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      status)
        _arguments '1:jail name:' && ret=0
        ;;
      set|get)
        _arguments '1:jail name:' '2:property:' && ret=0
        ;;
      unban)
        _arguments '*:IP address:' && ret=0
        ;;
      start|stop|restart|reload)
        _arguments '1:jail name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
