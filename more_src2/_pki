#compdef pki
# Documentation: https://docs.strongswan.org/docs/5.9/pki/pki.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  '--gen:generate a private key'
  '--pub:extract public key'
  '--req:create a PKCS#10 certificate request'
  '--issue:issue a certificate'
  '--self:create a self-signed certificate'
  '--signcrl:sign a CRL'
  '--verify:verify a certificate'
  '--print:print certificate / key / CRL / AC details'
  '--pkcs7:create / verify PKCS#7'
  '--pkcs8:convert PKCS#8 keys'
  '--pkcs12:create / extract PKCS#12'
  '--scep:run SCEP enrollment'
  '--est:run EST enrollment'
  '--keyid:show keyid of key / cert'
  '--acert:create an attribute certificate'
  '--ocsp:OCSP responder'
  '--dn:parse / encode DN'
  '--help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pki command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (--gen)
        _arguments \
          '(-t --type)'{-t,--type}'+[key type]:type:(rsa rsa-pss ecdsa ed25519 ed448 bliss)' \
          '(-s --size)'{-s,--size}'+[key size]:bits:' \
          '(-f --outform)'{-f,--outform}'+[output format]:fmt:(pem der pgp)' \
          '(-o --output)'{-o,--output}'+[output file]:file:_files' && ret=0 ;;
      (--req|--self)
        _arguments \
          '(-t --type)'{-t,--type}'+[input key type]:type:(rsa ecdsa ed25519 ed448)' \
          '(-i --in)'{-i,--in}'+[input key]:file:_files' \
          '(-d --dn)'{-d,--dn}'+[subject DN]:dn:' \
          '(-a --san)'{-a,--san}'+[subject alt name]:san:' \
          '(-c --ca)'{-c,--ca}'[CA certificate]' \
          '(-l --lifetime)'{-l,--lifetime}'+[lifetime in days]:days:' \
          '(-f --outform)'{-f,--outform}'+[output format]:fmt:(pem der)' && ret=0 ;;
      (--verify|--print)
        _arguments \
          '(-i --in)'{-i,--in}'+[input file]:file:_files' \
          '(-c --cacert)'{-c,--cacert}'+[CA certificate]:file:_files' && ret=0 ;;
    esac ;;
esac

return ret
