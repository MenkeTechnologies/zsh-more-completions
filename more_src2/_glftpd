#compdef glftpd
# Documentation: http://mewbies.com/glftpd-LNX_2.01_docs/glftpd.docs.txt
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-l[log new dirs/nukes/logins/logouts]' \
  '-i[log uploads to xferlog]' \
  '-o[log downloads to xferlog]' \
  '-d[log connections and commands as debug]' \
  '-r+[alternate glftpd.conf file]:file:_files -g "*.conf"' \
  '-t+[default idle timeout seconds]:seconds:' \
  '-T+[max idle timeout users may select]:seconds:' \
  '-B[only allow port bouncer connections]' \
  '-b[allow bouncer or direct connections]' \
  '-I[disable ident lookups]' \
  '-n+[DNS retries (0 disables)]:n:' \
  '-e[use European week format for stats]' \
  '-x[log only IPs on errors]' \
  '-X[prevent IP logging entirely]' \
  '-s+[full path to glstrings binary]:file:_files' \
  '-L[enhanced directory logging beyond dirlog path]' && ret=0

return ret
