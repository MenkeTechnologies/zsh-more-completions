#compdef mozc-tool
# Documentation: https://github.com/google/mozc/blob/master/src/gui/tool/mozc_tool_libmain.cc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (ABSL_FLAG declarations).

# mozc-tool: Mozc Japanese IME GUI launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '--mode=[GUI dialog mode]:mode:(about_dialog config_dialog dictionary_tool word_register_dialog error_message_dialog post_install_dialog administration_dialog prelauncher)' \
  '--error_type=[error type (used with error_message_dialog)]:type:' && ret=0
return ret
