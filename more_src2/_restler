#compdef restler
# _restler — REST API stateful fuzzer driver (microsoft/restler-fuzzer)
# upstream: https://github.com/microsoft/restler-fuzzer
# Subcommands from src/driver/Program.fs (custom argv parsing).

_restler() {
    local context state state_descr line
    typeset -A opt_args
    local -a common=(
        '--disable_log_upload[disable uploading full logs]'
        '--logsUploadRootDirPath=[upload logs to this directory]:dir:_files -/'
        '--python_path=[full path to python executable]:cmd:_command_names -e'
        '--workingDirPath=[local logs directory (default: cwd)]:dir:_files -/'
    )

    _arguments -C \
        '(- *)--version[show version]' \
        $common \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                generate_config:'auto-generate a compiler config from OpenAPI specs'
                compile:'compile an API spec into a grammar'
                test:'run a single-shot smoke test'
                fuzz-lean:'run test mode with limited fuzzing'
                fuzz:'run the full RESTler fuzzing campaign'
                replay:'replay a recorded bug or trace'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                generate_config)
                    _arguments \
                        '*--specs=[OpenAPI spec files or directory]:file:_files' \
                        '--output_dir=[output directory]:dir:_files -/' \
                        '--relative_path=[relative path]:path:' ;;
                compile)
                    _arguments \
                        '--api_spec=[Swagger spec path]:file:_files' \
                        '1:compiler config file:_files' ;;
                test|fuzz-lean|fuzz)
                    _arguments \
                        '--grammar_file=[grammar file]:file:_files' \
                        '--dictionary_file=[dictionary file]:file:_files' \
                        '--target_ip=[target IP]:ip:_hosts' \
                        '--target_port=[target port]:port:' \
                        '--token_refresh_interval=[token refresh interval]:s:' \
                        '--token_refresh_command=[token refresh command]:cmd:' \
                        '--producer_timing_delay=[delay after producer call]:s:' \
                        '--path_regex=[path regex filter]:regex:' \
                        '--no_ssl[do not use SSL]' \
                        '--host=[override Host header]:host:_hosts' \
                        '--settings=[engine settings file]:file:_files' \
                        '--enable_checkers=[checkers to enable]:list:' \
                        '--disable_checkers=[checkers to disable]:list:' \
                        '--no_results_analyzer[skip results analyzer]' \
                        '--test_all_combinations[test all parameter combinations]' \
                        '--time_budget=[max fuzz duration in hours]:hours:' \
                        '--search_strategy=[fuzz search strategy]:strategy:(bfs-fast bfs bfs-cheap random-walk)' ;;
                replay)
                    _arguments \
                        '--dictionary_file=[dictionary file]:file:_files' \
                        '--token_refresh_interval=[token refresh interval]:s:' \
                        '--token_refresh_command=[token refresh command]:cmd:' \
                        '--no_ssl[do not use SSL]' \
                        '--host=[override Host header]:host:_hosts' \
                        '--settings=[engine settings file]:file:_files' \
                        '--replay_log=[bug bucket repro or trace file]:file:_files -g "*.(replay.txt|ndjson)"' ;;
            esac
            ;;
    esac
}

_restler "$@"
