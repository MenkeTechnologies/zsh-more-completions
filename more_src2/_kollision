#compdef kollision
# Documentation: https://invent.kde.org/games/kollision/-/blob/master/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KDE kollision main.cpp registers no app-specific
# command-line options; only the standard KAboutData --help/--version
# flags apply. STUB: GUI-only game.

# kollision: KDE ball-dodging game (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' && ret=0
return ret
