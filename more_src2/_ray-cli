#compdef ray-cli rayctl
# _ray-cli — Anyscale Ray ray-cli rayctl CLI command-line frontend wrapping the Ray distributed computing framework providing start head stop status submit job logs cluster up down attach exec rsync get set autoscaler operator dashboard metrics serve tune train rllib air actor task placement-group (Anyscale team, Python); click
# upstream: https://www.ray.io/

_ray-cli() {
    local -a sub=(
        'start:start ray node'
        'stop:stop ray node'
        'status:show ray cluster status'
        'submit:submit a Ray job'
        'job:job operations'
        'cluster:cluster management'
        'up:start ray cluster'
        'down:tear down ray cluster'
        'attach:attach to ray cluster'
        'exec:exec on ray cluster'
        'rsync-down:rsync down'
        'rsync-up:rsync up'
        'get:get info'
        'set:set value'
        'metrics:show metrics'
        'dashboard:open dashboard'
        'autoscaler:autoscaler operations'
        'operator:operator operations'
        'serve:Ray Serve operations'
        'tune:Ray Tune operations'
        'train:Ray Train operations'
        'rllib:Ray RLlib operations'
        'air:Ray AIR operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--address=+[host:port]:str:' \
        '--port=+[port]:n:' \
        '--head[start as head]' \
        '--dashboard-host=+[host]:_hosts' \
        '--dashboard-port=+[port]:n:' \
        '--num-cpus=+[N]:n:' \
        '--num-gpus=+[N]:n:' \
        '--memory=+[bytes]:str:' \
        '--object-store-memory=+[bytes]:str:' \
        '--temp-dir=+[dir]:dir:_files -/' \
        '--node-ip-address=+[ip]:_hosts' \
        '--node-name=+[name]:str:' \
        '--cluster-name=+[name]:str:' \
        '--working-dir=+[dir]:dir:_files -/' \
        '--runtime-env=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--no-restart[no restart]' \
        '--restart-only[restart only]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ray-cli subcommand' sub ;;
        args)
            case $words[1] in
                up|down|attach|exec|rsync-up|rsync-down) _arguments '*:cluster config:_files -g "*.yaml *.yml"' ;;
                submit) _arguments '*:script:_files -g "*.py"' ;;
                job) _arguments '1:op:(list submit status logs stop)' '*:job id:' ;;
                serve|tune|train|rllib|air) _arguments '1:op:(deploy delete status list run)' '*:name:' ;;
            esac
            ;;
    esac
}

_ray-cli "$@"
