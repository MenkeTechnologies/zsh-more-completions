#compdef dovecot-imap dovecot-imapd
# _dovecot-imap — Dovecot per-protocol IMAP backend (imap binary launched by dovecot's master process to serve a single IMAP4rev1 / IMAP4rev2 client; -c config file, -F foreground, -o key=value config override, -t timeout seconds, -u user (for impersonation), -p protocol (rarely set), --version, --help)
# upstream: https://github.com/dovecot/core
# Flags from dovecot src/imap/main.c on tip.

_dovecot-imap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[config file]:file:_files' \
        '-F[foreground]' \
        '-t+[timeout seconds]:seconds:' \
        '*-o+[KEY=VAL]:setting:' \
        '-u+[user]:user:_users'
}

_dovecot-imap "$@"
