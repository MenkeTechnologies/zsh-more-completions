#compdef downsample-fits
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/downsample-fits.1 — scale down a FITS image (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s+[downsample scale (default 2)]:n:_default' \
    '-e+[read extension (default 0)]:n:_default' \
    '-v[verbose]' \
    '1:input FITS:_files -g "*.{fits,fit,fts}"' \
    '2:output FITS (- for stdout):_files' \
    && ret=0

return ret
