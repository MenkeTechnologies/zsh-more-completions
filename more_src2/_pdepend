#compdef pdepend
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/pdepend.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--summary-xml=[write summary XML report]:file:_files -g "*.xml"' \
  '--dependency-xml=[write dependency XML report]:file:_files -g "*.xml"' \
  '--jdepend-chart=[generate jDepend chart]:file:_files -g "*.svg"' \
  '--jdepend-xml=[generate jDepend XML report]:file:_files -g "*.xml"' \
  '--overview-pyramid=[generate overview pyramid]:file:_files -g "*.svg"' \
  '--coderank-mode=[coderank strategy]:mode:(inheritance property method)' \
  '--coverage-report=[coverage report for analysis]:file:_files' \
  '--configuration=[configuration file]:file:_files -g "*.xml"' \
  '--suffix=[file suffixes to analyze]:suffixes' \
  '--ignore=[ignore directories]:directories' \
  '--exclude=[exclude packages/namespaces]:packages' \
  '--without-annotations[do not parse annotations]' \
  '--quiet[quiet mode]' \
  '--debug[enable debug mode]' \
  '-d+[set runtime option as key=value]:option' \
  '*:directory:_files -/' && ret=0

return ret
