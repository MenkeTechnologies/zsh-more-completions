#compdef dwm-cli dwm-status
# _dwm-cli — suckless dwm dynamic window manager binary (suckless.org, C); custom argparse
# upstream: https://git.suckless.org/dwm

_dwm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-r[restart in place]' \
        '-c+[config file]:file:_files' \
        '*:arg:'
}

_dwm-cli "$@"
