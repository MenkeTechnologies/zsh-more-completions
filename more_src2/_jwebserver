#compdef jwebserver
# Documentation: https://docs.oracle.com/en/java/javase/21/docs/specs/man/jwebserver.html
# Reference accessed: 2026-05-17
# Verified: Oracle JDK 21 jwebserver man page (JEP 408 simple web server,
# JDK 18+). Real flag is -version (single dash) not --version.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --version (real is -version).

local -a arguments

arguments=(
    '-b[bind address]:address'
    '--bind-address=[bind address]:address'
    '-p[port number]:port'
    '--port=[port number]:port'
    '-d[directory to serve]:directory:_directories'
    '--directory=[directory to serve]:directory:_directories'
    '-o[output format]:(none info verbose)'
    '--output=[output format]:(none info verbose)'
    '-h[show help]'
    '-?[show help]'
    '--help[show help]'
    '-version[show version]'
)

_arguments -s -S $arguments
