#compdef ocp-build
# Documentation: http://www.typerex.org/ocp-build.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'root:set project root directory'
  'configure:configure project options'
  'project:query project information'
  'build:build project'
  'install:install packages'
  'test:build and run package tests'
  'clean:clean build artefacts'
  'query:query environment information'
  'uninstall:uninstall packages'
)

_arguments -C \
  '-help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ocp-build command' commands && ret=0 ;;
esac

return ret
