#compdef icebox_asc2hlc
# Documentation: https://github.com/YosysHQ/icestorm
# Source: YosysHQ/icestorm icebox/icebox_asc2hlc.py — convert iCE40 .asc bitstream to high-level config (HLC).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m[print tile config bitmaps]' \
    '-A[do not skip uninteresting tiles]' \
    '--help[display help and exit]' \
    '--version[output version information and exit]' \
    '*:.asc bitstream:_files' \
    && ret=0

return ret
