#compdef pip-deepfreeze
# _pip-deepfreeze — fast Python requirements freezer (sbidoul/pip-deepfreeze)
# upstream: https://github.com/sbidoul/pip-deepfreeze
# Subcommands from src/pip_deepfreeze/__main__.py (typer).

_pip-deepfreeze() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-p --python)'{-p+,--python=}'[Python executable in target env]:python:_command_names -e' \
        '(-r --project-root)'{-r+,--project-root=}'[project root directory]:dir:_files -/' \
        '(-v --verbose)*'{-v,--verbose}'[increase verbosity]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'sync:install / update deps and refresh requirements.txt'
                'tree:show installed dep tree'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                sync)
                    _arguments \
                        '(-u --update)'{-u+,--update=}'[comma-separated deps to upgrade]:deps:' \
                        '--update-all[upgrade all dependencies]' \
                        '(-x --extras)'{-x+,--extras=}'[comma-separated extras to install]:extras:' \
                        '(--uninstall-unneeded --no-uninstall-unneeded)--uninstall-unneeded[uninstall unneeded distributions]' \
                        '(--uninstall-unneeded --no-uninstall-unneeded)--no-uninstall-unneeded[do not uninstall unneeded]' \
                        '*--pre-sync-command=[command to run before sync]:cmd:' \
                        '*--post-sync-command=[command to run after sync]:cmd:' \
                        '--installer=[installer to use]:installer:(pip uv pdm pip-tools)' \
                        '--build-constraints=[build constraints file]:file:_files -g "*.txt"'
                    ;;
            esac
            ;;
    esac
}

_pip-deepfreeze "$@"
