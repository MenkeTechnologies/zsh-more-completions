#compdef kubectl-node-shell
# Documentation: https://github.com/kvaps/kubectl-node-shell/blob/master/kubectl-node_shell
# Reference accessed: 2026-05-19
# Verified: upstream kubectl-node_shell script argument parser at the URL above.

# kubectl-node-shell (kvaps/kubectl-node-shell). Same plugin as
# kubectl-node_shell; underscore vs hyphen depends on krew install variant.

_arguments -s -S \
  '(- *)'{-v,--version}'[show version]' \
  '--context=[kube context]:context:' \
  '--kubecontext=[kube context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[pod namespace]:namespace:' \
  '(-m --mount)'{-m+,--mount=}'[mount a PVC into the pod]:pvc:' \
  '-x[X-mode (mount /host, do not enter host namespace)]' \
  '--image=[custom image for the pod]:image:' \
  '--no-ipc[do not enter the ipc namespace]' \
  '--no-mount[do not enter the mount namespace]' \
  '--no-pid[do not enter the pid namespace]' \
  '--no-net[do not enter the net namespace]' \
  '--no-uts[do not enter the uts namespace]' \
  '1:node:' \
  '*::command: _default'
