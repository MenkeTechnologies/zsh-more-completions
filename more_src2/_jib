#compdef jib
# Documentation: https://github.com/GoogleContainerTools/jib/blob/master/jib-cli/README.md
# Reference accessed: 2026-05-19
# Verified: upstream jib-cli README at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build:containerize using a build file (jib.yaml)'
  'jar:containerize JAR files'
  'war:containerize WAR files'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--target=[target image reference]:ref:' \
  '--credential-helper=[credential helper for registry auth]:helper:' \
  '--username=[registry username]:user:_users' \
  '--password=[registry password]:password:' \
  '--to-credential-helper=[credential helper for target only]:helper:' \
  '--to-username=[target registry username]:user:_users' \
  '--to-password=[target registry password]:password:' \
  '--from-credential-helper=[credential helper for base image only]:helper:' \
  '--from-username=[base image registry username]:user:_users' \
  '--from-password=[base image registry password]:password:' \
  '--allow-insecure-registries[allow insecure registries (HTTP/self-signed)]' \
  '--send-credentials-over-http[send credentials over insecure HTTP]' \
  '--verbosity=[logging verbosity]:level:(quiet error warn lifecycle info debug)' \
  '--stacktrace[print stacktrace on error]' \
  '--http-trace[enable HTTP tracing]' \
  '--serialize[serialize execution]' \
  '--console=[console output type]:type:(auto rich plain)' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'jib subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (build)
        _arguments \
          '(-b --build-file)'{-b,--build-file=}'[Jib build file]:file:_files -g "*.(yaml|yml)"' \
          '(-c --context)'{-c,--context=}'[build context]:dir:_files -/' \
          '*'{-p,--parameter=}'[template parameter key=value]:param:' && ret=0
        ;;
      (jar)
        _arguments \
          '--creation-time=[image creation time]:time:' \
          '--entrypoint=[container entrypoint]:entrypoint:' \
          '*--environment-variables=[environment variables]:env:' \
          '--expose=[exposed ports]:ports:' \
          '--from=[base image]:image:' \
          '--image-format=[image format]:format:(Docker OCI)' \
          '--labels=[image labels]:labels:' \
          '--program-args=[program arguments]:args:' \
          '(-u --user)'{-u,--user=}'[container user]:user:_users' \
          '--volumes=[container volumes]:volumes:' \
          '--jvm-flags=[JVM flags for the container]:flags:' \
          '--mode=[jar mode]:mode:(exploded packaged)' \
          '*:jar:_files -g "*.jar"' && ret=0
        ;;
      (war)
        _arguments \
          '--creation-time=[image creation time]:time:' \
          '--entrypoint=[container entrypoint]:entrypoint:' \
          '*--environment-variables=[environment variables]:env:' \
          '--expose=[exposed ports]:ports:' \
          '--from=[base image]:image:' \
          '--image-format=[image format]:format:(Docker OCI)' \
          '--labels=[image labels]:labels:' \
          '--program-args=[program arguments]:args:' \
          '(-u --user)'{-u,--user=}'[container user]:user:_users' \
          '--volumes=[container volumes]:volumes:' \
          '--app-root=[application root in container]:path:' \
          '*:war:_files -g "*.war"' && ret=0
        ;;
    esac
    ;;
esac

return ret
