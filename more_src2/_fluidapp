#compdef fluidapp fluid-app
# _fluidapp — Fluid FluidApp controller (fluid-cloudnative/fluid)
# upstream: https://github.com/fluid-cloudnative/fluid
# Subcommands + flags from cmd/fluidapp/app/fluidapp.go on tip.

_fluidapp() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                start:'start the FluidApp controller'
                version:'print version and exit'
            )
            _describe -t commands 'fluidapp command' cmds
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--metrics-addr=[metrics bind address]:host\:port:' \
                        '--enable-leader-election=[enable leader election]:bool:(true false)' \
                        '--leader-election-namespace=[leader-election namespace]:ns:' \
                        '--development=[enable development mode logging]:bool:(true false)' \
                        '--pprof-addr=[pprof bind address]:host\:port:' \
                        '--runtime-workers=[max concurrent FluidApp reconciles]:n:'
                    ;;
            esac
            ;;
    esac
}

_fluidapp "$@"
