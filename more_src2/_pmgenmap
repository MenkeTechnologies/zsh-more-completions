#compdef pmgenmap
# _pmgenmap — generate a Performance Metrics Name Space map from a spec file (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Usage from src/pmgenmap/pmgenmap.sh: pmgenmap [infile]

_pmgenmap() {
    _arguments \
        '(- *)-?[show help]' \
        '1:input spec file:_files'
}

_pmgenmap "$@"
