#compdef gitql
# Documentation: https://github.com/filhodanuvem/gitql
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-p --path)'{-p,--path}'=[repository path]:path:_files -/'
  '--format=[output format]:format:(json csv table)'
  '(-h --help)'{-h,--help}'[show help message]'
  '--version[show version]'
  '1:SQL query:'
)

_arguments -s -S $arguments
