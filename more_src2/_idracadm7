#compdef idracadm7
# Documentation: https://www.dell.com/support/manuals/en-us/idrac9-lifecycle-controller-v4.x-series/idrac_4.00.00.00_racadm/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# idracadm7: Dell iDRAC7/8 RACADM remote management CLI.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'getsysinfo:show iDRAC system info'
  'getconfig:get configuration group'
  'setconfig:set configuration group'
  'serveraction:powercycle/shutdown/reset server'
  'sysinfo:summary system info'
  'racreset:reset iDRAC'
  'racreset hard:hard reset iDRAC'
  'racreset soft:soft reset iDRAC'
  'getsel:retrieve System Event Log'
  'clrsel:clear System Event Log'
  'getsensorinfo:show sensor data'
  'getsvctag:show service tag'
  'gethwinventory:hardware inventory'
  'getversion:firmware/idrac versions'
  'set:set config item (Server Configuration Profile path)'
  'get:get config item'
  'jobqueue:manage iDRAC job queue'
  'lclog:lifecycle controller log'
  'storage:storage subsystem commands'
  'systemconfig:export/import server configuration profile'
  'sshpkauth:manage iDRAC SSH public keys'
  'remoteimage:virtual media remote image'
  'connect:open serial-over-LAN to host'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-?[show help]' \
  '-r[remote iDRAC host]:host:_hosts' \
  '-u[remote iDRAC user]:user:_users' \
  '-p[remote iDRAC password]:password:' \
  '-i[interactive prompt for password]' \
  '-S[run via SSL]' \
  '-T[transport: ssh|sshv6|telnet]:transport:(ssh sshv6 telnet)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'idracadm7 command' commands && ret=0 ;;
esac
return ret
