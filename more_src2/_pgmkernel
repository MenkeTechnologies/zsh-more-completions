#compdef pgmkernel
# Documentation: man pgmkernel (Netpbm)
# Source: generate a PGM convolution kernel.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-weight=[center-weight]:number:' \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:size or width:' \
    '2:height (optional):' \
    && ret=0

return ret
