#compdef partx-cli
# _partx-cli — util-linux partx kernel partition table updater CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_partx-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[add specified partitions]' \
        '--add[add specified partitions]' \
        '-d[delete specified partitions]' \
        '--delete[delete specified partitions]' \
        '-u[update specified partitions]' \
        '--update[update specified partitions]' \
        '-s[show partitions]' \
        '--show[show partitions]' \
        '-i+[increase output]:str:' \
        '--increase=+[increase output]:str:' \
        '-z[disable partition table check]' \
        '--no-tt[disable partition table check]' \
        '-b[print SIZE in bytes rather than human-readable]' \
        '--bytes[print SIZE in bytes]' \
        '-g[no headings]' \
        '--noheadings[no headings]' \
        '-n+[partition number range]:str:' \
        '--nr=+[partition number range]:str:' \
        '-o+[output cols]:str:' \
        '--output=+[output cols]:str:' \
        '--output-all[output all cols]' \
        '-P[parsable output]' \
        '--pairs[parsable output]' \
        '-r[raw output]' \
        '--raw[raw output]' \
        '-t+[partition type]:str:' \
        '--type=+[partition type]:str:' \
        '--list-types[list types]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper,loop}*"'
}

_partx-cli "$@"
