#compdef durdraw
# Documentation: https://github.com/cmang/durdraw
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for durdraw - ASCII/ANSI art editor (TUI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --play)'{-p,--play}'[play file and exit]' \
  '(-d --delayexit)'{-d+,--delayexit=}'[delay seconds after playback]:seconds:' \
  '(-x --times)'{-x+,--times=}'[play animation X times]:n:' \
  '--256color[use 256 color mode]' \
  '--16color[use 16 color mode]' \
  '(-b --blackbg)'{-b,--blackbg}'[use black background]' \
  '(-W --width)'{-W+,--width=}'[canvas width]:cols:' \
  '(-H --height)'{-H+,--height=}'[canvas height]:rows:' \
  '(-m --max)'{-m,--max}'[maximize canvas to terminal size]' \
  '--wrap=[column wrapping for ASCII/ANSI files]:n:' \
  '--notheme[disable theme support]' \
  '--theme=[load theme file]:file:_files' \
  '--cursor=[cursor mode]:mode:(block underscore pipe)' \
  '--cp437[use Code Page 437 encoding]' \
  '--nomouse[disable mouse support]' \
  '--export-ansi[export loaded art to .ansi file]' \
  '(-u --undosize)'{-u+,--undosize=}'[undo history states (default 100)]:n:' \
  '--fetch[replace fetch strings with Neofetch output]' \
  '*:ANSI/ASCII art file:_files' && ret=0

return ret
