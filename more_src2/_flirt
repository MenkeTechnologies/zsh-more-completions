#compdef flirt
# flirt — FMRIB linear image registration tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-in[input volume]:input image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '-ref[reference volume]:reference image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '-out[output volume]:output image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '-omat[output affine matrix]:output matrix:_files -g "*.mat"' \
  '-init[input initial transform matrix]:initial matrix:_files -g "*.mat"' \
  '-dof[number of degrees of freedom]:DOF:(6 7 9 12)' \
  '-cost[cost function]:cost function:(mutualinfo corratio normcorr normmi leastsq labeldiff bbr)' \
  '-searchrx[search angles in x (min max)]:min angle:' \
  '-searchry[search angles in y (min max)]:min angle:' \
  '-searchrz[search angles in z (min max)]:min angle:' \
  '-interp[interpolation method]:interpolation:(trilinear nearestneighbour sinc spline)' \
  '-bins[number of histogram bins]:bins:' \
  '-applyxfm[apply existing transform]' \
  '-applyisoxfm[apply transform with isotropic resampling]:resolution (mm):' \
  '-verbose[verbose output]:verbosity level:(0 1 2)'
