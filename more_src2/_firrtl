#compdef firrtl firrtl-cli treadle
# _firrtl — UCB BAR FIRRTL Flexible Internal Representation for RTL hardware intermediate representation compiler for Chisel HW designs (chipsalliance team, Scala); custom argparse
# upstream: https://github.com/chipsalliance/firrtl

_firrtl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input file]:file:_files -g "*.fir *.firrtl"' \
        '--input-file=+[input file]:file:_files -g "*.fir *.firrtl"' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-X+[compiler]:c:(none sverilog verilog low high middle minimum mverilog)' \
        '--compiler=+[compiler]:c:(none sverilog verilog low high middle minimum mverilog)' \
        '-fct+[transforms csv]:str:' \
        '--firrtl-custom-transforms=+[transforms csv]:str:' \
        '-faf+[annotations file]:file:_files' \
        '--annotation-file=+[annotations file]:file:_files' \
        '-foaf+[output annotation file]:file:_files' \
        '--output-annotation-file=+[output annotation file]:file:_files' \
        '-iif+[info include file]:file:_files' \
        '--info-mode=+[mode]:m:(ignore use gen append)' \
        '--list-transforms[list transforms]' \
        '--firrtl-source=+[source]:str:' \
        '--top-name=+[name]:str:' \
        '--target-dir=+[dir]:dir:_files -/' \
        '--log-level=+[level]:l:(trace debug info warn error none)' \
        '--class-log-level=+[csv]:str:' \
        '--log-file=+[log file]:file:_files' \
        '--log-classes-in-scope[log classes in scope]' \
        '--allow-unrecognized-annotations[allow unrecognized annotations]' \
        '*:additional file:_files -g "*.fir *.firrtl *.anno.json *.json"'
}

_firrtl "$@"
