#compdef darktable-cli
# Documentation: https://docs.darktable.org/usermanual/development/en/special-topics/program-invocation/darktable-cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a icc_types icc_intents

icc_types=(
  NONE FILE SRGB ADOBERGB LIN_REC709 LIN_REC2020 XYZ LAB
  INFRARED DISPLAY EMBEDDED_ICC EMBEDDED_MATRIX
  STANDARD_MATRIX ENHANCED_MATRIX VENDOR_MATRIX ALTERNATE_MATRIX
  BRG EXPORT SOFTPROOF WORK DISPLAY2
  REC709 PROPHOTO_RGB PQ_REC2020 HLG_REC2020 PQ_P3 HLG_P3 DISPLAY_P3
)

icc_intents=(PERCEPTUAL RELATIVE_COLORIMETRIC SATURATION ABSOLUTE_COLORIMETRIC)

_arguments -s \
  '--width=[max width]:n:' \
  '--height=[max height]:n:' \
  '--bpp=[bits per pixel]:n:' \
  '--hq=[high quality resampling]:bool:(0 1 true false)' \
  '--upscale=[allow upscaling]:bool:(0 1 true false)' \
  '--export_masks=[export masks]:bool:(0 1 true false)' \
  '--style=[style name]:style:' \
  '--style-overwrite[overwrite history with style]' \
  '--apply-custom-presets=[apply custom presets]:bool:(0 1 true false)' \
  '--out-ext=[output extension]:ext:(jpg jpeg tif tiff png webp jxl avif j2k jp2 exr pfm ppm)' \
  '*--import=[import file or dir]:path:_files' \
  '--library=[library db path]:db:_files' \
  '--icc-type=[ICC profile type]:type:('"${icc_types[*]}"')' \
  '--icc-file=[ICC profile file]:file:_files' \
  '--icc-intent=[ICC intent]:intent:('"${icc_intents[*]}"')' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]:topic:' \
  '(- *)--version[show version]' \
  '--core[pass remaining args to core]' \
  '*:file:_files'
