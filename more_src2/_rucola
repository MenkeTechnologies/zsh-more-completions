#compdef rucola
# ============================================================================
# rucola - Terminal markdown note manager / Zettelkasten (Rust, GPL-3.0)
#
# Author : Linus Mussmaecher
# Upstream: https://github.com/Linus-Mussmaecher/rucola
# crates : rucola-notes (binary: rucola)
#
# rucola is a TUI ("vault" navigator) for a folder of markdown
# notes - aimed at the Zettelkasten / Obsidian-vault workflow
# but with a terminal-only UI: ratatui frontend, in-process
# fuzzy-matching note search, live recomputation of note links
# (forward+back), graph view of the link structure, stats per
# note (word count, last-modified, link in-degree), tag
# extraction from YAML frontmatter, and one-key open of any
# note in `$EDITOR`. Configurable through a TOML file at
# `~/.config/rucola/config.toml` (XDG) with per-vault override.
#
# Usage:
#   rucola [target_folder]            - launch TUI on vault
#   rucola -s <style.toml>            - apply UI style override
#   rucola -l                         - print license + warranty
#
# Flags (clap derive):
#   target_folder       - positional path to the vault directory
#                         (overrides config-file path)
#   -s, --style <file>  - style file (relative to config dir)
#   -l, --license       - output the license and warranty
#   -V, --version       - print version
#   -h, --help          - print help
#
# The comrak lane is built on `comrak ^0.39` (declared verbatim
# at upstream Cargo.toml HEAD), one of the two canonical Rust
# markdown libraries by Asherah Connor (github.com/kivikakk/
# comrak, 1100+ stars). comrak is the Rust port of the CommonMark
# C reference implementation (jgm/cmark) + GFM extensions, and
# is the only Rust markdown library that passes the full
# CommonMark + GFM conformance suite (~650 tests). The
# competitor `pulldown-cmark` is faster but less feature-complete
# (no tables/strikethrough/tasklist by default, no fix-up
# rendering, no raw-HTML safety mode). rucola picks comrak
# because the note-rendering pipeline must handle Obsidian-
# style tables + task lists + footnotes faithfully - the
# extra parser overhead doesn't matter at TUI render scale.
#
# ----------------------------------------------------------------------------
# AXIS 224 :: Markdown parsers (CommonMark + GFM conformance)  [OPENS]
# Round 1370 :: Rust slot 1 of 4 :: OPENS Axis 224
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : kivikakk/comrak              - CommonMark + GFM, AST + render
#   Go      : yuin/goldmark                - extensible CommonMark, Hugo's parser
#   TS/Node : markedjs/marked              - de-facto Node markdown renderer
#
# The three lanes converge on the same spec (CommonMark 0.31.2
# + GFM extensions) but diverge in extensibility model:
#
#   comrak (Rust)      : flag-driven options struct
#                        (ComrakOptions { extension: { table: true, ... } })
#                        per-call configuration, all extensions
#                        compile-time-known
#   goldmark (Go)      : pluggable parser/renderer/extension
#                        interfaces - users can register custom
#                        block parsers + render functions; Hugo
#                        uses this to plug shortcodes
#   marked (Node)      : lexer/parser/renderer hooks - users
#                        override token render fns to inject
#                        custom HTML/JSX; defaults to GFM since
#                        v1, syntax-highlighting via separate
#                        plugin
#
# Use-case alignment for this axis:
#   - Rust slot (rucola): TUI note manager, render-to-ratatui
#   - Go slot (TBD):      file-based docs/blog/wiki generator
#   - Node slot (TBD):    server-side renderer or build tool
#
# All three target CommonMark + GFM byte-for-byte (matched
# against the published 650+ conformance tests). The
# structural commentary: markdown parsers are one of the rare
# spec-bound libraries with active conformance-suite gating -
# breaking the spec test suite means the parser stops being
# canonical. This drives unusual cross-language consistency
# despite three independent maintainer trees.
# ============================================================================

_rucola() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-s --style)'{-s,--style}'[style file (relative to config dir)]:file:_files' \
        '(-l --license)'{-l,--license}'[output the license and warranty]' \
        '(- *)'{-V,--version}'[print version]' \
        '(- *)'{-h,--help}'[print help]' \
        '1:target vault folder:_files -/'
}

_rucola "$@"
