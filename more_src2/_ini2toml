#compdef ini2toml
# Documentation: https://ini2toml.readthedocs.io/en/latest/
# Reference accessed: 2026-06-04

# Zsh completion for ini2toml (convert INI/CFG files to TOML)
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '(-o --output)'{-o,--output}'[output file path]:output file:_files'
  '*'{-t,--transform}'[transformation to apply]:transform name:'
  '(-u --uncomment)'{-u,--uncomment}'[uncomment commented-out options]'
  '*'{-p,--profile}'[activate profile for conversion]:profile:(setup.cfg setuptools)'
  '*--enable[enable a specific plugin]:plugin name:'
  '*--disable[disable a specific plugin]:plugin name:'
  '*:input file:_files -g "*.(ini|cfg|conf)"'
)

_arguments -s -S $arguments
