#compdef ko
# Documentation: https://ko.build/reference/ko/
# Reference accessed: 2026-05-19
# Verified: upstream docs at ko.build/reference (ko, ko_build, ko_apply,
# ko_login).

# Zsh completion for ko (Build and deploy Go containers)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help information]' \
  '(-v --verbose)'{-v,--verbose}'[enable debug logs]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'apply:apply input files with image references resolved'
      'build:build and publish container images from importpaths'
      'create:create input files with image references resolved'
      'delete:delete resources (see kubectl help delete)'
      'login:log in to a registry'
      'resolve:print input files with image references resolved'
      'run:variant of kubectl run that containerizes IMPORTPATH first'
      'version:print ko version'
    )
    _describe -t commands 'ko command' commands && ret=0
    ;;
  args)
    local -a build_flags=(
      '(-h --help)'{-h,--help}'[display help information]'
      '(-v --verbose)'{-v,--verbose}'[enable debug logs]'
      '--bare[use KO_DOCKER_REPO without additional context]'
      '(-B --base-import-paths)'{-B,--base-import-paths}'[use base path without MD5 hash]'
      '(-P --preserve-import-paths)'{-P,--preserve-import-paths}'[preserve full import path]'
      '--debug[include Delve debugger listening on port 40000]'
      '--disable-optimizations[disable Go build optimizations]'
      '*--image-annotation=[annotations to add to OCI manifest]:key=value'
      '*--image-label=[labels to add to the image]:key=value'
      '--image-refs=[path to file for published image references]:file:_files'
      '--image-user=[default user for running the image]:user:_users'
      '(-j --jobs)'{-j+,--jobs=}'[maximum concurrent builds]:n:'
      '--insecure-registry[skip TLS verification on registry]'
      '(-L --local)'{-L,--local}'[load images to local docker daemon]'
      '--oci-layout-path=[path to save OCI image layout]:dir:_directories'
      '*--platform=[platform selection for multi-platform base]:platform'
      '--push[push images to KO_DOCKER_REPO (default true)]'
      '--sbom=[SBOM media type]:type:(spdx none)'
      '--sbom-dir=[directory for SBOM output]:dir:_directories'
      '--tag-only[include tags but not digests in references]'
      '(-t --tags)'{-t+,--tags=}'[custom tags for produced images]:tag'
      '--tarball=[file to save image tarballs]:file:_files'
    )

    case ${words[1]} in
      build)
        _arguments -s -S $build_flags '*:importpath' && ret=0
        ;;
      resolve|apply|create)
        _arguments -s -S \
          $build_flags \
          '(-f --filename)'{-f+,--filename=}'[filename, directory, or URL]:file:_files' \
          '(-R --recursive)'{-R,--recursive}'[process the directory recursively]' \
          '(-l --selector)'{-l+,--selector=}'[selector (label query) to filter on]:selector' \
          '*:importpath' && ret=0
        ;;
      delete)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help information]' \
          '(-f --filename)'{-f+,--filename=}'[filename, directory, or URL to delete]:file:_files' \
          '(-R --recursive)'{-R,--recursive}'[process the directory recursively]' \
          '(-l --selector)'{-l+,--selector=}'[selector (label query) to filter on]:selector' && ret=0
        ;;
      run)
        _arguments -s -S $build_flags '*:importpath' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[display help information]' \
          '(-u --username)'{-u+,--username=}'[username for registry authentication]:username' \
          '(-p --password)'{-p+,--password=}'[password for registry authentication]:password' \
          '--password-stdin[take the password from stdin]' \
          '1:server' && ret=0
        ;;
    esac
    ;;
esac

return ret
