#compdef kubectl-grep
# Documentation: https://github.com/guessi/kubectl-grep
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-grep (guessi/kubectl-grep). Syntax: kubectl grep RESOURCE-TYPE [keyword]
# Resource type is the FIRST positional arg, optional keyword is second.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[search resources in all namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:namespace:' \
  '(-l --selector)'{-l+,--selector=}'[label selector]:selector:' \
  '--field-selector=[field selector]:fields:' \
  '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
  '(-x --exclude)'{-x+,--exclude=}'[exclude pattern]:pattern:' \
  '(-t --timeout)'{-t+,--timeout=}'[API call timeout]:duration:' \
  '1:resource type:->restype' \
  '*:keyword: _default' && ret=0

case $state in
  restype)
    local -a restype=(
      version
      pods po pod
      deployments deploy deployment
      replicasets rs replicaset
      statefulsets sts statefulset
      daemonsets ds daemonset
      hpas hpa
      cronjobs cj cronjob
      jobs job
      ingresses ing ingress
      roles role
      rolebindings rolebinding
      clusterroles clusterrole
      clusterrolebindings clusterrolebinding
      csidrivers
      storageclasses sc
      configmaps cm configmap
      nodes no node
      secrets secret
      serviceaccounts sa serviceaccount
      services svc service
    )
    _describe -t restype 'resource type' restype && ret=0
    ;;
esac

return ret
