#compdef rofi
# Documentation: https://davatorium.github.io/rofi/current/rofi.1/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[display help]' \
  '(- *)-version[display version]' \
  '-info[show useful debugging information]' \
  '-show[open in specified mode]:mode:(window windowcd run drun ssh combi keys filebrowser script)' \
  '-modes[enabled modes (comma list)]:modes:' \
  '-dmenu[run rofi in dmenu mode]' \
  '-e[show message dialog]:message:' \
  '-rasi-validate[validate a rasi file]:file:_files -g "*.rasi"' \
  '-list-keybindings[list all known keybindings]' \
  '-dump-config[dump current config in rasi format]' \
  '-dump-theme[dump current theme in rasi format]' \
  '-threads[number of threads]:n:' \
  '-display[X display]:display:' \
  '-wayland-layer[Wayland layer]:layer:(background bottom top overlay)' \
  '-case-sensitive[case-sensitive matching]' \
  '-case-smart[vim-like smartcase]' \
  '-cycle[cycle through results]' \
  '-filter[set initial filter text]:filter:' \
  '-config[alternative config file]:file:_files -g "*.rasi"' \
  '-cache-dir[directory for cached files]:dir:_directories' \
  '-scroll-method[scroll method]:m:(0 1)' \
  '-normalize-match[normalize strings before matching]' \
  '-no-lazy-grab[force keyboard grab before GUI]' \
  '-no-plugins[disable plugins]' \
  '-plugin-path[plugin directory]:dir:_directories' \
  '-show-icons[show application icons]' \
  '-icon-theme[icon theme]:theme:' \
  '-markup[use Pango markup]' \
  '-normal-window[behave as normal window]' \
  '-transient-window[modal to focused window]' \
  '-steal-focus[steal focus]' \
  '-no-steal-focus[do not steal focus]' \
  '-refilter-timeout-limit[ms before switching filter mode]:ms:' \
  '-matching[matching algorithm]:algorithm:(normal regex glob fuzzy prefix)' \
  '-tokenize[tokenized word matching]' \
  '-no-tokenize[disable tokenization]' \
  '-drun-categories[restrict drun to categories]:cats:' \
  '-drun-exclude-categories[exclude drun categories]:cats:' \
  '-drun-match-fields[drun fields to match]:fields:' \
  '-drun-display-format[drun display format]:fmt:' \
  '-drun-show-actions[show desktop file actions]' \
  '-no-drun-show-actions[hide desktop file actions]' \
  '-drun-use-desktop-cache[use desktop file cache]' \
  '-drun-reload-desktop-cache[rebuild desktop cache]' \
  '-drun-url-launcher[command for url launches]:cmd:' \
  '-window-match-fields[window match fields]:fields:' \
  '-window-format[window display format]:fmt:' \
  '-window-command[window action command]:cmd:' \
  '-window-thumbnail[show window thumbnails]' \
  '-combi-modes[modes for combi]:modes:' \
  '-combi-display-format[combi display format]:fmt:' \
  '-matching-negate-char[query negation char]:c:' \
  '-sort[enable sort]' \
  '-no-sort[disable sort]' \
  '-sorting-method[sort method]:m:(levenshtein fzf)' \
  '-location[window location 0-8]:loc:(0 1 2 3 4 5 6 7 8)' \
  '-fixed-num-lines[keep fixed line count]' \
  '-sidebar-mode[show mode sidebar]' \
  '-hover-select[select entry under mouse]' \
  '-eh[row height in chars]:n:' \
  '-auto-select[auto-select single entry]' \
  '(-m -monitor)'{-m,-monitor}'[monitor]:monitor:' \
  '-theme[theme file or name]:theme:_files -g "*.rasi"' \
  '-theme-str[override theme parts]:rasi:' \
  '-dpi[override DPI]:n:' \
  '-selected-row[initially selected row]:n:' \
  '-terminal[terminal emulator]:terminal:_command_names -e' \
  '-ssh-client[ssh client]:cmd:' \
  '-ssh-command[ssh launch command]:cmd:' \
  '-parse-hosts[parse /etc/hosts]' \
  '-parse-known-hosts[parse ~/.ssh/known_hosts]' \
  '-no-parse-known-hosts[do not parse known_hosts]' \
  '-run-command[run mode command]:cmd:' \
  '-run-shell-command[run shell command]:cmd:' \
  '-run-list-command[external run-list generator]:cmd:' \
  '-disable-history[disable history]' \
  '-no-disable-history[enable history]' \
  '-max-history-size[max history entries]:n:' \
  '-pid[pid file path]:file:_files' \
  '-replace[replace running rofi instance]' \
  '-click-to-exit[click-to-exit enabled]' \
  '-no-click-to-exit[click-to-exit disabled]' \
  '-global-kb[override compositor keybindings]' \
  '-no-global-kb[disable global keybindings]' \
  '-xserver-i300-workaround[apply Xserver workaround]' \
  && ret=0

return ret
