#compdef objection
# Documentation: https://github.com/sensepost/objection/blob/master/objection/console/cli.py
# Reference accessed: 2026-05-19
# Verified: objection upstream cli.py. Real top-level commands:
# api, start, explore (deprecated), run, version, patchipa,
# patchapk, signapk. Global flags: -N/--network, -L/--local,
# -h/--host, -P/--port, -ah/--api-host, -ap/--api-port,
# -n/--name, -S/--serial, -d/--debug, -s/--spawn, -p/--no-pause,
# -f/--foremost, --debugger, --uid.
# Corrected from prior file: removed bogus -g/--gadget,
# -S/--startup-script and -c at global level (these are 'start'
# subcmd flags), -P/--parameters (does not exist), -H/--host
# (real is -h/--host but conflicts with help — flatten),
# fabricated 'device-type' subcommand. Added 'api' and 'start'.

# Zsh completion for objection - mobile exploration toolkit (Frida-based)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-N --network)'{-N,--network}'[connect via network]' \
  '(-L --local)'{-L,--local}'[connect via local (iOS Simulator)]' \
  '--host=[host address]:host:' \
  '(-P --port)'{-P+,--port=}'[port]:port:' \
  '(-ah --api-host)'{-ah+,--api-host=}'[API host]:host:' \
  '(-ap --api-port)'{-ap+,--api-port=}'[API port]:port:' \
  '(-n --name)'{-n+,--name=}'[name or bundle identifier]:name:' \
  '(-S --serial)'{-S+,--serial=}'[device serial]:serial:' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-s --spawn)'{-s,--spawn}'[spawn target]' \
  '(-p --no-pause)'{-p,--no-pause}'[resume target immediately]' \
  '(-f --foremost)'{-f,--foremost}'[use foremost application]' \
  '--debugger[enable Chrome debug port]' \
  '--uid=[uid to run as (Android)]:uid:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'api:start objection API server in headless mode'
      'start:start a new objection session'
      'explore:deprecated alias for start'
      'run:run a single objection command'
      'version:show version'
      'patchipa:patch an IPA with the Frida gadget'
      'patchapk:patch an APK with the Frida gadget'
      'signapk:zipalign and sign an APK'
    )
    _describe -t commands 'objection command' commands && ret=0
    ;;
  args)
    case $line[1] in
      start|explore)
        _arguments -s -S \
          '(-P --plugin-folder)'{-P+,--plugin-folder=}'[plugin folder]:dir:_files -/' \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '(-s --startup-command)'{-s+,--startup-command=}'[command to run before REPL]:command:' \
          '(-c --file-commands)'{-c+,--file-commands=}'[file with commands]:file:_files' \
          '(-S --startup-script)'{-S+,--startup-script=}'[startup script]:script:_files -g "*.js"' \
          '(-a --enable-api)'{-a,--enable-api}'[start API server]' && ret=0
        ;;
      patchapk)
        _arguments -s -S \
          '(-s --source)'{-s+,--source=}'[APK file]:apk:_files -g "*.apk"' \
          '(-a --architecture)'{-a+,--architecture=}'[target architecture]:arch:(arm64-v8a armeabi-v7a x86 x86_64)' \
          '(-V --gadget-version)'{-V+,--gadget-version=}'[Frida gadget version]:version:' \
          '(-p --pause)'{-p,--pause}'[pause before rebuild]' \
          '(-k --skip-cleanup)'{-k,--skip-cleanup}'[retain temporary files]' \
          '(-d --enable-debug)'{-d,--enable-debug}'[set debuggable flag]' \
          '(-N --network-security-config)'{-N,--network-security-config}'[trust user CA certs]' \
          '(-D --skip-resources)'{-D,--skip-resources}'[skip resource decoding]' \
          '(-C --skip-signing)'{-C,--skip-signing}'[skip APK signing]' \
          '(-t --target-class)'{-t+,--target-class=}'[target class]:class:' \
          '(-2 --use-aapt2)'{-2,--use-aapt2}'[use aapt2]' \
          '(-c --gadget-config)'{-c+,--gadget-config=}'[Frida gadget config]:config:_files -g "*.json"' \
          '(-l --script-source)'{-l+,--script-source=}'[script source]:script:_files -g "*.js"' \
          '(-n --ignore-nativelibs)'{-n,--ignore-nativelibs}'[do not modify extractNativeLibs]' \
          '(-m --manifest)'{-m+,--manifest=}'[custom AndroidManifest.xml]:file:_files' \
          '--only-main-classes[patch main dex only]' \
          '(-j --fix-concurrency-to)'{-j+,--fix-concurrency-to=}'[thread limit]:n:' && ret=0
        ;;
      patchipa)
        _arguments -s -S \
          '(-s --source)'{-s+,--source=}'[IPA file]:ipa:_files -g "*.ipa"' \
          '(-V --gadget-version)'{-V+,--gadget-version=}'[Frida gadget version]:version:' \
          '(-c --codesign-signature)'{-c+,--codesign-signature=}'[codesign identity]:identity:' \
          '(-P --provision-file)'{-P+,--provision-file=}'[mobileprovision file]:file:_files' \
          '(-b --binary-name)'{-b+,--binary-name=}'[Mach-O binary name]:name:' \
          '(-k --skip-cleanup)'{-k,--skip-cleanup}'[retain temporary files]' \
          '(-p --pause)'{-p,--pause}'[pause before rebuild]' \
          '(-z --unzip-unicode)'{-z,--unzip-unicode}'[handle Unicode in IPA]' \
          '(-C --gadget-config)'{-C+,--gadget-config=}'[gadget config file]:config:_files' \
          '(-l --script-source)'{-l+,--script-source=}'[script source]:script:_files' && ret=0
        ;;
      signapk)
        _arguments -s -S \
          '(-k --skip-cleanup)'{-k,--skip-cleanup}'[retain temporary files]' \
          '*:apk:_files -g "*.apk"' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-d --hook-debug)'{-d,--hook-debug}'[print compiled hooks]' \
          '*:command:' && ret=0
        ;;
    esac
    ;;
esac

return ret
