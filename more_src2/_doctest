#compdef doctest
# _doctest — Python doctest stdlib test extractor CLI alias (python team, Python); argparse
# upstream: https://docs.python.org/3/library/doctest.html

_doctest() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose - print result of every test]' \
        '--verbose[verbose - print result of every test]' \
        '-f[stop after first failure]' \
        '--fail-fast[stop after first failure]' \
        '-o+[option]:o:(DONT_ACCEPT_TRUE_FOR_1 DONT_ACCEPT_BLANKLINE NORMALIZE_WHITESPACE ELLIPSIS SKIP IGNORE_EXCEPTION_DETAIL DONT_ACCEPT_TRUE_FOR_1 ALLOW_UNICODE ALLOW_BYTES NUMBER FAIL_FAST REPORT_UDIFF REPORT_CDIFF REPORT_NDIFF REPORT_ONLY_FIRST_FAILURE)' \
        '--option=+[option]:o:(DONT_ACCEPT_TRUE_FOR_1 DONT_ACCEPT_BLANKLINE NORMALIZE_WHITESPACE ELLIPSIS SKIP IGNORE_EXCEPTION_DETAIL ALLOW_UNICODE ALLOW_BYTES NUMBER FAIL_FAST REPORT_UDIFF REPORT_CDIFF REPORT_NDIFF REPORT_ONLY_FIRST_FAILURE)' \
        '*:files:_files -g "*.{py,txt,rst,md}"'
}

_doctest "$@"
