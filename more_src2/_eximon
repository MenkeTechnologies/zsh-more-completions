#compdef eximon
# Documentation: https://manpages.debian.org/bookworm/exim4-base/eximon.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm eximon(8) manpage. Synopsis is bare `eximon`; no
# CLI flags documented. Behavior is controlled by X resources and the
# eximon.conf file, not options.
# Removed from prior file: fabricated -h/--help/-V/--version flags (not
# accepted by the binary) and bogus man.archlinux.org search URL.

# eximon: X11 monitor for the Exim mail transfer agent
local curcontext="$curcontext" ret=1
_arguments -C && ret=0
return ret
