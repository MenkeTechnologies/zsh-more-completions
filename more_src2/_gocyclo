#compdef gocyclo
# Documentation: https://github.com/fzipp/gocyclo
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gocyclo - Go cyclomatic complexity analyzer

local -a arguments

arguments=(
  '-over[show functions with complexity above this threshold]:threshold:'
  '-top[show top N most complex functions]:n:'
  '-avg[show the average complexity]'
  '-avg-short[show only the average complexity as a number]'
  '-total[show total complexity of all functions]'
  '-total-short[show only the total complexity as a number]'
  '-ignore[regex to match paths to ignore]:pattern:'
  '-help[show help information]'
  '*:path:_files'
)

_arguments -s $arguments
