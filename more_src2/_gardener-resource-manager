#compdef gardener-resource-manager
# _gardener-resource-manager — Gardener resource-manager (manages ManagedResources)
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-resource-manager/app/options.go on tip.

_gardener-resource-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[resource-manager config file]:file:_files -g "*.(yaml|yml)"' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardener-resource-manager "$@"
