#compdef mdbook-tabs
# _mdbook-tabs — mdbook preprocessor for tabbed sections (RustForWeb/mdbook-plugins)
# upstream: https://github.com/RustForWeb/mdbook-plugins
# Subcommands from packages/mdbook-tabs/src/bin/mdbook-tabs.rs (clap).

_mdbook-tabs() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'install:install theme assets into book directory'
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-tabs "$@"
