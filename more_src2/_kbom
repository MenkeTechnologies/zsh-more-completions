#compdef kbom
# _kbom — Kubernetes Bill of Materials generator (rad-security/kbom)
# upstream: https://github.com/rad-security/kbom
# Subcommands + flags from cmd/*.go (cobra).

_kbom() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --context)'{-c+,--context=}'[Kubernetes context to use (default: current)]:context:' \
        '(-v --verbose)'{-v,--verbose}'[enable verbose (DEBUG+) logging]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_kbom_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                generate)
                    _arguments \
                        '--short[only include metadata, nodes, images and resource counts]' \
                        '(-o --output)'{-o+,--output=}'[output destination]:dest:(stdout file)' \
                        '(-f --format)'{-f+,--format=}'[output format]:format:(json yaml cyclonedx-json cyclonedx-xml)' \
                        '(-p --out-path)'{-p+,--out-path=}'[directory for the KBOM file (with --output=file)]:dir:_files -/'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kbom_commands] )) ||
_kbom_commands() {
    local -a commands
    commands=(
        'generate:generate a KBOM for the connected Kubernetes cluster'
        'schema:print the KBOM JSON schema'
        'version:print the kbom version'
        'help:help about any command'
    )
    _describe -t commands 'kbom command' commands
}

_kbom "$@"
