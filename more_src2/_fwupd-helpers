#compdef fwupd-helpers fwupd
# Documentation: https://github.com/fwupd/fwupd/blob/main/src/fu-main.c
# Reference accessed: 2026-05-16
# Verified: upstream src/fu-main.c GOptionEntry array.

# fwupd: firmware update daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '--timed-exit[exit after a small delay]' \
  '--immediate-exit[exit after the engine has loaded]' \
  '--verbose[verbose output]' \
  '--plugin-verbose=[verbose for specific plugin]:plugin:' \
  '--no-timestamp[disable timestamp in log output]' \
  '--no-domain[disable domain in log output]' \
  '--log=[log to file]:file:_files' && ret=0
return ret
