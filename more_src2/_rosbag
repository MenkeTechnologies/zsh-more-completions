#compdef rosbag
# Documentation: http://wiki.ros.org/rosbag/Commandline
# Source: ros/ros_comm noetic-devel tools/rosbag/src/rosbag/rosbag_main.py — ROS1 bag file record/playback CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:((
        record\:"record specified topics to a bag"
        info\:"summarize contents of bag file(s)"
        play\:"play back bag file(s) in time-synchronized order"
        check\:"check if a bag is playable or migratable"
        fix\:"repair bag messages so they can be played"
        filter\:"filter bag contents"
        compress\:"compress bag file(s)"
        decompress\:"decompress bag file(s)"
        reindex\:"reindex bag file(s)"
        encrypt\:"encrypt bag file(s) (Unix only)"
        decrypt\:"decrypt bag file(s) (Unix only)"
    ))' \
    '*::args:_files -g "*.bag(-.)"' \
    && ret=0

return ret
