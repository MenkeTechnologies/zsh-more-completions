#compdef node-red
# Documentation: https://nodered.org/docs/getting-started/local
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Flags per Node-RED Getting Started: -p/--port, -s/--settings,
# --title, -u/--userDir, -v (no --verbose long form), --safe,
# -D X=Y|@file (no --define long form), -?/--help.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --port)'{-p+,--port=}'[set the TCP port to listen on]:port' \
  '(-s --settings)'{-s+,--settings=}'[set the settings file]:settings file:_files -g "*.js"' \
  '--title=[set a custom process title]:title' \
  '(-u --userDir)'{-u+,--userDir=}'[set the user directory]:directory:_files -/' \
  '-v[enable verbose output]' \
  '--safe[start in safe mode without launching flows]' \
  '*-D+[override individual settings (key=value or @file)]:key=value or @file' \
  '(-? --help)'{-\?,--help}'[print help]' \
  ':flow file or project name:_files -g "*.json"' && ret=0

return ret
