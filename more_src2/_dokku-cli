#compdef dokku-cli
# _dokku-cli — Dokku PaaS the smallest open-source PaaS CLI alias (dokku team, Shell/Go); custom argparse
# upstream: https://github.com/dokku/dokku

_dokku-cli() {
    local -a sub=(
        'apps:list:list apps'
        'apps:create:create app'
        'apps:destroy:destroy app'
        'apps:rename:rename app'
        'apps:exists:check app exists'
        'apps:lock:lock app'
        'apps:unlock:unlock app'
        'apps:locked:check lock'
        'apps:report:show report'
        'apps:clone:clone app'
        'apps:transfer:transfer app'
        'config:show:show config'
        'config:get:get config var'
        'config:set:set config vars'
        'config:unset:unset config vars'
        'config:clear:clear config'
        'config:export:export config'
        'config:keys:list config keys'
        'config:bundle:bundle config'
        'domains:show:show domains'
        'domains:add:add domain'
        'domains:remove:remove domain'
        'domains:clear:clear domains'
        'domains:report:show report'
        'domains:set:set domain'
        'domains:enable:enable domains'
        'domains:disable:disable domains'
        'domains:add-global:add global domain'
        'domains:remove-global:remove global domain'
        'domains:set-global:set global domain'
        'domains:clear-global:clear global domain'
        'domains:report-global:global report'
        'enter:enter container'
        'events:show events'
        'events:on:turn on events'
        'events:off:turn off events'
        'events:list:list events'
        'events:logs:event logs'
        'git:auth:setup auth'
        'git:from-archive:deploy from archive'
        'git:from-image:deploy from image'
        'git:initialize:initialize git'
        'git:public-key:get public key'
        'git:report:git report'
        'git:set:set git option'
        'git:sync:sync git'
        'git:unlock:unlock git repo'
        'help:show help'
        'logs:show logs'
        'logs:failed:show failed logs'
        'logs:report:logs report'
        'logs:set:set log option'
        'network:list:list networks'
        'network:create:create network'
        'network:destroy:destroy network'
        'network:exists:check network exists'
        'network:info:show network info'
        'network:report:network report'
        'network:rebuildall:rebuild networks'
        'network:set:set network option'
        'nginx:start:start nginx'
        'nginx:stop:stop nginx'
        'nginx:reload:reload nginx'
        'nginx:report:show nginx report'
        'nginx:set:set nginx option'
        'nginx:validate-config:validate nginx config'
        'nginx:access-logs:show access logs'
        'nginx:error-logs:show error logs'
        'nginx:show-config:show nginx config'
        'plugin:install:install plugin'
        'plugin:install-dependencies:install plugin deps'
        'plugin:list:list plugins'
        'plugin:uninstall:uninstall plugin'
        'plugin:update:update plugins'
        'plugin:enable:enable plugin'
        'plugin:disable:disable plugin'
        'plugin:trigger:run plugin trigger'
        'ps:show running processes'
        'ps:scale:scale processes'
        'ps:report:show ps report'
        'ps:restart:restart app'
        'ps:rebuild:rebuild app'
        'ps:start:start app'
        'ps:stop:stop app'
        'ps:stopinparallel:stop in parallel'
        'ps:inspect:inspect ps'
        'ps:retire:retire ps'
        'ps:set:set ps option'
        'proxy:enable:enable proxy'
        'proxy:disable:disable proxy'
        'proxy:set:set proxy'
        'proxy:ports:show ports'
        'proxy:ports-add:add ports'
        'proxy:ports-remove:remove ports'
        'proxy:ports-set:set ports'
        'proxy:ports-clear:clear ports'
        'proxy:report:proxy report'
        'registry:set:set registry option'
        'registry:login:login to registry'
        'registry:report:registry report'
        'registry:logout:logout from registry'
        'registry:pull:pull image'
        'storage:list:list storage mounts'
        'storage:mount:mount storage'
        'storage:unmount:unmount storage'
        'storage:ensure-directory:ensure dir exists'
        'storage:report:storage report'
        'tags:create:create tag'
        'tags:deploy:deploy tag'
        'tags:list:list tags'
        'tags:destroy:destroy tag'
        'tags:report:tags report'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--app=+[app]:str:' \
        '--global[global]' \
        '--quiet[quiet]' \
        '--force[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dokku subcommand' sub ;;
    esac
}

_dokku-cli "$@"
