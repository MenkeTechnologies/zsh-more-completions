#compdef kubectl-dup
# Documentation: https://github.com/vash/dup/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --disable-probes)'{-d,--disable-probes}'[disable readiness and liveness probes for duplicated pods]' \
  '(-p --pod)'{-p,--pod}'[duplicate pod of complex objects (StatefulSet/Deployment/CronJob/Job)]' \
  '(-k --skip-edit)'{-k,--skip-edit}'[skip editing duplicated resource before creation]' \
  '*:resource:_default'
