#compdef fence
# Documentation: https://github.com/Use-Tusk/fence/blob/main/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fence: sandbox CLI commands with network/filesystem restrictions (Use-Tusk/fence).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:inspect or initialize fence configuration'
  'import:import settings from external sources'
)

_arguments -s -S -C \
  '(- *)--help[show help]' \
  '-d[enable debug logging]' \
  '-m[monitor mode (display violations)]' \
  '-c[run a shell command (with shell expansion)]:command:' \
  '-t[use a template]:template:' \
  '-p[expose port]:port:' \
  '--settings=[path to custom config file]:file:_files' \
  '--fence-log-file=[direct fence logs to file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'fence subcommand' commands
    _command_names -e && ret=0 ;;
  (args)
    case $line[1] in
      (config)
        _arguments \
          '1:action:(show init)' \
          '--scaffold[include scaffold arrays as editable hints]' && ret=0 ;;
      (import)
        _arguments \
          '--save[save imported settings]' \
          '--claude[import from Claude Code]' && ret=0 ;;
      (*)
        _normal && ret=0 ;;
    esac ;;
esac

return ret
