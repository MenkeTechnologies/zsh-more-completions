#compdef lazynpm
# Documentation: https://github.com/jesseduffield/lazynpm
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-v --version)'{-v,--version}'[print current version]' \
  '(-d --debug)'{-d,--debug}'[run in debug mode with logging]' \
  '(-c --config)'{-c,--config}'[print default config]' \
  '(-p --path)'{-p,--path}'[path of package]:path:_files -/' && ret=0

return ret
