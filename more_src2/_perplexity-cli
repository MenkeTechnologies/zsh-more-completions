#compdef perplexity-cli
# Documentation: https://github.com/jamiemills/perplexity-cli
# Reference accessed: 2026-05-23
# Verified: pxcli / perplexity-cli README command reference.

# Zsh completion for perplexity-cli - Perplexity API CLI (pxcli)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'query:send a query'
  'auth:authenticate'
  'export-threads:export conversation threads'
  'configure:configure client'
  'set-config:set config value'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[INFO logging]' \
  '(-d --debug)'{-d,--debug}'[DEBUG logging]' \
  '--log-file[log file path]:file:_files' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'perplexity-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (query)
        _arguments \
          '(-f --format)'{-f+,--format=}'[output format]:format:(plain markdown rich json)' \
          '--strip-references[strip citations]' \
          '--stream[stream response]' \
          '--no-stream[wait for full response]' \
          '--attach[attach file]:file:_files' \
          ':query:' && ret=0
        ;;
      (auth)
        _arguments '--port[local auth port]:port:' && ret=0
        ;;
      (export-threads)
        _arguments \
          '--from-date[start date]:date:' \
          '--to-date[end date]:date:' \
          '(-o --output)'{-o+,--output=}'[output path]:file:_files' \
          '--force-refresh[force refresh]' \
          '--clear-cache[clear cache]' && ret=0
        ;;
      (configure|set-config)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
