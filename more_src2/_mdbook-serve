#compdef mdbook-serve
# Documentation: https://rust-lang.github.io/mdBook/cli/serve.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mdbook serve subcommand (standalone)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dest-dir)'{-d+,--dest-dir=}'[output directory]:directory:_directories' \
  '-n+[hostname to listen on]:hostname:_hosts' \
  '-p+[port to listen on]:port:' \
  '(-o --open)'{-o,--open}'[open browser after starting server]' \
  '--watcher=[file change detection backend]:backend:(poll native)' \
  '1:directory:_directories' && ret=0

return ret
