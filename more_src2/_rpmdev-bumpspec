#compdef rpmdev-bumpspec
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-bumpspec
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools rpmdev-bumpspec source.

# rpmdev-bumpspec: bump release+changelog in RPM spec files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --comment)'{-c+,--comment=}'[changelog comment (default \\- rebuilt)]:comment:' \
  '(-u --userstring)'{-u+,--userstring=}'[user name+email string]:user:' \
  '(-r --rightmost)'{-r,--rightmost}'[bump rightmost integer or append .1]' \
  '(-n --new)'{-n+,--new=}'[new package version (resets release to 1)]:version:' \
  '(-V --verbose)'{-V,--verbose}'[additional output]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:spec file:_files -g "*.spec(-.)"' && ret=0
return ret
