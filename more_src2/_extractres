#compdef extractres
# Documentation: extractres usage (psutils)
# Source: extract embedded resources (fonts/procsets) from a PostScript file into separate files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-merge[merge resources extracted from multiple files of same name]' \
    '1:ps file:_files -g "*.ps"' \
    && ret=0

return ret
