#compdef llama-gen-docs
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/examples/gen-docs/gen-docs.cpp
# Reference accessed: 2026-05-27
# Verified: upstream gen-docs.cpp main() takes no command-line flags (it rewrites tools/cli/README.md, tools/completion/README.md, tools/server/README.md in place)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' && ret=0

return ret
