#compdef nop
# Documentation: man nop(1) (graphviz)
# Source: GraphViz nop — pretty-print DOT files in canonical form.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[validate only; produce no output]' \
    '(- *)-?[show usage]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
