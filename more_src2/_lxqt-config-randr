#compdef lxqt-config-randr
# Documentation: https://github.com/lxqt/lxqt-config
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: lxqt-config-randr was an older RandR tool replaced by lxqt-config-monitor
# in current LXQt; only built-in help and version are exposed.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
