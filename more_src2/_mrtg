#compdef mrtg
# Documentation: https://oss.oetiker.ch/mrtg/doc/mrtg.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. MRTG Multi Router Traffic Grapher.

_arguments -s \
  '--user=[run as user]:user:_users' \
  '--group=[run as group]:group:_groups' \
  '--lock-file=[lock file]:file:_files' \
  '--confcache-file=[config cache file]:file:_files' \
  '--logging=[log destination (filename or eventlog)]:dest:' \
  '--pid-file=[PID file]:file:_files' \
  '--debug=[debug categories (comma-separated)]:cats:' \
  '--daemon[run as daemon]' \
  '--fhs[use FHS layout]' \
  '--check[check config and exit]' \
  '--log-only[update logfile only, no graphics/html]' \
  ':cfgfile:_files'
