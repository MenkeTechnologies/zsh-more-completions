#compdef mysqlshow
# Documentation: https://mariadb.com/kb/en/mysqlshow/
# Source: MariaDB/server client/mysqlshow.c — show databases/tables/columns (C, my_getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-c+,--character-sets-dir=}'[directory for character set files]:dir:_files -/' \
    '--default-character-set=-[default character set]:charset:_default' \
    '--count[show row count of each table]' \
    {-C,--compress}'[use compression in server/client protocol]' \
    '--debug=-[debug log spec]:spec:_default' \
    '--debug-check[check memory and open file usage at exit]' \
    '--debug-info[print debug info on exit]' \
    {-\?,--help}'[show help]' \
    {-h+,--host=}'[server host]:host:_hosts' \
    {-i,--status}'[show extra info about each table]' \
    {-k,--keys}'[show keys for table]' \
    {-p-,--password=-}'[password]::pass:_default' \
    {-P+,--port=}'[port number]:port:_default' \
    {-W,--pipe}'[use named pipes]' \
    '--protocol=-[connection protocol]:protocol:(TCP SOCKET PIPE MEMORY)' \
    {-t,--show-table-type}'[show table type column]' \
    {-S+,--socket=}'[socket file]:file:_files' \
    {-u+,--user=}'[login user]:user:_users' \
    {-v,--verbose}'[verbose output]' \
    {-V,--version}'[show version]' \
    '*:db/table/column:_default' \
    && ret=0

return ret
