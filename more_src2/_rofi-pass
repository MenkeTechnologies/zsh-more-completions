#compdef rofi-pass
# Documentation: https://github.com/carnager/rofi-pass
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (main case statement).

# Zsh completion for rofi-pass (rofi-based interface for pass/password-store)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--insert[insert a new password entry]:name:' \
  '--root[set password-store root]:dir:_files -/' \
  '--last-used[highlight last used entry]' \
  '--show-last[show details for last used entry]' \
  '--bmarks[open bookmarks mode]' \
  '--help[show help]' && ret=0

return ret
