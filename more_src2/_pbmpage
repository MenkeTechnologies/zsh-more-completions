#compdef pbmpage
# Documentation: man pbmpage (Netpbm)
# Source: generate a printer test page (PBM).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a4[use A4 page size (default Letter)]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:test pattern number:' \
    && ret=0

return ret
