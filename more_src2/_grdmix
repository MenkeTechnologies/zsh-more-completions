#compdef grdmix
# Documentation: https://docs.generic-mapping-tools.org/latest/grdmix.html
# Source: GenericMappingTools/gmt classic-mode grdmix — blend grids+images / build RGBA / decompose / set alpha.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output raster (image or grid)]:file:_files' \
    '-A+[alpha layer (constant/grid/image)]:opts:_default' \
    '-C+[build image from grids / apply CPT]:opts:_default' \
    '-D[decompose image → R/G/B/A grids]' \
    '-I+[intensity grid / constant]:opts:_default' \
    '-M[monochrome (YIQ)]' \
    '-N+[normalize 0..255 / 0..1]:opts:_default' \
    '-Q[remove alpha (make opaque)]' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[blending weights for two rasters]:opts:_default' \
    '-f+[I/O column data types]:types:_default' \
    '*:input raster:_files -g "*.(grd|nc|tif|cdf|png|jpg|jpeg|gif|tiff)(-.)"' \
    && ret=0

return ret
