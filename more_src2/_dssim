#compdef dssim
# Documentation: https://github.com/kornelski/dssim
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# RGBA Structural Similarity Rust implementation

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-o+[write difference visualization to file]:output png:_files -g "*.png"' \
  '*:image:_files -g "*.(png|jpg|jpeg|webp)"' && ret=0

return ret
