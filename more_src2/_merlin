#compdef merlin ocamlmerlin
# Documentation: https://github.com/ocaml/merlin
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'server:run as server'
  'single:run single query'
  'stop-server:stop server'
  'list:list features'
  'check-config:validate config'
  'help:show help'
  'old-protocol:use legacy protocol'
)

_arguments -C \
  '(- *)-h[show help]' \
  '-version[show version]' \
  '-vnum[print numeric version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'merlin command' commands && ret=0 ;;
esac

return ret
