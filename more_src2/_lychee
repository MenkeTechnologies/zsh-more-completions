#compdef lychee
# Documentation: https://github.com/lycheeverse/lychee/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*'{-c,--config}'+[config file]:file:_files -g "*.toml"' \
  '*'{-v,--verbose}'[verbose output]' \
  '*'{-q,--quiet}'[less output]' \
  '(-n --no-progress)'{-n,--no-progress}'[do not show progress bar]' \
  '--cache[use request cache]' \
  '--cache-exclude-status=[status codes ignored from cache]:codes:' \
  '--max-cache-age=[max cache age]:duration:' \
  '--dump[dump all found links]' \
  '--dump-inputs[dump all input sources]' \
  '--archive=[web archive for suggestions]:archive:' \
  '--suggest[suggest link replacements]' \
  '*--exclude=[exclude URLs matching regex]:pattern:' \
  '*--exclude-path=[exclude file path matching regex]:pattern:' \
  '(-E --exclude-all-private)'{-E,--exclude-all-private}'[exclude all private IPs]' \
  '--exclude-private[exclude private IP ranges]' \
  '--exclude-link-local[exclude link-local addresses]' \
  '--exclude-loopback[exclude loopback addresses]' \
  '*--include=[include URL pattern]:pattern:' \
  '--include-fragments=[check fragments]:mode:(none anchor-only text-only full)' \
  '--include-mail[also check email addresses]' \
  '--include-verbatim[find links in verbatim sections]' \
  '--include-wikilinks[check WikiLinks in Markdown]' \
  '--index-files=[resolve directory links to index]:files:' \
  '*--remap=[remap URI pattern]:pattern:' \
  '*'{-H,--header}'+[custom request header]:header:' \
  '(-a --accept)'{-a,--accept}'+[accepted status codes]:codes:' \
  '--accept-timeouts[treat timeouts as success]' \
  '(-t --timeout)'{-t,--timeout}'+[request timeout]:seconds:' \
  '(-r --retry-wait-time)'{-r,--retry-wait-time}'+[retry wait time]:seconds:' \
  '--max-retries=[max retries]:count:' \
  '(-m --max-redirects)'{-m,--max-redirects}'+[max redirects]:count:' \
  '--max-concurrency=[max concurrent requests]:count:' \
  '--host-concurrency=[max concurrent requests per host]:count:' \
  '--host-request-interval=[min interval between requests to same host]:duration:' \
  '--host-stats[show per-host statistics]' \
  '(-T --threads)'{-T,--threads}'+[number of threads]:count:' \
  '(-u --user-agent)'{-u,--user-agent}'+[custom user agent]:agent:' \
  '(-i --insecure)'{-i,--insecure}'[skip TLS verification]' \
  '--min-tls=[minimum accepted TLS version]:version:' \
  '(-s --scheme)'{-s,--scheme}'+[only check specified schemes]:scheme:' \
  '--offline[only check local files]' \
  '(-b --base-url)'{-b,--base-url}'+[base URL]:url:' \
  '--basic-auth=[basic auth credentials]:user\:pass:' \
  '--github-token=[GitHub API token]:token:' \
  '--skip-missing[skip missing input files]' \
  '--no-ignore[do not skip ignore-listed files]' \
  '--hidden[do not skip hidden files]' \
  '--glob-ignore-case[case-insensitive globbing]' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-f --format)'{-f,--format}'+[output format]:format:(compact detailed json markdown raw)' \
  '--mode=[output display mode]:mode:' \
  '--require-https[require HTTPS links]' \
  '--cookie-jar=[cookie jar file]:file:_files' \
  '--default-extension=[default file extension]:ext:' \
  '--extensions=[file extensions]:exts:' \
  '--fallback-extensions=[fallback extensions]:exts:' \
  '--files-from=[read input filenames from file]:file:_files' \
  '--generate=[generate special output]:type:' \
  '--root-dir=[root directory for absolute links]:dir:_files -/' \
  '(-p --preprocess)'{-p,--preprocess}'+[preprocess command]:command:' \
  '(-X --method)'{-X,--method}'+[request method]:method:(GET HEAD POST PUT DELETE OPTIONS)' \
  '*:inputs:_files' && ret=0

return ret
