#compdef ranger-usersync ranger-usersync-services.sh
# Documentation: https://github.com/apache/ranger/blob/master/unixauthservice/scripts/ranger-usersync-services.sh
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a actions

actions=(
  'start:start the Ranger usersync service'
  'stop:stop the Ranger usersync service'
  'restart:restart the Ranger usersync service'
  'version:show version'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->action' && ret=0

case $state in
  (action)
    _describe -t actions 'ranger-usersync action' actions && ret=0
    ;;
esac

return ret
