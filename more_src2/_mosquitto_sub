#compdef mosquitto_sub
# Documentation: https://mosquitto.org/man/mosquitto_sub-1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mosquitto_sub - MQTT subscribe client.
_arguments -s -S \
  '(- *)--help[show help]' \
  '(-h --host)'{-h+,--host=}'[broker host]:host:_hosts' \
  '--unix=[broker UNIX socket path]:socket:_files' \
  '(-p --port)'{-p+,--port=}'[broker port]:port' \
  '(-L --url)'{-L+,--url=}'[mqtt(s) URL]:url' \
  '-A+[bind to source address]:address' \
  '--nodelay[disable TCP Nagle algorithm]' \
  '-S[use SRV lookups]' \
  '--ws[use MQTT over WebSockets]' \
  '--proxy=[SOCKS5 proxy URL]:url' \
  '(-u --username)'{-u+,--username=}'[broker username]:user:_users' \
  '(-P --pw)'{-P+,--pw=}'[broker password]:password' \
  '-E[exit once all subscriptions acknowledged]' \
  '-o+[config file path]:file:_files' \
  '-W+[timeout (seconds)]:seconds' \
  '(-c --disable-clean-session)'{-c,--disable-clean-session}'[persistent client mode]' \
  '*'{-D+,--property=}'[MQTT v5 property]:property' \
  '(-i --id)'{-i+,--id=}'[client ID]:id' \
  '(-I --id-prefix)'{-I+,--id-prefix=}'[client ID prefix]:prefix' \
  '(-k --keepalive)'{-k+,--keepalive=}'[keepalive interval (seconds)]:seconds' \
  '(-q --qos)'{-q+,--qos=}'[quality of service level]:qos:(0 1 2)' \
  '--retain-as-published[set retain-as-published subscription option]' \
  '--retain-handling=[when to deliver retained messages]:mode:(always new never)' \
  '(-V --protocol-version)'{-V+,--protocol-version=}'[MQTT protocol version]:version:(mqttv31 mqttv311 mqttv5)' \
  '-x+[session expiry interval]:seconds' \
  '--will-topic=[will topic]:topic' \
  '--will-payload=[will payload]:payload' \
  '--will-qos=[will QoS]:qos:(0 1 2)' \
  '--will-retain[mark will as retained]' \
  '(-d --debug)'{-d,--debug}'[enable debug messages]' \
  '-C+[disconnect after receiving COUNT messages]:count' \
  '--message-rate=[rate-limit message delivery]:rate' \
  '-N[do not print end-of-line character]' \
  '--pretty[pretty-print JSON payloads]' \
  '--random-filter=[randomly filter (drop) messages by percentage]:percent' \
  '--remove-retained[clear retained messages received]' \
  '(-R --retained-only)'{-R,--retained-only}'[only print retained messages]' \
  '--quiet[do not print error messages]' \
  '*'{-T+,--filter-out=}'[filter out matching topics]:topic filter' \
  '(-v --verbose)'{-v,--verbose}'[print topic and payload]' \
  '-F+[output format string]:format' \
  '(-w --watch)'{-w,--watch}'[watch mode (re-subscribe on disconnect)]' \
  '--no-tls[disable TLS encryption]' \
  '--cafile=[CA certificate file]:file:_files' \
  '--capath=[CA certificates directory]:dir:_directories' \
  '--tls-use-os-certs[use OS-provided certificates]' \
  '--cert=[client certificate file]:file:_files' \
  '--key=[client private key file]:file:_files' \
  '--ciphers=[TLS cipher list]:ciphers' \
  '--insecure[disable hostname verification]' \
  '--tls-alpn=[TLS ALPN protocol]:name' \
  '--tls-keylog=[TLS keylog file]:file:_files' \
  '--tls-version=[TLS protocol version]:version:(tlsv1.2 tlsv1.3)' \
  '--tls-engine=[OpenSSL engine ID]:engine' \
  '--keyform=[private key format]:format:(pem engine)' \
  '--tls-engine-kpass-sha1=[engine password SHA1]:hash' \
  '--psk=[pre-shared key (hex)]:key' \
  '--psk-identity=[PSK identity]:identity' \
  '*'{-t+,--topic=}'[subscribe topic]:topic' \
  '*'{-U+,--unsubscribe=}'[unsubscribe from topic]:topic'
