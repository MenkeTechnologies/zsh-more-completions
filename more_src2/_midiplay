#compdef midiplay
# Documentation: man midiplay(1)
# Source: netbsd/src usr.bin/midiplay — play MIDI/RMID files via sequencer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[MIDI device number]:device number:_default' \
    '-f+[sequencer device path]:sequencer device:_files' \
    '-l[list available devices, do not play]' \
    '-m[show MIDI metadata (copyright, lyrics)]' \
    '-p+[force program 1-128 on all channels]:program:_default' \
    '-q[parse file without playing]' \
    '-s[send ALL SOUNDS OFF before exit]' \
    '-t+[tempo adjust percentage (100 = normal)]:tempo:_default' \
    '*-v[verbose (repeatable)]' \
    '-x[play demonstration sound]' \
    '*:MIDI file:_files' \
    && ret=0

return ret
