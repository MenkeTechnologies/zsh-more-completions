#compdef ios-deploy
# Documentation: https://github.com/ios-control/ios-deploy
# Source: ios-deploy — install/run/debug iOS apps on a physical device from the command line.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d --debug)'{-d,--debug}'[launch app in lldb after installation]' \
    '(-i --id)'{-i+,--id=}'[device ID to connect to]:id:' \
    '(-c --detect)'{-c,--detect}'[list all connected devices]' \
    '(-b --bundle)'{-b+,--bundle=}'[app bundle to install]:bundle:_files -/' \
    '(-a --args)'{-a+,--args=}'[command-line args to pass to the app]:args:' \
    '(-s --envs)'{-s+,--envs=}'[env vars (space-separated key=value)]:envs:' \
    '(-t --timeout)'{-t+,--timeout=}'[seconds to wait for a device]:seconds:' \
    '(-u --unbuffered)'{-u,--unbuffered}'[do not buffer stdout]' \
    '(-n --nostart)'{-n,--nostart}'[do not start the app when debugging]' \
    '(-N --nolldb)'{-N,--nolldb}'[start debugserver only; do not run lldb]' \
    '(-I --noninteractive)'{-I,--noninteractive}'[non-interactive (quit on crash/exit)]' \
    '(-L --justlaunch)'{-L,--justlaunch}'[launch app and exit lldb]' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-m --noinstall)'{-m,--noinstall}'[debug directly without installing]' \
    '(-A --app_deltas)'{-A+,--app_deltas=}'[incremental install; deltas directory]:dir:_directories' \
    '(-p --port)'{-p+,--port=}'[port used for device (default dynamic)]:port:' \
    '(-r --uninstall -9 --uninstall_only)'{-r,--uninstall}'[uninstall before install]' \
    '(-r --uninstall -9 --uninstall_only)'{-9,--uninstall_only}'[uninstall the app ONLY]' \
    '(-1 --bundle_id)'{-1+,--bundle_id=}'[bundle id (for list/upload/etc)]:bundle id:' \
    '(-l --list)'{-l-,--list=-}'[list all app files or specified directory]:dir:' \
    '(-o --upload)'{-o+,--upload=}'[upload file]:file:_files' \
    '(-w --download)'{-w-,--download=-}'[download app tree or specified file/dir]:path:' \
    '(-2 --to)'{-2+,--to=}'[target pathname for up/download]:target:' \
    '(-D --mkdir)'{-D+,--mkdir=}'[mkdir on device]:dir:' \
    '(-R --rm)'{-R+,--rm=}'[remove file or dir on device]:path:' \
    '(-X --rmtree)'{-X+,--rmtree=}'[remove directory recursively]:path:' \
    '(- *)'{-V,--version}'[print version]' \
    '(-e --exists)'{-e,--exists}'[check if app with bundle_id is installed]' \
    '(-B --list_bundle_id)'{-B,--list_bundle_id}'[list bundle ids]' \
    '(-W --no-wifi)'{-W,--no-wifi}'[ignore wifi devices]' \
    '(-C --get_battery_level)'{-C,--get_battery_level}'[get battery capacity]' \
    '(-O --output)'{-O+,--output=}'[write stdout to this file]:file:_files' \
    '(-E --error_output)'{-E+,--error_output=}'[write stderr to this file]:file:_files' \
    '--detect_deadlocks=[periodic backtraces for all threads]:seconds:' \
    '(-f --file_system)'{-f,--file_system}'[specify file system for mkdir/list/upload/download/rm]' \
    '(-F --non-recursively)'{-F,--non-recursively}'[non-recursive directory walk]' \
    '(-S --symbols)'{-S+,--symbols=}'[download OS symbols to directory]:dir:_directories' \
    '(-j --json)'{-j,--json}'[JSON output]' \
    '(-k --key)'{-k+,--key=}'[keys for properties of bundle]:keys:' \
    '--custom-script=[custom Python script to execute in lldb]:script:_files' \
    '--custom-command=[additional lldb command to execute]:command:' \
    '--faster-path-search[alternative device-support-path search]' \
    '(-P --list_profiles)'{-P,--list_profiles}'[list provisioning profiles on device]' \
    '--profile-uuid=[provisioning profile UUID to target]:uuid:' \
    '--profile-download=[download provisioning profile]:path:_files' \
    '--profile-install=[install provisioning profile]:file:_files' \
    '--profile-uninstall[uninstall provisioning profile]' \
    '--check-developer-mode[check whether Developer Mode is enabled]' \
    && ret=0

return ret
