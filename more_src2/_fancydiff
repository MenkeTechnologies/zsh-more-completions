#compdef fancydiff
# Documentation: da-x/fancydiff
# Source: da-x/fancydiff app/Internal/Opts.hs (master) — colorized diff highlighter (Haskell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'file:format a single file'
    'stdin:format from stdin'
    'make-scss:emit SCSS for HTML themes'
    'setup:configure git/local aliases'
)

_arguments -s -C \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-f --format)'{-f+,--format=}'[output format]:format:(ansi html html-inline html-css meta)' \
    '(-p --pager)'{-p+,--pager=}'[pager]:pager:(less none)' \
    '(-t --theme)'{-t+,--theme=}'[color theme]:theme:(dark bright)' \
    '1:command:->cmd' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmd) _describe -t commands 'fancydiff command' cmds && ret=0 ;;
    cmdargs)
        case $line[1] in
            file) _arguments '1:pathname:_files' '-e[edit by running editor]' ;;
            stdin) _arguments '--highlighter=[language highlighter]:lang:_default' '--filename=[implicit filename for type detection]:file:_files' ;;
            setup) _arguments '(-a --aliases)'{-a,--aliases}'[only configure git aliases]' '(-l --local)'{-l,--local}'[apply locally instead of globally]' ;;
        esac
        ;;
esac

return ret
