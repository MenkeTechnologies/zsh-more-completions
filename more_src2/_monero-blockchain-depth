#compdef monero-blockchain-depth
# Documentation: https://github.com/monero-project/monero/blob/master/src/blockchain_utilities/blockchain_depth.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Source: https://github.com/BibXMR/monero-zsh-completions/blob/6540df4783f354863955175790dae12735e30b2d/_monero-blockchain-depth
# Repository: BibXMR/monero-zsh-completions (_monero-blockchain-depth)

_monero-blockchain-depth() {
  _arguments \
    '(- *)--help[Produce help message]' \
    '--data-dir=[Specify data directory]:data directory:_directories' \
    '--height=[Get min depth for all txes at this height]:block height' \
    '--include-coinbase[Include coinbase in the average]' \
    '--log-level=[0-4 or categories]:log level' \
    '(--testnet --regtest)--stagenet[Run on stagenet]' \
    '(--stagenet --regtest)--testnet[Run on testnet]' \
    '(--testnet --stagenet)--regtest[Run on regtest]' \
    '--txid=[Get min depth for this txid]:transaction hash'
}

_monero-blockchain-depth "$@"
