#compdef kuby
# ============================================================================
#  _kuby — Kuby: convention-over-configuration Rails-to-Kubernetes deployer
#
#  Source-direct extraction from
#    https://github.com/getkuby/kuby-core/blob/master/lib/kuby/commands.rb
#    https://github.com/davetron5000/gli (Git-Like Interface library)
#
#  Maintained by Getkuby organization (getkuby/kuby-core).  578 GH
#  stars.  Kuby is a CONVENTION OVER CONFIGURATION approach for
#  running Rails apps in Kubernetes — generates Dockerfiles,
#  Kubernetes manifests, and deployment workflows from a small
#  `kuby.rb` config file.  Handles Docker image build/push, Kubernetes
#  cluster setup, plugin system (CertManager, Sidekiq, etc.),
#  rolling deploys, rollbacks, remote shell/console/logs, and rake
#  task execution against deployed pods.  Sister tools: Heroku CLI
#  (in corpus), Capistrano (Ruby deploy framework), kubectl (in
#  corpus, used by Kuby internally), Hatch (Ruby on Rails to PaaS),
#  Mina (in corpus).
#
#  CLI library taxonomy update: 3rd Ruby CLI library — Dave Copeland's
#  **gli** (Git-Like Interface; davetron5000/gli).  Ruby ecosystem
#  now has 3 documented CLI libraries (R281 OptionParser/Getopt::Long
#  + R358 Thor + R379 gli).
#
#  gli (davetron5000/gli) is Dave Copeland's Git-Like Interface CLI
#  framework for Ruby — designed specifically for building tools with
#  git-style subcommands (`tool command [subcommand] [flags] [args]`).
#  Used by Kuby (Rails-to-K8s), CyberArk Conjur (enterprise secrets
#  management), AWS CodeDeploy Agent, GoodData Ruby SDK, drjekyll
#  themes, Hookapp (macOS Hook.app CLI), Glyph (rapid document
#  authoring), and many Ruby CLI tools that prefer a git-like UX
#  over Thor's task-runner model or argparse-like flag bags.
#
#  gli API:
#    require 'gli'
#
#    class MyApp
#      extend GLI::App
#
#      program_desc 'My awesome tool'
#      version '1.0.0'
#
#      subcommand_option_handling :normal
#      arguments :strict
#
#      desc 'Verbose output'
#      switch [:v, :verbose]
#
#      desc 'Config file path'
#      default_value '~/.myapp.conf'
#      flag [:c, :config]
#
#      desc 'Build the project'
#      command :build do |c|
#        c.desc 'Build target'
#        c.flag [:t, :target], required: true
#
#        c.desc 'Clean before build'
#        c.switch [:clean], default_value: false
#
#        c.action do |global_options, options, args|
#          puts "Building #{options[:target]}"
#        end
#      end
#
#      desc 'Remote operations'
#      command :remote do |rc|
#        rc.command :status do |c|
#          c.action do |g, o, a|
#            puts "Remote status"
#          end
#        end
#        rc.command :deploy do |c|
#          c.action do |g, o, a|
#            puts "Remote deploy"
#          end
#        end
#      end
#
#      pre do |global, command, options, args|
#        true  # truthy = proceed; falsy = abort
#      end
#
#      post do |global, command, options, args|
#        puts "Done with #{command.name}"
#      end
#
#      on_error do |exception|
#        puts "Error: #{exception.message}"
#        true  # continue with GLI's default error handling
#      end
#
#      exit run(ARGV)
#    end
#
#  gli distinctive features:
#    - GIT-LIKE INTERFACE — subcommand-first design where `tool COMMAND
#      [SUBCOMMAND] [--flag value] [args]` is the canonical invocation
#    - `extend GLI::App` MODULE — gli is module-extended into a Ruby
#      class to inject all the DSL methods
#    - `program_desc 'description'` — program description for `--help`
#    - `version 'X.Y.Z'` — version string for `--version`
#    - `desc '...'` + `flag [:short, :long]` — value-taking option
#      defined by PRECEDING `desc` (a stateful pair)
#    - `desc '...'` + `switch [:short, :long]` — boolean flag (no
#      value)
#    - `default_value 'X'` — default for the IMMEDIATELY FOLLOWING
#      flag/switch
#    - `flag [...], required: true | required: false` — required flag
#    - `flag [...], type: String | Integer | Float | Date | Time`
#    - `flag [...], multiple: true` — repeatable flag (returns array)
#    - `flag [...], must_match: /regex/` — regex validation
#    - `command :name do |c| ... end` — subcommand definition block
#      with command-specific flags inside `c.desc`/`c.flag`/`c.switch`
#    - NESTED SUBCOMMANDS via nested `command` blocks: `command :remote
#      do |rc| rc.command :status do |c| ... end end` — recursive
#    - `c.action do |global_options, options, args| ... end` — command
#      body receives THREE blocks of inputs (global flags, command
#      flags, remaining positional args)
#    - `command_missing do |command_name, global_options| ... end` —
#      FALLBACK handler when an unknown command is invoked (Kuby uses
#      this for plugin dispatch!)
#    - `pre do |global, command, options, args| ... end` — PRE-COMMAND
#      hook (return truthy to proceed)
#    - `post do |global, command, options, args| ... end` — POST-COMMAND
#      hook
#    - `on_error do |exception| ... end` — error handler hook
#    - `subcommand_option_handling :normal | :legacy` — controls how
#      subcommand options are parsed relative to global options
#    - `arguments :strict | :loose` — controls whether unknown args
#      are errors or passed through
#    - `exit run(ARGV)` — entry point; returns exit code
#    - AUTO-GENERATED `help` SUBCOMMAND — `tool help` and `tool help
#      COMMAND` produce auto-formatted documentation
#    - AUTO-GENERATED `--help`/`-h` and `--version` flags
#    - AUTO-GENERATED `initconfig` subcommand for creating config files
#    - PROCESS EXIT model — caller gets exit code from `run()` and
#      passes to `exit` (NEVER halts internally; clean exit code
#      propagation)
#  Distinct from R281 Ruby OptionParser/Getopt::Long (stdlib LOW-LEVEL
#  imperative `OptionParser.new { |opts| opts.on('-v', '--verbose')
#  {...} }` — no subcommands), R358 Ruby Thor (rails/Thor — TASK
#  RUNNER style with `class MyTool < Thor; desc 'X', '...'; def x ...
#  end; end` — closest analog but Thor's task model is method-based
#  not block-based; gli is BLOCK-DRIVEN), R275 Rust clap-derive
#  (Rust struct + macros), R322 Java JCommander (Java annotations),
#  R343 commander.js (JS fluent builder), R357 Go mitchellh/cli (Go
#  Cmd interface with `Run`/`Help`/`Synopsis` methods).  gli's
#  approach: GIT-LIKE INTERFACE + `extend GLI::App` MODULE + STATEFUL
#  `desc`-FOLLOWED-BY-`flag`/`switch` PAIRS + `command :name do |c|
#  ... end` BLOCK SYNTAX + NESTED SUBCOMMANDS via NESTED BLOCKS +
#  `c.action` THREE-ARG CALLBACK with global+command+args + `pre`/
#  `post`/`on_error`/`command_missing` HOOKS + AUTO-GENERATED `help`
#  SUBCOMMAND + EXIT CODE RETURNED FROM `run(ARGV)` — corpus's
#  **first documented git-like-interface-with-extend-module-and-
#  desc-followed-by-flag-blocks Ruby CLI library**.  Brings cross-
#  language CLI library taxonomy variant count to 118; Ruby ecosystem
#  now has 3 documented CLI libraries.
#
#  Surface (verbatim from `lib/kuby/commands.rb`):
#
#  Global options:
#    -e, --environment ENV          Kuby environment (overrides
#                                   KUBY_ENV)
#    -c, --config FILE              Path to Kuby config file
#                                   (default: ./kuby.rb)
#    --help, -h                     Show help (auto-generated by gli)
#    --version                      Show version (auto-generated)
#
#  Subcommands:
#    build [-a ARG]... [--ignore-missing-args] [--only ID]... \
#          [-c CONTEXT] [-l|--cache-from-latest]
#                                   Build Docker images
#                                   `-a, --arg ARG` (repeatable build arg)
#                                   `--ignore-missing-args` (switch)
#                                   `--only ID` (repeatable image ID filter)
#                                   `-c, --context DIR` (Docker context)
#                                   `-l, --cache-from-latest` (default true)
#
#    push [--only ID]...             Push Docker images to registries
#
#    setup [--only ID]...            Set up K8s cluster for the app
#
#    dockerfiles [--only ID]...      Print effective Dockerfiles
#
#    deploy [-t TAG]                 Deploy app (default: most recent tag)
#
#    rollback                        Rollback to previous release
#
#    resources [-K KIND] [-N NAME]   Print effective K8s resources
#                                   that will be applied on deploy
#
#    kubeconfig                      Print Kubernetes config (for
#                                   accessing the deployed cluster)
#
#    images                          List all images managed by Kuby
#
#    kubectl ARG...                  Run kubectl against deployed cluster
#                                   (args passed through to kubectl)
#
#    plugin SUBCMD                   Plugin management
#      plugin remove NAME            Remove a plugin
#      plugin list                   List installed plugins
#
#    rake ARG...                     Run rake task in deployed pod
#                                   (args passed through to rake)
#
#    remote SUBCMD                   Remote operations against pods
#      remote logs [-f] [POD]        Tail logs from a pod
#      remote status                 Show pod status
#      remote exec ARG...            Execute command in pod
#      remote shell                  Open shell in pod
#      remote console                Open Rails console in pod
#      remote dbconsole              Open database console in pod
#      remote restart                Restart pods
#
#    help [COMMAND]                  Show help (auto-generated by gli)
#    initconfig                      Generate config file (auto-gli)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base):
#    - tugboat (IN CORPUS — DigitalOcean CLI, uses gli but different
#      product; already documented under different attribution)
#    - pomodoro (IN CORPUS via _pomodoro)
#    - conjur / conjur-cli (CyberArk Conjur 932 stars enterprise
#      secrets — FUTURE candidate with strong impact)
#    - codedeploy-agent (AWS CodeDeploy 335 stars — uses gli but the
#      AWS CodeDeploy CLI itself is in aws-cli package which is IN
#      CORPUS via _aws-cli)
#    - drjekyll (Jekyll themes — niche)
#    - hookapp (ttscoff/hookapp 103 stars — macOS-only Hook.app CLI)
#    - glyph (h3rald/glyph 79 stars — Ruby document authoring, niche)
#    - imapcli (bovender/imapcli — IMAP CLI, smaller community)
#    - cinch (IRC bot framework — library not user-facing CLI)
# ============================================================================

_kuby() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-e --environment)'{-e,--environment}'=[Kuby environment (overrides KUBY_ENV)]:env' \
    '(-c --config)'{-c,--config}'=[Kuby config file path (default ./kuby.rb)]:file:_files -g "*.rb"' \
    '--help[show help]' \
    '-h[show help]' \
    '--version[show version]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'build:build Docker images'
        'push:push Docker images to registries'
        'setup:set up Kubernetes cluster for the app'
        'dockerfiles:print effective Dockerfiles'
        'deploy:deploy the application'
        'rollback:rollback to previous release'
        'resources:print effective Kubernetes resources'
        'kubeconfig:print Kubernetes config'
        'images:list all Kuby-managed images'
        'kubectl:run kubectl against deployed cluster'
        'plugin:plugin management'
        'rake:run rake task in deployed pod'
        'remote:remote operations against pods'
        'help:show help'
        'initconfig:generate config file'
      )
      _describe -t commands 'kuby subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        build)
          _arguments -s -S \
            '*'{-a,--arg}'=[Docker build argument (repeatable)]:arg' \
            '--ignore-missing-args[ignore missing build arguments]' \
            '*--only=[only build images for identifier]:id' \
            '(-c --context)'{-c,--context}'=[Docker build context directory]:dir:_directories' \
            '(-l --cache-from-latest)'{-l,--cache-from-latest}'[pull latest image and reuse layers]'
          ;;
        push)
          _arguments -s -S '*--only=[only push images for identifier]:id'
          ;;
        setup)
          _arguments -s -S '*--only=[run setup for plugin identifier]:id'
          ;;
        dockerfiles)
          _arguments -s -S '*--only=[print Dockerfiles for identifier]:id'
          ;;
        deploy)
          _arguments -s -S '(-t --tag)'{-t,--tag}'=[Docker tag to deploy (default: most recent)]:tag'
          ;;
        resources)
          _arguments -s -S \
            '(-K --kind)'{-K,--kind}'=[only print resources of given kind]:kind' \
            '(-N --name)'{-N,--name}'=[only print resources matching name]:name'
          ;;
        plugin)
          _arguments -C \
            '1: :->plugincmd' \
            '*:: :->pluginargs'
          case $state in
            plugincmd)
              local -a pverbs=(
                'remove:remove a plugin'
                'list:list installed plugins'
              )
              _describe -t commands 'plugin subcommand' pverbs
              ;;
          esac
          ;;
        remote)
          _arguments -C \
            '1: :->remotecmd' \
            '*:: :->remoteargs'
          case $state in
            remotecmd)
              local -a rverbs=(
                'logs:tail logs from a pod'
                'status:show pod status'
                'exec:execute command in pod'
                'shell:open shell in pod'
                'console:open Rails console in pod'
                'dbconsole:open database console in pod'
                'restart:restart pods'
              )
              _describe -t commands 'remote subcommand' rverbs
              ;;
          esac
          ;;
        kubectl|rake)
          _normal
          ;;
      esac
      ;;
  esac
}

_kuby "$@"
