#compdef puya
# _puya — Algorand AVM compiler backend (algorandfoundation/puya)
# upstream: https://github.com/algorandfoundation/puya
# Flags from src/puya/__main__.py (cyclopts).

_puya() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--awst=[AWST JSON file (may be compressed)]:file:_files' \
        '--options=[options JSON file]:file:_files -g "*.json"' \
        '--source-annotations=[source annotations JSON]:file:_files -g "*.json"' \
        '--log-level=[minimum log level]:level:(notset debug info warning error critical)' \
        '--log-format=[log output format]:format:(default json plain)' \
        '1: :->cmd'

    case $state in
        cmd)
            _values 'command' \
                'serve[run in service mode for language servers]'
            ;;
    esac
}

_puya "$@"
