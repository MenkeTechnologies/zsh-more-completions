#compdef loc
# Documentation: https://github.com/cgag/loc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for loc - Lines of Code counter

_arguments \
  '--help[print help information]' \
  '--version[print version information]' \
  '--files[show statistics for individual files]' \
  '--sort=[sort output by column]:column:(language blanks code comments files lines)' \
  '-u[disregard ignore files]' \
  '-uu[include hidden files and directories]' \
  '*--exclude=[exclude files matching regex pattern]:pattern:' \
  '*--include=[include only files matching regex pattern]:pattern:' \
  '*:path:_files'
