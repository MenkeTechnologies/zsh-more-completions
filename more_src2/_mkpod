#compdef mkpod
# _mkpod — turn a Prow job into a stand-alone Pod (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/mkpod/main.go (flag).

_mkpod() {
    _arguments \
        '-prow-job=[ProwJob file (- for stdin)]:file:_files' \
        '-build-id=[build ID for the run (snowflake to generate)]:id:' \
        '-local[configure pod utils for local mode (no GCS upload)]' \
        '-out-dir=[output directory for --local mode]:dir:_files -/'
}

_mkpod "$@"
