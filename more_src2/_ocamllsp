#compdef ocamllsp ocaml-lsp-server
# Documentation: https://github.com/ocaml/ocaml-lsp (ocaml-lsp-server/bin/main.ml)
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[print version and exit]' \
  '(- *)--help[show help message]' \
  '--prefer-dot-merlin[always read Merlin config from existing .merlin files]' \
  '--fallback-read-dot-merlin[deprecated alias for --prefer-dot-merlin]' \
  '--stdio[use standard input/output for LSP communication]' \
  '--socket=[listen on the specified socket port]:port:' \
  '--port=[listen on the specified port]:port:' \
  '--pipe=[use named pipe for LSP communication]:pipe:_files' \
  '--clientProcessId=[client process identifier]:pid:_pids' && ret=0

return ret
