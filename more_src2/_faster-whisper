#compdef faster-whisper faster-whisper-cli whisper-ctranslate2
# _faster-whisper — SYSTRAN faster-whisper reimplementation of Whisper using CTranslate2 4× faster with less memory (SYSTRAN team, Python); argparse
# upstream: https://github.com/SYSTRAN/faster-whisper

_faster-whisper() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--model=+[model size]:m:(tiny tiny.en base base.en small small.en medium medium.en large large-v1 large-v2 large-v3 large-v3-turbo distil-large-v3 distil-medium.en distil-small.en distil-large-v3.5 distil-large-v2 turbo)' \
        '--device=+[device]:d:(cpu cuda auto)' \
        '--compute-type=+[type]:t:(default int8 int8_float32 int8_float16 int8_bfloat16 int16 float16 bfloat16 float32)' \
        '--device-index=+[index]:n:' \
        '--num-workers=+[N]:n:' \
        '--cpu-threads=+[N]:n:' \
        '--download-root=+[model cache dir]:dir:_files -/' \
        '--language=+[lang code]:l:(af am ar as az ba be bg bn bo br bs ca cs cy da de el en es et eu fa fi fo fr gl gu ha haw he hi hr ht hu hy id is it ja jw ka kk km kn ko la lb ln lo lt lv mg mi mk ml mn mr ms mt my ne nl nn no oc pa pl ps pt ro ru sa sd si sk sl sn so sq sr su sv sw ta te tg th tk tl tr tt uk ur uz vi yi yo yue zh)' \
        '--task=+[task]:t:(transcribe translate)' \
        '--beam-size=+[N]:n:' \
        '--best-of=+[N]:n:' \
        '--patience=+[F]:f:' \
        '--length-penalty=+[F]:f:' \
        '--repetition-penalty=+[F]:f:' \
        '--no-repeat-ngram-size=+[N]:n:' \
        '--temperature=+[csv]:str:' \
        '--initial-prompt=+[prompt]:str:' \
        '--prefix=+[prefix]:str:' \
        '--suppress-blank=+[bool]:b:(true false)' \
        '--suppress-tokens=+[ids csv]:str:' \
        '--without-timestamps[no timestamps]' \
        '--word-timestamps[word timestamps]' \
        '--prepend-punctuations=+[chars]:str:' \
        '--append-punctuations=+[chars]:str:' \
        '--vad-filter[VAD filter]' \
        '--vad-method=+[method]:m:(silero pyannote)' \
        '--vad-min-silence-duration-ms=+[ms]:n:' \
        '--vad-speech-pad-ms=+[ms]:n:' \
        '--vad-min-speech-duration-ms=+[ms]:n:' \
        '--vad-threshold=+[F]:f:' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--output-format=+[format]:f:(txt srt vtt tsv json all)' \
        '--max-line-width=+[chars]:n:' \
        '--max-line-count=+[N]:n:' \
        '--highlight-words[highlight words]' \
        '--verbose=+[bool]:b:(true false)' \
        '*:audio file:_files -g "*.wav *.mp3 *.flac *.ogg *.opus *.aac *.m4a *.mp4 *.mov *.webm *.mkv *.avi"'
}

_faster-whisper "$@"
