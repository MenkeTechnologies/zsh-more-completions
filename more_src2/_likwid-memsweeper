#compdef likwid-memsweeper
# _likwid-memsweeper — flush NUMA memory domains (RRZE-HPC/likwid)
# upstream: https://github.com/RRZE-HPC/likwid
# Flags from src/applications/likwid-memsweeper.lua (likwid.getopt).

_likwid-memsweeper() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '-c+[NUMA node list (e.g. 0, 1-2, 0\,1-2)]:nodes:'
    )
    _arguments -s $args
}

_likwid-memsweeper "$@"
