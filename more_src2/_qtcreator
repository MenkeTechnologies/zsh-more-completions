#compdef qtcreator
# _qtcreator — Qt Creator cross-platform Qt IDE (C++/QML); ships with Qt distribution
# upstream: https://github.com/qt-creator/qt-creator

_qtcreator() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-block[block until app exits]' \
        '-client[connect to existing instance]' \
        '-color+[color]:color:' \
        '-customwizard-verbose[verbose custom wizard]' \
        '-disable-extensions+[disable plugins]:list:' \
        '-disable-tools[disable external tools]' \
        '-installsettingspath+[install settings dir]:dir:_files -/' \
        '-language+[language]:lang:' \
        '-load+[load plugin]:plugin:' \
        '-noload+[skip plugin]:plugin:' \
        '-notour[skip welcome tour]' \
        '-pid+[connect to PID]:pid:_pids' \
        '-pluginpath+[plugin path]:dir:_files -/' \
        '-presentationMode[presentation mode]' \
        '-profile[CPU profile]' \
        '-settingspath+[settings dir]:dir:_files -/' \
        '-temporarycleansettings[fresh settings]' \
        '-test+[test plugin]:plugin:' \
        '-theme+[theme]:theme:' \
        '-userdir+[user data dir]:dir:_files -/' \
        '*:project or file:_files'
}

_qtcreator "$@"
