#compdef goneovim
# Documentation: https://github.com/akiyosi/goneovim/wiki/Usage
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--maximized[maximize window on startup]' \
  '--fullscreen[start in fullscreen mode]' \
  '--geometry=[initial window geometry (e.g. 800x600)]:WxH:' \
  '--server=[connect to remote nvim session]:host\:port:' \
  '--nvim=[path to nvim executable]:nvim path:_files' \
  '--ssh=[attach to remote nvim via SSH]:user@host\:port:' \
  '--wsl=[attach to nvim in WSL distribution]:distro:' \
  '--debug=[run debug mode with log file]:log file:_files' \
  '--exttabline[externalize the tabline]' \
  '--extcmdline[externalize the command line]' \
  '--extmessages[externalize messages]' \
  '--extpopupmenu[externalize the popup menu]' \
  '--nofork[run in foreground]' \
  '*:file:_files' && ret=0

return ret
