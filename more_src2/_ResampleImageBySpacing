#compdef ResampleImageBySpacing
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ResampleImageBySpacing.cxx — resample image by target spacing (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:inputImageFile:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outputImageFile:_files' \
    '4:outxspc:_default' \
    '5:outyspc:_default' \
    '6::outzspacing:_default' \
    '7::dosmooth (default 1):(0 1)' \
    '8::addvox (default 0):_default' \
    '9::nn-interp (default 0):(0 1)' \
    && ret=0

return ret
