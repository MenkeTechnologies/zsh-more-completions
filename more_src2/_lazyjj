#compdef lazyjj
# Documentation: https://github.com/Cretezy/lazyjj/blob/main/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (clap Args struct).

# Flag set from the Args struct in src/main.rs.
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --path)'{-p,--path}'=[path to jj repo (defaults to cwd)]:repo path:_files -/' \
  '(-r --revisions)'{-r,--revisions}'=[default revset]:revset:' \
  '--jj-bin=[path to jj binary (env JJ_BIN)]:file:_files' \
  '--ignore-jj-version[do not exit if jj version check fails]'
