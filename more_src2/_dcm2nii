#compdef dcm2nii
# dcm2nii — convert DICOM images to NIfTI format

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-d[include date in filename]:include date:(y n)' \
  '-e[create events file]:create events:(y n)' \
  '-f[use source filename]:source filename:(y n)' \
  '-g[gzip output (.nii.gz)]:gzip:(y n)' \
  '-i[include ID in filename]:include ID:(y n)' \
  '-n[output .nii instead of .hdr/.img]:nii format:(y n)' \
  '-o[output directory]:output directory:_directories' \
  '-p[include protocol in filename]:include protocol:(y n)' \
  '-r[reorient image to nearest orthogonal]:reorient:(y n)' \
  '-v[verbose output]:verbose:(y n 0 1 2)' \
  '-x[reorient and crop]:reorient and crop:(y n)' \
  '*:input files or directory:_files'
