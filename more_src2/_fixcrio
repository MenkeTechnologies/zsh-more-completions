#compdef fixcrio
# _fixcrio — DJB ucspi-tcp fixcrio (translate newline conventions: add CR on output, strip CR on input; commonly wrapped around line-oriented programs run under tcpserver to handle internet CRLF lines)
# upstream: https://github.com/schmonz/ucspi-tcp
# Source: fixcrio.c on tip; positional only.

_fixcrio() {
    _arguments \
        '1:program:_command_names -e' \
        '*::args:'
}

_fixcrio "$@"
