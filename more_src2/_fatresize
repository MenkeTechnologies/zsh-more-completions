#compdef fatresize
# Documentation: https://github.com/ya-mouse/fatresize
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --size)'{-s,--size}'+[new size]:size:' \
  '(-i --info)'{-i,--info}'[show info]' \
  '(-p --progress)'{-p,--progress}'[show progress]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-f --force)'{-f,--force}'[force]' \
  '*:device:_files' && ret=0

return ret
