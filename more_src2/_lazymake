#compdef lazymake
# Documentation: https://github.com/rshelekhov/lazymake
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lazymake — Makefile TUI

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-f+[path to Makefile]:file:_files' \
  '--dry-run[preview commands without executing]' && ret=0

return ret
