#compdef kro
# _kro — kro.run CLI (Kube Resource Orchestrator — manage ResourceGraphDefinitions + their ResourceGraphInstances)
# upstream: https://github.com/kro-run/kro
# Subcommands + persistent flags from cmd/kro/main.go + cmd/kro/commands/root.go on tip (cobra).

_kro() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[path to kubeconfig file]:file:_files' \
        '--context=[Kubernetes context to use]:ctx:' \
        '--verbose[enable verbose logging]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                generate:'generate kro resources (RGD, examples, etc.)'
                validate:'validate kro resources'
            )
            _describe -t commands 'kro subcommand' subs
            ;;
    esac
}

_kro "$@"
