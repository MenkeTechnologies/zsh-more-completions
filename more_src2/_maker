#compdef maker maker_p mpi_maker iprscan2gff3 fasta_merge gff3_merge maker2zff maker2eval evaluator
# _maker — Carson Holt Mark Yandell MAKER eukaryotic genome annotation pipeline integrating evidence repeats and gene predictions (Yandell-Lab team, Perl); custom argparse
# upstream: https://github.com/Yandell-Lab/maker

_maker() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-genome=+[genome fasta]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
        '-RM_off[disable RepeatMasker]' \
        '-c+[continue]:n:' \
        '-cpus=+[N CPUs]:n:' \
        '-f[force overwrite]' \
        '-CTL[generate control files]' \
        '-OPTS[generate options]' \
        '-EXE[generate executable paths]' \
        '-BOPTS[generate base options]' \
        '-MWAS+[base options file]:file:_files' \
        '-fix_nucleotides[fix nucleotides]' \
        '-base+[run name]:str:' \
        '-tries=+[N]:n:' \
        '-quiet[quiet]' \
        '-debug[debug]' \
        '-only_runs[only runs]' \
        '-cleanup[cleanup]' \
        '-again[run again]' \
        '-nodatastore[no datastore]' \
        '-r+[range]:str:' \
        '-RM+[repeat masker output]:file:_files' \
        '-q[quiet]' \
        '-evaluator+[evaluator options]:file:_files' \
        '-existing[use existing]' \
        '-bopts=+[bopts file]:file:_files' \
        '-opts=+[opts file]:file:_files' \
        '-exe=+[exe file]:file:_files' \
        '*:control files:_files -g "*.ctl maker*.ctl"'
}

_maker "$@"
