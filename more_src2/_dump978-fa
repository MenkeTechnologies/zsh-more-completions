#compdef dump978-fa faup978 skyaware978
# Documentation: source-direct extraction from upstream
# flightaware/dump978 dump978_main.cc + faup978_main.cc +
# skyaware978_main.cc `po::options_description desc("Allowed
# options"); desc.add_options()(...)` blocks. The 3 binaries all
# use Boost.Program_options (NOT getopt or argparse) and ship from
# the same monorepo. Binary names confirmed via Makefile targets
# `all: dump978-fa skyaware978` + `faup978: faup978_main.o ...`.
# Reference accessed: 2026-05-30 via gh api.
# FlightAware dump978 R141b — 978 MHz UAT (Universal Access
# Transceiver) ADS-B decoder family from FlightAware. Sister to
# the 1090 MHz `dump1090` decoder (already covered in the corpus).
# All 3 binaries support Boost.Program_options' standard --help
# and --version that are not enumerated per-binary below.

case $service in

  dump978-fa)
    # Demodulate UAT samples from an SDR/file/stdin and write
    # decoded messages to stdout or to network listeners.
    _arguments -s -S \
      '--help[show help]' \
      '--json-stdout[write decoded JSON to stdout]' \
      '--format=[sample input format]:format:(UC8 SC16 SC16Q11)' \
      '--stdin[read sample data from stdin]' \
      '--file=[read sample data from a file]:file:_files' \
      '--file-throttle[throttle file input to realtime]' \
      '--sdr=[read sample data from named SDR device (SoapySDR args)]:device args:' \
      '--sdr-auto-gain[enable SDR AGC]' \
      '--sdr-gain=[SDR gain in dB]:dB:' \
      '--sdr-ppm=[SDR frequency correction in PPM]:ppm:' \
      '--sdr-antenna=[SDR antenna name]:antenna:' \
      '--sdr-stream-settings=[SDR stream key=value settings (comma-separated)]:settings:' \
      '--sdr-device-settings=[SDR device key=value settings (comma-separated)]:settings:' \
      '--stratuxv3=[read messages from Stratux v3 UAT dongle on serial port]:serial port:_files -g "/dev/tty*"' \
      '*--raw-port=[listen on [host:]port and provide raw messages (repeatable)]:[host:]port:' \
      '*--raw-legacy-port=[listen on [host:]port and provide raw messages without metadata header (repeatable)]:[host:]port:' \
      '*--json-port=[listen on [host:]port and provide decoded JSON (repeatable)]:[host:]port:'
    ;;

  faup978)
    # Minimal protocol-bridge: connect to a dump978 raw-message
    # source and rebroadcast for SkyAware/PiAware-style consumers.
    _arguments -s -S \
      '--help[show help]' \
      '--version[show version]' \
      '--connect=[connect to host:port for raw UAT data]:[host:]port:'
    ;;

  skyaware978)
    # SkyAware-style aggregator: connect to raw UAT source and
    # write rolling JSON history files for visualization.
    _arguments -s -S \
      '--help[show help]' \
      '--version[show version]' \
      '--connect=[connect to host:port for raw UAT data]:[host:]port:' \
      '--reconnect-interval=[reconnect interval in seconds on failure (default 0=disabled)]:sec:' \
      '--json-dir=[directory to write rolling JSON files into]:dir:_directories' \
      '--history-count=[number of history files to maintain (default 120)]:n:' \
      '--history-interval=[interval between history files in seconds (default 30)]:sec:' \
      '--lat=[receiver latitude (decimal degrees)]:lat:' \
      '--lon=[receiver longitude (decimal degrees)]:lon:'
    ;;

esac
