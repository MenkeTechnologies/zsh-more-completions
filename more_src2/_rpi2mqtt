# ============================================================================

_rpi2mqtt() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-c --config)'{-c,--config}'[config file path]:file:_files' \
        '(-l --log)'{-l,--log}'[log file path]:file:_files' \
        '(-v --verbosity)'{-v,--verbosity}'[log level]:level:(error info debug)' \
        '-d[do not fork into background; log to stdout]' \
        '*'{-a,--alias}'[alias topic mapping (source:alias)]:mapping:' \
        '*'{-i,--in,--input}'[GPIO pin to use as input]:gpio:' \
        '*'{-o,--out,--output}'[GPIO pin to use as output]:gpio:' \
        '(-p --payload)'{-p,--payload}'[MQTT payload format]:type:(plain json)' \
        '(-r --retain)'{-r,--retain}'[publish with retain flag]' \
        '(-t --status-topic)'{-t,--status-topic}'[topic prefix for status messages]:prefix:' \
        '(-z --set-topic)'{-z,--set-topic}'[topic prefix for set messages]:prefix:' \
        '(-x --testament-topic)'{-x,--testament-topic}'[topic for connect + last-will]:topic:' \
        '(-u --url)'{-u,--url}'[MQTT broker URL]:url:' \
        '(-s --w1-wait)'{-s,--w1-wait}'[seconds to wait before reading 1-wire devices]:seconds:' \
        '(-n --w1-interval)'{-n,--w1-interval}'[1-wire polling interval (seconds)]:seconds:' \
        '(-w --w1-disable)'{-w,--w1-disable}'[disable 1-wire sensor polling]' \
        '(- *)'{-h,--help}'[print help]'
}

_rpi2mqtt "$@"
