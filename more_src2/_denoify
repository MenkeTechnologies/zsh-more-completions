_denoify() {
    case "${service:-${words[1]}}" in
        enable_short_npm_import_path)
            _arguments -s \
                '1:target module path:_files -/' ;;
        remove_deno_dist_from_gitignore)
            _arguments -s \
                '1:module directory:_files -/' ;;
        denoify|*)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '(-p --project)'{-p,--project}'=[root path of the project to denoify (default ./)]:path:_files -/' \
                '--src=[path to the source .ts files directory]:path:_files -/' \
                '(-o --out)'{-o,--out}'=[path to the output directory (default $(dirname <tsconfig.outDir>)/deno_lib)]:path:_files -/' \
                '(-i --index)'{-i,--index}'=[path to the index.ts file (default read from package.json)]:path:_files -g "*.ts"' ;;
    esac
}

_denoify "$@"
