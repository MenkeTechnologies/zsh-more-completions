#compdef eksdemo
# _eksdemo — easy button for learning/testing/demoing Amazon EKS (awslabs/eksdemo)
# upstream: https://github.com/awslabs/eksdemo
# Subcommands from cmd/root.go (cobra).

_eksdemo() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--profile=[AWS credentials profile]:profile:' \
        '--region=[AWS region override]:region:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'create:create a cluster or AWS resource'
                'delete:delete a cluster or AWS resource'
                'get:get/list AWS resources (kubectl-like)'
                'install:install an application onto the cluster'
                'uninstall:uninstall a previously installed app'
                'update:update eksdemo'
                'completion:generate shell completion script'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_eksdemo "$@"
