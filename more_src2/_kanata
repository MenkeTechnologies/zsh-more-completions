#compdef kanata
# Documentation: https://github.com/jtroo/kanata/blob/main/src/main_lib/args.rs
# Reference accessed: 2026-05-19
# Verified: upstream src/main_lib/args.rs clap struct at the URL above.

# kanata keyboard remapper. Corrected from prior file: -w is
# --wait-device-ms (takes ms, not --wait-on-startup-error); added the
# real --cfg-stdin, -s/--symlink-path, -q/--quiet, --no-wait,
# --emergency-exit-code, --release-grab-on-lock,
# --macos-request-permissions; --port takes a value.

_arguments -s -S \
  '(-c --cfg)'{-c,--cfg}'[configuration file(s)]:config file:_files -g "*.kbd"' \
  '--cfg-stdin[read configuration from stdin]' \
  '(-p --port)'{-p,--port}'[TCP server port or IP:PORT]:port:' \
  '(-s --symlink-path)'{-s,--symlink-path}'[symlink path for the created device]:path:_files' \
  '(-l --list)'{-l,--list}'[list grabbable keyboards and exit]' \
  '(-q --quiet)'{-q,--quiet}'[disable logging except errors]' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '(-t --trace)'{-t,--trace}'[enable trace logging (implies --debug)]' \
  '(-n --nodelay)'{-n,--nodelay}'[remove the startup delay]' \
  '(-w --wait-device-ms)'{-w,--wait-device-ms}'[ms to wait before registering a new device]:ms:' \
  '--check[validate configuration file and exit]' \
  '--log-layer-changes[log layer changes even if disabled in config]' \
  '--no-wait[skip the press-enter-to-exit prompt]' \
  '--emergency-exit-code=[exit code for emergency exit]:code:' \
  '--release-grab-on-lock[release keyboard grab while screen is locked]' \
  '--macos-request-permissions[request macOS Accessibility permission and exit]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' && return 0
