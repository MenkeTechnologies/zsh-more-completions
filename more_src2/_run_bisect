#compdef run_bisect run_bisect_qemu
# Documentation: https://manpages.debian.org/run_bisect
# Source: debian/devscripts scripts/run_bisect.sh — debbisect helper to bisect Debian package issues (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:depends:_default' \
    '2:script or shell snippet:_files' \
    '3:mirror URL:_urls' \
    '4:architecture:_default' \
    '5:suite:_default' \
    '6:components:_default' \
    '7::second mirror URL:_urls' \
    '8::package to upgrade:_default' \
    && ret=0

return ret
