#compdef kubectl-lineage
# Documentation: https://github.com/tohjustin/kube-lineage
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; flags cross-checked against
# tohjustin/kube-lineage pkg/cmd/lineage/flags.go.

# kube-lineage takes TYPE[/NAME] [NAME] directly (no tree/list/graph
# subcommands); 'helm' is the only subcommand.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[list relationships across all namespaces]' \
  '(-D --dependencies)'{-D,--dependencies}'[list dependencies instead of dependents]' \
  '(-d --depth)'{-d+,--depth=}'[maximum depth to find relationships]:n:' \
  '--exclude-types=[resource types to exclude]:types:' \
  '--include-types=[resource types to only include]:types:' \
  '(-S --scopes)'{-S+,--scopes=}'[additional namespaces to find relationships]:namespaces:' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:namespace:' \
  '--context=[kube context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(wide split split-wide)' \
  '1:type or helm:' \
  '*:name or args: _default'
