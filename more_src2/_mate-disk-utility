#compdef mate-disk-utility
# Documentation: https://github.com/assen-totin/mate-disk-utility
# Reference accessed: 2026-05-19
# Verified: third-party fork repository; mate-disk-utility is not an upstream MATE
# binary and has no published man page or canonical CLI reference.
# STUB: minimal completion (standard help/GTK options only).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including GTK]' \
  '(- *)--help-gtk[show GTK options]' \
  '--display=[X display]:display:' \
  '*::args:_files' && ret=0
return ret
