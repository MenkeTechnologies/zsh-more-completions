#compdef explain-my-error eme
# Documentation: https://www.npmjs.com/package/explain-my-error
# Reference accessed: 2026-05-22
# Verified: npm package command reference and CLI help.

# Zsh completion for explain-my-error - AI programming error explainer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--json[structured JSON output]' \
  '--stack[stack trace context]:trace:' \
  '--stack-file[stack trace from file]:file:_files' \
  '--code[code snippet context]:code:' \
  '--code-file[code snippet from file]:file:_files' \
  '--runtime[runtime context]:runtime:' \
  '--framework[framework context]:framework:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'explain-my-error command' \
      'explain[explain a programming error]' && ret=0
    ;;
  args)
    case $line[1] in
      explain)
        _arguments '*:error message:' && ret=0
        ;;
      *)
        _arguments '*:error message:' && ret=0
        ;;
    esac
    ;;
esac

return ret
