#compdef jack_netsource
# Documentation: https://jackaudio.org/
# Source: jackaudio/jack2 man/jack_netsource.0 — NetJack1 audio-network source client.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-H[slave host name]:host:_hosts' \
    '-o[number of audio playback channels]:n:' \
    '-i[number of audio capture channels]:n:' \
    '-O[number of midi playback channels]:n:' \
    '-I[number of midi capture channels]:n:' \
    '-n[network latency in JACK periods]:periods:' \
    '-p[UDP port the slave is listening on]:port:' \
    '-r[UDP port we are listening on]:port:' \
    '-B[reply port (for NAT environments)]:port:' \
    '-b[transport bit-depth]:bitdepth:(8 16)' \
    '-c[CELT encoding bytes per period and channel]:bytes:' \
    '-m[assume MTU for the link]:mtu:' \
    '-R[redundancy: send packets N times]:n:' \
    '-e[skip host-to-network endianness conversion]' \
    '-N[reports a different client name to jack]:name:' \
    '(-s --server)'{-s+,--server=}'[JACK server name to connect to]:server:' \
    '(- *)'{-h,--help}'[display help]' \
    '(- *)'{-v,--version}'[output version and exit]' \
    && ret=0

return ret
