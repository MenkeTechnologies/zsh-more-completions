#compdef kubetrigger
# _kubetrigger — KubeVela KubeTrigger (event-driven workflow triggers)
# upstream: https://github.com/kubevela/kube-trigger
# Subcommands + flags from pkg/cmd/cmd.go + options.go on tip.

_kubetrigger() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c,--config=}'[config file or directory (yaml/json/cue)]:path:_files' \
        '--log-level=[log level]:level:(debug info warn error)' \
        '--multi-cluster-config-type=[multi-cluster config type]:type:(cluster-gateway cluster-gateway-kubeconfig)' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'version:print kubetrigger version'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_kubetrigger "$@"
