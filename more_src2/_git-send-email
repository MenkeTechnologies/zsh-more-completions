#compdef git-send-email
# Documentation: https://git-scm.com/docs/git-send-email
# Source: git/git git-send-email.perl — send a collection of patches as email (Perl, Getopt::Long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--from=-[email From: header]:str:_default' \
    '*--to=-[email To: header]:str:_default' \
    '*--no-to[clear To:]' \
    '*--cc=-[email Cc: header]:str:_default' \
    '*--no-cc[clear Cc:]' \
    '*--bcc=-[email Bcc: header]:str:_default' \
    '*--no-bcc[clear Bcc:]' \
    '--subject=-[email Subject: header]:str:_default' \
    '--reply-to=-[email Reply-To: header]:str:_default' \
    '--in-reply-to=-[email In-Reply-To: header]:str:_default' \
    '(--no-outlook-id-fix)--outlook-id-fix[server munges Message-ID]' \
    '(--outlook-id-fix)--no-outlook-id-fix[disable Outlook ID fix]' \
    '(--no-xmailer)--xmailer[add X-Mailer header]' \
    '(--xmailer)--no-xmailer[suppress X-Mailer header]' \
    '(--no-annotate)--annotate[edit each patch before sending]' \
    '(--annotate)--no-annotate[do not annotate]' \
    '--compose[open editor for introduction]' \
    '--compose-encoding=-[introduction encoding]:str:_default' \
    '--8bit-encoding=-[8bit-content encoding]:str:_default' \
    '--transfer-encoding=-[transfer encoding]:enc:(quoted-printable 8bit base64)' \
    '(--no-mailmap)--mailmap[map emails via mailmap]' \
    '(--mailmap)--no-mailmap[do not use mailmap]' \
    '--envelope-sender=-[envelope sender]:str:_default' \
    '--sendmail-cmd=-[command to send email]:cmd:_command_names' \
    '--smtp-server=-[SMTP server]:host[:port]:_default' \
    '*--smtp-server-option=-[SMTP server option]:str:_default' \
    '--smtp-server-port=-[SMTP server port]:port:_default' \
    '--smtp-user=-[SMTP user]:str:_default' \
    '--smtp-pass=-[SMTP password]:str:_default' \
    '--smtp-encryption=-[SMTP encryption]:enc:(tls ssl none)' \
    '--smtp-ssl[deprecated alias for --smtp-encryption=ssl]' \
    '--smtp-ssl-cert-path=-[CA cert path]:path:_files' \
    '--smtp-ssl-client-cert=-[client cert]:path:_files' \
    '--smtp-ssl-client-key=-[client key]:path:_files' \
    '--smtp-domain=-[HELO/EHLO domain]:str:_default' \
    '--smtp-auth=-[allowed AUTH mechanisms]:str:_default' \
    '--no-smtp-auth[disable SMTP authentication]' \
    '--smtp-debug=-[enable Net::SMTP debug]:n:(0 1)' \
    '--imap-sent-folder=-[IMAP folder for sent copy]:str:_default' \
    '--batch-size=-[max messages per connection]:int:_default' \
    '--relogin-delay=-[seconds between logins]:int:_default' \
    '--identity=-[sendemail.<id> identity]:str:_default' \
    '--to-cmd=-[email To: via cmd]:cmd:_default' \
    '--cc-cmd=-[email Cc: via cmd]:cmd:_default' \
    '--header-cmd=-[add headers via cmd]:cmd:_default' \
    '--no-header-cmd[disable header command]' \
    '--suppress-cc=-[suppress Cc category]:cat:(author self sob cc cccmd body bodycc misc-by all)' \
    '--confirm=-[confirm recipients]:mode:(always never auto cc compose)' \
    '--quiet[output one line per email]' \
    '--dry-run[do not actually send]' \
    '--force[bypass safety checks]' \
    '--dump-aliases[dump aliases and exit]' \
    '--translate-aliases[translate aliases from stdin]' \
    '*:patch files or directories:_files' \
    && ret=0

return ret
