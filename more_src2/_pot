#compdef pot
# Documentation: https://pot.pizzamig.dev/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'help:show help'
      'version:show the pot version'
      'config:show pot framework configuration'
      'ls:list installed pots'
      'list:list installed pots'
      'show:show pot information'
      'info:print minimal information on a pot'
      'top:run unix top in the pot'
      'ps:show running pots'
      'init:initialize the ZFS layout'
      'de-init:deinstall pot from system'
      'vnet-start:start the vnet configuration'
      'create-base:create a new base image'
      'create-fscomp:create a new fs component'
      'create-private-bridge:create a new private bridge'
      'create:create a new pot'
      'clone:clone a pot creating a new one'
      'clone-fscomp:clone a fscomp'
      'rename:rename a pot'
      'destroy:destroy a pot'
      'prune:destroy not running prunable pots'
      'copy-in:copy a file or directory into a pot'
      'mount-in:mount a directory, dataset or fscomp into a pot'
      'add-dep:add a dependency'
      'set-rss:set a resource constraint'
      'get-rss:get current resource usage'
      'set-cmd:set the command to start the pot'
      'set-env:set environment variables inside a pot'
      'set-hosts:set etc/hosts entries inside a pot'
      'set-hook:set hook scripts for a pot'
      'set-attr:set a pot attribute'
      'get-attr:get a pot attribute'
      'export-ports:export tcp ports'
      'start:start a jail'
      'stop:stop a jail'
      'term:start a terminal in a pot'
      'run:start and open a terminal in a pot'
      'snap:take a snapshot of a pot'
      'snapshot:take a snapshot of a pot'
      'rollback:restore the last snapshot'
      'revert:restore the last snapshot'
      'purge-snapshots:remove old or all snapshots'
      'export:export a pot to a file'
      'import:import a pot from a file or URL'
      'prepare:import and prepare a pot'
      'update-config:update the configuration of a pot'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (start|stop|term|destroy|snap|snapshot|rollback|revert|info|show|top|export|clone|rename|set-attr|get-attr|set-cmd|set-env|set-hosts|set-hook|add-dep|set-rss|get-rss|copy-in|mount-in|purge-snapshots|run|prepare|update-config)
        _arguments '-p+[pot name]:pot name:' '-h[show help]' '-v[verbose]' '*:args:' && ret=0
        ;;
      (create)
        _arguments \
          '-h[show help]' \
          '-v[verbose]' \
          '-k[keep the pot if create fails]' \
          '-p+[pot name]:name:' \
          '-l+[pot level for multi type]:level:' \
          '-b+[base pot]:base:' \
          '-P+[reference pot]:pot:' \
          '-d+[DNS handling]:dns:(inherit pot off custom)' \
          '-f+[flavour to use]:flavour:' \
          '-t+[pot type]:type:(single multi)' \
          '-N+[network type]:type:(inherit alias public-bridge private-bridge)' \
          '-i+[IP address or auto]:ip:' \
          '-B+[bridge name for private-bridge]:bridge:' \
          '-S+[network stack]:stack:(ipv4 ipv6 dual)' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
