#compdef labelsgmfix
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/labelsgmfix.html
# Source: MRtrix3/mrtrix3 bin/labelsgmfix — replace FreeSurfer SGM with FSL FIRST (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-premasked[T1 input has already been brain-masked]' \
    '-sgm_amyg_hipp[also replace amygdalae+hippocampi]' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:parc (FreeSurfer parcellation):_files -g "*.{nii,nii.gz,mif,mgz}"' \
    '2:t1 (T1 image):_files -g "*.{nii,nii.gz,mif,mgz}"' \
    '3:lut (lookup table):_files -g "*.txt"' \
    '4:output (parcellation):_files' \
    && ret=0

return ret
