#compdef fod2fixel
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fod2fixel.html
# Source: MRtrix3/mrtrix3 cmd/fod2fixel.cpp — perform FOD segmentation into fixels (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[binary brain mask]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-maxnum+[max fixels per voxel]:n:_default' \
    '-nii[output index/direction files as .nii instead of .mif]' \
    '-dirpeak[use peak direction (not weighted mean) for fixels]' \
    '-afd+[output fixel-data file with AFD]:image:_files' \
    '-peak_amp+[output fixel-data file with peak amplitude]:image:_files' \
    '-disp+[output fixel-data file with dispersion]:image:_files' \
    '-fmls_integral+[FMLS amplitude threshold]:value:_default' \
    '-fmls_peak_value+[FMLS peak value threshold]:value:_default' \
    '-fmls_no_thresholds[disable all FMLS thresholds]' \
    '-fmls_lobe_merge_ratio+[merge adjacent lobes if ratio above this]:value:_default' \
    '1:fod (input FOD image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:fixel_directory (output):_files -/' \
    && ret=0

return ret
