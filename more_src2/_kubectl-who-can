#compdef kubectl-who-can
# Documentation: https://github.com/aquasecurity/kubectl-who-can
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Shows which subjects have RBAC permissions to VERB
# [TYPE | TYPE/NAME | NONRESOURCEURL] in Kubernetes.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[check for users that can do the action in any namespace]' \
  '(-n --namespace)'{-n+,--namespace=}'[if present, the namespace scope for this CLI request]:namespace:' \
  '(-o --output)'{-o+,--output=}'[output format (wide or JSON)]:format:(wide json)' \
  '--subresource=[SubResource such as pod/log or deployment/scale]:subresource:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster:' \
  '--user=[the name of the kubeconfig user to use]:user:' \
  '(-s --server)'{-s+,--server=}'[address and port of the Kubernetes API server]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '--certificate-authority=[path to a cert file for the certificate authority]:file:_files' \
  '--client-certificate=[path to a client certificate file]:file:_files' \
  '--client-key=[path to a client key file]:file:_files' \
  '--insecure-skip-tls-verify[skip server certificate validation]' \
  '--request-timeout=[length of time before giving up on a single server request]:timeout:' \
  '--as=[username to impersonate]:user:' \
  '--as-group=[group to impersonate]:group:' \
  '-v+[number for the log level verbosity]:level:' \
  '1:verb:(get list watch create update patch delete deletecollection)' \
  '2:resource:' && ret=0

return ret
