#compdef minicom
# Documentation: minicom -h (minicom 2.10 on macOS Homebrew)
# Reference accessed: 2026-05-19
# Verified: local "minicom -h" output. Prior file invented -T (terminal
# capabilities), -8, -R (no long form), -7, -a (incorrect description),
# -t with limited terminal list; missed -m/--metakey, -M/--metakey8,
# -H/--displayhex, -F/--statlinefmt, --capturefile-buffer-mode.

# Zsh completion for minicom - serial communication program

_arguments -s -S \
  '(-b --baudrate)'{-b,--baudrate=}'[set baudrate (ignore the value from config)]:baud rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
  '(-D --device)'{-D,--device=}'[set device name]:device:_files -W /dev -g "tty*"' \
  '(-s --setup)'{-s,--setup}'[enter setup mode]' \
  '(-o --noinit)'{-o,--noinit}'[do not initialize modem & lockfiles at startup]' \
  '(-m --metakey)'{-m,--metakey}'[use meta or alt key for commands]' \
  '(-M --metakey8)'{-M,--metakey8}'[use 8bit meta key for commands]' \
  '(-l --ansi)'{-l,--ansi}'[literal; assume screen uses non IBM-PC character set]' \
  '(-L --iso)'{-L,--iso}'[do not assume screen uses ISO8859]' \
  '(-w --wrap)'{-w,--wrap}'[linewrap on]' \
  '(-H --displayhex)'{-H,--displayhex}'[display output in hex]' \
  '(-z --statline)'{-z,--statline}'[try to use terminal status line]' \
  '(-7 --7bit)'{-7,--7bit}'[force 7bit mode]' \
  '(-8 --8bit)'{-8,--8bit}'[force 8bit mode]' \
  '(-c --color)'{-c,--color=}'[ANSI color usage on or off]:color:(on off)' \
  '(-a --attrib)'{-a,--attrib=}'[reverse or highlight attributes on or off]:attribute usage:(on off)' \
  '(-t --term)'{-t,--term=}'[override TERM environment variable]:terminal type:' \
  '(-S --script)'{-S,--script=}'[run SCRIPT at startup]:script file:_files' \
  '(-d --dial)'{-d,--dial=}'[dial ENTRY from the dialing directory]:entry:' \
  '(-p --ptty)'{-p,--ptty=}'[connect to pseudo terminal]:pseudo terminal:_files -W /dev -g "pts/*"' \
  '(-C --capturefile)'{-C,--capturefile=}'[start capturing to FILE]:capture file:_files' \
  '--capturefile-buffer-mode=[set buffering mode of capture file]:mode:' \
  '(-F --statlinefmt)'{-F,--statlinefmt=}'[format of status line]:format:' \
  '(-R --remotecharset)'{-R,--remotecharset=}'[character set of communication partner]:charset:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[output version information and exit]' \
  '::configuration:_files'
