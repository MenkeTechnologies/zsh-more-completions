#compdef mgd77sniffer
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77sniffer.html
# Source: GenericMappingTools/gmt supplements/mgd77 — sanity-check MGD77 cruise data for quality issues.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[scale + offset for a data field]:opts:_default' \
    '-C+[max ship speed (m/s, default 10)]:mps:_default' \
    '-D+[suppress warnings / select formats]:opts:_default' \
    '-E[reverse navigation quality flags]' \
    '-G+[compare cruise against GMT/IMG grid]:opts:_default' \
    '-H+[decimation during regression]:opts:_default' \
    '-I+[flag record ranges as bad]:opts:_default' \
    '-L+[error-detection limits file]:file:_files' \
    '-M+[inland nav threshold (meters)]:m:_default' \
    '-N[use nautical units]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[gradient type (change/spatial/time)]:type:_default' \
    '-T+[gap handling for continuity checks]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[warning output filter]:opts:_default' \
    '-Z+[regression-stats confidence flag]:pct:_default' \
    '*:GEODAS-ID:_default' \
    && ret=0

return ret
