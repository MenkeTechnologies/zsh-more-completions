#compdef decap netlify-cms
# _decap — Netlify Decap CMS git-based headless CMS CLI alias (decaporg, JavaScript); cac
# upstream: https://github.com/decaporg/decap-cms

_decap() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "config.{yml,yaml,json}"' \
        '-c+[config file]:file:_files -g "config.{yml,yaml,json}"' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--watch[watch mode]' \
        '--build[build production]' \
        '*:arg:'
}

_decap "$@"
