#compdef liquidwar6
# Documentation: https://git.savannah.gnu.org/cgit/liquidwar6.git/tree/liquidwar6/src/lib/lw6-options.c
# Reference accessed: 2026-05-16
# Verified: src/lib/lw6-options.c top-level dispatch + grep of LW6DEF_* macros
# Note: lw6 is config-driven; any of 514 config keys can be passed as --key=value
# This completion lists only the top-level CLI actions that are dispatched in lw6-options.c,
# plus the documented meta flags. Config-key options are out of scope.

# Liquid War 6: GNU networked real-time-strategy game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[short alias for --help]' \
  '(- *)--help[print help]' \
  '(- *)-v[short alias for --version]' \
  '(- *)--version[print version]' \
  '--about[show keyword info]:keyword:' \
  '--copy[show copying]' \
  '--copyleft[show copyleft]' \
  '--copyright[show copyright]' \
  '--credits[show credits]' \
  '--list[list all keywords]' \
  '--list-quick[list quick keywords]' \
  '--list-doc[list doc keywords]' \
  '--list-show[list show keywords]' \
  '--list-path[list path keywords]' \
  '--list-players[list player keywords]' \
  '--list-input[list input keywords]' \
  '--list-graphics[list graphics keywords]' \
  '--list-sound[list sound keywords]' \
  '--list-network[list network keywords]' \
  '--list-map[list map keywords]' \
  '--list-map-rules[list rules.xml keywords]' \
  '--list-map-hints[list hints.xml keywords]' \
  '--list-map-style[list style.xml keywords]' \
  '--list-map-teams[list teams.xml keywords]' \
  '--list-funcs[list Guile-exported functions]' \
  '--list-hooks[list user hooks]' \
  '--list-advanced[list advanced keywords]' \
  '--list-aliases[list keyword aliases]' \
  '--list-team-colors[list team colors]' \
  '--list-weapons[list weapons]' \
  '--test[run unit tests]' \
  '--check[run high-level integration check]' \
  '--cunit[run CUnit tests]' \
  '--bench[run benchmark]' \
  '--reset[reset all keys to defaults]' \
  '--defaults[print defaults to stdout]' \
  '--show-user-dir[print user dir]' \
  '--show-log-file[print log file path]' \
  '--show-music-path[print music path]' \
  '--show-map-path[print map path]' \
  '--base64-encode[base64-encode stdin]' \
  '--base64-decode[base64-decode stdin]' \
  '--z-encode[gzip-encode stdin]' \
  '--z-decode[gzip-decode stdin]' \
  '--simulate-basic[run a simulation without graphics]' \
  '--simulate-full[run a full simulation]' \
  '--demo[demo mode]' \
  '--server[run as a server (config key)]' \
  '*::extra args (config key=value pairs):_files' && ret=0
return ret
