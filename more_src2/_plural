#compdef plural
# Documentation: https://github.com/pluralsh/plural-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (cmd/command/ directory).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'ai:AI assistant commands'
  'api:interact with the Plural API'
  'auth:authentication commands'
  'cd:continuous deployment commands'
  'clone:clone a Plural repository'
  'config:manage local Plural CLI configuration'
  'crypto:cryptography utilities'
  'down:tear down a Plural management cluster'
  'edge:edge cluster commands'
  'init:initialize a new Plural workspace'
  'mgmt:management cluster commands'
  'pr:create and manage pull requests'
  'profile:manage Plural profiles'
  'stacks:infrastructure-as-code stacks'
  'up:create a Plural management cluster'
  'version:show version information'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'plural command' commands && ret=0
    ;;
  (args)
    _default && ret=0
    ;;
esac

return ret
