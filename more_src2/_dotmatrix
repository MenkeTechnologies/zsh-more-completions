#
# dotmatrix renders raster images, GIF animations, MP4 video, and live
# webcam feeds (macOS only) to the terminal as Unicode braille art
# (U+2800–U+28FF) — 8 dots per character at 2×4 pixel density, giving
# crisp grayscale renderings without needing a tmux-image-pixel-protocol
# or kitty/sixel-capable terminal.  Floyd-Steinberg dithering by default
# (disable with `--mono` for stark monochrome).  Pre-processing via
# `disintegration/imaging` for gamma/brightness/contrast/sharpen/mirror
# before quantizing to the braille grid.  Accepts file path, URL, or
# stdin pipe; auto-detects MIME type from content sniffing or
# `Content-Type` HTTP header.
#
# === AXIS 175 CONTINUES — pure-language image processing libraries =======
# Axis position: Go=230 continues Axis 175 (slot 2/0/0).  Canonical Go
# pure-language image processing library is `disintegration/imaging`
# by Grigory Dryapak — pure-Go transforms (resize / crop / rotate /
# blur / sharpen / brightness / contrast / gamma) operating on the
# stdlib `image.Image` interface.  Same high-quality resampling kernels
# (Lanczos, CatmullRom, MitchellNetravali, NearestNeighbor, Linear,
# Box, Hermite, BSpline, Bartlett, Hann, Hamming, Blackman, Welch,
# Cosine) as Pillow/skimage but native Go without CGO or libjpeg/
# libpng/giflib system dependencies.  Used by dotmatrix (this CLI),
# esimov/pigo (face detection — covered separately), neonmodem
# (BBS TUI), kevin-cantwell/dotmatrix, knowsuchagency/pocketbase-
# template, deanishe/alfred-ssh, mrusme/neonmodem, fachschaftinformatik/
# web, and most Go CLIs that touch raster images.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=230     _noaa-apt             ← previous round (axis 175 OPENS, 1/0/0)
#   Go=230       ← THIS FILE           (axis 175 continues, slot 2/0/0)
#   TS-Node=230  ← next round          (axis 175 CLOSES at triple-230, 1/1/1)
# ---------------------------------------------------------------------------

_dotmatrix() {
    _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-i --invert)'{-i,--invert}'[invert colors (for dark backgrounds)]' \
        '(-g --gamma)'{-g,--gamma=}'[adjust gamma (-1.0 to 1.0: negative darkens, positive lightens)]:gamma:' \
        '(-b --brightness)'{-b,--brightness=}'[adjust brightness (-100 to 100)]:brightness:' \
        '(-c --contrast)'{-c,--contrast=}'[adjust contrast (-100 to 100)]:contrast:' \
        '(-s --sharpen)'{-s,--sharpen=}'[sharpen image (0+)]:sharpen:' \
        '(-m --mirror)'{-m,--mirror}'[flip image horizontally]' \
        '--mono[disable Floyd-Steinberg dithering (stark monochrome instead)]' \
        '(-w --webcam)'{-w,--webcam}'[capture from webcam (macOS only)]' \
        '(--framerate --fps)'{--framerate=,--fps=}'[playback framerate (default -1 = native)]:fps:' \
        '(--mimeType --mime)'{--mimeType=,--mime=}'[override auto-detected MIME type]:mime type:(image/png image/jpeg image/gif image/bmp image/webp video/mp4 application/mp4)' \
        '*:file or URL (or pipe via stdin):_files -g "*.(png|jpg|jpeg|gif|bmp|webp|mp4)"'
}

_dotmatrix "$@"
