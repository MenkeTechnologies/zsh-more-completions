#compdef feluda
# Documentation: https://github.com/anistark/feluda
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyze:analyze project dependency licenses (default)'
  'generate:create compliance documentation files'
  'sbom:generate Software Bill of Materials'
  'cache:manage cached data'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--path[project path to scan]:directory:_files -/' \
  '--language[target language]:lang:(rust node go python c cpp r)' \
  '--json[output JSON]' \
  '--yaml[output YAML]' \
  '--gist[condensed summary]' \
  '--gui[terminal UI mode]' \
  '--verbose[detailed output]' \
  '--osi[filter by OSI status]:status:(approved not-approved unknown)' \
  '--restrictive[show only restrictive licenses]' \
  '--project-license[your project license for compatibility]:license:' \
  '--incompatible[show incompatible licenses only]' \
  '--fail-on-restrictive[exit with error if restrictive licenses found]' \
  '--fail-on-incompatible[exit with error if incompatible licenses found]' \
  '--no-local[skip local file checks]' \
  '--github-token[GitHub API token]:token:' \
  '--repo[analyze remote Git repository]:repo:' \
  '--output-file[write results to file]:file:_files' \
  '--ci-format[CI output format]:fmt:(github jenkins)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'feluda command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sbom)
        _arguments '*::sbom subcommand:(spdx cyclonedx validate)' && ret=0 ;;
      (cache)
        _arguments '--clear[remove cached data]' && ret=0 ;;
    esac ;;
esac

return ret
