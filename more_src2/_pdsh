#compdef pdsh
# Documentation: https://manpages.debian.org/bookworm/pdsh/pdsh.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-S[return largest remote exit status]' \
  '-R[select remote command module]:module:(ssh rsh exec mrsh mqsh xcpu)' \
  '-M[load misc modules]:modules:' \
  '-N[disable hostname prepend on output lines]' \
  '-L[list pdsh modules]' \
  '-d[enable extra debug information]' \
  '-q[list option values and hosts, do not execute]' \
  '-b[disable interactive (batch) mode]' \
  '-s[combine stderr/stdout on remote (rsh module)]' \
  '-u[set command timeout]:seconds:' \
  '-t[set connect timeout]:seconds:' \
  '-f[set max number of simultaneous remote commands]:fanout:' \
  '-w[target specific hosts]:host list:_hosts' \
  '-x[exclude specific hosts]:host list:_hosts' \
  '-g[target hosts in a netgroup or genders group]:group:' \
  '-X[exclude hosts in a netgroup or genders group]:group:' \
  '-a[target all nodes]' \
  '-A[target all nodes per genders attribute]' \
  '-l[remote username]:username:_users' \
  '-i[request alternate hostnames]' \
  '-F[genders file]:file:_files' \
  '-v[verify hosts are up before issuing commands]' \
  '*:command:_command_names' && ret=0

return ret
