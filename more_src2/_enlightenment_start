#compdef enlightenment_start
# Documentation: https://www.enlightenment.org/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# enlightenment_start: launcher that runs enlightenment with recovery loop
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '*::enlightenment_start args:_files' && ret=0
return ret
