#compdef filebeat2
# _filebeat2 — Elastic filebeat2 CLI command-line frontend wrapping the Filebeat lightweight log shipper from the Elastic Beats family providing run setup test export keystore modules version completion harvester prospector container-input log-input filestream-input journald-input syslog-input redis-input docker-input udp-tcp-input fingerprint-multiline-include-exclude registry-state Elasticsearch-Logstash-Kafka-Redis output (Elastic Beats team, Go); cobra
# upstream: https://www.elastic.co/beats/filebeat

_filebeat2() {
    local -a sub=(
        'run:run filebeat'
        'setup:setup index pipelines templates'
        'test:test config or output'
        'export:export config or template'
        'keystore:keystore operations'
        'modules:modules management'
        'version:show version'
        'help:show help'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "filebeat.yml *.yml *.yaml"' \
        '--c=+[file]:file:_files -g "filebeat.yml *.yml *.yaml"' \
        '-d+[selectors]:str:' \
        '-e[log to stderr]' \
        '-E+[k=v]:str:' \
        '-M+[module setting]:str:' \
        '-N[disable publishing]' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '--strict.perms[strict perms]' \
        '--system.hostfs=+[dir]:dir:_files -/' \
        '--once[run once]' \
        '--httpprof=+[host:port]:_hosts' \
        '--cpuprofile=+[file]:file:_files' \
        '--memprofile=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'filebeat subcommand' sub ;;
        args)
            case $words[1] in
                setup) _arguments '1:target:(--index-management --pipelines --dashboards --enable-all-filesets --machine-learning --policy)' '*:arg:' ;;
                test) _arguments '1:target:(config output)' ;;
                export) _arguments '1:target:(config ilm-policy index-pattern template dashboard)' ;;
                keystore) _arguments '1:op:(add create list remove)' '*:key:' ;;
                modules) _arguments '1:op:(enable disable list)' '*:module:' ;;
            esac
            ;;
    esac
}

_filebeat2 "$@"
