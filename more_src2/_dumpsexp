#compdef dumpsexp
# Documentation: dumpsexp --help (Libgcrypt 1.12.2)
# Source: debug tool for s-expressions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--decimal[print offsets in decimal]' \
    '--assume-hex[assume input is a hex dump]' \
    '--advanced[print file in advanced format]' \
    '--verbose[verbose]' \
    '1:input file:_files' \
    && ret=0

return ret
