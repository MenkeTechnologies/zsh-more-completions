#compdef kchm
# _kchm — KCHM (legacy KDE CHM viewer; ancestor of kchmviewer; positional argument is the .chm file; --search/--page/--zoom open with pre-set state, --noverify skips ToC validation, --help/--version standard help)
# upstream: https://www.kchmviewer.net/ (legacy; superseded by kchmviewer)
# Flags from kchm src/main.cpp on tip.

_kchm() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--search+[search text]:query:' \
        '--page+[opening page]:page:' \
        '--zoom+[zoom percent]:zoom:' \
        '--noverify[skip ToC validation]' \
        '1:CHM file:_files -g "*.chm"'
}

_kchm "$@"
