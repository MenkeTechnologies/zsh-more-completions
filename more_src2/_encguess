#compdef encguess
# Documentation: encguess -h (Perl)
# Source: guess the character encoding of text files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '-s+[suspect encoding list (comma/colon separated)]:encodings:' \
    '-S[list all acceptable encoding types]' \
    '-u[suppress display of unidentified types]' \
    '*:file:_files' \
    && ret=0

return ret
