#compdef deptry
# _deptry — Python dependency issue checker (missing, unused, transitive)
# upstream: https://github.com/fpgmaas/deptry

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--config=[path to config file]:file:_files' \
  '--no-ansi[disable ANSI color output]' \
  '-o+[output JSON report to file]:file:_files' \
  '--json-output=[output JSON report to file]:file:_files' \
  '--exclude=[regex patterns of directories to exclude]:pattern' \
  '--extend-exclude=[additional directories to exclude]:pattern' \
  '--ignore=[comma-separated list of dependency names to ignore]:deps' \
  '--ignore-notebooks[skip scanning Jupyter notebooks]' \
  '--per-rule=[per-rule ignores in format RULE\:dep1,dep2]:config' \
  '--known-first-party=[known first-party modules]:modules' \
  '--experimental-namespace-package[enable namespace package support]' \
  '--pep621-dev-dependency-groups=[PEP 621 dev dependency groups]:groups' \
  '--requirements-txt=[path to requirements.txt]:file:_files' \
  '--requirements-txt-dev=[path to dev requirements.txt]:file:_files' \
  '--package-module-name-map=[mapping of package to module names]:mapping' \
  '*:source-directory:_directories' && ret=0

return ret
