#compdef pamtooctaveimg
# Documentation: man pamtooctaveimg (Netpbm)
# Source: convert a Netpbm image to a GNU Octave image-matrix script.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
