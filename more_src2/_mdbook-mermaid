#compdef mdbook-mermaid
# Documentation: https://github.com/badboy/mdbook-mermaid
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'install:install mermaid assets and update book.toml'
      'supports:check whether a renderer is supported'
    )
    _describe -t commands 'mdbook-mermaid command' commands && ret=0
    ;;
  args)
    case $line[1] in
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:book directory:_directories' && ret=0
        ;;
      supports)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:renderer:' && ret=0
        ;;
    esac
    ;;
esac

return ret
