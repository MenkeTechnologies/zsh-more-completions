#compdef etcdctl
# Documentation: etcdctl --help (etcdctl 3.6.12, API 3.6)
# Source: command-line client for etcd v3.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'alarm:alarm subcommands'
    'auth:auth subcommands'
    'check:cluster health/performance/data-scale check'
    'compaction:compact event history'
    'completion:generate shell completion script'
    'defrag:defragment storage'
    'del:delete keys/range'
    'downgrade:cluster downgrade subcommands'
    'elect:leader election'
    'endpoint:endpoint subcommands'
    'get:get key/range'
    'help:command help'
    'lease:lease subcommands'
    'lock:acquire named lock'
    'make-mirror:make a mirror at destination'
    'member:member subcommands'
    'move-leader:transfer leadership'
    'put:put key/value'
    'role:role subcommands'
    'snapshot:save/restore backend snapshot'
    'txn:transaction'
    'user:user subcommands'
    'version:show version'
    'watch:watch keys/prefixes'
)

_arguments -C -s \
    '(- *)'{-h,--help}'[show help]' \
    '--cacert=[CA bundle for TLS]:file:_files' \
    '--cert=[TLS client certificate file]:file:_files' \
    '--command-timeout=[short-command timeout]:duration:' \
    '--debug[client-side debug logging]' \
    '--dial-timeout=[dial timeout]:duration:' \
    '(-d --discovery-srv)'{-d+,--discovery-srv=}'[SRV discovery domain]:domain:' \
    '--discovery-srv-name=[SRV discovery service name]:name:' \
    '*--endpoints=[gRPC endpoints]:endpoint:' \
    '--hex[print byte strings as hex]' \
    '--insecure-discovery[accept insecure SRV records]' \
    '--insecure-skip-tls-verify[skip TLS verification]' \
    '--insecure-transport[disable transport security]' \
    '--keepalive-time=[keepalive duration]:duration:' \
    '--keepalive-timeout=[keepalive timeout]:duration:' \
    '--key=[TLS client key file]:file:_files' \
    '--max-recv-bytes=[client-side recv limit]:bytes:' \
    '--max-request-bytes=[client-side send limit]:bytes:' \
    '--password=[auth password]:password:' \
    '--user=[auth user[:password]]:user:_users' \
    '(-w --write-out)'{-w+,--write-out=}'[output format]:format:(fields json protobuf simple table)' \
    '1:command:->verbs' \
    '*::args:_normal' \
    && ret=0

case $state in
    verbs) _describe -t verbs command verbs && ret=0 ;;
esac

return ret
