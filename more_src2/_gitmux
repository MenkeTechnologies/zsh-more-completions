#compdef gitmux
# Documentation: https://github.com/arl/gitmux
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gitmux - Git status in tmux status line

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--cfg[config file]:file:_files -g "*.yml"' \
  '--printcfg[print default config]' \
  '-q[quiet mode]' \
  '-dbg[debug mode]' \
  '-timeout[timeout for git operations]:duration' \
  '1:git directory:_files -/'
