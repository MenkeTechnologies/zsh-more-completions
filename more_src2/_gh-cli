#compdef gh-cli
# _gh-cli — GitHub CLI gh alias for GitHub-from-terminal (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-cli() {
    local -a sub=(
        'alias:manage aliases'
        'api:make GitHub API calls'
        'attestation:download/verify attestations'
        'auth:authenticate'
        'browse:open repository in browser'
        'cache:GitHub Actions cache commands'
        'codespace:manage Codespaces'
        'config:manage gh config'
        'extension:manage gh extensions'
        'gist:manage gists'
        'gpg-key:manage GPG keys'
        'help:show help'
        'issue:manage issues'
        'label:manage labels'
        'org:manage organizations'
        'pr:manage pull requests'
        'project:manage projects'
        'release:manage releases'
        'repo:manage repositories'
        'ruleset:manage rulesets'
        'run:GitHub Actions runs'
        'search:search GitHub'
        'secret:manage secrets'
        'ssh-key:manage SSH keys'
        'status:show GitHub status'
        'variable:manage Actions variables'
        'workflow:GitHub Actions workflows'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--repo=+[repository in owner/name]:str:' \
        '-R+[repository in owner/name]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh subcommand' sub ;;
        args)
            case $words[1] in
                pr) _arguments \
                    '1:cmd:(checkout checks close comment create diff edit list lock merge ready reopen review status update-branch view)' \
                    '*:arg:' ;;
                issue) _arguments \
                    '1:cmd:(close comment create delete develop edit list lock pin reopen status transfer unlock unpin view)' \
                    '*:arg:' ;;
                repo) _arguments \
                    '1:cmd:(archive autolink clone create delete deploy-key edit fork list rename set-default sync unarchive view)' \
                    '*:arg:' ;;
                release) _arguments \
                    '1:cmd:(create delete download edit list upload view)' \
                    '*:arg:' ;;
                workflow) _arguments \
                    '1:cmd:(disable enable list run view)' \
                    '*:arg:' ;;
                run) _arguments \
                    '1:cmd:(cancel delete download list rerun view watch)' \
                    '*:arg:' ;;
                gist) _arguments \
                    '1:cmd:(clone create delete edit list rename view)' \
                    '*:arg:' ;;
                secret) _arguments \
                    '1:cmd:(delete list set)' \
                    '*:arg:' ;;
                api) _arguments \
                    '--method=+[HTTP method]:m:(GET POST PUT PATCH DELETE)' \
                    '-X+[HTTP method]:m:(GET POST PUT PATCH DELETE)' \
                    '--header=+[header]:list:' \
                    '-H+[header]:list:' \
                    '--field=+[field]:list:' \
                    '-f+[field]:list:' \
                    '--raw-field=+[raw field]:list:' \
                    '-F+[raw field]:list:' \
                    '--input=+[input file]:file:_files' \
                    '--paginate[paginate]' \
                    '--preview=+[preview API]:str:' \
                    '--cache=+[cache duration]:dur:' \
                    '*:endpoint:' ;;
                auth) _arguments \
                    '1:cmd:(login logout refresh setup-git status switch token)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get list set clear-cache)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gh-cli "$@"
