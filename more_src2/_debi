#compdef debi
# Documentation: https://manpages.debian.org/debi
# Source: debian/devscripts scripts/debi.pl — install just-built Debian packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '-a+[Debian target architecture]:arch:_default' \
    '-t+[GNU target architecture]:target:_default' \
    '--debs-dir=-[directory with .deb files]:dir:_files -/' \
    '(-m --multi)'{-m,--multi}'[use most recent multiarch .changes]' \
    '(-u --upgrade)'{-u,--upgrade}'[upgrade only (do not install new)]' \
    '--check-dirname-level=-[directory check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory regex]:regex:_default' \
    '--with-depends[install dependencies]' \
    '--tool=-[installer tool]:tool:(apt apt-get apt-mark dpkg gdebi)' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '--list-changes[list .changes file and exit]' \
    '--list-debs[list .deb files and exit]' \
    '1::changes file:_files -g "*.changes"' \
    '*:package:_default' \
    && ret=0

return ret
