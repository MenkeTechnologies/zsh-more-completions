#compdef kubectl-emit-event
# Documentation: https://github.com/rajatjindal/kubectl-emit-event
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[target namespace]:namespace:' \
  '--reason=[reason for the event]:reason:' \
  '--message=[event message]:message:' \
  '*:object reference:_default'
