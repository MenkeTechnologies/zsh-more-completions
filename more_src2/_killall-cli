#compdef killall-cli
# _killall-cli — psmisc killall kill processes by name CLI alias (psmisc team, C); custom argparse
# upstream: https://gitlab.com/psmisc/psmisc

_killall-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-e[require exact name match]' \
        '--exact[require exact name match]' \
        '-I[case insensitive]' \
        '--ignore-case[case insensitive]' \
        '-g[kill process group instead]' \
        '--process-group[kill process group instead]' \
        '-i[ask for confirmation]' \
        '--interactive[ask for confirmation]' \
        '-l[list signal names]' \
        '--list[list signal names]' \
        '-n[match against newest only]' \
        '-o+[older than]:str:' \
        '--older-than=+[older than]:str:' \
        '-q[no warning if no match]' \
        '--quiet[no warning if no match]' \
        '-r[interpret as regex]' \
        '--regexp[interpret as regex]' \
        '-s+[signal]:str:' \
        '--signal=+[signal]:str:' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w[wait for processes to die]' \
        '--wait[wait for processes to die]' \
        '-y+[younger than]:str:' \
        '--younger-than=+[younger than]:str:' \
        '-Z+[context]:str:' \
        '--context=+[context]:str:' \
        '-Y[skip processes with selinux]' \
        '--ns=+[pid]:pid:_pids' \
        '-N+[match container]:str:' \
        '*:process names:'
}

_killall-cli "$@"
