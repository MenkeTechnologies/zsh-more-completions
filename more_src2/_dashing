#compdef dashing
# Documentation: https://github.com/technosophos/dashing
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Dash docset generator

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:initialize a new Dashing project (dashing.json)'
  'build:build a docset from HTML documentation'
  'help:display help'
  'version:show version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'dashing command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments \
          '--source=[source HTML directory]:dir:_directories' \
          '--config=[dashing.json path]:file:_files -g "*.json"' \
          '1:docset name:' && ret=0
        ;;
      create)
        _arguments \
          '1:project name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
