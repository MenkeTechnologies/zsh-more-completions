#compdef juliaup
# Documentation: https://github.com/JuliaLang/juliaup/blob/main/src/cli.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap CLI definition at the URL above.

# Zsh completion for juliaup - Julia version manager

_juliaup() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'default:set the default Julia version'
        'add:add a specific Julia version or channel'
        'link:link an existing Julia binary or channel to a custom channel name'
        'list:list all available channels'
        'ls:list all available channels'
        'override:manage directory overrides'
        'update:update all or a specific channel to the latest Julia version'
        'up:update all or a specific channel to the latest Julia version'
        'remove:remove a Julia version from your system'
        'rm:remove a Julia version from your system'
        'status:show all installed Julia versions'
        'st:show all installed Julia versions'
        'gc:garbage collect uninstalled Julia versions'
        'config:juliaup configuration'
        'completions:generate tab-completion scripts for your shell'
        'self:manage this juliaup installation'
    )

    _arguments -C \
        '(- *)--help[print help]' \
        '(- *)--version[print version]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'juliaup command' commands
            ;;
        args)
            case $words[1] in
                add|default|remove|rm)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1:channel:'
                    ;;
                update|up)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1::channel:'
                    ;;
                link)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '1:channel:' \
                        '2:target:' \
                        '*:args:'
                    ;;
                list|ls|status|st)
                    _arguments -s -S \
                        '(- *)--help[print help]'
                    ;;
                gc)
                    _arguments -s -S \
                        '(- *)--help[print help]' \
                        '--prune-linked[also prune linked channels]'
                    ;;
                override)
                    local -a override_commands=(
                        'status:view configured overrides'
                        'set:set a directory override'
                        'unset:remove a directory override'
                    )
                    _arguments -C \
                        '(- *)--help[print help]' \
                        '1:override command:->overridecmd' \
                        '*::arg:->overrideargs'
                    case $state in
                        overridecmd)
                            _describe -t override_commands 'override command' override_commands
                            ;;
                        overrideargs)
                            case $words[1] in
                                set)
                                    _arguments -s -S \
                                        '(-p --path)'{-p+,--path=}'[path to override]:dir:_files -/' \
                                        '1:channel:'
                                    ;;
                                unset)
                                    _arguments -s -S \
                                        '(-n --nonexistent)'{-n,--nonexistent}'[unset nonexistent overrides]' \
                                        '(-p --path)'{-p+,--path=}'[path to unset]:dir:_files -/'
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                self)
                    local -a self_commands=(
                        'update:update juliaup itself'
                        'up:update juliaup itself'
                        'channel:configure the channel to use for juliaup updates'
                        'uninstall:uninstall this version of juliaup'
                    )
                    _arguments -C \
                        '(- *)--help[print help]' \
                        '1:self command:->selfcmd'
                    case $state in
                        selfcmd)
                            _describe -t self_commands 'self command' self_commands
                            ;;
                    esac
                    ;;
                completions)
                    _arguments -s -S \
                        '1:shell:(bash elvish fish nushell powershell zsh)'
                    ;;
                config)
                    _arguments -s -S \
                        '(- *)--help[print help]'
                    ;;
            esac
            ;;
    esac
}

_juliaup "$@"
