#compdef miniwdl
# _miniwdl — Mike Lin miniwdl pure Python WDL workflow developer kit and runner (chanzuckerberg team, Python); argparse subcommands
# upstream: https://github.com/chanzuckerberg/miniwdl

_miniwdl() {
    local -a sub=(
        'check:syntax check WDL source'
        'run:run a WDL workflow'
        'configure:configure miniwdl'
        'eval:evaluate WDL expression'
        'localize:fetch remote files'
        'zip:archive WDL workflow'
        'cromwell:download Cromwell'
        'input_template:generate input template'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--no-color[disable color]' \
        '--debug[debug logging]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'miniwdl subcommand' sub ;;
        args)
            case $words[1] in
                check) _arguments \
                    '--strict[strict mode]' \
                    '-p+[search path]:dir:_files -/' \
                    '--path=+[search path]:dir:_files -/' \
                    '--no-quant-check[no quant check]' \
                    '*:wdl file:_files -g "*.wdl"' ;;
                run) _arguments \
                    '-i+[input JSON]:file:_files -g "*.json *.yaml *.yml"' \
                    '--input=+[input JSON]:file:_files -g "*.json *.yaml *.yml"' \
                    '-d+[output dir]:dir:_files -/' \
                    '--dir=+[output dir]:dir:_files -/' \
                    '--cfg=+[config file]:file:_files' \
                    '--env=+[env vars csv]:str:' \
                    '--task=+[task name]:str:' \
                    '--copy-input-files[copy input files]' \
                    '--no-cache[no cache]' \
                    '--no-outside-imports[no outside imports]' \
                    '--max-tasks=+[N]:n:' \
                    '--max-runtime-cpu=+[N]:n:' \
                    '--max-runtime-memory=+[size]:str:' \
                    '--max-runtime-time=+[seconds]:n:' \
                    '--runtime-defaults=+[JSON]:str:' \
                    '--allow-no-default-runtime-container[allow no default container]' \
                    '--mount-default=+[mode]:m:(none host docker)' \
                    '*:wdl file:_files -g "*.wdl"' ;;
                input_template) _arguments \
                    '*:wdl file:_files -g "*.wdl"' ;;
                localize) _arguments \
                    '--cache-dir=+[dir]:dir:_files -/' \
                    '*:url file:' ;;
                zip) _arguments \
                    '-o+[output zip]:file:_files -g "*.zip"' \
                    '*:wdl file:_files -g "*.wdl"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_miniwdl "$@"
