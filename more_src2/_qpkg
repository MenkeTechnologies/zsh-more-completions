#compdef qpkg
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qpkg.c — manage Gentoo binary-package directory.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --clean)'{-c,--clean}'[clean pkgdir of not-installed files]' \
    '(-E --eclean)'{-E,--eclean}'[clean pkgdir of files no longer in tree]' \
    '(-g --gpkg -x --xpak)'{-g,--gpkg}'[force gpkg build format]' \
    '(-g --gpkg -x --xpak)'{-x,--xpak}'[force tbz2/xpak build format]' \
    '(-p --pretend)'{-p,--pretend}'[pretend only]' \
    '(-P --pkgdir)'{-P+,--pkgdir=}'[alternate package directory]:dir:_directories' \
    '*:package atom:_default' \
    && ret=0

return ret
