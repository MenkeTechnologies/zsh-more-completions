#compdef docsify-cli docsify
# _docsify-cli — Sun QingChao docsify magical documentation site generator CLI alias (docsifyjs team, JavaScript); commander
# upstream: https://github.com/docsifyjs/docsify-cli

_docsify-cli() {
    local -a sub=(
        'init:initialize project'
        'serve:serve docs locally'
        'generate:generate sidebar/index'
        'start:start docs server (alias of serve)'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'docsify subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '1:path:_files -/' \
                    '--local[copy local docsify files]' \
                    '-l[copy local docsify files]' \
                    '--theme=+[theme]:t:(vue buble dark pure dolphin)' \
                    '-t+[theme]:t:(vue buble dark pure dolphin)' \
                    '--plugins[include plugins]' \
                    '-p[include plugins]' ;;
                serve|start) _arguments \
                    '1:path:_files -/' \
                    '--open[open browser]' \
                    '-o[open browser]' \
                    '--port=+[port]:port:' \
                    '-P+[port]:port:' \
                    '--livereload-port=+[livereload port]:port:' \
                    '-l+[livereload port]:port:' \
                    '--index-name=+[index name]:str:' \
                    '-i+[index name]:str:' \
                    '--no-livereload[disable livereload]' ;;
                generate) _arguments \
                    '1:path:_files -/' \
                    '--sidebar=+[sidebar file]:file:_files' \
                    '-s+[sidebar file]:file:_files' ;;
            esac
            ;;
    esac
}

_docsify-cli "$@"
