#compdef rambox Rambox
# _rambox — Rambox Electron messaging client (multi-service tabs over Slack/Teams/Telegram/Discord/Gmail/etc.; inherits Electron --user-data-dir, --proxy-server, --enable-features, --ozone-platform; --service-id opens to a specific service tab)
# upstream: https://github.com/ramboxapp/community-edition
# Flags from rambox/community-edition src/main.js on tip.

_rambox() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--no-sandbox[disable Electron sandbox]' \
        '--disable-gpu[disable GPU]' \
        '--user-data-dir=*[user data dir]:dir:_files -/' \
        '--proxy-server=*[proxy URI]:proxy:' \
        '--enable-features=*[Chromium features]:features:' \
        '--disable-features=*[Chromium features]:features:' \
        '--ozone-platform=*[ozone backend]:platform:(x11 wayland)' \
        '--service-id=*[open to service tab]:service:' \
        '*::url:'
}

_rambox "$@"
