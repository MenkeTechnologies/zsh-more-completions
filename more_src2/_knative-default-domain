#compdef knative-default-domain
# _knative-default-domain — Knative Serving default-domain helper (writes the default-domain ConfigMap)
# upstream: https://github.com/knative/serving
# Flags from cmd/default-domain/main.go on tip.

_knative-default-domain() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-server=[Kubernetes API server URL]:url:_urls' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-magic-dns=[magic DNS hostname]:host:(sslip.io nip.io xip.io)'
}

_knative-default-domain "$@"
