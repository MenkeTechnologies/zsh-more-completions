#compdef mail.mboxfile
# _mail.mboxfile — OpenSMTPD mail.mboxfile delivery helper (reads stdin and appends it to a single mbox file; called by smtpd(8) for mbox: destinations)
# upstream: https://github.com/OpenSMTPD/OpenSMTPD
# Flags from usr.sbin/smtpd/mail.mboxfile.8 on tip.

_mail.mboxfile() {
    _arguments '1:mbox-file:_files'
}

_mail.mboxfile "$@"
