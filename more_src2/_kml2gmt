#compdef kml2gmt
# Documentation: https://docs.generic-mapping-tools.org/latest/kml2gmt.html
# Source: GenericMappingTools/gmt classic-mode kml2gmt — convert Google Earth KML to GMT table format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[take altitude from ExtendData (ignore z)]' \
    '-F+[filter output by feature type]:type:(s l p)' \
    '-Z[output altitude as GMT z coords]' \
    '*-V[verbose (stackable)]' \
    '-bo+[binary output format]:format:_default' \
    '-do+[output NaN → nodata replacement]:value:_default' \
    '-h+[header records]:n:_default' \
    '-:+[swap first two cols on input/output]:dir:(i o)' \
    '(- *)-\?[show help]' \
    '*:KML file:_files -g "*.(kml|kmz)(-.)"' \
    && ret=0

return ret
