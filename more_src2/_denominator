#compdef denominator
# Documentation: https://github.com/Netflix/denominator
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Netflix/denominator — portable Java DNS clouds library (archived 2025-12-19)
local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'zone:zone operations'
  'record:record operations'
  'providers:list available DNS providers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-p+[DNS provider]:provider:(mock route53 ultradns dynect clouddns designate)' \
  '*-c+[credentials piece]:credential' \
  '-u+[provider URL]:url' \
  '-n+[provider config name]:name' \
  '-q[quiet output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'denominator command' commands && ret=0 ;;
  args)
    case $line[1] in
      zone)
        local -a zone_subs=(
          'list:list zones'
          'add:add a zone'
          'update:update a zone'
          'delete:delete a zone'
        )
        _describe -t zsubs 'zone subcommand' zone_subs && ret=0 ;;
      record)
        _arguments \
          '-z+[zone]:zone' \
          '*::action:(list add replace delete get applyttl)' && ret=0 ;;
    esac ;;
esac

return ret
