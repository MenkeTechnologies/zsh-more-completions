#compdef metallb-controller controller
# _metallb-controller — MetalLB cluster controller (allocates LoadBalancer IPs from IPAddressPool CRs)
# upstream: https://github.com/metallb/metallb
# Flags from controller/main.go on tip.

_metallb-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-port=[HTTPS metrics port]:port:' \
        '-namespace=[config / memberlist secret namespace]:ns:' \
        '-ml-secret-name=[memberlist secret name]:name:' \
        '-deployment=[controller Deployment name]:name:' \
        '-log-level=[log level]:level:(all debug info warn error none)' \
        '-pprof-bind-address=[pprof endpoint bind addr (empty=off)]:addr:' \
        '-health-probe-port=[health probe port]:port:' \
        '-disable-cert-rotation[disable automatic webhook TLS cert rotation]' \
        '-cert-dir=[webhook serving cert directory]:dir:_files -/' \
        '-cert-service-name=[service name for webhook TLS hostname]:name:' \
        '-lb-class=[only handle services with this spec.loadBalancerClass]:class:' \
        '-webhook-mode=[webhook mode]:mode:(enabled disabled onlywebhook)' \
        '-webhook-secret=[webhook secret name]:name:' \
        '-pod-name=[name of this controller pod]:name:' \
        '-webhook-http2[enable HTTP/2 for the webhook endpoint]' \
        '-tls-min-version=[minimum TLS version]:ver:(VersionTLS12 VersionTLS13)' \
        '-tls-cipher-suites=[comma-separated TLS 1.2 cipher suites]:list:' \
        '-tls-curve-preferences=[comma-separated CurveID values]:list:' \
        '-metrics-cert-dir=[directory with tls.crt/tls.key for metrics TLS]:dir:_files -/'
}

_metallb-controller "$@"
