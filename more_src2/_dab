#compdef dab
# Documentation: man dab(6)
# Source: netbsd/src games/dab/main.cc — dots and boxes game (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[disable alternate character set]' \
    '-n+[number of games to play]:ngames:_default' \
    '-p+[player types (c=computer, h=human)]:players:(cc ch hc hh)' \
    '-w[wait for keypress between games]' \
    '1::board width (0 = max):_default' \
    '2::board height (0 = max):_default' \
    && ret=0

return ret
