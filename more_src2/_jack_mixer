#compdef jack_mixer
# Documentation: https://github.com/jack-mixer/jack_mixer/blob/main/jack_mixer/app.py
# Reference accessed: 2026-05-19
# Verified: upstream argparse block at the URL above.
# Note: prior file invented -v/--version and -n/--client-name; the
# real CLI is -c/--config FILE, -d/--debug, and a positional NAME
# (JACK client name), plus argparse's auto -h/--help.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'+[load mixer project configuration from FILE]:file:_files' \
  '(-d --debug)'{-d,--debug}'[enable debug logging messages]' \
  '1:JACK client name:' && ret=0

return ret
