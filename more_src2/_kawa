#compdef kawa
# Documentation: https://www.gnu.org/software/kawa/Options.html
# Reference accessed: 2026-05-19
# Verified: GNU Kawa "Command-line arguments" documentation.
# Fixed from prior file: -c/-C semantics (-C compiles, -c evals
# with init file), removed invented --script0 (real: --script2),
# corrected -T (top class name) and --target values, fixed
# malformed --module-extends/--module-implements arg specs.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[print help message]' \
  '--version[print version number]' \
  '-e+[evaluate expression at startup (no init file)]:expr:' \
  '-c+[evaluate expression at startup (run init file)]:expr:' \
  '-f+[read and evaluate file or URL]:file:_files -g "*.scm *.kawa"' \
  '-C+[compile named source file to .class files]:file:_files -g "*.scm *.kawa"' \
  '-d+[output directory for compiled .class files]:dir:_files -/' \
  '-s[pass remaining arguments to the script]' \
  '--script+[execute script file or URL]:file:_files' \
  '--script2+[execute script after skipping two lines]:file:_files' \
  '--server+[start a server listening on portnum]:port:' \
  '--connect+[connect to a server portnum (kawa front-end)]:port:' \
  '-w[start a read-eval-print loop in a new window]' \
  '--main[generate a main method (standalone application)]' \
  '--applet[generate an applet class]' \
  '--servlet[generate a servlet class]' \
  '--module-static[map module to a static Java class]' \
  '--module-static-run[static module whose body runs on class load]' \
  '--module-nonstatic[map module to a non-static Java class]' \
  '--module-extends=[parent class for generated module]:class:' \
  '--module-implements=[interfaces implemented by module (comma-separated)]:list:' \
  '--full-tailcalls[implement proper tail calls]' \
  '--no-full-tailcalls[disable proper tail calls (default)]' \
  '--no-inline[disable procedure inlining]' \
  '--inline[enable procedure inlining]' \
  '--warn-undefined-variable[warn on undefined variables]' \
  '--warn-unknown-member[warn on unknown members]' \
  '--warn-invoke-unknown-method[warn on invoke-unknown-method]' \
  '--warn-unused[warn on unused declarations]' \
  '--warn-as-error[make warnings into errors]' \
  '-T+[name of the top-level generated class]:topname:' \
  '-P+[prefix prepended to generated class names]:prefix:' \
  '--target+[target JDK version]:version:(5 6 7)' \
  '--scheme[use Scheme language (default)]' \
  '--r5rs[Scheme R5RS mode]' \
  '--r6rs[Scheme R6RS mode]' \
  '--r7rs[Scheme R7RS mode]' \
  '--commonlisp[use Common Lisp language]' \
  '--clisp[use Common Lisp language]' \
  '--elisp[use Emacs Lisp language]' \
  '--emacs[use Emacs Lisp language]' \
  '--xquery[use XQuery language]' \
  '--xslt[use XSLT language]' \
  '--brl[use BRL language]' \
  '--krl[use KRL language]' \
  '*-J-[pass option to the Java launcher]:jvm-option:' \
  '*-D-[set a JVM system property]:var=value:' \
  '*: :_files -g "*.scm *.kawa *.xq *.cl *.el"' && ret=0

return ret
