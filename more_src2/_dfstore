#compdef dfstore
# _dfstore — Dragonfly P2P object-store CLI (dragonflyoss/client)
# upstream: https://github.com/dragonflyoss/client
# Subcommands from dragonfly-client/src/bin/dfstore/main.rs (clap).

_dfstore() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'import:import a file into the Dragonfly P2P network (with object-storage persistence)'
                'export:export a file from the Dragonfly P2P network'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                import) _arguments '1:local file:_files' ;;
                export) _arguments '1:task ID:' ;;
            esac
            ;;
    esac
}

_dfstore "$@"
