#compdef roboflow
# _roboflow — Roboflow computer-vision CLI (roboflow/roboflow-cli)
# upstream: https://github.com/roboflow/roboflow-cli
# Subcommands from cli/index.js (commander).

_roboflow() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[print verbose debugging info]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'auth:log in to Roboflow'
                'login:alias for auth'
                'config:show/reset local Roboflow config'
                'open:open a Roboflow workspace in browser'
                'workspace:workspace-related commands'
                'project:project-related commands'
                'upload:upload images to a project'
                'import:import a dataset'
                'download:download dataset for a project version'
                'infer:run inference against an endpoint'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                config) _arguments '1:action:(show reset)' ;;
                workspace) _arguments '1:sub:(select get list)' ;;
                project) _arguments '1:sub:(list get)' ;;
                open|upload|import|download|infer)
                    _arguments '(-w --workspace)'{-w+,--workspace=}'[workspace id]:workspace:'
                    ;;
            esac
            ;;
    esac
}

_roboflow "$@"
