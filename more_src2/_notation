#compdef notation
# Documentation: https://github.com/notaryproject/notation/blob/main/specs/notation-cli.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'sign:sign OCI artifacts'
      'verify:verify OCI artifacts'
      'certificate:manage certificates in trust store'
      'key:manage keys used for signing'
      'login:log into OCI registries'
      'logout:log out from OCI registries'
      'list:list signatures of a signed OCI artifact'
      'inspect:inspect OCI signatures'
      'blob:sign, verify and inspect signatures for blobs'
      'plugin:manage plugins'
      'policy:manage OCI trust policy for verification'
      'version:print the version of notation CLI'
    )
    _describe -t commands 'notation command' commands && ret=0
    ;;
  args)
    case $words[1] in
      sign)
        _arguments -s -S \
          '(-k --key)'{-k,--key}'=[signing key name]:key' \
          '--plugin=[signing plugin name]:plugin' \
          '--id=[key ID (required if --plugin is set)]:id' \
          '--signature-format=[envelope format]:format:(jws cose)' \
          '(-e --expiry)'{-e,--expiry}'=[signature expiry duration]:duration' \
          '*--plugin-config=[plugin config key=value]:kv' \
          '*'{-m,--user-metadata}'=[user metadata key=value]:kv' \
          '--timestamp-url=[TSA server URL]:url' \
          '--timestamp-root-cert=[TSA root cert path]:file:_files' \
          '--force-referrers-tag[force referrers tag schema]' \
          '--insecure-registry[use HTTP for registry]' \
          '--oci-layout[sign artifact stored as OCI image layout]' \
          '(-u --username)'{-u,--username}'=[username]:user' \
          '(-p --password)'{-p,--password}'=[password]:pass' \
          '(-d --debug)'{-d,--debug}'[debug mode]' \
          '1:reference' \
          && ret=0
        ;;
      verify)
        _arguments -s -S \
          '--scope=[trust policy scope for artifact verification (with --oci-layout)]:scope' \
          '*--plugin-config=[plugin config key=value]:kv' \
          '*'{-m,--user-metadata}'=[user metadata key=value]:kv' \
          '--max-signatures=[maximum signatures to evaluate]:n' \
          '--insecure-registry[use HTTP for registry]' \
          '--oci-layout[verify artifact stored as OCI image layout]' \
          '(-u --username)'{-u,--username}'=[username]:user' \
          '(-p --password)'{-p,--password}'=[password]:pass' \
          '(-d --debug)'{-d,--debug}'[debug mode]' \
          '1:reference' \
          && ret=0
        ;;
      login)
        _arguments -s -S \
          '(-u --username)'{-u,--username}'=[username]:username' \
          '(-p --password)'{-p,--password}'=[password]:password' \
          '--password-stdin[read password from stdin]' \
          '--insecure-registry[use HTTP for registry]' \
          '1:server' \
          && ret=0
        ;;
      logout)
        _arguments -s -S \
          '1:server' \
          && ret=0
        ;;
      list|inspect)
        _arguments -s -S \
          '1:reference' \
          && ret=0
        ;;
      key)
        _arguments -s -S -C \
          '1:subcommand:(add delete list update)' \
          && ret=0
        ;;
      certificate)
        _arguments -s -S -C \
          '1:subcommand:(add delete list show generate-test)' \
          && ret=0
        ;;
      plugin)
        _arguments -s -S -C \
          '1:subcommand:(install list uninstall)' \
          && ret=0
        ;;
      policy)
        _arguments -s -S -C \
          '1:subcommand:(import show)' \
          && ret=0
        ;;
      blob)
        _arguments -s -S -C \
          '1:subcommand:(sign verify inspect policy)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
