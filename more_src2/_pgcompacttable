#compdef pgcompacttable
# Documentation: https://github.com/dataegret/pgcompacttable
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --man)'{-m,--man}'[show full man page]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --host)'{-h+,--host=}'[database host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[database port]:port:' \
  '(-U --user)'{-U+,--user=}'[database user]:user:_users' \
  '(-W --password)'{-W+,--password=}'[database password]:password:' \
  '(-d --dbname)'{-d+,--dbname=}'[database name]:db:' \
  '(-a --all)'{-a,--all}'[process all databases]' \
  '(-n --schema)'{-n+,--schema=}'[schema name]:schema:' \
  '(-N --exclude-schema)'{-N+,--exclude-schema=}'[exclude schema]:schema:' \
  '(-t --table)'{-t+,--table=}'[table name]:table:' \
  '(-T --exclude-table)'{-T+,--exclude-table=}'[exclude table]:table:' \
  '--tables-like=[filter tables by pattern]:pattern:' \
  '--min-table-size=[minimum table size MB]:mb:' \
  '--max-table-size=[maximum table size MB]:mb:' \
  '(-f --force)'{-f,--force}'[force compaction even on low bloat]' \
  '(-r --no-reindex)'{-r,--no-reindex}'[skip reindex]' \
  '--no-initial-vacuum[skip initial vacuum]' \
  '(-i --initial-reindex)'{-i,--initial-reindex}'[perform initial reindex]' \
  '--reindex-replace[replace indexes during reindex]' \
  '--reindex-retry-count=[max reindex retries]:n:' \
  '--reindex-retry-pause=[pause between retries seconds]:s:' \
  '--reindex-lock-timeout=[reindex lock timeout ms]:ms:' \
  '(-s --print-reindex-queries)'{-s,--print-reindex-queries}'[print reindex SQL]' \
  '(-E --delay-ratio)'{-E+,--delay-ratio=}'[delay ratio]:n:' \
  '(-o --max-retry-count)'{-o+,--max-retry-count=}'[max retry count]:n:' \
  '(-Q --after-round-query)'{-Q+,--after-round-query=}'[query to run after each round]:sql:' \
  '(-R --routine-vacuum)'{-R,--routine-vacuum}'[enable routine vacuuming]' && ret=0

return ret
