#compdef git-brv git-clear git-clear-soft git-contrib git-cp git-create-branch git-delete-branch git-delete-squashed-branches git-delete-submodule git-delete-tag git-force-clone git-pull-request
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 5. Companion to rounds 150-153 + the pre-existing
# _git-changelog / _git-info / _git-ignore / _git-get standalone files.
# Hunt-skip log this round: git-mailmap / git-merges / git-promote /
# git-psykick / git-line-summary / git-jira all 404 on direct fetch
# from tj/git-extras master; defer per the source-404 precedent.

local curcontext="$curcontext" state line ret=1

case $service in

  git-brv)
    # man/git-brv.1 — list branches sorted by last commit date. No options.
    _arguments -s -S \
      && ret=0
    ;;

  git-clear)
    # man/git-clear.1 — combined hard reset + clean.
    _arguments -s -S \
      '(- *)-h[show usage]' \
      '(- *)--help[show usage]' \
      '(-f --force)-f[force the clean with no warning]' \
      '(-f --force)--force[force the clean with no warning]' \
      && ret=0
    ;;

  git-clear-soft)
    # man/git-clear-soft.1 — git-clear that respects .gitignore.
    # Preserves any files/dirs listed in .gitignore. No options.
    _arguments -s -S \
      && ret=0
    ;;

  git-contrib)
    # man/git-contrib.1 — show commits by a specific user.
    _arguments -s -S \
      '1:username or email:' \
      && ret=0
    ;;

  git-cp)
    # man/git-cp.1 — copy a file preserving git history.
    _arguments -s -S \
      '1:source filename:_files' \
      '2:destination filename:_files' \
      && ret=0
    ;;

  git-create-branch)
    # man/git-create-branch.1 — create a branch with optional remote tracking.
    #   git-create-branch [-r|--remote [remote_name]] [--from [start_point]] <branchname>
    _arguments -s -S \
      '(-r --remote)-r+[set up remote tracking branch (default origin)]:remote:__git_remotes' \
      '(-r --remote)--remote=[set up remote tracking branch (default origin)]:remote:__git_remotes' \
      '--from=[start point for the new branch (default current)]:start point:__git_revisions' \
      '*:branch name:' \
      && ret=0
    ;;

  git-delete-branch)
    # man/git-delete-branch.1 — delete one or more local + remote branches.
    _arguments -s -S \
      '*:branch:__git_branch_names' \
      && ret=0
    ;;

  git-delete-squashed-branches)
    # man/git-delete-squashed-branches.1 — delete branches squash-merged into target.
    #   git-delete-squashed-branches [--proceed, -p] [<branch-name>]
    _arguments -s -S \
      '(-p --proceed)-p[continue if a branch cannot be deleted]' \
      '(-p --proceed)--proceed[continue if a branch cannot be deleted]' \
      '1:target branch where squash-merged were integrated (default current):__git_branch_names' \
      && ret=0
    ;;

  git-delete-submodule)
    # man/git-delete-submodule.1 — fully remove a submodule.
    _arguments -s -S \
      '1:submodule path:_files -/' \
      && ret=0
    ;;

  git-delete-tag)
    # man/git-delete-tag.1 — delete one or more tags locally + remotely.
    _arguments -s -S \
      '*:tag:__git_tags' \
      && ret=0
    ;;

  git-force-clone)
    # man/git-force-clone.1 — clone, replacing the dest dir if it exists.
    #   force-clone [--branch <name>] <remote_url> <destination_path>
    _arguments -s -S \
      '(- *)--help[show help]' \
      '--branch=[checkout this branch after clone]:branch:' \
      '1:remote URL:' \
      '2:destination path:_files -/' \
      && ret=0
    ;;

  git-pull-request)
    # man/git-pull-request.1 — file a PR against optional target branch.
    _arguments -s -S \
      '1:target branch:__git_branch_names' \
      && ret=0
    ;;

esac

return ret
