#compdef gomatrix
# gomatrix - Displays "The Matrix" in a terminal (Go CMatrix clone)
#
# Upstream: https://github.com/GeertJohan/gomatrix  (314 stars, BSD-2-Clause)
# Author:   Geert-Johan Riemer (@GeertJohan)
# Library:  gdamore/tcell (canonical Go async terminal IO, MPL-2.0)
#           jessevdk/go-flags (POSIX-style flag parser used here in struct-tag form)
#
# Source-direct extraction from main.go `var opts struct {...}` block:
#   https://github.com/GeertJohan/gomatrix/blob/master/main.go
#
# Character mode is set by mutually exclusive --ascii / --kana flags; default
# is the combined halfWidthKana + alphaNumerics set ("authentic" cmatrix look).

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show command-line help and exit]' \
    '(-a --ascii -k --kana)'{-a,--ascii}'[use ASCII/alphanumeric characters only (no half-width kana)]' \
    '(-a --ascii -k --kana)'{-k,--kana}'[use Japanese half-width kana only (no ASCII)]' \
    '(-l --log)'{-l,--log}'[enable logging debug messages to ~/.gomatrix-log]' \
    '(-p --profile)'{-p,--profile}'+[write a Go pprof CPU profile to FILE]:profile file:_files' \
    '--fps=[target frames per second (1-60; default 25)]:fps:' \
    && ret=0

return ret
