#compdef fdesetup
# Documentation: https://www.unix.com/man-page/osx/8/fdesetup/
# Source: Apple macOS — FileVault 2 administration CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'help:abbreviated help'
            'list:list enabled users'
            'enable:enable FileVault'
            'disable:disable FileVault'
            'status:current FileVault status'
            'sync:sync info from Open Directory to FileVault'
            'add:add additional FileVault users'
            'remove:remove an enabled user'
            'changerecovery:update the recovery key'
            'removerecovery:remove the recovery key'
            'authrestart:authenticated restart (skip initial unlock)'
            'isactive:exit 0 + "true" if FileVault is enabled'
            'haspersonalrecoverykey:check for a personal recovery key'
            'hasinstitutionalrecoverykey:check for an institutional recovery key'
            'usingrecoverykey:check if unlocked using the personal recovery key'
            'supportsauthrestart:check if authenticated restart is supported'
            'validaterecovery:validate the personal recovery key'
            'showdeferralinfo:show deferred-enable settings'
            'version:print tool version'
        )
        _describe -t subcmds 'fdesetup command' subcmds && ret=0
        ;;
    args)
        _arguments \
            '-defer[defer enable until next user logout]:plist:_files' \
            '-user[short username]:user:_users' \
            '-uuid[user UUID]:uuid:' \
            '-usertoadd[additional user(s) for FileVault]:user:_users' \
            '-inputplist[read configuration from stdin (plist)]' \
            '-prompt[always request information interactively]' \
            '-forcerestart[force normal restart after configuration]' \
            '-authrestart[authenticated restart after enable]' \
            '-outputplist[write recovery key to stdout as plist]' \
            '-keychain[use institutional recovery key from FileVaultMaster.keychain]' \
            '-certificate[institutional cert (DER)]:file:_files' \
            '-key[keychain with institutional recovery key]:file:_files' \
            '-norecoverykey[omit personal recovery key generation]' \
            '-verbose[detailed output]' \
            '*:argument:' \
            && ret=0
        ;;
esac

return ret
