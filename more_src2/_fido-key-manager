_fido-key-manager() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _fido_commands=(
                'selection:request user presence on a connected FIDO token'
                'info:show information about all connected FIDO tokens'
                'factory-reset:reset the connected FIDO token to factory settings'
                'toggle-always-uv:toggle the Always Require User Verification feature'
                'enable-enterprise-attestation:enable the Enterprise Attestation feature'
                'bio-info:get information about biometric authentication'
                'enroll-fingerprint:enroll a fingerprint on the device'
                'list-fingerprints:list all enrolled fingerprints'
                'rename-fingerprint:rename an enrolled fingerprint'
                'remove-fingerprint:remove an enrolled fingerprint'
                'set-pin-policy:set policies for PINs'
                'set-pin:set a PIN on a token that does not already have one'
                'change-pin:change a PIN on a token that already has one'
                'get-credential-metadata:get discoverable-credential storage metadata'
                'list-credentials:list all discoverable credentials on this token'
                'delete-credential:delete a discoverable credential'
                'update-credential-user:update user info for a discoverable credential'
                'solo-key-info:info about a connected SoloKey 2 / Trussed device'
                'solo-key-random:get random bytes from a SoloKey 2 / Trussed device'
                'yubikey-get-config:get a YubiKey config'
                'wink:wink a connected USB device'
            )
            _describe -t commands 'fido-key-manager command' _fido_commands && ret=0
            ;;
        args)
            case $words[1] in
                info|bio-info|solo-key-info|wink)
                    _arguments '--watch[continue watching until explicitly terminated]' && ret=0
                    ;;
                enroll-fingerprint)
                    _arguments '1:human-readable friendly name:' && ret=0
                    ;;
                rename-fingerprint)
                    _arguments \
                        '1:template ID:' \
                        '2:human-readable friendly name:' && ret=0
                    ;;
                remove-fingerprint)
                    _arguments '*:template ID(s) to remove:' && ret=0
                    ;;
                set-pin-policy)
                    _arguments \
                        '(-l --length)'{-l,--length}'=[minimum PIN length in Unicode codepoints]:length:' \
                        '*'{-r,--rpids}'=[RPIDs authorised to use minPinLength extension]:rpid:' \
                        '--force-change[invalidate existing PIN, force change]' && ret=0
                    ;;
                set-pin)
                    _arguments '(-n --new-pin)'{-n,--new-pin}'=[new PIN value]:pin:' && ret=0
                    ;;
                change-pin)
                    _arguments \
                        '(-o --old-pin)'{-o,--old-pin}'=[old PIN value]:pin:' \
                        '(-n --new-pin)'{-n,--new-pin}'=[new PIN value]:pin:' && ret=0
                    ;;
                list-credentials)
                    _arguments \
                        '(--hash)--rpid=[relying-party ID]:rpid:' \
                        '(--rpid)--hash=[SHA-256 hash of an RPID (hex)]:hash:' && ret=0
                    ;;
                delete-credential)
                    _arguments '1:credential ID (hex):' && ret=0
                    ;;
                update-credential-user)
                    _arguments \
                        '1:credential ID (hex):' \
                        '2:user ID (hex):' \
                        '--name=[human-palatable username/email/phone]:name:' \
                        '--display-name=[human-palatable display name]:name:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_fido-key-manager "$@"
