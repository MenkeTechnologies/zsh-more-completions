#compdef LesionFilling
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/LesionFilling.cxx — fill T1 lesion voxels with WM neighbour intensities (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:T1_image.nii.gz:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:lesion_mask.nii.gz:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:output_filled.nii.gz:_files' \
    && ret=0

return ret
