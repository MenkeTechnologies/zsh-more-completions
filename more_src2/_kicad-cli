#compdef kicad-cli
# Documentation: https://docs.kicad.org/9.0/en/cli/cli.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'fp:footprint and footprint library operations'
  'jobset:run a jobset'
  'pcb:PCB operations'
  'sch:schematic operations'
  'sym:symbol and symbol library operations'
  'version:display version information'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      pcb)
        local -a pcb_cmds=(
          'drc:run design rule check on a PCB'
          'export:export a PCB'
        )
        _arguments '1:subcommand:->subcmd' '*::args:->subargs' && ret=0
        case $state in
          subcmd) _describe -t commands 'pcb subcommand' pcb_cmds && ret=0 ;;
          subargs)
            case ${words[1]} in
              export)
                local -a export_cmds=(
                  'brep:export BREP'
                  'drill:export drill files'
                  'dxf:export DXF'
                  'gencad:export GenCAD'
                  'gerber:export Gerber files'
                  'gerbers:export Gerber file set'
                  'glb:export GLB (binary glTF)'
                  'ipc2581:export IPC-2581'
                  'ipcd356:export IPC-D-356 netlist'
                  'odb:export ODB++'
                  'pdf:export PDF'
                  'ply:export PLY'
                  'pos:export position file'
                  'step:export STEP 3D model'
                  'stl:export STL'
                  'svg:export SVG'
                  'vrml:export VRML'
                  'xao:export XAO'
                )
                _arguments '1:format:->fmt' '*::args:' && ret=0
                [[ $state == fmt ]] && _describe -t commands 'export format' export_cmds && ret=0
                ;;
              drc)
                _arguments \
                  '(-o --output)'{-o,--output}'[output report file]:file:_files' \
                  '--format=[report format]:format:(json report)' \
                  '--severity-all[report all violations]' \
                  '--severity-error[report only errors]' \
                  '--severity-warning[report warnings and errors]' \
                  '--exit-code-violations[return exit code on violations]' \
                  '1:PCB file:_files -g "*.kicad_pcb"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      sch)
        local -a sch_cmds=(
          'erc:run electrical rules check'
          'export:export a schematic'
        )
        _arguments '1:subcommand:->subcmd' '*::args:->subargs' && ret=0
        case $state in
          subcmd) _describe -t commands 'sch subcommand' sch_cmds && ret=0 ;;
          subargs)
            case ${words[1]} in
              export)
                local -a sch_export_cmds=(
                  'bom:export BOM'
                  'dxf:export DXF'
                  'hpgl:export HPGL'
                  'netlist:export netlist'
                  'pdf:export PDF'
                  'ps:export PostScript'
                  'python-bom:export legacy XML-based BOM'
                  'svg:export SVG'
                )
                _arguments '1:format:->fmt' '*::args:' && ret=0
                [[ $state == fmt ]] && _describe -t commands 'export format' sch_export_cmds && ret=0
                ;;
              erc)
                _arguments \
                  '(-o --output)'{-o,--output}'[output report file]:file:_files' \
                  '--format=[report format]:format:(json report)' \
                  '--severity-all[report all violations]' \
                  '--severity-error[report only errors]' \
                  '--severity-warning[report warnings and errors]' \
                  '--exit-code-violations[return exit code on violations]' \
                  '1:schematic file:_files -g "*.kicad_sch"' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      fp)
        local -a fp_cmds=(
          'export:export footprints'
          'upgrade:upgrade footprint libraries'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'fp subcommand' fp_cmds && ret=0
        ;;
      sym)
        local -a sym_cmds=(
          'export:export symbols'
          'upgrade:upgrade symbol libraries'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'sym subcommand' sym_cmds && ret=0
        ;;
      jobset)
        local -a jobset_cmds=(
          'run:run a jobset'
        )
        _arguments '1:subcommand:->subcmd' '*::args:' && ret=0
        [[ $state == subcmd ]] && _describe -t commands 'jobset subcommand' jobset_cmds && ret=0
        ;;
    esac
    ;;
esac

return ret
