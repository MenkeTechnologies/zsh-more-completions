#compdef gnark-bench
# Documentation: https://github.com/Consensys/gnark-bench (cmd/{root,groth16,plonk}.go cobra)
# Reference accessed: 2026-05-29
# gnark-bench — benchmark and profile gnark zk-SNARK proving systems.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'groth16:benchmark/profile Groth16 proof system'
  'plonk:benchmark/profile PlonK proof system'
  'help:show help for a subcommand'
)

local -a _persistent
_persistent=(
  '--circuit=[circuit to benchmark (default expo)]:circuit:(expo cubic mimc sha256 ecdsa eddsa)'
  '--size=[circuit size parameter (default 10000)]:size:'
  '--count=[number of executions for averaging (default 2)]:n:'
  '--algo=[algorithm to benchmark (default prove)]:algo:(compile setup prove verify)'
  '--profile=[profiling type (default none)]:profile:(none trace cpu mem)'
  '--curve=[elliptic curve (default bn254)]:curve:(bn254 bls12-377 bls12-381 bls24-315 bls24-317 bw6-633 bw6-756 bw6-761)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  $_persistent \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'gnark-bench subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      groth16|plonk)
        _arguments $_persistent && ret=0
        ;;
    esac
    ;;
esac

return ret
