#compdef golines
# _golines-bin — Go long-line formatter (Benjamin Yolken, Go); reformat Go files to fit within line length
# upstream: https://github.com/segmentio/golines

_golines-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-l[list non-conforming files]' \
        '-m+[max line length]:n:' \
        '-t+[tab length]:n:' \
        '-w[write to files]' \
        '--base-formatter+[base formatter]:fmt:(gofmt goimports gofumpt)' \
        '--chain-split-dots[chain split dots]' \
        '--dry-run[dry run]' \
        '--ignore-generated[ignore generated]' \
        '--ignored-dirs+[ignore dirs]:dirs:_files -/' \
        '--no-chain-split-dots[no chain split dots]' \
        '--no-reformat-tags[no reformat struct tags]' \
        '--reformat-tags[reformat struct tags]' \
        '--shorten-comments[shorten comments]' \
        '*:file or dir:_files'
}

_golines-bin "$@"
