#compdef pbmclean
# Documentation: man pbmclean (Netpbm)
# Source: clean speckle noise from a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-minneighbors=[min same-color neighbours to keep pixel]:n:' \
    '(-black -white)-black[only clean black pixels]' \
    '(-black -white)-white[only clean white pixels]' \
    '-extended[use extended (8-neighbour) connectivity]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
