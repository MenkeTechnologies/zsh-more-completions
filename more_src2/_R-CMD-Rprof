#compdef R-CMD-Rprof
# _R-CMD-Rprof — R Core Team R CMD Rprof summarize Rprof output produced by Rprof function for R profiling (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Rprof() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--lines[show line profile]' \
        '--memory[show memory profile]' \
        '--no-lines[no line profile]' \
        '--no-memory[no memory profile]' \
        '--total=+[N]:n:' \
        '--self=+[N]:n:' \
        '--min-self=+[F]:f:' \
        '--min-total=+[F]:f:' \
        '--include-functions=+[regex]:str:' \
        '--exclude-functions=+[regex]:str:' \
        '*:Rprof file:_files -g "Rprof.out *.out *.prof Rprof*"'
}

_R-CMD-Rprof "$@"
