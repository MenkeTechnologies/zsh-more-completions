#compdef go-licenses
# Documentation: https://github.com/google/go-licenses
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'check:check licenses against allow/disallow lists'
  'csv:print licenses as CSV'
  'help:show help'
  'report:generate license report (HTML/markdown)'
  'save:save licenses for distribution'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*--alsologtostderr[also log to stderr]' \
  '*--confidence_threshold=[confidence threshold]:n:' \
  '*--ignore=[ignore packages csv]:list:' \
  '*--include_tests[include tests]' \
  '*--include_imports[include imports]' \
  '*--logtostderr[log to stderr]' \
  '*--log_dir=[log dir]:dir:_files -/' \
  '*--stderrthreshold=[stderr threshold]:l:' \
  '*-v[verbosity]' \
  '*--vmodule=[vmodule]:m:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'go-licenses command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (check)
        _arguments \
          '*--allowed_licenses=[allowed csv]:list:' \
          '*--disallowed_types=[disallowed types csv]:list:' \
          '*--allowed_types=[allowed types csv]:list:' \
          '*--git_remote=[git remote]:r:' \
          '*: :' && ret=0 ;;
      (csv|report)
        _arguments \
          '*--git_remote=[git remote]:r:' \
          '*--template=[template path]:file:_files' \
          '*: :' && ret=0 ;;
      (save)
        _arguments \
          '*--save_path=[save path]:dir:_files -/' \
          '*--force[overwrite]' \
          '*--ignore=[ignore packages csv]:list:' \
          '*: :' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
