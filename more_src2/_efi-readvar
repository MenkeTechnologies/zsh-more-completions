#compdef efi-readvar
# Documentation: https://manpages.debian.org/testing/efitools/efi-readvar.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v+[variable name]:var:(PK KEK db dbx MokList MokListX SbatLevel)' \
  '-s+[index of signature list to print]:n:' \
  '-o+[output to file]:file:_files' && ret=0

return ret
