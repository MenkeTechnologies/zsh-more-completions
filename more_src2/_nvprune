#compdef nvprune
# Documentation: https://docs.nvidia.com/cuda/cuda-binary-utilities/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvprune: prune unused architectures from a CUDA library/executable
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '-arch=[GPU architectures to retain]:arch:' \
  '--arch=[GPU architectures to retain]:arch:' \
  '-gencode=[multiple architectures (nvcc format)]:gencode:' \
  '--generate-code=[multiple architectures (nvcc format)]:gencode:' \
  '-no-relocatable-elf[exclude relocatable ELF from output]' \
  '--no-relocatable-elf[exclude relocatable ELF from output]' \
  '-o+[output file]:file:_files' \
  '--output-file=[output file]:file:_files' \
  '-optf=[read options from file]:file:_files' \
  '--options-file=[read options from file]:file:_files' \
  '*:input library/exec:_files -g "*.(a|so|so.*|elf|cubin)"' && ret=0
return ret
