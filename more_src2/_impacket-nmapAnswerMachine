#compdef impacket-nmapAnswerMachine
# Documentation: https://github.com/fortra/impacket/blob/impacket_0_11_0/examples/nmapAnswerMachine.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-nmapAnswerMachine: respond to nmap OS-detection probes by impersonating an OS fingerprint
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-f[OS fingerprint string to emulate]:fingerprint:' \
  '-p[IP address to bind to]:ip:' \
  '-m[MAC address to use]:mac:' \
  '-i[network interface]:iface:' \
  '-d[path to nmap-os-db file]:file:_files' && ret=0
return ret
