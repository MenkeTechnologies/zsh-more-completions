#compdef bdeinfo bdemount
# _libbde — libbde tools (libyal Microsoft BitLocker Drive Encryption parser; bdeinfo prints BitLocker header / key-slot metadata, bdemount FUSE-mounts the decrypted volume given a recovery password / external key / startup key; -h help, -V version, -v verbose, -p recovery password, -r recovery key, -k key file, -s startup key, -X exclusive; positional argument is the BitLocker image)
# upstream: https://github.com/libyal/libbde
# Flags from libyal/libbde bdetools/bdemount.c on tip.

_libbde() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-p+[recovery password]:password:' \
        '-r+[recovery key]:key:' \
        '-k+[key file]:file:_files' \
        '-s+[startup key]:file:_files' \
        '-X[exclusive]' \
        '*:image:_files'
}

_libbde "$@"
