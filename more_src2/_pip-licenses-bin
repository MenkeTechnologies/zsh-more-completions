#compdef pip-licenses
# _pip-licenses-bin — pip-licenses Python license inventory tool (Raimon Esteve, Python); list license info for installed Python packages
# upstream: https://github.com/raimon49/pip-licenses

_pip-licenses-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--python+[python interpreter]:file:_files' \
        '--from+[license source]:source:(meta classifier mixed all)' \
        '-f+[output format]:fmt:(plain plain-vertical markdown rst confluence html json json-license-finder csv)' \
        '--format+[output format]:fmt:' \
        '--order+[order by]:by:(name license author url)' \
        '-i+[ignore packages]:packages:' \
        '--ignore-packages+[ignore packages]:packages:' \
        '-p+[packages]:packages:' \
        '--packages+[packages]:packages:' \
        '-s[show summary]' \
        '--summary[show summary]' \
        '--with-system[include system packages]' \
        '--with-authors[include authors]' \
        '--with-urls[include URLs]' \
        '--with-description[include descriptions]' \
        '--with-license-file[include license file content]' \
        '--no-license-path[no license file path]' \
        '--with-notice-file[include notice file]' \
        '--filter-strings[filter strings]' \
        '--filter-code-page+[filter codepage]:codepage:' \
        '--fail-on+[fail on licenses]:str:' \
        '--allow-only+[allow only licenses]:str:' \
        '--output-file+[output file]:file:_files'
}

_pip-licenses-bin "$@"
