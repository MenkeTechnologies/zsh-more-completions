#compdef runc
# _runc — OCI low-level container runtime (reference impl of the runtime-spec)
# upstream: https://github.com/opencontainers/runc
# Global flags + subcommand list from main.go on tip (urfave/cli/v3).

_runc() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print runc version]' \
        '--debug[enable debug logging]' \
        '--log=[log file to write runc logs to]:file:_files' \
        '--log-format=[log format]:fmt:(text json)' \
        '--root=[root directory for storage of container state]:dir:_files -/' \
        '--systemd-cgroup[enable systemd cgroup support]' \
        '--rootless=[ignore cgroup permission errors]:mode:(true false auto)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                checkpoint:'checkpoint a running container (CRIU)'
                create:'create a container from a bundle'
                delete:'delete any resources held by the container'
                events:'stream container events / stats'
                exec:'execute a new process inside the container'
                kill:'send a signal to the container'
                list:'list containers started by runc with given root'
                pause:'pause processes in the container (freezer cgroup)'
                ps:'list processes inside the container'
                restore:'restore a container from a checkpoint'
                resume:'resume processes in the container'
                run:'create and run a container'
                spec:'create a new spec config.json'
                start:'start the user-defined process in a created container'
                state:'show container state'
                update:'update container resource constraints'
                features:'show kernel/runtime features available to runc'
            )
            _describe -t commands 'runc subcommand' subs
            ;;
    esac
}

_runc "$@"
