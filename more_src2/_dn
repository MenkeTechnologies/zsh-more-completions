# Source-direct completion: every positional argument below is verbatim from
# src/args.js on the DownloadNet tip — the positional argv parse block
# at top of file: `server_port = $PORT || argv[2] || 22120`, `mode = argv[3] ||
# 'save'`, `chrome_port = argv[4] || 9222`, `BasePath = argv[5] || Pref ||
# CONFIG_DIR`.  Browser-hook config from BROWSERS array in src/app.js
