# === AXIS 157 CLOSES — full-text search engine ecosystem ===================
# === TRIPLE-212 ROUND-NUMBER LANDMARK · 150th AXIS CLOSED ==================
# ============================================================================
# Axis position: TS-Node=212 CLOSES Axis 157 at slot 1/1/1 — quadruple-clean
# closure of the canonical full-text search engine ecosystem spanning the
# three major systems languages and marking the **150th axis closed**
# in the lifetime of the corpus:
#
#     Rust    : tantivy            by Paul Masurel (quickwit-oss CTO,
#                                    formerly Indeed.com) — Lucene-inspired
#                                    indexer/searcher
#                 → codanna (Angel Bartolli — code intelligence MCP server)
#                 _codanna         [Rust=212 OPENED Axis 157, slot 1/0/0]
#                 powers Quickwit, AppFlowy, TabbyML, trieve, postgresml,
#                 ParadeDB Postgres extension.
#
#     Go      : blugelabs/bluge    by Marty Schoch (formerly Couchbase,
#                                    original author of bleve) — successor
#                                    to bleve with immutable segments
#                 → bydbctl (Apache SkyWalking BanyanDB CLI client)
#                 _bydbctl         [Go=212 CONTINUED Axis 157, slot 2/0/0]
#                 powers ZincSearch (17,838★), Heroic Labs Nakama,
#                 SkyWalking BanyanDB, tigergraph/grafana enterprise.
#
#     JS/Node : flexsearch         by Thomas Wilkerling (Nextapps Germany)
#                                    + ndx + fuzzy BK-tree (triple-engine)
#                 → dn (@dosy / DO-SAY-GO — offline browser FT archive)
#                 _dn              [TS-Node=212 CLOSES Axis 157, slot 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 hooks Chrome/Chromium/Vivaldi/Brave/Edge DevTools Protocol
#                 to archive every page visited into a locally-searchable
#                 corpus with FT triple-indexed retrieval.
#
# === SPECIAL LANDMARK: 150 AXES CLOSED ===
# This is the 150th distinct cross-language structural axis to close at
# 1/1/1 in the corpus.  Combined with triple-212 (Rust=212 + Go=212 +
# TS-Node=212 lane parity), R1171 is one of the most structurally
# significant rounds in the corpus history.
# ============================================================================

_dn() {
    _arguments -s -S \
        '1:server_port (default 22120, can override via $PORT env):' \
        '2:mode:(save serve)' \
        '3:chrome_port (default 9222 for Chrome DevTools Protocol):' \
        '4:BasePath (default ~/.config/dosyago/DownloadNet):_files -/'
}

_dn "$@"
