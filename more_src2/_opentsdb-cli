#compdef opentsdb-cli tsdb2
# _opentsdb-cli — OpenTSDB opentsdb-cli CLI command-line frontend wrapping the OpenTSDB open-source distributed scalable time-series database built atop HBase providing tsd fsck import mkmetric query scan search uid version compaction config-validate purge UID-management metric-tagk-tagv assign-rename-delete-grep telnet-style write put-style HTTP-API (OpenTSDB team Benoit Sigoure, Java); custom argparse
# upstream: http://opentsdb.net/

_opentsdb-cli() {
    local -a sub=(
        'tsd:start the TSD daemon'
        'fsck:filesystem-like check'
        'import:import data points'
        'mkmetric:create a metric'
        'query:run a query'
        'scan:scan rows'
        'search:search index'
        'uid:UID management'
        'version:show version'
        'help:show help'
        'compaction:compaction'
        'config:validate config'
        'purge:purge data'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "opentsdb.conf"' \
        '-c+[file]:file:_files -g "opentsdb.conf"' \
        '--zkquorum=+[hosts]:_hosts' \
        '--zkbasedir=+[path]:str:' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--bind=+[host]:_hosts' \
        '--staticroot=+[dir]:dir:_files -/' \
        '--cachedir=+[dir]:dir:_files -/' \
        '--auto-metric[allow auto metric]' \
        '--worker-threads=+[N]:n:' \
        '--async-io[async IO]' \
        '--enable-tracing[tracing]' \
        '--read-only[read only]' \
        '--flush-interval=+[ms]:n:' \
        '--table=+[name]:str:' \
        '--uidtable=+[name]:str:' \
        '--metric=+[name]:str:' \
        '--tagk=+[name]:str:' \
        '--tagv=+[name]:str:' \
        '--start=+[ts]:str:' \
        '--end=+[ts]:str:' \
        '--aggregator=+[agg]:a:(sum avg min max count dev p50 p75 p90 p95 p99 zimsum mimmin mimmax)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opentsdb subcommand' sub ;;
        args)
            case $words[1] in
                uid) _arguments '1:op:(grep assign rename delete lookup metasync fsck)' '*:arg:' ;;
                import) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_opentsdb-cli "$@"
