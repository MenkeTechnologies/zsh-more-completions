#compdef rootmkdir
# Documentation: https://github.com/root-project/root/blob/master/main/src/rootmkdir.cxx
# Reference accessed: 2026-05-27
# Verified: upstream RCmdLineOpts AddFlag calls in main/src/rootmkdir.cxx

# rootmkdir: create directories inside ROOT files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --parents)'{-p,--parents}'[create parent directories as needed; no error if existing]' \
  '*'{-v,--verbose}'[verbose output (repeatable)]' \
  '*:file:_files -g "*.root"' && ret=0

return ret
