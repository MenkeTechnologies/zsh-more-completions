#compdef pnmstitch
# Documentation: man pnmstitch (Netpbm)
# Source: stitch two overlapping Netpbm images into one panorama.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[output width]:width:' \
    '-height=[output height]:height:' \
    '-xrightpos=[right image x position]:column:' \
    '-yrightpos=[right image y position]:row:' \
    '-stitcher=[stitching algorithm]:algo:(RotateSliver BiLinearSliver LinearSliver)' \
    '-filter=[stitching filter]:filter:(LineAtATime HorizontalCrop)' \
    '-output=[output file]:file:_files' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pnm files (left right output):_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
