#compdef kuzco
# Documentation: https://github.com/RoseSecurity/Kuzco
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kuzco (RoseSecurity/Kuzco). Cobra-based Terraform/OpenTofu analyzer.
# Subcommands: completion, fix, help, list, recommend, version.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'completion:generate shell autocompletion script'
  'fix:diagnose configuration errors'
  'help:help about any command'
  'list:list available Ollama models'
  'recommend:analyze Terraform/OpenTofu config and recommend improvements'
  'version:print CLI version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args' && ret=0

case $state in
  (cmds)
    _describe -t commands 'kuzco command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (recommend|fix)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --file)'{-f+,--file=}'[path to Terraform/OpenTofu file]:file:_files' \
          '(-t --tool)'{-t+,--tool=}'[configuration tool]:tool:(terraform opentofu)' \
          '(-m --model)'{-m+,--model=}'[LLM model]:model:' \
          '(-p --prompt)'{-p+,--prompt=}'[custom user prompt]:prompt:' \
          '(-a --address)'{-a+,--address=}'[LLM model address]:url:' \
          '--init-backend[run terraform/tofu init backend]' && ret=0
        ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
