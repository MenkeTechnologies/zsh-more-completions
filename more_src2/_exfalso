#compdef exfalso ex_falso
# _exfalso — Quod Libet exfalso GTK audio tag editor companion to Quod Libet for bulk metadata renaming patterns and ReplayGain (quodlibet team, Python/GTK); argparse
# upstream: https://github.com/quodlibet/quodlibet

_exfalso() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--print-config[print config]' \
        '--no-plugins[no plugins]' \
        '--list-plugins[list plugins]' \
        '--enable-plugin=+[plugin]:str:' \
        '--disable-plugin=+[plugin]:str:' \
        '--debug[debug]' \
        '--print-playing[print playing]' \
        '--print-query=+[query]:str:' \
        '--print-query-text=+[query]:str:' \
        '--quit[quit]' \
        '--start-hidden[start hidden]' \
        '--show-window[show window]' \
        '--hide-window[hide window]' \
        '--toggle-window[toggle window]' \
        '--with-pattern=+[pattern]:str:' \
        '--list-patterns[list patterns]' \
        '*:audio file or directory:_files -g "*.mp3 *.flac *.ogg *.oga *.opus *.m4a *.mp4 *.aac *.wav *.aiff *.ape *.wv *.wma *.tta *.mpc *.dsf *.dff *.spx *.tak *.shn"'
}

_exfalso "$@"
