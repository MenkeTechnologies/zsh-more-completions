#compdef extism-dev
# _extism-dev — Extism developer workflow CLI for managing dev repos (extism/cli)
# upstream: https://github.com/extism/cli
# Subcommands from extism-dev/dev.go (cobra).

_extism-dev() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--root=[root directory of extism development repos]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                init:'initialize dev repos'
                exec:'run a command in each dev repo'
                call:'call a plugin function'
                find:'find a repo by pattern'
                add:'add a new repo by URL'
                remove:'remove a repo by URL'
                path:'print the dev root path'
                clean:'clean dev repos'
                list:'list dev repos'
                update:'pull updates for all dev repos'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                init)
                    _arguments \
                        '(-p --parallel)'{-p+,--parallel=}'[number of repos to download in parallel]:n:' \
                        '--local[do not set as global extism-dev path]' \
                        '(-c --category)'{-c+,--category=}'[category]:cat:(sdk pdk plugin runtime other)' \
                        '1:dev_root:_files -/' ;;
                call) _arguments '1:plugin:' '2:function:' '*::args:' ;;
                find) _arguments '1:pattern:' ;;
                add|remove) _arguments '1:url:_urls' ;;
            esac
            ;;
    esac
}

_extism-dev "$@"
