#compdef kubelogin
# Documentation: https://github.com/int128/kubelogin/blob/master/docs/usage.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'get-token:run as a kubectl credential plugin'
  'setup:verify provider configuration and dump ID token claims'
  'clean:remove cached tokens'
  'version:print version information'
  'help:help about any command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      get-token)
        _arguments \
          '--oidc-issuer-url=[OIDC issuer URL]:URL' \
          '--oidc-client-id=[OIDC client ID]:client ID' \
          '--oidc-client-secret=[OIDC client secret]:secret' \
          '--oidc-extra-scope=[extra scopes]:scopes' \
          '--certificate-authority=[path to CA certificate]:cert file:_files' \
          '--certificate-authority-data=[base64 encoded CA certificate]:data' \
          '--insecure-skip-tls-verify[skip TLS verification]' \
          '--token-cache-dir=[directory for token cache]:directory:_files -/' \
          '--token-cache-storage=[token cache storage backend]:storage:(disk keyring)' \
          '--force-refresh[force token refresh]' \
          '--grant-type=[authorization grant type]:type:(auto authcode authcode-keyboard password device-code client-credentials)' \
          '--listen-address=[address for redirect URI server]:address' \
          '--listen-port=[deprecated alias for --listen-address]:port' \
          '--skip-open-browser[skip opening browser]' \
          '--authentication-timeout-sec=[authentication timeout in seconds]:seconds' \
          '--local-server-cert=[path to certificate for local server]:file:_files' \
          '--local-server-key=[path to certificate key for local server]:file:_files' \
          '--username=[username for password grant]:username' \
          '--password=[password for password grant]:password' && ret=0
        ;;
      setup)
        _arguments \
          '--oidc-issuer-url=[OIDC issuer URL]:URL' \
          '--oidc-client-id=[OIDC client ID]:client ID' \
          '--oidc-client-secret=[OIDC client secret]:secret' \
          '--oidc-extra-scope=[extra scopes]:scopes' \
          '--certificate-authority=[path to CA certificate]:cert file:_files' \
          '--grant-type=[authorization grant type]:type:(auto authcode authcode-keyboard password device-code client-credentials)' \
          '--listen-address=[address for redirect URI server]:address' && ret=0
        ;;
      clean)
        _arguments \
          '--token-cache-dir=[directory for token cache]:directory:_files -/' \
          '--token-cache-storage=[token cache storage backend]:storage:(disk keyring)' && ret=0
        ;;
    esac
    ;;
esac

return ret
