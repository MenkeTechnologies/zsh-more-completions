#compdef metar_dump
# Documentation: https://confluence.ecmwf.int/display/ECC/metar_dump
# Source: ecmwf/eccodes tools/metar_dump.cc — dump METAR messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-O[octet mode (WMO documentation style)]' \
    '-D[debug mode]' \
    '-d[print all data values]' \
    '-t[print type information]' \
    '-j[JSON mode]' \
    '-H[print octet content in hex]' \
    '-a[dump aliases]' \
    '-w+[where clause filter]:filter:_default' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '(- *)-V[show version]' \
    '-x[fast parsing (headers only)]' \
    '*:metar file:_files' \
    && ret=0

return ret
