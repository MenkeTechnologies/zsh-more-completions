_filecoin-pin() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '--no-update-check[skip check for npm registry updates]' \
        '1: :_filecoin_pin_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                server)
                    _arguments \
                        '(-p --port)'{-p,--port}'=[server port (default 3000)]:port:' \
                        '--host=[server host (default 127.0.0.1)]:host:' \
                        '--car-storage=[path for CAR file storage (default ./cars)]:path:_files -/' \
                        '--database=[path to SQLite database (default ./pins.db)]:path:_files' \
                        '--private-key=[private key for Synapse (env PRIVATE_KEY)]:key:' \
                        '--wallet-address=[wallet address for session key auth (env WALLET_ADDRESS)]:address:' \
                        '--session-key=[session key for session key auth (env SESSION_KEY)]:key:' \
                        '--access-token=[bearer token required on API requests (env ACCESS_TOKEN)]:token:' && ret=0 ;;
                payments)
                    _arguments \
                        '1:payments subcommand:(setup fund withdraw status deposit)' \
                        '*::arg:->payment_args'
                    case $state in
                        payment_args)
                            case $words[1] in
                                setup)
                                    _arguments '--auto[run in automatic mode with defaults]' && ret=0 ;;
                                fund)
                                    _arguments \
                                        '--days=[set final runway to N days]:days:' \
                                        '--amount=[set final deposited total to N USDFC]:usdfc:' && ret=0 ;;
                                status)
                                    _arguments '--include-rails[show payment rail details]' && ret=0 ;;
                                deposit)
                                    _arguments \
                                        '--amount=[USDFC amount to deposit (e.g. 10.5)]:usdfc:' \
                                        '--days=[fund enough to keep current spend alive for N days]:days:' && ret=0 ;;
                                withdraw)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac ;;
                data-set|dataset)
                    _arguments \
                        '1:data-set subcommand:(show list ls terminate)' \
                        '*::arg:->ds_args'
                    case $state in
                        ds_args)
                            case $words[1] in
                                show)
                                    _arguments '1:data set id:' && ret=0 ;;
                                list|ls)
                                    _arguments \
                                        '--all[show all data sets, not just those created with filecoin-pin]' \
                                        '--provider-id=[filter data sets by provider ID]:id:' && ret=0 ;;
                                terminate)
                                    _arguments \
                                        '1:data set id:' \
                                        '--wait[wait for the termination transaction to be confirmed]' && ret=0 ;;
                            esac ;;
                    esac ;;
                import)
                    _arguments \
                        '--copies=[number of storage copies to create (default 2)]:n:' \
                        '1:CAR file:_files -g "*.car"' && ret=0 ;;
                add)
                    _arguments \
                        '--copies=[number of storage copies to create (default 2)]:n:' \
                        '1:path to add (file or directory):_files' && ret=0 ;;
                rm)
                    _arguments \
                        '--wait-for-confirmation[wait for transaction confirmation before exiting]' \
                        '--force[skip confirmation prompt when using --all]' \
                        '*:piece CID:' && ret=0 ;;
                provider)
                    _arguments \
                        '1:provider subcommand:(list ls show ping)' \
                        '*::arg:->prov_args'
                    case $state in
                        prov_args)
                            case $words[1] in
                                list|ls)
                                    _arguments \
                                        '--all[list all active providers (ignoring approval status)]' \
                                        '--endorsed[list only endorsed providers]' && ret=0 ;;
                                show)
                                    _arguments '1:provider id:' && ret=0 ;;
                                ping)
                                    _arguments \
                                        '--all[ping all active providers (ignoring approval status)]' \
                                        '::provider id:' && ret=0 ;;
                            esac ;;
                    esac ;;
                session)
                    _arguments \
                        '1:session subcommand:(create authorize generate)' \
                        '*::arg:->sess_args'
                    case $state in
                        sess_args)
                            case $words[1] in
                                create)
                                    _arguments \
                                        '--validity-days=[number of days the session key should be valid (max 365, default 10)]:days:' \
                                        '--session-key=[reuse an existing session private key (env SESSION_KEY)]:key:' && ret=0 ;;
                                authorize)
                                    _arguments \
                                        '1:session address:' \
                                        '--validity-days=[number of days the authorization is valid (max 365, default 10)]:days:' && ret=0 ;;
                                generate)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_filecoin_pin_commands] )) ||
_filecoin_pin_commands() {
    local -a commands
    commands=(
        'server:start the IPFS Pinning Service API server'
        'payments:manage payment setup for Filecoin Onchain Cloud'
        'data-set:inspect data sets managed through Filecoin Onchain Cloud'
        'dataset:alias for data-set'
        'import:import an existing CAR file to Filecoin via Synapse'
        'add:add a file or directory to Filecoin (creates UnixFS CAR)'
        'rm:remove piece(s) from a DataSet'
        'provider:inspect and interact with storage providers'
        'session:session-key lifecycle (create/authorize/generate)'
    )
    _describe -t commands 'filecoin-pin command' commands
}

_filecoin-pin "$@"
