#compdef dargo
# ============================================================================
# _dargo — zsh completion for the duck-lang programming language driver
#           (`dargo` — duck-compiler/duckc) — "a modern, compiled and
#           batteries-included programming language for full-stack
#           development" (173rd programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/duck-compiler/duckc
#   Maintainer : @Mvmo and duck-compiler contributors
#   License    : MIT
#   Stars      : 147
#   Language   : Rust (compiler) emitting Go via tree-sitter-go
#                (with TypeScript / JavaScript / HTML interop
#                 through tree-sitter-typescript / -javascript /
#                 -html)
#   Crate      : dargo  (Cargo.toml [package] name = "dargo";
#                         the duck-compiler driver is named
#                         after duck + cargo)
#   Binary     : dargo
#   Source ext : .duck
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   duck-lang is "a modern, compiled and batteries-included
#   programming language for full-stack" development.  The
#   compiler is hand-written in Rust using chumsky as the
#   parser-combinator library and ariadne for error reporting;
#   the back-end emits Go source, runs `go build`, and produces
#   a single binary.  The `dargo` driver (named after duck +
#   cargo) wraps the entire workflow with a Cargo-style command
#   surface — `new` / `init` to scaffold a project (with an
#   optional `--web` template that pulls in the duckwind
#   Tailwind-style style engine and tree-sitter-html JSX
#   interop), `build` / `compile` / `run` / `test` to drive the
#   compile-and-execute pipeline (with `--optimize-go` enabling
#   Go-side optimizations and `--timing` reporting per-stage
#   timings), `docs` to generate documentation, and `clean` to
#   tear down the `.dargo` cache directory.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/dargo/cli.rs
#                       `DargoCliParser` + `Commands` enum +
#                       per-subcommand `*Args` structs — clap 4
#                       with derive feature)
#   dargo [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options:
#     -v, --verbose                  Verbose output
#                                    (global to every command)
#
#   Subcommands:
#     build                          Compile the current project
#                                    (uses .dargo/project + the
#                                     local duck.toml manifest)
#       -b, --bin <NAME>               Build a specific binary
#                                      target
#       -o, --output-name <NAME>       Output binary name
#       -G, --optimize-go              Enable Go-side
#                                      optimizations
#       --timing                       Report per-stage timings
#
#     compile <FILE>                 Compile a single .duck file
#                                    (lower-level than `build`)
#       -o, --output-name <NAME>       Output binary name
#       -G, --optimize-go              Enable Go-side
#                                      optimizations
#       --timing                       Report per-stage timings
#
#     init [<PROJECT_NAME>]          Initialize a duck-lang
#                                    project in the current
#                                    directory
#
#     new [<PROJECT_NAME>]           Create a new duck-lang
#                                    project directory
#       --web                          Generate a web project
#                                      template (duckwind +
#                                      tree-sitter-html JSX)
#
#     clean                          Remove the .dargo cache
#                                    directory
#
#     run [<FILE>]                   Build + run the current
#                                    project (or single file)
#       -b, --bin <NAME>               Run a specific binary
#                                      target
#       -G, --optimize-go              Enable Go-side
#                                      optimizations
#       --timing                       Report per-stage timings
#
#     test [<FILE>]                  Run tests for the current
#                                    project (or single file)
#       -b, --bin <NAME>               Test a specific binary
#                                      target
#       -G, --optimize-go              Enable Go-side
#                                      optimizations
#
#     docs <FILE>                    Generate documentation from
#                                    doc comments
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# LANGUAGE-CORPUS POSITION
#   duck-lang (binary `dargo`) is the 173rd programming language
#   entry in this completion corpus, completing the 3+1 micro-
#   cycle that began at R961 (_uxc / Holon Run Rust=148 OPENS
#   Axis 93 OpenAPI / openapiv3 schema library) and continued
#   through R962 (_hrp / httprunner Go=148) and R963 (_portman
#   / Apideck TS-Node=148 CLOSES Axis 93 at 1/1/1 three-language
#   symmetry — triple-148 landmark and 86th axis closed).
#   duck-lang joins Rascal (R960 172nd — R960 round-number
#   commit landmark), Ixion (R956 171st), KernelScript (R952
#   170th — round-number 170th-language milestone), Prog8
#   (R948 169th), Objeck (R944 168th), Feral (R940 167th —
#   R940 round-number commit landmark), Biscuit/BL (R936
#   166th), Rux (R932 165th), Jule (R928 164th), Nevalang
#   (R924 163rd), Corvid (R920 162nd — round-number R920
#   commit landmark), Soppo (R916 161st), Cyrus (R912 160th —
#   round-number language milestone), Lumina (R908 159th),
#   Penne (R904 158th), EndBASIC (R900 157th — R900 TRIPLE-9
#   commit landmark), goboscript (R896 156th), Alan (R892
#   155th), Mech (R888 154th — triple-8 landmark), Lisette
#   (R884 153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG
#   (R872 150th — round-number language milestone), Roto
#   (R868 149th), Pipefish (R864 148th), Mochi (R860 147th),
#   Oden (R856 146th), Hop (R852 145th), Lustre via Kind 2
#   (R848 144th), Ravi (R844 143rd), ZetZ (R840 142nd),
#   Granule (R836 141st), Sixten (R832 140th), Imba (R828
#   139th), Tao (R824 138th), Dada (R820 137th), Acton
#   (R816 136th), and Stanza (R812 135th).
#
#   No completion for `dargo` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_dargo() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '1: :_dargo_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build)
                    _arguments \
                        '(-b --bin)'{-b,--bin}'=[build a specific binary target]:bin:' \
                        '(-o --output-name)'{-o,--output-name}'=[output binary name]:name:' \
                        '(-G --optimize-go)'{-G,--optimize-go}'[enable Go-side optimizations]' \
                        '--timing[report per-stage timings]' && ret=0 ;;
                compile)
                    _arguments \
                        '(-o --output-name)'{-o,--output-name}'=[output binary name]:name:' \
                        '(-G --optimize-go)'{-G,--optimize-go}'[enable Go-side optimizations]' \
                        '--timing[report per-stage timings]' \
                        ':Duck source file:_files -g "*.duck"' && ret=0 ;;
                init|new)
                    _arguments \
                        '--web[generate a web project (new only)]' \
                        '::project name:' && ret=0 ;;
                clean)
                    _arguments && ret=0 ;;
                run|test)
                    _arguments \
                        '(-b --bin)'{-b,--bin}'=[run/test a specific binary target]:bin:' \
                        '(-G --optimize-go)'{-G,--optimize-go}'[enable Go-side optimizations]' \
                        '--timing[report per-stage timings (run only)]' \
                        '::Duck source file:_files -g "*.duck"' && ret=0 ;;
                docs)
                    _arguments \
                        ':Duck source file:_files -g "*.duck"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_dargo_commands] )) ||
_dargo_commands() {
    local -a commands
    commands=(
        'build:compile the current duck-lang project'
        'compile:compile a single .duck file'
        'init:initialize a duck-lang project in the current directory'
        'new:create a new duck-lang project directory'
        'clean:remove the .dargo cache directory'
        'run:build + run the current project'
        'test:run tests for the current project'
        'docs:generate documentation from doc comments'
    )
    _describe -t commands 'dargo command' commands
}

_dargo "$@"
