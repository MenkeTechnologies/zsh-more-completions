#compdef ipxe
# _ipxe — iPXE open-source network boot firmware; supports HTTP/iSCSI/AoE/FCoE chain-load + scripting
# upstream: https://github.com/ipxe/ipxe

_ipxe() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-s+[script file]:script:_files -g "*.ipxe"' \
        '-c+[config file]:config:_files' \
        '-n+[network interface]:iface:_net_interfaces' \
        '-b+[boot file URL]:url:' \
        '*:script:_files'
}

_ipxe "$@"
