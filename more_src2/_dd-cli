#compdef dd-cli
# _dd-cli — GNU coreutils dd convert and copy a file CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_dd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        'bs=+[block size]:str:' \
        'cbs=+[conversion block size]:str:' \
        'conv=+[conversions csv]:str:' \
        'count=+[blocks]:n:' \
        'ibs=+[input block size]:str:' \
        'if=+[input file]:file:_files' \
        'iflag=+[flags csv]:str:' \
        'obs=+[output block size]:str:' \
        'of=+[output file]:file:_files' \
        'oflag=+[flags csv]:str:' \
        'seek=+[skip output blocks]:n:' \
        'skip=+[skip input blocks]:n:' \
        'status=+[mode]:m:(none noxfer progress)' \
        '*:arg:'
}

_dd-cli "$@"
