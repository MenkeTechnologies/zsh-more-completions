#compdef gnocchi
# _gnocchi — OpenStack Gnocchi CLI (time-series database CLI built on cliff; subcommands: metric (list|show|create|delete|measures), resource (list|show|create|update|delete|history), resource-type (list|show|create|update|delete), archive-policy (list|show|create|update|delete), archive-policy-rule (list|show|create|delete), benchmark, capabilities (list), status, version; --os-auth-type, --os-username, --os-password, --os-project, --os-region-name, --endpoint, --insecure, --debug)
# upstream: https://github.com/gnocchixyz/python-gnocchiclient
# Subcommands from python-gnocchiclient on tip.

_gnocchi() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--version[show version]' \
        '--os-auth-type+[auth type]:auth:(keystone basic noauth)' \
        '--os-username+[user]:user:_users' \
        '--os-password+[password]:password:' \
        '--os-project-name+[project]:project:' \
        '--os-region-name+[region]:region:' \
        '--endpoint+[gnocchi endpoint]:url:' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:format:(json yaml csv table value shell html)' \
        '--format+[format]:format:(json yaml csv table value shell html)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gnocchi command' '(metric resource resource-type archive-policy archive-policy-rule capabilities status version benchmark help)' ;;
        args)
            case $line[1] in
                metric) _describe -t commands 'metric action' '(list show create delete measures aggregates)' ;;
                resource) _describe -t commands 'resource action' '(list show create update delete history)' ;;
                resource-type) _describe -t commands 'resource-type action' '(list show create update delete)' ;;
                archive-policy) _describe -t commands 'archive-policy action' '(list show create update delete)' ;;
                archive-policy-rule) _describe -t commands 'archive-policy-rule action' '(list show create delete)' ;;
            esac
            ;;
    esac
}

_gnocchi "$@"
