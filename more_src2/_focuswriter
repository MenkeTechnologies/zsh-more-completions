#compdef focuswriter
# Documentation: https://manpages.debian.org/testing/focuswriter/focuswriter.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# FocusWriter: hide-the-world fullscreen writing app
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '*:documents:_files -g "*.(odt|docx|rtf|txt|md|fountain)"' && ret=0
return ret
