#compdef kitty
# _kitty-bin — kitty fast GPU-based terminal (Kovid Goyal, Python+Go); cross-platform terminal with images, scrollback, kittens
# upstream: https://github.com/kovidgoyal/kitty

_kitty-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files -g "*.conf"' \
        '(-o --override)'{-o,--override}'+[KEY=value]:str:' \
        '-d+[working dir]:dir:_files -/' \
        '--directory+[working dir]:dir:_files -/' \
        '--detach[detach from terminal]' \
        '--session+[session file]:file:_files' \
        '--hold[hold after exit]' \
        '--single-instance[single instance]' \
        '--instance-group+[instance group]:str:' \
        '--listen-on+[control socket]:addr:' \
        '--start-as+[start state]:state:(normal fullscreen maximized minimized)' \
        '--class+[wm class]:str:' \
        '--name+[wm name]:str:' \
        '--title+[window title]:str:' \
        '--debug-gl[debug GL]' \
        '--debug-keyboard[debug keyboard]' \
        '--debug-rendering[debug rendering]' \
        '--debug-input[debug input]' \
        '--watcher+[watcher]:file:_files' \
        '--replay-commands+[replay command file]:file:_files' \
        '*::command:_command_names -e'
}

_kitty-bin "$@"
