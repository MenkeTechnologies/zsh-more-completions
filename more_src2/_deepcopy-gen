#compdef deepcopy-gen
# _deepcopy-gen — Kubernetes DeepCopy method generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/deepcopy-gen/args/args.go on tip.

_deepcopy-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-file=[generated deepcopy file basename]:file:_files' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '*--lint-rules=[gengo lint rules to enable (comma-sep)]:rules:' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_deepcopy-gen "$@"
