#compdef passport-cli
# _passport-cli — Andy Wendt Laravel Passport OAuth2 server CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/passport

_passport-cli() {
    local -a sub=(
        'passport:install:install passport'
        'passport:keys:generate encryption keys'
        'passport:client:create oauth client'
        'passport:purge:purge revoked tokens'
        'passport:hash:hash existing client secrets'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'passport subcommand' sub ;;
        args)
            case $words[1] in
                passport:install) _arguments \
                    '--uuids[use uuids for client ids]' \
                    '--force[force regenerate keys]' \
                    '--length=+[key length]:n:' \
                    '--provider=+[provider]:str:' ;;
                passport:keys) _arguments \
                    '--force[force regenerate]' \
                    '--length=+[length]:n:' ;;
                passport:client) _arguments \
                    '--personal[personal access client]' \
                    '--password[password grant client]' \
                    '--client[client credentials]' \
                    '--name=+[name]:str:' \
                    '--provider=+[provider]:str:' \
                    '--redirect_uri=+[redirect uri]:url:_urls' \
                    '--user_id=+[user id]:n:' \
                    '--public[public client (PKCE)]' ;;
                passport:purge) _arguments \
                    '--revoked[purge revoked]' \
                    '--expired[purge expired]' \
                    '--hours=+[hours]:n:' ;;
            esac
            ;;
    esac
}

_passport-cli "$@"
