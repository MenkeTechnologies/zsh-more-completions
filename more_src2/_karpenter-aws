#compdef karpenter-aws
# _karpenter-aws — Karpenter for AWS node provisioner
# upstream: https://github.com/aws/karpenter-provider-aws
# AWS-specific flags from pkg/operator/options/options.go on tip; core Karpenter flags inherit from sigs.k8s.io/karpenter.

_karpenter-aws() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cluster-ca-bundle=[cluster CA bundle for new node TLS]:bundle:' \
        '--cluster-name=[Kubernetes cluster name for resource discovery]:name:' \
        '--cluster-endpoint=[external cluster endpoint (else discovered via DescribeCluster)]:url:_urls' \
        '--isolated-vpc=[assume no internet egress (disables on-demand pricing API)]:bool:(true false)' \
        '--eks-control-plane=[discover cluster details via DescribeCluster API]:bool:(true false)' \
        '--vm-memory-overhead-percent=[VM memory overhead %% to subtract]:f:' \
        '--interruption-queue=[SQS queue name for EC2 interruption events]:name:' \
        '--reserved-enis=[ENIs to reserve (VPC CNI custom networking)]:n:' \
        '--disable-dry-run=[disable EC2NodeClass dry-run validation]:bool:(true false)' \
        '--enable-zonal-shift=[enable zonal shifting feature]:bool:(true false)' \
        '--ami-refresh-interval=[AMI discovery refresh interval]:dur:' \
        '--subnet-refresh-interval=[subnet discovery refresh interval]:dur:' \
        '--metrics-port=[metrics endpoint port]:port:' \
        '--health-probe-port=[health probe endpoint port]:port:' \
        '--leader-election-name=[leader-election lease name]:name:' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--kube-client-qps=[K8s API QPS]:n:' \
        '--kube-client-burst=[K8s API burst]:n:' \
        '--log-level=[log level]:level:(debug info error)' \
        '--feature-gates=[feature gates]:gates:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_karpenter-aws "$@"
