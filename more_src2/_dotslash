#compdef dotslash
# Documentation: https://github.com/facebook/dotslash
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dotslash (facebook/dotslash) - portable executable scripts.
# Subcommands are invoked via `dotslash -- <subcommand>`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1: :->target' \
  '*:: :->args' && ret=0

case $state in
  (target)
    # The primary argument is a dotslash file to execute; `--` switches to
    # built-in subcommands.
    local -a subcommands=(
      'b3sum:compute BLAKE3 hash of a file'
      'cache-dir:print the dotslash cache directory path'
      'clean:clean the dotslash cache directory'
      'create-url-entry:generate an HTTP provider entry from a URL'
      'fetch:prepare for execution and print the executable path'
      'get-extracted-cache-path:print the path to the extracted artifact in cache'
      'parse:parse a dotslash file and output as JSON'
      'sha256:compute SHA-256 hash of a file'
      'version:display the dotslash version'
      'help:print help information'
    )
    _alternative \
      'files:dotslash file:_files' \
      "subcommands:dotslash subcommand (use --):(($subcommands))" && ret=0
    ;;
  (args)
    case ${words[1]} in
      (--)
        _arguments '1:subcommand:(b3sum cache-dir clean create-url-entry fetch get-extracted-cache-path parse sha256 version help)' && ret=0
        ;;
      (*)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
