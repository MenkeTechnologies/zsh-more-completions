#
# THE flowgger CLI
#
# flowgger is a minimal single-positional-argument
# CLI built on clap v4.  Invocation:
#   flowgger [config_file]
#
# Positional arguments:
#   [config_file]                     path to TOML
#                                     configuration
#                                     file (default
#                                     "flowgger.toml"
#                                     in cwd)
#
# Flags:
#   -V, --version                     show version
#   -h, --help                        show clap help
#
# All behavior — input source, decoder format,
# encoder format, output destination, TLS
# certificates, Redis URI, Kafka brokers, NATS
# subjects, file paths — is configured via the
# TOML file, NOT via command-line flags.  Run
# `flowgger /path/to/flowgger.toml` and inspect
# the wiki for the schema.
#
# Common invocations:
#   # Run with default flowgger.toml in cwd
#   flowgger
#
#   # Specify a config file path
#   flowgger /etc/flowgger/flowgger.toml
#
#   # Run with a project-specific config
#   flowgger ./conf/production.toml
#
#   # Print version
#   flowgger --version
#
#   # systemd service launcher
#   ExecStart=/usr/bin/flowgger /etc/flowgger/flowgger.toml
#
#   # Docker container
#   CMD ["flowgger", "/config/flowgger.toml"]
#
#   # Verify configuration syntax (dry-run via test
#   # config; flowgger validates on startup)
#   flowgger ./test/flowgger.toml
#
# Sample flowgger.toml structure (consult the wiki
# for full schema):
#   [input]
#   type = "redis"
#   redis_url = "redis://127.0.0.1:6379"
#   redis_queue_key = "log:queue"
#   format = "gelf"
#
#   [output]
#   type = "kafka"
#   kafka_brokers = "broker1:9092,broker2:9092"
#   kafka_topic = "logs"
#   kafka_compression = "snappy"
#   format = "ltsv"
#
#   [tls]
#   ca_file = "/etc/ssl/certs/ca-bundle.crt"
#   cert_file = "/etc/ssl/certs/server.crt"
#   key_file = "/etc/ssl/private/server.key"
#
# OPTIONS (sourced directly from
# https://github.com/awslabs/flowgger/blob/master/src/main.rs):
#
#   [config_file]                     TOML config file
#                                     (default
#                                     "flowgger.toml")
#   -V, --version                     show version
#   -h, --help                        show help
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1:flowgger TOML config file:_files -g "*.(toml|TOML)"' \
    && ret=0

return ret
