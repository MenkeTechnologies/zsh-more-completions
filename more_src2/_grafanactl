#compdef grafanactl
# Documentation: https://grafana.github.io/grafanactl/reference/cli/grafanactl/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# grafanactl: command-line tool for interacting with Grafana resources (cobra)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'config:view or manipulate configuration settings'
  'resources:manipulate Grafana resources'
  'completion:generate shell completion scripts'
  'help:print help for any command'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--no-color[disable color output]' \
  '*'{-v,--verbose}'[increase verbosity (up to 3)]' \
  '--version[show version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'grafanactl command' commands && ret=0 ;;
  args)
    case $line[1] in
      config)
        local -a config_subs=(
          'set:set a configuration value'
          'use-context:switch active context'
          'check:check configuration validity'
          'view:show current configuration'
          'current-context:show name of active context'
          'list-contexts:list configured contexts'
        )
        _describe -t commands 'config subcommand' config_subs && ret=0
        ;;
      resources)
        local -a res_subs=(
          'get:get a resource'
          'list:list resources'
          'pull:pull resources from Grafana'
          'push:push resources to Grafana'
          'edit:edit a resource'
          'delete:delete a resource'
          'validate:validate resource manifests'
          'serve:serve resources locally'
        )
        _describe -t commands 'resources subcommand' res_subs && ret=0
        ;;
      completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
