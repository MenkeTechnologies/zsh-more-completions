#compdef nix-cli
# _nix-cli — Nix purely functional package manager / system manager CLI alias (NixOS Foundation / Eelco Dolstra, C++); custom argparse
# upstream: https://github.com/NixOS/nix

_nix-cli() {
    local -a sub=(
        'build:build derivations'
        'bundle:bundle an app into single file'
        'config:manage configuration'
        'copy:copy paths between stores'
        'daemon:run nix-daemon'
        'derivation:work with derivations'
        'develop:enter dev shell'
        'doctor:diagnose installation'
        'edit:edit attribute source file'
        'eval:evaluate a Nix expression'
        'fmt:format Nix expressions'
        'flake:flake commands'
        'hash:hash commands'
        'help:show help'
        'help-stores:show help on stores'
        'key:key management'
        'log:show derivation log'
        'nar:NAR archive commands'
        'path-info:show info on paths'
        'print-dev-env:print dev env script'
        'profile:profile commands'
        'realisation:CA derivation realisation'
        'registry:flake registry commands'
        'repl:interactive Nix REPL'
        'run:run an app'
        'search:search packages'
        'shell:start ephemeral shell with packages'
        'show-config:show config (deprecated)'
        'show-derivation:show derivation (deprecated)'
        'store:store commands'
        'upgrade-nix:upgrade nix'
        'verify:verify path integrity'
        'why-depends:explain why path depends on another'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--log-format=+[log format]:fmt:(raw internal-json bar bar-with-logs)' \
        '--print-build-logs[print build logs]' \
        '-L[print build logs]' \
        '--keep-going[keep going]' \
        '-k[keep going]' \
        '--max-jobs=+[max jobs]:n:' \
        '-j+[max jobs]:n:' \
        '--cores=+[cores]:n:' \
        '--extra-experimental-features=+[extra experimental features]:list:' \
        '--experimental-features=+[experimental features]:list:' \
        '--option=+[option name value]:str:' \
        '--store=+[store URL]:url:_urls' \
        '--builders=+[builders]:str:' \
        '--no-substitute[no substitution]' \
        '--substitute[substitution]' \
        '--use-substitutes[use substitutes]' \
        '--substituters=+[substituters]:list:' \
        '--trusted-public-keys=+[trusted public keys]:list:' \
        '--show-trace[show trace]' \
        '--narinfo-cache-positive-ttl=+[narinfo cache positive ttl]:n:' \
        '--no-print-build-logs[no print build logs]' \
        '--no-link[no link]' \
        '--print-out-paths[print out paths]' \
        '--out-link=+[out link]:dir:_files -/' \
        '-o+[out link]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nix subcommand' sub ;;
        args)
            case $words[1] in
                build|develop|run|shell|run|eval|print-dev-env|why-depends|path-info|verify|copy|search) _arguments \
                    '*:installable:' ;;
                profile) _arguments \
                    '1:cmd:(install upgrade list remove rollback wipe-history history diff-closures)' \
                    '*:arg:' ;;
                flake) _arguments \
                    '1:cmd:(archive check clone init lock metadata new prefetch show update)' \
                    '*:arg:' ;;
                store) _arguments \
                    '1:cmd:(add-file add-path cat copy delete diff-closures dump-path gc info ls make-content-addressed mount optimise path-from-hash-part prefetch-file ping repair sign verify)' \
                    '*:arg:' ;;
                hash) _arguments \
                    '1:cmd:(file path to-base16 to-base32 to-base64 to-sri)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(show)' ;;
                registry) _arguments \
                    '1:cmd:(add list pin remove)' \
                    '*:arg:' ;;
                key) _arguments \
                    '1:cmd:(generate-secret convert-secret-to-public)' \
                    '*:arg:' ;;
                nar) _arguments \
                    '1:cmd:(cat dump-path ls)' \
                    '*:arg:' ;;
                derivation) _arguments \
                    '1:cmd:(show add)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_nix-cli "$@"
