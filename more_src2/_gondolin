_gondolin() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    local -a _gdl_common_flags=(
        '--cwd=[working directory in guest]:path:'
        '*--env=[guest env var KEY=VALUE]:env:'
        '--image=[guest image selector (asset dir, build id, name:tag)]:image:'
        '--vmm=[VM backend]:backend:(qemu krun)'
        '--rootfs-size=[minimum rootfs virtual disk size]:size:'
        '*--mount-hostfs=[mount host directory at guest path HOST:GUEST[:ro]]:spec:'
        '*--mount-memfs=[memory-backed mount at guest path]:path:'
        '*--allow-host=[allow outbound HTTP to host]:host:'
        '*--host-secret=[NAME@HOST[,HOST...][=VALUE]]:spec:'
        '--dns=[DNS mode]:mode:(synthetic trusted open)'
        '*--dns-trusted-server=[trusted resolver IPv4]:ip:'
        '--dns-synthetic-host-mapping=[synthetic DNS mapping]:mapping:(single per-host)'
        '*--tcp-map=[GUEST_HOST[:PORT]=UPSTREAM_HOST:PORT]:spec:'
        '*--ssh-allow-host=[allow outbound SSH to host (default port 22)]:host:'
        '--ssh-agent=[ssh-agent socket path (default $SSH_AUTH_SOCK)]:sock:_files'
        '*--ssh-known-hosts=[OpenSSH known_hosts file]:path:_files'
        '*--ssh-credential=[HOST[:PORT]=PATH or USER@HOST[:PORT]=PATH]:spec:'
        '--disable-websockets[disable WebSocket upgrades (egress + ingress)]'
        '--help[show help]'
    )

    case $state in
        cmd)
            local -a _gdl_cmds=(
                'exec:run a command via the virtio socket or in-process VM'
                'bash:start an interactive shell in the sandbox (Ctrl-] to detach)'
                'list:list running VM sessions'
                'attach:attach to a running VM session'
                'snapshot:snapshot a running VM session (stops it)'
                'build:build custom guest assets (kernel/initramfs/rootfs)'
                'image:manage local image refs and objects'
                'help:show help'
            )
            _describe -t commands 'gondolin command' _gdl_cmds && ret=0
            ;;
        args)
            case $words[1] in
                bash)
                    _arguments \
                        $_gdl_common_flags \
                        '--resume=[resume from snapshot ID or .qcow2 path]:id-or-path:_files -g "*.qcow2"' \
                        '--listen=[start host ingress gateway HOST:PORT]:addr:' \
                        '--ssh[enable SSH access via localhost port forward]' \
                        '--ssh-user=[SSH username (default root)]:user:' \
                        '--ssh-port=[local listen port (default 0 = ephemeral)]:port:' \
                        '--ssh-listen=[local listen host (default 127.0.0.1)]:host:' \
                        '*:: :_files' && ret=0
                    ;;
                exec)
                    _arguments \
                        $_gdl_common_flags \
                        '--sock=[virtio sock path]:path:_files' \
                        '*--cmd=[command (repeatable)]:cmd:_command_names -e' \
                        '*--arg=[arg for last --cmd (repeatable)]:arg:' \
                        '*:: :_files' && ret=0
                    ;;
                list)
                    _arguments \
                        '--all[show stale/dead sessions]' \
                        '--help[show help]' \
                        '(-h)-h[show help]' && ret=0
                    ;;
                attach)
                    _arguments \
                        '1:session id:' \
                        '--cwd=[working directory]:path:' \
                        '*--env=[guest env var KEY=VALUE]:env:' \
                        '--help[show help]' \
                        '(-h)-h[show help]' \
                        '*:: :_files' && ret=0
                    ;;
                snapshot)
                    _arguments \
                        '1:session id:' \
                        '--output=[snapshot .qcow2 path]:path:_files' \
                        '--name=[snapshot name]:name:' \
                        '--help[show help]' \
                        '(-h)-h[show help]' && ret=0
                    ;;
                build)
                    _arguments \
                        '--help[show help]' \
                        '*:: :_files' && ret=0
                    ;;
                image)
                    _arguments \
                        '--help[show help]' \
                        '*:: :_files' && ret=0
                    ;;
                help)
                    _arguments '1:command:(exec bash list attach snapshot build image)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_gondolin "$@"
