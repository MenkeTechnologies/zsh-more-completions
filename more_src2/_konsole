#compdef konsole
# Documentation: https://docs.kde.org/trunk_kf6/en/konsole/konsole/command-line-options.html
# Reference accessed: 2026-05-19
# Verified: KDE Konsole command-line options docs.

# Removed invented flags not on the KDE options page:
# --show-toolbars, --hide-toolbars, --force-reuse, -T/--title,
# --help-all, --version.
_arguments -s \
  '--help[list various options]' \
  '--profile=[start using the specified profile]:profile:' \
  '--layout=[start using a saved JSON layout file]:file:_files' \
  '--builtin-profile[use the built-in profile]' \
  '--workdir=[set the initial working directory]:dir:_files -/' \
  '(--hold --noclose)'{--hold,--noclose}'[do not close the initial session when it ends]' \
  '--new-tab[create a new tab in an existing window]' \
  '--tabs-from-file=[create tabs as specified in the given tabs config file]:file:_files' \
  '--background-mode[start in the background, show on Ctrl+Shift+F12]' \
  '(--separate --nofork)'{--separate,--nofork}'[run in a separate process]' \
  '--show-menubar[show the menubar, overriding the default]' \
  '--hide-menubar[hide the menubar, overriding the default]' \
  '--show-tabbar[show the tabbar, overriding the default]' \
  '--hide-tabbar[hide the tabbar, overriding the default]' \
  '--fullscreen[start in fullscreen mode]' \
  '--notransparency[disable transparent backgrounds]' \
  '--list-profiles[list all available profiles]' \
  '--list-profile-properties[list all possible properties with name and type]' \
  '*-p[change the value of a profile property]:property=value:' \
  '-e[execute command instead of the normal shell]:command:_command_names' \
  '*::args:_normal'
