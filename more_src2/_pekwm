#compdef pekwm
# Documentation: https://manpages.debian.org/bookworm/pekwm/pekwm.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--info[show compile-time information]' \
  '--display[X display to use]:display:' \
  '--config[config file]:file:_files' \
  '--replace[replace any running window manager]' && ret=0

return ret
