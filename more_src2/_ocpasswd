#compdef ocpasswd
# _ocpasswd — OpenConnect ocserv ocpasswd (manage the ocserv plain-text password database; -c create new ocpasswd file, -d delete user, -l lock, -u unlock, -p set password from stdin, -g group, -i import from stdin, --version; positional argument is the username then optional ocpasswd file path)
# upstream: https://gitlab.com/openconnect/ocserv
# Flags from openconnect/ocserv src/ocpasswd/main.c on tip.

_ocpasswd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c[create new ocpasswd file]' \
        '-d[delete user]' \
        '-l[lock]' \
        '-u[unlock]' \
        '-p+[password file]:file:_files' \
        '-g+[group]:group:_groups' \
        '-i[import from stdin]' \
        '1:username:_users' \
        '2::ocpasswd file:_files'
}

_ocpasswd "$@"
