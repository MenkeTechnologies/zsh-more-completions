#compdef krane
# Documentation: https://github.com/Shopify/krane
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (lib/krane/cli/krane.rb
# Thor registrations + deploy_command.rb options). Replaced the
# bare stub with the real Shopify krane subcommands and deploy
# flags.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:ship resources to a namespace'
  'global-deploy:ship non-namespaced resources to a cluster'
  'render:render templates'
  'restart:restart the pods in one or more deployments'
  'run:run a pod that exits upon completing a task'
  'version:prints the version'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'krane command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy|global-deploy)
        _arguments -s -S \
          '(-f --filenames)'{-f+,--filenames=}'[directories and files with configuration to apply]:path:_files' \
          '--stdin[(deprecated) read resources from stdin]' \
          '--global-timeout=[max duration to monitor workloads]:duration:' \
          '*--protected-namespaces=[namespaces deploys are allowed to]:ns:' \
          '(--prune --no-prune)--prune[enable deletion of resources not in the template dir]' \
          '(--prune --no-prune)--no-prune[disable pruning]' \
          '--selector=[select workloads by selector(s)]:selector:' \
          '--selector-as-filter[use --selector as a label filter]' \
          '--verbose-log-prefix[add [context][namespace] to the log prefix]' \
          '(--verify-result --no-verify-result)--verify-result[verify workloads correctly deployed]' \
          '(--verify-result --no-verify-result)--no-verify-result[skip result verification]' \
          '*: :_files' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
