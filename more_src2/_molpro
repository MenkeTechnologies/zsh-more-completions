#compdef molpro molpro-cli molproc
# _molpro — MOLPRO collaboration molpro ab initio package for high-accuracy electronic structure calculations (molpro team, Fortran); custom argparse
# upstream: https://www.molpro.net

_molpro() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-n+[number of CPUs]:n:' \
        '--nproc=+[number of CPUs]:n:' \
        '-N+[host:cpus per host]:str:' \
        '--hosts=+[host:cpus per host]:str:' \
        '-t+[number of threads]:n:' \
        '--threads=+[number of threads]:n:' \
        '-m+[memory MW per process]:str:' \
        '--memory=+[memory MW per process]:str:' \
        '-G+[GA memory]:str:' \
        '--ga-memory=+[GA memory]:str:' \
        '-d+[scratch dir]:dir:_files -/' \
        '--scratch=+[scratch dir]:dir:_files -/' \
        '-W+[wavefunction dir]:dir:_files -/' \
        '--wfn-dir=+[wavefunction dir]:dir:_files -/' \
        '-I+[integral dir]:dir:_files -/' \
        '--int-dir=+[integral dir]:dir:_files -/' \
        '-o+[output file]:file:_files -g "*.out *.log *.mo"' \
        '--output=+[output file]:file:_files -g "*.out *.log *.mo"' \
        '-l[log only]' \
        '--log[log only]' \
        '-x+[xml output]:file:_files -g "*.xml"' \
        '--xml=+[xml output]:file:_files -g "*.xml"' \
        '-s[silent]' \
        '--silent[silent]' \
        '-T+[time limit hrs]:n:' \
        '--time=+[time limit hrs]:n:' \
        '-K[keep scratch]' \
        '--keep-scratch[keep scratch]' \
        '-q+[queue]:str:' \
        '--queue=+[queue]:str:' \
        '--license=+[license file]:file:_files' \
        '-V+[verbose level]:n:' \
        '--verbose=+[verbose level]:n:' \
        '-g+[geometry from]:file:_files -g "*.xyz *.mol *.zmat"' \
        '*:input file:_files -g "*.com *.inp *.molpro *.mp"'
}

_molpro "$@"
