#compdef firod
# _firod — Firo formerly Zcoin firod daemon CLI for the privacy-focused Lelantus Spark MTP fork of Bitcoin running a full node maintaining the blockchain validating shielded transactions network sync RPC API memory pool wallet (firoorg team, C++); custom argparse
# upstream: https://github.com/firoorg/firo

_firod() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf firo.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-daemon[run as daemon]' \
        '-pid=+[file]:file:_files' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb znode lelantus mtp spark all)' \
        '-loglevel=+[level]:l:(info debug trace)' \
        '-logips[log IPs]' \
        '-logtimestamps[log timestamps]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserver[enable RPC server]' \
        '-rpcwait[wait for RPC server]' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-blocksonly[only blocks]' \
        '-maxconnections=+[N]:n:' \
        '-paytxfee=+[FIRO/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[file]:file:_files' \
        '-znode=+[b]:b:(0 1)' \
        '-znodeprivkey=+[key]:str:' \
        '-znodeaddr=+[host:port]:str:' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:' \
        '-zmqpubhashblock=+[address]:str:' \
        '-zmqpubhashtx=+[address]:str:'
}

_firod "$@"
