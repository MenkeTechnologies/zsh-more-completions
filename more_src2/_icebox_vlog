#compdef icebox_vlog
# Documentation: https://github.com/YosysHQ/icestorm
# Source: YosysHQ/icestorm icebox/icebox_vlog.py — convert iCE40 .asc bitstream to a synthesizable Verilog netlist.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[strip comments from output]' \
    '-S[strip comments about interconn wires from output]' \
    '(-p -P)-l[convert IO tile port names to chip pin numbers]' \
    '-L[lookup symbol names (using .sym statements in input)]' \
    '-n[name for the exported module (default: chip)]:name:' \
    '(-l -P)-p[use set_io commands from specified pcf file]:pcf:_files' \
    '(-l -p)-P[like -p, enable hacks for iCEcube2-created pcf files]:pcf:_files' \
    '-d[use given package for chip pin numbers (overrides device default)]:package:' \
    '-c[collect multi-bit ports]' \
    '-R[enable IeRen database checks]' \
    '-D[enable exactly-one-driver checks]' \
    '*:.asc bitstream:_files' \
    && ret=0

return ret
