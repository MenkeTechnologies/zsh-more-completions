#compdef kube-hunter
# _kube-hunter-bin — Aqua kube-hunter k8s attack-surface tool (Aqua Security, Python); discover k8s security issues from inside/outside
# upstream: https://github.com/aquasecurity/kube-hunter

_kube-hunter-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--list[list available tests]' \
        '--interface[hunt all network interfaces]' \
        '--pod[hunt from inside a pod]' \
        '--remote+[hunt remote IP/host]:host:_hosts' \
        '--cidr+[hunt CIDR]:cidr:' \
        '--mapping[only map discovered services]' \
        '--include-patched-versions[also report patched versions]' \
        '--quick[quick scan]' \
        '--log+[log level]:level:(debug info warning error critical)' \
        '--statistics[publish statistics]' \
        '--raw-hunter-errors[show raw hunter errors]' \
        '--service-account-token+[service account token]:file:_files' \
        '--report+[report mode]:mode:(plain json yaml)' \
        '--dispatch+[dispatch mode]:mode:(stdout http)' \
        '--active[active hunting]' \
        '--k8s-auto-discover-nodes[auto discover nodes]' \
        '--network-bound[network bound]' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--kube-context+[kube context]:context:' \
        '--all-active[all active hunters]' \
        '*::args:'
}

_kube-hunter-bin "$@"
