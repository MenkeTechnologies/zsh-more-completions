#compdef fregec
# ============================================================================
#  _fregec — fregec: the Frege compiler — purely functional
#            Haskell-like language for the JVM
#            (Ingo "ingomaier" Wechsung, Frege project)
#
#  Source-direct extraction from
#    https://github.com/Frege/frege/blob/master/frege/compiler/common/CompilerOptions.fr
#    https://github.com/Frege/frege/blob/master/scripts/fregec.bat
#    (the canonical Frege compiler launcher that invokes
#    `java frege.compiler.Main`)
#
#  Maintained by Ingo Wechsung (Frege language designer and primary
#  implementer).  3,696 GH stars on Frege/frege.  Frege is a
#  PURELY FUNCTIONAL programming language for the JVM with a
#  Haskell-derived syntax and type system — strong static typing,
#  type inference, monadic IO, lazy evaluation by default,
#  algebraic data types, type classes, pattern matching, list
#  comprehensions, do-notation.  Compiles to JVM bytecode that
#  interoperates with the Java standard library.  Named after
#  Gottlob Frege (mathematician/logician who developed first-order
#  predicate logic).  Distinct from other JVM functional languages:
#  Scala (object-functional hybrid with mutable state), Clojure
#  (Lisp dynamic typing), Kotlin (Java-friendly OO), Eta
#  (deprecated; was another Haskell-on-JVM attempt).  Frege is
#  closer to Haskell semantically than any other JVM language —
#  pure-by-default, lazy-by-default, type-classes-everywhere.
#  Sister tools: ghc (Glasgow Haskell Compiler — in corpus via
#  _ghc + STOCK in Haskell installations), runghc (in corpus via
#  _runghc + STOCK), stack (Haskell build tool — in corpus + STOCK),
#  cabal (Haskell build tool — in corpus + STOCK), scala (in
#  corpus + STOCK in JVM functional ecosystem), kotlinc (in
#  corpus + STOCK), clojure (in corpus + STOCK).
#
#  CLI library taxonomy update: 1st Frege CLI library — Frege
#  compiler's **HAND-ROLLED FUNCTIONAL PATTERN-MATCHING PARSER**
#  in `frege/compiler/common/CompilerOptions.fr`.  Frege joins
#  the cross-language taxonomy as the 36th documented language.
#  🎉 NEW LANGUAGE entry — Frege joins alongside Rust, Go,
#  TypeScript-Node, Python, Ruby, Perl, Haskell, OCaml, Elixir,
#  R, Bash, Deno, Lua, Scheme, Clojure, Common Lisp, Racket,
#  Crystal, Nim, Zig, Odin, V, Mojo, Roc, Hare, Standard ML,
#  Erlang, Pony, Prolog, Pike, F#, Janet, D, Picat, BQN.
#
#  Frege's compiler-options parser is HAND-ROLLED in Frege itself
#  — `scanOpts :: Options -> [String] -> IO (Maybe (Options,
#  [String]))` is a recursive pattern-matching function that
#  consumes argv as a list.  This is the FUNCTIONAL HASKELL-STYLE
#  approach common in Haskell ecosystem — GHC, Hugs, and other
#  Haskell tools also use hand-rolled list-pattern-matching
#  parsers rather than reaching for libraries like cmdliner
#  (OCaml) or optparse-applicative (Haskell).  Frege follows
#  this tradition because:
#    (a) Frege is bootstrapped from itself + Java, no native
#        getopt available
#    (b) Pattern-matching on the argv [String] list is idiomatic
#        and ergonomic in Haskell/Frege
#    (c) The CLI is small-and-static enough that abstracting it
#        into a library would be over-engineering
#
#  Frege's hand-rolled functional parser API (in Frege):
#    -- The Options record holds all parsed config
#    data Options = Options {
#      dir         :: String,           -- output directory (-d)
#      sourcePath  :: [String],         -- source path (-sp)
#      path        :: [String],         -- classpath (-fp)
#      target      :: Target,           -- JDK target (-t)
#      encoding    :: Maybe String,     -- source encoding (-enc)
#      prefix      :: String,           -- prefix (-prefix)
#      flags       :: BitSet Flag,      -- boolean-flag bitset
#      tRanges     :: [(Int, Int)],     -- trace line ranges
#    }
#
#    -- Recursive list-pattern-matching parser
#    scanOpts :: Options -> [String] -> IO (Maybe (Options, [String]))
#    scanOpts opts []                       = pure (Just (opts, []))
#    scanOpts opts ("-d" : dir : rest)      = scanOpts opts.{dir} rest
#    scanOpts opts ("-sp" : path : rest)    = scanOpts opts.{sourcePath = ...} rest
#    scanOpts opts ("-fp" : path : rest)    = scanOpts opts.{path = ...} rest
#    scanOpts opts (´^-t(arget)?$´ : v : r) = scanOpts opts.{target = ...} r
#    scanOpts opts (´^-enc(oding)?$´ : e : r) = scanOpts opts.{encoding = ...} r
#    scanOpts opts ("-version" : rest)      = printVersion >> scanOpts opts rest
#    scanOpts opts ("-help" : rest)         = printHelp >> scanOpts opts rest
#    scanOpts opts ((flag@´^-´) : rest)     = case flagtree.lookup flag of
#      Just f  -> scanOpts opts.{flags <- f} rest  -- bitset modifier from table
#      Nothing -> error_unknown_flag rest
#    scanOpts opts (filename : rest)        = ... -- positional files
#
#    -- BITSET FLAGS lookup table (flagtree)
#    -- Each key is a CLI flag; value is a BitSet operation
#    -- (union to set, differenceE to clear)
#    flagtree = TM.fromList [
#      ("-nocp",   BitSet.`differenceE` WITHCP),       -- disable classpath inheritance
#      ("-j",      BitSet.`differenceE` RUNJAVAC),     -- disable javac post-step
#      ("-nowarn", BitSet.`differenceE` WARNINGS),     -- disable warnings
#      ("-hints",  BitSet.`unionE` HINTS),             -- enable hints
#      ("-make",   BitSet.`unionE` MAKE),              -- enable make-mode
#      ("-O",      BitSet.union (fromList [OPTIMIZE, INLINE])),
#      ("-v",      BitSet.`unionE` VERBOSE),
#      ("-x1",     BitSet.`unionE` TRACE1),
#      -- ... TRACE2-9 + TRACET/X/M/K/O/S/G/Z
#    ]
#
#    -- Entry point: scanOpts called from compiler/Main.fr
#    getOpts :: [String] -> IO (Maybe (Options, [String]))
#    getOpts = scanOpts stdOptions
#
#  Frege's hand-rolled functional parser distinctive features:
#    - PATTERN-MATCHING ON ARGV LIST — each option-handling case is
#      a separate pattern in the `scanOpts` function; Frege's
#      pattern-matching on `[String]` (list of strings) makes this
#      ergonomic and exhaustive
#    - REGEX-PATTERN GUARDS — uses Frege's regex pattern matching
#      `´^-t(arget)?$´` to match both `-t` and `-target` forms in
#      a single pattern (similar to Haskell's TDNR/View patterns)
#    - BITSET FLAG TABLE — `flagtree :: TreeMap String (BitSet
#      Flag -> BitSet Flag)` maps each boolean flag NAME to a
#      BitSet modifier function (either union to set, differenceE
#      to clear); allows complex flag interactions like `-greek`
#      simultaneously enables USEUNICODE + USEGREEK and disables
#      USEFRAKTUR via function composition
#    - RECORD UPDATE SYNTAX — `opts.{dir}` updates the Options
#      record with the new dir field (Frege's record-update
#      syntax inherited from Haskell extensions)
#    - VALIDATION INLINE — each arg pattern can do sanity checks
#      (e.g. `-d` checks that the dir is an existing readable/
#      writable directory before proceeding) and abort with an
#      error message if invalid
#    - HAND-MAINTAINED USAGE STRING in `printHelp` function —
#      not auto-generated from option metadata
#    - NO subcommand framework (frege compiler has single
#      invocation pattern; subcommand-style tools like Frege REPL
#      `fregeci` ship as separate binaries with their own argv
#      parsers)
#    - NO env-var fallback (config is purely from argv)
#    - Frege's parser interleaves IO actions (validation: dir
#      exists, file readable, jar/zip type check) directly into
#      the recursive descent — possible because scanOpts returns
#      `IO (Maybe ...)` and threads through actions
#  Frege's hand-rolled functional parser philosophy is shared
#  with: R424 Picat (hand-rolled C parser), R425 BQN (hand-rolled
#  C parser), GHC (Haskell compiler — hand-rolled options.hs),
#  most Haskell tools historically before optparse-applicative
#  became mainstream.  Frege is the FIRST DOCUMENTED Frege CLI
#  library in the corpus's cross-language taxonomy.  Frege joins
#  the 35 other documented languages (Rust, Go, TypeScript-Node,
#  Python, Ruby, Perl, Haskell, OCaml, Elixir, R, Bash, Deno, Lua,
#  Scheme, Clojure, Common Lisp, Racket, Crystal, Nim, Zig, Odin,
#  V, Mojo, Roc, Hare, Standard ML, Erlang, Pony, Prolog, Pike,
#  F#, Janet, D, Picat, BQN) as the 36th represented language.
#  Brings cross-language CLI library taxonomy variant count to
#  168 (167 + hand-rolled-functional-Frege = 168).
#
#  Surface (verbatim from `frege/compiler/common/CompilerOptions.fr`
#  `scanOpts` function + `flagtree` table):
#
#  Usage:
#    fregec [options]* source-file.fr [source-file.fr ...]
#
#  Output:
#    -d <DIR>                       Output directory for compiled
#                                   .class files (must exist; must
#                                   be readable + writable)
#
#  Source paths:
#    -sp <PATH>                     Source path — colon-separated
#                                   list of directories where
#                                   Frege source files are looked
#                                   up by import statements
#    -fp <CLASSPATH>                Frege classpath — colon-separated
#                                   list of directories AND/OR
#                                   JAR/ZIP archives for compiled
#                                   Frege modules (similar to
#                                   Java's -cp)
#
#  JVM target:
#    -t <TARGET>                    Target JDK version (1.6, 1.7,
#                                   1.8, 1.9, 1.10, 1.11, etc.;
#                                   minimum 1.6; max is the JDK
#                                   running the compiler)
#    -target <TARGET>               Same as -t (long form)
#
#  Source encoding:
#    -enc <ENCODING>                Source encoding (default:
#                                   platform default; "DEFAULT"
#                                   string means platform default)
#    -encoding <ENCODING>           Same as -enc (long form)
#
#  Prefix and trace ranges:
#    -prefix <STR>                  Prefix string for ... internal
#                                   compiler use
#    -xr <RANGE>                    Trace line range (e.g.
#                                   "100-200" or "150"); restricts
#                                   trace output to source lines
#                                   in the range
#    -explain <RANGE>               Explain line range — enables
#                                   EXPLAIN flag and restricts to
#                                   range
#
#  Boolean flags (compiler behavior):
#    -nocp                          Disable inheriting WITHCP
#                                   (frege.classpath system prop)
#    -j                             Disable running javac on
#                                   generated .java (output stops
#                                   at the .java intermediate)
#    -nowarn                        Disable warnings
#    -ascii                         ASCII-only output (disables
#                                   USEUNICODE)
#    -hints                         Enable HINTS — extra compiler
#                                   diagnostic suggestions
#    -make                          Make-mode (dependency-driven
#                                   builds — only recompile what
#                                   changed)
#    -inline                        Enable function inlining
#                                   optimization
#    -O                             Enable BOTH optimize AND inline
#                                   (shorthand for -inline + opt)
#    -symbols                       Enable Unicode symbols in output
#    -greek                         Enable Greek-letter Unicode in
#                                   error messages (e.g. forall →
#                                   ∀) + USEUNICODE
#    -fraktur                       Enable Fraktur-letter Unicode
#                                   in error messages + USEUNICODE
#                                   (mutually exclusive with -greek)
#    -latin                         Plain Latin letters only
#                                   (disables -greek and -fraktur)
#    -comments                      Include Frege source comments
#                                   in generated .java code
#    -propertc                      Enable proper tail-call
#                                   optimization
#    -strict-pats                   Enable strict left-to-right
#                                   pattern matching
#    -v                             Verbose output
#
#  Trace flags (compiler-internal — for debugging Frege itself):
#    -x1 .. -x9                     Trace levels 1-9 (general
#                                   compiler tracing)
#    -xt                            Trace type checker
#    -xx                            Trace env operations (lots of
#                                   output)
#    -xm                            Trace make operations
#    -xk                            Trace kind inference
#    -xo                            Trace optimizer
#    -xs                            Trace strictness analysis
#    -xg                            Trace code generator
#    -xz                            On-demand mysterious-things
#                                   trace
#
#  Meta:
#    -version                       Print Frege version and exit
#    -help                          Print help and exit
#
#  Positional:
#    source-file.fr                 Frege source files to compile
#                                   (.fr extension); multiple files
#                                   allowed
#
#  Examples:
#    fregec Hello.fr                                   # Compile single file
#    fregec -d build/ Hello.fr                         # Compile to build/
#    fregec -sp src/:lib/ -d build/ App.fr             # Multiple source paths
#    fregec -fp frege.jar -d build/ App.fr             # Use frege.jar classpath
#    fregec -t 1.8 -d build/ App.fr                    # Target JDK 1.8
#    fregec -O -hints App.fr                           # Optimize + show hints
#    fregec -make src/                                 # Make-mode (incremental build)
#    fregec -nowarn -v App.fr                          # Silent warnings, verbose
#    fregec -greek -v App.fr                           # Verbose with Greek symbols
#    fregec -xt -v Module.fr                           # Verbose + trace typechecker
#    fregec -enc UTF-8 -d build/ Russian.fr            # UTF-8 source files
#    fregec -version                                   # Print version
#    fregec -help                                      # Print help
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  similar hand-rolled functional parsers):
#    - ghc (IN CORPUS via _ghc + STOCK — GHC Haskell compiler;
#      uses similar hand-rolled options.hs parser; FUTURE
#      candidate for formal Haskell stdlib parser documentation)
#    - runghc (IN CORPUS + STOCK)
#    - stack (IN CORPUS + STOCK — uses optparse-applicative)
#    - cabal (IN CORPUS + STOCK — uses GetOpt + custom)
#    - frege itself (`frege` shell script — only wraps `java
#      -cp`, NOT a CLI with Frege-implemented argv parser; the
#      actual parser is in `fregec` for the compiler invocation)
#    - eta (Eta-Lang, deprecated 2018 — was another Haskell-on-
#      JVM attempt; not in corpus)
# ============================================================================

_fregec() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-help[print help and exit]' \
    '-version[print version and exit]' \
    '-d[output directory]:dir:_directories' \
    '-sp[source path (colon-separated dirs)]:path:' \
    '-fp[Frege classpath (colon-separated jars/dirs)]:path:' \
    '-t[target JDK version]:version:(1.6 1.7 1.8 1.9 1.10 1.11 1.12 1.13 1.14 1.15 1.16 1.17)' \
    '-target[target JDK version (long form)]:version:(1.6 1.7 1.8 1.9 1.10 1.11 1.12 1.13 1.14 1.15 1.16 1.17)' \
    '-enc[source encoding]:encoding:(DEFAULT UTF-8 ISO-8859-1 ASCII)' \
    '-encoding[source encoding (long form)]:encoding:(DEFAULT UTF-8 ISO-8859-1 ASCII)' \
    '-prefix[prefix string]:prefix:' \
    '-xr[trace line range]:range:' \
    '-explain[explain line range]:range:' \
    '-nocp[disable inheriting WITHCP]' \
    '-j[disable running javac on generated .java]' \
    '-nowarn[disable warnings]' \
    '-ascii[ASCII-only output (disable Unicode)]' \
    '-hints[enable HINTS]' \
    '-make[make-mode (incremental builds)]' \
    '-inline[enable function inlining optimization]' \
    '-O[enable optimize + inline]' \
    '-symbols[enable Unicode symbols in output]' \
    '-greek[enable Greek-letter Unicode + USEUNICODE]' \
    '-fraktur[enable Fraktur-letter Unicode + USEUNICODE]' \
    '-latin[plain Latin letters only]' \
    '-comments[include Frege source comments in generated .java]' \
    '-propertc[enable proper tail-call optimization]' \
    '-strict-pats[enable strict left-to-right pattern matching]' \
    '-v[verbose output]' \
    '-x1[trace level 1]' \
    '-x2[trace level 2]' \
    '-x3[trace level 3 (symbol table operations)]' \
    '-x4[trace level 4]' \
    '-x5[trace level 5]' \
    '-x6[trace level 6]' \
    '-x7[trace level 7]' \
    '-x8[trace level 8]' \
    '-x9[trace level 9]' \
    '-xt[trace type checker]' \
    '-xx[trace env operations]' \
    '-xm[trace make operations]' \
    '-xk[trace kind inference]' \
    '-xo[trace optimizer]' \
    '-xs[trace strictness analysis]' \
    '-xg[trace code generator]' \
    '-xz[on-demand mysterious-things trace]' \
    '*:file:_files -g "*.fr"'
}

_fregec "$@"
