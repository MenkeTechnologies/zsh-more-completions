#compdef excalidraw excalidraw-cli
# _excalidraw — Excalidraw excalidraw-cli local Node CLI for converting Excalidraw .excalidraw drawing files into PNG SVG PDF formats headlessly using puppeteer (excalidraw team, TypeScript); commander.js
# upstream: https://github.com/excalidraw/excalidraw

_excalidraw() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-i+[input]:file:_files -g "*.excalidraw *.excalidraw.json *.excalidrawlib *.svg *.png"' \
        '--input=+[input]:file:_files -g "*.excalidraw *.excalidraw.json *.excalidrawlib *.svg *.png"' \
        '-o+[output]:file:_files -g "*.png *.svg *.pdf"' \
        '--output=+[output]:file:_files -g "*.png *.svg *.pdf"' \
        '-f+[format]:f:(png svg pdf jpeg)' \
        '--format=+[format]:f:(png svg pdf jpeg)' \
        '-w+[width px]:n:' \
        '--width=+[width px]:n:' \
        '-H+[height px]:n:' \
        '--height=+[height px]:n:' \
        '-s+[scale]:f:' \
        '--scale=+[scale]:f:' \
        '-b+[background]:c:(transparent white black light dark)' \
        '--background=+[background]:c:(transparent white black light dark)' \
        '--theme=+[theme]:t:(light dark)' \
        '-t+[theme]:t:(light dark)' \
        '--padding=+[px]:n:' \
        '-p+[px]:n:' \
        '--exportEmbedScene[embed scene]' \
        '--exportWithDarkMode[dark mode]' \
        '--exportScale=+[F]:f:' \
        '--quality=+[N]:n:' \
        '*:input file:_files -g "*.excalidraw *.excalidraw.json *.excalidrawlib"'
}

_excalidraw "$@"
