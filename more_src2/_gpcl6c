#compdef gpcl6c gpdlc
# Documentation: https://ghostscript.readthedocs.io/en/latest/Use.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '*-d+[set device parameter]:param=value:' \
  '*-s+[set string parameter]:param=value:' \
  '*-r+[resolution DPI]:dpi:' \
  '-q[quiet]' \
  '-o+[output file]:file:_files' \
  '-sDEVICE=-[output device]:device:' \
  '-sOutputFile=-[output file]:file:_files' \
  '*:input file:_files -g "*.(pcl|pxl|prn)"' && ret=0

return ret
