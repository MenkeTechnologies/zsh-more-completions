#compdef rtorrent-cli
# _rtorrent-cli — Jari Sundell rTorrent ncurses BitTorrent client CLI alias (rakshasa team, C++); custom argparse
# upstream: https://github.com/rakshasa/rtorrent

_rtorrent-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-n[no rc file]' \
        '-D[no XMLRPC]' \
        '-I[disable IP filter]' \
        '-K[unchoke based on local seeds]' \
        '-b+[bind IP]:str:' \
        '-i+[ip override]:str:' \
        '-p+[port range]:str:' \
        '-d+[directory]:dir:_files -/' \
        '-s+[session dir]:dir:_files -/' \
        '-o+[option=value]:str:' \
        '*:torrent files:_files -g "*.torrent"'
}

_rtorrent-cli "$@"
