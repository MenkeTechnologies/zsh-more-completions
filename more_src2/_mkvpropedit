#compdef mkvpropedit
# Documentation: https://mkvtoolnix.download/doc/mkvpropedit.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mkvpropedit - MKVToolNix property editor

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[suppress status output]' \
  '(-l --list-property-names)'{-l,--list-property-names}'[list editable properties]' \
  '(-p --parse-mode)'{-p,--parse-mode}'=[parse mode]:mode:(fast full)' \
  '--disable-language-ietf[apply changes only to legacy Language element]' \
  '--normalize-language-ietf=[normalize IETF BCP 47 tags]:mode:(canonical extlang off)' \
  '--enable-legacy-font-mime-types[use legacy font MIME types]' \
  '--command-line-charset=[input character encoding]:charset' \
  '--output-charset=[output character encoding]:charset' \
  '(-r --redirect-output)'{-r,--redirect-output}'=[write messages to file]:file:_files' \
  '--no-bom[disable BOM in UTF output]' \
  '--abort-on-warnings[stop on first warning]' \
  '--debug=[enable debugging]:topic' \
  '--engage=[activate experimental features]:feature' \
  '--ui-language=[interface language]:language' \
  '--gui-mode[enable GUI mode]' \
  '--flush-on-close[flush buffers on close]' \
  '(-e --edit)'{-e,--edit}'[element selector]:selector:(info track\:v1 track\:a1 track\:s1)' \
  '(-a --add)'{-a,--add}'[add a property]:name=value' \
  '(-s --set)'{-s,--set}'[set a property]:name=value' \
  '(-d --delete)'{-d,--delete}'[delete a property]:name' \
  '--add-track-statistics-tags[add track statistics tags]' \
  '--delete-track-statistics-tags[delete track statistics tags]' \
  '(-t --tags)'{-t,--tags}'=[modify tags]:selector\:file:_files -g "*.xml"' \
  '(-c --chapters)'{-c,--chapters}'=[set chapters]:file:_files -g "*.xml *.txt"' \
  '--attachment-name=[attachment name]:name' \
  '--attachment-description=[attachment description]:description' \
  '--attachment-mime-type=[attachment MIME type]:type' \
  '--attachment-uid=[attachment UID]:UID' \
  '--add-attachment=[add an attachment]:file:_files' \
  '--replace-attachment=[replace an attachment]:selector\:file:_files' \
  '--update-attachment=[update attachment properties]:selector' \
  '--delete-attachment=[delete an attachment]:selector' \
  '1:Matroska file:_files -g "*.mkv *.mka *.mks *.mk3d *.webm"'
