#compdef gtester
# Documentation: gtester --help (GLib)
# Source: GLib gtester — GTest test-binary runner (XML log producer for gtester-report).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version information]' \
    '--g-fatal-warnings[treat warnings as fatal (abort)]' \
    '(-k --keep-going)'{-k,--keep-going}'[continue after test failures]' \
    '-l[list paths of available test cases]' \
    '*-m+[test mode]:mode:(perf slow thorough quick undefined no-undefined)' \
    '*-p=+[only run tests matching TESTPATH]:testpath:' \
    '*-s=+[skip tests matching TESTPATH]:testpath:' \
    '--seed=[start tests with random seed]:seedstring:' \
    '-o=+[write test log to file]:logfile:_files' \
    '(-q --quiet --verbose)'{-q,--quiet}'[suppress per-test-binary output]' \
    '(-q --quiet --verbose)--verbose[report success per testcase]' \
    '*:test program:_command_names -e' \
    && ret=0

return ret
