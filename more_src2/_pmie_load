#compdef pmie_load
# _pmie_load — Performance Co-Pilot pmie_load (developer/operator helper that loads, validates and unloads pmie rule files against a live pmcd(1) context without restarting the running pmie daemon; -c rules file, -h host, -a archive, -V verbose, -t interval, positional rule file optional)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmie/pmie_load on tip.

_pmie_load() {
    _arguments \
        '-c+[rules file]:file:_files' \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-t+[interval]:interval:' \
        '-V[verbose]' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-Z+[timezone]:tz:' \
        '1:rule file:_files'
}

_pmie_load "$@"
