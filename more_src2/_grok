# Zsh completion for grok - xAI Grok Build CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-p --prompt)'{-p+,--prompt=}'[headless prompt]:prompt:' \
  '(-d --directory)'{-d+,--directory=}'[working directory]:directory:_directories' \
  '(-k --api-key)'{-k+,--api-key=}'[API key]:key:' \
  '(-u --base-url)'{-u+,--base-url=}'[API base URL]:url:_urls' \
  '(-m --model)'{-m+,--model=}'[model name]:model:' \
  '--max-tool-rounds[max tool rounds]:n:' \
  '--output-format[output format]:format:(json streaming-json)' \
  '--format[output format alias]:format:(json)' \
  '--session[resume session]:session:(latest)' \
  '-s[session id]:id:' \
  '--batch-api[use batch API]' \
  '--verify[verification mode]' && ret=0

return ret
