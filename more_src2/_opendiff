#compdef opendiff
# Documentation: https://www.manpagez.com/man/1/opendiff/
# Reference accessed: 2026-05-20
# Verified: Apple opendiff(1) manpage.

local -a arguments

arguments=(
    '-ancestor[Common ancestor file for three-way merge]:ancestor file:_files'
    '-merge[Output merged file]:merge output:_files'
    '1:first file or directory:_files'
    '2:second file or directory:_files'
)

_arguments -s -S $arguments
