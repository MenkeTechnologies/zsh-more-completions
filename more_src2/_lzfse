#compdef lzfse
# Documentation: https://github.com/lzfse/lzfse/blob/master/src/lzfse_main.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[show help]' \
  '-v[verbose output]' \
  '-encode[compress input]' \
  '-decode[decompress input]' \
  '-i[input file]:input file:_files' \
  '-o[output file]:output file:_files' && ret=0

return ret
