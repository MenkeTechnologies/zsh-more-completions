#compdef ecpdll
# _ecpdll — Project Trellis ecpdll CLI configuring DLL Delay Locked Loop clock primitives in ECP5 bitstream EHXPLLL EHXPLL frequency divider multiplier feedback path delay parameters for clock generation networks (David Shah team, C++); custom argparse
# upstream: https://github.com/YosysHQ/prjtrellis

_ecpdll() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--input-freq=+[MHz]:n:' \
        '--output-freq=+[MHz]:n:' \
        '--primary-input-freq=+[MHz]:n:' \
        '--secondary-input-freq=+[MHz]:n:' \
        '--feedback-mode=+[m]:m:(internal external user_clock clkop)' \
        '--phase-shift=+[deg]:n:' \
        '--duty-cycle=+[pct]:n:' \
        '--ext-feedback=+[N]:n:' \
        '--clkop-cphase=+[N]:n:' \
        '--clkop-fphase=+[N]:n:' \
        '--clkos-cphase=+[N]:n:' \
        '--clkos-fphase=+[N]:n:' \
        '--clki-div=+[N]:n:' \
        '--clkop-div=+[N]:n:' \
        '--clkos-div=+[N]:n:' \
        '--clkos2-div=+[N]:n:' \
        '--clkos3-div=+[N]:n:' \
        '--module=+[name]:str:' \
        '--clkop-name=+[name]:str:' \
        '*:output file:_files -g "*.v"'
}

_ecpdll "$@"
