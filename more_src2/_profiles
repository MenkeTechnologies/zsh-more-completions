#compdef profiles
# Documentation: profiles -h (macOS 26)
# Source: install, remove, list configuration / provisioning profiles.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-x[display version]' \
    '-P[print all configuration profiles]' \
    '-H[exit 0 if any configuration profiles installed]' \
    '-C[display all device profiles]' \
    '-D[delete existing configuration profiles (root)]' \
    '-d[delete existing provisioning profiles (root)]' \
    '-f[auto confirm any questions]' \
    '-v[verbose mode]' \
    '-o+[output XML plist path (or stdout)]:path:_files' \
    '-s+[set startup profile filename]:path:_files' \
    '(-R -L -W)-I[install a profile]' \
    '(-I -L -W)-R[remove a profile]' \
    '(-I -R -W)-L[list a user'\''s profiles]' \
    '(-I -R -L)-W[renew certificates in an installed profile]' \
    '-F+[profile file path (or -)]:file:_files -g "*.mobileconfig"' \
    '-p+[profile identifier (for removal)]:identifier:' \
    '-U+[user name for -L]:user:_users' \
    && ret=0

return ret
