#compdef pnpx
# Documentation: pnpm dlx --help (pnpx is alias for `pnpm dlx`)
# Source: pnpm — run a package in a temporary environment.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--allow-build=[package names allowed to run postinstall scripts]:pkg:' \
    '--package=[package to install before running command]:pkg:' \
    '(-c --shell-mode)'{-c,--shell-mode}'[run inside a shell (sh / cmd.exe)]' \
    '--reporter=[output reporter]:reporter:(append-only default ndjson silent)' \
    '(-s --silent)'{-s,--silent}'[no output (alias for --reporter silent)]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:command + args:_command_names -e' \
    && ret=0

return ret
