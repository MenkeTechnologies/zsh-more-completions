#compdef kaniko-executor executor
# _kaniko-executor — Kaniko in-container Docker-image builder (GoogleContainerTools/kaniko)
# upstream: https://github.com/GoogleContainerTools/kaniko
# Flags from cmd/executor/cmd/root.go (cobra).

_kaniko-executor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbosity)'{-v+,--verbosity=}'[log level]:level:(trace debug info warn error fatal panic)' \
        '--log-format=[log format]:format:(text color json)' \
        '--log-timestamp[include timestamp in log output]' \
        '--force[force building outside of a container]' \
        '--whitelist-var-run[ignore /var/run when snapshotting]' \
        '--ignore-var-run[ignore /var/run when snapshotting]' \
        '(-f --dockerfile)'{-f+,--dockerfile=}'[Dockerfile path]:file:_files -g "Dockerfile*"' \
        '(-c --context)'{-c+,--context=}'[build context path]:dir:_files -/' \
        '--context-sub-path=[subpath within build context]:path:' \
        '(-b --bucket)'{-b+,--bucket=}'[GCS bucket containing context tarball]:name:' \
        '*'{-d+,--destination=}'[push destination registry (repeat)]:dest:' \
        '--snapshot-mode=[file attributes inspected during snapshot]:mode:(full redo time)' \
        '--custom-platform=[build platform override]:platform:' \
        '*--build-arg=[build arg KEY=VALUE]:kv:' \
        '--insecure[push to insecure registry over plain HTTP]' \
        '--skip-tls-verify[push ignoring TLS verify]' \
        '--insecure-pull[pull from insecure registry over plain HTTP]' \
        '--skip-tls-verify-pull[pull ignoring TLS verify]' \
        '--push-retry=[number of retries for push]:n:' \
        '--push-ignore-immutable-tag-errors[ignore known tag-immutability errors on push]' \
        '--image-fs-extract-retry=[retries for image FS extraction]:n:' \
        '--image-download-retry=[retries for downloading the remote image]:n:' \
        '--kaniko-dir=[kaniko directory]:dir:_files -/' \
        '--tar-path=[save image as tarball instead of pushing]:file:_files' \
        '--single-snapshot[take a single snapshot at end of build]' \
        '--reproducible[strip timestamps from image]' \
        '--target=[target build stage]:stage:' \
        '--no-push[do not push image to registry]' \
        '--no-push-cache[do not push cache layers to registry]' \
        '--cache-repo=[repository to use as cache]:repo:' \
        '--cache-dir=[local cache directory]:dir:_files -/' \
        '--digest-file=[file to save built image digest]:file:_files' \
        '--image-name-with-digest-file=[file to save image name+digest]:file:_files' \
        '--image-name-tag-with-digest-file=[file to save image name+tag+digest]:file:_files' \
        '--oci-layout-path=[path to save OCI image layout]:dir:_files -/' \
        '--compression=[compression algorithm]:algo:(gzip zstd)' \
        '--compression-level=[compression level (-1 = default)]:n:' \
        '--cache[use cache when building image]' \
        '--compressed-caching[compress the cached layers]' \
        '--cleanup[clean filesystem at end]' \
        '--cache-ttl=[cache timeout (Go duration)]:duration:' \
        '*--insecure-registry=[insecure registry (repeat)]:registry:' \
        '*--skip-tls-verify-registry=[skip TLS verify (repeat)]:registry:' \
        '*--registry-certificate=[registry TLS certificate host=path]:kv:' \
        '*--registry-client-cert=[registry mTLS client cert host=cert,key]:kv:' \
        '--registry-map=[mirror registries host=new;...]:map:' \
        '*--registry-mirror=[pull-through mirror registry (repeat)]:host:' \
        '--skip-default-registry-fallback[do not fall back to default registry]' \
        '*--label=[image metadata label]:label:' \
        '--skip-unused-stages[build only stages used by target]' \
        '--use-new-run[experimental run-detection without snapshots]' \
        '--git=[git branch to clone if context is a git repo]:branch:' \
        '--cache-copy-layers[cache COPY layers]' \
        '--cache-run-layers[cache RUN layers]' \
        '*--ignore-path=[paths to ignore in snapshot (repeat)]:path:' \
        '--force-build-metadata[force-add metadata layers to build image]' \
        '--skip-push-permission-check[skip push permission check]'
}

_kaniko-executor "$@"
