#compdef kyverno2
# _kyverno2 — Nirmata Kyverno kyverno2 CLI command-line frontend wrapping the Kyverno CNCF Graduated Kubernetes-native open-source policy engine that uses policies as Kubernetes resources YAML-based written-in-Go-style ValidatingWebhookConfiguration-MutatingWebhookConfiguration-mutate-validate-generate-cleanup-imageVerify-policy-types K8s-resource-policies CEL-expression-cluster-policies signed-image-verification-Cosign-Notary policy create apply test fix migrate jp json oci docker docker-pull docker-push docker-config-file docker-image-format version completion (Nirmata Kyverno CNCF team Anubhav Singh Ritesh Patel Jim Bugwadia Shuting Zhao, Go); cobra
# upstream: https://kyverno.io/

_kyverno2() {
    local -a sub=(
        'apply:apply policies to resources'
        'create:create a new policy'
        'docs:generate CLI docs'
        'fix:fix policies/tests'
        'jp:run JMESPath query'
        'migrate:migrate policies'
        'oci:OCI operations'
        'test:test policies'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbosity]:n:' \
        '--verbosity=+[N]:n:' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--add_dir_header[add dir header]' \
        '--alsologtostderr[also log to stderr]' \
        '--log-format=+[f]:f:(text json)' \
        '--log_dir=+[dir]:dir:_files -/' \
        '--log_file=+[file]:file:_files' \
        '--logtostderr[log to stderr]' \
        '--policy=+[file/dir]:_files' \
        '*-p+[policy]:_files' \
        '*--policy=+[file/dir]:_files' \
        '--resource=+[file/dir]:_files' \
        '*-r+[resource]:_files' \
        '*--resource=+[file/dir]:_files' \
        '--values-file=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[values file]:file:_files' \
        '--variables=+[k=v]:str:' \
        '*--variables=+[k=v]:str:' \
        '--user-info=+[file]:file:_files' \
        '--registry[allow registry calls]' \
        '--cluster[connect to cluster]' \
        '-c[connect to cluster]' \
        '--policy-report[generate PolicyReport]' \
        '--stdin[read from stdin]' \
        '--git-branch=+[name]:str:' \
        '-b+[git branch]:str:' \
        '--audit-warn[audit warn]' \
        '--exception=+[file]:file:_files' \
        '*--exception=+[file]:file:_files' \
        '--exceptions=+[file]:file:_files' \
        '*--exceptions=+[file]:file:_files' \
        '--generate-exceptions[generate exceptions]' \
        '--generated-exceptions-ttl=+[d]:str:' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '--detailed-results[detailed results]' \
        '--remove-color[no color]' \
        '--bail[bail on first failure]' \
        '--continue-on-fail[continue on fail]' \
        '--save[save results]' \
        '--target-resource=+[file]:_files' \
        '*--target-resource=+[file]:_files' \
        '--target-resources=+[file]:_files' \
        '--warn-no-pass[warn no pass]' \
        '--cluster-context=+[name]:str:' \
        '--imageRegistry[image registry]' \
        '--imageRegistry-username=+[user]:_users' \
        '--imageRegistry-password=+[password]:str:' \
        '--imageRegistry-disable-keychain-pull[disable keychain pull]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kyverno subcommand' sub ;;
        args)
            case $words[1] in
                apply|test) _arguments '*:policy:_files' ;;
                create) _arguments '1:type:(policy validate mutate generate cleanup image-verify exception metrics-config user-info values test)' '*:arg:' ;;
                jp) _arguments '1:op:(function parse query)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kyverno2 "$@"
