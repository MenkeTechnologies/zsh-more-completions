#compdef microsocks
# Documentation: https://github.com/rofl0r/microsocks (sockssrv.c getopt)
# Reference accessed: 2026-05-30
# microsocks — tiny SOCKS5 proxy server (single-binary, < 1000 SLOC). Supports user/pass auth.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-1[auth_once mode: authenticated IPs added to whitelist for future passwordless access]' \
  '-q[disable logging output (quiet mode)]' \
  '-i+[listening IP address (default 0.0.0.0)]:ip:' \
  '-p+[listening port (default 1080)]:port:' \
  '-u+[username for authentication (use with -P)]:user:' \
  '-P+[password for authentication (use with -u)]:pass:' \
  '-b+[bind outgoing connections to this IP]:ip:' \
  '-w+[comma-separated whitelist of IPs allowed without auth]:csv-ips:' \
  && ret=0

return ret
