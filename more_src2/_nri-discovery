#compdef nri-discovery
# Documentation: https://github.com/newrelic/nri-discovery-kubernetes
# Reference accessed: 2026-05-19
# Verified: upstream repo README at the URL above. STUB - upstream documents
# only `--discover-services`; remaining flags inherited from infra-integrations-sdk
# args.DefaultArgumentList.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--discover-services[discover Kubernetes services instead of pods]' \
  '-verbose[print more information to logs]' \
  '-pretty[print pretty formatted JSON]' \
  '-metrics[publish metrics data]' \
  '-inventory[publish inventory data]' \
  '-events[publish events data]' \
  '-metadata[add customer-defined key-value attributes]' \
  '-nri_cluster=[cluster name]:cluster:' \
  '-nri_service=[service name]:service:' \
  '*::nri-discovery args:_files' && ret=0
return ret
