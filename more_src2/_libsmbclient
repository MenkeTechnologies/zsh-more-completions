#compdef smbclient-tester libsmbclient-test
# _libsmbclient — Samba libsmbclient test harness (small libsmbclient/example binaries used to verify Samba client library behaviour against a remote SMB server; -U user, -W workgroup, -d debug level, -k Kerberos, -E send messages to stderr, -L list shares, -N no password, -O socket options, -P always print SMB version, -V version, -h help; positional argument is the //server/share URI)
# upstream: https://github.com/samba-team/samba (libsmbclient)
# Common flag shape from samba/samba source3/libsmb/test_* on tip.

_libsmbclient() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-U+[user]:user:_users' \
        '-W+[workgroup]:workgroup:' \
        '-d+[debug level]:level:' \
        '-k[Kerberos]' \
        '-E[stderr messages]' \
        '-L+[list shares]:host:_hosts' \
        '-N[no password]' \
        '-O+[socket options]:options:' \
        '-P[print SMB version]' \
        '*:share URI:'
}

_libsmbclient "$@"
