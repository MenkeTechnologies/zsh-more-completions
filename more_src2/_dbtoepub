#compdef dbtoepub
# Documentation: https://github.com/docbook/xslt10-stylesheets/blob/master/xsl/epub/bin/dbtoepub
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(-c --css)'{-c,--css}'[use FILE for CSS on generated XHTML]:stylesheet:_files -g "*.css"'
    '(-d --debug)'{-d,--debug}'[show debugging output]'
    '(-f --font)'{-f,--font}'[embed OTF font file in epub]:font file:_files -g "*.(otf|OTF)"'
    '(-h --help)'{-h,--help}'[display usage info]'
    '(-o --output)'{-o,--output}'[output epub filename]:output file:_files -g "*.epub"'
    '(-s --stylesheet)'{-s,--stylesheet}'[XSL customization layer]:xsl file:_files -g "*.xsl"'
    '(-v --verbose)'{-v,--verbose}'[verbose output]'
    '*:DocBook file:_files -g "*.xml"'
)

_arguments -s -S $arguments
