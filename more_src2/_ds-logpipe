# Documentation: https://github.com/389ds/389-ds-base/blob/main/ldap/admin/src/scripts/ds-logpipe.py
# Reference accessed: 2026-05-16
# Verified: upstream ldap/admin/src/scripts/ds-logpipe.py.

# ds-logpipe: 389-DS named-pipe log buffer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-m --maxlines)'{-m,--maxlines=}'[lines to buffer (default 1000)]:n:' \
  '(-u --userid)'{-u,--userid=}'[user owning pipe and created files]:user:_users' \
  '(-s --serverpidfile)'{-s,--serverpidfile=}'[server PID file to track]:file:_files' \
  '(-t --servertimeout)'{-t,--servertimeout=}'[server timeout (use with -s)]:seconds:' \
  '--serverpid=[server PID to track]:pid:' \
  '(-p --plugin)'{-p,--plugin=}'[plugin .py file]:file:_files -g "*.py"' \
  '*:named pipe path:_files' && ret=0
return ret
