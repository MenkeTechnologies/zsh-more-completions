#compdef mlc
# Documentation: https://github.com/becheran/mlc/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --debug)'{-d,--debug}'[print debug information]' \
  '(-o --offline)'{-o,--offline}'[do not check web links]' \
  '--no-web-links[alias for --offline]' \
  '*--do-not-warn-for-redirect-to=[comma-separated redirect URLs to ignore]:links:' \
  '(-e --match-file-extension)'{-e,--match-file-extension}'[require exact file extension when resolving files]' \
  '*'{-p,--ignore-path=}'[comma-separated paths to skip]:paths:' \
  '*'{-i,--ignore-links=}'[comma-separated link URLs to skip]:links:' \
  '*'{-t,--markup-types=}'[comma-separated markup types]:types:(md html)' \
  {-T,--throttle=}'[delay in ms between HTTP requests to same host]:delay:' \
  {-r,--root-dir=}'[root directory for relative paths]:directory:_files -/' \
  '(-g --gitignore)'{-g,--gitignore}'[skip files ignored by git]' \
  '--csv=[write CSV report to file]:file:_files' \
  '(-u --gituntracked)'{-u,--gituntracked}'[skip files untracked by git]' \
  '*'{-f,--files=}'[comma-separated files to check]:files:_files' \
  '*'{-H,--http-headers=}'[comma-separated Name\: Value HTTP headers]:headers:' \
  '1::directory:_files -/'
