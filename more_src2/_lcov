#compdef lcov
# Documentation: https://man.archlinux.org/man/lcov.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for lcov (code coverage)

_lcov() {
  local curcontext="$curcontext" state line ret=1

  _arguments -s -S \
    '(-c --capture)'{-c,--capture}'[capture coverage data]' \
    '(-z --zerocounters)'{-z,--zerocounters}'[reset execution counts to zero]' \
    '(-l --list)'{-l,--list}'[list contents of tracefile]:tracefile:_files' \
    '(-a --add-tracefile)'{-a,--add-tracefile}'[aggregate tracefiles]:tracefile:_files' \
    '(-e --extract)'{-e,--extract}'[extract data from tracefile]:tracefile:_files' \
    '(-r --remove)'{-r,--remove}'[remove data from tracefile]:tracefile:_files' \
    '--summary[show summary of tracefile]:tracefile:_files' \
    '(-o --output-file)'{-o,--output-file}'+[output file]:file:_files' \
    '(-d --directory)'{-d,--directory}'+[use .da files in directory]:directory:_files -/' \
    '(-b --base-directory)'{-b,--base-directory}'+[base directory for relative paths]:directory:_files -/' \
    '(-k --kernel-directory)'{-k,--kernel-directory}'+[limit kernel coverage to subdirectory]:directory:_files -/' \
    '--build-directory=[search for .gcno files]:directory:_files -/' \
    '--source-directory=[add directory to source search path]:directory:_files -/' \
    '(-f --follow)'{-f,--follow}'[follow symbolic links when searching]' \
    '(-i --initial)'{-i,--initial}'[capture initial zero coverage data]' \
    '(-t --test-name)'{-t,--test-name}'+[set test name identifier]:name:' \
    '--config-file=[use custom configuration file]:file:_files' \
    '*--rc=[override configuration directive]:setting=value:' \
    '--branch-coverage[include branch coverage data]' \
    '--mcdc-coverage[retain MC/DC coverage data]' \
    '*--include=[include matching source files]:pattern:' \
    '*--exclude=[exclude matching source files]:pattern:' \
    '*--erase-functions=[exclude matching functions]:pattern:' \
    '*--omit-lines=[exclude matching lines]:pattern:' \
    '*--substitute=[regex substitute on paths]:regex:' \
    '--external[include data from external source files]' \
    '--no-external[ignore data from external source files]' \
    '--checksum[create checksums]' \
    '--no-checksum[do not create checksums]' \
    '--version-script=[compare file version IDs]:script:_files' \
    '--resolve-script=[find sources via script]:script:_files' \
    '(-j --parallel)'{-j,--parallel}'+[enable parallel processing]:N:' \
    '--memory=[limit memory in parallel execution]:MB:' \
    '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
    '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
    '--debug[enable debug messaging]' \
    '--msg-log=[log errors and warnings]:file:_files' \
    '*--ignore-errors=[continue after specified errors]:errors:' \
    '--prune-tests[identify unique tracefiles]' \
    '--map-functions[list functions with coverage]' \
    '--intersect[merge coverage data intersection]' \
    '--subtract[remove coverage data from union]' \
    '--gcov-tool=[specify gcov location]:tool:_command_names -e' \
    '--demangle-cpp[demangle C++ function names]' \
    '--compat=[set compatibility modes]:mode:' \
    '--compat-libtool[enable libtool compatibility]' \
    '--no-compat-libtool[disable libtool compatibility]' \
    '--context-script=[script collecting execution context]:script:_files' \
    '--criteria-script=[test acceptance criteria]:script:_files' \
    '--comment=[append comment to output]:text:' \
    '--large-file[handle large files]' \
    '--to-package=[package coverage data]:file:_files' \
    '--from-package=[import packaged coverage data]:file:_files' \
    '--no-markers[ignore source exclusion markers]' \
    '--no-recursion[do not recurse into subdirectories]' \
    '--sort-input[sort filenames before processing]' \
    '--list-full-path[list full paths]' \
    '--no-list-full-path[truncate paths]' \
    '--preserve[keep intermediate files]' \
    '*--filter=[apply coverpoint filter]:filter:' \
    '--forget-test-names[ignore test case identifiers]' \
    '--fail-under-lines=[exit if line coverage below threshold]:pct:' \
    '--fail-under-branches=[exit if branch coverage below threshold]:pct:' \
    '--expect-message-count=[validate message count]:spec:' \
    '--keep-going[continue despite errors]' \
    '--tempdir=[set temporary file directory]:dir:_files -/' \
    '(- *)'{-h,--help}'[display help]' \
    '(- *)--version[display version]' \
    && ret=0

  return ret
}

_lcov "$@"
