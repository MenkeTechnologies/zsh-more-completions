#compdef k3s-etcd-snapshot
# _k3s-etcd-snapshot — manage k3s etcd snapshots (k3s-io/k3s)
# upstream: https://github.com/k3s-io/k3s
# Subcommands and flags from pkg/cli/cmds/etcd_snapshot.go (urfave/cli).

_k3s-etcd-snapshot() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--debug[turn on debug logging]' \
        '(-c --config)'{-c+,--config=}'[k3s config file]:file:_files' \
        '--log=[log file]:file:_files' \
        '--alsologtostderr[log to standard error as well as file]' \
        '--node-name=[node name]:name:' \
        '--data-dir=[data directory]:dir:_files -/' \
        '(-t --etcd-token)'{-t+,--etcd-token=}'[shared secret for etcd]:token:' \
        '(-s --etcd-server)'{-s+,--etcd-server=}'[etcd server URL]:url:_urls' \
        '--dir=[snapshot directory]:dir:_files -/' \
        '--name=[snapshot base name]:name:' \
        '--snapshot-compress[compress etcd snapshot]' \
        '--snapshot-retention=[number of snapshots to retain]:n:' \
        '--s3[enable backup to S3]' \
        '--s3-endpoint=[S3 endpoint URL]:url:_urls' \
        '--s3-endpoint-ca=[S3 endpoint CA cert]:file:_files' \
        '--s3-skip-ssl-verify[disable S3 SSL verification]' \
        '--s3-access-key=[S3 access key]:key:' \
        '--s3-secret-key=[S3 secret key]:key:' \
        '--s3-session-token=[S3 session token]:token:' \
        '--s3-bucket=[S3 bucket name]:name:' \
        '--s3-bucket-lookup-type=[S3 bucket lookup type]:type:(auto dns path)' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                save:'trigger an on-demand etcd snapshot'
                list:'list etcd snapshots'
                prune:'prune snapshots over retention limit'
                delete:'delete one or more snapshots'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                delete) _arguments '*:snapshot name:' ;;
            esac
            ;;
    esac
}

_k3s-etcd-snapshot "$@"
