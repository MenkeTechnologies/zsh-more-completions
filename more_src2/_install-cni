#compdef install-cni
# _install-cni — Istio CNI node-agent installer (cobra; writes the chained Istio CNI conflist + manages the CNI socket)
# upstream: https://github.com/istio/istio
# Flag names from cni/pkg/cmd/root.go + cni/pkg/constants/constants.go on tip.

_install-cni() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--cni-conf-name=[name of the CNI configuration file]:name:' \
        '--chained-cni-plugin=[whether to chain into an existing CNI conflist]:bool:(true false)' \
        '--cni-network-config=[CNI configuration template as a string]:json:' \
        '--cni-network-config-file=[CNI configuration template as a file]:file:_files' \
        '--istio-owned-cni-config[install a standalone Istio-owned CNI config]' \
        '--istio-owned-cni-config-filename=[filename for the Istio-owned CNI config]:name:' \
        '--log-level=[fallback log level for the CNI config]:level:(debug info warn error fatal)' \
        '--kubeconfig-mode=[file mode for the generated kubeconfig]:octal:' \
        '--cni-conf-group-read[set group-read on the generated CNI conf]' \
        '--mounted-cni-net-dir=[directory in container where CNI networks are installed]:dir:_files -/' \
        '--cni-agent-run-dir=[node-agent writable path for sockets]:dir:_files -/' \
        '--kube-ca-file=[CA file for the generated kubeconfig]:file:_files' \
        '--skip-tls-verify[skip kube API TLS verification]' \
        '--monitoring-port=[Prometheus metrics port]:port:' \
        '--log-uds-socket=[UDS path for plugin-side logs]:socket:_files' \
        '--ztunnel-uds-address=[UDS path for ztunnel commands]:socket:_files' \
        '--cni-event-address=[UDS path for plugin events]:socket:_files' \
        '--exclude-namespaces=[csv of namespaces excluded from ambient enrolment]:csv:' \
        '--pod-namespace=[namespace running this agent]:ns:' \
        '--ambient-enabled[enable ambient mode]' \
        '--ambient-enablement-selector=[label selector for ambient enrolment]:sel:' \
        '--ambient-dns-capture[enable ambient DNS capture]' \
        '--ambient-ipv6[enable ambient IPv6]' \
        '--ambient-disable-safe-upgrade[disable ambient safe-upgrade]' \
        '--ambient-reconcile-pod-rules-on-startup[reconcile pod rules at startup]' \
        '--enable-ambient-detection-retry[retry ambient mode detection]' \
        '--native-nftables[use nftables instead of iptables]' \
        '--repair-enabled[enable repair controller]' \
        '--repair-delete-pods[delete broken pods rather than repair]' \
        '--repair-repair-pods[reinitialize broken pods in place]' \
        '--repair-label-pods[label broken pods]' \
        '--repair-broken-pod-label-key=[label key marking broken pods]:key:' \
        '--repair-broken-pod-label-value=[label value marking broken pods]:value:' \
        '--repair-node-name=[only manage this node]:node:' \
        '--repair-sidecar-annotation=[annotation that records sidecar status]:ann:' \
        '--repair-init-container-name=[name of the init container]:name:' \
        '--repair-init-container-termination-message=[termination message to match]:msg:' \
        '--repair-init-container-exit-code=[exit code to match]:n:' \
        '--repair-label-selectors=[label selector for repair scope]:sel:' \
        '--repair-field-selectors=[field selector for repair scope]:sel:'
}

_install-cni "$@"
