#compdef recoverpy
# Documentation: https://github.com/PabloLec/RecoverPy
# Reference accessed: 2026-05-20
# Verified: upstream recoverpy/__init__.py defines a single argparse flag
# (-d/--debug); the prior -p/--partition was a fabrication.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --debug)'{-d,--debug}'[enable logging]' && ret=0

return ret
