#compdef pcm-msr
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-msr.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-msr: Intel PCM raw MSR read/write helper
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[show version]' \
  '-w[write value before reading the MSR]:value:' \
  '-c[core list (default 0)]:cores:' \
  '-a[operate on all cores]' \
  '-x[show core numbers in hex]' \
  '-d[decimal output]' \
  '-b[read/write specific bit range]:low\:high:' \
  '-s[iteration interval in seconds]:seconds:' \
  '-o[write iteration results to file]:file:_files' \
  '*:MSR register (hex):' && ret=0
return ret
