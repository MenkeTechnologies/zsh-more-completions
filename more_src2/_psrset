#compdef psrset
# Documentation: man psrset(8)
# Source: netbsd/src usr.sbin/psrset — processor set control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[assign CPUs to processor set]' \
    '-b[bind processes to processor set]' \
    '-c[create processor set, optionally with CPUs]' \
    '-d[delete processor set]' \
    '-e[execute command in processor set]' \
    '-i[list processor sets and member CPUs]' \
    '-p[list CPUs with their processor sets]' \
    '-r[return CPUs to default set]' \
    '-u[bind processes to system default set]' \
    '*::setid, cpuid, pid, or command:_default' \
    && ret=0

return ret
