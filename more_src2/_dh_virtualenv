#compdef dh_virtualenv
# _dh_virtualenv — Debian packaging with self-contained virtualenv (spotify/dh-virtualenv)
# upstream: https://github.com/spotify/dh-virtualenv
# Flags from dh_virtualenv(1) man page.

_dh_virtualenv() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
        '*'{-p+,--package=}'[act on PACKAGE]:package:' \
        '*'{-N+,--no-package=}'[skip PACKAGE]:package:' \
        '*--extra-index-url=[extra index URL for pip]:url:' \
        '*--preinstall=[preinstall PACKAGE before pip]:package:' \
        '--pip-tool=[tool to install requirements]:tool:' \
        '*--extra-pip-arg=[extra arg for pip]:arg:' \
        '*--extra-virtualenv-arg=[extra arg for virtualenv]:arg:' \
        '--index-url=[base PyPI URL]:url:' \
        '--setuptools[use setuptools instead of distribute]' \
        '--install-suffix=[override virtualenv install suffix]:suffix:' \
        '--upgrade-pip[force upgrade pip in virtualenv]' \
        '--requirements=[requirements file]:file:_files' \
        '--setuptools-test[run setup.py test on build]' \
        '--python=[Python interpreter path]:path:_files' \
        '--builtin-venv[use built-in venv of Python 3]' \
        '--skip-install[do not run pip install .]'
}

_dh_virtualenv "$@"
