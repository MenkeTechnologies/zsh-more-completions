#compdef dosemu
# Documentation: https://manpages.debian.org/stretch/dosemu/dosemu.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian stretch dosemu(1) manpage OPTIONS section. Wrapper script;
# dosemu.bin(1) has the larger flag set.

# dosemu: DOS emulator (wrapper script)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--version[show version]' \
  '-dumb[use dumb terminal mode]' \
  '-quiet[no startup comment, no prompting]' \
  '-input[simulate keystrokes after DOS boot]:keystroke string:' \
  '-s[invoke dosemu via sudo]' \
  '-install[(re-)install DOS for DOSEMU]:bootdir:_files -/' \
  '*::extra args (passed to dosemu.bin):_files' && ret=0
return ret
