#compdef jr
# Documentation: https://github.com/jrnd-io/jr
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# cobra; top-level commands from pkg/cmd/*.go rootCmd.AddCommand(); global
# persistent flags from pkg/cmd/root.go init()

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'template:group template commands'
  'run:run a template (shortcut)'
  'list:list templates (shortcut)'
  'show:show template (shortcut)'
  'server:HTTP server mode'
  'emitter:configure and run emitters'
  'producer:kafka producer helpers'
  'function:list JR template functions'
  'man:detailed function reference'
  'createTopic:create Kafka topic'
  'version:print version'
)

_arguments -s -S \
  '--jr_system_dir=[system templates dir]:dir:_directories' \
  '--jr_user_dir=[user templates dir]:dir:_directories' \
  '--log_level=[zerolog log level]:level:(trace debug info warn error fatal panic)' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'jr command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
