#compdef qrexec-client qrexec-client-vm qrexec-policy qrexec-policy-graph
# Documentation: https://github.com/QubesOS/qubes-core-qrexec/blob/master/daemon/qrexec-client.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-d+[target VM (domain) name]:dom:' \
  '-l+[local program command]:cmd:_command_names' \
  '-c+[connect to existing process (service trigger response)]:cmd:' \
  '-e[exit after sending command]' \
  '-E[always exit with code 0]' \
  '-p[send data before stdin]' \
  '-t[replace problematic bytes with underscore in stdout]' \
  '-T[replace problematic bytes with underscore in stderr]' \
  '-w+[connection timeout override (seconds, default 5)]:secs:' \
  '-W[wait for connection end even in VM-VM mode]' \
  '-k[kill the domain before exiting]' \
  '--socket-dir=[qrexec socket directory]:dir:_files -/' \
  '--no-exit-code[always exit with 0]' \
  '--prefix-data=[data to send before stdin]:data:' \
  '--use-stdin-socket[use fd 0 (socket) for stdin/stdout]' \
  '*: :' && ret=0

return ret
