#compdef ipsec-iked-ctl ikectl
# Documentation: https://man.openbsd.org/ikectl.8
# Reference accessed: 2026-05-16
# Verified: OpenBSD ikectl(8) manpage.

# ikectl: OpenBSD iked(8) control utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'active:make peer active'
  'passive:make peer passive'
  'couple:couple SADB'
  'decouple:decouple SADB'
  'load:load config file'
  'log:set log mode'
  'monitor:monitor iked events'
  'reload:reload config'
  'reset:reset state'
  'show:show state'
  'ca:CA management'
)
_arguments -C \
  '-q[suppress confirmation prompts]' \
  '-s[control socket (default /var/run/iked.sock)]:socket:_files' \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'ikectl command' commands && ret=0 ;;
esac
return ret
