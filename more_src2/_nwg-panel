#compdef nwg-panel
# Documentation: https://github.com/nwg-piotr/nwg-panel/wiki/Installation
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --config)'{-c,--config=}'[specify a different config file name]:config file:_files' \
  '(-s --style)'{-s,--style=}'[specify a different css file name]:css file:_files' \
  '(-r --restore)'{-r,--restore}'[restore default config and style.css]' && ret=0

return ret
