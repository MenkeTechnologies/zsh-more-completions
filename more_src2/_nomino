#compdef nomino
# Documentation: https://github.com/yaa110/nomino
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --dir)'{-d,--dir}'=[working directory]:directory:_directories' \
  '(-r --regex)'{-r,--regex}'=[regex pattern]:pattern' \
  '(-s --sort)'{-s,--sort}'=[sort order]:order:(asc desc)' \
  '(-m --map --from-file)'{-m,--map}'=[map file for renaming]:file:_files' \
  '--from-file=[map file for renaming (alias for --map)]:file:_files' \
  '(-g --generate)'{-g,--generate}'=[store JSON map after renaming]:path:_files' \
  '(-k --mkdir)'{-k,--mkdir}'[create missing parent directories]' \
  '(-E --no-extension)'{-E,--no-extension}'[preserve file extensions in sort/regex modes]' \
  '(-t --test --dry-run)'{-t,--test}'[test mode without renaming]' \
  '--dry-run[alias for --test]' \
  '(-w --overwrite)'{-w,--overwrite}'[overwrite output files]' \
  '(-q --quiet)'{-q,--quiet}'[suppress stdout output]' \
  '--depth=[subdirectory depth in regex mode]:depth' \
  '--max-depth=[maximum subdirectory depth in regex mode]:depth' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:input pattern' && ret=0

return ret
