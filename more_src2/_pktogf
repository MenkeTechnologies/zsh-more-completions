#compdef pktogf
# Documentation: pktogf --help (TeX Live 2026)
# Source: translate a packed bitmap font (PK) to GF format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '1:pk font:_files -g "*.pk"' \
    '2:gf output:_files -g "*gf"' \
    && ret=0

return ret
