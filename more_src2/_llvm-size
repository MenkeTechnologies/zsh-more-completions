#compdef llvm-size
# _llvm-size — LLVM size (LLVM project, C++); print size of object file sections, GNU size-compatible
# upstream: https://github.com/llvm/llvm-project

_llvm-size() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-A[sysv format]' \
        '--format=sysv[sysv format]' \
        '-B[berkeley format]' \
        '--format=berkeley[berkeley format]' \
        '--format=darwin[darwin format]' \
        '-G[GNU format]' \
        '--format=gnu[GNU format]' \
        '-d[decimal]' \
        '--radix=10[decimal]' \
        '-o[octal]' \
        '--radix=8[octal]' \
        '-x[hex]' \
        '--radix=16[hex]' \
        '-t[print totals]' \
        '--totals[print totals]' \
        '--common[print common syms too]' \
        '--target=+[target]:target:' \
        '-arch+[arch]:arch:' \
        '*:file:_files'
}

_llvm-size "$@"
