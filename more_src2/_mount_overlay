#compdef mount_overlay
# Documentation: man mount_overlay(8)
# Source: netbsd/src sbin/mount_overlay — mount an overlay layer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:overlay path:_files -/' \
    '2:mount point:_files -/' \
    && ret=0

return ret
