#compdef m4 gm4
# Documentation: m4 --help (GNU M4)
# Source: GNU M4 — macro processor (autoconf foundation; processes macros in FILEs).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[display help and exit]' \
    '(- *)--version[output version information and exit]' \
    '(-E --fatal-warnings)'{-E,--fatal-warnings}'[stop execution after first warning]' \
    '(-e --interactive)'{-e,--interactive}'[unbuffer output and ignore interrupts]' \
    '(-P --prefix-builtins)'{-P,--prefix-builtins}'[force "m4_" prefix on all builtins]' \
    '(-Q --quiet --silent)'{-Q,--quiet,--silent}'[suppress some builtin warnings]' \
    '*'{-D,--define=}'[define NAME has having VALUE (or empty)]:NAME[=VALUE]:' \
    '*'{-I,--include=}'[append directory to include path]:dir:_files -/' \
    '(-s --synclines)'{-s,--synclines}'[generate "#line NUM FILE" directives]' \
    '*'{-U,--undefine=}'[undefine NAME]:name:' \
    '(-G --traditional)'{-G,--traditional}'[suppress all GNU extensions]' \
    '(-H --hashsize)'{-H,--hashsize=}'[set symbol lookup hash table size]:prime:' \
    '(-L --nesting-limit)'{-L,--nesting-limit=}'[artificial nesting limit]:N:' \
    '(-F --freeze-state)'{-F,--freeze-state=}'[produce frozen state file]:file:_files' \
    '(-R --reload-state)'{-R,--reload-state=}'[reload frozen state file]:file:_files' \
    '(-d --debug)'{-d,--debug=-}'[debug level (default flags aeq)]::flags:' \
    '(-l --arglength)'{-l,--arglength=}'[restrict macro tracing size]:n:' \
    '(-o --error-output)'{-o,--error-output=}'[redirect debug+trace output]:file:_files' \
    '*'{-t,--trace=}'[trace NAME]:macro:' \
    '*:input file:_files -g "*.{m4,ac,mk}"' \
    && ret=0

return ret
