#compdef patroni
# Documentation: https://patroni.readthedocs.io/en/latest/patroni_configuration.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--validate-config[validate configuration and exit]' \
  '(-i --ignore-listen-port)'{-i,--ignore-listen-port}'[ignore bind failures for listen ports]' \
  '1:config file:_files -g "*.(yml|yaml)"' && ret=0

return ret
