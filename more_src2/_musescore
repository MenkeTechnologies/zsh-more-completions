#compdef musescore mscore
# Documentation: https://manpages.debian.org/unstable/musescore/musescore.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian musescore(1) manpage and MuseScore Studio
# Handbook command-line usage page at the URL above.

# Zsh completion for MuseScore music notation editor

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--long-version[show long version with git revision]' \
  '(-a --use-audio)'{-a,--use-audio}'[use specified audio driver]:driver:' \
  '(-b --bitrate)'{-b,--bitrate}'[MP3 output bitrate (kbit/s)]:bitrate:' \
  '(-c --config-folder)'{-c,--config-folder}'[override configuration directory]:path:_files -/' \
  '(-d --debug)'{-d,--debug}'[start in debug mode]' \
  '-D[monitor resolution in DPI]:DPI:' \
  '--monitor-resolution=[monitor resolution in DPI]:DPI:' \
  '(-E --install-extension)'{-E,--install-extension}'[install extension file]:file:_files' \
  '(-e --experimental)'{-e,--experimental}'[enable experimental features]' \
  '(-F --factory-settings)'{-F,--factory-settings}'[use built-in presets, delete preferences]' \
  '(-f --force)'{-f,--force}'[force conversion, ignore corruption warnings]' \
  '(-I --dump-midi-in)'{-I,--dump-midi-in}'[display MIDI input on console]' \
  '(-i --load-icons)'{-i,--load-icons}'[load icons from filesystem]' \
  '(-j --job)'{-j,--job}'[process JSON conversion job file]:job file:_files -g "*.json"' \
  '(-L --layout-debug)'{-L,--layout-debug}'[layout debug mode]' \
  '(-M --midi-operations)'{-M,--midi-operations}'[MIDI import operations file]:file:_files' \
  '(-m --no-midi)'{-m,--no-midi}'[disable MIDI input]' \
  '(-n --new-score)'{-n,--new-score}'[start with New Score wizard]' \
  '(-O --dump-midi-out)'{-O,--dump-midi-out}'[display MIDI output on console]' \
  '(-o --export-to)'{-o,--export-to}'[export to file]:output file:_files -g "*.{pdf,png,svg,mp3,wav,ogg,flac,mid,midi,musicxml,mxl,mscz,mscx}"' \
  '(-P --export-score-parts)'{-P,--export-score-parts}'[append parts to PDF output]' \
  '(-p --plugin)'{-p,--plugin}'[execute plugin by name]:plugin name:' \
  '(-R --revert-settings)'{-R,--revert-settings}'[use built-in presets, keep preferences]' \
  '(-r --image-resolution)'{-r,--image-resolution}'[PNG export DPI (default 300)]:DPI:' \
  '(-S --style)'{-S,--style}'[load style file]:style file:_files -g "*.mss"' \
  '(-s --no-synthesizer)'{-s,--no-synthesizer}'[disable software synthesizer]' \
  '(-T --trim-image)'{-T,--trim-image}'[trim PNG/SVG whitespace (pixels)]:margin:' \
  '(-t --test-mode)'{-t,--test-mode}'[set test mode flag]' \
  '(-w --no-webview)'{-w,--no-webview}'[disable web view in Start Center]' \
  '(-x --gui-scaling)'{-x,--gui-scaling}'[scale GUI by factor]:factor:' \
  '--diff[print conditioned diff between scores]' \
  '--raw-diff[print raw diff between scores]' \
  '--no-fallback-font[do not use Bravura as fallback font]' \
  '--run-test-script=[run test script]:file:_files' \
  '--score-media=[export score media as JSON to stdout]:output file:_files -g "*.json"' \
  '--score-meta[export score metadata as JSON to stdout]' \
  '--score-parts[generate parts as separate files]' \
  '--score-parts-pdf[generate parts as JSON to stdout]' \
  '--score-transpose=[transpose and export as JSON]:transpose spec:' \
  '--sound-profile=[use specific sound profile]:profile:' \
  '--source-update[update source info in score]' \
  '--template-mode[save in template mode]' \
  '--highlight-config=[set highlight to SVG config]:file:_files -g "*.json"' \
  '*:file:_files -g "*.{mscz,mscx,musicxml,mxl,xml,mid,midi,cap,capx,gtp,gp3,gp4,gp5,gpx,bww,ove,sgu,pdf}"' && ret=0

return ret
