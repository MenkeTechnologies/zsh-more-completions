#compdef dwishellmath
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwishellmath.html
# Source: MRtrix3/mrtrix3 bin/dwishellmath — apply mrmath operation per b-value shell (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:input (DWI series):_files -g "*.{nii,nii.gz,mif}"' \
    '2:operation:(mean median sum product rms norm var std min max absmax magmax)' \
    '3:output image:_files' \
    && ret=0

return ret
