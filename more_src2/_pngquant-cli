#compdef pngquant-cli
# _pngquant-cli — Kornel Lesinski pngquant lossy PNG compressor CLI alias (kornelski team, C/Rust); custom argparse
# upstream: https://github.com/kornelski/pngquant

_pngquant-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--force[overwrite existing files]' \
        '-f[overwrite existing files]' \
        '--no-force[do not overwrite]' \
        '--quality=+[min-max]:str:' \
        '-Q+[min-max]:str:' \
        '--speed=+[1-11]:n:' \
        '-s+[1-11]:n:' \
        '--ext=+[extension]:str:' \
        '--output=+[file]:file:_files -g "*.png"' \
        '-o+[file]:file:_files -g "*.png"' \
        '--floyd=+[strength 0-1]:str:' \
        '--ordered[ordered dithering]' \
        '--nofs[no Floyd-Steinberg dithering]' \
        '--skip-if-larger[skip if larger]' \
        '--strip[strip all metadata]' \
        '--posterize=+[bits]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--map=+[file]:file:_files' \
        '--transbug[fix transparency bug]' \
        '*:files:_files -g "*.{png,PNG}"'
}

_pngquant-cli "$@"
