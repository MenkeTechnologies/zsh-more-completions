#compdef dcraw
# Documentation: source-direct extraction from upstream
# ncruces/dcraw mirror of Dave Coffin's dcraw.c (canonical).
# main() case-arm `switch(opt)` block decoded source-direct +
# the `puts(_("-X ..."))` documented-usage block in the help-
# print branch.  Enum autocompletes decoded source-direct from
# the documented [0-N] ranges in each `puts` line.
# Reference accessed: 2026-05-30 via gh api.
# Dave Coffin dcraw R189 — the canonical RAW-camera-image
# decoder by Dave Coffin (dcoffin@cybercom.net) that underlies
# libraw, RawTherapee, darktable, dcraw.js, and countless other
# RAW processing pipelines.  Adds support for 600+ camera
# models.  Sister tool to the heavily-covered RAW + photo
# processing family (rawtherapee/rawtherapee-cli, darktable/
# darktable-cli, digikam/digikam-cli, enfuse, enblend, exiftool,
# exiftran, exif, exiv2 all already in the corpus).

_arguments -s -S \
  '-v[print verbose messages]' \
  '-c[write image data to standard output]' \
  '-e[extract embedded thumbnail image]' \
  '-i[identify files without decoding them]' \
  '-z[change file dates to camera timestamp]' \
  '-w[use camera white balance, if possible]' \
  '-a[average the whole image for white balance]' \
  '-A+[average a grey-box for white balance (4 ints x y w h)]:x:y:w:h:' \
  '-r+[set custom white balance (4 floats r g b g)]:r:g:b:g:' \
  '(-M)+M[use the embedded camera color matrix]' \
  '(+M)-M[do not use the embedded camera color matrix]' \
  '-C+[correct chromatic aberration (2 floats r b)]:r:b:' \
  '-P+[fix dead pixels listed in this file]:file:_files' \
  '-K+[subtract dark-frame (16-bit raw PGM)]:file:_files -g "*.(pgm|raw)"' \
  '-k+[set the darkness level]:n:' \
  '-S+[set the saturation level]:n:' \
  '-n+[wavelet-denoising threshold]:n:' \
  '-H+[highlight mode]:mode:((0\:clip 1\:unclip 2\:blend 3\:rebuild-3 4\:rebuild-4 5\:rebuild-5 6\:rebuild-6 7\:rebuild-7 8\:rebuild-8 9\:rebuild-9))' \
  '-t+[flip image]:flip:((0\:none 3\:180-degrees 5\:90-CCW 6\:90-CW))' \
  '-o+[output colorspace OR output ICC profile file]:colorspace-or-icc:((0\:raw 1\:sRGB 2\:Adobe 3\:Wide 4\:ProPhoto 5\:XYZ 6\:ACES))' \
  '-p+[apply camera ICC profile from file (or "embed")]:file:_files -g "*.(icc|icm)"' \
  '-d[document mode (no color, no interpolation)]' \
  '-D[document mode without scaling (totally raw)]' \
  '-E[document mode + extra raw passes (stacking with -D/-d)]' \
  '-j[do not stretch or rotate raw pixels]' \
  '-W[do not automatically brighten the image]' \
  '-b+[adjust brightness (default 1.0)]:f:' \
  '-g+[custom gamma curve (2 floats p ts; default 2.222 4.5)]:p:ts:' \
  '-q+[interpolation quality]:q:((0\:bilinear 1\:VNG 2\:PPG 3\:AHD))' \
  '-h[half-size color image (twice as fast as -q 0)]' \
  '-f[interpolate RGGB as four colors]' \
  '-m+[apply a 3x3 median filter to R-G and B-G]:n:' \
  '-s+[select one raw image or "all" from each file]:select:' \
  '-6[write 16-bit instead of 8-bit]' \
  '-4[linear 16-bit (same as "-6 -W -g 1 1")]' \
  '-T[write TIFF instead of PPM]' \
  '-I[read RAW input from stdin instead of files]' \
  '*:RAW file:_files -g "*.(arw|ARW|cr2|CR2|cr3|CR3|crw|CRW|dng|DNG|nef|NEF|raf|RAF|raw|RAW|rw2|RW2|orf|ORF|pef|PEF|srw|SRW|x3f|X3F|mrw|MRW|3fr|3FR|fff|FFF|iiq|IIQ|kdc|KDC|nrw|NRW)"'
