#compdef disnix-build
# _disnix-build — distributed Nix store build over Disnix (svanderburg/disnix)
# upstream: https://github.com/svanderburg/disnix
# Flags from src/build/main.c (getopt_long).

_disnix-build() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-m --max-concurrent-transfers)'{-m+,--max-concurrent-transfers=}'[max concurrent closure transfers]:n:' \
        '1:manifest:_files'
}

_disnix-build "$@"
