#compdef ovhai
# Documentation: https://github.com/ovh/ovhai-cheat-sheet
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'login:authenticate'
  'me:show profile info'
  'upgrade:upgrade ovhai'
  'debug:debug helpers'
  'config:CLI config'
  'capabilities:list capabilities'
  'token:manage tokens'
  'job:manage jobs'
  'app:manage applications'
  'notebook:manage notebooks'
  'data:manage data buckets'
  'registry:manage container registries'
)

_arguments -C \
  '(-o --output)'{-o,--output}'=[output format]:fmt:(json yaml)' \
  '--watch[watch the resource]' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ovhai subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (config)
        _values 'config action' ls set && ret=0
        ;;
      (capabilities)
        _values 'capability' 'flavor' 'framework' 'editor' && ret=0
        ;;
      (token)
        _values 'token action' create && ret=0
        ;;
      (job)
        _values 'job action' ls run get logs exec push-data pull-data stop && ret=0
        ;;
      (app)
        _values 'app action' ls run get stop delete && ret=0
        ;;
      (notebook)
        _values 'notebook action' ls run start stop delete get && ret=0
        ;;
      (data)
        _values 'data action' ls upload delete && ret=0
        ;;
      (registry)
        _values 'registry action' ls add get delete && ret=0
        ;;
    esac
    ;;
esac

return ret
