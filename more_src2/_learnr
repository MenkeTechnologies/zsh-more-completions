#compdef learnr
# _learnr — Posit/RStudio learnr R package CLI for authoring interactive tutorials with embedded code exercises Shiny widgets quiz components and progress tracking (rstudio team, R); R argparse
# upstream: https://github.com/rstudio/learnr

_learnr() {
    local -a sub=(
        'run-tutorial:run a tutorial'
        'available-tutorials:list installed tutorials'
        'tutorial-options:show tutorial options'
        'restart-tutorial:restart a tutorial'
        'tutorial-event:emit event for tutorial'
        'tutor-event:tutor event'
        'submission:get submission state'
        'submissions:list submissions'
        'reset-tutorial:reset tutorial state'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'learnr subcommand' sub ;;
        args)
            case $words[1] in
                run-tutorial) _arguments \
                    '--package=+[package]:str:' \
                    '--shiny-args=+[csv]:str:' \
                    '--local=+[b]:b:(true false)' \
                    '--display.mode=+[m]:m:(auto normal showcase)' \
                    '--quiet[quiet]' \
                    '--clean[clean]' \
                    '--as-rstudio-job=+[b]:b:(true false)' \
                    '*:tutorial name:' ;;
                available-tutorials) _arguments \
                    '--package=+[package]:str:' ;;
                reset-tutorial|restart-tutorial) _arguments \
                    '--tutorial-id=+[id]:str:' \
                    '--user-id=+[id]:str:' ;;
            esac
            ;;
    esac
}

_learnr "$@"
