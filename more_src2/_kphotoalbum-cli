#compdef kphotoalbum-cli
# Documentation: https://manpages.debian.org/testing/kphotoalbum/kphotoalbum.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: no upstream binary named "kphotoalbum-cli" exists in the
# KDE/kphotoalbum project; only "kphotoalbum" is shipped. Removed
# invented --config/--export/--export-in-2-hands and mirrored the
# real kphotoalbum option set in case a distro symlinks this name.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options, including generic KDE and Qt options]' \
  '(- *)'{-v,--version}'[show version]' \
  '-c+[load alternate config file]:file:_files -g "*.xml"' \
  '--demo[start with a prebuilt set of demo images]' \
  '--import[import database (.kim) file]:file:_files -g "*.kim"' \
  '*:album xml:_files -g "*.xml"' && ret=0
return ret
