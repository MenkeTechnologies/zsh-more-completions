#compdef relayd
# _relayd — OpenBSD relayd (layer-3 and layer-7 load balancer + transparent proxy; configures pf(4) anchors for L3 redirection, handles L7 relays itself, monitors host groups for liveness)
# upstream: https://github.com/openbsd/src (usr.sbin/relayd)
# Flags from usr.sbin/relayd/relayd.c getopt + relayd.8 on tip.

_relayd() {
    _arguments \
        '-d[do not detach (foreground + log to stderr)]' \
        '-n[validate config + exit]' \
        '*-v[verbose (repeat for more)]' \
        '*-D+[define macro=value (overrides relayd.conf)]:macro=value:' \
        '-I+[CARP demote group]:group:' \
        '-P+[pid file]:file:_files' \
        '-f+[config file]:file:_files'
}

_relayd "$@"
