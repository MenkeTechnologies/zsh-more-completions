#compdef go-tool
# _go-tool — go tool subcommand wrapper; dispatch to bundled go tools (asm, cgo, compile, cover, etc.)
# upstream: https://pkg.go.dev/cmd/go

_go-tool() {
    local -a sub=(
        'addr2line:print line for address in binary'
        'asm:assemble Go source'
        'buildid:print build id'
        'cgo:translate cgo source'
        'compile:compile Go package'
        'covdata:cover data analyzer'
        'cover:analyze coverage profile'
        'dist:multi-tool dispatcher'
        'doc:show docs'
        'fix:run go fix'
        'link:link object files'
        'nm:list symbols'
        'objdump:disassemble executable'
        'pack:pack archive'
        'pprof:CPU/memory profile viewer'
        'preprofile:pre-load profile for PGO'
        'test2json:test JSON converter'
        'trace:execution trace viewer'
        'vet:run vet analyzers'
        'help:show help'
    )
    _arguments -C \
        '-n[print without running]' \
        '-x[print + run]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'go tool subcommand' sub ;;
    esac
}

_go-tool "$@"
