#compdef gmsh
# Documentation: https://manpages.debian.org/bookworm/gmsh/gmsh.1.en.html
# Reference accessed: 2026-05-30
# gmsh — Christophe Geuzaine & Jean-François Remacle's 3D finite-element
# mesh generator with a built-in CAD engine and post-processor. CLI drives
# both interactive GUI and headless batch meshing.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-help[show help]' \
  '(- *)-version[show version]' \
  '(- *)-info[detailed version info]' \
  '-[parse input files, then exit]' \
  '-0[output model, then exit]' \
  '-tol+[geometrical tolerance]:float:' \
  '(-1 -2 -3)-1[perform 1D mesh generation]' \
  '(-1 -2 -3)-2[perform 2D mesh generation]' \
  '(-1 -2 -3)-3[perform 3D mesh generation]' \
  '-o+[output filename]:file:_files' \
  '-format+[output mesh format]:fmt:(msh msh1 msh2 msh4 stl vrml unv vtk wrl mesh ply ply2 bdf cgns med inp diff key x3d ir3 mail neu su2 p3d)' \
  '-bin[binary format when available]' \
  '-saveall[save all elements (discard physical groups)]' \
  '-algo+[mesh algorithm]:algo:(meshadapt del2d front2d delquad pack initial2d auto del3d front3d mmg3d hxt initial3d)' \
  '-parametric[save nodes with parametric coords]' \
  '-part+[partition mesh after batch generation]:N:' \
  '-smooth+[mesh smoothing steps]:N:' \
  '-order+[mesh order]:order:(1 2 3 4 5)' \
  '-clscale+[global element-size scaling factor]:scale:' \
  '-clmin+[minimum element size]:size:' \
  '-clmax+[maximum element size]:size:' \
  '-rand+[random perturbation factor]:float:' \
  '-bgm+[load post-processing view as background mesh]:file:_files' \
  '-check[run mesh consistency checks]' \
  '-combine[combine input views into multi-time-step ones]' \
  '-n[hide all meshes/views on startup]' \
  '-fontsize+[GUI font size]:N:' \
  '-display+[X display]:display:' \
  '-new[create new model before merging]' \
  '-merge[merge next files]' \
  '-open[open next files]' \
  '(-a -g -m -s -p)-a[start in automatic mode]' \
  '(-a -g -m -s -p)-g[start in geometry mode]' \
  '(-a -g -m -s -p)-m[start in mesh mode]' \
  '(-a -g -m -s -p)-s[start in solver mode]' \
  '(-a -g -m -s -p)-p[start in post-processing mode]' \
  '-pid[print process ID to stdout]' \
  '-listen+[listen for connections on socket]:socket:' \
  '-v+[verbosity level]:level:(0 1 2 3 4 5 99)' \
  '-nopopup[disable dialog popups (scripting)]' \
  '*-setnumber+[set numeric constant (name value)]:name value:' \
  '*-setstring+[set string constant (name value)]:name value:' \
  '*-string+[parse option string at startup]:option:' \
  '*-option+[parse option file at startup]:file:_files' \
  '-convert+[convert files to latest formats, exit]:files:_files' \
  '*:geo/msh/stp/igs/iges/brep/stl file:_files -g "*.(geo|msh|stp|igs|iges|brep|stl|step|opt|pos)"' \
  && ret=0

return ret
