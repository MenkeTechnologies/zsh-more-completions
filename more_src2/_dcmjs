_dcmjs_dcmjs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _c=(
                'dump:dump a DICOM Part-10 file'
                'instance:write the instance data'
            )
            _describe -t commands 'dcmjs command' _c && ret=0
            ;;
        args)
            case $words[1] in
                dump)
                    _arguments '1:DICOM Part-10 file:_files -g "*.dcm *.dicom *.DCM *.DICOM"' && ret=0
                    ;;
                instance)
                    _arguments \
                        '1:DICOM Part-10 file:_files -g "*.dcm *.dicom *.DCM *.DICOM"' \
                        '(-p --pretty)'{-p,--pretty}'[pretty-print]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_dcmjs_dicomwebjs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-s --study)'{-s,--study}'=[download a specific Study Instance UID]:uid:' \
        '--seriesUID=[for a specific Series Instance UID]:uid:' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _c=(
                'dump:dump a DICOMweb resource'
                'instance:write the instance data'
                'download:download a full study from any supported source'
                'part10:convert DICOMweb metadata to Part-10'
            )
            _describe -t commands 'dicomwebjs command' _c && ret=0
            ;;
        args)
            case $words[1] in
                dump)
                    _arguments \
                        '1:DICOMweb URL or file location:' \
                        '--debug[set debug-level logging]' && ret=0
                    ;;
                instance)
                    _arguments \
                        '1:DICOM Part-10 file:_files -g "*.dcm *.dicom *.DCM *.DICOM"' \
                        '(-p --pretty)'{-p,--pretty}'[pretty-print]' \
                        '--debug[set debug-level logging]' && ret=0
                    ;;
                download|part10)
                    _arguments \
                        '1:URL or local path:' \
                        '(-S --StudyInstanceUID)'{-S,--StudyInstanceUID}'=[StudyInstanceUID to download]:uid:' \
                        '(-d --directory)'{-d,--directory}'=[target directory (default .)]:dir:_files -/' \
                        '--debug[enable debug logging]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_dcmjs_dimsejs() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _c=('study:query for studies at the named DICOM AE')
            _describe -t commands 'dimsejs command' _c && ret=0
            ;;
        args)
            case $words[1] in
                study)
                    _arguments '1:AE name (Application Entity):' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

case "${service:-${words[1]}}" in
    dicomwebjs) _dcmjs_dicomwebjs "$@" ;;
    dimsejs)    _dcmjs_dimsejs "$@" ;;
    dcmjs|*)    _dcmjs_dcmjs "$@" ;;
esac
