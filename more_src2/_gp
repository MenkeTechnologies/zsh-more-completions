#compdef gp pari
# Documentation: https://manpages.debian.org/bookworm/pari-gp/gp.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-f --fast)'{-f,--fast}'[skip .gprc]' \
  '-p[prime table limit]:limit:' \
  '(-q --quiet)'{-q,--quiet}'[suppress headers]' \
  '*'{-D,--default}'=[key=val]:setting:' \
  '-s[stack size]:size:' \
  '--emacs[Emacs mode]' \
  '--help[show help]' \
  '--test[test mode]' \
  '--texmacs[TeXmacs mode]' \
  '--version[full version]' \
  '--version-short[short version]' \
  '*:file:_files'
