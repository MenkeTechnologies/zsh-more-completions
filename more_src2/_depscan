#compdef depscan
# Documentation: source-direct extraction from upstream
# owasp-dep-scan/dep-scan depscan/cli_options.py argparse
# `parser.add_argument(...)` calls including the
# `parser.add_mutually_exclusive_group(required=False)` block
# for the --bom-engine xor --vulnerability-analyzer mutex pair.
# Reference accessed: 2026-05-30 via gh api.
# OWASP depscan R147b — open-source security audit tool for
# project dependencies. Sister to the heavily-covered supply-
# chain family (snyk/trivy/grype/syft/cosign/cyclonedx/cargo-deny
# /cargo-audit).

_arguments -s -S \
  '--no-banner[suppress the depscan banner]' \
  '(-i)-i+[input file or directory (project source)]:path:_files' \
  '(-o)-o+[output report file path]:file:_files' \
  '(-t)-t+[project type to scan as]:type:(java python nodejs go rust ruby php csharp swift dart cpp dockerfile yaml-manifest binary)' \
  '(-q --quiet)'{-q,--quiet}'[suppress logging output]' \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '--csaf[generate CSAF v2.0 VEX output]' \
  '--profile=[depscan profile to use]:profile:(appsec research generic standard mlsec licence)' \
  '--lifecycle=[lifecycle stage to scan against]:stage:(pre-build build post-build operations)' \
  '--technique=[scan technique]:technique:(precise approximate llm)' \
  '(--vulnerability-analyzer)--bom-engine=[BOM generation engine (mutex with --vulnerability-analyzer)]:engine:(CdxgenGenerator BlintGenerator CdxgenImageBasedGenerator CdxgenServerGenerator)' \
  '(--bom-engine)--vulnerability-analyzer=[vulnerability analyzer (mutex with --bom-engine)]:analyzer:(VDRAnalyzer VEXAnalyzer)' \
  '--reachability-analyzer=[reachability analyzer]:analyzer:(SemanticReachability FrameworkReachability off)' \
  '--bom=[pre-built BOM (CycloneDX) file to scan]:file:_files -g "*.(json|xml|cdx.json)"' \
  '--bom-dir=[directory containing pre-built BOM files]:dir:_directories' \
  '--cdxgen-args=[extra args to pass through to cdxgen]:args:' \
  '--cdxgen-server=[cdxgen-as-a-server URL]:url:_urls' \
  '--custom-data=[custom JSON data to merge into the BOM]:file:_files -g "*.json"' \
  '--debug[enable debug logging]' \
  '--deep[run a deep scan with semantic reachability]' \
  '--explain[explain why each vulnerability was flagged]' \
  '--explanation-mode=[explanation mode]:mode:(none normal verbose)' \
  '--fuzzy-search[enable fuzzy version-string matching]' \
  '--no-suggest[do not emit upgrade suggestions]' \
  '--no-universal[do not generate the universal BOM]' \
  '--no-vuln-table[suppress the vulnerabilities table in console output]' \
  '--private-ns=[private namespaces to flag as malicious (comma list)]:namespaces:' \
  '--purl=[scan a single Package URL (purl) instead of a project]:purl:' \
  '--report-name=[report filename stem (no extension)]:name:' \
  '--report-template=[Jinja2 report template file]:file:_files' \
  '--reports-dir=[reports output directory]:dir:_directories' \
  '--risk-audit[run a risk audit (license + maintainer signals)]' \
  '--search-order=[BOM search order (comma list)]:order:' \
  '--server[run depscan as a server]' \
  '--server-host=[server bind host]:host:_hosts' \
  '--server-port=[server port]:port:' \
  '--server-allowed-hosts=[allowed hosts when in server mode]:hosts:_hosts' \
  '--server-allowed-paths=[allowed paths when in server mode]:paths:' \
  '--src=[project source directory (synonym for -i)]:dir:_directories' \
  '--annotate[annotate the input with VEX statements]'
