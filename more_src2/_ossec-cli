#compdef ossec-cli ossec-control ossecctl
# _ossec-cli — Trend Micro OSSEC ossec-cli CLI command-line frontend wrapping the OSSEC open-source HIDS host-based intrusion detection system Wazuh-predecessor FIM-File-Integrity-Monitoring rootkit-detection log-analysis Active-Response platform control script ossec-control providing start stop restart status info enable disable agent_control authd alertd analysisd csyslogd dbd execd logcollector maild monitord remoted reportd rootcheckd syscheckd syslogd registerd (Trend Micro OSSEC team Daniel Cid, C); custom argparse
# upstream: https://www.ossec.net/

_ossec-cli() {
    local -a sub=(
        'start:start OSSEC'
        'stop:stop OSSEC'
        'restart:restart OSSEC'
        'reload:reload config'
        'status:show status'
        'info:show info'
        'enable:enable feature'
        'disable:disable feature'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[debug]' \
        '-f[foreground]' \
        '-c+[config file]:file:_files -g "ossec.conf *.conf"' \
        '--config=+[file]:file:_files -g "ossec.conf *.conf"' \
        '-D+[OSSEC dir]:dir:_files -/' \
        '-u+[run as user]:_users' \
        '-g+[run as group]:_groups' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ossec-control subcommand' sub ;;
        args)
            case $words[1] in
                enable|disable) _arguments '1:feature:(client-syslog database agentless debug auth integrator)' ;;
                info) _arguments '1:type:(server agent)' ;;
            esac
            ;;
    esac
}

_ossec-cli "$@"
