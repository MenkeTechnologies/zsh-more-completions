#compdef gistit
# Documentation: https://github.com/fabricio7p/gistit
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gistit - hash-based code snippet sharing (Rust)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'send:upload a snippet'
      'fetch:fetch a shared snippet'
      'host:manage P2P node daemon'
    )
    _describe -t commands 'gistit command' commands && ret=0
    ;;
  args)
    case $line[1] in
      send)
        _arguments -s -S \
          '(-c --clipboard)'{-c,--clipboard}'[copy hash to clipboard]' \
          '--github[also post to GitHub Gists]' \
          '(-a --author)'{-a,--author}'=[author name]:author' \
          '(-d --description)'{-d,--description}'=[snippet description]:description' \
          '*:files:_files' && ret=0
        ;;
      fetch|f)
        _arguments -s -S \
          '--save[save snippet to disk]' \
          '*:hash:' && ret=0
        ;;
      host)
        _arguments -s -S \
          '--start[start the P2P daemon]' \
          '--stop[stop the P2P daemon]' \
          '--status[show daemon status]' && ret=0
        ;;
    esac
    ;;
esac

return ret
