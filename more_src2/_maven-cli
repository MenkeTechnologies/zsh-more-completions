#compdef maven-cli mvn-cli
# _maven-cli — Apache Maven Java build tool CLI alias (apache team, Java); commons-cli
# upstream: https://github.com/apache/maven

_maven-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--show-version[show version and continue]' \
        '-V[show version and continue]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--debug[debug]' \
        '-X[debug]' \
        '--errors[show errors]' \
        '-e[show errors]' \
        '--batch-mode[batch mode]' \
        '-B[batch mode]' \
        '--non-recursive[non recursive]' \
        '-N[non recursive]' \
        '--also-make[also make]' \
        '-am[also make]' \
        '--also-make-dependents[also make dependents]' \
        '-amd[also make dependents]' \
        '--projects=+[project list csv]:str:' \
        '-pl+[project list csv]:str:' \
        '--resume-from=+[project]:str:' \
        '-rf+[project]:str:' \
        '--threads=+[threads]:n:' \
        '-T+[threads]:n:' \
        '--file=+[pom file]:file:_files -g "pom.xml"' \
        '-f+[pom file]:file:_files -g "pom.xml"' \
        '--settings=+[settings.xml]:file:_files -g "settings.xml"' \
        '-s+[settings.xml]:file:_files -g "settings.xml"' \
        '--global-settings=+[global settings.xml]:file:_files -g "settings.xml"' \
        '-gs+[global settings.xml]:file:_files -g "settings.xml"' \
        '--toolchains=+[toolchains.xml]:file:_files' \
        '-t+[toolchains.xml]:file:_files' \
        '--global-toolchains=+[global toolchains.xml]:file:_files' \
        '-gt+[global toolchains.xml]:file:_files' \
        '--offline[offline]' \
        '-o[offline]' \
        '--update-snapshots[force update of snapshots]' \
        '-U[force update of snapshots]' \
        '--no-snapshot-updates[suppress snapshot updates]' \
        '-nsu[suppress snapshot updates]' \
        '--no-transfer-progress[no transfer progress]' \
        '-ntp[no transfer progress]' \
        '--check-plugin-updates[force check for plugin updates]' \
        '-cpu[force check for plugin updates]' \
        '--fail-fast[fail fast]' \
        '-ff[fail fast]' \
        '--fail-at-end[fail at end]' \
        '-fae[fail at end]' \
        '--fail-never[fail never]' \
        '-fn[fail never]' \
        '--lax-checksums[lax checksums]' \
        '-c[lax checksums]' \
        '--strict-checksums[strict checksums]' \
        '-C[strict checksums]' \
        '--legacy-local-repository[legacy local repository]' \
        '-llr[legacy local repository]' \
        '--builder=+[builder id]:str:' \
        '-b+[builder id]:str:' \
        '--log-file=+[log file]:file:_files' \
        '-l+[log file]:file:_files' \
        '--activate-profiles=+[profiles csv]:str:' \
        '-P+[profiles csv]:str:' \
        '--define=+[property=value]:str:' \
        '-D+[property=value]:str:' \
        '--color=+[color]:c:(auto always never)' \
        '--encrypt-password=+[password]:str:' \
        '-ep+[password]:str:' \
        '--encrypt-master-password=+[master password]:str:' \
        '-emp+[master password]:str:' \
        '*:goal:(clean validate compile test package verify install deploy site dependency:tree dependency:resolve dependency:analyze dependency:list versions:set versions:display-dependency-updates versions:display-plugin-updates versions:use-latest-versions exec:java exec:exec spring-boot:run spring-boot:repackage jar:jar war:war assembly:single shade:shade enforcer:enforce help:describe help:effective-pom help:effective-settings archetype:generate release:prepare release:perform)'
}

_maven-cli "$@"
