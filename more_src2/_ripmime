#compdef ripmime ripMIME
# Documentation: https://manpages.debian.org/testing/ripmime/ripmime.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help/usage information]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '-i+[input MIME file (- for stdin)]:file:_files' \
  '-d+[output directory]:dir:_files -/' \
  '-p+[prefix for unnamed files]:prefix:' \
  '-e+[dump headers to file]:name:' \
  '-v[enable verbosity]' \
  '-q[run quietly]' \
  '--verbose-contenttype[verbose file content type reporting]' \
  '--verbose-oldstyle[v1.2.x style filename reporting]' \
  '--verbose-defects[report MIME defects]' \
  '--stdout[report to stdout (default)]' \
  '--stderr[report to stderr]' \
  '--syslog[report to syslog]' \
  '--paranoid[enforce strict 7-bit filename compliance]' \
  '--name-by-type[name by content-type if unnamed]' \
  '--no-nameless[skip unnamed attachments]' \
  '--overwrite[overwrite duplicate filenames]' \
  '--unique-names[avoid overwriting (default behavior)]' \
  '--prefix=[add unique code at filename start]:prefix:' \
  '--postfix=[add unique code at filename end]:postfix:' \
  '--infix=[add unique code in filename middle]:infix:' \
  '--no-multiple-filenames[disable multiple filename handling]' \
  '--recursion-max=[set maximum recursion depth]:level:' \
  '--mailbox[process mailbox format]' \
  '--disable-header-fix[skip header repairs]' \
  '--disable-qmail-bounce[disable RFC822 look-ahead]' \
  '--no-ole[disable OLE decoding]' \
  '--no-uudecode[disable UUencoding detection]' \
  '--no-quotedprintable[disable QuotedPrintable decoding]' \
  '--no-doublecr[disable double-CR handling]' \
  '--no-mht[disable MHT decoding]' \
  '--extended-errors[return error codes for non-fatal issues]' \
  '--debug[detailed decoding information]' \
  '--buildcodes[display build information]' \
  '*:input file:_files' && ret=0

return ret
