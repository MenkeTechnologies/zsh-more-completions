#compdef distrobox-upgrade
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/distrobox-upgrade.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Container name is positional (no -n/--name flag).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[upgrade all containers]' \
  '--running[upgrade only running containers]' \
  '(-r --root)'{-r,--root}'[run podman/docker/lilipod as root]' \
  '(-v --verbose)'{-v,--verbose}'[show more verbosity]' \
  '*:container name:' && ret=0

return ret
