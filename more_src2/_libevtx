#compdef evtxinfo evtxexport
# _libevtx — libyal Windows XML EventLog (.evtx, Vista+) parser; dumps event records as XML or text with system/user data sections
# upstream: https://github.com/libyal/libevtx

_libevtx() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[codepage]:codepage:(ascii windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-f+[output format]:format:(text xml)' \
        '-m+[mode]:mode:(all recovered)' \
        '-t+[template file]:template:_files' \
        '-T[use templates]' \
        '-X[exclusive]' \
        '*:EVTX file:_files -g "*.evtx"'
}

_libevtx "$@"
