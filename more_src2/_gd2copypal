#compdef gd2copypal
# Documentation: https://manpages.debian.org/unstable/libgd-tools/gd2copypal.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gd2copypal - copy palette from one GD2 image file to another
# Usage: gd2copypal palettefile.gd2 filename.gd2

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:palette file:_files -g "*.gd2"' \
  '2:target file:_files -g "*.gd2"' && ret=0

return ret
