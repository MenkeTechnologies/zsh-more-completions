#compdef gtk4-path-tool
# _gtk4-path-tool — GNOME GTK4 gtk4-path-tool CLI utility manipulating GskPath SVG path data string representations decompose info render show reverse roundup symmetrize geometric subdivision rounding shape-conversion operations for previewing programmatic vector paths from gskpath-renderer (GNOME team, C); custom argparse
# upstream: https://gitlab.gnome.org/GNOME/gtk

_gtk4-path-tool() {
    local -a sub=(
        'decompose:decompose a path into simpler curves'
        'info:show information about a path'
        'render:render a path to PNG/SVG/PDF'
        'show:show a path'
        'reverse:reverse a path'
        'restrict:restrict a path to a range'
        'symmetrize:make a path symmetric'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--flags=+[f]:f:(none flat cubic conic quad)' \
        '--name=+[n]:str:' \
        '--fg-color=+[color]:str:' \
        '--bg-color=+[color]:str:' \
        '--zoom=+[N]:n:' \
        '--margin=+[N]:n:' \
        '--start=+[N]:n:' \
        '--end=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gtk4-path-tool subcommand' sub ;;
        args)
            _arguments '*:path string or file:_files'
            ;;
    esac
}

_gtk4-path-tool "$@"
