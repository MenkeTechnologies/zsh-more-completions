#compdef ncdu
# Documentation: ncdu --help
# Source: NCurses Disk Usage analyzer.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,-V,--version}'[show version]' \
    '-f+[import scanned directory]:file:_files' \
    '-o+[export to JSON]:file:_files' \
    '-O+[export to binary]:file:_files' \
    {-e,--extended}'[enable extended info]' \
    '--ignore-config[do not load config files]' \
    {-x,--one-file-system}'[stay on same filesystem]' \
    '*--exclude=[exclude files matching PATTERN]:pattern:' \
    '*'{-X+,--exclude-from=}'[exclude files matching FILE patterns]:file:_files' \
    '--exclude-caches[exclude dirs with CACHEDIR.TAG]' \
    {-L,--follow-symlinks}'[follow symbolic links]' \
    '--exclude-kernfs[exclude Linux pseudo filesystems]' \
    '-t+[scan threads]:n:' \
    {-c,--compress}'[Zstandard compression with -o]' \
    '--compress-level=[compression level]:level:' \
    '--export-block-size=[KiB block size with -O]:kib:' \
    '-0[no UI when scanning]' \
    '-1[minimal UI when scanning]' \
    '-2[full ncurses UI when scanning]' \
    {-q,--slow-ui-updates}'[quiet mode (2s refresh)]' \
    '--enable-shell[enable shell spawning]' \
    '--disable-shell[disable shell spawning]' \
    '--enable-delete[enable file deletion]' \
    '--disable-delete[disable file deletion]' \
    '--enable-refresh[enable directory refresh]' \
    '--disable-refresh[disable directory refresh]' \
    '--si[use SI prefixes (1k=1000)]' \
    '--color=[color scheme]:scheme:(off dark dark-bg)' \
    '--graph-style=[graph style]:style:(hash half-block eighth-block)' \
    '--cache-dir=[cache directory]:dir:_files -/' \
    '*:directory:_files -/' \
    && ret=0

return ret
