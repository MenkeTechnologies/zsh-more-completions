#compdef foamListBinDirs foamListThirdPartyBinDirs
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/tools/foamListBinDirs + foamListThirdPartyBinDirs — list per-arch bin/lib dirs of an OpenFOAM/ThirdParty pack.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:pack dir:_directories' \
    '2:archOptions ($WM_OPTIONS):' \
    && ret=0

return ret
