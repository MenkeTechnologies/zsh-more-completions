#compdef linuxsampler
# Documentation: https://man.archlinux.org/man/linuxsampler.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus search URL; fabricated flags
# --instruments-db-backend, --no-stacktrace, --detach, -h short form
# (man page lists only long forms beyond --help/--version).

# linuxsampler: standalone software sampler engine (LSCP control protocol)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help and exit]' \
  '--version[show version and exit]' \
  '--exec-after-init=[shell command(s) to execute after initialization]:cmd:' \
  '--lscp-addr=[LSCP listen address]:host:' \
  '--lscp-port=[LSCP listen port (default 8888)]:port:' \
  '--create-instruments-db=[create new instruments DB file]:file:_files' \
  '--instruments-db-location=[override instruments DB file location]:file:_files' \
  '--profile[output benchmark messages (currently unsupported)]' \
  '--no-tune[disable assembly optimizations like MMX and SSE]' \
  '--statistics[output voice and disk stream count periodically]' && ret=0
return ret
