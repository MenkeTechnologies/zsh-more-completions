#compdef falco
# _falco-bin — Falco cloud-native runtime security (Sysdig + CNCF, C++); detect anomalous host/container syscall behavior
# upstream: https://github.com/falcosecurity/falco

_falco-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-c+[config file]:file:_files' \
        '--cri+[CRI socket path]:file:_files' \
        '--cri-async+[CRI async]:bool:(true false)' \
        '--cri-buffer-size+[CRI buffer size]:n:' \
        '--disable-source+[disable source]:source:(syscall internal k8s_audit)' \
        '--enable-source+[enable source]:source:(syscall internal k8s_audit)' \
        '-D+[rule disable substring]:str:' \
        '--exclude-tags+[exclude tags]:tags:' \
        '--fields[print supported fields]' \
        '--gvisor-config+[gVisor config]:file:_files' \
        '--gvisor-generate-config+[generate gVisor config]:path:_files' \
        '--gvisor-root+[gVisor root]:dir:_files -/' \
        '--ignored-events[print ignored events]' \
        '--list[list supported fields]' \
        '-M+[stop after seconds]:n:' \
        '--mark[mark all rules disabled]' \
        '-o+[override]:k=v:' \
        '--option+[override]:k=v:' \
        '-p+[output format]:fmt:(k m c o p s)' \
        '-P+[plugin]:plugin:' \
        '-pc+[plugin config]:file:_files' \
        '-pe+[plugin enable]:plugin:' \
        '--pidfile+[pid file]:file:_files' \
        '-r+[rules file]:file:_files' \
        '--rules+[rules file]:file:_files' \
        '--snaplen+[snaplen]:n:' \
        '-s+[stats file]:file:_files' \
        '--support[get support info]' \
        '-T+[exclude tag]:tag:' \
        '-t+[include tag]:tag:' \
        '-u[userspace mode]' \
        '-U[userspace events]' \
        '-V+[validate rules file]:file:_files' \
        '--validate+[validate rules file]:file:_files' \
        '-w+[write log to file]:file:_files' \
        '*::args:'
}

_falco-bin "$@"
