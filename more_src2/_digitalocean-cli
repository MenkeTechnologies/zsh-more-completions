#compdef digitalocean-cli doctl-cli
# _digitalocean-cli — DigitalOcean doctl CLI alias (digitalocean team, Go); cobra
# upstream: https://github.com/digitalocean/doctl

_digitalocean-cli() {
    local -a sub=(
        'account:get account info'
        'auth:authentication commands'
        'auth:init:init authentication'
        'auth:list:list authentication contexts'
        'auth:remove:remove context'
        'auth:switch:switch context'
        'apps:list apps'
        'apps:create:create app'
        'apps:get:get app'
        'apps:delete:delete app'
        'apps:update:update app'
        'apps:logs:get logs'
        'apps:list-deployments:list deployments'
        'apps:get-deployment:get deployment'
        'apps:create-deployment:create deployment'
        'apps:propose:propose app spec'
        'apps:tier:list:list app tiers'
        'apps:tier:instance-size:list:list instance sizes'
        'balance:get balance'
        'billing-history:list:list billing history'
        'compute:droplet:list:list droplets'
        'compute:droplet:create:create droplet'
        'compute:droplet:get:get droplet'
        'compute:droplet:delete:delete droplet'
        'compute:droplet:actions:droplet actions'
        'compute:droplet:reboot:reboot droplet'
        'compute:droplet:shutdown:shutdown droplet'
        'compute:droplet:power-cycle:power-cycle droplet'
        'compute:droplet:power-on:power on droplet'
        'compute:droplet:power-off:power off droplet'
        'compute:droplet:resize:resize droplet'
        'compute:droplet:snapshot:snapshot droplet'
        'compute:image:list:list images'
        'compute:image:get:get image'
        'compute:image:create:create image'
        'compute:image:delete:delete image'
        'compute:ssh:ssh to droplet'
        'compute:ssh-key:list:list ssh keys'
        'compute:ssh-key:create:create ssh key'
        'compute:ssh-key:get:get ssh key'
        'compute:ssh-key:delete:delete ssh key'
        'compute:tag:list:list tags'
        'compute:tag:create:create tag'
        'compute:tag:apply:apply tag'
        'compute:tag:delete:delete tag'
        'compute:volume:list:list volumes'
        'compute:volume:create:create volume'
        'compute:volume:get:get volume'
        'compute:volume:delete:delete volume'
        'compute:volume-action:attach:attach volume'
        'compute:volume-action:detach:detach volume'
        'databases:list:list dbs'
        'databases:create:create db'
        'databases:get:get db'
        'databases:delete:delete db'
        'databases:connection:show connection'
        'databases:firewalls:list:list firewalls'
        'databases:db:list:list user dbs'
        'databases:user:list:list users'
        'databases:user:create:create user'
        'kubernetes:cluster:list:list clusters'
        'kubernetes:cluster:create:create cluster'
        'kubernetes:cluster:get:get cluster'
        'kubernetes:cluster:delete:delete cluster'
        'kubernetes:cluster:upgrade:upgrade cluster'
        'kubernetes:cluster:kubeconfig:save:save kubeconfig'
        'kubernetes:cluster:kubeconfig:show:show kubeconfig'
        'kubernetes:cluster:node-pool:list:list node pools'
        'kubernetes:cluster:node-pool:create:create node pool'
        'kubernetes:cluster:node-pool:delete:delete node pool'
        'projects:list:list projects'
        'projects:create:create project'
        'projects:get:get project'
        'projects:update:update project'
        'projects:delete:delete project'
        'projects:resources:list:list resources'
        'registry:create:create registry'
        'registry:delete:delete registry'
        'registry:get:get registry'
        'registry:login:login to registry'
        'registry:logout:logout from registry'
        'registry:repository:list:list repos'
        'registry:repository:list-tags:list tags'
        'registry:repository:list-manifests:list manifests'
        'registry:garbage-collection:start:start gc'
        'serverless:init:init serverless'
        'serverless:deploy:deploy serverless'
        'serverless:functions:invoke:invoke function'
        'serverless:functions:list:list functions'
        'serverless:logs:show logs'
        'spaces-key:list:list spaces keys'
        'spaces-key:create:create spaces key'
        'spaces-key:delete:delete spaces key'
        '1-click:list:list 1-clicks'
        'monitoring:alert:list:list alerts'
        'monitoring:alert:create:create alert'
        'monitoring:uptime:check:list:list uptime checks'
        'monitoring:uptime:check:create:create uptime check'
        'network:firewall:list:list firewalls'
        'network:firewall:create:create firewall'
        'network:floating-ip:list:list floating ips'
        'network:floating-ip:create:create floating ip'
        'network:floating-ip:delete:delete floating ip'
        'network:reserved-ip:list:list reserved ips'
        'network:vpc:list:list vpcs'
        'network:vpc:create:create vpc'
        'network:vpc:delete:delete vpc'
        'invoice:list:list invoices'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--access-token=+[token]:str:' \
        '-t+[token]:str:' \
        '--api-url=+[api url]:url:_urls' \
        '--context=+[context]:str:' \
        '--config=+[config file]:file:_files -g "config.yaml"' \
        '-c+[config file]:file:_files -g "config.yaml"' \
        '--output=+[output format]:f:(text json)' \
        '-o+[output format]:f:(text json)' \
        '--verbose[verbose]' \
        '--trace[trace]' \
        '--interactive[interactive]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doctl subcommand' sub ;;
        args)
            case $words[1] in
                compute:droplet:create) _arguments \
                    '1:name:' \
                    '--image=+[image slug]:str:' \
                    '--size=+[size]:str:' \
                    '--region=+[region]:r:(nyc1 nyc3 ams3 sfo3 sgp1 lon1 fra1 tor1 blr1 syd1)' \
                    '--ssh-keys=+[ssh keys]:str:' \
                    '--user-data=+[user data]:str:' \
                    '--user-data-file=+[user data file]:file:_files' \
                    '--tag-names=+[tags]:str:' \
                    '--enable-backups[enable backups]' \
                    '--enable-ipv6[enable ipv6]' \
                    '--enable-private-networking[enable private networking]' \
                    '--enable-monitoring[enable monitoring]' \
                    '--vpc-uuid=+[vpc uuid]:str:' \
                    '--wait[wait for completion]' ;;
                kubernetes:cluster:create) _arguments \
                    '1:name:' \
                    '--region=+[region]:str:' \
                    '--version=+[k8s version]:str:' \
                    '--node-pool=+[node pool spec]:str:' \
                    '--tag=+[tags]:str:' \
                    '--auto-upgrade[auto upgrade]' \
                    '--maintenance-window=+[window]:str:' \
                    '--ha[high availability]' \
                    '--wait[wait]' \
                    '--update-kubeconfig[update kubeconfig]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_digitalocean-cli "$@"
