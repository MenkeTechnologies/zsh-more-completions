#compdef git-merge-resolve
# Documentation: https://git-scm.com/docs/git-merge
# Source: git/git git-merge-resolve.sh — resolve two trees via enhanced read-tree (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:merge bases -- heads:_default' \
    && ret=0

return ret
