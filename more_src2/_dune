#compdef dune
# Documentation: source-direct extraction from upstream
# ocaml/dune bin/ (**OCaml language**; uses
# `Cmdliner` library; corpus's first documented OCaml
# CLI + first use of the famous Cmdliner ecosystem):
#   bin/main.ml lines 3-46 (`let all : _ Cmdliner.Cmd.t
#     list = ...` — list of subcommands split into
#     `terms` (23 direct commands) and `groups` (12
#     command groups))
#   bin/main.ml line 19 (`Util.command_alias Printenv
#     .command Printenv.term "printenv"` — explicit
#     command alias via helper)
#   bin/main.ml lines 60-96 (top-level `Cmd.info "dune"
#     ~doc ~envs ~version ~man:[...]` with man-page-
#     style documentation via `\`S` / `\`P` /
#     `\`Blocks` markers)
#   bin/main.ml line 98 (`Cmd.group info all` — composes
#     terms + groups into the top-level group command)
#   bin/main.ml lines 105-118 (entrypoint: `Cmd.eval_value
#     cmd ~catch:false` + custom exit code handling
#     including Dune_scheduler shutdown signals)
#   bin/clean.ml lines 13-46 (Clean command: `let+
#     builder = Common.Builder.term and+ paths = Arg.(
#     value & pos_all string [] & info [] ~docv:"PATH"
#     ~doc:None)` — `let+` / `and+` applicative-binding
#     operators)
#   bin/build.ml lines 98-126 (Build command: 3
#     `Arg.(...)` with `opt_all` (repeatable options))
# Reference accessed: 2026-05-30 via gh api.
#
# dune is the **OCaml composable build system** — the
# de-facto standard build tool for OCaml projects.
# Pivots from Haskell (R270 carp) into the **OCaml
# language tooling cluster**.  Sister to opam (OCaml
# package manager; uses Cmdliner too) and odoc (OCaml
# documentation; Cmdliner too).  **MAJOR MILESTONE**:
# corpus's **first documented OCaml CLI** AND first
# use of the famous **Cmdliner** library — adds OCaml
# to the cross-language CLI taxonomy (13 library
# variants now).
#
# Critical extraction note: dune uses **OCaml's
# `Cmdliner`** library at `open Import` (which re-
# exports Cmdliner submodules) — corpus's **first
# documented OCaml CLI** AND first use of the
# **Cmdliner ecosystem**.  Extends the **cross-language
# CLI taxonomy** to THIRTEEN library variants
# (R269 added Crystal; R270 added Haskell; R271 adds
# OCaml): (a) Rust clap derive (R247-R262, R268), (b)
# Rust clap builder (R259), (c) Rust clap v3 (R261),
# (d) Go cobra (multiple), (e) Go pflag (multiple),
# (f) Go flaggy (R263), (g) Go stdlib flag (R264,
# R265), (h) Python Click (R266), (i) Python argparse
# (R267), (j) Python Typer (R268), (k) Crystal
# OptionParser (R269), (l) Haskell optparse-applicative
# (R270), (m) **OCaml Cmdliner** (R271 — NEW).  Cmdliner
# is THE standard OCaml CLI library — used by dune,
# opam, odoc, merlin, utop, ocamlformat, and most of
# the OCaml ecosystem.  Cmdliner is INSPIRED BY Haskell
# optparse-applicative (R270) but uses OCaml's
# **applicative `let+` / `and+` syntax** introduced in
# OCaml 4.08.  Documents the **OCaml binding-operator
# applicative pattern**.
#
# Critical extraction note: dune uses **`let+` / `and+`
# applicative binding operators** at clean.ml:14-15 +
# build.ml:100-126 — OCaml's syntactic sugar for
# applicative-functor binding (added in OCaml 4.08):
# ```
#   let+ builder = Common.Builder.term
#   and+ paths   = Arg.(value & pos_all string [] & info [...])
#   and+ aliases = Arg.(value & opt_all ... & info [...])
#   in (* term body *)
# ```
# Each `and+` adds another sub-parser to compose into
# the full Term.  Documents the **OCaml `let+` / `and+`
# binding operator pattern** — distinct from Haskell's
# `<$>` / `<*>` (R270 carp) at the SURFACE syntax but
# IDENTICAL in semantics (both are applicative-functor
# composition).  OCaml's binding-operators are more
# readable for multi-variable patterns; Haskell's
# `<$> <*>` chain is more concise for single-record
# constructors.  Corpus's **first documented
# `let+` / `and+` binding operator** usage.
#
# Critical extraction note: dune uses **`Arg.(value &
# opt_all ... & info [...])`** pipeline syntax at
# build.ml:103-114 — the `&` operator is OCaml's
# `|>` (pipe-forward) repurposed for Cmdliner argument
# construction:
#   `value` — make the arg's value optional (no error
#             if missing)
#   `opt_all X default` — accept the option multiple
#             times, accumulating values of type X
#             with default
#   `info ["name"] ~docv:"DOCV" ~doc:(Some "...")` —
#             metadata: long names, doc value
#             placeholder, help text
# The chain `value & opt_all & info` builds up the
# argument spec by piping through each transformation.
# Documents the **Cmdliner pipeline syntax** — distinct
# from clap derive's struct attributes (R247+) and from
# Haskell optparse-applicative's `<>` Semigroup append
# (R270 carp).  The Cmdliner pipeline is OCaml-specific
# but conceptually similar to Builder API patterns in
# other languages.
#
# Critical extraction note: dune uses **`Cmd.group info
# all`** at main.ml:98 to compose 23 individual `Cmd.t`
# values + 12 sub-group `Cmd.t` values into a top-level
# group command.  Plus subcommands are organized into
# `terms` (flat list of commands) and `groups`
# (commands that themselves contain subcommands —
# e.g. `dune init project ...`, `dune rpc status`,
# `dune pkg lock`).  Documents the **Cmdliner
# `Cmd.group` composable subcommand pattern** —
# distinct from Click's nested `@click.group` decorator
# and from clap derive's `#[clap(subcommand)]` enum.
# Each subcommand is a SEPARATE FILE in `bin/`
# (clean.ml, build.ml, install.ml, etc.) and its
# `command` value is collected in main.ml.  This is
# the **one-subcommand-per-file** convention common in
# OCaml CLIs.
#
# Critical extraction note: dune uses **`man` field
# with ` \`S` / ` \`P` / ` \`Blocks` markers** at
# main.ml:70-95 + clean.ml:5-11 — Cmdliner's
# **man-page-style documentation** structure:
#   - `\`S "DESCRIPTION"` — start a section
#   - `\`P {|paragraph text|}` — paragraph (multi-line
#     string with `{|...|}` raw string delimiters)
#   - `\`Blocks Common.help_secs` — embed a reusable
#     block of common sections
#   - `Common.examples [...]` — render an examples
#     section from a list of (description, command)
#     pairs
# Documents the **Cmdliner man-page documentation**
# pattern — generates a proper man-page formatted help
# output.  Distinct from clap's after_help/after_long_help
# (R247 sncast) which uses plain strings.  Cmdliner
# auto-formats sections, paragraphs, and examples into
# a structured help page that matches Unix `man`
# conventions.  Corpus's first documented man-page-
# style structured help.
#
# Critical extraction note: dune defines **command
# aliases via a helper** at main.ml:18 —
# `Util.command_alias Printenv.command Printenv.term
# "printenv"` creates a `printenv` command that's an
# alias for the actual `Printenv.command`.  Documents
# the **helper-fn-based command alias** pattern —
# distinct from clap derive's `#[command(alias = "X")]`
# attribute (R250 sozo).  In Cmdliner, aliases require
# wrapping the term in a new Cmd.t with a different
# name.  More verbose but explicit.

local curcontext="$curcontext" state line ret=1

# 23 direct commands + 12 groups decoded source-direct
# from main.ml lines 4-43.
local -a subcommands=(
  'build:build the given targets (or default targets if none given)'
  'runtest:run tests (alias: test)'
  'test:alias for runtest'
  'runtest-rerun:re-run last test failures'
  'installed-libraries:list libraries installed on the system'
  'external-lib-deps:print external libraries needed to build the project'
  'fmt:format source files (formatters per file extension)'
  'clean:clean the project (remove _build and intermediate artifacts)'
  'install:install build artifacts'
  'uninstall:uninstall build artifacts'
  'exec:execute a binary built by dune'
  'subst:substitute watermarks in source files'
  'print-rules:print build rules'
  'utop:load workspace files into a utop REPL'
  'promote:promote files from build dir back to source dir'
  'printenv:print the environment dune uses'
  'help:show help about a topic or command'
  'format-dune-file:format a single dune file'
  'upgrade:upgrade jbuilder project to the latest version of dune'
  'cache:manage the dune cache'
  'top:integration with ocaml top'
  'ocaml-merlin:start a server for merlin integration'
  'shutdown:cancel and shutdown any running builds'
  'diagnostics:print diagnostics from any open dune RPC sessions'
  'monitor:monitor a running dune instance'
  'ocaml:command group for ocaml-specific commands'
  'rocq:command group for Coq/Rocq integration'
  'describe:command group for describing project state'
  'show:command group for showing project info'
  'rpc:command group for dune RPC clients'
  'internal:command group for internal dune commands'
  'init:command group for initializing dune projects (sub: project / lib / exec / test)'
  'promotion:command group for managing promotions'
  'pkg:command group for opam/pkg integration'
  'tools:command group for dune-installed tools'
  'trace:command group for build tracing'
)

# A few key per-subcommand flag sketches.  Full flag
# extraction would span dozens of bin/*.ml files.
local -a build_flags=(
  '*--alias=[build ALIAS in its parent directory only (equivalent to @@ALIAS); repeatable]:alias:'
  '*--alias-rec=[build ALIAS in parent dir + all subdirs (equivalent to @ALIAS); repeatable]:alias:'
  '--watch[watch for source changes and rebuild]'
)

local -a init_subs=(
  'project:create a project skeleton with name (default: cwd) at PATH'
  'lib:create a library skeleton with name at PATH'
  'exec:create an executable skeleton with name at PATH'
  'test:create a test skeleton with name at PATH'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'dune subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      build)
        _arguments \
          $build_flags \
          '*:target (file path / alias / package):' && ret=0
        ;;
      runtest|test)
        _arguments \
          '--watch[watch for source changes and re-run tests]' \
          '*:test alias or directory:' && ret=0
        ;;
      clean)
        _arguments \
          '*:path inside _build to clean:_files' && ret=0
        ;;
      exec)
        _arguments \
          '1:executable name:' \
          '*:args to forward to executable:' && ret=0
        ;;
      install|uninstall)
        _arguments \
          '*:package name:' && ret=0
        ;;
      init)
        if (( CURRENT == 2 )); then
          _describe -t init-subs 'init kind' init_subs && ret=0
        else
          _arguments \
            '1:name:' \
            '2:path:_files -/' \
            '*--libs=[comma-separated library dependencies]:libs:' \
            '*--ppx=[comma-separated PPX dependencies]:ppx:' \
            '--inline-tests[generate inline-tests stanza]' && ret=0
        fi
        ;;
      utop)
        _arguments \
          '1:dir to load workspace from:_files -/' && ret=0
        ;;
      printenv)
        _arguments \
          '*:directory to print env for:_files -/' && ret=0
        ;;
      *)
        # Generic fallback for other commands
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
