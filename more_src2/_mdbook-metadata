#compdef mdbook-metadata
# _mdbook-metadata — add YAML front-matter metadata to mdbook chapters (jeffersonroth/mdbook-metadata)
# upstream: https://github.com/jeffersonroth/mdbook-metadata
# Subcommands from src/main.rs.

_mdbook-metadata() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-metadata "$@"
