#compdef datadog-cli ddev datadog-ci
# _datadog-cli — DataDog dd-trace/ddev/datadog-ci toolkit (Datadog, Node/Python); commander/click
# upstream: https://github.com/DataDog/datadog-ci

_datadog-cli() {
    local -a sub=(
        'cloud-run:cloud run integration'
        'lambda:lambda integration'
        'dora:dora metrics'
        'sourcemaps:upload sourcemaps'
        'react-native:rn sourcemaps'
        'dsyms:upload dsyms'
        'flutter-symbols:upload flutter symbols'
        'tag:tag pipelines/jobs'
        'trace:trace ci commands'
        'metric:emit metrics'
        'gate:quality gate evaluation'
        'synthetics:run synthetics'
        'junit:upload junit XML'
        'sarif:upload sarif'
        'sbom:upload sbom'
        'measure:emit measures'
        'deployment:track deployments'
        'git-metadata:upload git metadata'
        'elf-symbols:upload ELF symbols'
        'breakpoints:set breakpoints'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datadog-cli subcommand' sub ;;
        args)
            case $words[1] in
                synthetics) _arguments \
                    '1:cmd:(run-tests trigger-tests upload-application import-tests)' \
                    '--config=+[config file]:file:_files' \
                    '--public-id=+[test public id]:id:' \
                    '--api-key=+[api key]:str:' \
                    '--app-key=+[app key]:str:' ;;
                junit|sarif|sbom|deployment) _arguments \
                    '1:cmd:(upload mark)' \
                    '--service=+[service name]:str:' \
                    '--env=+[env]:str:' \
                    '--tags=+[tags]:str:' \
                    '*:file:_files' ;;
                lambda) _arguments \
                    '1:cmd:(instrument uninstrument flare)' \
                    '--functions=+[function arns]:list:' \
                    '--region=+[aws region]:region:' \
                    '--layer-version=+[layer version]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_datadog-cli "$@"
