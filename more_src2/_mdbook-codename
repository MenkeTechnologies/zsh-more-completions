#compdef mdbook-codename
# _mdbook-codename — annotate mdbook code blocks with filename labels (smallkirby/mdbook-codename)
# upstream: https://github.com/smallkirby/mdbook-codename
# Subcommands from src/main.rs (clap).

_mdbook-codename() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-codename "$@"
