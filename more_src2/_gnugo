#compdef gnugo
# Documentation: https://manpages.debian.org/bookworm/gnugo/gnugo.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm gnugo(6) manpage.
# Removed from prior file: bogus man.archlinux.org search URL.

# gnugo: GNU Go playing engine (GTP/SGF)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help=[show topic help]:topic:(debug)' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--copyright[show copyright]' \
  '--mode=[interaction mode]:mode:(ascii gtp gmp)' \
  '--replay=[replay color]:color:(black white)' \
  '--quiet[quiet output]' \
  '(-l --infile)'{-l+,--infile=}'[input SGF file]:file:_files -g "*.sgf(-.)"' \
  '(-L --until)'{-L+,--until=}'[stop at move]:move:' \
  '(-o --outfile)'{-o+,--outfile=}'[output file]:file:_files' \
  '--boardsize=[board size 1-19]:n:' \
  '--color=[gnugo color]:color:(black white)' \
  '--handicap=[handicap stones]:n:' \
  '--komi=[komi value]:n:' \
  '(-T --printboard)'{-T,--printboard}'[print board and exit]' \
  '--level=[playing strength level]:n:' \
  '(-b --benchmark)'{-b+,--benchmark=}'[benchmark mode for N games]:n:' \
  '(-t --trace)'{-t,--trace}'[trace search]' \
  '(-r --seed)'{-r+,--seed=}'[random seed]:n:' \
  '--score=[score game]:mode:(estimate finish aftermath)' \
  '--printsgf=[output SGF to file]:file:_files' \
  '(-D --depth)'{-D+,--depth=}'[search depth]:n:' \
  '(-B --backfill_depth)'{-B+,--backfill_depth=}'[backfill depth]:n:' \
  '(-a --allpats)'{-a,--allpats}'[try all patterns]' \
  '(-d --debug)'{-d+,--debug=}'[debug bitmask]:level:' \
  '(-w --worms)'{-w,--worms}'[print worms]' \
  '(-m --moyo)'{-m+,--moyo=}'[moyo analysis level]:level:' && ret=0
return ret
