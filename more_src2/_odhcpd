#compdef odhcpd
# Documentation: https://github.com/openwrt/odhcpd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# odhcpd: lightweight DHCPv4/v6 + RA daemon (OpenWrt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[debug / foreground]' \
  '-S[disable scripting]' \
  '-T[take down all interfaces]' \
  '*::odhcpd args:_files' && ret=0
return ret
