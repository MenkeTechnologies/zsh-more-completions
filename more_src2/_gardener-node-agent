#compdef gardener-node-agent
# _gardener-node-agent — Gardener per-node agent (worker config syncer)
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-node-agent/app/options.go on tip.

_gardener-node-agent() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-dir=[directory containing the node-agent config file]:dir:_files -/' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardener-node-agent "$@"
