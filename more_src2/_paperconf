#compdef paperconf
# Documentation: paperconf usage line (libpaper)
# Source: print paper size config (name / dims / unit).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-d -a)-p+[show info for named paper]:paper:(letter legal a3 a4 a5 b5 executive monarch dl com10 c5 ledger tabloid)' \
    '(-p -a)-d[default paper info]' \
    '(-p -d)-a[list all known papers]' \
    '-z[print size in points]' \
    '(-N)-n[print name]' \
    '(-n)-N[print name and dimensions]' \
    '(-w -h)-s[print size]' \
    '(-s -h)-w[print width]' \
    '(-s -w)-h[print height]' \
    '(-m -i)-c[output in cm]' \
    '(-c -i)-m[output in mm]' \
    '(-c -m)-i[output in inches]' \
    '*:paper:(letter legal a3 a4 a5 b5 executive monarch dl com10 c5 ledger tabloid)' \
    && ret=0

return ret
