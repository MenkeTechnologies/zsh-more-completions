#compdef pgmetrics
# Documentation: https://pgmetrics.io/docs/invoke.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pgmetrics - PostgreSQL metrics collector

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-t --timeout)'{-t+,--timeout=}'[query timeout seconds]:seconds:' \
  '--lock-timeout=[lock timeout ms]:ms:' \
  '(-i --input)'{-i+,--input=}'[read previously saved JSON]:file:_files -g "*.json"' \
  '(-S --no-sizes)'{-S,--no-sizes}'[skip tablespace and relation sizes]' \
  '(-c --schema)'{-c+,--schema=}'[collect only matching schemas]:regex:' \
  '(-C --exclude-schema)'{-C+,--exclude-schema=}'[exclude schemas matching pattern]:regex:' \
  '(-a --table)'{-a+,--table=}'[collect only matching tables]:regex:' \
  '(-A --exclude-table)'{-A+,--exclude-table=}'[exclude tables matching pattern]:regex:' \
  '*--omit=[skip collection items]:item:(tables indexes sequences functions extensions triggers statements log citus indexdefs bloat)' \
  '--sql-length=[truncate SQL queries to N chars]:n:' \
  '--statements-limit=[max pg_stat_statements rows]:n:' \
  '--only-listed[collect only from databases listed as arguments]' \
  '--all-dbs[collect from all user databases]' \
  '--log-file=[PostgreSQL log file]:file:_files' \
  '--log-dir=[PostgreSQL log directory]:dir:_files -/' \
  '--log-span=[examine last N minutes of logs]:minutes:' \
  '--aws-rds-dbid=[AWS RDS/Aurora instance ID]:id:' \
  '--az-resource=[Azure resource ID]:id:' \
  '--pgpool[collect only Pgpool metrics]' \
  '(-f --format)'{-f+,--format=}'[output format]:format:(human json csv)' \
  '(-l --toolong)'{-l+,--toolong=}'[transactions over N sec are too long]:seconds:' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--no-pager[do not invoke pager]' \
  '(-h --host)'{-h+,--host=}'[database host or socket dir]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[database port]:port:' \
  '(-U --username)'{-U+,--username=}'[database user]:user:_users' \
  '(-w --no-password)'{-w,--no-password}'[never prompt for password]' \
  '--role=[execute collection as role]:role:' \
  '*:database name:' && ret=0

return ret
