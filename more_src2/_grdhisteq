#compdef grdhisteq
# Documentation: https://docs.generic-mapping-tools.org/latest/grdhisteq.html
# Source: GenericMappingTools/gmt classic-mode grdhisteq — histogram-equalize a grid (linear / quadratic / Gaussian).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[number of cells (divisions, default 16)]:n:_default' \
    '-D+[level info to file (or stdout)]:file:_files' \
    '-G+[output grid file]:file:_files' \
    '-N+[Gaussian-distributed output (optional ±norm)]:opts:_default' \
    '-Q[quadratic equalization (default linear)]' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-h+[header records]:n:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
