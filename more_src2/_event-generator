#compdef event-generator opkssh
# Documentation: upstream READMEs at github.com/{falcosecurity/event-generator,openpubkey/opkssh}
# Reference accessed: 2026-05-30
# Mixed-theme R52 — Falco event-generator + OpenPubkey opkssh.
# event-generator sister-binary to existing _falco/_falcoctl coverage.
# opkssh: SSH access via OpenID Connect identities (no long-lived keys).

local curcontext="$curcontext" state line ret=1

case $service in

  event-generator)
    # falcosecurity/event-generator — generate suspect actions for
    # Falco-rule testing.
    local -a _subcmds
    _subcmds=(
      'run:execute suspicious actions to trigger Falco alerts'
      'test:validate actions against a running Falco instance'
      'bench:measure event throughput (EPS)'
      'suite:YAML-declarative test scenarios (v0.13+)'
    )
    local -a _suite_subs
    _suite_subs=(
      'run:execute declared actions from a suite file'
      'test:execute + verify Falco alerts from a suite file'
      'explain:show suite YAML schema documentation'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'event-generator subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          run)
            _arguments \
              '--loop[execute actions repeatedly]' \
              '--sleep=[duration between actions (default 100ms)]:duration:' \
              '--all[enable all actions including non-default]' \
              '*:action regexp (default: all default actions):' && ret=0
            ;;
          test)
            _arguments \
              '--falco-server=[Falco HTTP server (default localhost:8080)]:url:' \
              '*:action regexp:' && ret=0
            ;;
          bench)
            _arguments \
              '--loop[halve sleep duration each round]' \
              '--sleep=[controls EPS; lower = higher EPS]:duration:' \
              '--pid=[monitor specific Falco process]:pid:' \
              '*:action regexp:' && ret=0
            ;;
          suite)
            _arguments -C \
              '(-): :->scmd' \
              '(-)*:: :->scmd_args' && ret=0
            case $state in
              scmd)
                _describe -t commands 'event-generator suite subcommand' _suite_subs && ret=0
                ;;
              scmd_args)
                case $words[1] in
                  run|test)
                    _arguments \
                      '1:suite YAML file:_files -g "*.yaml"' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;

  opkssh)
    # openpubkey/opkssh — SSH access via OpenID Connect identities.
    # Eliminates long-lived SSH keys by integrating with OpenID Providers.
    local -a _subcmds
    _subcmds=(
      'login:generate SSH key containing your OpenID token'
      'logout:remove generated SSH keys'
      'inspect:display details of opkssh-generated SSH keys/certificates'
      'audit:validate policy file consistency'
      'add:add authorization rules (server-side)'
      'permissions:manage filesystem permissions (check/fix/install)'
    )
    local -a _perm_subs
    _perm_subs=(
      'check:check current filesystem permissions'
      'fix:fix filesystem permissions'
      'install:install required filesystem permissions'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'opkssh subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          login)
            _arguments \
              '--provider=[OpenID Provider (issuer,client_id[,client_secret,scopes])]:provider:' \
              '-i+[custom key name (e.g. opkssh_server_group1)]:key:' \
              '--create-config[generate client config at ~/.opk/config.yml]' && ret=0
            ;;
          logout)
            _arguments \
              '-i+[remove a specific SSH key pair]:key:_files' && ret=0
            ;;
          inspect)
            _arguments \
              '1:path:_files' && ret=0
            ;;
          add)
            _arguments \
              '1:user:' \
              '2:identity (email/sub/group):' \
              '3:issuer (URL or shorthand: google/azure/etc):' && ret=0
            ;;
          permissions)
            _arguments \
              '1:permissions action:(check fix install)' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
