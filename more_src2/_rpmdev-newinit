#compdef rpmdev-newinit
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-newinit.in
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools rpmdev-newinit source.

# rpmdev-newinit: create new SysV init script from template
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output file (- for stdout)]:file:_files' \
  '*:app name:' && ret=0
return ret
