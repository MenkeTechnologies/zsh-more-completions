#compdef plop-cli
# _plop-cli — Andrew Worcester Plop micro-generator framework CLI alias (amwmedia / Andrew Worcester, JavaScript); commander
# upstream: https://github.com/plopjs/plop

_plop-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--plopfile=+[plopfile path]:file:_files -g "plopfile.* *.js *.ts *.cjs *.mjs"' \
        '--cwd=+[change cwd]:dir:_files -/' \
        '--require=+[require module]:list:' \
        '--dest=+[destination dir]:dir:_files -/' \
        '--bypass=+[bypass prompts]:list:' \
        '--force[force]' \
        '-f[force]' \
        '--showTypeNames[show type names]' \
        '--list[list generators]' \
        '-l[list generators]' \
        '--show-type-names[show type names]' \
        '--no-color[no color]' \
        '*:generator-name-and-args:'
}

_plop-cli "$@"
