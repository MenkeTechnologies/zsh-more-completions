#compdef foamVTKSeries
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamVTKSeries — emit a ParaView .vtk.series JSON descriptor for VTK time-series.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-case -c)'{-case,-c}'[case directory (default cwd)]:dir:_directories' \
    '(-dir -d)'{-dir,-d}'[post-processing directory (default postProcessing)]:dir:_directories' \
    '(-help -h)'{-help,-h}'[print usage]' \
    && ret=0

return ret
