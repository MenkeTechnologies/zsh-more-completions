#compdef dfu-suffix
# Documentation: https://dfu-util.sourceforge.net/dfu-suffix.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--check=[check for a valid DFU suffix]:file:_files' \
  '--add=[add a DFU file suffix]:file:_files' \
  '--delete=[remove a DFU suffix]:file:_files' \
  '(-v --vid)'{-v+,--vid=}'[USB vendor ID (hex)]:vid' \
  '(-p --pid)'{-p+,--pid=}'[USB product ID (hex)]:pid' \
  '(-d --did)'{-d+,--did=}'[USB device ID (hex)]:did' \
  '(-S --spec)'{-S+,--spec=}'[DFU specification version (hex)]:spec' && ret=0

return ret
