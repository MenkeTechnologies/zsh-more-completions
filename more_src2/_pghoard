#compdef pghoard pghoard_archive_cleanup pghoard_archive_sync pghoard_create_keys pghoard_postgres_command pghoard_restore
# Documentation: https://github.com/Aiven-Open/pghoard
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

case $service in
  (pghoard)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '--short-log[short log format]' \
      '--config=[config file]:file:_files -g "*.json"' && ret=0 ;;
  (pghoard_restore)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)--version[show version]' \
      '(-D --debug)'{-D,--debug}'[enable debug logging]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '--config=[pghoard config file]:file:_files' \
      '--status-output-file=[status output JSON file]:file:_files' \
      '--site=[pghoard site]:name:' \
      '--host=[repository host]:host:_hosts' \
      '--port=[repository port]:port:' \
      '--username=[repository username]:user:' \
      '--password=[repository password]:pw:' \
      '--basebackup=[basebackup name (default: latest)]:name:' \
      '--target-dir=[PostgreSQL data directory]:dir:_files -/' \
      '--overwrite[overwrite existing target directory]' \
      '*--tablespace-dir=[map tablespace NAME=DIR]:mapping:' \
      '--tablespace-base-dir=[map all tablespaces to base dir]:dir:_files -/' \
      '--primary-conninfo=[replication connection info]:conninfo:' \
      '--recovery-target-name=[named restore point]:name:' \
      '--recovery-target-time=[timestamp for recovery]:time:' \
      '--recovery-target-xid=[transaction ID for recovery]:xid:' \
      '--recovery-target-action=[action at recovery target]:action:(pause promote shutdown)' \
      '--recovery-end-command=[command at recovery end]:cmd:' \
      '--restore-to-primary[restore as primary]' \
      '--preserve-until=[preserve until date]:date:' \
      '--cancel-preserve-on-success[cancel preservation after success]' \
      '--pghoard-postgres-command-bin=[postgres command binary path]:file:_files' \
      '1:command:(list-basebackups-http list-basebackups get-basebackup)' && ret=0 ;;
  (pghoard_archive_cleanup|pghoard_archive_sync)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--config=[config file]:file:_files' \
      '--site=[site name]:name:' && ret=0 ;;
  (pghoard_create_keys)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--key-id=[key id]:id:' \
      '--config=[config file]:file:_files' \
      '--site=[site name]:name:' && ret=0 ;;
  (pghoard_postgres_command)
    _arguments \
      '(- *)'{-h,--help}'[show help]' \
      '--config=[config file]:file:_files' \
      '--mode=[mode]:mode:(archive restore)' \
      '--site=[site name]:name:' \
      '--xlog=[xlog name]:name:' \
      '--output=[output file]:file:_files' && ret=0 ;;
esac

return ret
