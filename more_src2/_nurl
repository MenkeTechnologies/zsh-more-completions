autoload -U is-at-least

_nurl() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-S+[Fetch submodules instead of using the fetcher'\''s default]::SUBMODULES:(true false)' \
'--submodules=[Fetch submodules instead of using the fetcher'\''s default]::SUBMODULES:(true false)' \
'-f+[Specify the fetcher function instead of inferring from the URL]:FETCHER:(builtins.fetchGit fetchCrate fetchFromBitbucket fetchFromGitHub fetchFromGitLab fetchFromGitea fetchFromGitiles fetchFromRepoOrCz fetchFromSourcehut fetchHex fetchPypi fetchgit fetchhg fetchpatch fetchpatch2 fetchsvn fetchurl fetchzip)' \
'--fetcher=[Specify the fetcher function instead of inferring from the URL]:FETCHER:(builtins.fetchGit fetchCrate fetchFromBitbucket fetchFromGitHub fetchFromGitLab fetchFromGitea fetchFromGitiles fetchFromRepoOrCz fetchFromSourcehut fetchHex fetchPypi fetchgit fetchhg fetchpatch fetchpatch2 fetchsvn fetchurl fetchzip)' \
'-F+[The fetcher to fall back to when nurl fails to infer it from the URL]:FALLBACK:(builtins.fetchGit fetchCrate fetchFromBitbucket fetchFromGitHub fetchFromGitLab fetchFromGitea fetchFromGitiles fetchFromRepoOrCz fetchFromSourcehut fetchHex fetchPypi fetchgit fetchhg fetchpatch fetchpatch2 fetchsvn fetchurl fetchzip)' \
'--fallback=[The fetcher to fall back to when nurl fails to infer it from the URL]:FALLBACK:(builtins.fetchGit fetchCrate fetchFromBitbucket fetchFromGitHub fetchFromGitLab fetchFromGitea fetchFromGitiles fetchFromRepoOrCz fetchFromSourcehut fetchHex fetchPypi fetchgit fetchhg fetchpatch fetchpatch2 fetchsvn fetchurl fetchzip)' \
'-n+[Path to nixpkgs (in nix)]:NIXPKGS:_default' \
'--nixpkgs=[Path to nixpkgs (in nix)]:NIXPKGS:_default' \
'-i+[Extra indentation (in number of spaces)]:INDENT:_default' \
'--indent=[Extra indentation (in number of spaces)]:INDENT:_default' \
'*-a+[Additional arguments to pass to the fetcher]:NAME:_default:NAME:_default' \
'*--arg=[Additional arguments to pass to the fetcher]:NAME:_default:NAME:_default' \
'*-A+[Same as --arg, but accepts strings instead Nix expressions]:NAME:_default:NAME:_default' \
'*--arg-str=[Same as --arg, but accepts strings instead Nix expressions]:NAME:_default:NAME:_default' \
'*-o+[Overwrite arguments in the final output, not taken into consideration when fetching the hash]:NAME:_default:NAME:_default' \
'*--overwrite=[Overwrite arguments in the final output, not taken into consideration when fetching the hash]:NAME:_default:NAME:_default' \
'*-O+[Same as --overwrite, but accepts strings instead Nix expressions]:NAME:_default:NAME:_default' \
'*--overwrite-str=[Same as --overwrite, but accepts strings instead Nix expressions]:NAME:_default:NAME:_default' \
'--overwrite-rev=[Same as --overwrite (rev|tag|version) <EXPR>, depending on the rev-like attribute the fetcher uses]:EXPR:_default' \
'--overwrite-rev-str=[Same as --overwrite-str (rev|tag|version) <STRING>, depending on the rev-like attribute the fetcher uses]:STRING:_default' \
'-e+[Instead of fetching a URL, get the hash of a fixed-output derivation, implies --hash and ignores all other options]:EXPR:_default' \
'--expr=[Instead of fetching a URL, get the hash of a fixed-output derivation, implies --hash and ignores all other options]:EXPR:_default' \
'-s+[Print out the listed fetchers with the specified separator, only used when --list-fetchers or --list-possible-fetchers is specified]:SEPARATOR:_default' \
'--list-sep=[Print out the listed fetchers with the specified separator, only used when --list-fetchers or --list-possible-fetchers is specified]:SEPARATOR:_default' \
'-H[Only output the hash]' \
'--hash[Only output the hash]' \
'-j[Output in json format]' \
'--json[Output in json format]' \
'-p[Parse the url without fetching the hash, output in json format]' \
'--parse[Parse the url without fetching the hash, output in json format]' \
'-l[List all available fetchers]' \
'--list-fetchers[List all available fetchers]' \
'-L[List all fetchers that can be generated without --fetcher]' \
'--list-possible-fetchers[List all fetchers that can be generated without --fetcher]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::url -- URL to the repository to be fetched:_default' \
'::rev -- The revision or reference to be fetched:_default' \
&& ret=0
}

(( $+functions[_nurl_commands] )) ||
_nurl_commands() {
    local commands; commands=()
    _describe -t commands 'nurl commands' commands "$@"
}

if [ "$funcstack[1]" = "_nurl" ]; then
    _nurl "$@"
else
    compdef _nurl nurl
fi
