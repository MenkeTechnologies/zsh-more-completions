#compdef plink
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/plink.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-V[show version]' \
  '-pgpfp[show PGP key fingerprints]' \
  '-v[verbose]' \
  '-load+[load saved session]:session:' \
  '(-ssh -telnet -rlogin -raw -serial -ssh-connection)-ssh[SSH protocol]' \
  '(-ssh -telnet -rlogin -raw -serial -ssh-connection)-telnet[Telnet protocol]' \
  '(-ssh -telnet -rlogin -raw -serial -ssh-connection)-rlogin[rlogin protocol]' \
  '(-ssh -telnet -rlogin -raw -serial -ssh-connection)-raw[raw protocol]' \
  '(-ssh -telnet -rlogin -raw -serial -ssh-connection)-serial[serial protocol]' \
  '(-ssh -telnet -rlogin -raw -serial -ssh-connection)-ssh-connection[bare ssh-connection]' \
  '-P+[port]:port:' \
  '-l+[login user]:user:_users' \
  '-pw+[password]:pw:' \
  '-pwfile+[password file]:file:_files' \
  '-batch[no interactive prompts]' \
  '-proxycmd+[local proxy command]:cmd:' \
  '-sercfg+[serial config]:str:' \
  '-D+[SOCKS dynamic forward]:port:' \
  '*-L+[local forward]:forward:' \
  '*-R+[remote forward]:forward:' \
  '-X[enable X11 forwarding]' \
  '-x[disable X11 forwarding]' \
  '-A[enable agent forwarding]' \
  '-a[disable agent forwarding]' \
  '-t[allocate PTY]' \
  '-T[no PTY]' \
  '-1[force SSH v1]' \
  '-2[force SSH v2]' \
  '-4[force IPv4]' \
  '-6[force IPv6]' \
  '-C[enable compression]' \
  '-i+[private key file]:file:_files' \
  '-noagent[do not use Pageant]' \
  '-agent[use Pageant]' \
  '-no-trivial-auth[reject trivial auth]' \
  '-noshare[do not share connection]' \
  '-share[share connection]' \
  '*-hostkey+[accept host key]:key:' \
  '-sanitise-stderr[sanitize stderr]' \
  '-no-sanitise-stderr[do not sanitize stderr]' \
  '-sanitise-stdout[sanitize stdout]' \
  '-no-sanitise-stdout[do not sanitize stdout]' \
  '-no-antispoof[disable antispoof]' \
  '-m+[remote command file]:file:_files' \
  '-s[command is SSH subsystem]' \
  '-N[no shell/command]' \
  '-nc+[tunnel mode]:host\:port:' \
  '-sshlog+[log SSH packets]:file:_files' \
  '-sshrawlog+[log raw SSH data]:file:_files' \
  '-logoverwrite[overwrite logs]' \
  '-logappend[append logs]' \
  '-shareexists[test for shareable connection]' \
  ':host:_hosts' \
  '*:command:'
