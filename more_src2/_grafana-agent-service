#compdef grafana-agent-service
# _grafana-agent-service — Windows service wrapper that supervises a grafana-agent binary
# upstream: https://github.com/grafana/agent
# Source: cmd/grafana-agent-service/{main_windows,config_windows}.go on tip.
# Has no CLI flags — service config (ServicePath, Arguments, Environment) is read from the Windows registry under HKLM\Software\Grafana\Grafana Agent Flow.

_grafana-agent-service() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_grafana-agent-service "$@"
