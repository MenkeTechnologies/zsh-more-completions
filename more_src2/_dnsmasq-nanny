#compdef dnsmasq-nanny
# _dnsmasq-nanny — kubernetes/dns dnsmasq supervisor (restarts dnsmasq on ConfigMap change)
# upstream: https://github.com/kubernetes/dns
# Flags from cmd/dnsmasq-nanny/main.go on tip.

_dnsmasq-nanny() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--dnsmasqExec=[dnsmasq binary path]:file:_files' \
        '--restartDnsmasq=[restart dnsmasq on config change]:bool:(true false)' \
        '--configDir=[directory with stub-domain configs]:dir:_files -/' \
        '--syncInterval=[ConfigMap sync interval]:dur:' \
        '--kubednsServer=[kube-dns server address]:host\:port:' \
        '--logInterval=[periodic restart log interval]:dur:' \
        '-v[klog verbosity level]:n:'
}

_dnsmasq-nanny "$@"
