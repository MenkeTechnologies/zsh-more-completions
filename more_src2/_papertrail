#compdef papertrail
# Documentation: https://github.com/papertrail/papertrail-cli/blob/master/lib/papertrail/cli.rb
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --follow)'{-f,--follow}'[continue running and print new events]' \
  '(-d --delay)'{-d+,--delay=}'[delay between refreshes (s)]:seconds:' \
  '(-c --configfile)'{-c+,--configfile=}'[config file path]:file:_files' \
  '(-s --system)'{-s+,--system=}'[filter by system/source]:system:' \
  '(-g --group)'{-g+,--group=}'[filter by group name]:group:' \
  '(-S --search)'{-S+,--search=}'[use a saved search]:search:' \
  '(-j --json)'{-j,--json}'[output raw JSON]' \
  '--color=[colorize output]:mode:(program system all off)' \
  '--force-color[force ANSI colors on non-TTY output]' \
  '--min-time=[earliest time to search]:time:' \
  '--max-time=[latest time to search]:time:' \
  '*::query:' && ret=0

return ret
