#compdef laika
# _laika — Jens Halm Laika Scala site/e-book generator CLI alias (typelevel team, Scala); sbt plugin and tools
# upstream: https://github.com/typelevel/Laika

_laika() {
    local -a sub=(
        'laikaSite:build site'
        'laikaGenerate:generate output'
        'laikaPublish:publish site'
        'laikaPreview:preview site'
        'laikaPreviewStop:stop preview server'
        'laikaPdf:generate pdf'
        'laikaHtml:generate html'
        'laikaEpub:generate epub'
        'laikaAst:dump ast'
        'laikaXslFo:generate xsl-fo'
        'laikaPackageSite:package as zip'
        'laikaIncludeAPI:include API docs'
        'laikaCleanTargets:clean output'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--input=+[input dir]:dir:_files -/' \
        '-i+[input dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--theme=+[theme jar]:file:_files -g "*.jar"' \
        '--format=+[format]:f:(html epub pdf xsl-fo ast)' \
        '--strict[strict parsing]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-c+[config file]:file:_files -g "*.conf"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'laika subcommand' sub ;;
        args)
            case $words[1] in
                laikaPreview) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' ;;
                laikaPdf|laikaHtml|laikaEpub|laikaXslFo) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_laika "$@"
