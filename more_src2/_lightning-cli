#compdef lightning-cli
# Documentation: https://github.com/ElementsProject/lightning (cli/lightning-cli.c getopt_long table)
# Reference accessed: 2026-05-29
# Core Lightning RPC client.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show this message; use the help command without hyphens for daemon help]' \
  '(-H --human-readable)'{-H,--human-readable}'[output formatted for human consumption]' \
  '(-F --flat)'{-F,--flat}'[flatten output using dot-notation (x.y.z=value)]' \
  '(-J --json)'{-J,--json}'[JSON output (default unless running help)]' \
  '(-R --raw)'{-R,--raw}'[raw, unformatted JSON output]' \
  '(-k --keywords)'{-k,--keywords}'[use key=value format for parameters]' \
  '(-o --order)'{-o,--order}'[use positional parameters in order]' \
  '(-N --notifications)'{-N,--notifications=}'[set notification level, or none to disable]:level:(none debug info warn error)' \
  '(-l --filter)'{-l,--filter=}'[apply JSON reply filter]:filter:' \
  '(-c --commando)'{-c,--commando=}'[send as commando command to nodeid\:rune]:nodeid:rune:' \
  '--conf=[path to lightningd config file]:file:_files' \
  '--lightning-dir=[lightningd data directory]:dir:_directories' \
  '--network=[network name]:network:(bitcoin testnet signet regtest litecoin)' \
  '--testnet[shortcut for --network=testnet]' \
  '--signet[shortcut for --network=signet]' \
  '--regtest[shortcut for --network=regtest]' \
  '--mainnet[shortcut for --network=bitcoin]' \
  '--rpc-file=[RPC unix socket filename]:file:_files' \
  '*: :->args' && ret=0

return ret
