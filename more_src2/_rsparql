#compdef rsparql sparql qparse arq
# Documentation: https://jena.apache.org/documentation/query/cmds.html
# Source: apache/jena ARQ SPARQL command-line tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --query)'{-q+,--query=}'[query file]:file:_files -g "*.(rq|sparql)(-.)"' \
    '--file=[query file]:file:_files -g "*.(rq|sparql)(-.)"' \
    '*--data=[default-graph data file]:file:_files' \
    '*--namedgraph=[named-graph data file]:file:_files' \
    '*--graph=[graph data file]:file:_files' \
    '--desc=[Jena assembler description of dataset]:file:_files' \
    '--dataset=[Jena assembler description of dataset]:file:_files' \
    '--service=[remote SPARQL endpoint URL]:url:_urls' \
    '--print=[print parsed query/algebra (op|query|prefix|none)]:what:(op query prefix none)' \
    '--results=[results output format]:format:(text json xml csv tsv rdf/xml turtle nt srx srj)' \
    '--in=[result-set input format]:format:_default' \
    '--out=[result-set output format]:format:_default' \
    '--base=[set base IRI]:iri:_urls' \
    '--syntax=[query syntax]:syntax:(SPARQL_11 ARQ SPARQL_10 SPARQL_12)' \
    '--time[print query timing]' \
    '--explain[print explain output]' \
    '--strict[strict SPARQL mode]' \
    '--closeworld[closed-world semantics]' \
    '--reduced[use REDUCED instead of DISTINCT]' \
    '-v[verbose]' \
    && ret=0

return ret
