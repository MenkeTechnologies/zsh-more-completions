#compdef gpspipe
# Documentation: https://gpsd.io/gpspipe.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help,-\?}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-2 --split24)'{-2,--split24}'[set split24 flag on AIS reports]' \
  '(-B --nobuffer)'{-B,--nobuffer}'[disable output buffering]' \
  '(-d --daemonize)'{-d,--daemonize}'[run as daemon]' \
  '(-D --debug)'{-D+,--debug=}'[debug level]:level:' \
  '(-l --sleep)'{-l,--sleep}'[wait 10 seconds before connecting]' \
  '(-n --count)'{-n+,--count=}'[stop after N packets]:n:' \
  '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
  '(-p --profile)'{-p,--profile}'[include profiling info]' \
  '(-P --pps)'{-P,--pps}'[enable PPS drift JSON output]' \
  '(-r --nmea)'{-r,--nmea}'[output NMEA sentences]' \
  '(-R --raw)'{-R,--raw}'[output raw GPS binary data]' \
  '(-s --serial)'{-s+,--serial=}'[also write to serial device]:dev:_files' \
  '(-S --scaled)'{-S,--scaled}'[scaled flag for AIS/SUBFRAME data]' \
  '(-t --timestamp)'{-t,--timestamp}'[add UTC timestamp]' \
  '(-T --timefmt)'{-T+,--timefmt=}'[strftime time format]:fmt:' \
  '(-u --usec)'{-u,--usec}'[microsecond precision timestamps]' \
  '(-v --spinner)'{-v,--spinner}'[show activity indicator]' \
  '(-w --json)'{-w,--json}'[output native gpsd JSON]' \
  '(-x --seconds)'{-x+,--seconds=}'[exit after N seconds]:sec:' \
  '(-Z --zulu)'{-Z,--zulu}'[use ISO8601 timestamp format]' \
  '*:gpsd_source:' && ret=0

return ret
