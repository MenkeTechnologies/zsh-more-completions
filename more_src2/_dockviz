#compdef dockviz
# Documentation: https://github.com/justone/dockviz
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'images:visualize docker images'
  'containers:visualize docker containers'
  'help:show help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[help]' \
  '--version[show version]' \
  '--stdin[read docker JSON from stdin]' \
  '--tlscacert=[TLS CA cert]:file:_files' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'dockviz command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      images)
        _arguments \
          '(-t --tree)'{-t,--tree}'[display as terminal tree]' \
          '(-d --dot)'{-d,--dot}'[output Graphviz dot format]' \
          '(-s --short)'{-s,--short}'[short summary form]' \
          '(-l --only-labelled)'{-l,--only-labelled}'[only tagged images]' \
          '(-i --incremental)'{-i,--incremental}'[incremental sizes]' \
          '(-c --no-human)'{-c,--no-human}'[raw byte counts]' && ret=0
        ;;
      containers)
        _arguments \
          '(-d --dot)'{-d,--dot}'[output Graphviz dot format]' \
          '-r[only running containers]' && ret=0
        ;;
    esac
    ;;
esac

return ret
