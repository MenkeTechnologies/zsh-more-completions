#compdef dhcrelay
# Documentation: https://manpages.debian.org/bookworm/isc-dhcp-relay/dhcrelay.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcrelay: ISC DHCP relay agent (DHCPv4 mode by default; -6 selects DHCPv6).
local curcontext="$curcontext" ret=1
_arguments -C \
  '-4[DHCPv4/BOOTP mode (default)]' \
  '-6[DHCPv6 mode]' \
  '-d[run as foreground process]' \
  '-q[quiet mode]' \
  '-a[append agent option field]' \
  '-A+[maximum size of forwarded packet]:length' \
  '-c+[maximum hop count]:count' \
  '-D[drop packets with relay agent options]' \
  '-g+[replace gateway IP address]:ipaddr' \
  '-i+[interface to listen on]:iface:_net_interfaces' \
  '-iu+[upstream interface]:iface:_net_interfaces' \
  '-id+[downstream interface]:iface:_net_interfaces' \
  '-m+[relay agent option handling]:mode:(append replace forward discard)' \
  '-p+[port to listen/transmit on]:port' \
  '-pf+[alternate pid file path]:file:_files' \
  '--no-pid[do not write pid file]' \
  '-U+[enable RFC 3527 link selection suboption]:iface:_net_interfaces' \
  '*:dhcp server:_hosts' && ret=0
return ret
