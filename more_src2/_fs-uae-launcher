#compdef fs-uae-launcher
# Documentation: https://github.com/FrodeSolheim/fs-uae-launcher/blob/master/launcher/launcherapp.py
# Reference accessed: 2026-05-16
# Verified: launcher/launcherapp.py lines 88-108 (sys.argv inspection, no
# argparse). Also: launcher/ui/launcherwindow.py (--window-border,
# --no-window-border, --editor), launcher/devicemanager.py (--add-dummy-joystick),
# launcher/ui/launch.py (--no-gui), launcher/apps/__init__.py (--server,
# --arcade), launcher/launcherapp.py (--new-config, --new-config=<platform>).

# FS-UAE Launcher: Python GUI launcher for FS-UAE
local curcontext="$curcontext" ret=1
_arguments -C \
  '--window-border[force window border]' \
  '--no-window-border[disable window border]' \
  '--editor[start in editor mode]' \
  '--add-dummy-joystick[add a dummy joystick]' \
  '--no-gui[run without GUI]' \
  '--server[run as server]' \
  '--arcade[run in arcade mode]' \
  '--new-config[create new config]' \
  '*:config / archive / floppy:_files -g "*.(fs-uae|zip|lha|adf|adz|dms|ipf|cue|iso)"' && ret=0
return ret
