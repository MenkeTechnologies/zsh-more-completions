#compdef igniter
# Documentation: https://github.com/ash-project/igniter/tree/main/lib/mix/tasks
# Documentation: https://github.com/ash-project/igniter/blob/main/installer/lib/mix/tasks/igniter.new.ex
# Reference accessed: 2026-05-27
# Verified: upstream Mix.Tasks.Igniter.* schema/aliases blocks and igniter.new OptionParser strict list.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'igniter.new:create a new Igniter project'
  'igniter.install:install one or more packages and run their installers'
  'igniter.add:add deps to mix.exs without running installers'
  'igniter.remove:remove deps from mix.exs and clean unused'
  'igniter.add_extension:add an extension to .igniter.exs'
  'igniter.update_gettext:update gettext setup using igniter'
  'igniter.setup:run igniter setup on the project'
  'igniter.move_files:move files according to module locations'
  'igniter.apply_upgrades:apply pending upgrade tasks'
  'igniter.upgrade:upgrade deps and run their upgrade tasks'
  'igniter.upgrade_igniter:upgrade igniter itself'
  'igniter.gen.task:generate a new igniter task'
  'igniter.phx.install:install Phoenix via igniter'
  'igniter.refactor.rename_function:rename a function across the project'
  'igniter.refactor.rename_module:rename a module across the project'
  'igniter.refactor.unless_to_if_not:rewrite unless x to if !x'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'igniter subcommand' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      igniter.new)
        _arguments -s -S \
          '*'{-i+,--install=}'[comma-separated deps to install after creation]:deps:' \
          '(-l --local)'{-l+,--local=}'[path to a local igniter checkout]:path:_files -/' \
          '(-e --example)'{-e,--example}'[request example code in installed packages]' \
          '(-w --with)'{-w+,--with=}'[command to use instead of mix new (e.g. phx.new)]:cmd:' \
          '--with-args=[additional args for the --with command]:args:' \
          '--module=[base module name for the project]:module:' \
          '--sup[generate OTP application with supervision tree]' \
          '--umbrella[generate an umbrella project]' \
          '--no-installer-version-check[skip latest igniter_new version check]' \
          '--no-git[skip initializing a git repository]' \
          '1:project_name:' && ret=0
        ;;
      igniter.install)
        _arguments -s -S \
          '--only=[install only in given environments (comma-sep)]:env:' \
          '--dry-run[run the task without making any changes]' \
          '--yes[automatically answer yes to prompts]' \
          '--yes-to-deps[answer yes only to new-deps prompts]' \
          '--verbose[display additional output]' \
          '--example[request installed packages include example code]' \
          '*:package:' && ret=0
        ;;
      igniter.add)
        _arguments -s -S \
          '--yes[automatically answer yes to prompts]' \
          '*:dep:' && ret=0
        ;;
      igniter.remove)
        _arguments -s -S \
          '*:dep:' && ret=0
        ;;
      igniter.add_extension)
        _arguments -s -S \
          '1:extension:(phoenix)' && ret=0
        ;;
      igniter.upgrade)
        _arguments -s -S \
          '--yes[accept all changes automatically]' \
          '--all[upgrade all dependencies]' \
          '--only=[only fetch deps for given environment]:env:' \
          '--target=[only fetch deps for given target]:target:' \
          '--verbose[display additional output]' \
          '--no-archives-check[do not check archives before fetching]' \
          '--git-ci[use git HEAD~1 to detect previous versions (implies --yes)]' \
          '*:package:' && ret=0
        ;;
      igniter.gen.task)
        _arguments -s -S \
          '(-o --no-optional)'{-o,--no-optional}'[task is not optional-dep compatible]' \
          '(-u --upgrade)'{-u,--upgrade}'[generate an upgrade task]' \
          '(-p --private)'{-p,--private}'[generate a private task]' \
          '1:task_name:' && ret=0
        ;;
      igniter.refactor.rename_function)
        _arguments -s -S \
          '--deprecate=[deprecation kind for old function]:kind:(soft hard)' \
          '1:old:' \
          '2:new:' && ret=0
        ;;
      igniter.refactor.rename_module)
        _arguments -s -S \
          '1:old_module:' \
          '2:new_module:' && ret=0
        ;;
      igniter.refactor.unless_to_if_not|igniter.setup|igniter.move_files|igniter.apply_upgrades|igniter.upgrade_igniter|igniter.update_gettext|igniter.phx.install)
        _normal && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
