#compdef dnsmx
# _dnsmx — djbdns dnsmx (look up MX records for one or more domain names; prints each MX in priority,host form)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from dnsmx.c on tip.

_dnsmx() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '(-n --new)'{-n,--new}'[new output style]' \
        '*:domain:_hosts'
}

_dnsmx "$@"
