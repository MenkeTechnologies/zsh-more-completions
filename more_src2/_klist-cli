#compdef klist-cli
# _klist-cli — MIT Kerberos klist list cached Kerberos tickets CLI alias (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_klist-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c[show credentials cache]' \
        '-k[show keytab]' \
        '-A[show all caches]' \
        '-f[show flags]' \
        '-e[show encryption type]' \
        '-d[show ticket DNS]' \
        '-K[show key]' \
        '-t[show keytab entries timestamps]' \
        '-n[show numeric addresses]' \
        '-l[show list of caches]' \
        '-s[silent (exit only)]' \
        '-i+[input cache]:file:_files' \
        '-C[show config entries]' \
        '-V[show version]' \
        '*:cache:_files'
}

_klist-cli "$@"
