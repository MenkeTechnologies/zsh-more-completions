#compdef kpropd
# _kpropd — MIT Kerberos Consortium kpropd Kerberos V5 KDB propagation receive daemon for incremental updates (krb5 team, C); custom argparse
# upstream: https://github.com/krb5/krb5

_kpropd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-r+[realm]:str:' \
        '--realm=+[realm]:str:' \
        '-A+[admin server host]:host:_hosts' \
        '-a+[ACL file]:file:_files' \
        '-d[debug mode]' \
        '-D[no fork]' \
        '--standalone[standalone mode]' \
        '-S[server mode]' \
        '-f+[kerberos slave file]:file:_files' \
        '-F+[ifd file]:file:_files' \
        '-P+[port]:port:_ports' \
        '-p+[propagate command]:str:' \
        '-x+[db arg]:str:' \
        '--db-args=+[db arg]:str:' \
        '-t[run only once]' \
        '--debug[debug mode]'
}

_kpropd "$@"
