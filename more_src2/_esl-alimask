#compdef esl-alimask
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-alimask.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-alimask: mask MSA columns based on annotation, gap freq, or PP
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-o[output file]:file:_files' \
  '-q[quiet (only with -o)]' \
  '-g[gap frequency masking mode]' \
  '-p[posterior probability masking mode]' \
  '-t[truncation masking mode]' \
  '--informat=[input alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip phylips)' \
  '--outformat=[output alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip phylips)' \
  '--small[memory-saving mode (Pfam format only)]' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '--fmask-rf=[save final mask (RF length) to file]:file:_files' \
  '--fmask-all=[save final mask (full length) to file]:file:_files' \
  '--gmask-rf=[save gap-frequency mask (RF length)]:file:_files' \
  '--gmask-all=[save gap-frequency mask (full length)]:file:_files' \
  '--pmask-rf=[save PP-based mask (RF length)]:file:_files' \
  '--pmask-all=[save PP-based mask (full length)]:file:_files' \
  '--gapthresh=[gap fraction threshold]:x' \
  '--pfract=[fraction threshold for PP masking]:x' \
  '--pthresh=[PP threshold for keeping residues]:x' \
  '--pavg=[average PP threshold for keeping column]:x' \
  '--ppcons=[use PP_cons annotation with threshold]:x' \
  '--pallgapok[allow all-gap columns in PP mode]' \
  '--t-rf[interpret -t coords as RF positions]' \
  '--t-rmins[remove RF gap columns in truncation range]' \
  '--keepins[allow keeping RF gap columns]' \
  '*:alignment file:_files' && ret=0
return ret
