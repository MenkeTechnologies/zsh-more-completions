#compdef kubescape2
# _kubescape2 — ARMO Kubescape kubescape2 CLI command-line frontend wrapping the Kubescape open-source CNCF Sandbox project comprehensive Kubernetes security platform from your IDE to production scans Kubernetes clusters Kubernetes-manifests-YAML Helm charts code-repositories-and-container-images-for-misconfigurations-vulnerabilities-and-network-issues NSA CIS MITRE-ATT&CK ArmoBest All YAML JSON HTML PDF PRometheus framework controls Helm-scan image-scan attack-chain operator (ARMO Kubescape CNCF team Ben Hirschberg Craig Box, Go); cobra
# upstream: https://kubescape.io/

_kubescape2() {
    local -a sub=(
        'scan:scan resources'
        'submit:submit results'
        'list:list known frameworks/controls/configs'
        'config:configure CLI'
        'patch:patch image'
        'download:download artifacts'
        'completion:generate shell completion'
        'fix:fix manifests'
        'operator:operator subcommand'
        'prometheus:Prometheus scan'
        'delete:delete results'
        'update:update CLI'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--logger=+[l]:l:(debug info warning error fatal panic disable)' \
        '--log-file=+[file]:file:_files' \
        '-a+[account]:str:' \
        '--account=+[id]:str:' \
        '--access-key=+[key]:str:' \
        '-c+[cache dir]:dir:_files -/' \
        '--cache-dir=+[dir]:dir:_files -/' \
        '--disable-color[no color]' \
        '--format-version=+[v]:str:' \
        '-f+[format]:f:(pretty-printer json prometheus pdf html sarif junit)' \
        '--format=+[fmt]:f:(pretty-printer json prometheus pdf html sarif junit)' \
        '-t+[fail threshold]:n:' \
        '--fail-threshold=+[N]:n:' \
        '--compliance-threshold=+[N]:n:' \
        '--severity-threshold=+[s]:s:(low medium high critical)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--use-default[use default config]' \
        '--use-from=+[file]:file:_files' \
        '*--use-from=+[file]:file:_files' \
        '-e+[exclude namespaces]:str:' \
        '--exclude-namespaces=+[ns]:str:' \
        '--include-namespaces=+[ns]:str:' \
        '-s+[submit results]' \
        '--submit[submit results]' \
        '--keep-local[keep local]' \
        '--enable-host-scan[enable host scan]' \
        '--exceptions=+[file]:file:_files -g "*.json"' \
        '--controls-config=+[file]:file:_files -g "*.json"' \
        '--scan-images[scan images]' \
        '--credentials-username=+[user]:_users' \
        '--credentials-password=+[password]:str:' \
        '--credentials-token=+[token]:str:' \
        '--kube-context=+[context]:str:' \
        '--enable-rules-by-rego[enable rego rules]' \
        '--enable-attack-tracks[attack tracks]' \
        '--cluster-name=+[name]:str:' \
        '--exceptions-policy=+[file]:file:_files' \
        '--frameworks=+[fw]:str:' \
        '*--frameworks=+[fw]:str:' \
        '--controls=+[ids]:str:' \
        '--allow-host-scanner[allow host scanner]' \
        '--workloads=+[workloads]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubescape subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments '1:type:(framework control image workload helm-chart code-repo all)' '*:arg:' ;;
                list) _arguments '1:type:(frameworks controls exceptions configurations)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kubescape2 "$@"
