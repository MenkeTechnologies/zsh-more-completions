#compdef numbat
# Documentation: https://numbat.dev/
# Reference accessed: 2026-05-19
# Verified: upstream Args struct in numbat-cli/src/main.rs.

# Zsh completion for numbat (scientific calculator language with units)

_arguments -s -S \
  '*'{-e,--expression}'[evaluate expression]:expression:' \
  '(-i --inspect-interactively)'{-i,--inspect-interactively}'[enter interactive session after running script/expression]' \
  '--no-config[do not load the user configuration file]' \
  '(-N --no-prelude)'{-N,--no-prelude}'[do not load the prelude]' \
  '--no-init[do not load init file]' \
  '--pretty-print=[pretty-print input expressions]:when:(always never auto)' \
  '--color=[enable/disable color output]:when:(always never auto)' \
  '--intro-banner=[intro banner display mode]:mode:(short long off)' \
  '--generate-config[generate a default configuration file]' \
  '(-d --debug)'{-d,--debug}'[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files -g "*.nbt"' && return 0
