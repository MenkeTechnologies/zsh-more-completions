#compdef gdk-pixbuf-pixdata
# Documentation: gdk-pixbuf-pixdata --help (GdkPixbuf)
# Source: convert image to GdkPixdata serialization (deprecated but still shipped).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    {-r,--rle}'[compress the image data using RLE]' \
    '--g-fatal-warnings[make warnings fatal]' \
    '1:input-file:_files' \
    '2:output-file:_files' \
    && ret=0

return ret
