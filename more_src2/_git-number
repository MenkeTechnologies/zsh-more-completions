#compdef git-number
# Documentation: https://github.com/holygeek/git-number
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Numbered git index shortcuts (holygeek/git-number)

_arguments -s -S \
  '--set-git-alias[set up git id and git list aliases]' \
  '-s[run git status with --short]' \
  '-c[run arbitrary commands (not just git) on numbered files]' \
  '--column[show untracked files in columnar listing]' \
  '*::args:_default' && return 0
