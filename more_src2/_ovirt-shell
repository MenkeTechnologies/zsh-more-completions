#compdef ovirt-shell
# _ovirt-shell — oVirt CLI shell (interactive REPL over the oVirt Engine REST API; -A access token, -c connection URL, -u user, -p password, -K kerberos auth, -I insecure, -d disable batch mode; inside the shell: list/show/add/update/remove/action vm|host|cluster|template|disk|...)
# upstream: https://github.com/oVirt/ovirt-engine-cli
# Flags from ovirt-engine-cli src/ovirt-shell on tip.

_ovirt-shell() {
    _arguments \
        '-h[show help]' \
        '-l[list known connections]' \
        '-c+[connection name]:name:' \
        '-A+[access token]:token:' \
        '-u+[user]:user:_users' \
        '-p+[password]:password:' \
        '--password-file+[password file]:file:_files' \
        '-K[kerberos auth]' \
        '-C+[CA file]:file:_files' \
        '-I[insecure (no cert check)]' \
        '-d[disable batch mode]' \
        '-f+[batch script file]:file:_files' \
        '-E+[execute command]:command:' \
        '-v[verbose]' \
        '*::command:'
}

_ovirt-shell "$@"
