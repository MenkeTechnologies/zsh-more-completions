#compdef function-pythonic
# _function-pythonic — Crossplane composition function that exposes a Pythonic API (argparse multi-subcommand CLI: grpc / render / version)
# upstream: https://github.com/crossplane-contrib/function-pythonic
# Subcommands + flags from crossplane/pythonic/{main,command,grpc}.py on tip (argparse); TLS_SERVER_CERTS_DIR env var binds to --tls-certs-dir.

_function-pythonic() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                grpc:'run the function as a gRPC server'
                render:'render a composition locally'
                version:'print version'
            )
            _describe -t commands 'function-pythonic subcommand' subs
            ;;
        args)
            local -a common=(
                '(-d --debug)'{-d,--debug}'[emit debug logs]'
                '--log-name-width=[width of logger name in log output]:n:'
                '*--logger-level=[logger=LEVEL (e.g. botocore.hooks=INFO)]:spec:'
                '*--python-path=[directory added to sys.path]:dir:_files -/'
                '(-u --render-unknowns)'{-u,--render-unknowns}'[render resources with unknown fields]'
                '--allow-oversize-protos[allow oversized protobuf messages]'
                '--crossplane-v1[enable Crossplane V1 compatibility]'
            )
            case $line[1] in
                grpc)
                    _arguments \
                        "${common[@]}" \
                        '--address=[gRPC listen address]:addr:' \
                        '--tls-certs-dir=[directory containing mTLS certs (TLS_SERVER_CERTS_DIR env var)]:dir:_files -/' \
                        '--insecure[run without mTLS credentials (--tls-certs-dir is ignored)]' \
                        '--packages-configmaps[discover python packages from function-pythonic ConfigMaps]' \
                        '--packages[DEPRECATED alias for --packages-configmaps]' \
                        '--packages-secrets[also discover python packages from Secrets]' \
                        '*--packages-namespace=[namespace to search for package CMs/Secrets]:ns:' \
                        '--packages-environmentconfigs[also discover python packages from EnvironmentConfigs]' \
                        '--packages-compositions[also discover python packages from Compositions]' \
                        '--packages-dir=[directory to store discovered package CMs]:dir:_files -/' \
                        '--pip-install=[pip install spec for additional Python packages]:spec:'
                    ;;
                render)
                    _arguments \
                        "${common[@]}"
                    ;;
            esac
            ;;
    esac
}

_function-pythonic "$@"
