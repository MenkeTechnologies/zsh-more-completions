#compdef pad-file
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/pad-file.1 — pad a FITS file to required size in-place (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v+[numerical value of pad byte (default 0)]:n:_default' \
    '-c+[character to pad with]:c:_default' \
    '1:desired length:_default' \
    '*:input file:_files' \
    && ret=0

return ret
