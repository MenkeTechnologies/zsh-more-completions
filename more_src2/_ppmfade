#compdef ppmfade
# Documentation: man ppmfade (Netpbm)
# Source: generate intermediate frames fading between two PPM images.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[first PPM image]:file:_files -g "*.ppm"' \
    '-l+[last PPM image]:file:_files -g "*.ppm"' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-mix[mix fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-spread[spread fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-shift[shift fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-relief[relief fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-oil[oil-paint fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-edge[edge fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-bentley[Bentley fade]' \
    '(-mix -spread -shift -relief -oil -edge -bentley -block)-block[block fade]' \
    '-base+[base name for output frames]:name:' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
