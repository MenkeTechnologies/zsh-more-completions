#compdef kinit-helper
# _kinit-helper — kinit wrapper helper (small distro-shipped helper around MIT or Heimdal kinit(1) that auto-detects whether to use a keytab or password prompt and renews tickets in the background; -k use keytab, -K keytab path, -p principal, -c ccache, -r renew interval, -l lifetime, -V version, -h help; positional argument is the principal name)
# upstream: distro-shipped helpers around Kerberos kinit on tip.
# Common flag shape from krb5/krb5 src/clients/kinit/kinit.c on tip.

_kinit-helper() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-k[use keytab]' \
        '-K+[keytab path]:file:_files' \
        '-p+[principal]:principal:' \
        '-c+[ccache]:file:_files' \
        '-r+[renew interval]:duration:' \
        '-l+[lifetime]:duration:' \
        '*:principal:'
}

_kinit-helper "$@"
