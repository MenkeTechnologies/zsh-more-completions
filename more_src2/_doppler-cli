#compdef doppler-cli
# _doppler-cli — Doppler secrets management CLI alias (Doppler / DopplerHQ, Go); spf13/cobra
# upstream: https://github.com/DopplerHQ/cli

_doppler-cli() {
    local -a sub=(
        'analytics:opt-in/out analytics'
        'change-set:make changes via JSON'
        'completion:generate shell completion'
        'configs:configs commands'
        'configure:configure CLI'
        'environments:environments commands'
        'feedback:open feedback dialog'
        'groups:group commands'
        'gui:open Doppler dashboard'
        'help:show help'
        'import:import from another source'
        'install:install Doppler updates'
        'integrations:integrations commands'
        'invites:invite team members'
        'login:login to Doppler'
        'logout:logout'
        'logs:fetch audit logs'
        'me:show current user'
        'open:open Doppler URL'
        'projects:projects commands'
        'run:run command with secrets in env'
        'scripts:scripts helpers'
        'secrets:secrets commands'
        'service-tokens:service tokens commands'
        'setup:setup project + config'
        'tokens:scoped tokens'
        'update:update CLI to latest'
        'version:show version'
        'workplace:workplace commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--api-host=+[API host]:url:_urls' \
        '--dashboard-host=+[dashboard host]:url:_urls' \
        '--config=+[config name]:str:' \
        '-c+[config name]:str:' \
        '--project=+[project name]:str:' \
        '-p+[project name]:str:' \
        '--scope=+[scope dir]:dir:_files -/' \
        '--token=+[service token]:str:' \
        '-t+[service token]:str:' \
        '--no-update-check[no update check]' \
        '--no-verify-tls[skip TLS verify]' \
        '--no-timeout[no timeout]' \
        '--silent[silent]' \
        '--json[json output]' \
        '--no-read-env[no read env]' \
        '--enclave-config=+[enclave config]:str:' \
        '--enclave-project=+[enclave project]:str:' \
        '--enclave-environment=+[enclave environment]:str:' \
        '--enclave-secrets-config=+[secrets config]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doppler subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '--preserve-env[preserve env]' \
                    '--mount=+[mount as file]:file:_files' \
                    '--mount-template=+[mount template]:str:' \
                    '--mount-format=+[mount format]:f:(env json yaml docker docker-compose)' \
                    '--name-transformer=+[name transformer]:t:(upper-snake camel lower-snake screaming-snake dotnet-env)' \
                    '--watch[watch for changes]' \
                    '--forward-signals[forward signals]' \
                    '--command=+[command]:str:' \
                    '*:cmd:_command_names -e' ;;
                secrets) _arguments \
                    '1:cmd:(delete download get list set substitute upload)' \
                    '*:arg:' ;;
                configs) _arguments \
                    '1:cmd:(create delete get list logs lock unlock rename update)' \
                    '*:arg:' ;;
                projects) _arguments \
                    '1:cmd:(create delete get list update)' \
                    '*:arg:' ;;
                environments) _arguments \
                    '1:cmd:(create delete get list rename update)' \
                    '*:arg:' ;;
                service-tokens|tokens) _arguments \
                    '1:cmd:(create delete list)' \
                    '*:arg:' ;;
                setup) _arguments \
                    '--no-interactive[no interactive]' \
                    '--no-save-token[no save token]' \
                    '--no-prompt[no prompt]' ;;
                configure) _arguments \
                    '1:cmd:(get set unset reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_doppler-cli "$@"
