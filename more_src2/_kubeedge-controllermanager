#compdef kubeedge-controllermanager kubeedge-controller-manager controllermanager
# _kubeedge-controllermanager — KubeEdge controller manager (reconciles EdgeApplication, NodeGroup and DeviceModel deployments across edge nodes)
# upstream: https://github.com/kubeedge/kubeedge
# Flags from cloud/cmd/controllermanager/app/{controllermanager,options/options}.go on tip.

_kubeedge-controllermanager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--use-server-side-apply=[use server-side apply when updating templates]:bool:(true false)' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--kubeconfig=[path to kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)'
}

_kubeedge-controllermanager "$@"
