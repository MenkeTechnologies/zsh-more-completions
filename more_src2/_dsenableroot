#compdef dsenableroot
# Documentation: man dsenableroot (macOS 26)
# Source: enable or disable the root account.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[disable the root account]' \
    '-u+[admin username]:user:_users' \
    '-p+[admin password (prompt if absent)]:password:' \
    '-r+[new root password (prompt if absent)]:password:' \
    && ret=0

return ret
