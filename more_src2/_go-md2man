#compdef go-md2man
# Documentation: go-md2man -h
# Source: convert Markdown to man pages (Go port of md2man).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input file (default stdin)]:file:_files -g "*.md"' \
    '-out+[output file (default stdout)]:file:_files' \
    && ret=0

return ret
