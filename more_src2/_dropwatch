#compdef dropwatch
# Documentation: https://github.com/nhorman/dropwatch
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-l+[lookup translation method]:method:(kas)' \
  '-c+[command file to execute]:file:_files' && ret=0

return ret
