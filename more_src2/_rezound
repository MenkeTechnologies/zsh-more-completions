#compdef rezound
# Documentation: https://manpages.debian.org/bookworm/rezound/rezound.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm rezound(1) manpage documents no CLI flags;
# accepts positional file paths only.
# Removed from prior file: fabricated -h/--help/-V/--version flags and bogus
# man.archlinux.org search URL.

# rezound: graphical audio file editor
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:audio file:_files -g "*.(wav|aiff|au|flac|ogg|mp3|raw|vox)(-.)"' && ret=0
return ret
