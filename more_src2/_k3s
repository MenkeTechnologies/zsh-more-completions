#compdef k3s
# _k3s — Rancher k3s lightweight Kubernetes (single binary; multi-call: server / agent / kubectl / crictl / ctr / token / certificate / etcd-snapshot / secrets-encrypt)
# upstream: https://github.com/k3s-io/k3s
# Subcommands from cmd/server/main.go on tip (urfave/cli/v2; same registry as the k3s-server / k3s-agent / k3s-* symlinks).

_k3s() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--debug[enable debug logging]' \
        '(-d --data-dir)'{-d,--data-dir}'=[k3s state directory]:dir:_files -/' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                server:'run the k3s server (control-plane + agent)'
                agent:'run the k3s agent (worker node)'
                kubectl:'run kubectl against the embedded k3s cluster'
                crictl:'run crictl against the embedded containerd'
                ctr:'run ctr against the embedded containerd'
                token:'manage cluster join tokens (create/delete/generate/list/rotate)'
                certificate:'manage k3s certificates'
                'etcd-snapshot':'manage embedded etcd snapshots'
                'secrets-encrypt':'manage secrets encryption keys'
                completion:'generate shell completion'
            )
            _describe -t commands 'k3s subcommand' subs
            ;;
    esac
}

_k3s "$@"
