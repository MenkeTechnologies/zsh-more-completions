#compdef intel_gpu_top intel-gpu-top
# Documentation: https://manpages.debian.org/bookworm/intel-gpu-tools/intel_gpu_top.1.en.html
# Reference accessed: 2026-05-17
# Verified: Debian bookworm intel_gpu_top(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -p/--pid filter (intel_gpu_top has no -p flag);
# mislabeled -l/-L (real -l is "list plain text", -L is "list GPUs");
# fabricated -d device-file filter (real -d takes a filter string).

# intel_gpu_top: Intel GPU utilization monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-J[JSON output]' \
  '-l[list plain text]' \
  '-o[output file]:file:_files' \
  '-s[refresh period in ms]:ms:' \
  '-L[list available GPUs]' \
  '-d[GPU device filter]:filter:' && ret=0
return ret
