#compdef elixir-ls
# Documentation: https://github.com/elixir-lsp/elixir-ls
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for ElixirLS (Elixir Language Server)
# ElixirLS is launched via language_server.sh/.bat; no documented CLI flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--stdio[use stdio transport]' && ret=0

return ret
