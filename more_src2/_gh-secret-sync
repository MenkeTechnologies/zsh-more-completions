# Documentation: upstream READMEs at github.com/{Nick2bad4u/gh-secret-sync,Nick2bad4u/gh-runs-cleanup,mona-actions/gh-repo-stats-plus}
# Reference accessed: 2026-05-30
# gh-extension family round 11. Continued TypeScript slice harvest.
# Hunt-defer log this round:
#   gh-contribution-mate (trunklabs/gh-contribution-mate) — README describes
#     features but doesn't name CLI flags; defer per the gh-grep precedent.
#   gh-polyrepos (YanZisuka/gh-polyrepos) — README describes purpose but
#     doesn't enumerate CLI subcommand/flag names; defer.
#   gh-edu (gh-cli-for-education/gh-edu) — README references plugin-developer
#     conventions (-f/--force, -s/--silence) but doesn't document the
#     extension's own complete CLI surface; defer.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-secret-sync)
    # Nick2bad4u/gh-secret-sync — safe secret sync across repos/envs/orgs.
    # Default is dry-run; --confirm or --yes commits the changes.
    # Multiple secret-value input methods, mutex'd because each represents
    # a different secret-source channel.
    _arguments -s -S \
      '(--confirm --yes)--confirm[apply changes (default is dry-run)]' \
      '(--confirm --yes)--yes[apply changes (default is dry-run)]' \
      '--secret-name=[secret name (for single-secret CLI mode)]:name:' \
      '(--secret-value-env --secret-value-file --secret-value-prompt --secret-value-stdin)--secret-value-env=[secret value from environment variable]:envvar:' \
      '(--secret-value-env --secret-value-file --secret-value-prompt --secret-value-stdin)--secret-value-file=[secret value from file]:file:_files' \
      '(--secret-value-env --secret-value-file --secret-value-prompt --secret-value-stdin)--secret-value-prompt[prompt interactively for secret value]' \
      '(--secret-value-env --secret-value-file --secret-value-prompt --secret-value-stdin)--secret-value-stdin[read secret value from stdin]' \
      '*--set=[name=value secret entry (repeatable)]:spec:' \
      '*--set-env=[name=value env-scoped secret entry (repeatable)]:spec:' \
      '--plan-file=[JSON or CSV plan file]:file:_files -g "*.(json|csv)"' \
      '--json[machine-readable JSON output]' \
      && ret=0
    ;;

  gh-runs-cleanup)
    # Nick2bad4u/gh-runs-cleanup — bulk delete GitHub Actions workflow runs.
    # Default filter is status=failure,cancelled. Like gh-secret-sync,
    # default is dry-run; --confirm or --yes commits.
    _arguments -s -S \
      '--repo=[owner/repo (auto-detect if omitted)]:repo:' \
      '(--confirm --yes)--confirm[delete (default is dry-run)]' \
      '(--confirm --yes)--yes[delete (default is dry-run)]' \
      '--dry-run[preview matches without deleting]' \
      '*--status=[filter by status (repeatable)]:status:(failure cancelled success skipped action_required neutral stale timed_out queued in_progress completed)' \
      '*--workflow=[filter by workflow name (repeatable)]:workflow:' \
      '--branch=[filter by branch]:branch:__git_branch_names' \
      '--event=[filter by triggering event]:event:(push pull_request workflow_dispatch schedule release)' \
      '--user=[filter by triggering user]:user:' \
      '--commit=[filter by commit SHA]:sha:' \
      '--max-delete=[limit number deleted]:N:' \
      '--fail-fast[stop on first error]' \
      '(--json --verbose --quiet)--json[JSON output]' \
      '(--json --verbose --quiet)--verbose[verbose output]' \
      '(--json --verbose --quiet)--quiet[suppress output]' \
      && ret=0
    ;;

  gh-repo-stats-plus)
    # mona-actions/gh-repo-stats-plus — comprehensive repo stats collection.
    # 8 documented subcommands. Per-subcommand flags are not enumerated in
    # upstream README; only subcommand names + purposes are listed. Use
    # subcommand dispatch but leave each subcommand's flag space empty.
    local -a _subcmds
    _subcmds=(
      'repo-stats:collect detailed repository metrics'
      'project-stats:count ProjectsV2 linked to repos'
      'org-repos:list repos in an org (with optional batch matrices)'
      'combine-stats:merge multiple batch CSV files'
      'post-process:transform/standardize CSV data via rules'
      'rows-to-columns:pivot rows from secondary CSVs into columns'
      'package-stats:retrieve package stats (Maven/npm/Docker/NuGet/RubyGems/PyPI)'
      'codespace-stats:gather codespace usage statistics'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-repo-stats-plus subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

esac

return ret
