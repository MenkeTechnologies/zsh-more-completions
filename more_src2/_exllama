#compdef exllama
# _exllama — turboderp ExLlama original optimized GPU-only inference engine for LLaMA-family quantized GPTQ models with custom CUDA kernels (turboderp team, Python); argparse
# upstream: https://github.com/turboderp/exllama

_exllama() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[dir]:dir:_files -/' \
        '--directory=+[dir]:dir:_files -/' \
        '-m+[model file]:file:_files -g "*.safetensors *.pt *.bin"' \
        '--model=+[model file]:file:_files -g "*.safetensors *.pt *.bin"' \
        '-c+[config json]:file:_files -g "*.json"' \
        '--config=+[config json]:file:_files -g "*.json"' \
        '-t+[tokenizer model]:file:_files -g "*.model *.json"' \
        '--tokenizer=+[tokenizer model]:file:_files -g "*.model *.json"' \
        '-l+[ctx len]:n:' \
        '--length=+[ctx len]:n:' \
        '-cm+[compress positional]:f:' \
        '--compress-pos-emb=+[compress positional]:f:' \
        '-a+[alpha for RoPE]:f:' \
        '--alpha=+[alpha for RoPE]:f:' \
        '-mmrt+[matmul reorder threshold]:n:' \
        '-mmnh+[matmul non-Hadamard]:n:' \
        '-fwt+[fused MLP wlen]:n:' \
        '-mlp+[fused MLP type]:t:(0 1 2)' \
        '-sdpn+[SDP no-norm]:b:(0 1)' \
        '--gpu-split=+[csv]:str:' \
        '-gs+[csv]:str:' \
        '--temperature=+[F]:f:' \
        '--top-p=+[F]:f:' \
        '--top-k=+[N]:n:' \
        '--typical=+[F]:f:' \
        '--repetition-penalty=+[F]:f:' \
        '-tps+[N tokens per second]:n:' \
        '-st+[N tokens]:n:' \
        '-p+[prompt]:str:' \
        '--prompt=+[prompt]:str:' \
        '-pn+[prompt file]:file:_files -g "*.txt"' \
        '-cml+[cache lm head]:b:(0 1)' \
        '-rml+[recurse lm head]:b:(0 1)' \
        '--no-stream[no stream]' \
        '--no-attention-flash[no flash attention]'
}

_exllama "$@"
