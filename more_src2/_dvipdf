#compdef dvipdf
# _dvipdf — TeX Live dvipdf (one-shot DVI->PDF wrapper: pipes through dvips then ghostscript ps2pdf; positional dvi file required, optional pdf output path; -o sends PS through stdin instead)
# upstream: https://tug.org/svn/texlive (Build/source/texk/dvipsk)
# Argument shape from texlive scripts/dvipdf on tip.

_dvipdf() {
    _arguments \
        '-o[read PS from stdin]' \
        '1:dvi file:_files -g "*.dvi"' \
        '2:pdf output:_files -g "*.pdf"'
}

_dvipdf "$@"
