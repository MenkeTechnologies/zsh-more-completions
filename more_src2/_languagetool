#compdef languagetool
# Documentation: https://github.com/languagetool-org/languagetool/blob/master/languagetool-commandline/src/main/java/org/languagetool/commandline/CommandLineParser.java
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Completion for the languagetool command-line tool (org.languagetool.commandline.Main).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help,--help,--\?}'[show help]' \
  '(- *)--version[show version]' \
  '(- *)--list[list supported languages]' \
  '(-l --language)'{-l,--language}'[language code]:language:(en-US en-GB de-DE fr es pt-BR nl pl ru it ca uk zh ja ko)' \
  '(-m --mothertongue)'{-m,--mothertongue}'[mother tongue language code]:language:(en-US en-GB de-DE fr es pt-BR nl pl ru it)' \
  '(-d --disable)'{-d,--disable}'[comma-separated rule IDs to disable]:rules' \
  '(-e --enable)'{-e,--enable}'[comma-separated rule IDs to enable]:rules' \
  '--disablecategories=[comma-separated category IDs to disable]:categories' \
  '--enablecategories=[comma-separated category IDs to enable]:categories' \
  '(-eo --enabledonly)'{-eo,--enabledonly}'[only check enabled rules]' \
  '--level=[rule severity level]:level:(default picky)' \
  '(-c --encoding)'{-c,--encoding}'[input encoding]:encoding:(utf-8 iso-8859-1 iso-8859-15 ascii)' \
  '(-a --apply)'{-a,--apply}'[auto-apply suggestions]' \
  '(-adl --autoDetect)'{-adl,--autoDetect}'[auto-detect language]' \
  '(-b2 --bitext)'{-b2,--bitext}'[bitext mode]' \
  '-b[input is broken/single sentence per line]' \
  '(-r --recursive)'{-r,--recursive}'[process directories recursively]' \
  '(-t --taggeronly)'{-t,--taggeronly}'[run tagger without rules]' \
  '(-u --list-unknown)'{-u,--list-unknown}'[list unknown words]' \
  '(-p --profile)'{-p,--profile}'[print profiling info]' \
  '--json[JSON output]' \
  '--line-by-line[process input line by line]' \
  '--clean-overlapping[clean overlapping matches]' \
  '--enable-temp-off[allow temporary rule disabling]' \
  '--xmlfilter[enable XML filtering]' \
  '--rulefile=[XML rule file]:file:_files' \
  '--remoterules=[remote rules file]:file:_files' \
  '--falsefriends=[false friends file]:file:_files' \
  '--bitextrules=[bitext rules file]:file:_files' \
  '--languagemodel=[Lucene language model dir]:dir:_files -/' \
  '--fasttextmodel=[fasttext model file]:file:_files' \
  '--fasttextbinary=[fasttext binary]:file:_files' \
  '*:files:_files' && ret=0

return ret
