#compdef pew
# _pew — virtualenv-aware Python environment switcher (berdario/pew)
# upstream: https://github.com/berdario/pew
# Subcommands from pew/pew.py.

_pew() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'new:create a new virtualenv'
                'rm:remove a virtualenv'
                'show:show info about a virtualenv'
                'ls:list virtualenvs'
                'workon:activate a virtualenv'
                'add:add directories to PYTHONPATH'
                'sitepackages_dir:print site-packages dir'
                'lssitepackages:list site-packages contents'
                'toggleglobalsitepackages:toggle global site-packages access'
                'cp:copy a virtualenv'
                'rename:rename a virtualenv'
                'setproject:set project dir for current venv'
                'getproject:get project dir for current venv'
                'mkproject:create a new project (venv + dir)'
                'mktmpenv:create a temporary venv'
                'wipeenv:remove all installed packages'
                'inall:run a command in all virtualenvs'
                'in:run a command in a virtualenv'
                'restore:restore broken virtualenv'
                'dir:print path of a virtualenv'
                'install:install a Python version (via pythonz)'
                'uninstall:uninstall a Python version (via pythonz)'
                'list_pythons:list available Python versions'
                'locate_python:locate installed Python version'
                'version:show version'
                'shell_config:print shell config'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_pew "$@"
