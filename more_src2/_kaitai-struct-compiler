#compdef kaitai-struct-compiler
# Documentation: https://doc.kaitai.io/user_guide.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Kaitai Struct .ksy compiler. Expanded from prior help-only stub with
# real options from the official user guide.

_arguments -s -S \
  '(-t --target)'{-t,--target}'[target language]:lang:(cpp_stl csharp java javascript perl php python ruby graphviz html nim all)' \
  '(-d --outdir)'{-d,--outdir}'[output directory]:dir:_directories' \
  '*'{-I,--import-path}'[add import search path]:path:_directories' \
  '--cpp-namespace[C++ namespace]:namespace:' \
  '--dotnet-namespace[.NET/C# namespace]:namespace:' \
  '--java-package[Java package]:package:' \
  '--java-from-file-class[Java fromFile helper class]:class:' \
  '--php-namespace[PHP namespace]:namespace:' \
  '--python-package[Python package]:package:' \
  '--go-package[Go package]:package:' \
  '--opaque-types[allow unknown types as opaque external impls]:bool:(true false)' \
  '--ksc-exceptions[throw exceptions instead of human-readable errors]' \
  '--ksc-json-output[output compilation results as JSON to stdout]' \
  '--verbose[enable verbose output]:setting:' \
  '--no-auto-read[do not generate auto _read call]' \
  '--read-pos[generate _io positions for debug]' \
  '--debug[enable debug mode]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:ksy file:_files -g "*.ksy"' && return 0
