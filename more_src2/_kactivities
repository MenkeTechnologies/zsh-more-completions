#compdef kactivities kactivities6 kactivitymanagerd
# _kactivities — KDE Activity Manager daemon CLI alias (KDE Project, C++); QCommandLineParser
# upstream: https://invent.kde.org/frameworks/kactivities

_kactivities() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--help-all[show all help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--platform=+[Qt platform plugin]:str:' \
        '--replace[replace running instance]' \
        '*:arg:'
}

_kactivities "$@"
