#compdef kind
# Documentation: https://github.com/kubernetes-sigs/kind/blob/main/pkg/cmd/kind/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Corrected from prior file: removed fabricated --loglevel flag (not
# registered); -v is --verbosity (int), not bundled with -h; removed
# fabricated --kube-root and docker|bazel build types (real --type
# values are url|file|release|source); create has -n/--name; delete
# cluster has no --all; build target is node-image.

# Zsh completion for kind (Kubernetes IN Docker).

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'build:Build one of [node-image]'
  'completion:Output shell completion code for the specified shell'
  'create:Creates one of [cluster]'
  'delete:Deletes one of [cluster clusters]'
  'export:Exports one of [kubeconfig logs]'
  'get:Gets one of [clusters kubeconfig nodes]'
  'load:Loads images into nodes'
  'version:Prints the kind CLI version'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[Help for kind]' \
  '(-q --quiet)'{-q,--quiet}'[Silence all stderr output]' \
  '(-v --verbosity)'{-v,--verbosity}'=[Info log verbosity, higher value produces more output]:level:' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'kind command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      build)
        _arguments -C \
          '1:target:(node-image)' \
          '--base-image=[name:tag of the base image to use for the build]:image:' \
          '--image=[name:tag of the resulting image to be built]:image:' \
          '--arch=[architecture to build for, defaults to the host architecture]:arch:' \
          "--type=[type of build: url, file, release or source]:type:(url file release source)" && ret=0
        ;;
      completion)
        _arguments \
          '1:shell:(bash zsh fish)' && ret=0
        ;;
      create)
        _arguments -C \
          '1:resource:(cluster)' \
          '(-n --name)'{-n,--name=}'[cluster name, overrides KIND_CLUSTER_NAME, config (default kind)]:name:' \
          '--config=[path to a kind config file]:file:_files' \
          '--image=[node docker image to use for booting the cluster]:image:' \
          '--retain[retain nodes for debugging when cluster creation fails]' \
          '--wait=[wait for control plane node to be ready (default 0s)]:duration:' \
          '--kubeconfig=[sets kubeconfig path instead of $KUBECONFIG or $HOME/.kube/config]:file:_files' && ret=0
        ;;
      delete)
        _arguments -C \
          '1:resource:(cluster clusters)' \
          '--name=[the cluster name]:name:' \
          '--kubeconfig=[sets kubeconfig path instead of $KUBECONFIG or $HOME/.kube/config]:file:_files' && ret=0
        ;;
      export)
        _arguments -C \
          '1:resource:(kubeconfig logs)' \
          '(-n --name)'{-n,--name=}'[the cluster name]:name:' \
          '--kubeconfig=[sets kubeconfig path instead of $KUBECONFIG or $HOME/.kube/config]:file:_files' \
          '--internal[use internal address instead of external]' && ret=0
        ;;
      get)
        _arguments -C \
          '1:resource:(clusters kubeconfig nodes)' \
          '(-n --name)'{-n,--name=}'[the cluster name]:name:' && ret=0
        ;;
      load)
        _arguments -C \
          '1:subcommand:(docker-image image-archive)' \
          '(-n --name)'{-n,--name=}'[the cluster name]:name:' \
          '--nodes=[comma separated list of nodes to load images into]:nodes:' \
          '*:image:' && ret=0
        ;;
      version)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
