#compdef kratix
# _kratix — Syntasso kratix CLI command-line frontend for the Kratix Promise-based Internal Developer Platform IDP framework for Kubernetes managing Promises Resources composability across Crossplane Argo Helm Terraform-providers GitOps reconciliation healthcheck-status delivery-mode operator-loop for platform engineering teams (Syntasso team, Go); cobra
# upstream: https://kratix.io/

_kratix() {
    local -a sub=(
        'install:install kratix server'
        'uninstall:uninstall kratix'
        'init:initialize a Promise'
        'build:build a Promise'
        'update:update a Promise'
        'promise:promise operations'
        'resource:resource operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[name]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '-o+[output format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure-skip-tls-verify[skip TLS verify]' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kratix subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments '1:promise name:' ;;
                build) _arguments '*:promise dir:_files -/' ;;
                promise|resource) _arguments '1:op:(list get create update delete)' '*:name:' ;;
            esac
            ;;
    esac
}

_kratix "$@"
