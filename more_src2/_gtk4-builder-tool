#compdef gtk4-builder-tool gtk-builder-tool
# _gtk4-builder-tool — GTK 4 gtk4-builder-tool (operate on GtkBuilder .ui XML files: validate parses + reports errors, simplify rewrites with default values stripped + 4.x property renames, enumerate lists referenced objects, preview opens the UI in a window for designer-time validation)
# upstream: https://gitlab.gnome.org/GNOME/gtk (tools/gtk-builder-tool*)
# Subcommands from gtk tools/gtk-builder-tool.c on tip.

_gtk4-builder-tool() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gtk4-builder-tool command' '(validate simplify enumerate preview)' ;;
        args)
            case $line[1] in
                simplify) _arguments \
                    '--3to4[port a 3.x .ui to 4.x]' \
                    '--replace[overwrite source]' \
                    '*:ui file:_files -g "*.ui"' ;;
                preview) _arguments \
                    '--id+[object id to show]:id:' \
                    '--css+[CSS file]:file:_files -g "*.css"' \
                    '*:ui file:_files -g "*.ui"' ;;
                *) _arguments '*:ui file:_files -g "*.ui"' ;;
            esac
            ;;
    esac
}

_gtk4-builder-tool "$@"
