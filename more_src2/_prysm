#compdef prysm
# Documentation: https://prysm.offchainlabs.com/docs/install/install-with-script
# Reference accessed: 2026-05-20
# Verified: upstream Prysm (OffchainLabs) docs at the URL above.
# Note: top-level `prysm` here is the launcher script; beacon-chain,
# validator, client-stats, and deposit are the Prysm components.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--datadir=[Prysm data root]:directory:_directories' \
  '--execution-endpoint=[Engine API HTTP endpoint]:url:' \
  '--jwt-secret=[JWT secret for engine RPC]:file:_files' \
  '--checkpoint-sync-url=[Checkpoint sync Beacon API URL]:url:' \
  '--mainnet[Use Ethereum mainnet]' \
  '--sepolia[Use Sepolia testnet]' \
  '--holesky[Use Holesky testnet]' \
  '--holesky-testnetDeprecated[Holesky alias]' \
  '--accept-terms-of-use[Acknowledge terms for binary distributions]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'beacon-chain:Run Prysm beacon node'
      'validator:Run Prysm validator process'
      'client-stats:Publish client stats'
      'deposit:Submit Eth2 deposits'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
