#compdef google-java-format
# Documentation: https://github.com/google/google-java-format
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for google-java-format (Java source code formatter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-i --replace)'{-i,--replace}'[modify files in-place]' \
  '--aosp[use AOSP style (4-space indentation)]' \
  '--dry-run[print filenames that would change]' \
  '--fix-imports-only[only fix imports]' \
  '--skip-sorting-imports[do not sort imports]' \
  '--skip-removing-unused-imports[do not remove unused imports]' \
  '--skip-reflowing-long-strings[do not reflow long strings]' \
  '--skip-javadoc-formatting[do not format Javadoc]' \
  '--length=[character length to format]:length:' \
  '--lines=[format specific line range start\:end]:line range:' \
  '--offset=[starting offset]:offset:' \
  '--assume-filename=[filename to use for diagnostics]:filename:' \
  '(-v --version)'{-v,--version}'[print version]' \
  '(-h --help)'{-h,--help}'[print help]' \
  '--set-exit-if-changed[return exit code 1 if input needs formatting]' \
  '*:java file:_files -g "*.java"' && ret=0

return ret
