#compdef etags
# Documentation: https://www.gnu.org/software/emacs/manual/html_node/emacs/Tags-Tables.html
# Source: emacs-mirror/emacs lib-src/etags.c — generate Emacs/ctags tags table (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-a,--append}'[append to existing tags file]' \
    '--packages-only[only tag package declarations]' \
    {-C,--c++}'[treat .c/.h as C++]' \
    '--ctags[emit ctags-style output]' \
    '--debug[enable debug output]' \
    '--declarations[include all declarations]' \
    '--no-line-directive[no #line directive in output]' \
    '--no-duplicates[suppress duplicate tags]' \
    '(-h --help)'{-h,--help,-H}'[show help]' \
    {-I,--ignore-indentation}'[ignore indentation as heuristic]' \
    '*'{-l+,--language=}'[language for files]:lang:(asm c c++ c* cobol erlang forth fortran go html java lisp lua makefile objc pascal perl php postscript proc prolog python ruby rust scheme sml tex texinfo verilog vhdl yacc plain auto)' \
    '--members[include all members]' \
    '--no-members[do not include members]' \
    {-o+,--output=}'[output tags file]:file:_files' \
    {-Q,--class-qualify}'[qualify tag names with class]' \
    '*'{-r+,--regex=}'[regex pattern]:regex:_default' \
    {-R,--no-regex}'[disable previous regex]' \
    '*'{-c+,--ignore-case-regex=}'[case-insensitive regex]:regex:_default' \
    '--parse-stdin=-[parse stdin as filename]:filename:_files' \
    {-V,--version}'[show version]' \
    {-B,--backward-search}'[ctags backward-search pattern]' \
    {-x,--cxref}'[ctags cross-reference output]' \
    {-d,--defines}'[create tags for #define]' \
    '--globals[include global declarations]' \
    {-t,--typedefs}'[create tags for typedefs]' \
    {-u,--update}'[update tags in-place]' \
    {-v,--vgrind}'[vgrind output]' \
    {-w,--no-warn}'[suppress warnings]' \
    '--no-defines[do not create tags for #define]' \
    '--no-globals[do not include global declarations]' \
    '--include=-[include other tags file]:file:_files' \
    '--no-fallback-lang[error if language guess fails]' \
    '--fallback-lang=-[fallback language]:lang:_default' \
    '--no-empty-file-entries[skip empty files]' \
    '--empty-file-entries[include empty files]' \
    '*:source files:_files' \
    && ret=0

return ret
