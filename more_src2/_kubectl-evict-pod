#compdef kubectl-evict-pod
# Documentation: https://github.com/rajatjindal/kubectl-evict-pod
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope for this request]:namespace:' \
  '(-l --selector)'{-l+,--selector=}'[label selector to evict multiple pods]:selector:' \
  '--all[evict every pod in the namespace]' \
  '--retry[repeatedly evict pods until none remain]' \
  '*:pod name:_default'
