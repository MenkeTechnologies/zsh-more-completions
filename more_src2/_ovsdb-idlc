#compdef ovsdb-idlc
# _ovsdb-idlc — Open vSwitch ovsdb-idlc IDL compiler generating C bindings from OVSDB schema files (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovsdb-idlc() {
    local -a sub=(
        'annotate:annotate schema with type information'
        'c-idl-header:generate IDL header'
        'c-idl-source:generate IDL source'
        'doc:generate documentation'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-C+[type]:str:' \
        '--c-output-type=+[type]:str:' \
        '-d[create dependency file]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ovsdb-idlc subcommand' sub ;;
        args)
            case $words[1] in
                annotate|c-idl-header|c-idl-source|doc) _arguments \
                    '*:schema:_files -g "*.ovsschema *.json"' ;;
            esac
            ;;
    esac
}

_ovsdb-idlc "$@"
