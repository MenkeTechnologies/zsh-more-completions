#compdef luarocks-cli
# _luarocks-cli — Lua language LuaRocks package manager CLI alias (Hisham Muhammad / LuaRocks team, Lua); custom argparse
# upstream: https://github.com/luarocks/luarocks

_luarocks-cli() {
    local -a sub=(
        'build:build rock from rockspec'
        'config:manage LuaRocks config'
        'doc:show documentation'
        'download:download rock'
        'help:show help'
        'init:scaffold module'
        'install:install rock'
        'list:list installed rocks'
        'lint:lint rockspec'
        'make:build local rockspec'
        'new_version:create new version rockspec'
        'pack:pack rock'
        'path:print LUA_PATH'
        'purge:remove rocks from tree'
        'remove:remove rock'
        'search:search rocks'
        'show:show rock info'
        'test:run rock tests'
        'unpack:unpack rock source'
        'upload:upload rock to LuaRocks.org'
        'which:print module file'
        'write_rockspec:scaffold rockspec'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--lua-dir=+[lua dir]:dir:_files -/' \
        '--lua-version=+[lua version]:str:' \
        '--tree=+[install tree]:str:' \
        '--only-server=+[only from server]:str:' \
        '--only-sources=+[only sources]:str:' \
        '--namespace=+[namespace]:str:' \
        '--server=+[server URL]:url:_urls' \
        '--dev[also use dev manifests]' \
        '--from=+[server URL]:url:_urls' \
        '--only-deps[only deps]' \
        '--keep[keep previous version]' \
        '--verbose[verbose]' \
        '--timeout=+[timeout]:n:' \
        '--global[global tree]' \
        '--local[local tree]' \
        '--project-tree=+[project tree]:dir:_files -/' \
        '--system-config=+[system config]:file:_files' \
        '--user-config=+[user config]:file:_files' \
        '--quiet[quiet]' \
        '--no-manifest[no manifest]' \
        '--force[force]' \
        '--force-fast[force fast]' \
        '--no-doc[no doc]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'luarocks subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|show|list|search|build|make|test|doc|unpack|download|pack|which) _arguments \
                    '*:rock:' ;;
                config) _arguments \
                    '1:cmd:(api_key get set unset)' \
                    '*:arg:' ;;
                init|new_version|write_rockspec) _arguments \
                    '*:arg:_files' ;;
            esac
            ;;
    esac
}

_luarocks-cli "$@"
