#compdef expireover
# Documentation: man expireover(8)
# Source: InterNetNews/inn expire/expireover.c — expire entries from overview (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-e -k)-e[earliest deletion: per group, soonest expire wins]' \
    '-f+[active file path]:file:_files' \
    '(-e -k)-k[keep mode: most permissive expire wins]' \
    '-N[ignore self-expiring entries]' \
    '-p[use Posting date instead of Arrival date]' \
    '-q[quiet mode]' \
    '-s[always stat articles]' \
    '-w+[time warp in days]:days:_default' \
    '-z+[delay removal — write paths to file]:file:_files' \
    '-Z+[lowmark file path]:file:_files' \
    && ret=0

return ret
