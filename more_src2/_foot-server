#compdef foot-server footserver
# Documentation: https://codeberg.org/dnkl/foot
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# foot --server: foot Wayland terminal in server/daemon mode

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config=}'[config file]:config:_files' \
  '(-C --check-config)'{-C,--check-config}'[check config and exit]' \
  '(-o --override)'{-o,--override=}'[override config option]:[section.]key=value:' \
  '(-f --font)'{-f,--font=}'[font specification (fontconfig)]:font:' \
  '(-t --term)'{-t,--term=}'[terminal type]:TERM:' \
  '(-T --title)'{-T,--title=}'[window title]:title:' \
  '(-a --app-id)'{-a,--app-id=}'[Wayland app-id]:app id:' \
  '(-w --window-size-pixels)'{-w,--window-size-pixels=}'[window size in pixels]:WxH:' \
  '(-W --window-size-chars)'{-W,--window-size-chars=}'[window size in chars]:WxH:' \
  '(-m --maximized)'{-m,--maximized}'[start maximized]' \
  '(-F --fullscreen)'{-F,--fullscreen}'[start fullscreen]' \
  '(-L --login-shell)'{-L,--login-shell}'[start a login shell]' \
  '(-s --server)'{-s,--server=-}'[run as server (optional socket path/FD)]:socket:_files' \
  '(-p --print-pid)'{-p,--print-pid=}'[print PID to file or FD]:file:_files' \
  '(-S --log-no-syslog)'{-S,--log-no-syslog}'[disable syslog logging (server mode)]' \
  '(-H --hold)'{-H,--hold}'[keep window open after exit]' \
  '(-d --log-level)'{-d,--log-level=}'[log level]:level:(info warning error none)' \
  '(-l --log-colorize)'{-l,--log-colorize=}'[colorize log]:when:(never always auto)' \
  '-e[ignored (xterm compat)]' && ret=0

return ret
