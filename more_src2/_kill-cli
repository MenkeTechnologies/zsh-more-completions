#compdef kill-cli
# _kill-cli — util-linux kill terminate a process CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_kill-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[do not restrict to processes of current user]' \
        '--all[do not restrict to processes of current user]' \
        '-s+[signal name/number]:str:' \
        '--signal=+[signal name/number]:str:' \
        '-l[list signal names]' \
        '--list[list signal names]' \
        '-L[list signal names with table]' \
        '--table[list signal names with table]' \
        '-q+[value]:n:' \
        '--queue=+[value]:n:' \
        '-p[print pid only]' \
        '--pid[print pid only]' \
        '-d+[delay between signals]:str:' \
        '--timeout=+[duration signal]:str:' \
        '*:pid:_pids'
}

_kill-cli "$@"
