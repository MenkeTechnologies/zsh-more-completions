#compdef dotnet-stack
# Documentation: https://github.com/dotnet/diagnostics/tree/main/src/Tools/dotnet-stack
# Reference accessed: 2026-05-27
# Verified: upstream src/Tools/dotnet-stack/{Program.cs,ReportCommand.cs,Symbolicate.cs}

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'report:print the managed stack trace of every thread in the target process'
  'symbolicate:symbolicate a stack trace using assemblies and pdbs'
  'ps:list dotnet processes that stack traces can be collected from'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dotnet-stack subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (report)
        _arguments \
          '(-p --process-id)'{-p+,--process-id=}'[process id to report the stack for]:pid:' \
          '(-n --name)'{-n+,--name=}'[name of the process to report the stack for]:name:' \
          '--duration=[trace duration in dd:hh:mm:ss format]:duration:' && ret=0
        ;;
      (symbolicate)
        _arguments \
          '*'{-d+,--search-dir=}'[directory containing assemblies and pdbs]:directory:_files -/' \
          '(-o --output)'{-o+,--output=}'[output file (default <input>.symbolicated)]:file:_files' \
          '(-c --stdout)'{-c,--stdout}'[output directly to console]' \
          '1:input path:_files' && ret=0
        ;;
      (ps)
        _arguments && ret=0
        ;;
    esac
    ;;
esac

return ret
