#compdef kedro-cli
# Documentation: https://docs.kedro.org/en/0.18.4/development/commands_reference.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# STUB-ish: there is no canonical `kedro-cli` binary; the Kedro CLI is
# invoked as `kedro` (older Kedro templates generated a kedro_cli.py
# wrapper exposing the same command set). Corrected from prior file:
# removed the broken `case kedro-cli in metaflow-cli|zenml-cli)` literal
# and the unrelated metaflow/zenml command lists; kept only the
# documented Kedro command surface.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'new:create a new project'
  'info:show installed plugins and versions'
  'run:run the pipeline'
  'jupyter:Jupyter integration'
  'ipython:IPython integration'
  'package:package the project'
  'build-reqs:build requirements'
  'catalog:show data catalog'
  'pipeline:pipeline operations'
  'registry:show pipelines registry'
  'micropkg:micro-package operations'
  'docs:open the Kedro documentation'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'kedro-cli command' commands && ret=0 ;;
esac
return ret
