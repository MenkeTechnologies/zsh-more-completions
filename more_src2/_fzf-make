#compdef fzf-make
# Documentation: https://github.com/kyu08/fzf-make
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fzf-make accepts a single subcommand (or its short/long flag aliases).
# Source of truth: src/usecase/{help,history,repeat,version}.rs command_str().
# Note: -h is the alias for the `history` subcommand, NOT --help.
local -a subcommands=(
  'help:show help message'
  '--help:show help message'
  'history:launch with history pane focused'
  '--history:launch with history pane focused'
  '-h:launch with history pane focused'
  'repeat:execute the previously run target'
  '--repeat:execute the previously run target'
  '-r:execute the previously run target'
  'version:show version'
  '--version:show version'
  '-v:show version'
)

_describe -t subcommands 'fzf-make subcommand' subcommands
