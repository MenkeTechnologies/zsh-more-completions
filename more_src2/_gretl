#compdef gretl gretlcli
# _gretl — Allin Cottrell gretl CLI GNU Regression Econometrics and Time-series Library command-line interactive shell for performing OLS GLS 2SLS regression cointegration unit-root-tests VAR-VECM-ARIMA panel-data discrete-choice-Logit-Probit-MNL-Poisson Kalman-filter MIDAS estimation econometric workflows (Allin Cottrell team, C); getopt
# upstream: https://gretl.sourceforge.net/

_gretl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-b+[batch mode script]:file:_files -g "*.inp"' \
        '--batch=+[file]:file:_files -g "*.inp"' \
        '-r+[run script]:file:_files -g "*.inp"' \
        '--run=+[file]:file:_files -g "*.inp"' \
        '-e+[command]:str:' \
        '-c[continue if errors]' \
        '--continue[continue if errors]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s+[seed]:n:' \
        '--seed=+[seed]:n:' \
        '-d+[debug level]:n:' \
        '--debug=+[level]:n:' \
        '-l+[language]:l:(C en es fr de it ja zh-CN pt-BR ru pl tr)' \
        '--language=+[lang]:l:(C en es fr de it ja zh-CN pt-BR ru pl tr)' \
        '-x+[english]:str:' \
        '--english[english]' \
        '-t+[utf8 input]:str:' \
        '-w+[working dir]:dir:_files -/' \
        '--workdir=+[dir]:dir:_files -/' \
        '-p[print]' \
        '--prn[print to terminal]' \
        '-f[force append]' \
        '--force[force append]' \
        '-i[ignore startup script]' \
        '--no-rc[ignore startup script]' \
        '-T[print timestamp]' \
        '--time=+[count]:str:' \
        '--basket=+[name]:str:' \
        '--quiet-final[quiet final]' \
        '*:data file:_files -g "*.gdt *.gdtb *.csv *.xls *.xlsx *.dat *.txt *.gnumeric *.ods *.dta *.sav *.por *.octave *.bin *.jmd *.rdata *.json"'
}

_gretl "$@"
