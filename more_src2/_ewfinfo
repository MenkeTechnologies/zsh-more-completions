#compdef ewfinfo
# Documentation: https://github.com/libyal/libewf
# Source: libyal/libewf manuals/ewfinfo.1 — display media/acquisition info of an EWF image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a codepages=(ascii windows-874 windows-932 windows-936 windows-949 windows-950 windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)

_arguments -s \
    "-A[codepage of header section]:codepage:($codepages)" \
    '-B[output logical files info as a bodyfile]:bodyfile:_files' \
    '-d[date format]:date format:(ctime dm md iso8601)' \
    '(-e -i -m)-e[only show EWF read error info]' \
    '-f[output format]:format:(text dfxml)' \
    '-F[show info about a specific file entry path]:path:' \
    '-h[show help]' \
    '-H[show logical files hierarchy]' \
    '(-e -i -m)-i[only show EWF acquisition info]' \
    '(-e -i -m)-m[only show EWF media info]' \
    "-s[path segment separator]:sep:(/ \\\\)" \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:EWF image:_files' \
    && ret=0

return ret
