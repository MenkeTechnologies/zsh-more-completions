#compdef dhall-to-nixpkgs
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-nixpkgs
# Source: dhall-lang/dhall-haskell dhall-nixpkgs/Main.hs — convert a Dhall project to a Nix package.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dtn_cmds
_dtn_cmds=(
    'github:create a Nix package from a GitHub repository'
    'directory:create a Nix package from a local directory'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'dhall-to-nixpkgs command' _dtn_cmds && ret=0
        ;;
    args)
        case $words[1] in
            github)
                _arguments -s -S \
                    '--name=[name for the Nix derivation]:name:_default' \
                    '--rev=[Git revision to use]:rev:_default' \
                    '--hash=[expected SHA256 hash]:hash:_default' \
                    '--fetch-submodules[fetch git submodules]' \
                    '--directory=[subdirectory containing the Dhall package]:directory:_files -/' \
                    '--file=[file to import, relative to the top-level directory]:file:_files' \
                    '--source[configure the Nix package to include source code]' \
                    '--document[generate documentation for the Nix package]' \
                    '(-)1:URL:_default' \
                    && ret=0
                ;;
            directory)
                _arguments -s -S \
                    '--name=[name for the Nix derivation]:name:_default' \
                    '--file=[file to import, relative to the top-level directory]:file:_files' \
                    '--source[configure the Nix package to include source code]' \
                    '--document[generate documentation for the Nix package]' \
                    '--fixed-output-derivations[translate Dhall remote imports to Nix fixed-output derivations]' \
                    '(-)1:DIRECTORY:_files -/' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
