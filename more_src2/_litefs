#compdef litefs
# Documentation: https://github.com/superfly/litefs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for litefs - LiteFS distributed SQLite

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'mount:Mount the LiteFS FUSE file system'
      'export:Export a database from a LiteFS cluster to disk'
      'import:Import a SQLite database into a LiteFS cluster'
      'run:Execute a subcommand for remote writes'
      'version:Print the version'
    )
    _describe -t commands 'litefs command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      mount)
        _arguments -s -S \
          '-config[config file path]:config file:_files' \
          '-no-expand-env[disable environment variable expansion in config]' \
          '-skip-unmount[skip unmounting existing mount point]' \
          '-fuse.debug[enable FUSE debug logging]' \
          '-debug[enable DEBUG level logging]' \
          '-tracing[enable trace logging output]' && ret=0
        ;;
      export)
        _arguments -s -S \
          '-url[LiteFS API URL]:url:' \
          '-name[database name]:name:' \
          '1:output path:_files' && ret=0
        ;;
      import)
        _arguments -s -S \
          '-url[LiteFS API URL]:url:' \
          '-name[database name]:name:' \
          '1:input path:_files' && ret=0
        ;;
      run)
        _arguments -s -S \
          '-url[LiteFS API URL]:url:' \
          '-promote[elevate local node to primary]' \
          '-if-candidate[execute only if node is a candidate]' \
          '-with-halt-lock-on[acquire HALT lock on database path]:path:' \
          '-v[verbose logging output]' && ret=0
        ;;
    esac
    ;;
esac

return ret
