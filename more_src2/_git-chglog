#compdef git-chglog
# Documentation: https://github.com/git-chglog/git-chglog
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--init[generate .chglog config in interactive mode]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
  '(-t --template)'{-t,--template}'=[path to custom template file]:template:_files' \
  '(-o --output)'{-o,--output}'=[output path]:output file:_files' \
  '--next-tag=[treat unreleased commits as specified tag]:tag' \
  '--silent[suppress stdout output]' \
  '--no-color[disable color output]' \
  '--no-emoji[disable emoji output]' \
  '--no-case[case-insensitive tag pattern matching]' \
  '--tag-filter-pattern=[filter tags by regex pattern]:regex pattern' \
  '--sort=[sort order for entries]:order:(date semver)' \
  '--path=[filter commits by path]:path:_files' \
  '--repository-url=[URL of git repository]:URL' \
  '--jira-url=[Jira base URL]:URL' \
  '--jira-username=[Jira username]:user' \
  '--jira-token=[Jira API token]:token' \
  '(-h --help)'{-h,--help}'[display help]' \
  '(-v --version)'{-v,--version}'[display version]' \
  '*:tag query' && ret=0

return ret
