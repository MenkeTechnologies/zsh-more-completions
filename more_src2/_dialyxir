#compdef dialyxir
# Documentation: https://github.com/jeremyjh/dialyxir/blob/master/lib/mix/tasks/dialyzer.ex
# Reference accessed: 2026-05-27
# Verified: upstream @command_options in Mix.Tasks.Dialyzer and Mix.Tasks.Dialyzer.Clean.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'dialyzer:run dialyzer (build/check PLT, then analyse)'
  'dialyzer.build:build the required PLT(s) and exit'
  'dialyzer.clean:delete PLT(s) and hash file'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'dialyxir subcommand' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      dialyzer|'')
        _arguments -s -S \
          '--plt[only build the required PLT(s) and exit]' \
          '--no-check[do not perform quick PLT freshness check]' \
          '--force-check[force PLT check even when lockfile is unchanged]' \
          '--no-compile[do not compile the project]' \
          '--ignore-exit-status[display warnings but always exit 0]' \
          '--list-unused-filters[list unused ignore filters (CI use)]' \
          '*--format=[warning output format]:format:(short raw dialyxir dialyzer github ignore_file ignore_file_strict)' \
          '--quiet[suppress all informational messages]' \
          '--quiet-with-result[suppress info messages except the final result]' \
          '*:warning-flag:' && ret=0
        ;;
      dialyzer.build)
        _arguments -s -S \
          '--no-compile[do not compile the project]' && ret=0
        ;;
      dialyzer.clean)
        _arguments -s -S \
          '--all[also delete core PLTs]' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
