#compdef looker-cli looker
# _looker-cli — Looker Google looker-cli CLI command-line frontend wrapping the Looker Google Cloud Looker Studio modern BI analytics platform managing user authentication looks dashboards explores models LookML projects boards runs queries permissions roles access workspaces space content datagroups schedules merges dashboards-tile-update content-folder (Google team, Go); cobra
# upstream: https://looker.com/

_looker-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user management'
        'role:role management'
        'group:group management'
        'workspace:workspace management'
        'space:space management'
        'look:look management'
        'dashboard:dashboard management'
        'explore:explore operations'
        'model:model management'
        'project:project management'
        'lookml:LookML operations'
        'query:run a query'
        'schedule:schedule operations'
        'content:content operations'
        'permission:permission operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--token=+[token]:str:' \
        '--api-version=+[v]:v:(4.0 3.1)' \
        '-c+[config file]:file:_files -g "looker.ini *.ini *.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.ini *.yaml *.yml *.json"' \
        '--workspace-id=+[id]:str:' \
        '--insecure[skip TLS verify]' \
        '-f+[format]:f:(json yaml csv table txt png)' \
        '--format=+[format]:f:(json yaml csv table txt png)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'looker-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|role|group|workspace|space|look|dashboard|explore|model|project|schedule|content|permission) _arguments '1:op:(list get create update delete enable disable run)' '*:id:' ;;
            esac
            ;;
    esac
}

_looker-cli "$@"
