#compdef ngrok-cli
# _ngrok-cli — ngrok secure introspectable tunneling CLI alias (ngrok Inc., Go); spf13/cobra
# upstream: https://github.com/inconshreveable/ngrok

_ngrok-cli() {
    local -a sub=(
        'api:make ngrok API requests'
        'completion:generate shell completion'
        'config:manage local ngrok config'
        'credits:show credits info'
        'diagnose:diagnose connection'
        'help:show help'
        'http:start http tunnel'
        'service:run ngrok as a service'
        'start:start tunnels from config'
        'tcp:start tcp tunnel'
        'tls:start tls tunnel'
        'tunnel:start labeled tunnel'
        'update:update ngrok'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--authtoken=+[authtoken]:str:' \
        '--config=+[config file]:list:_files -g "*.yml *.yaml"' \
        '--log=+[log file]:file:_files' \
        '--log-format=+[log format]:fmt:(json term logfmt)' \
        '--log-level=+[log level]:level:(crit warn error info debug)' \
        '--metadata=+[metadata]:str:' \
        '--region=+[region]:r:(us us-cal-1 eu ap au sa in jp)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ngrok subcommand' sub ;;
        args)
            case $words[1] in
                http) _arguments \
                    '1:url-or-port:' \
                    '--domain=+[reserved domain]:str:' \
                    '--basic-auth=+[basic auth user:pass]:str:' \
                    '--circuit-breaker=+[circuit breaker]:f:' \
                    '--compression[enable compression]' \
                    '--host-header=+[host header]:str:' \
                    '--ip-restriction-allow-cidrs=+[ip allow cidrs]:list:' \
                    '--ip-restriction-deny-cidrs=+[ip deny cidrs]:list:' \
                    '--mutual-tls-cas=+[mutual tls cas]:list:_files' \
                    '--oauth-allow-domains=+[oauth allow domains]:list:' \
                    '--oauth-allow-emails=+[oauth allow emails]:list:' \
                    '--oauth-scopes=+[oauth scopes]:list:' \
                    '--oauth=+[oauth provider]:p:(google github facebook microsoft gitlab twitch amazon linkedin)' \
                    '--request-header-add=+[req header add]:str:' \
                    '--request-header-remove=+[req header remove]:list:' \
                    '--response-header-add=+[resp header add]:str:' \
                    '--response-header-remove=+[resp header remove]:list:' \
                    '--scheme=+[scheme]:s:(http https)' \
                    '--user-agent-filter-allow=+[ua allow]:list:' \
                    '--user-agent-filter-deny=+[ua deny]:list:' \
                    '--verify-webhook-secret=+[verify webhook secret]:str:' \
                    '--verify-webhook=+[verify webhook provider]:p:(slack stripe twilio github bitbucket xero shopify gitlab svix sns sendgrid)' ;;
                tcp) _arguments \
                    '1:port:' \
                    '--remote-addr=+[remote addr]:str:' \
                    '--ip-restriction-allow-cidrs=+[ip allow cidrs]:list:' \
                    '--ip-restriction-deny-cidrs=+[ip deny cidrs]:list:' ;;
                tls) _arguments \
                    '1:port:' \
                    '--domain=+[domain]:str:' \
                    '--terminate-at=+[terminate at]:t:(edge upstream)' \
                    '--mutual-tls-cas=+[mutual tls cas]:list:_files' \
                    '--ip-restriction-allow-cidrs=+[ip allow cidrs]:list:' \
                    '--ip-restriction-deny-cidrs=+[ip deny cidrs]:list:' ;;
                tunnel) _arguments \
                    '1:label:' \
                    '--label=+[label]:str:' ;;
                config) _arguments \
                    '1:cmd:(add-authtoken add-api-key check edit upgrade)' \
                    '*:arg:' ;;
                api) _arguments \
                    '1:resource:(abuse_reports agent_ingresses api_keys application_sessions application_users certificate_authorities credentials edges endpoint_configurations event_destinations event_sources event_subscriptions failover_backends http_response_backends ip_policies ip_restrictions reserved_addresses reserved_domains ssh_certificate_authorities ssh_credentials ssh_host_certificates ssh_user_certificates tunnel_sessions tunnels users)' \
                    '*:arg:' ;;
                start) _arguments \
                    '--all[all tunnels]' \
                    '--none[start without tunnels]' \
                    '*:tunnel:' ;;
                service) _arguments \
                    '1:cmd:(install start stop uninstall)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ngrok-cli "$@"
