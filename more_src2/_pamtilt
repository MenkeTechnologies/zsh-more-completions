#compdef pamtilt
# Documentation: man pamtilt (Netpbm)
# Source: detect the tilt angle of a scanned (deskewable) Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-angle=[max angle to consider]:maxangle:' \
    '-fast[fast mode]' \
    '-quality=[search quality]:q:' \
    '-hstep=[horizontal sampling step]:n:' \
    '-vstep=[vertical sampling step]:n:' \
    '-dstep=[diagonal sampling step]:n:' \
    '-astep=[angle sampling step]:n:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
