#compdef e2b-cli
# Documentation: https://github.com/e2b-dev/E2B
# Reference accessed: 2026-05-27
# Verified: upstream packages/cli/src/commands/index.ts and per-group
# index.ts files (auth/index.ts, template/index.ts, sandbox/index.ts).
# Note: the installed binary is `e2b` (covered by the sibling _e2b file).
# This file targets the alternate `e2b-cli` name reserved in the parent
# project's plan.
# Deviations from spec: replaced bare `login`, `logout`, `whoami` top-level
# entries with the real nested layout under `auth` (login, logout, info,
# configure). Real top-level groups are only `auth`, `template`, `sandbox`.

local curcontext="$curcontext" state line ret=1

local -a _e2b_subcommands
_e2b_subcommands=(
  'auth:authentication commands'
  'template:manage sandbox templates'
  'sandbox:work with sandboxes'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-V,--version}'[show e2b CLI version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'e2b-cli subcommand' _e2b_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        local -a _e2b_auth
        _e2b_auth=(
          'login:sign in to E2B'
          'logout:sign out of E2B'
          'info:print info about the current authenticated user'
          'configure:configure team and API key for the local CLI'
        )
        _describe -t commands 'e2b auth subcommand' _e2b_auth && ret=0
        ;;
      template|tpl)
        local -a _e2b_tpl
        _e2b_tpl=(
          'create:build a sandbox template from a Dockerfile'
          'list:list sandbox templates'
          'init:scaffold a new e2b.Dockerfile in the current directory'
          'delete:delete a sandbox template'
          'publish:publish a sandbox template to the marketplace'
          'unpublish:unpublish a sandbox template from the marketplace'
          'migrate:migrate a sandbox template config'
        )
        _describe -t commands 'e2b template subcommand' _e2b_tpl && ret=0
        ;;
      sandbox|sbx)
        local -a _e2b_sbx
        _e2b_sbx=(
          'connect:connect to a running sandbox via terminal'
          'info:print info about a running sandbox'
          'list:list running sandboxes'
          'kill:kill a running sandbox'
          'pause:pause a running sandbox'
          'resume:resume a paused sandbox'
          'create:create and run a new sandbox'
          'logs:stream logs from a sandbox'
          'metrics:show metrics for a sandbox'
          'exec:execute a command inside a sandbox'
        )
        _describe -t commands 'e2b sandbox subcommand' _e2b_sbx && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
