#compdef mosdepth
# Documentation: https://github.com/brentp/mosdepth/blob/master/mosdepth.nim
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Mosdepth: fast BAM/CRAM depth calculator. Flags taken from docopt usage in mosdepth.nim.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-t --threads)'{-t,--threads=}'[number of BAM decompression threads]:n' \
  '(-c --chrom)'{-c,--chrom=}'[chromosome to restrict depth calculation]:chrom' \
  '(-b --by)'{-b,--by=}'[BED file or integer window-size]:value' \
  '(-n --no-per-base)'{-n,--no-per-base}'[do not output per-base depth]' \
  '(-f --fasta)'{-f,--fasta=}'[FASTA file for CRAM]:file:_files -g "*.(fa|fasta)"' \
  '--d4[output per-base depth in d4 format]' \
  '(-F --flag)'{-F,--flag=}'[exclude reads with any of these flag bits]:flag' \
  '(-i --include-flag)'{-i,--include-flag=}'[include only reads with any of these flag bits]:flag' \
  '(-x --fast-mode -a --fragment-mode)'{-x,--fast-mode}'[skip internal CIGAR / mate-overlap correction]' \
  '(-a --fragment-mode -x --fast-mode)'{-a,--fragment-mode}'[count full fragment coverage for proper pairs]' \
  '(-q --quantize)'{-q,--quantize=}'[write quantized output by segments]:segments' \
  '(-Q --mapq)'{-Q,--mapq=}'[minimum mapping quality]:n' \
  '(-l --min-frag-len)'{-l,--min-frag-len=}'[minimum insert size]:n' \
  '(-u --max-frag-len)'{-u,--max-frag-len=}'[maximum insert size]:n' \
  '(-T --thresholds)'{-T,--thresholds=}'[coverage thresholds, comma list]:list' \
  '(-m --use-median)'{-m,--use-median}'[report median per region instead of mean]' \
  '(-R --read-groups)'{-R,--read-groups=}'[restrict to these comma-separated read group IDs]:list' \
  ':prefix:' \
  ':BAM or CRAM:_files -g "*.(bam|cram)"' && ret=0
return ret
