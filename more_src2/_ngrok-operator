#compdef ngrok-operator
# _ngrok-operator — ngrok ingress + AgentEndpoint controller manager
# upstream: https://github.com/ngrok/ngrok-operator
# Subcommands + flags from cmd/api-manager.go, cmd/agent-manager.go, cmd/bindings-forwarder-manager.go on tip.

_ngrok-operator() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'api-manager:run the ngrok API + ingress/Gateway controller'
                'agent-manager:run the AgentEndpoint reconciler'
                'bindings-forwarder-manager:run the Endpoint Bindings forwarder'
            )
            _describe -t commands command cmds
            ;;
        args)
            local -a common=(
                '--release-name=[Helm release name]:name:'
                '--metrics-bind-address=[metrics bind host\:port]:host\:port:'
                '--health-probe-bind-address=[health probe bind host\:port]:host\:port:'
                '--description=[description applied to ngrok resources]:text:'
                '--region=[ngrok tunnel region]:region:'
                '--server-addr=[ngrok server address]:host\:port:'
                '--enable-feature-ingress=[enable Ingress controller]:bool:(true false)'
                '--enable-feature-gateway=[enable Gateway API support]:bool:(true false)'
                '--disable-reference-grants=[opt out of ReferenceGrants for cross-ns refs]:bool:(true false)'
                '--enable-feature-bindings=[enable Endpoint Bindings controller]:bool:(true false)'
                '--default-domain-reclaim-policy=[default domain reclaim policy]:policy:(Delete Retain)'
                '--kubeconfig=[kubeconfig file]:file:_files'
            )
            case $line[1] in
                api-manager)
                    _arguments \
                        $common \
                        '--election-id=[leader-election configmap name]:name:' \
                        '--ngrokMetadata=[k=v list added as labels on ngrok resources]:csv:' \
                        '--api-url=[ngrok API base URL]:url:_urls' \
                        '--ingress-controller-name=[Ingress controller class name]:class:' \
                        '--ingress-watch-namespace=[Ingress watch namespace]:ns:' \
                        '--manager-name=[manager instance name]:name:' \
                        '--cluster-domain=[Kubernetes cluster DNS domain]:domain:' \
                        '--one-click-demo-mode[run in one-click demo mode (Ready, not running)]' \
                        '*--bindings-endpoint-selectors=[Endpoint Bindings selectors]:selector:' \
                        '--bindings-service-annotations=[annotations propagated to target Service]:csv:' \
                        '--bindings-service-labels=[labels propagated to target Service]:csv:' \
                        '--bindings-ingress-endpoint=[Bindings forwarder ingress endpoint]:endpoint:' \
                        '--drain-policy=[uninstall drain policy]:policy:(Delete Retain)'
                    ;;
                agent-manager)
                    _arguments \
                        $common \
                        '--manager-name=[manager instance name]:name:' \
                        '--watch-namespace=[AgentEndpoint watch namespace]:ns:' \
                        '--root-cas=[CA trust mode]:mode:(trusted host)'
                    ;;
                bindings-forwarder-manager)
                    _arguments \
                        $common \
                        '--manager-name=[manager instance name]:name:'
                    ;;
            esac
            ;;
    esac
}

_ngrok-operator "$@"
