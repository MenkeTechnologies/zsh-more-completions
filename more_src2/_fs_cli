#compdef fs_cli
# Documentation: https://developer.signalwire.com/freeswitch/FreeSWITCH-Explained/Installation/Linux/fs_cli/
# Source: signalwire/freeswitch libs/esl/fs_cli.c — FreeSWITCH event socket CLI client.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help,-\?}'[show help]' \
    '(-H --host)'{-H+,--host=}'[host to connect]:host:_hosts' \
    '(-P --port)'{-P+,--port=}'[port to connect (1-65535)]:port:_default' \
    '(-u --user)'{-u+,--user=}'[user@domain]:user:_default' \
    '(-p --password)'{-p+,--password=}'[password]:password:_default' \
    '(-i --interrupt)'{-i,--interrupt}'[allow Ctrl-c to interrupt]' \
    '(-x --execute)'{-x+,--execute=}'[execute command and exit]:command:_default' \
    '(-l --loglevel)'{-l+,--loglevel=}'[log level]:level:_default' \
    '(-U --log-uuid)'{-U,--log-uuid}'[include UUID in log output]' \
    '(-S --log-uuid-short)'{-S,--log-uuid-short}'[include shortened UUID in log output]' \
    '(-q --quiet)'{-q,--quiet}'[disable logging]' \
    '(-r --retry)'{-r,--retry}'[retry connection on failure]' \
    '(-R --reconnect)'{-R,--reconnect}'[reconnect if disconnected]' \
    '(-d --debug)'{-d+,--debug=}'[debug level (0-7)]:level:(0 1 2 3 4 5 6 7)' \
    '(-b --batchmode)'{-b,--batchmode}'[batch mode]' \
    '(-t --timeout)'{-t+,--timeout=}'[API command timeout (ms)]:ms:_default' \
    '(-T --connect-timeout)'{-T+,--connect-timeout=}'[socket connection timeout (ms)]:ms:_default' \
    '(-n --no-color)'{-n,--no-color}'[disable color]' \
    '(-s --set-log-uuid)'{-s+,--set-log-uuid=}'[UUID to filter log events]:uuid:_default' \
    && ret=0

return ret
