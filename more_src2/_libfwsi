#compdef fwsiinfo
# _libfwsi — libyal Windows Shell Item / ItemIDList parser; decodes shell items used inside .lnk targets, jump lists, ShellBags, automatic destinations
# upstream: https://github.com/libyal/libfwsi

_libfwsi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[codepage]:codepage:(ascii windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-X[exclusive]' \
        '*:shell item:_files'
}

_libfwsi "$@"
