#compdef icecast2 icecast
# Documentation: https://manpages.debian.org/testing/icecast2/icecast2.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# icecast2: Xiph streaming media server. Only -c (config) is supported per man page.

_arguments -s \
  '-c+[config file]:file:_files -g "*.xml"' \
  '-b[run in background]' \
  '(- *)-v[show version]' \
  '(- *)-h[show help]'
