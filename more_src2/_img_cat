#compdef img_cat
# Documentation: https://www.sleuthkit.org/sleuthkit/man/img_cat.html
# Source: sleuthkit/sleuthkit man/img_cat.1 — output contents of an image file to stdout.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i[identify type of image file]:imgtype:(raw aff afd afm afflib ewf split)' \
    '-b[underlying device sector size in bytes]:sector size:(512 1024 2048 4096)' \
    '-s[sector number to start at]:start sector:' \
    '-e[sector number to stop at]:stop sector:' \
    '-v[verbose output of debugging statements to stderr]' \
    '-V[display version]' \
    '*:image file:_files' \
    && ret=0

return ret
