#compdef dirmngr-client
# Documentation: dirmngr-client --help (GnuPG 2.5.20)
# Source: query an X.509 certificate against a CRL/OCSP via dirmngr.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-q --quiet)'{-q,--quiet}'[quieter output]' \
    '--ocsp[use OCSP instead of CRLs]' \
    '--ping[check whether a dirmngr is running]' \
    '--cache-cert[add a certificate to the cache]' \
    '--validate[validate a certificate]' \
    '(-l --local)'{-l,--local}'[lookup only locally stored certs]' \
    '--lookup[lookup a certificate]' \
    '(-u --url)'{-u,--url}'[expect URL for --lookup]' \
    '--load-crl[load a CRL into dirmngr]' \
    '--squid-mode[special mode for use by Squid]' \
    '--pem[expect certificates in PEM format]' \
    '--force-default-responder[force default OCSP responder]' \
    '1:certfile or pattern:_files' \
    && ret=0

return ret
