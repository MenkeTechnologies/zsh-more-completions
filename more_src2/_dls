#compdef dls
# Documentation: http://www.sleuthkit.org/sleuthkit/man/blkls.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: dls is the legacy name for blkls (pre-TSK 3.0); accepts the same flags.

# dls: Sleuth Kit data unit (block) lister
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose]' \
  '-V[show version]' \
  '-A[list all allocated blocks]' \
  '-a[display only allocated blocks]' \
  '-e[copy every block (including metadata)]' \
  '-l[list block details (time-machine format)]' \
  '-s[copy only slack space]' \
  '-f[filesystem type]:fstype:(ntfs fat fat12 fat16 fat32 ext ext2 ext3 ext4 ufs ufs1 ufs2 iso9660 hfs swap raw)' \
  '-i[image type]:imgtype:(raw split aff afd afm afflib ewf)' \
  '-o[sector offset to filesystem]:n:' \
  '-b[device sector size in bytes]:bytes:' \
  '*:image file:_files' && ret=0
return ret
