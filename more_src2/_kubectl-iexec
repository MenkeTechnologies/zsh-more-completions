#compdef kubectl-iexec
# Documentation: https://github.com/gabeduke/kubectl-iexec
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-iexec (gabeduke/kubectl-iexec). Syntax: iexec [pod filter] [remote command(s)]
# Only the flags below are documented upstream.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --container)'{-c+,--container=}'[container to search]:container:' \
  '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(trace debug info warn error fatal panic)' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace to search]:namespace:' \
  '(-v --vim-mode)'{-v,--vim-mode}'[vim mode enabled]' \
  '(-x --naked)'{-x,--naked}'[decolorize output]' \
  '1:pod filter:' \
  '*:remote command: _default'
