#compdef git-who
# Documentation: https://github.com/sinclairtarget/git-who
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'table:summary table of author contributions (default)'
      'tree:file tree with authorship annotations'
      'hist:timeline bar chart of commit activity'
    )
    _describe -t commands 'git-who command' commands && ret=0
    ;;
  (args)
    local -a common_opts=(
      '*--author=[include specific authors]:author:'
      '*--nauthor=[exclude specific authors]:author:'
      '--since=[filter commits since date]:date:'
      '--until=[filter commits until date]:date:'
      '--merges[count merge commits toward totals]'
    )
    case $line[1] in
      (table)
        _arguments -s -S \
          $common_opts \
          '-m[sort by most recent modification]' \
          '-c[sort by first commit (earliest contributor)]' \
          '-l[sort by lines modified; show file and line stats]' \
          '-f[sort by number of files modified]' \
          '-n[limit displayed rows (0 = all)]:n:' && ret=0
        ;;
      (tree)
        _arguments -s -S \
          $common_opts \
          '-m[sort by most recent modification]' \
          '-c[sort by first commit]' \
          '-l[sort by lines modified]' \
          '-f[sort by number of files modified]' \
          '-a[annotate all files and show deleted paths]' \
          '-d[limit tree depth]:depth:' && ret=0
        ;;
      (hist)
        _arguments -s -S \
          $common_opts \
          '-l[sort by lines modified]' \
          '-f[sort by number of files modified]' && ret=0
        ;;
    esac
    ;;
esac

return ret
