#compdef fvdemount
# Documentation: https://github.com/libyal/libfvde
# Source: libyal/libfvde manuals/fvdemount.1 — FUSE-mount a FileVault (FVDE) volume as a raw block device.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-e[path of the EncryptedRoot.plist.wipekey file]:plist:_files' \
    '-h[show help]' \
    '-k[volume master key in base16]:key:' \
    '-o[volume offset]:offset:' \
    '-p[password]:password:' \
    '-r[recovery password]:recovery password:' \
    '-u[unattended (disable user interaction)]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-X[extended options to pass to FUSE]:fuse opts:' \
    '*:image or volume then mountpoint:_files' \
    && ret=0

return ret
