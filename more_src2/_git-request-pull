#compdef git-request-pull
# Documentation: https://git-scm.com/docs/git-request-pull
# Source: git/git git-request-pull.sh — generate pull-request summary of changes (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p[include the patches in the message]' \
    '1:start (committish):_default' \
    '2:url:_urls' \
    '3::end (committish):_default' \
    && ret=0

return ret
