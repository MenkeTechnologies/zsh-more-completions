#compdef gputop
# _gputop — Intel gputop GPU performance monitor for Intel graphics OA counters and profiling (rib team, C); custom argparse
# upstream: https://github.com/rib/gputop

_gputop() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-l[list available metrics]' \
        '--list-metrics[list available metrics]' \
        '-q[query only]' \
        '--query[query only]' \
        '-m+[metric set]:str:' \
        '--metric=+[metric set]:str:' \
        '-f+[frequency Hz]:n:' \
        '--frequency=+[frequency Hz]:n:' \
        '-p+[period ns]:n:' \
        '--period=+[period ns]:n:' \
        '-d+[duration secs]:n:' \
        '--duration=+[duration secs]:n:' \
        '-c+[ctx pid]:n:' \
        '--context=+[ctx pid]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-r[record only]' \
        '--record[record only]' \
        '-w+[web ui port]:port:_ports' \
        '--web-port=+[web ui port]:port:_ports' \
        '--device=+[drm device]:file:_files -g "/dev/dri/*"'
}

_gputop "$@"
