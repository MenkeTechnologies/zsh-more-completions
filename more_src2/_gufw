#compdef gufw
# _gufw — GUI front-end to ufw (Uncomplicated Firewall) — Python GTK app that mirrors ufw rule management with profiles, application policies, real-time logging, and tray applet; -V print version, -h show help, --debug print debug info; no positional arguments (settings live in /etc/gufw/gufw.cfg + user dconf keys)
# upstream: https://gitlab.gnome.org/costales/gufw
# Flags from costales/gufw gufw/gufw.py on tip.

_gufw() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--debug[debug]'
}

_gufw "$@"
