#compdef mkfs-btrfs-cli mkfs.btrfs-cli
# _mkfs-btrfs-cli — kdave btrfs-progs mkfs.btrfs Btrfs filesystem creator CLI alias (kdave team, C); custom argparse
# upstream: https://github.com/kdave/btrfs-progs

_mkfs-btrfs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '--byte-count=+[bytes]:str:' \
        '-b+[bytes]:str:' \
        '--csum=+[algo]:c:(crc32c xxhash sha256 blake2)' \
        '--checksum=+[algo]:c:(crc32c xxhash sha256 blake2)' \
        '-d+[data profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 dup single)' \
        '--data=+[data profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 dup single)' \
        '-m+[metadata profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 dup single)' \
        '--metadata=+[metadata profile]:p:(raid0 raid1 raid1c3 raid1c4 raid5 raid6 raid10 dup single)' \
        '-M[mixed data and metadata]' \
        '--mixed[mixed data and metadata]' \
        '-l+[leaf size]:n:' \
        '--leafsize=+[leaf size]:n:' \
        '--nodesize=+[node size]:n:' \
        '-n+[node size]:n:' \
        '-L+[label]:str:' \
        '--label=+[label]:str:' \
        '-O+[features]:str:' \
        '--features=+[features]:str:' \
        '-A+[sector size]:n:' \
        '--alloc-start=+[bytes]:str:' \
        '-s+[sector size]:n:' \
        '--sectorsize=+[size]:n:' \
        '-r+[fill from dir]:dir:_files -/' \
        '--rootdir=+[fill from dir]:dir:_files -/' \
        '--shrink[shrink to fit]' \
        '-K[no discard]' \
        '--nodiscard[no discard]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-U+[UUID]:str:' \
        '--uuid=+[UUID]:str:' \
        '--device-uuid=+[uuid]:str:' \
        '-f[force]' \
        '--force[force]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_mkfs-btrfs-cli "$@"
