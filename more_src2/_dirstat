#compdef dirstat
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dirstat.html
# Source: MRtrix3/mrtrix3 cmd/dirstat.cpp — statistics on a direction set (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*-shell+[restrict to shell(s) of given b-value]:b:_default' \
    '*-output+[shorthand metrics to output (e.g. SH8, BN, BN-, BN+, ASYM, N)]:metrics:_default' \
    '1:directions file or image:_files' \
    && ret=0

return ret
