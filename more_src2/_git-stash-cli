#compdef git-stash-cli
# _git-stash-cli — Git git stash subcommand CLI alias (Git project, C); custom argparse
# upstream: https://github.com/git/git

_git-stash-cli() {
    local -a sub=(
        'list:list stashes'
        'show:show stash diff'
        'drop:drop a stash'
        'pop:apply and drop a stash'
        'apply:apply a stash without dropping'
        'branch:create branch from a stash'
        'clear:clear all stashes'
        'create:create stash without storing'
        'store:store created stash'
        'push:push changes to stash (default)'
        'save:save stash (legacy)'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'git-stash subcommand' sub ;;
        args)
            case $words[1] in
                push|save) _arguments \
                    '--message=+[message]:str:' \
                    '-m+[message]:str:' \
                    '--include-untracked[include untracked]' \
                    '-u[include untracked]' \
                    '--all[include ignored]' \
                    '-a[include ignored]' \
                    '--keep-index[keep index]' \
                    '-k[keep index]' \
                    '--no-keep-index[no keep index]' \
                    '--patch[interactive patch]' \
                    '-p[interactive patch]' \
                    '--staged[only staged]' \
                    '-S[only staged]' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--pathspec-from-file=+[pathspec file]:file:_files' \
                    '--pathspec-file-nul[pathspec file null]' \
                    '*:path:_files' ;;
                pop|apply|drop|show|branch) _arguments \
                    '--index[restore index]' \
                    '-q[quiet]' \
                    '--quiet[quiet]' \
                    '*:stash:' ;;
                list) _arguments \
                    '*:rev-list-arg:' ;;
                show) _arguments \
                    '-p[patch]' \
                    '--patch[patch]' \
                    '*:stash:' ;;
                clear|create|store) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_git-stash-cli "$@"
