#compdef natpmpc
# _natpmpc — NAT-PMP client for managing port mappings (miniupnp/libnatpmp)
# upstream: https://github.com/miniupnp/libnatpmp
# Flags from natpmpc.c usage().

_natpmpc() {
    _arguments \
        '(- *)-h[show help]' \
        '-g+[force gateway IPv4 for NAT-PMP commands]:ipv4:' \
        '-a[add a port mapping (public private proto [lifetime])]' \
        '*::args:'
}

_natpmpc "$@"
