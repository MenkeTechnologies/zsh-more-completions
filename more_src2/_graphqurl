#compdef graphqurl gq
# _graphqurl — Hasura graphqurl curl-style GraphQL client CLI (Hasura team, JavaScript); commander
# upstream: https://github.com/hasura/graphqurl

_graphqurl() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--query=+[graphql query]:str:' \
        '-q+[graphql query]:str:' \
        '--header=+[header]:list:' \
        '-H+[header]:list:' \
        '--variable=+[variable key=value]:list:' \
        '-v+[variable key=value]:list:' \
        '--variables-json=+[variables json]:str:' \
        '-n+[variables json]:str:' \
        '--queryFile=+[query file]:file:_files -g "*.graphql *.gql"' \
        '-f+[query file]:file:_files -g "*.graphql *.gql"' \
        '--variablesFile=+[variables file]:file:_files -g "*.json"' \
        '-r+[variables file]:file:_files -g "*.json"' \
        '--operation-name=+[operation name]:str:' \
        '-o+[operation name]:str:' \
        '--introspect[introspect schema]' \
        '-i[introspect schema]' \
        '--format=+[output format]:fmt:(graphql json js ts flow)' \
        '-x+[output format]:fmt:(graphql json js ts flow)' \
        '--name=+[introspect output name]:str:' \
        '-N+[introspect output name]:str:' \
        '--graphiql[open graphiql ui]' \
        '-g[open graphiql ui]' \
        '--port=+[graphiql port]:port:' \
        '-p+[graphiql port]:port:' \
        '--bypass-cors[bypass cors]' \
        '-b[bypass cors]' \
        '--single-line[single line output]' \
        '*:endpoint:_urls'
}

_graphqurl "$@"
