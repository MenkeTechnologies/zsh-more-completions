#compdef foamMergeCase
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamMergeCase — merge a "child" case directory on top of a base case.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '*:base case then child case:_directories' \
    && ret=0

return ret
