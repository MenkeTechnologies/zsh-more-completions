#compdef elm-format
# Documentation: https://github.com/avh4/elm-format
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for elm-format (Elm source code formatter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--yes[apply changes without prompting]' \
  '--validate[check formatting without writing]' \
  '--stdin[read from stdin]' \
  '--output[output file]:file:_files' \
  '--elm-version[target Elm version]:version:(0.17 0.18 0.19)' \
  '--json[output as JSON]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:elm file:_files -g "*.elm"' && ret=0

return ret
