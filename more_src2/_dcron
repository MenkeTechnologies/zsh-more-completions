#compdef dcron
# Documentation: https://github.com/dubiousjim/dcron/blob/master/crond.markdown
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-b[background]' \
  '-f[foreground]' \
  '-l+[log level]:lvl:' \
  '-L+[log file]:file:_files' \
  '-d+[debug level]:lvl:' \
  '-S[use syslog]' \
  '-M+[mailprog]:cmd:_command_names' \
  '-m+[mailbody size limit]:n:' \
  '-s+[spool dir]:dir:_files -/' \
  '-c+[cron dir]:dir:_files -/' \
  '-p+[pid file]:file:_files' \
  '-x+[debug flags]:flags:' && ret=0

return ret
