#compdef kuryr-server
# Documentation: https://docs.openstack.org/kuryr-libnetwork/latest/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# OpenStack kuryr-libnetwork kuryr-server: Docker libnetwork remote driver
# that bridges to OpenStack Neutron. Entry point:
# kuryr-server = kuryr_libnetwork.server:start. Uses oslo.config logging.

local curcontext="$curcontext" ret=1

_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "(- *)--version[show version]" \
  "*--config-file=[config file]:file:_files" \
  "*--config-dir=[config dir]:dir:_files -/" \
  "(--debug -d --nodebug)"{--debug,-d}"[set log level to DEBUG]" \
  "(--debug -d --nodebug)--nodebug[unset --debug]" \
  "--log-config-append=[python logging config file]:file:_files" \
  "--log-date-format=[log date format (Python strftime)]:fmt:" \
  "--log-dir=[base directory for relative --log-file paths]:dir:_files -/" \
  "--log-file=[log to file]:file:_files" \
  "(--use-journal --nouse-journal)--use-journal[log to systemd journal]" \
  "(--use-journal --nouse-journal)--nouse-journal[disable journal logging]" \
  "(--use-json --nouse-json)--use-json[log as JSON]" \
  "(--use-json --nouse-json)--nouse-json[disable JSON logging]" \
  "(--use-syslog --nouse-syslog)--use-syslog[log via syslog]" \
  "(--use-syslog --nouse-syslog)--nouse-syslog[disable syslog logging]" \
  "(--watch-log-file --nowatch-log-file)--watch-log-file[watch log file for changes]" \
  "(--watch-log-file --nowatch-log-file)--nowatch-log-file[disable log file watching]" \
  "--rate-limit-burst=[oslo.log rate limit burst]:n:" \
  "--rate-limit-except=[oslo.log rate limit exceptions]:list:" \
  "--rate-limit-interval=[oslo.log rate limit interval seconds]:n:" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "--rpc-conn-pool-size=[oslo.messaging RPC connection pool size]:n:" \
  "--rpc-response-timeout=[oslo.messaging RPC response timeout (s)]:n:" \
  "--transport-url=[oslo.messaging transport URL]:url:" \
  '*::args:' && ret=0

return ret
