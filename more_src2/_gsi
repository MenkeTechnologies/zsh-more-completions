#compdef gsi gsi-script gsc gsc-script
# Documentation: https://gambitscheme.org/latest/manual/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (gsi|gsi-script)
    _arguments -C \
      '-:[runtime options]:opts:' \
      '-h[show help]' \
      '--help[show help]' \
      '-v[show version]' \
      '--version[show version]' \
      '-i[interactive after script]' \
      '-e+[evaluate expression]:expr:' \
      '-s+[run script]:file:_files -g "*.scm *.six"' \
      '-f+[load file]:file:_files -g "*.scm *.six"' \
      '-c[compile and run]' \
      '-thread-debug-old-style[old debug style]' \
      '-debug[enable debug]' \
      '-:s,m,h,d+[runtime opts]:opts:' \
      '*: :_files -g "*.scm *.six *.o[1-9]"' && ret=0 ;;
  (gsc|gsc-script)
    _arguments -C \
      '-:[runtime options]:opts:' \
      '-h[show help]' \
      '--help[show help]' \
      '-v[show version]' \
      '--version[show version]' \
      '-i[force input compilation]' \
      '-c[compile to C only]' \
      '-cc-options+[C compiler options]:opts:' \
      '-ld-options+[linker options]:opts:' \
      '-ld-options-prelude+[ld prelude]:opts:' \
      '-prelude+[prelude expression]:expr:' \
      '-postlude+[postlude expression]:expr:' \
      '-cc+[C compiler]:cc:_command_names -e' \
      '-keep-c[keep C output]' \
      '-debug[debug info]' \
      '-debug-location[debug locations]' \
      '-debug-source[debug source]' \
      '-debug-environments[debug envs]' \
      '-track-scheme[track scheme]' \
      '-link[link object files]' \
      '-flat[flat link]' \
      '-l+[base for link]:base:_files' \
      '-warnings[show warnings]' \
      '-no-warnings[suppress warnings]' \
      '-expansion[show macro expansion]' \
      '-gvm[output GVM]' \
      '-cps[CPS conversion]' \
      '-exe[output executable]' \
      '-dynamic[dynamic library]' \
      '-obj[object file]' \
      '-o+[output file]:file:_files' \
      '-target+[target backend]:t:(C js java python ruby php)' \
      '-module-ref+[module ref]:ref:' \
      '-r5rs[R5RS]' \
      '-r6rs[R6RS]' \
      '-r7rs[R7RS]' \
      '*: :_files -g "*.scm *.six *.c *.o"' && ret=0 ;;
esac

return ret
