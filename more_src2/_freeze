#compdef freeze
# Documentation: https://github.com/charmbracelet/freeze
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for Charm Freeze - code screenshot tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'=[config file or template]:file:_files' \
  '--interactive[launch interactive TUI]' \
  '(-l --language)'{-l,--language}'=[language for syntax highlighting]:language' \
  '(-t --theme)'{-t,--theme}'=[color theme]:theme' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-b --background)'{-b,--background}'=[background color]:color' \
  '(-m --margin)'{-m,--margin}'=[margin around window]:margin' \
  '(-p --padding)'{-p,--padding}'=[padding around code]:padding' \
  '(-H --height)'{-H,--height}'=[terminal window height]:height' \
  '(-w --window)'{-w,--window}'[show window controls]' \
  '(-r --border.radius)'{-r,--border.radius}'=[border corner radius]:radius' \
  '--border.width=[border width]:width' \
  '--border.color=[border color]:color' \
  '--shadow.blur=[shadow blur radius]:blur' \
  '--shadow.x=[shadow x offset]:offset' \
  '--shadow.y=[shadow y offset]:offset' \
  '--font.family=[font family]:font' \
  '--font.size=[font size]:size' \
  '--font.file=[embed custom font file]:file:_files' \
  '--font.ligatures[enable font ligatures]' \
  '--line-height=[line height]:height' \
  '--lines=[capture line range start,end]:range' \
  '--show-line-numbers[show line numbers]' \
  '--execute=[execute a command and screenshot output]:command' \
  '*:file:_files' \
  && ret=0

return ret
