#compdef kickstart
# Documentation: https://github.com/Keats/kickstart/blob/master/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream source (clap) at the URL above.

# Zsh completion for kickstart (project scaffolding tool)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'validate:validates that a template.toml is valid'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output-dir)'{-o,--output-dir}'+[where to output the project (default: .)]:directory:_directories' \
  '(-d --directory)'{-d,--directory}'+[directory of the template within the folder/repository]:directory:' \
  '--no-input[do not prompt for variables, use template.toml defaults]' \
  '(-i --input-file)'{-i,--input-file}'+[JSON file with variable values (implies --no-input)]:file:_files' \
  '--run-hooks[run all the hooks]' \
  '1:template (local path or HTTP git URL):_files' \
  '*::args:->args' && ret=0

case $state in
  args)
    if (( CURRENT == 1 )); then
      _describe -t commands 'kickstart command' commands && ret=0
    elif [[ ${words[1]} == validate ]]; then
      _arguments '1:template.toml path:_files' && ret=0
    fi
    ;;
esac

return ret
