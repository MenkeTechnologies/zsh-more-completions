#compdef pbmto10x
# Documentation: man pbmto10x (Netpbm)
# Source: convert a PBM image to Gemini 10X printer commands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[high-resolution mode]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
