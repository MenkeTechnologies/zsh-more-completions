#compdef rio
# Documentation: https://github.com/raphamorim/rio/blob/main/frontends/rioterm/src/cli.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help]' \
  '(- *)'{-V,--version}'[print version]' \
  '(-e --command)'{-e,--command}'[command and args to execute (must be last argument)]:command:_command_names -e' \
  '(-w --working-dir)'{-w,--working-dir}'[start the shell in the specified working directory]:directory:_directories' \
  '--write-config=[write the config to a given path or the default location]:path:_files' \
  '--enable-log-file[write logs to a file inside the config directory]' \
  '--title-placeholder=[start window with specified title]:title' \
  '--app-id=[set the Wayland app_id or X11 WM_CLASS (Linux/BSD only)]:app id' \
  '*:program and arguments:_command_names -e' && ret=0

return ret
