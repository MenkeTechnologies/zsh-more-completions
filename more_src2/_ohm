#compdef ohm
# _ohm — Ohm parsing-toolkit CLI (ohmjs/ohm)
# upstream: https://github.com/ohmjs/ohm
# Subcommands from packages/cli/src/commands.

_ohm() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-n --dryRun)'{-n,--dryRun}'[print what would be written without writing]' \
        '(- *)'{-v,--version}'[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_ohm_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                generateBundles)
                    _arguments \
                        '(-t --withTypes)'{-t,--withTypes}'[also emit a matching .d.ts]' \
                        '(-e --esm)'{-e,--esm}'[emit ES module bundles (default is CommonJS)]' \
                        '*:.ohm grammar glob:_files -g "*.ohm"' && ret=0 ;;
                match)
                    _arguments \
                        '(-f --grammarFile)'{-f+,--grammarFile=}'[grammar source (.ohm) or bundle (.ohm-bundle.js)]:file:_files -g "*.(ohm|ohm-bundle.js)"' \
                        '(-g --grammarName)'{-g+,--grammarName=}'[name of the grammar to match against]:name:' \
                        '1:input file to match:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ohm_commands] )) ||
_ohm_commands() {
    local -a commands
    commands=(
        'generateBundles:emit standalone parser bundles for one or more .ohm files'
        'match:match an input against a given Ohm grammar'
    )
    _describe -t commands 'ohm command' commands
}

_ohm "$@"
