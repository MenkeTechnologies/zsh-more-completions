#compdef docker-scan
# _docker-scan — Docker Inc docker scan CLI Snyk-powered container-image vulnerability scanner integrated into Docker Desktop that scans a Docker image local-or-registry-stored for vulnerabilities CVE Snyk-database known-vulnerabilities license-issues reporting JSON SARIF text exit-code-on-severity (Docker team, Go); cobra
# upstream: https://docs.docker.com/scout/

_docker-scan() {
    local -a sub=(
        'auth:authenticate with Snyk'
        'login:authenticate with Snyk'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-f+[dockerfile]:file:_files' \
        '--file=+[file]:file:_files' \
        '-d[show dependency tree]' \
        '--dependency-tree[show dependency tree]' \
        '--severity=+[s]:s:(low medium high critical)' \
        '--exclude-base[exclude base image vulnerabilities]' \
        '--exclude-app-vulns[exclude application vulnerabilities]' \
        '--accept-license[accept license]' \
        '--reject-license[reject license]' \
        '--json[json output]' \
        '--sarif[SARIF output]' \
        '--group-issues[group issues]' \
        '--token=+[token]:str:' \
        '-t+[token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'docker-scan subcommand' sub ;;
        args)
            _arguments '*:image:'
            ;;
    esac
}

_docker-scan "$@"
