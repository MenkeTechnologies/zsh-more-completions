#compdef dmraid
# _dmraid — Linux device-mapper dmraid CLI managing software RAID metadata via dm-raid kernel target activating deactivating discovering ATARAID DDF1 Intel ISW Highpoint37x Highpoint45x JMicron LSI NVidia Promise SiL VIA fake-RAID controllers across host BIOS metadata formats (Heinz Mauelshagen team, C); getopt
# upstream: https://people.redhat.com/heinzm/sw/dmraid/

_dmraid() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[activate]:s:(y n)' \
        '--activate=+[activate]:s:(y n)' \
        '-b[block devices]' \
        '--block_devices[block devices]' \
        '-c+[device only]:str:' \
        '--display_columns=+[fmt]:str:' \
        '-d[debug]' \
        '--debug[debug]' \
        '-D+[dump metadata]:dir:_files -/' \
        '--dump_metadata=+[dir]:dir:_files -/' \
        '-E[erase metadata]' \
        '--erase_metadata[erase metadata]' \
        '-f+[format]:f:(asr ddf1 hpt37x hpt45x isw jmicron lsi nvidia pdc sil via)' \
        '--format=+[format]:f:(asr ddf1 hpt37x hpt45x isw jmicron lsi nvidia pdc sil via)' \
        '-g[group sets]' \
        '--display_group[display group]' \
        '-l[list metadata formats]' \
        '--list_formats[list metadata formats]' \
        '-n+[native log]:str:' \
        '-p[no partitions]' \
        '--no_partitions[no partitions]' \
        '-P[partitions]' \
        '--partchar=+[char]:str:' \
        '-r[raw devices]' \
        '--raid_devices[raid devices]' \
        '-R+[rebuild]:str:' \
        '--rebuild=+[set]:str:' \
        '-s[sets]' \
        '--sets[sets]' \
        '-t[tree]' \
        '--test[test]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-x[remove device]' \
        '--remove[remove]' \
        '-y[yes]' \
        '*:device:_files -g "/dev/sd* /dev/nvme* /dev/mapper/*"'
}

_dmraid "$@"
