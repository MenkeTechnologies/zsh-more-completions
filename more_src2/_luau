#compdef luau
# =============================================================================
# luau — the Luau programming language interpreter and REPL.  Luau is a
#        small, fast, embeddable, gradually typed programming language
#        forked from Lua 5.1 by ROBLOX in 2019 and open-sourced in 2021.
#        Powers the runtime of every game on the Roblox platform (200M+
#        monthly active users) and is increasingly adopted by other game
#        engines and embedded scripting hosts that want Lua's
#        embeddability plus optional static typing.
#
# Author:  Roblox Engineering (Arseny Kapoulkine et al.)
# Source:  https://github.com/luau-lang/luau
# CLI:     CLI/src/Repl.cpp (hand-rolled C++ argv parser)
# Library: hand-rolled C++ strcmp/strncmp argv dispatcher
# License: MIT
# Status:  Stable production at Roblox scale — 5,575+ stars; ships in the
#          Roblox Studio editor + Roblox Player runtime; adopted by
#          tabletop simulators (Tabletop Simulator), MMOs (Mortal Online 2),
#          and increasing third-party game engines as a Lua replacement.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — LUAU IS NOW LANGUAGE 53
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 52 to 53 documented languages.  Luau joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, Beluga, REBOL, Io, Pure, Yeti, Whiley, Boogie, Beef, and now Luau.
# luau is documented as the FIRST Luau CLI library variant in the taxonomy
# (hand-rolled C++ strcmp/strncmp argv dispatcher with --program-args
# terminator, --fflags= Roblox fast-flags integration, and --codegen-perf
# Linux perf JIT-aware tracing) — bringing the total to 220 cross-language
# CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS LUAU AND WHY IS IT A DISTINCT LANGUAGE FROM Lua (not a dialect)?
#
# Luau started as a fork of Lua 5.1 in 2017-2019 at Roblox.  The codebase
# has diverged significantly enough that Luau is now best understood as
# a SIBLING LANGUAGE to Lua rather than a dialect:
#
#   * GRADUAL STATIC TYPING — Luau adds an OPTIONAL TYPE SYSTEM with
#     type inference, function signatures, generics, intersection/union
#     types, table type literals.  This makes Luau the FIRST documented
#     "Lua-syntax language with first-class types"; pure Lua has no
#     types at all.
#   * NATIVE CODE GENERATION (CodeGen) — Luau ships a HAND-WRITTEN JIT
#     compiler that emits x86_64 native code for hot Luau functions.
#     This is OPT-IN via the --codegen flag and is automatic in Roblox
#     Studio.  Lua has no JIT (LuaJIT is a separate project not from
#     the Lua authors).
#   * BYTECODE COMPATIBILITY BREAKS — Luau bytecode is incompatible with
#     Lua 5.1 bytecode (different opcodes, different instruction
#     encoding).  This is intentional: Luau's VM is significantly faster
#     than Lua 5.1's for typed code paths.
#   * STRICT NO-COMPILER-OPTIMIZATIONS-AT-ROBLOX-DEFAULT — Luau enforces
#     deterministic execution (no floating-point reordering, no
#     associativity transformations) to prevent multi-machine state
#     divergence in MMO servers.
#   * SANDBOX MODEL — Luau adds a SECURITY-FIRST sandboxing layer with
#     readonly-table support, function-environment isolation, and
#     CALL_SECURITY tags that Roblox uses to restrict untrusted player
#     code.  Lua has no such layer.
#   * NEW SYNTAX EXTENSIONS — `continue` keyword, type annotations
#     (`local x: number`), string interpolation (`f"hello {name}"`),
#     compound assignment (`x += 1`).
#
# Luau is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented language with GRADUAL TYPING built on
#     top of a dynamic-typed BASE (Lua).  TypeScript adds gradual
#     typing to JavaScript but is a SEPARATE compile-target language;
#     Luau adds types to LUA SYNTAX and compiles to a LUA-COMPATIBLE
#     VM with both dynamic and typed code paths in the same VM.
#   * It is the FIRST documented language deployed at >200M MAU scale
#     as the application scripting layer of a major consumer platform
#     (Roblox).  No other documented language has Roblox-scale
#     deployment of user-written scripts.
#   * Its DEFAULT-DETERMINISTIC FLOATING POINT (no Kahan summation, no
#     FMA, no x87 80-bit) is a UNIQUE design choice driven by Roblox's
#     networking model where every client must produce identical
#     results for shared simulation.
#   * Its FAST FLAGS (FFlag) infrastructure — runtime-toggleable feature
#     gates accessible via --fflags=key=value — is integrated with
#     Roblox's broader A/B testing and gradual-rollout machinery.
#
# -----------------------------------------------------------------------------
# LUAU'S CLI LIBRARY — HAND-ROLLED C++ argv DISPATCHER
# -----------------------------------------------------------------------------
#
# Luau's CLI parser is a HAND-ROLLED C++ argv loop in CLI/src/Repl.cpp.
# It is the FIRST documented "C++ argv parser with --program-args
# terminator and FFlag string-DSL" pattern in the corpus's cross-language
# taxonomy.
#
# The dispatcher pattern (from Repl.cpp):
#
#     int replMain(int argc, char** argv) {
#         for (int i = 1; i < argc; ++i) {
#             if (strcmp(argv[i], "-h") == 0 || strcmp(argv[i], "--help") == 0) {
#                 displayHelp(argv[0]);
#                 return 0;
#             }
#             else if (strcmp(argv[i], "-i") == 0 || ...) { interactive = true; }
#             else if (strncmp(argv[i], "-O", 2) == 0) {
#                 int level = atoi(argv[i] + 2);          // -O2 → 2
#                 if (level < 0 || level > 2) error();
#             }
#             else if (strncmp(argv[i], "-g", 2) == 0) {
#                 int level = atoi(argv[i] + 2);          // -g1 → 1
#             }
#             else if (strcmp(argv[i], "--profile") == 0) {
#                 profile = 10000;                         // default 10kHz
#             }
#             else if (strncmp(argv[i], "--profile=", 10) == 0) {
#                 profile = atoi(argv[i] + 10);            // --profile=20000
#             }
#             else if (strcmp(argv[i], "--codegen") == 0) { codegen = true; }
#             else if (strcmp(argv[i], "--codegen-perf") == 0) { ... }
#             else if (strncmp(argv[i], "--fflags=", 9) == 0) {
#                 setLuauFlags(argv[i] + 9);               // delegate to FFlag parser
#             }
#             else if (strcmp(argv[i], "--program-args") == 0 ||
#                      strcmp(argv[i], "-a") == 0) {
#                 // remaining argv passed to the Luau script
#                 break;
#             }
#             else {
#                 // treat as script filename
#             }
#         }
#     }
#
# DISTINCTIVE PROPERTIES OF Luau's CLI DISPATCHER:
#
#   1. ATTACHED-VALUE SHORT FLAGS — `-O2`, `-g1`, `-O0`, `-g0` use
#      strncmp(prefix, 2) + atoi(value+2) to extract the integer level.
#      No support for `-O 2` separated form.  This is the GCC convention
#      (`-O2`, `-g3`, `-flto`) being reused for an interpreter, which is
#      unusual (most interpreters use separated values).
#
#   2. --PROFILE WITH OPTIONAL VALUE — `--profile` (default 10000 Hz) vs
#      `--profile=20000` (explicit Hz).  This is the dual-form pattern
#      shared with Pure (R467) and several other documented C/C++ CLIs.
#      Distinctive here: the DEFAULT is set when bare `--profile` is
#      seen, before the equals-suffix check.
#
#   3. --FFLAGS=<DSL> FOR ROBLOX FAST FLAGS — `--fflags=true,false,
#      LuauFlag1=true,LuauFlag2=false` is a comma-separated DSL passed
#      verbatim to setLuauFlags().  Fast flags are RUNTIME-TOGGLEABLE
#      feature gates that map to Roblox's A/B-testing infrastructure;
#      the same flags are settable in Roblox Studio via a separate
#      Studio Flags UI.  No other documented CLI library has a flag
#      whose value is a SECOND-LEVEL DSL passed to a separate parser.
#
#   4. --PROGRAM-ARGS / -A POSITIONAL TERMINATOR — like POSIX `--` but
#      with a custom flag name.  Everything after `-a` is passed to the
#      Luau program as part of `arg` table at the script level.  POSIX
#      `--` ALSO works (it's not specifically handled — falls through
#      to the "treat as filename" branch and Lua's loadfile handles it).
#      Distinctive: most CLIs use POSIX `--` only; Luau adds a NAMED
#      ALIAS that is more discoverable.
#
#   5. --CODEGEN-PERF FOR LINUX perf INTEGRATION — `--codegen-perf`
#      enables Linux perf-tools profiling of JIT-compiled native code
#      by emitting /tmp/perf-<pid>.map symbol files in the format perf
#      expects.  This is JIT-AWARE PROFILER INTEGRATION at the CLI flag
#      level — a feature unique to JIT-capable language CLIs.  Java's
#      `-XX:+PrintAssembly` is similar but is set via JVM flags not a
#      simple --flag.
#
#   6. NO HELP/VERSION REGISTRATION — `displayHelp(argv[0])` is a static
#      C function called from the main argv loop.  No help-generation
#      from spec data.  Adding a new flag requires editing displayHelp
#      manually to keep help text in sync.
#
#   7. SHIPS AS PART OF A SUITE — `luau` is one of SIX binaries from the
#      Luau distribution: luau (REPL/interpreter), luau-analyze (type
#      checker), luau-ast (AST printer), luau-reduce (test-case reducer),
#      luau-compile (bytecode compiler), luau-bytecode (bytecode dumper).
#      Each has its own CLI parser, but they share Luau.CLI.lib for
#      common parts (file utils, fflag parsing).  This SUITE-WITH-SHARED-
#      LIBRARY pattern is similar to llvm-* tools (llvm-objdump,
#      llvm-as, llvm-dis, llvm-link, etc.) but at a smaller scale.
#
# CONTRAST WITH OTHER HAND-ROLLED C/C++ CLI PARSERS DOCUMENTED IN THE CORPUS
#
#   * GNU getopt / getopt_long              — single-table state machine
#   * gcc / clang driver                     — spec-file driver
#   * mold / wild / GNU ld (R454)            — linker convention parser
#   * Beluga main.ml (R460, OCaml)           — tri-prefix +/- match
#   * REBOL host-args.c (R462, C)            — three flag tables +
#                                              bitfield-OR'd options
#   * Pure pure.cc (R467, C++)               — strcmp/strncmp if-chain
#                                              with env var fallback
#   * Luau Repl.cpp (THIS, C++)              — strcmp/strncmp if-chain
#                                              with --program-args
#                                              terminator + fflag DSL
#
# Luau's parser is closest in spirit to Pure (R467) — both use strcmp/
# strncmp dispatch in C++.  Luau is unique in:
#   * Named positional terminator (--program-args/-a) instead of `--`
#   * Embedded DSL (FFlag string) for runtime feature gates
#   * JIT-aware profiler integration via --codegen-perf
#   * GCC-style attached-value short flags (-O2, -g1) on an interpreter
#
# -----------------------------------------------------------------------------
# LUAU'S CLI SURFACE (verbatim from CLI/src/Repl.cpp displayHelp)
# -----------------------------------------------------------------------------
#
# USAGE:
#   luau [options] [file list] [-a] [arg list]
#
# When file list is omitted, an interactive REPL is started instead.
#
# Available options:
#   -h, --help                Display usage and exit
#   -i, --interactive         Run interactive REPL after executing scripts
#   -O0, -O1, -O2             Optimization level (default 1, range 0-2)
#   -g0, -g1, -g2             Debug level (default 1, range 0-2)
#   --coverage                Collect coverage to coverage.out
#   --counters                Collect native counters to callgrind.out
#   --profile[=N]             Profile at N Hz (default 10000) to profile.out
#   --timetrace               Record compiler time tracing to trace.json
#   --codegen                 Execute via native code generation (JIT)
#   --codegen-cold            JIT including unprofitable functions
#   --codegen-perf            JIT + emit Linux perf maps for profiling
#   --fflags=<flags>          Comma-separated fast-flag list
#                             e.g. --fflags=true,false,LuauTypeCheck=true
#   --program-args, -a        End of luau options; subsequent args are
#                             passed to the Luau program via `arg` table
#
# Positional:
#   [file list]               One or more .lua/.luau script files
#                             (omit for REPL)
#   [arg list]                Arguments passed to the Luau script
#                             (must come after -a / --program-args)
#
# Companion binaries (separate completions):
#   luau-analyze              Static type checker
#   luau-ast                  AST printer (parse + print)
#   luau-reduce               Test-case reducer (delta debugger)
#   luau-compile              Bytecode compiler (.luau → .luac)
#   luau-bytecode             Bytecode disassembler
#
# =============================================================================

_luau() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '(-h --help)'{-h,--help}'[display usage and exit]' \
        '(-i --interactive)'{-i,--interactive}'[run REPL after executing scripts]' \
        '-O-[optimization level (0-2)]:level:(0 1 2)' \
        '-g-[debug level (0-2)]:level:(0 1 2)' \
        '--coverage[collect code coverage to coverage.out]' \
        '--counters[collect native counters to callgrind.out]' \
        '--profile=-[profile at N Hz (default 10000)]::Hz:' \
        '--timetrace[record compiler timing to trace.json]' \
        '--codegen[execute via native code generation (JIT)]' \
        '--codegen-cold[JIT including unprofitable functions]' \
        '--codegen-perf[JIT + emit Linux perf maps]' \
        '--fflags=-[comma-separated fast-flag list]:flags:' \
        '(--program-args -a)'{--program-args,-a}'[start of args passed to Luau program]' \
        '*:Luau source:_files -g "*.(lua|luau)"' \
        && ret=0

    return ret
}

_luau "$@"
