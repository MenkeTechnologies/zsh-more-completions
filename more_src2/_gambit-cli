#compdef gambit-cli gsi gsc gambit gambc
# _gambit-cli — Marc Feeley gambit-cli CLI command-line frontend wrapping the Gambit Gambit-C Scheme compiler and interpreter open-source written in C and Scheme originally Marc Feeley at Universite de Montreal now Gambit team complete portable efficient and reliable implementation of the Scheme programming language Gambit-C compiles to C bytecode interpreter native compilation tail-call elimination Termite Erlang concurrency R5RS R7RS gsi gsc gambit gambc compile interpret install repl threads object module library exe debug optimize ssrx ssrr block C-FFI tail-calls (Université de Montréal Marc Feeley team, C/Scheme); custom argparse
# upstream: https://gambitscheme.org/

_gambit-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-e+[expression]:str:' \
        '*-e+[expression]:str:' \
        '-eval=+[expr]:str:' \
        '-c[compile only]' \
        '-c-flags=+[flags]:str:' \
        '-cc=+[cmd]:str:' \
        '-cpp[C++]' \
        '-cppopt=+[opt]:str:' \
        '*-cppopt=+[opt]:str:' \
        '-ccopt=+[opt]:str:' \
        '*-ccopt=+[opt]:str:' \
        '-ldopt=+[opt]:str:' \
        '*-ldopt=+[opt]:str:' \
        '-o+[output]:file:_files' \
        '-l+[lib]:str:' \
        '-debug[debug info]' \
        '-debug-environments[debug envs]' \
        '-debug-location[debug locations]' \
        '-debug-source[debug source]' \
        '-track-scheme[track scheme]' \
        '-prelude=+[expr]:str:' \
        '-postlude=+[expr]:str:' \
        '-no-error-msg[no error msg]' \
        '-no-warnings[no warnings]' \
        '-warnings[warnings]' \
        '-keep-c[keep C]' \
        '-link[link]' \
        '-flat[flat]' \
        '-mod[mod]' \
        '-target=+[t]:t:(C cpp js)' \
        '-shared[shared library]' \
        '-dynamic[dynamic]' \
        '-static[static]' \
        '-exe[executable]' \
        '-obj[object]' \
        '-base-version=+[v]:str:' \
        '-runtime-option=+[opt]:str:' \
        '-:?+[option]:str:' \
        '-:m+[option]:str:' \
        '-:M+[option]:str:' \
        '-:d-[debug option]:str:' \
        '-quiet[quiet]' \
        '-q[quiet]' \
        '-:tE[term escape]' \
        '-:tU[term up]' \
        '-:da[disable async]' \
        '-:d0[disable opt]' \
        '-:d1[disable opt 1]' \
        '-:di[disable inline]' \
        '-:dq[disable quasi]' \
        '-:f-[float option]:str:' \
        '-:f8,8[float prec]' \
        '-:r[ratiomatic]' \
        '-:R[ratiomatic]' \
        '-:s[stack max]' \
        '-:S[stack heap max]' \
        '-:l[live max]' \
        '-:L[liveheap max]' \
        '-:m[heap max]' \
        '-:M[memory map]' \
        '-:r=[runtime]:str:' \
        '-:p[path]' \
        '-:t[trace]' \
        '-:T[trace]' \
        '-:y[yield]' \
        '-:I[input flag]' \
        '-:O[output flag]' \
        '*:scheme file:_files -g "*.scm *.ss *.sld *.sps *.6 *.o[0-9]*"'
}

_gambit-cli "$@"
