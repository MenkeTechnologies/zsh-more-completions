#compdef llvm-objdump
# _llvm-objdump — LLVM ELF/Mach-O/COFF disassembler (LLVM project, C++); objdump compatible
# upstream: https://github.com/llvm/llvm-project

_llvm-objdump() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-d[disassemble]' \
        '--disassemble[disassemble]' \
        '-D[disassemble all]' \
        '--disassemble-all[disassemble all]' \
        '-r[show relocations]' \
        '-R[dynamic relocations]' \
        '-s[show section contents]' \
        '-S[interleave source]' \
        '--source[interleave source]' \
        '-t[show symbol table]' \
        '-T[show dynamic symbol table]' \
        '-x[all info]' \
        '--all-headers[all info]' \
        '-f[file headers]' \
        '-p[private headers]' \
        '--private-headers[private headers]' \
        '-h[section headers]' \
        '--section-headers[section headers]' \
        '-l[show line numbers]' \
        '--line-numbers[show line numbers]' \
        '-z[show zero bytes]' \
        '--disassemble-zeroes[show zero bytes]' \
        '-C[demangle]' \
        '--demangle[demangle]' \
        '--prefix-strip=+[prefix strip]:n:' \
        '--section=+[section]:section:' \
        '-j+[section]:section:' \
        '--start-address=+[start addr]:addr:' \
        '--stop-address=+[stop addr]:addr:' \
        '--arch=+[arch]:arch:' \
        '--triple=+[triple]:str:' \
        '--mattr=+[mattr]:str:' \
        '--mcpu=+[mcpu]:cpu:' \
        '--disassembler-options=+[disasm options]:str:' \
        '-M+[disasm options]:str:' \
        '--no-show-raw-insn[no raw insn]' \
        '--no-leading-addr[no leading addr]' \
        '--print-imm-hex[print imm hex]' \
        '--prefix=+[prefix]:str:' \
        '--source-encoding=+[source encoding]:enc:' \
        '*:file:_files'
}

_llvm-objdump "$@"
