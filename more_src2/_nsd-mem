#compdef nsd-mem
# _nsd-mem — NLnet Labs NSD memory estimator (parses nsd.conf + zonefiles and reports the RAM usage per zone and total — useful for capacity planning)
# upstream: https://github.com/NLnetLabs/nsd
# Flags from nsd-mem.c usage() on tip.

_nsd-mem() {
    _arguments \
        '(- *)-h[show usage]' \
        '-c+[config file (default: install prefix nsd.conf)]:file:_files'
}

_nsd-mem "$@"
