#compdef dhcp_release
# Documentation: https://manpages.debian.org/bookworm/dnsmasq-utils/dhcp_release.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcp_release <interface> <address> <MAC address> <client_id>
# Sends a DHCPRELEASE to dnsmasq to free an IPv4 lease. Must run as root.
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:interface:_net_interfaces' \
  '2:IP address:' \
  '3:MAC address:' \
  '4:client-id (optional, "*" if absent):' && ret=0
return ret
