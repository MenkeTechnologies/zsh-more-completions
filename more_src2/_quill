#compdef quill
# Documentation: https://github.com/dfinity/quill (src/main.rs GlobalOpts + src/commands/mod.rs Command enum)
# Reference accessed: 2026-05-29
# DFINITY Quill — Internet Computer ledger/governance toolkit for cold wallets.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'public-ids:retrieve public principal/account/neuron IDs'
  'send:transmit a signed message file to the IC network'
  'transfer:generate a signed transfer message'
  'claim-neurons:claim neuron stakes for genesis account'
  'neuron-stake:create a new neuron from an ICP balance'
  'neuron-manage:administer a neuron (dissolve, follow, vote, etc.)'
  'list-neurons:list available neurons'
  'list-proposals:list NNS proposals'
  'get-proposal-info:get NNS proposal details'
  'get-neuron-info:get neuron information'
  'account-balance:check account ICP balance'
  'update-node-provider:modify node-provider settings'
  'replace-node-provider-id:replace node-provider identifier'
  'ckbtc:ckBTC subcommands (transfer/balance/etc.)'
  'sns:SNS-related subcommands'
  'generate:create a new identity (PEM keys)'
  'decrypt-pem:decrypt an encrypted PEM file'
  'scanner-qrcode:show QR code for the QR scanner companion app'
  'qr-code:generate a QR code for a previously-signed message'
  'help:show help for a subcommand'
)

local -a _global
_global=(
  '(-h --help)'{-h,--help}'[show help]'
  '(-V --version)'{-V,--version}'[show version]'
  '--pem-file=[PEM file (- for stdin)]:file:_files -g "*.pem"'
  '--password-file=[password file for encrypted PEM (requires --pem-file)]:file:_files'
  '(--hsm --ledger)--hsm[enable hardware key signing via PKCS#11]'
  '--hsm-libpath=[PKCS#11 module library path]:file:_files'
  '--hsm-slot=[hardware key slot]:slot:'
  '--hsm-id=[hardware key id]:id:'
  '(--hsm --ledger)--ledger[authenticate using Ledger hardware wallet]'
  '--qr[output results as UTF-8 QR codes]'
  '--insecure-local-dev-mode[fetch root key for local testing only]'
  '--seed-file=[deprecated]:file:_files'
)

_arguments -C \
  $_global \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'quill subcommand' _subcmds && ret=0
    ;;
  args)
    local -a _ckbtc _sns _neuron_manage
    _ckbtc=(
      'balance:check ckBTC balance'
      'transfer:send ckBTC to another principal'
      'retrieve-btc:withdraw ckBTC back to BTC'
      'retrieve-btc-status:check retrieve-btc operation status'
      'update-balance:update ckBTC balance from deposit'
    )
    _sns=(
      'configure-dissolve-delay:configure neuron dissolve delay'
      'follow-neuron:follow another SNS neuron'
      'get-sale-participation:check SNS sale participation'
      'get-swap-refund:get swap refund'
      'list-deployed-snses:list deployed SNSes'
      'make-proposal:create an SNS proposal'
      'make-upgrade-canister-proposal:propose canister upgrade'
      'new-sale-ticket:create a new sale ticket'
      'pay:pay for an SNS sale ticket'
      'register-vote:register a vote on a proposal'
      'stake-neuron:stake an SNS neuron'
      'stake-maturity:stake neuron maturity'
      'status:show SNS status'
      'transfer:transfer SNS tokens'
      'balance:check SNS token balance'
    )
    _neuron_manage=(
      'dissolve:start/stop dissolving'
      'follow:set follow targets'
      'vote:cast a vote'
      'stake-maturity:stake matured rewards'
      'split:split a neuron'
      'merge:merge with another neuron'
      'spawn:spawn a neuron from maturity'
      'disburse:disburse a dissolved neuron'
      'register-vote:register a vote'
    )
    case $line[1] in
      ckbtc)
        _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'ckbtc' _ckbtc && ret=0
        ;;
      sns)
        _arguments '1: :->sub' && [[ $state == sub ]] && _describe -t commands 'sns' _sns && ret=0
        ;;
      neuron-manage)
        _arguments \
          ':neuron id:' \
          '*: :->mgr' && [[ $state == mgr ]] && _describe -t commands 'neuron manage' _neuron_manage && ret=0
        ;;
      send)
        _arguments \
          '--dry-run[print the message without sending]' \
          '--yes[skip confirmation prompt]' \
          ':signed message file:_files -g "*.json"' && ret=0
        ;;
      generate)
        _arguments \
          '--seed-file=[seed phrase file]:file:_files' \
          '--phrase=[BIP39 seed phrase]:phrase:' \
          '--storage-mode=[storage mode]:mode:(plain-text password-protected)' && ret=0
        ;;
      qr-code|scanner-qrcode)
        _arguments \
          '--file=[message file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
