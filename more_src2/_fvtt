_fvtt() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--config=[path to YAML config file]:file:_files -g "*.(yaml|yml)"' \
        '(-h --help)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _fv_cmds=(
                'configure:manage configuration'
                'package:manage packages + compendia'
                'launch:launch Foundry VTT server'
            )
            _describe -t commands 'fvtt command' _fv_cmds && ret=0
            ;;
        args)
            case $words[1] in
                configure)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'configure action' '(get set view path)' && ret=0
                    else
                        case $words[2] in
                            get|set)
                                _arguments \
                                    '1:key:(installPath dataPath currentPackageId currentPackageType)' \
                                    '2:value:' && ret=0
                                ;;
                        esac
                    fi
                    ;;
                package)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'package action' '(workon clear unpack pack)' && ret=0
                    else
                        _arguments \
                            '1:value:' \
                            '--id=[package ID]:id:' \
                            '--type=[package type]:type:(Module System World)' \
                            '(-n --compendiumName)'{-n,--compendiumName}'=[compendium name]:name:' \
                            '(-t --compendiumType)'{-t,--compendiumType}'=[compendium document type (NeDB)]:type:(Actor Item Adventure Card Cards ChatMessage Combat Folder JournalEntry Macro Playlist RollTable Scene User Setting AmbientLight AmbientSound Drawing MeasuredTemplate Note Tile Token Wall)' \
                            '--inputDirectory=[input directory]:dir:_files -/' \
                            '--in=[input directory (alias)]:dir:_files -/' \
                            '--outputDirectory=[output directory]:dir:_files -/' \
                            '--out=[output directory (alias)]:dir:_files -/' \
                            '--yaml[use YAML instead of JSON]' \
                            '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
                            '--nedb[use NeDB instead of ClassicLevel]' \
                            '(-r --recursive)'{-r,--recursive}'[recurse input directories (pack mode)]' \
                            '(-c --clean)'{-c,--clean}'[delete destination before unpack]' \
                            '--folders[match compendium folder structure (unpack)]' \
                            '--expandAdventures[extract embedded Adventure docs separately]' \
                            '--omitVolatile[skip entries with only volatile-field changes]' && ret=0
                    fi
                    ;;
                launch)
                    _arguments \
                        '--demo[launch in demo mode]' \
                        '--port=[port (default 30000)]:port:' \
                        '--world=[world to load]:world:' \
                        '--noupnp[disable UPnP port forwarding]' \
                        '--noupdate[disable auto-update checking]' \
                        '--adminKey=[admin-screen lock key]:key:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_fvtt "$@"
