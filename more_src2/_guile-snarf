#compdef guile-snarf
# Documentation: https://www.gnu.org/software/guile/manual/html_node/Snarfing-Macros.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[output file]:file:_files' \
  '*:CPP arg / source file:_files' && ret=0

return ret
