#compdef esxcli
# _esxcli — VMware esxcli ESXi command-line tool CLI alias (VMware team, Python/C); custom argparse
# upstream: https://developer.vmware.com/web/dp/tool/esxcli

_esxcli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--formatter=+[formatter]:f:(xml table simple keyvalue csv)' \
        '--debug[debug mode]' \
        '--server=+[server]:host:_hosts' \
        '-s+[server]:host:_hosts' \
        '--vihost=+[vihost]:host:_hosts' \
        '-h+[vihost]:host:_hosts' \
        '--portnumber=+[port]:port:' \
        '--protocol=+[protocol]:p:(http https)' \
        '--username=+[user]:_users' \
        '-u+[user]:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--credstore=+[credstore]:file:_files' \
        '-c+[credstore]:file:_files' \
        '--config=+[config file]:file:_files' \
        '--cacertsfile=+[ca certs file]:file:_files' \
        '--sessionfile=+[session file]:file:_files' \
        '--savesessionfile=+[file]:file:_files' \
        '--passthroughauth[passthrough auth]' \
        '--passthroughauthpackage=+[package]:str:' \
        '--encoding=+[encoding]:str:' \
        '--httpdomain=+[domain]:str:' \
        '--httpalwaysuseproxy[always use proxy]' \
        '--httpproxyhost=+[proxy host]:host:_hosts' \
        '--httpproxyport=+[proxy port]:port:' \
        '--httpproxyusername=+[proxy user]:_users' \
        '--httpproxypassword=+[proxy pass]:str:' \
        '*:namespace command:'
}

_esxcli "$@"
