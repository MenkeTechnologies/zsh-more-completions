# kgpg: KDE GPG frontend (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '*:file:_files' && ret=0
return ret
