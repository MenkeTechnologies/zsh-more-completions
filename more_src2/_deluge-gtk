#compdef deluge-gtk
# Documentation: https://manpages.debian.org/bookworm/deluge-gtk/deluge-gtk.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm deluge-gtk(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL.

# deluge-gtk: Deluge GTK GUI client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[configuration directory]:dir:_files -/' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '(-L --loglevel)'{-L+,--loglevel=}'[log level]:level:(none info warning error debug)' \
  '(-q --quiet)'{-q,--quiet}'[quiet output]' \
  '--logrotate=-[log rotation max size]:size:' \
  '*:torrent or magnet:_files -g "*.torrent(-.)"' && ret=0
return ret
