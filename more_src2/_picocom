#compdef picocom
# Documentation: https://github.com/npat-efault/picocom
# Source: npat-efault/picocom bash_completion/picocom — minimal dumb-terminal emulator (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-b --baud)'{-b+,--baud=}'[baud rate]:rate:(1200 2400 4800 9600 19200 38400 57600 115200 230400 460800 921600)' \
    '(-f --flow)'{-f+,--flow=}'[flow control]:flow:(x h n)' \
    '(-d --databits)'{-d+,--databits=}'[data bits]:bits:(5 6 7 8)' \
    '(-p --stopbits)'{-p+,--stopbits=}'[stop bits]:bits:(1 2)' \
    '(-y --parity)'{-y+,--parity=}'[parity]:parity:(o e n)' \
    '(-I --imap)'{-I+,--imap=}'[input map]:map:_default' \
    '(-O --omap)'{-O+,--omap=}'[output map]:map:_default' \
    '(-E --emap)'{-E+,--emap=}'[local echo map]:map:_default' \
    '--echo[enable local echo]' \
    '(-t --initstring)'{-t+,--initstring=}'[string sent at startup]:string:_default' \
    '--noinit[do not initialize terminal device]' \
    '--noreset[do not reset terminal device on exit]' \
    '--hangup[send HUP signal to processes using port]' \
    '--lower-rts[lower RTS line on startup]' \
    '--lower-dtr[lower DTR line on startup]' \
    '--raise-rts[raise RTS line on startup]' \
    '--raise-dtr[raise DTR line on startup]' \
    '(-v --receive-cmd)'{-v+,--receive-cmd=}'[receive command]:command:_command_names' \
    '(-s --send-cmd)'{-s+,--send-cmd=}'[send command]:command:_command_names' \
    '(-e --escape)'{-e+,--escape=}'[escape character]:char:_default' \
    '--no-escape[disable the escape character]' \
    '(-g --logfile)'{-g+,--logfile=}'[log all I/O to file]:file:_files' \
    '(-x --exit-after)'{-x+,--exit-after=}'[exit after N idle ms]:ms:_default' \
    '(-X --exit)'{-X,--exit}'[exit after sending initstring]' \
    '--nolock[do not try to lock the port]' \
    '(-q --quiet)'{-q,--quiet}'[suppress diagnostic messages]' \
    '(- *)'{-h,--help}'[show help]' \
    '1:port:_files -g "/dev/tty*"' \
    && ret=0

return ret
