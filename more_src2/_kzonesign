#compdef kzonesign keymgr knot-tools
# _kzonesign — CZ.NIC Labs kzonesign Knot DNS DNSSEC zone-signing tool helper for the Knot DNS authoritative server (CZNIC team, C); custom argparse
# upstream: https://gitlab.nic.cz/knot/knot-dns

_kzonesign() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[knot config file]:file:_files -g "knot.conf *.conf"' \
        '--config=+[knot config file]:file:_files -g "knot.conf *.conf"' \
        '-C+[confdb dir]:dir:_files -/' \
        '--confdb=+[confdb dir]:dir:_files -/' \
        '-o+[output file]:file:_files' \
        '--outfile=+[output file]:file:_files' \
        '-t+[seconds]:n:' \
        '--time=+[seconds]:n:' \
        '-r[rollover]' \
        '--rollover[rollover]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-z+[zone file]:file:_files' \
        '--zone=+[zone file]:file:_files' \
        '*:zone:'
}

_kzonesign "$@"
