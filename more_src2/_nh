#compdef nh
# Documentation: https://github.com/nix-community/nh
# Source: https://github.com/viperML/nh/blob/master/crates/nh/src/interface.rs
# Reference accessed: 2026-06-01
# "yet another Nix helper" — unified front-end for nixos-rebuild / home-manager / darwin-rebuild.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _nh_cmds
_nh_cmds=(
    'os:NixOS system management (replaces nixos-rebuild)'
    'home:Home Manager configuration (replaces home-manager)'
    'darwin:macOS/nix-darwin management (replaces darwin-rebuild)'
    'search:fast package searching via Elasticsearch'
    'clean:enhanced garbage collection with gcroot cleanup'
)

local -a _nh_os_subs
_nh_os_subs=(
    'switch:build and activate the new configuration'
    'boot:build and set as boot default'
    'test:build and activate without making boot default'
    'build:build only'
    'repl:nix repl in configuration context'
    'info:print system information'
)

_arguments -C \
    '*'{-v,--verbose}'[increase logging verbosity (repeatable)]' \
    '(-q --quiet)'{-q,--quiet}'[decrease logging verbosity]' \
    '(-e --elevation-strategy)'{-e+,--elevation-strategy=}'[privilege elevation strategy]:strategy:(none passwordless auto sudo doas run0 pkexec)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'nh command' _nh_cmds && ret=0
        ;;
    args)
        case $line[1] in
            os|darwin)
                _arguments -s -S \
                    '1:subcommand:->os-sub' \
                    '(-n --dry)'{-n,--dry}'[only print actions]' \
                    '(-a --ask)'{-a,--ask}'[ask for confirmation]' \
                    '-H+[hostname / configuration name]:hostname:_default' \
                    '-f+[flake path]:flake:_files -/' \
                    '(-o --out-link)'{-o+,--out-link=}'[result link path]:path:_files' \
                    '--no-nom[disable nix-output-monitor]' \
                    '(-d --diff)'{-d+,--diff=}'[package diff display]:mode:(auto always never)' \
                    '--specialisation=[NixOS specialisation]:name:_default' \
                    '(-j --max-jobs)'{-j+,--max-jobs=}'[concurrent jobs]:n:_default' \
                    '--cores=[cores per build]:n:_default' \
                    '--log-format=[Nix log format]:fmt:_default' \
                    '(-k --keep-going)'{-k,--keep-going}'[continue despite errors]' \
                    '(-K --keep-failed)'{-K,--keep-failed}'[keep failed build outputs]' \
                    '--fallback[build locally on substituter failure]' \
                    '--repair[repair corrupted store paths]' \
                    '*-I+[include path]:path:_files -/' \
                    '(-L --print-build-logs)'{-L,--print-build-logs}'[print build logs to stdout]' \
                    '(-t --show-trace)'{-t,--show-trace}'[show tracebacks]' \
                    '--accept-flake-config[accept config from flakes]' \
                    '--refresh[refresh flakes]' \
                    '--impure[allow impure builds]' \
                    '--offline[no internet access]' \
                    '--no-net[prohibit network usage]' \
                    '--recreate-lock-file[recreate flake.lock]' \
                    '--no-update-lock-file[do not update flake.lock]' \
                    '--no-write-lock-file[do not write a lock file]' \
                    '--no-use-registries[do not use registries]' \
                    '--commit-lock-file[commit flake.lock]' \
                    '(-Q --no-build-output)'{-Q,--no-build-output}'[suppress build output]' \
                    '--use-substitutes[use substitutes when copying]' \
                    '--json[output JSON]' \
                    && ret=0
                case $state in
                    os-sub) _describe -t os 'subcommand' _nh_os_subs && ret=0 ;;
                esac
                ;;
            home)
                _arguments -s -S \
                    '(-n --dry)'{-n,--dry}'[only print actions]' \
                    '(-a --ask)'{-a,--ask}'[ask for confirmation]' \
                    '-c+[configuration name]:cfg:_default' \
                    '-f+[flake path]:flake:_files -/' \
                    '(-o --out-link)'{-o+,--out-link=}'[result link path]:path:_files' \
                    '--no-nom[disable nix-output-monitor]' \
                    '(-d --diff)'{-d+,--diff=}'[package diff display]:mode:(auto always never)' \
                    && ret=0
                ;;
            search)
                _arguments -s -S \
                    '*:query:_default' && ret=0
                ;;
            clean)
                _arguments -s -S \
                    '*:targets:_files -/' && ret=0
                ;;
        esac
        ;;
esac

return ret
