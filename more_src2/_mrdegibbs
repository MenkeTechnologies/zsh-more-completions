#compdef mrdegibbs
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrdegibbs.html
# Source: MRtrix3/mrtrix3 cmd/mrdegibbs.cpp — remove Gibbs ringing via local subvoxel-shift method (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-axes+[comma-separated axes (default 0,1)]:list:_default' \
    '-nshifts+[subpixel spacing discretization (default 20)]:n:_default' \
    '-minW+[left border of TV window (default 1)]:n:_default' \
    '-maxW+[right border of TV window (default 3)]:n:_default' \
    '1:in (input image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:out (output image):_files' \
    && ret=0

return ret
