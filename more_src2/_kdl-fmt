#compdef kdl-fmt
# _kdl-fmt — KDL document formatter (dj95/kdl-fmt)
# upstream: https://github.com/dj95/kdl-fmt
# Flags from src/config/args.rs (clap).

_kdl-fmt() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '--from-v1[force the v1 parser for input]'
        '--from-v2[force the v2 parser for input]'
        '--to-v1[emit the output as KDL v1]'
        '--to-v2[emit the output as KDL v2]'
        '--in-place[format the input file in place]'
        '(-s --strip-comments)'{-s,--strip-comments}'[remove all comments from the output]'
        '(-i --indent-level)'{-i+,--indent-level=}'[number of spaces to indent]:n:'
        '(-n --no-format)'{-n,--no-format}'[only parse and validate, do not format]'
        '1:KDL file or - for stdin:_files -g "*.kdl"'
    )
    _arguments -s $args
}

_kdl-fmt "$@"
