#compdef dcmmklut
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmmklut.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmpstat/apps/dcmmklut.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmpstat/apps/dcmmklut.cc OFCommandLine setup + docs/man/dcmmklut.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+Tm --modality)'{+Tm,--modality}'[create as Modality LUT]' \
  '(+Tp --presentation)'{+Tp,--presentation}'[create as Presentation LUT]' \
  '(+Tv --voi)'{+Tv,--voi}'[create as VOI LUT (default)]' \
  '(+Pa --add)'{+Pa,--add}'[add to existing transform (default for and only with --voi)]' \
  '(+Pr --replace)'{+Pr,--replace}'[replace existing transform (default for --modality and --presentation)]' \
  '(+Cg --gamma)'{+Cg+,--gamma=}'[use gamma value (default: 1.0)]:gamma:' \
  '(+Cm --map-file)'{+Cm+,--map-file=}'[read input data from MAP file]:file:_files' \
  '(+Ct --text-file)'{+Ct+,--text-file=}'[read input data from text file]:file:_files' \
  '(+Og --inverse-gsdf)'{+Og,--inverse-gsdf}'[apply inverse GSDF (print presentation LUT in OD)]' \
  '--min-density=[set min density to v in hundreds of OD (default: 20)]:value:' \
  '--max-density=[set max density to v in hundreds of OD (default: 300)]:value:' \
  '(+Oi --illumination)'{+Oi+,--illumination=}'[set illumination to v in cd/m^2 (default: 2000)]:value:' \
  '(+Or --reflection)'{+Or+,--reflection=}'[set reflected ambient light to v in cd/m^2 (default: 10)]:value:' \
  '(-b --bits)'{-b+,--bits=}'[create LUT with n bit values (8..16, default: 16)]:number:' \
  '(-e --entries)'{-e+,--entries=}'[create LUT with n entries (1..65536, default: 256)]:number:' \
  '(-f --first-mapped)'{-f+,--first-mapped=}'[first input value mapped (-31768..65535, default: 0)]:number:' \
  '(-r --random)'{-r+,--random=}'[perform n randomly selected permutations on the LUT]:number:' \
  '(-rs --random-seed)'{-rs+,--random-seed=}'[initialize random-number generator with n (default: 0)]:number:' \
  '(-o --order)'{-o+,--order=}'[use polynomial curve fitting with order n (0..99, default: 5)]:number:' \
  '(-E --explanation)'{-E+,--explanation=}'[LUT explanation (default: automatically created)]:name:' \
  '(-a --byte-align)'{-a,--byte-align}'[create byte-aligned LUT (default for and only with 8 bit values)]' \
  '(+a --word-align)'{+a,--word-align}'[create word-aligned LUT (default for 9-16 bit values)]' \
  '(+Dw --data-ow)'{+Dw,--data-ow}'[write LUT Data as OW (default)]' \
  '(+Du --data-us)'{+Du,--data-us}'[write LUT Data as US]' \
  '(+Ds --data-ss)'{+Ds,--data-ss}'[write LUT Data as SS (minimal support)]' \
  '(+Fi --dicom-input)'{+Fi+,--dicom-input=}'[read dataset from DICOM file]:file:_files' \
  '(+Fo --text-output)'{+Fo+,--text-output=}'[write LUT data to tabbed text file]:file:_files' \
  '*:dcmimg-out:_files'
