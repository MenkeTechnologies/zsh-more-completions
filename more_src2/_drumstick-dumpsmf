#compdef drumstick-dumpsmf
# _drumstick-dumpsmf — dump a Standard MIDI File as text (pedrolcl/drumstick)
# upstream: https://github.com/pedrolcl/drumstick
# Flags from utils/dumpsmf/dumpsmf.cpp (QCommandLineParser).

_drumstick-dumpsmf() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '*:SMF file:_files -g "*.{mid,midi}"'
}

_drumstick-dumpsmf "$@"
