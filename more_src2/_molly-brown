#compdef molly-brown
# _molly-brown — Molly Brown Gemini protocol server (Go); serves gemini:// from a docroot with TLS client-cert + CGI + tilde users
# upstream: https://tildegit.org/solderpunk/molly-brown

_molly-brown() {
    _arguments \
        '-c+[config TOML file]:file:_files -g "*.toml"' \
        '-d+[docroot dir]:dir:_files -/' \
        '-p+[port]:port:' \
        '-h+[hostname]:host:_hosts' \
        '--cert+[TLS cert]:file:_files' \
        '--key+[TLS key]:file:_files' \
        '--log+[access log]:file:_files' \
        '--help[show help]' \
        '--version[show version]'
}

_molly-brown "$@"
