#compdef ksqldb ksqldb-cli ksql-cli
# _ksqldb — Confluent ksqldb-cli interactive and headless CLI for ksqlDB SQL stream-processing engine on Apache Kafka with CREATE STREAM TABLE materialised view INSERT SELECT EMIT CHANGES (confluentinc team, Java); JCommander
# upstream: https://github.com/confluentinc/ksql

_ksqldb() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[url]:str:' \
        '-s+[url]:str:' \
        '--user=+[user]:u:_users' \
        '-u+[user]:u:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--config-file=+[file]:file:_files -g "*.properties *.conf"' \
        '-c+[file]:file:_files -g "*.properties *.conf"' \
        '--script=+[file]:file:_files -g "*.sql *.ksql"' \
        '-f+[file]:file:_files -g "*.sql *.ksql"' \
        '--execute=+[stmt]:str:' \
        '-e+[stmt]:str:' \
        '--query=+[stmt]:str:' \
        '-q+[stmt]:str:' \
        '--output=+[fmt]:f:(json tabular)' \
        '-o+[fmt]:f:(json tabular)' \
        '--no-confirm[skip confirm]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--ssl-cert-store=+[file]:file:_files -g "*.jks *.p12 *.pem"' \
        '--ssl-trust-store=+[file]:file:_files -g "*.jks *.p12 *.pem"' \
        '--ssl-key-password=+[password]:str:' \
        '--ssl-trust-password=+[password]:str:' \
        '*:server url:'
}

_ksqldb "$@"
