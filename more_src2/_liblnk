#compdef lnkinfo
# _liblnk — libyal Windows Shortcut File (.lnk) parser; prints target path, working dir, arguments, icon, MAC timestamps, drive serial, link target IDList
# upstream: https://github.com/libyal/liblnk

_liblnk() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[codepage]:codepage:(ascii windows-874 windows-932 windows-936 windows-949 windows-950 windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-X[exclusive]' \
        '*:LNK file:_files -g "*.lnk"'
}

_liblnk "$@"
