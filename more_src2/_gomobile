#compdef gomobile
# Documentation: https://pkg.go.dev/golang.org/x/mobile/cmd/gomobile

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bind:build a library for Android and iOS'
  'build:compile Android APK and iOS app'
  'clean:remove object files and cached gomobile files'
  'init:build OpenAL for Android'
  'install:compile Android APK and install on device'
  'version:print version'
)

_arguments -s -S \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'gomobile command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (bind)
        _arguments -s -S \
          '-target=[target systems (comma-separated)]:target:(android ios iossimulator macos maccatalyst)' \
          '-androidapi=[Android API level]:api level:' \
          '-iosversion=[minimum iOS version]:version:' \
          '-tags=[build tags]:tags:' \
          '-v[verbose output]' \
          '-x[print commands]' \
          '-work[print workdir and do not delete it]' \
          '-ldflags=[linker flags]:flags:' \
          '-gcflags=[go compiler flags]:flags:' \
          '-trimpath[remove all file system paths from the resulting binary]' \
          '-o=[output file or directory]:output:_files' \
          '-javapkg=[Java package prefix]:package:' \
          '-prefix=[Objective-C name prefix]:prefix:' \
          '-bootclasspath=[Java bootstrap classpath]:classpath:_files' \
          '-classpath=[Java classpath]:classpath:_files' \
          '*:package:_files -/' && ret=0
        ;;
      (build)
        _arguments -s -S \
          '-target=[target systems (comma-separated)]:target:(android ios iossimulator macos maccatalyst)' \
          '-androidapi=[Android API level]:api level:' \
          '-iosversion=[minimum iOS version]:version:' \
          '-tags=[build tags]:tags:' \
          '-v[verbose output]' \
          '-x[print commands]' \
          '-work[print workdir and do not delete it]' \
          '-ldflags=[linker flags]:flags:' \
          '-gcflags=[go compiler flags]:flags:' \
          '-trimpath[remove all file system paths from the resulting binary]' \
          '-o=[output file]:output:_files' \
          '-appID=[app identifier]:identifier:' \
          '*:package:_files -/' && ret=0
        ;;
      (install)
        _arguments -s -S \
          '-target=[target systems]:target:(android)' \
          '-androidapi=[Android API level]:api level:' \
          '-tags=[build tags]:tags:' \
          '-v[verbose output]' \
          '-x[print commands]' \
          '-work[print workdir and do not delete it]' \
          '-ldflags=[linker flags]:flags:' \
          '-gcflags=[go compiler flags]:flags:' \
          '-trimpath[remove all file system paths]' \
          '*:package:_files -/' && ret=0
        ;;
      (clean)
        ;;
      (init)
        _arguments -s -S \
          '-v[verbose output]' \
          '-x[print commands]' && ret=0
        ;;
    esac
    ;;
esac

return ret
