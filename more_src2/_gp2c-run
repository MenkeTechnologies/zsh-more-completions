#compdef gp2c-run
# Documentation: https://pari.math.u-bordeaux.fr/dochtml/html-stable/gp2c.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gp2c-run: compile + load a PARI/GP script (GP-to-C translator)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '-g[debug build]' \
  '-O[optimize build]' \
  '-W[warning level]:level:(0 1 2 3)' \
  '-p[install prefix for functions]:prefix:' \
  '*:GP source:_files -g "*.gp"' && ret=0
return ret
