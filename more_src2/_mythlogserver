#compdef mythlogserver
# Documentation: https://github.com/MythTV/mythtv/tree/master/mythtv/programs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; mythlogserver was removed from
# modern MythTV (shipped in 0.25-0.27 only). STUB: file kept per
# "do not delete files" directive.

# mythlogserver: legacy MythTV log server (removed in modern MythTV)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0
return ret
