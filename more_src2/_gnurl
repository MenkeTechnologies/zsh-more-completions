#compdef gnurl
# Documentation: https://gnunet.org/en/gnurl.html
# Reference accessed: 2026-05-16
# Verified: upstream gnunet.org page declares "bug-for-bug compatibility
# with the HTTP/HTTPS/GnuTLS subset of cURL". gnurl reuses curl's CLI.
# Only the most common HTTP-relevant flags are listed; for the full set
# defer to the system `_curl` completion.
# Removed from prior file: bogus man.archlinux.org search URL; the prior
# stub matched curl in name only.

# gnurl: GNUnet's libcurl fork (HTTPS/GnuTLS subset)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-X --request)'{-X+,--request=}'[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
  '(-d --data)'{-d+,--data=}'[POST data]:data:' \
  '--data-binary=[POST binary data]:data:' \
  '--data-raw=[POST raw data]:data:' \
  '--data-urlencode=[POST URL-encoded data]:data:' \
  '(-H --header)'*{-H+,--header=}'[extra header]:header:' \
  '(-o --output)'{-o+,--output=}'[write to file]:file:_files' \
  '(-O --remote-name)'{-O,--remote-name}'[save with remote filename]' \
  '(-L --location)'{-L,--location}'[follow redirects]' \
  '(-I --head)'{-I,--head}'[HEAD request]' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-k --insecure)'{-k,--insecure}'[skip TLS verification]' \
  '(-u --user)'{-u+,--user=}'[user:password]:credentials:' \
  '(-A --user-agent)'{-A+,--user-agent=}'[User-Agent string]:ua:' \
  '(-e --referer)'{-e+,--referer=}'[Referer URL]:url:' \
  '(-b --cookie)'{-b+,--cookie=}'[cookie data or file]:cookie:' \
  '(-c --cookie-jar)'{-c+,--cookie-jar=}'[write cookies to file]:file:_files' \
  '--cacert=[CA certificate file]:file:_files' \
  '--cert=[client certificate]:file:_files' \
  '--key=[client key]:file:_files' \
  '*:url:_urls' && ret=0
return ret
