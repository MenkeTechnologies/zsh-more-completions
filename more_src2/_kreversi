#compdef kreversi
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man6/kreversi.6.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# KReversi: KDE Reversi/Othello board game. Added real --demo,
# --author, --license, --help-qt/-kde/-all and --session from the
# upstream manpage.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help about options]' \
  '(- *)--help-qt[show Qt specific options]' \
  '(- *)--help-kde[show KDE specific options]' \
  '(- *)--help-all[show all options]' \
  '(- *)'{-v,--version}'[show version information]' \
  '(- *)--author[show author information]' \
  '(- *)--license[show license information]' \
  '--demo[start with demo game playing]' \
  '--display=[use specified X-server display]:disp:' \
  '--session=[restore application for given session ID]:id:' \
  '--config=[use alternative configuration file]:file:_files' \
  '--style=[set application GUI style]:style:' \
  '--geometry=[set main widget client geometry]:geometry:' && ret=0

return ret
