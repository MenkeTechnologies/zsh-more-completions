#compdef lesspipe lesspipe.sh
# Documentation: https://manpages.debian.org/bookworm/less/lesspipe.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# STUB: lesspipe is an input preprocessor for less invoked via
# `eval "$(lesspipe)"`. It takes no command-line options of its own;
# arguments are filenames passed to less, used for filetype dispatch.

local ret=1

_arguments -C \
  '*:file:_files' && ret=0

return ret
