#compdef quartz
# _quartz — fast static-site generator for digital gardens (jackyzha0/quartz)
# upstream: https://github.com/jackyzha0/quartz
# Subcommands + flags from quartz/bootstrap-cli.mjs + quartz/cli/args.js (yargs).

_quartz() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-d --directory)'{-d+,--directory=}'[content directory (default: content)]:dir:_files -/' \
        '(-v --verbose)'{-v,--verbose}'[print extra logging information]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :_quartz_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                create)
                    _arguments \
                        '(-s --source)'{-s+,--source=}'[source directory to copy/symlink from]:dir:_files -/' \
                        '(-X --strategy)'{-X+,--strategy=}'[content folder strategy]:strategy:(new copy symlink)' \
                        '(-l --links)'{-l+,--links=}'[link resolution strategy]:strategy:(absolute shortest relative)'
                    ;;
                sync)
                    _arguments \
                        '--commit=[create a git commit for unsaved changes]:bool:(true false)' \
                        '(-m --message)'{-m+,--message=}'[override the default sync commit message]:msg:' \
                        '--push=[push updates to your Quartz fork]:bool:(true false)' \
                        '--pull=[pull updates from your Quartz fork]:bool:(true false)'
                    ;;
                build)
                    _arguments \
                        '(-o --output)'{-o+,--output=}'[output folder (default: public)]:dir:_files -/' \
                        '--serve[run a local server to live-preview the site]' \
                        '--watch[watch for changes and rebuild]' \
                        '--baseDir=[base path for the local server]:path:' \
                        '--port=[HTTP server port (default: 8080)]:port:' \
                        '--wsPort=[WebSocket port for hot reload (default: 3001)]:port:' \
                        '--remoteDevHost=[WebSocket URL override (non-localhost dev)]:url:' \
                        '--bundleInfo[show detailed bundle information]' \
                        '--concurrency=[parser thread count]:n:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_quartz_commands] )) ||
_quartz_commands() {
    local -a commands
    commands=(
        'create:initialize a new Quartz site'
        'update:fetch the latest Quartz updates'
        'restore:restore the content folder from the cache'
        'sync:sync the Quartz repo with GitHub'
        'build:build Quartz into static HTML (optionally --serve / --watch)'
    )
    _describe -t commands 'quartz command' commands
}

_quartz "$@"
