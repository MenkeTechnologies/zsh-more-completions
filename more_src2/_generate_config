#compdef generate_config
# _generate_config — generate Synapse homeserver config (element-hq/synapse)
# upstream: https://github.com/element-hq/synapse
# Flags from synapse/_scripts/generate_config.py (argparse).

_generate_config() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config-dir=[Synapse config directory]:dir:_files -/' \
        '--data-dir=[Synapse data directory]:dir:_files -/' \
        '--server-name=[server name (e.g. example.com)]:name:' \
        '--report-stats=[report anonymous stats]:choice:(yes no)' \
        '--generate-secrets[generate cryptographic secrets]' \
        '(-o --output-file)'{-o+,--output-file=}'[output file]:file:_files -g "*.{yml,yaml}"' \
        '--header-file=[header file prepended to output]:file:_files'
}

_generate_config "$@"
