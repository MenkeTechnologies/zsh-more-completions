#compdef rvn rvnc
# ============================================================================
# _rvn — zsh completion for the Raven programming language toolchain
#         (`rvn` project driver + `rvnc` compiler driver).  Raven is "a
#         modern programming language for .NET, with a Roslyn-inspired
#         compiler architecture" (176th programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/marinasundstrom/raven
#   Maintainer : Marina Sundström
#   License    : MIT
#   Stars      : 93
#   Language   : C# (compiler implemented as a Roslyn-inspired
#                Compiler-as-a-Service architecture on .NET 10
#                / .NET 11)
#   Modules    : Raven  (assembly `rvn`, project driver) +
#                Raven.Compiler  (assembly `rvnc`, compiler
#                driver — both AssemblyName overrides via
#                <AssemblyName>rvn</AssemblyName> /
#                <AssemblyName>rvnc</AssemblyName>)
#   Binaries   : rvn   (project driver — init / build / run /
#                       clean / dev)
#                rvnc  (compiler driver — direct file
#                       compilation with full Raven option
#                       surface)
#   Source ext : .rvn  (Raven source files)
#   Project    : .rvnproj  (MSBuild-style project file)
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Raven is "a modern general-purpose programming language and
#   compiler inspired by the .NET Roslyn architecture".  It is
#   expression-first (`val`/`var`, `match`, `record class`,
#   `Result<T,E>`, `Option<T>`), uses `()` (`unit`) instead of
#   `void`, targets .NET IL directly and interoperates with
#   existing .NET libraries, and exposes a Compiler-as-a-Service
#   immutable, service-oriented compiler API.  The driver split
#   mirrors .NET / Roslyn:  `rvn` is the project-level wrapper
#   that forwards to `dotnet build/run/clean` for `.rvnproj`
#   files, while `rvnc` is the low-level compiler driver that
#   takes raw `.rvn` source files plus the full Raven
#   compilation option surface.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/Raven/Program.cs +
#                       src/Raven.Compiler/Program.cs — Raven
#                       uses hand-rolled Spectre.Console-driven
#                       arg parsers, not commander/cobra)
#
#   rvn — project driver:
#     rvn init [<NAME>]              Scaffold a new Raven
#                                    project
#     rvn build [<PROJECT.rvnproj>] [<dotnet-build-opts>]
#                                    Build a Raven project
#                                    (forwards to dotnet build)
#     rvn run [<PROJECT.rvnproj>] [<dotnet-run-opts>] [--
#       <app-args>]                  Run a Raven project
#                                    (forwards to dotnet run)
#     rvn clean [<PROJECT.rvnproj>]  Clean a Raven project
#                                    (forwards to dotnet clean)
#     rvn dev [<PROJECT.rvnproj>]    Dev-mode watch + rebuild
#     -h, --help                     Show help
#
#   rvnc — compiler driver:
#     rvnc [OPTIONS] <SOURCE.rvn>...
#
#     File / output:
#       -o, --output <PATH>          Output assembly path
#       --framework <TFM>            Target framework (net10.0|
#                                                       net11.0)
#       --refs <PATH>                Additional metadata
#                                    reference (repeatable)
#       --raven-core <PATH>          Prebuilt Raven.Core.dll
#                                    path (skips embedded core
#                                    types)
#       --emit-core-types-only       Embed Raven.Core shims
#                                    instead of referencing
#                                    Raven.Core.dll
#       --output-type <KIND>         Output kind (console |
#                                    classlib)
#
#     Language modes:
#       --unsafe                     Enable unsafe pointer
#                                    declarations
#       --no-global-statements       Disable top-level / global
#                                    statements
#       --no-namespace-members       Disable namespace-scope
#                                    function + const
#                                    declarations
#       --no-namespace-member-imports
#                                    Disable namespace imports
#                                    from [TopLevel] containers
#       --members-public-by-default  Type members default to
#                                    public  (default behavior)
#       --no-members-public-by-default
#                                    Require explicit `public`
#       --runtime-async              Enable runtime-async
#                                    metadata emission
#       --no-runtime-async           Disable runtime-async
#                                    metadata emission
#
#     Compilation:
#       --no-emit                    Skip emitting the output
#                                    assembly
#       --publish                    Emit runtime artifacts
#                                    (.runtimeconfig.json +
#                                     apphost for console apps)
#       --fix                        Apply supported code fixes
#                                    before diagnostics +
#                                    emission
#       --format                     Normalize whitespace and
#                                    indentation in source
#                                    files
#       --run                        Execute the produced
#                                    assembly on success
#                                    (console apps only)
#
#     Diagnostics / introspection:
#       -s, --syntax-tree [flat|group]
#                                    Display the syntax tree
#                                    (single file only)
#       -d, --dump [plain|pretty[:no-diagnostics]]
#                                    Dump syntax (single file
#                                    only)
#       --dump-macros [original|expanded|both][:plain|pretty]
#                                    Dump macro source views
#       -r                           Print the source (single
#                                    file only)
#       -b, --display-binders        Print the binder tree
#       -bt, --bound-tree            Print binder + bound tree
#       -q, --quote                  Print AST as C# compilable
#                                    code
#       --symbols [list|hierarchy]   Inspect produced symbols
#       --doc-tool [ravendoc|comments]
#                                    Documentation generator
#       --doc-format [md|xml]        Documentation format
#       --highlight                  Display diagnostics with
#                                    highlighted source
#       --suggestions                Display instructional
#                                    rewrite suggestions
#       --returned-value-handling <default|full|none|info|warning|error>
#                                    Configure RAV9029 diagnostics
#
#     Help:
#       -h, --help                   Show help
#
# LANGUAGE-CORPUS POSITION
#   Raven is the 176th programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R973 (_substudy / emk Rust=151 OPENS Axis 96 OpenAI /
#   async-openai) and continued through R974 (_codegpt /
#   appleboy Go=151) and R975 (_git-rewrite-commits / f TS-Node=
#   151 CLOSES Axis 96 at 1/1/1 three-language symmetry —
#   triple-151 landmark and 89th axis closed).  Raven joins
#   HydraScript (R972 175th), Lazurite (R968 174th), duck-lang
#   (R964 173rd), Rascal (R960 172nd — R960 round-number commit
#   landmark), Ixion (R956 171st), KernelScript (R952 170th —
#   round-number 170th-language milestone), Prog8 (R948 169th),
#   Objeck (R944 168th), Feral (R940 167th — R940 round-number
#   commit landmark), Biscuit/BL (R936 166th), Rux (R932 165th),
#   Jule (R928 164th), Nevalang (R924 163rd), Corvid (R920
#   162nd — round-number R920 commit landmark), Soppo (R916
#   161st), Cyrus (R912 160th — round-number language
#   milestone), Lumina (R908 159th), Penne (R904 158th),
#   EndBASIC (R900 157th — R900 TRIPLE-9 commit landmark),
#   goboscript (R896 156th), Alan (R892 155th), Mech (R888
#   154th — triple-8 landmark), Lisette (R884 153rd), Bril
#   (R880 152nd), Vyxal (R876 151st), EYG (R872 150th — round-
#   number language milestone), Roto (R868 149th), Pipefish
#   (R864 148th), Mochi (R860 147th), Oden (R856 146th), Hop
#   (R852 145th), Lustre via Kind 2 (R848 144th), Ravi (R844
#   143rd), ZetZ (R840 142nd), Granule (R836 141st), Sixten
#   (R832 140th), Imba (R828 139th), Tao (R824 138th), Dada
#   (R820 137th), Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `rvn` or `rvnc` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_rvn() {
    case "${service:-${words[1]}}" in
        rvnc)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '(-o --output)'{-o,--output}'=[output assembly path]:path:_files' \
                '--framework=[target framework]:tfm:(net10.0 net11.0)' \
                '*--refs=[additional metadata reference]:dll:_files -g "*.dll"' \
                '--raven-core=[prebuilt Raven.Core.dll path]:dll:_files -g "*.dll"' \
                '--emit-core-types-only[embed Raven.Core shims instead of referencing]' \
                '--output-type=[output kind]:kind:(console classlib)' \
                '--unsafe[enable unsafe pointer declarations]' \
                '--no-global-statements[disable top-level statements]' \
                '--no-namespace-members[disable namespace-scope function declarations]' \
                '--no-namespace-member-imports[disable namespace imports from TopLevel]' \
                '--members-public-by-default[type members default to public]' \
                '--no-members-public-by-default[require explicit public]' \
                '--runtime-async[enable runtime-async metadata emission]' \
                '--no-runtime-async[disable runtime-async metadata emission]' \
                '--no-emit[skip emitting the output assembly]' \
                '--publish[emit runtime artifacts (.runtimeconfig.json + apphost)]' \
                '--fix[apply supported code fixes before diagnostics]' \
                '--format[normalize whitespace and indentation]' \
                '--run[execute produced assembly on success]' \
                '(-s --syntax-tree)'{-s,--syntax-tree}'=[display syntax tree]:format:(flat group)' \
                '(-d --dump)'{-d,--dump}'=[dump syntax]:format:(plain pretty pretty\:no-diagnostics)' \
                '--dump-macros=[dump macro source views]:format:(original expanded both)' \
                '-r[print the source (single file only)]' \
                '(-b --display-binders)'{-b,--display-binders}'[print the binder tree]' \
                '(-bt --bound-tree)'{-bt,--bound-tree}'[print binder + bound tree]' \
                '(-q --quote)'{-q,--quote}'[print AST as C# compilable code]' \
                '--symbols=[inspect symbols]:mode:(list hierarchy)' \
                '--doc-tool=[documentation generator]:tool:(ravendoc comments)' \
                '--doc-format=[documentation format]:format:(md xml)' \
                '--highlight[display diagnostics with highlighted source]' \
                '--suggestions[display rewrite suggestions]' \
                '--returned-value-handling=[configure RAV9029 diagnostics]:mode:(default full none info warning error)' \
                '*:Raven source file:_files -g "*.rvn"' ;;
        rvn|*)
            _arguments -C \
                '(- *)'{-h,--help}'[show help]' \
                '1: :_rvn_commands' \
                '*::arg:->args'
            case $state in
                args)
                    case $words[1] in
                        init)
                            _arguments '::project name:' ;;
                        build|run|clean|dev)
                            _arguments \
                                '::Raven project file:_files -g "*.rvnproj"' \
                                '*::forwarded args:' ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

(( $+functions[_rvn_commands] )) ||
_rvn_commands() {
    local -a commands
    commands=(
        'init:scaffold a new Raven project'
        'build:build a Raven project (forwards to dotnet build)'
        'run:run a Raven project (forwards to dotnet run)'
        'clean:clean a Raven project (forwards to dotnet clean)'
        'dev:dev-mode watch + rebuild'
    )
    _describe -t commands 'rvn command' commands
}

_rvn "$@"
