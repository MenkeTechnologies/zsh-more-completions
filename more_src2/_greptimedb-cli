#compdef greptimedb-cli greptime
# _greptimedb-cli — Greptime greptimedb-cli CLI command-line frontend wrapping the GreptimeDB open-source unified time-series database for metrics events logs Rust-based providing standalone datanode frontend metasrv flownode cli wal-import backup restore export import sql region table migrate cluster info shell promql influxdb-line-protocol opentsdb-protocol mqtt prometheus-remote-write-read (Greptime team, Rust); custom argparse
# upstream: https://greptime.com/

_greptimedb-cli() {
    local -a sub=(
        'standalone:run standalone mode'
        'datanode:run datanode'
        'frontend:run frontend'
        'metasrv:run metasrv'
        'flownode:run flownode'
        'cli:run cli operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--log-dir=+[dir]:dir:_files -/' \
        '--http-addr=+[host:port]:_hosts' \
        '--grpc-addr=+[host:port]:_hosts' \
        '--mysql-addr=+[host:port]:_hosts' \
        '--postgres-addr=+[host:port]:_hosts' \
        '--metasrv-addrs=+[host:port]:_hosts' \
        '--node-id=+[id]:n:' \
        '--rpc-addr=+[host:port]:_hosts' \
        '--rpc-hostname=+[host]:_hosts' \
        '--data-home=+[dir]:dir:_files -/' \
        '--wal-dir=+[dir]:dir:_files -/' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--config-file=+[file]:file:_files -g "*.toml"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'greptimedb subcommand' sub ;;
        args)
            case $words[1] in
                cli) _arguments '1:op:(import export attach upgrade migrate bench data backup restore)' '*:arg:' ;;
            esac
            ;;
    esac
}

_greptimedb-cli "$@"
