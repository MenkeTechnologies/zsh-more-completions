#compdef gnina

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--receptor[rigid receptor file]:receptor file:_files' \
  '--flex[flexible side chains file]:flex file:_files' \
  '--ligand[ligand file]:ligand file:_files' \
  '--autobox_ligand[ligand to use for autobox]:autobox ligand file:_files' \
  '--autobox_add[amount of buffer to add to autobox]:buffer size:' \
  '--out[output file]:output file:_files' \
  '--out_flex[output file for flexible residues]:flex output file:_files' \
  '--log[log file]:log file:_files' \
  '--center_x[X coordinate of search box center]:X coordinate:' \
  '--center_y[Y coordinate of search box center]:Y coordinate:' \
  '--center_z[Z coordinate of search box center]:Z coordinate:' \
  '--size_x[size of search box in X dimension]:X size:' \
  '--size_y[size of search box in Y dimension]:Y size:' \
  '--size_z[size of search box in Z dimension]:Z size:' \
  '--cpu[number of CPUs to use]:threads:' \
  '--seed[explicit random seed]:seed:' \
  '--exhaustiveness[exhaustiveness of global search]:exhaustiveness:' \
  '--num_modes[maximum number of binding modes]:num modes:' \
  '--min_rmsd[minimum RMSD between output poses]:min RMSD:' \
  '--energy_range[maximum energy difference between modes]:energy range:' \
  '--cnn_scoring[CNN scoring mode]:cnn scoring:(none rescore refinement metrorescore all)' \
  '--cnn[built-in CNN model to use]:cnn model:' \
  '--cnn_model[custom CNN model file]:model file:_files' \
  '--cnn_weights[custom CNN weights file]:weights file:_files' \
  '--cnn_rotation[CNN pose rotation count]:rotation count:' \
  '--no_gpu[disable GPU acceleration]' \
  '--gpu[enable GPU acceleration]' \
  '--score_only[score only, no docking]' \
  '--local_only[do local search only]' \
  '--minimize[energy minimize ligand]' \
  '--randomize_only[randomize input only]' \
  '--num_mc_saved[number of Monte Carlo poses to save]:num saved:' \
  '--help[show help message]' \
  '--version[show version]' && ret=0

return ret
