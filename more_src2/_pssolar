#compdef pssolar
# Documentation: https://docs.generic-mapping-tools.org/latest/solar.html
# Source: GenericMappingTools/gmt classic-mode pssolar — plot sun terminators (day/night, civil/nautical/astronomical twilight).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C[tab-separated single-line output]' \
    '-G+[terminator fill / enable clipping]:opts:_default' \
    '-I+[current sun position + sunrise/sunset]:opts:_default' \
    '-J+[projection]:proj:_default' \
    '-M[terminator polygons as multisegment table]' \
    '-N[invert clipping (inside vs outside)]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T+[terminator type]:type:(d c n a)' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[terminator pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-bo+[binary output format]:format:_default' \
    '-o+[output column selection]:cols:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    && ret=0

return ret
