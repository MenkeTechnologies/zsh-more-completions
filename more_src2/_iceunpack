#compdef iceunpack
# Documentation: https://manpages.debian.org/testing/fpga-icestorm/icepack.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iceunpack: Project IceStorm bitstream unpacker (.bin -> .asc). Symlink to icepack -u.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose (repeat for more)]' \
  '1:input:_files -g "*.bin"' \
  '2:output:_files -g "*.asc"' && ret=0

return ret
