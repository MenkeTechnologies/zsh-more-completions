#compdef dftb+
# dftb+ — density-functional tight-binding simulation

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbosity[set verbosity level]:level:(0 1 2)' \
  '--hsd-input[specify HSD input file]:file:_files -g "*.hsd"' \
  '--log-level[set log level]:level:(error warning info debug)' \
  '*:input file:_files -g "*.hsd"'
