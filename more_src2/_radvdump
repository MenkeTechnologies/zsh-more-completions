#compdef radvdump
# _radvdump — radvd radvdump (dump received Router Advertisements on the local link in radvd.conf syntax so the output can be re-fed into radvd or analysed; -h help, -V version, -d debug level, -e exit after first RA (one-shot), -f log file)
# upstream: https://github.com/reubenhwk/radvd
# Flags from radvd radvdump.c on tip.

_radvdump() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[debug level]:level:' \
        '-e[exit after first RA]' \
        '-f+[log file]:file:_files'
}

_radvdump "$@"
