#compdef pgloader
# Documentation: https://pgloader.readthedocs.io/en/latest/pgloader.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-E --list-encodings)'{-E,--list-encodings}'[list available encodings]' \
  '(-U --upgrade-config)'{-U,--upgrade-config}'[convert pgloader 2.x config]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '--client-min-messages=[client minimum message level]:level:(debug info notice warning error)' \
  '--log-min-messages=[log minimum message level]:level:(debug info notice warning error)' \
  '(-S --summary)'{-S+,--summary=}'[summary file]:summary file:_files' \
  '(-D --root-dir)'{-D+,--root-dir=}'[root directory]:directory:_files -/' \
  '(-L --logfile)'{-L+,--logfile=}'[log file path]:log file:_files' \
  '(-l --load-lisp-file)*'{-l+,--load-lisp-file=}'[load lisp file]:lisp file:_files' \
  '--dry-run[perform dry run without changes]' \
  '--on-error-stop[stop on first error]' \
  '--no-ssl-cert-verification[disable SSL certificate verification]' \
  '(-C --context)'{-C+,--context=}'[set context variables]:context:' \
  '*--with=[loader option]:option:' \
  '*--set=[PostgreSQL setting]:parameter:' \
  '*--field=[define a field]:field spec:' \
  '*--cast=[cast rule]:cast rule:' \
  '--type=[source type]:type:(csv mysql sqlite postgres ixf db3 mssql copy fixed)' \
  '--encoding=[source encoding]:encoding:' \
  '--before=[SQL file to run before load]:file:_files' \
  '--after=[SQL file to run after load]:file:_files' \
  '--regress[regression testing mode]' \
  '--self-upgrade=[load newer pgloader from directory]:dir:_files -/' \
  '*:command file:_files' && ret=0
return ret
