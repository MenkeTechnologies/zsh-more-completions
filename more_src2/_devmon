#compdef devmon
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--exec-on-drive[command to run on drive insertion]:command' \
  '--exec-on-unmount[command to run on unmount]:command' \
  '--exec-on-remove[command to run on device removal]:command' \
  '--exec-on-change[command to run on device change]:command' \
  '--exec-on-video[command to run on video disc]:command' \
  '--exec-on-audio[command to run on audio disc]:command' \
  '--exec-on-disc[command to run on data disc]:command' \
  '--exec-on-net[command to run on network volume]:command' \
  '--mount-options[mount options to use]:mount options' \
  '--no-mount[do not automount]' \
  '--no-unmount[do not autounmount]' \
  '--no-gui[disable GUI notifications]' \
  '--always-exec[always execute commands]' \
  '--info-on-mount[show info on mount]' \
  '--internal[also handle internal devices]' \
  '--sync[mount with sync option]' \
  '--no-hangup[do not exit on hangup signal]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
