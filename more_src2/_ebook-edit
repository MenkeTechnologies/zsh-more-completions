#compdef ebook-edit
# Documentation: https://manual.calibre-ebook.com/generated/en/ebook-edit.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '--detach[detach from terminal]' \
  '(- *)'{-h,--help}'[show help]' \
  '--select-text=[text to select]:text:' \
  '--version[show version]' \
  '*:ebook:_files'
