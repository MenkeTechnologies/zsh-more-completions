#compdef kfp-viewercontroller viewercontroller
# _kfp-viewercontroller — KFP Viewer (TensorBoard) CRD controller (kubeflow/pipelines)
# upstream: https://github.com/kubeflow/pipelines
# Flags from backend/src/crd/controller/viewer/main.go on tip.

_kfp-viewercontroller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master_url=[apiserver URL]:url:_urls' \
        '--kubecfg=[kubeconfig file]:file:_files' \
        '--max_num_viewers=[max concurrent Viewer resources]:n:' \
        '--namespace=[informer namespace]:ns:' \
        '--client_qps=[Kubernetes client QPS]:f:' \
        '--client_burst=[Kubernetes client burst]:n:'
}

_kfp-viewercontroller "$@"
