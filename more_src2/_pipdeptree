#compdef pipdeptree
# Documentation: https://pipdeptree.readthedocs.io/en/latest/how-to/usage.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--python=[path to python interpreter (use auto to detect active virtualenv)]:python:_files' \
  '(-p --packages)'{-p,--packages}'=[comma-separated list of packages to show]:packages:' \
  '(-e --exclude)'{-e,--exclude}'=[comma-separated list of packages to exclude]:packages:' \
  '--exclude-dependencies[also hide transitive dependencies of excluded packages]' \
  '(-r --reverse)'{-r,--reverse}'[show reverse dependency tree]' \
  '(-o --output)'{-o,--output}'=[output format]:format:(freeze json json-tree mermaid graphviz-png graphviz-svg graphviz-dot graphviz-pdf)' \
  '(-m --metadata)'{-m,--metadata}'=[display metadata fields]:field:' \
  '(-c --computed)'{-c,--computed}'=[show computed info]:info:(size size-raw unique-deps-count unique-deps-names unique-deps-size)' \
  '--license[display license metadata (deprecated)]' \
  '(-d --depth)'{-d,--depth}'=[maximum depth of tree]:depth:' \
  '(-w --warn)'{-w,--warn}'=[warning mode]:mode:(silence suppress fail)' \
  '(-x --extras)'{-x,--extras}'[include optional (extras) dependencies]' && ret=0
return ret
