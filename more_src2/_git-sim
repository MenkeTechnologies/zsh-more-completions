#compdef git-sim
# Documentation: https://github.com/initialcommit-com/git-sim
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-sim (visually simulate git operations)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--animate[generate animated .mp4 video instead of static image]' \
  '--all[display all local branches in log output]' \
  '-n[number of commits to display from each branch head]:count:' \
  '--img-format[image output format]:format:(jpg png)' \
  '--video-format[video output format]:format:(mp4 webm)' \
  '--light-mode[use light color scheme]' \
  '(-r --reverse)'{-r,--reverse}'[display commit history in reverse]' \
  '--speed[animation speed multiplier]:speed:' \
  '--low-quality[render animation in low quality for faster creation]' \
  '--media-dir[path to store output media files]:directory:_files -/' \
  '-d[disable automatic opening of generated file]' \
  '--stdout[write raw image data to stdout]' \
  '--output-only-path[print only the media file path to stdout]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output except errors]' \
  '--color-by[color commits by parameter]:parameter:' \
  '--highlight-commit-messages[make commit messages bigger and bold]' \
  '--show-intro[add custom intro sequence to animation]' \
  '--show-outro[add custom outro sequence to animation]' \
  '--title[custom animation title]:title:' \
  '--logo[path to custom logo]:file:_files' \
  '--outro-top-text[outro top text]:text:' \
  '--outro-bottom-text[outro bottom text]:text:' \
  '--font[font family for rendered text]:font:' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'add:simulate git add'
      'branch:simulate git branch'
      'checkout:simulate git checkout'
      'cherry-pick:simulate git cherry-pick'
      'clean:simulate git clean'
      'clone:simulate git clone'
      'commit:simulate git commit'
      'config:simulate git config'
      'fetch:simulate git fetch'
      'init:simulate git init'
      'log:simulate git log'
      'merge:simulate git merge'
      'mv:simulate git mv'
      'pull:simulate git pull'
      'push:simulate git push'
      'rebase:simulate git rebase'
      'remote:simulate git remote'
      'reset:simulate git reset'
      'restore:simulate git restore'
      'revert:simulate git revert'
      'rm:simulate git rm'
      'stash:simulate git stash'
      'status:simulate git status'
      'switch:simulate git switch'
      'tag:simulate git tag'
    )
    _describe -t commands 'git-sim command' commands && ret=0
    ;;
esac

return ret
