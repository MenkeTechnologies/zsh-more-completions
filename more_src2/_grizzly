#compdef grizzly grr
# _grizzly — Grafana Labs's Grizzly resource-as-code CLI (apply/diff/pull Grafana dashboards, alerts, datasources, etc. from Jsonnet/YAML)
# upstream: https://github.com/grafana/grizzly
# Subcommands + flags from cmd/grr/{workflow,config}.go on tip; global flags are deduplicated onto each leaf.

_grizzly() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'get:fetch a single remote resource by <type>.<uid>'
                'list:list resources (local or with -r remote)'
                'pull:pull remote resources into a local directory'
                'show:render the resources at a path'
                'diff:diff local resources against remote state'
                'apply:push local resources to remote (alias: push)'
                'watch:watch a directory and re-apply on changes'
                'snapshot:create a Grafana snapshot of dashboard(s)'
                'serve:run a local dashboard preview server'
                'export:export remote resources to local files'
                'providers:list registered provider plugins'
                'config:manage grizzly contexts and configuration'
                'selfupdate:update the grr binary in place'
                'completion:emit shell completion'
                'version:show version'
                'help:show help for any subcommand'
            )
            _describe -t commands 'grizzly command' subs
            ;;
        args)
            local -a common=(
                '(-d --directory)'{-d,--directory}'[treat resource path as a directory (deprecated)]'
                '*'{-t+,--target=}'[resources to target (repeatable, comma-separated)]:targets:'
                '*'{-J+,--jpath=}'[Jsonnet library search dir (repeatable)]:dir:_files -/'
                '(-o --output)'{-o+,--output=}'[output format]:fmt:'
                '--disable-reporting[disable anonymous usage stats]'
                '(-s --only-spec)'{-s,--only-spec}'[output only dashboard spec (with --kind)]'
                '(-f --folder)'{-f+,--folder=}'[folder UID for dashboards]:uid:'
                '(-k --kind)'{-k+,--kind=}'[resource Kind (required with --only-spec)]:kind:'
                '(-l --log-level)'{-l+,--log-level=}'[log level]:level:(debug info warning error)'
            )
            case $line[1] in
                list)
                    _arguments \
                        '(-r --remote)'{-r,--remote}'[list remote resources]' \
                        '(-f --format)'{-f+,--format=}'[list output format]:fmt:(default wide json yaml)' \
                        $common
                    ;;
                pull|apply|export)
                    _arguments \
                        '(-e --continue-on-error)'{-e,--continue-on-error}'[do not stop on error]' \
                        $common
                    ;;
                snapshot)
                    _arguments \
                        '(-e --expires)'{-e+,--expires=}'[snapshot expiry seconds (0=never)]:n:' \
                        $common
                    ;;
                serve)
                    _arguments \
                        '(-w --watch)'{-w,--watch}'[watch filesystem for changes]' \
                        '(-b --open-browser)'{-b,--open-browser}'[open the UI in default browser]' \
                        '--listen=[server listen address]:addr:' \
                        '(-p --port)'{-p+,--port=}'[server listen port]:port:' \
                        '(-S --script)'{-S+,--script=}'[script to run on filesystem change]:file:_files' \
                        $common
                    ;;
                watch)
                    _arguments \
                        '(-e --continue-on-error)'{-e,--continue-on-error}'[do not stop on error]' \
                        $common
                    ;;
                config)
                    _arguments '1: :->confCmd'
                    case $state in
                        confCmd)
                            _describe -t commands 'config subcommand' \
                                '(path:show config file path import:import existing config current-context:show current context use-context:switch context get-contexts:list contexts get:show value at path set:set a value unset:unset a value create-context:create a new context check:validate config)'
                            ;;
                    esac
                    ;;
                *)
                    _arguments $common
                    ;;
            esac
            ;;
    esac
}

_grizzly "$@"
