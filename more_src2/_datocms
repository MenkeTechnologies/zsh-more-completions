#compdef datocms
# Documentation: https://www.npmjs.com/package/@datocms/cli
# Reference accessed: 2026-05-23
# Verified: npx @datocms/cli --help.

# Zsh completion for datocms - DatoCMS project CLI

local curcontext="$curcontext" state line ret=1
local -a commands topics

commands=(
  'autocomplete:autocomplete install instructions'
  'help:show command help'
  'link:link directory to a DatoCMS project'
  'login:authenticate via OAuth'
  'logout:remove stored credentials'
  'plugins:list installed plugins'
  'unlink:unlink directory from project'
  'whoami:show authenticated account'
)

topics=(
  'cma:Content Management API'
  'environments:manage sandbox environments'
  'maintenance:maintenance mode controls'
  'migrations:manage migration scripts'
  'plugins:official DatoCMS CLI plugins'
  'projects:discover accessible projects'
  'schema:generate TypeScript schema definitions'
)

_arguments -C   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'datocms command' commands topics && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
