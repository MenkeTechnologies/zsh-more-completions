#compdef mstdn
# ============================================================================
# _mstdn — zsh completion for mattn's mstdn, the reference Go Mastodon
#           CLI shipped inside the github.com/mattn/go-mastodon repo
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/mattn/go-mastodon
#   Author     : Yasuhiro "mattn" Matsumoto
#   License    : MIT
#   Language   : Go
#   Module     : github.com/mattn/go-mastodon  (also hosts the
#                cmd/mstdn nested module github.com/mattn/go-
#                mastodon/cmd/mstdn)
#   Binary     : mstdn  (cmd/mstdn/main.go, urfave/cli/v2 App.Name
#                = "mstdn")
#   Version    : 0.0.1  (App.Version in main.go)
#   Last push  : recent (active library)
#
# WHAT IT IS
#   mstdn is the reference Mastodon CLI bundled with mattn's
#   `github.com/mattn/go-mastodon` Go library — Yasuhiro Matsumoto's
#   typed Mastodon REST API client.  The CLI keeps per-profile auth
#   in `~/.config/mstdn/settings[-<profile>].json` (or
#   `%APPDATA%\mstdn\` on Windows), authenticates against any
#   Mastodon-compatible instance via OAuth2 password grant, and
#   exposes every common API verb — toot, timeline (home / local /
#   public / direct / by hashtag), notification, instance metadata,
#   account info, search, follow / followers, upload, delete, plus
#   a Server-Sent Events streaming consumer.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/mstdn/main.go
#                       urfave/cli/v2 App + Commands array)
#   mstdn [--profile <NAME>] <COMMAND> [args...]
#
#   Global flags:
#     --profile <NAME>          Profile name (selects
#                               settings-<NAME>.json instead of
#                               settings.json)
#
#   Standard urfave/cli auto-flags:
#     -h, --help                Show help
#     -v, --version             Show version
#
#   Subcommands:
#     init                      Initialize a profile (authenticate
#                               and persist credentials)
#
#     toot                      Post a toot (positional args =
#                               toot body, joined with spaces)
#       --ff <FILE>               Read UTF-8 body from file (`-` for
#                                 stdin)
#       --i  <ID>                 In-reply-to status ID
#
#     stream                    Stream statuses (Server-Sent Events)
#       --type <TYPE>             Stream type:
#                                   public / public/local /
#                                   user:<USERNAME> / hashtag:<TAG>
#       --json                    Output full JSON
#       --simplejson              Output simplified JSON
#       --template <TMPL>         Render with a Go text/template
#
#     timeline                  Show home timeline (default)
#     timeline-home             Show home timeline
#     timeline-local            Show local timeline
#     timeline-public           Show public/federated timeline
#     timeline-direct           Show direct-message timeline
#     timeline-tag <TAG>        Show tagged timeline
#       --local                   Local tags only
#
#     notification              Show notifications
#     instance                  Show instance information
#     instance_activity         Show instance activity stats
#     instance_peers            Show instance peers
#     account [USER]            Show account information
#     search <QUERY>            Search content
#     follow <ACCOUNT>          Follow an account
#     followers                 Show followers
#     upload <FILE>             Upload a media file
#     delete <ID>               Delete a status by ID
#     mikami                    Search "mikami"
#     xsearch <QUERY>           Cross-instance search
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/mattn/go-mastodon` declared in
#   cmd/mstdn/go.mod (nested module) — the canonical Go Mastodon
#   client maintained by Yasuhiro Matsumoto.  go-mastodon provides
#   a typed `mastodon.Client` over `mastodon.Config`, every public
#   `/api/v1/*` endpoint (Statuses, Timelines, Accounts, Filters,
#   Lists, Notifications, Search, Streaming, Media, Reports, Push,
#   Conversations, …), and a streaming-event consumer that
#   round-trips Server-Sent Events.  `cmd/mstdn/cmd_*.go` wires
#   each urfave/cli subcommand directly into the corresponding
#   `mastodon.Client` method (`PostStatus`, `GetTimelineHome`,
#   `GetTimelineHashtag`, `StreamingPublic`, `Search`, `UploadMedia`,
#   `Follow`, `DeleteStatus`, etc.).  Verified via:
#     gh api repos/mattn/go-mastodon/contents/cmd/mstdn/main.go
#       → import "github.com/mattn/go-mastodon"
#       → app.Name = "mstdn"
#     gh api repos/mattn/go-mastodon/contents/cmd/mstdn
#       → cmd_toot.go, cmd_stream.go, cmd_timeline.go, cmd_account.go,
#         cmd_search.go, cmd_follow.go, cmd_followers.go,
#         cmd_upload.go, cmd_delete.go, cmd_notification.go,
#         cmd_instance.go, cmd_mikami.go, cmd_xsearch.go
#   This entry is the Go=129 leader bump that continues Axis 74
#   (Mastodon / Fediverse Client Library) opened at R885 with
#   Rust=megalodon 1.0.0 (isfegu/musket).
#
#   No completion for `mstdn` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_mstdn() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--profile=[profile name (selects settings-<name>.json)]:profile:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_mstdn_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                toot)
                    _arguments \
                        '--ff=[read UTF-8 body from file (- for stdin)]:file:_files' \
                        '--i=[in-reply-to status ID]:status id:' \
                        '*: :' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                stream)
                    _arguments \
                        '--type=[stream type]:stream type:(public public/local user: hashtag:)' \
                        '--json[output full JSON]' \
                        '--simplejson[output simplified JSON]' \
                        '--template=[render with Go text/template]:template:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                timeline-tag)
                    _arguments \
                        '--local[local tags only]' \
                        ':tag:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                account|search|follow|delete|upload|xsearch)
                    _arguments \
                        ':argument:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
                *)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mstdn_commands] )) ||
_mstdn_commands() {
    local -a commands
    commands=(
        'init:initialize profile (authenticate and persist credentials)'
        'toot:post a toot'
        'stream:stream statuses (Server-Sent Events)'
        'timeline:show timeline'
        'timeline-home:show home timeline'
        'timeline-local:show local timeline'
        'timeline-public:show public/federated timeline'
        'timeline-direct:show direct-message timeline'
        'timeline-tag:show tagged timeline'
        'notification:show notifications'
        'instance:show instance information'
        'instance_activity:show instance activity stats'
        'instance_peers:show instance peers'
        'account:show account information'
        'search:search content'
        'follow:follow an account'
        'followers:show followers'
        'upload:upload a media file'
        'delete:delete a status by ID'
        'mikami:search "mikami"'
        'xsearch:cross-instance search'
    )
    _describe -t commands 'mstdn command' commands
}

_mstdn "$@"
