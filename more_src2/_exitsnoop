#compdef exitsnoop exitsnoop-bpfcc
# _exitsnoop — trace process termination + exit status (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/exitsnoop.py (argparse).

_exitsnoop() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-t --timestamp)'{-t,--timestamp}'[include timestamp (local time)]'
        '--utc[include timestamp in UTC (implies -t)]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
        '--label=[label each output line]:label:'
        '(-x --failed)'{-x,--failed}'[only trace failed exits (exclude exit(0))]'
        '--per-thread[trace per-thread termination]'
    )
    _arguments $args
}

_exitsnoop "$@"
