#compdef dbui
# Documentation: https://github.com/KenanBek/dbui
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dbui (universal database TUI for MySQL/PostgreSQL/SQLite)

_arguments \
  '-dsn[data source name (connection string)]:dsn' \
  '-type[data source type]:type:(mysql postgresql sqlite)' \
  '-f[path to dbui.yml config]:file:_files -g "*.(yml|yaml)"' \
  '-demo[launch with in-memory demo data sources]' \
  '-h[show help]' \
  '--help[show help]' \
  '-v[show version]' \
  '--version[show version]' && return 0
