#compdef gojq
# Documentation: https://github.com/itchyny/gojq
# Reference accessed: 2026-05-17
# Verified: itchyny/gojq README. Supports most jq flags but explicitly
# unsupports -a/--ascii-output, -S/--sort-keys, --seq, --unbuffered.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -S/--sort-keys (gojq does not support this).

# gojq: pure-Go jq implementation
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-C --color-output)'{-C,--color-output}'[force color output]' \
  '(-M --monochrome-output)'{-M,--monochrome-output}'[disable color output]' \
  '(-r --raw-output)'{-r,--raw-output}'[output raw strings]' \
  '(-R --raw-input)'{-R,--raw-input}'[read raw strings]' \
  '(-s --slurp)'{-s,--slurp}'[read entire input into array]' \
  '(-n --null-input)'{-n,--null-input}'[use null as input]' \
  '(-c --compact-output)'{-c,--compact-output}'[compact output]' \
  '(-j --join-output)'{-j,--join-output}'[no newline after each output]' \
  '(-e --exit-status)'{-e,--exit-status}'[set exit status from output]' \
  '--indent[set indent count]:n:' \
  '--tab[indent with tabs]' \
  '*--arg[set var to string]:name:value' \
  '*--argjson[set var to JSON]:name:json' \
  '*--slurpfile[set var to file contents]:name:file:_files' \
  '*--rawfile[set var to raw file]:name:file:_files' \
  '--jsonargs[remaining args are JSON values]' \
  '--args[remaining args are strings]' \
  '--yaml-input[read YAML]' \
  '--yaml-output[output YAML]' \
  '(-f --from-file)'{-f+,--from-file=}'[read filter from file]:file:_files' \
  '-L[module directory]:dir:_files -/' \
  '*:file:_files' && ret=0
return ret
