#compdef glulx
# Documentation: https://github.com/erkyrath/glulxe
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# glulx: virtual machine for Inform/IF (Glulx interpreter, glulxe upstream)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-undo=[undo buffer size]:n:' \
  '-debug[debug mode]' \
  '-randomize[use real-time RNG]' \
  '*:.ulx file:_files -g "*.(ulx|gblorb)"' && ret=0
return ret
