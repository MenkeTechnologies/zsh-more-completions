#compdef grub-customizer
# Documentation: https://launchpad.net/grub-customizer
# Reference accessed: 2026-05-16
# Verified: Daniel Richter's grub-customizer on Launchpad. Pure Qt GUI
# with only standard Qt options inherited; no documented CLI flags.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# grub-customizer: Qt GUI for GRUB configuration
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-display[X display]:display:' && ret=0
return ret
