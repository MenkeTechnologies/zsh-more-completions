#compdef darce
# Documentation: https://github.com/AmerSarhan/darce-cli
# Reference accessed: 2026-05-22
# Verified: src/entrypoints/cli.tsx argument and subcommand handling.

# Zsh completion for darce - AI coding agent CLI (darce.dev)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-r --resume)'{-r,--resume}'[resume last session in cwd]' \
  '--model[override default model]:model:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'darce command' \
      'login[sign in or create account]' \
      'logout[remove saved credentials]' \
      'upgrade[open Pro checkout]' && ret=0
    ;;
  args)
    case $line[1] in
      login|logout|upgrade) ret=0 ;;
      *) _arguments '*:prompt:' && ret=0 ;;
    esac
    ;;
esac

return ret
