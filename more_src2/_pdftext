#
# pdftext is the operator-facing CLI for the PDF text-extraction +
# editing primitives in tdewolff/canvas.  `pdftext <input.pdf>` does
# the obvious thing — extract text content stream as Unicode strings,
# preserving page boundaries and (with `--info`) document metadata.
# The more interesting subcommand is `pdftext replace --string "new
# text" --index N <input.pdf>` which rewrites a specific text-showing
# operator in the PDF content stream to display different text while
# preserving the font, character spacing, position offset, and
# alignment of the original.  Use cases: anonymize PII in archived
# PDFs, swap product names in marketing material PDFs that lost their
# source files, fix typos in published documents without reflowing
# the page, translate UI screenshots embedded in user-manual PDFs.
# The `-x` / `-y` flags let you nudge the replacement's position
# (positive values move right/down in PDF units), `--offset` adjusts
# the inter-character spacing in font units, and `-a/--alignment
# L|C|R` re-aligns the replacement against the original bounding box.
#
# === AXIS 193 CONTINUES — TrueType / OpenType font parser libraries =======
# Axis position: Go=248 continues Axis 193 (slot 2/0/0).  Canonical Go
# font-parsing-and-shaping library is `github.com/go-text/typesetting`
# by the go-text org (formerly benoitkugler/textlayout) — pure-Go
# HarfBuzz-equivalent text-shaping engine.  The older alternative is
# `golang.org/x/image/font/sfnt` (parser-only, no shaping).  go-text/
# typesetting has won the de-facto canonical slot because modern Go
# text-rendering needs OpenType layout features (ligatures, kerning,
# contextual forms) that the sfnt parser doesn't provide — every
# substantial Go text-rendering project (Gio UI, tdewolff/canvas,
# ajstarks/deck, esimov/diagram) has migrated to go-text/typesetting.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=248     _vl-convert          ← previous round (axis 193 OPENS, 1/0/0)
#   Go=248       ← THIS FILE          (axis 193 continues, slot 2/0/0)
#   TS-Node=248  ← next round         (axis 193 CLOSES at triple-248, 1/1/1)
#
# Cross-language design contrast for axis 193:
#   Rust    : ttf-parser (RazrFalcon) — PARSER ONLY, zero-allocation,
#             SAFE no_std-compatible.  Shaping is a separate lib
#             (rustybuzz, the Rust port of HarfBuzz) — strict
#             parser/shaper separation.
#   Go      : go-text/typesetting — PARSER + SHAPER in one umbrella.
#             Sub-packages opentype/loader (parser) and shaping
#             (shaper) ship as one go-mod-versioned project.  Modern
#             alternative to the parser-only golang.org/x/image/font/
#             sfnt.  Bundles HarfBuzz-equivalent shaping.
#   JS/Node : [TBD next round]  Likely opentype.js (parser-only, by
#             Frederik De Bleser) or fontkit (parser + basic
#             shaping by foliojs, same author as pdfkit).
# ---------------------------------------------------------------------------

_pdftext() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show CLI help]' \
        '--password=[PDF password (for encrypted files)]:password:' \
        '(-p --page)'{-p,--page}'=[page number to operate on (default 0)]:page:' \
        '--info[print document metadata (page count / encrypted status / Producer / CreationDate) instead of extracting text]' \
        '1: :->cmds_or_input' \
        '*::arg:->args' && ret=0

    case $state in
        cmds_or_input)
            # Top-level: either `pdftext replace <input>` or `pdftext <input>`
            local -a subcmds
            subcmds=(
                'replace:replace a specific text-showing operator in the PDF content stream while preserving font + spacing + position + alignment of the original'
            )
            _describe -t commands 'pdftext subcommand' subcmds
            _files -g "*.(pdf|PDF)" && ret=0
            ;;
        args)
            case $words[1] in
                replace)
                    _arguments \
                        '--password=[PDF password (for encrypted files)]:password:' \
                        '(-p --page)'{-p,--page}'=[page number to operate on (default 0)]:page:' \
                        '--xobj=[select XObject inside the page if the text is in a form-XObject]:xobject:' \
                        '--info=[update document info instead of string content (one of: Producer, CreationDate)]:field:(Producer CreationDate)' \
                        '(-i --index)'{-i,--index}'=[string index to replace (-1 means use --string content match; default -1)]:index:' \
                        '(-s --string)'{-s,--string}'=[text replacement string]:text:' \
                        '-x=[horizontal position offset in PDF units (positive = right)]:offset:' \
                        '-y=[vertical position offset in PDF units (positive = down)]:offset:' \
                        '--offset=[text X-offset in font units (inter-character spacing nudge)]:units:' \
                        '(-a --alignment)'{-a,--alignment}'=[text alignment within the original bounding box]:alignment:(L C R)' \
                        '--spacing=[character spacing type; `none` for regular spacing or a number for explicit character spacing]:type:(none)' \
                        '--copy[copy the text element (insert new without removing original)]' \
                        '(-o --output)'{-o,--output}'=[output PDF file path (default: overwrite input)]:file:_files -g "*.(pdf|PDF)"' \
                        '1:input PDF file:_files -g "*.(pdf|PDF)"' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_pdftext "$@"
