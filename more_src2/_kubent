#compdef kubent
# Documentation: https://github.com/doitintl/kube-no-trouble
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_kubent() {
  _arguments \
    '(-h --help)'{-h,--help}'[Show help]' \
    '(-v --version)'{-v,--version}'[Print version and exit]' \
    '(-A --additional-annotation)'{-A,--additional-annotation}'[additional annotations to check for last applied config]:annotation' \
    '(-a --additional-kind)'{-a,--additional-kind}'[additional kinds of resources to report in Kind.version.group.com format]:kind' \
    '(-c --cluster)'{-c,--cluster}'[Enable Cluster collector]' \
    '(-x --context)'{-x,--context}'[kubeconfig context]:context' \
    '(-e --exit-error)'{-e,--exit-error}'[Exit with non-zero code when issues are found]' \
    '(-f --filename)'{-f,--filename}'[manifests to check, use - for stdin]:file:_files' \
    '--helm3[Enable Helm v3 collector]' \
    '(-k --kubeconfig)'{-k,--kubeconfig}'[path to the kubeconfig file]:file:_files' \
    '(-l --log-level)'{-l,--log-level}'[set log level]:level:(trace debug info warn error fatal panic disabled)' \
    '(-o --output)'{-o,--output}'[output format]:format:(text json csv)' \
    '(-O --output-file)'{-O,--output-file}'[output destination]:file:_files' \
    '(-t --target-version)'{-t,--target-version}'[target Kubernetes version in SemVer format]:version'
}

_kubent "$@"
