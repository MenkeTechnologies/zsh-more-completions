#compdef magick-script
# Documentation: https://imagemagick.org/script/magick-script.php
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

(( $+functions[_magick] )) || autoload -Uz _magick 2>/dev/null
if (( $+functions[_magick] )); then
  _magick "$@"
  return
fi

_arguments \
  '-script[script file follows]:script:_files' \
  '*:image file:_files' && ret=0

return ret
