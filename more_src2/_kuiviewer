#compdef kuiviewer
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/kuiviewer.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for KUIViewer - a viewer for Qt Designer .ui files.
# Flags from the upstream man page; -h is overloaded with --screenshotheight
# (Qt's --help-all/-help still work; we keep --help long-form here).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options including Qt/KF]' \
  '(- *)--author[show author info]' \
  '(- *)--license[show license info]' \
  '(- *)--version[show version]' \
  '(-s --takescreenshot)'{-s+,--takescreenshot=}'[take a screenshot of the interface and exit]:filename:_files' \
  '(-w --screenshotwidth)'{-w+,--screenshotwidth=}'[interface width before screenshot]:width:' \
  '--screenshotheight=[interface height before screenshot]:height:' \
  '*:file:_files -g "*.ui"' && ret=0

return ret
