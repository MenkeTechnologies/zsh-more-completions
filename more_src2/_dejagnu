#compdef dejagnu
# Documentation: https://www.gnu.org/software/dejagnu/manual/Invoking-dejagnu.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help for dejagnu subcommands'
  'report-card:produce a report card'
  'runtest:run dejagnu test suite'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'dejagnu command' commands && ret=0 ;;
esac

return ret
