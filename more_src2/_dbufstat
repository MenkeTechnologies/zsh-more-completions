#compdef dbufstat
# _dbufstat — OpenZFS dbufstat (per-dbuf cache snapshot; -b raw fields, -d ARC types histogram, -n nice no-color, -t total only, -F field filter, -i interval (continuous mode), -p parsable, -r raw bytes, -x extended fields)
# upstream: https://github.com/openzfs/zfs (cmd/dbufstat)
# Flags from openzfs cmd/dbufstat on tip.

_dbufstat() {
    _arguments \
        '-h[show help]' \
        '-b[only buffer header counters]' \
        '-d[dump per-arc-type histograms]' \
        '-F+[field filter]:field:' \
        '-i+[interval seconds]:seconds:' \
        '-n[no color]' \
        '-p[parsable output]' \
        '-r[raw output]' \
        '-t[total only]' \
        '-x[extended fields]' \
        '-s+[sort field]:field:'
}

_dbufstat "$@"
