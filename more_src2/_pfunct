#compdef pfunct
# ============================================================================
#  _pfunct — pfunct: Linux kernel DWARF function-info extraction tool
#            (part of acmel/dwarves toolkit)
#
#  Source-direct extraction from
#    https://github.com/acmel/dwarves/blob/master/pfunct.c
#    https://www.gnu.org/software/libc/manual/html_node/Argp.html
#    (GNU libc argp(3) manual)
#
#  Maintained by Arnaldo Carvalho de Melo (acmel/dwarves), Linux
#  kernel ecosystem maintainer (also maintains perf, the Linux kernel
#  performance counter tool).  Part of the **dwarves** suite of
#  DWARF/CTF/BTF debug-info utilities used by Linux kernel developers
#  for type introspection, BPF type information generation, and
#  function signature analysis.  Sister tools: **pahole** (IN CORPUS
#  via _pahole — DWARF/BTF struct layout analyzer, also from dwarves
#  suite), **pglobal**, **pdwtags**, **ostra**, **codiff**, **prefcnt**
#  (all dwarves siblings).  pfunct extracts function prototypes,
#  signature lists, inline statistics, parameter counts, goto labels,
#  and variable counts from DWARF debug info in ELF binaries — used
#  by kernel devs analyzing function complexity, validating BPF type
#  information, and generating compilable C declarations from
#  pre-compiled binaries.
#
#  CLI library taxonomy update: 2nd C CLI library — **GNU argp**
#  (glibc's `<argp.h>`).  C ecosystem now has 2 documented CLI
#  libraries (R272 POSIX getopt + R382 GNU argp).
#
#  GNU argp is glibc's HIGHER-LEVEL CLI parsing library (versus POSIX
#  getopt R272) — provides AUTO-GENERATED --help and --usage and
#  --version output, GROUP-BASED option organization, NESTED parsers
#  (children parsers), per-parse-state custom data, and a
#  STRUCTURED PARSER FUNCTION callback model.  Ships with glibc (so
#  GNU/Linux systems by default; macOS/BSD needs `argp-standalone`
#  package).  Used by many GNU and Linux ecosystem tools: pfunct,
#  pahole (dwarves suite), GNU tar, GNU coreutils-some, GNU
#  inetutils, parted, ddrescue, gnubg, iucode-tool, F3 (Fight Flash
#  Fraud), crun (OCI container runtime, Red Hat), elfutils,
#  rmlint, hurd userland (translators), and most GNU project tools
#  that want richer parsing than POSIX getopt without resorting to
#  C++ libraries.
#
#  GNU argp API:
#    #include <argp.h>
#
#    const char *argp_program_version = "mytool 1.0";
#    const char *argp_program_bug_address = "<bug@example.com>";
#    static char args_doc[] = "FILE...";
#    static char doc[] = "mytool - do useful things.";
#
#    static struct argp_option options[] = {
#      { "verbose",     'v',  0,        0,
#        "Produce verbose output", 0 },
#      { "output",      'o', "FILE",    0,
#        "Output file (default: stdout)", 0 },
#      { "config",      'c', "FILE",    OPTION_ARG_OPTIONAL,
#        "Config file (default: /etc/foo.conf)", 0 },
#      { "level",       'l', "LEVEL",   0,
#        "Verbosity level (1-9)", 1 },  /* group=1 */
#      { 0 }  /* sentinel */
#    };
#
#    struct arguments {
#      int verbose;
#      char *output;
#      char *config;
#      int level;
#      char **input_files;
#    };
#
#    static error_t parse_opt(int key, char *arg, struct argp_state *state) {
#      struct arguments *args = state->input;
#      switch (key) {
#      case 'v': args->verbose = 1; break;
#      case 'o': args->output = arg; break;
#      case 'c': args->config = arg ?: "/etc/foo.conf"; break;
#      case 'l': args->level = atoi(arg); break;
#      case ARGP_KEY_ARG:
#        /* handle non-option positional */
#        break;
#      case ARGP_KEY_END:
#        /* end of input */
#        break;
#      default:
#        return ARGP_ERR_UNKNOWN;
#      }
#      return 0;
#    }
#
#    static struct argp argp = { options, parse_opt, args_doc, doc };
#
#    int main(int argc, char **argv) {
#      struct arguments args = {0};
#      argp_parse(&argp, argc, argv, 0, NULL, &args);
#      /* use args.verbose, args.output, ... */
#      return 0;
#    }
#
#  GNU argp distinctive features:
#    - HEADER `#include <argp.h>` — ships with glibc on Linux systems
#      (and via `argp-standalone` portable package on macOS/BSD)
#    - DECLARATIVE `struct argp_option` ARRAY — each option is a
#      struct literal: `{ .name = "long-name", .key = 'c', .arg =
#      "ARG", .flags = OPTION_X, .doc = "...", .group = N }`
#    - SHORT KEY via `.key = 'c'` C CHAR LITERAL — single character;
#      also `KEY_ARG`/`KEY_END`/named constants like `ARGP_KEY_ARG`
#      for special pseudo-keys
#    - LONG NAME via `.name = "long-name"` C string (no leading
#      dashes; argp adds `--` at parse time)
#    - VALUE PLACEHOLDER via `.arg = "ARG"` — non-NULL means option
#      takes a value; NULL means boolean flag
#    - FLAGS via `.flags`: `OPTION_ARG_OPTIONAL` (value-optional like
#      `-o` vs `-o file`), `OPTION_ALIAS` (this entry is an alias of
#      previous), `OPTION_HIDDEN` (exclude from --help), `OPTION_NO_USAGE`,
#      `OPTION_DOC` (this entry is just doc text)
#    - GROUP via `.group = N` — integer group ID for ordering and
#      sectioning in --help output
#    - DOC via `.doc = "..."` — per-option help text
#    - SENTINEL `{0}` or `{ .name = NULL }` at end of options array
#    - PARSER FUNCTION `error_t parser(int key, char *arg, struct
#      argp_state *state)` — switch-on-key callback handling each
#      parsed option; returns `0` on success, `ARGP_ERR_UNKNOWN` for
#      "not my key" propagation
#    - SPECIAL KEYS: `ARGP_KEY_ARG` (positional), `ARGP_KEY_ARGS`,
#      `ARGP_KEY_END` (end of args), `ARGP_KEY_NO_ARGS`, `ARGP_KEY_INIT`,
#      `ARGP_KEY_FINI`, `ARGP_KEY_SUCCESS`, `ARGP_KEY_ERROR`
#    - `struct argp argp = { options, parser, args_doc, doc, children,
#      help_filter, argp_domain }` — TOP-LEVEL PARSER STRUCT bundling
#      options + parser callback + positional doc string + doc text +
#      nested children parsers + i18n domain
#    - NESTED `children` PARSERS — array of `struct argp_child` with
#      per-child `argp` pointer, flags, header, group — for composing
#      independent option sets (e.g. libfoo provides its own argp,
#      caller embeds via children)
#    - `argp_parse(&argp, argc, argv, flags, &arg_index, &input)` —
#      MAIN PARSE FUNCTION; flags include `ARGP_PARSE_ARGV0`,
#      `ARGP_NO_ERRS`, `ARGP_NO_HELP`, `ARGP_LONG_ONLY`, `ARGP_SILENT`,
#      `ARGP_IN_ORDER`, `ARGP_NO_EXIT`
#    - GLOBAL `argp_program_version` (const char *) — sets --version
#      string
#    - GLOBAL `argp_program_bug_address` (const char *) — bug address
#      shown in --help footer
#    - GLOBAL `argp_program_version_hook` — function pointer for
#      dynamic version (e.g. include git hash)
#    - AUTO-GENERATED `--help`, `--usage`, `-?`, `-V`, `--version`
#      flags (suppressible via parse flags)
#    - AUTO-GENERATED multi-column terminal-width-aware help output
#      with grouping, indentation, line wrapping
#    - `argp_help(&argp, stream, flags, program_name)` — manual help
#      generation function (flags: `ARGP_HELP_SEE`/`ARGP_HELP_USAGE`/
#      `ARGP_HELP_LONG`/`ARGP_HELP_STD_USAGE`/`ARGP_HELP_STD_HELP`)
#    - `argp_usage(&state)` — print usage from parser callback
#    - `argp_error(&state, format, ...)` — formatted error from parser
#    - `argp_failure(&state, status, errnum, format, ...)` — fail
#      with exit status
#    - PROCESS EXIT model — argp calls `exit(EX_USAGE)` on parse
#      errors UNLESS `ARGP_NO_EXIT` flag set
#  Distinct from R272 C POSIX getopt (LOW-LEVEL char-by-char `getopt(argc,
#  argv, "ho:v")` with single-letter opts; `getopt_long(argc, argv,
#  shortopts, longopts, &index)` with `struct option longopts[]`;
#  NO auto-help generation; NO grouping; NO nested parsers; just
#  manual cursor-based iteration), R270 Haskell optparse-applicative
#  (functional applicative combinator in different language), R277
#  Java picocli (annotations + auto-color help), R275 Rust clap-derive
#  (struct + macros), R373 Haskell base stdlib System.Console.GetOpt
#  (closest analog — also list-of-records design with `OptDescr a`
#  containing short chars + long names + arg descriptor + help, but
#  Haskell pure-functional vs GNU argp's C imperative callbacks).
#  GNU argp's approach: C HEADER `<argp.h>` from glibc + DECLARATIVE
#  `struct argp_option` ARRAY with .key/.name/.arg/.flags/.doc/.group
#  + PARSER CALLBACK `error_t parser(int key, char *arg, struct
#  argp_state *state)` SWITCH-ON-KEY + SPECIAL KEYS (`ARGP_KEY_ARG`/
#  `KEY_END`/`KEY_INIT`/`KEY_FINI`/`KEY_SUCCESS`/`KEY_ERROR`) for
#  positional + lifecycle hooks + NESTED CHILDREN PARSERS via `struct
#  argp_child[]` for compositional CLI design + AUTO-GENERATED
#  `--help`/`--usage`/`--version` + GROUP-BASED help sectioning via
#  `.group = N` + GLOBAL `argp_program_version` + `argp_program_bug_address`
#  — corpus's **first documented GNU-glibc-argp-with-parser-callback-
#  and-children-parsers C CLI library**.  Brings cross-language CLI
#  library taxonomy variant count to 121; C ecosystem now has 2
#  documented CLI libraries.
#
#  Surface (verbatim from `pfunct.c` `pfunct__options[]` array):
#
#  Options:
#    -a, --addr=ADDR              Show just function at ADDR
#    -A, --all                    Show all functions matching filter,
#                                 or all prototypes if no filter
#    -b, --expand_types           Expand types needed by prototype
#    -c, --class=CLASS            Functions with CLASS pointer params
#    -E, --externals              Show just external functions
#    -f, --function=FUNCTION      Show just FUNCTION
#    -F, --format_path=FORMAT_LIST List of debugging formats to try
#    -g, --goto_labels            Show number of goto labels
#    -G, --cc_uninlined           Declared inline, uninlined by compiler
#    -H, --cc_inlined             Not declared inline, inlined by compiler
#    -i, --inline_expansions      Show inline expansions
#    -I, --inline_expansions_stats Show inline expansion stats
#    -l, --decl_info              Show source code info
#    -t, --total_inline_stats     Multi-CU total inline expansion stats
#    -s, --sizes                  Show size of functions
#    -N, --function_name_len      Show size of function names
#    -p, --nr_parms               Show number of parameters
#    -P, --prototypes             Show function prototypes
#    -S, --nr_variables           Show number of variables
#    -T, --variables              Show variables
#    -V, --verbose                Be verbose
#        --symtab[=NAME]          Show symbol table NAME
#                                 (OPTION_ARG_OPTIONAL; default .symtab)
#        --compile[=FUNCTION]     Generate compilable source code with
#                                 types expanded (OPTION_ARG_OPTIONAL;
#                                 default all functions)
#        --no_parm_names          Don't show parameter names
#
#  Auto-generated by GNU argp:
#    -?, --help                   Show help
#        --usage                  Show short usage
#        --version                Show version
#
#  Positional:
#    FILE...                      ELF binary files (with DWARF debug info)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also GNU argp users):
#    - pahole (IN CORPUS via _pahole — DWARF struct layout analyzer
#      from dwarves suite; same author Arnaldo Carvalho de Melo; uses
#      argp too)
#    - crun (IN CORPUS via _crun — OCI container runtime by Red Hat;
#      uses argp)
#    - f3 / f3read / f3write / f3probe / f3fix / f3brew (IN CORPUS —
#      Fight Flash Fraud suite by AltraMayor; uses argp)
#    - iucode-tool (IN CORPUS — Intel microcode tool; uses argp)
#    - parted / ddrescue / gnubg (IN CORPUS — GNU tools using argp)
#    - opal-toolset (CRoCS MUNI — Self-Encrypting Drive utilities,
#      smaller community)
#    - pi-sniffer (IanMercer/pi-sniffer 75 stars — BLE/WiFi scanner
#      for Raspberry Pi)
#    - vumz (26 stars — ncurses VU meter with pipewire)
#    - trdb (pulp-platform/trdb 16 stars — RISC-V Processor Tracing)
#    - serperf / udp-reverse-tunnel / goterm (smaller community)
# ============================================================================

_pfunct() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-a --addr)'{-a,--addr}'=[show function at ADDR]:addr' \
    '(-A --all)'{-A,--all}'[show all functions or prototypes]' \
    '(-b --expand_types)'{-b,--expand_types}'[expand types needed by prototype]' \
    '(-c --class)'{-c,--class}'=[functions with CLASS pointer params]:class' \
    '(-E --externals)'{-E,--externals}'[show just external functions]' \
    '(-f --function)'{-f,--function}'=[show just FUNCTION]:function' \
    '(-F --format_path)'{-F,--format_path}'=[debugging format list]:formats' \
    '(-g --goto_labels)'{-g,--goto_labels}'[show number of goto labels]' \
    '(-G --cc_uninlined)'{-G,--cc_uninlined}'[declared inline, uninlined by compiler]' \
    '(-H --cc_inlined)'{-H,--cc_inlined}'[not declared inline, inlined by compiler]' \
    '(-i --inline_expansions)'{-i,--inline_expansions}'[show inline expansions]' \
    '(-I --inline_expansions_stats)'{-I,--inline_expansions_stats}'[show inline expansion stats]' \
    '(-l --decl_info)'{-l,--decl_info}'[show source code info]' \
    '(-t --total_inline_stats)'{-t,--total_inline_stats}'[multi-CU total inline expansion stats]' \
    '(-s --sizes)'{-s,--sizes}'[show size of functions]' \
    '(-N --function_name_len)'{-N,--function_name_len}'[show size of function names]' \
    '(-p --nr_parms)'{-p,--nr_parms}'[show number of parameters]' \
    '(-P --prototypes)'{-P,--prototypes}'[show function prototypes]' \
    '(-S --nr_variables)'{-S,--nr_variables}'[show number of variables]' \
    '(-T --variables)'{-T,--variables}'[show variables]' \
    '(-V --verbose)'{-V,--verbose}'[be verbose]' \
    '--symtab=-[show symbol table (default .symtab)]::name' \
    '--compile=-[generate compilable source code]::function' \
    '--no_parm_names[do not show parameter names]' \
    '(-\? --help)'{-\?,--help}'[show help]' \
    '--usage[show short usage]' \
    '--version[show version]' \
    '*:ELF binary file:_files'
}

_pfunct "$@"
