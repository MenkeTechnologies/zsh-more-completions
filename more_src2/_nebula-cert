#compdef nebula-cert
# Documentation: https://github.com/slackhq/nebula
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nebula-cert - certificate manager for Slack's nebula overlay network.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,-help}'[print help]' \
  '(- *)-version[print version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'ca:create a self-signed certificate authority'
      'keygen:create a public/private key pair'
      'sign:create and sign a certificate'
      'print:print details about a certificate'
      'verify:verify a certificate against a CA'
    )
    _describe -t commands 'nebula-cert command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (ca)
        _arguments -s -S \
          '-name=[CA name (required)]:name' \
          '-version=[certificate format version]:version:(1 2)' \
          '-duration=[validity duration (e.g. 8760h)]:duration' \
          '-groups=[comma-separated groups]:groups' \
          '-networks=[comma-separated CIDR networks]:networks' \
          '-unsafe-networks=[comma-separated unsafe networks]:networks' \
          '-out-key=[output key file]:file:_files' \
          '-out-crt=[output certificate file]:file:_files' \
          '-out-qr=[output QR code PNG]:file:_files' \
          '-curve=[ECDSA curve]:curve:(25519 P256)' \
          '-encrypt[encrypt the private key with a passphrase]' \
          '-argon-memory=[Argon2 memory in KiB]:kib' \
          '-argon-parallelism=[Argon2 parallelism]:n' \
          '-argon-iterations=[Argon2 iterations]:n' \
          '-pkcs11=[PKCS#11 URL for hardware token]:url' && ret=0
        ;;
      (sign)
        _arguments -s -S \
          '-name=[certificate name (typically hostname)]:name' \
          '-version=[certificate format version]:version:(1 2)' \
          '-networks=[comma-separated IP/CIDR networks]:networks' \
          '-unsafe-networks=[networks this cert can route for]:networks' \
          '-duration=[validity duration]:duration' \
          '-groups=[comma-separated groups]:groups' \
          '-ca-key=[path to signing CA key]:file:_files' \
          '-ca-crt=[path to signing CA certificate]:file:_files' \
          '-in-pub=[path to previously generated public key]:file:_files' \
          '-out-key=[output key file]:file:_files' \
          '-out-crt=[output certificate file]:file:_files' \
          '-out-qr=[output QR code PNG]:file:_files' \
          '-pkcs11=[PKCS#11 URL for hardware token]:url' && ret=0
        ;;
      (print)
        _arguments -s -S \
          '-json[output certificate in JSON format]' \
          '-out-qr=[output QR code PNG]:file:_files' \
          '-path=[path to the certificate (required)]:file:_files' && ret=0
        ;;
      (verify)
        _arguments -s -S \
          '-ca=[path to file with one or more CA certs]:file:_files' \
          '-crt=[path to certificate to verify]:file:_files' && ret=0
        ;;
      (keygen)
        _arguments -s -S \
          '-out-key=[output private key file]:file:_files' \
          '-out-pub=[output public key file]:file:_files' \
          '-curve=[ECDH curve]:curve:(25519 P256)' \
          '-pkcs11=[PKCS#11 URL for hardware token]:url' && ret=0
        ;;
    esac
    ;;
esac

return ret
