#compdef rex
# Documentation: https://www.mankier.com/1/rex
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rex (Rexify) - Perl automation/deployment framework.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[show help]' \
  '-b[run batch]:batch:' \
  '-e[run code fragment]:code:' \
  '-E[execute on given environment]:env:' \
  '(-G -g)'{-G,-g}'[execute on server groups]:groups:' \
  '-H[execute on hosts (space-delimited)]:hosts:_hosts' \
  '-z[execute on hosts from command output]:command:' \
  '-K[SSH public key file]:file:_files' \
  '-P[SSH private key file]:file:_files' \
  '-p[SSH password]:password:' \
  '-u[SSH username]:user:_users' \
  '-d[show debug output]' \
  '-ddd[show more debug output (with profiling)]' \
  '-m[monochrome output: no colors]' \
  '-o[output format]:format:' \
  '-q[quiet mode: no log output]' \
  '-qw[quiet: only warnings and errors]' \
  '-Q[really quiet: output nothing]' \
  '-T[list tasks]' \
  '-Ta[list all tasks including hidden]' \
  '-Tm[list tasks in machine-readable format]' \
  '-Tv[list tasks verbosely]' \
  '-Ty[list tasks in YAML format]' \
  '-c[turn cache on]' \
  '-C[turn cache off]' \
  '-f[use this file instead of Rexfile]:file:_files' \
  '-F[force: disregard lock file]' \
  '*:task:' && ret=0

return ret
