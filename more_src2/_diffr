#compdef diffr
# Documentation: https://github.com/mookid/diffr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--line-numbers[Annotate output with left line numbers]' \
  '--tabular[Use tabular renderer instead of unified]' \
  '--colors=[Color policy]:policy:(none one-sided two-sided)' \
  '(-h --help)'{-h,--help}'[Show help]' \
  '(-V --version)'{-V,--version}'[Show version]' \
  '1:first file to compare:_files' \
  '2:second file to compare:_files'
