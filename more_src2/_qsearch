#compdef qsearch
# Documentation: https://github.com/gentoo/portage-utils
# Source: gentoo/portage-utils qsearch.c — search the Gentoo cache for packages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a --all)'{-a,--all}'[list descriptions of every package in cache]' \
    '(-s --search)'{-s,--search}'[regex search package basenames]' \
    '(-S --desc)'{-S,--desc}'[regex search descriptions (or homepage with -H)]' \
    '(-N --name-only)'{-N,--name-only}'[only show package name]' \
    '(-H --homepage)'{-H,--homepage}'[show homepage info instead of description]' \
    '(-R --repo)'{-R,--repo}'[show repository]' \
    '(-F --format)'{-F+,--format=}'[output format string]:fmt:_default' \
    '*:package or pattern:_default' \
    && ret=0

return ret
