#compdef pulldown-cmark
# Documentation: https://github.com/raphlinus/pulldown-cmark
# Reference accessed: 2026-05-20
# Verified: upstream pulldown-cmark/src/main.rs opts.optflag definitions.

# pulldown-cmark: CommonMark/markdown to HTML CLI
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-h[show help]' \
  '--help[show help]' \
  '-d[dry-run; do not write output]' \
  '-e[dump events instead of rendering HTML]' \
  '-T[enable tables extension]' \
  '-m[enable math extension]' \
  '-F[enable footnotes extension]' \
  '-f[enable old-style footnotes extension]' \
  '-S[enable strikethrough extension]' \
  '-U[enable superscript extension]' \
  '-B[enable subscript extension]' \
  '-L[enable task lists extension]' \
  '-P[enable smart punctuation]' \
  '-H[enable heading attributes]' \
  '-M[enable metadata blocks]' \
  '-R[reject broken links]' \
  '-G[enable GitHub-flavored markdown bundle]' \
  '-D[enable definition list extension]' \
  '-W[enable wikilinks extension]' \
  '-C[enable container extensions]' \
  '*:file:_files -g "*.(md|markdown)"' && ret=0

return ret
