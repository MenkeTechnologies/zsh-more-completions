#compdef pamtable
# Documentation: man pamtable (Netpbm)
# Source: print a tab-separated table of pixel sample values from a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-tuple[output a single tuple per row]' \
    '-hex[hexadecimal sample values]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
