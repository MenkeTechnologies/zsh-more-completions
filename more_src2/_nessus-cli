#compdef nessus-cli nessuscli
# _nessus-cli — Tenable Nessus nessuscli CLI command-line frontend to Nessus Professional Nessus Expert Tenable.io vulnerability assessment platform providing scanner-fix scanner-update scanner-restart user manage policies templates settings fetch-plugins update-plugins scans add-target import-export configuration agent-management (Tenable team, C); custom argparse
# upstream: https://www.tenable.com/

_nessus-cli() {
    local -a sub=(
        'fix:fix scanner state'
        'fetch:fetch plugins'
        'update:update scanner plugins'
        'scanner:scanner management'
        'agent:agent management'
        'user:user management'
        'policy:policy management'
        'scan:scan management'
        'import:import config'
        'export:export config'
        'reload:reload scanner'
        'restart:restart scanner'
        'service:service management'
        'systeminfo:show system info'
        'logs:show logs'
        'support:gather support data'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--secure[secure connection]' \
        '--plugin-set=+[set]:str:' \
        '--all[all scans]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nessus-cli subcommand' sub ;;
        args)
            case $words[1] in
                user) _arguments '1:op:(add delete list edit lock unlock)' '*:username:_users' ;;
                fix) _arguments '1:op:(reset secure-settings preferences scanners reset-engine reset-all)' ;;
                agent) _arguments '1:op:(group-create group-delete group-list link unlink list status)' ;;
                scan|policy) _arguments '1:op:(list show launch stop pause resume import export)' '*:id:' ;;
            esac
            ;;
    esac
}

_nessus-cli "$@"
