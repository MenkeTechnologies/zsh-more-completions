#compdef futurerestore
# _futurerestore — restore iOS to firmware versions with prior signing (tihmstar/futurerestore)
# upstream: https://github.com/tihmstar/futurerestore
# Flags from futurerestore/main.cpp.

_futurerestore() {
    local -a args
    args=(
        '(-t --apticket)'{-t+,--apticket=}'[signing tickets used for restoring (.shsh / .shsh2)]:file:_files'
        '(-u --update)'{-u,--update}'[update instead of erase (requires matching APTicket)]'
        '(-w --wait)'{-w,--wait}'[keep rebooting until ApNonce matches APTicket]'
        '(-e --exit-recovery)'{-e,--exit-recovery}'[exit recovery mode and quit]'
        '--use-pwndfu[restore via Odysseus method (device already in pwned DFU)]'
        '--just-boot=[tethered boot from pwned DFU mode; optional boot-args]:boot args:'
        '--latest-sep[use the latest signed SEP instead of --sep]'
        '(-s --sep)'{-s+,--sep=}'[SEP image to flash]:file:_files'
        '(-m --sep-manifest)'{-m+,--sep-manifest=}'[BuildManifest for requesting the SEP ticket]:file:_files -g "*.plist"'
        '--latest-baseband[use the latest signed baseband]'
        '(-b --baseband)'{-b+,--baseband=}'[baseband to flash]:file:_files'
        '(-p --baseband-manifest)'{-p+,--baseband-manifest=}'[BuildManifest for requesting the baseband ticket]:file:_files -g "*.plist"'
        '--no-baseband[skip checks and do not flash baseband]'
        '(-d --debug)'{-d,--debug}'[show all code; useful for capturing a debug log]'
        '(- *)'{-h,--help}'[show help]'
        '1:IPSW firmware file:_files -g "*.ipsw"'
    )
    _arguments -s -S $args
}

_futurerestore "$@"
