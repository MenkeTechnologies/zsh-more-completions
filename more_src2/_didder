#compdef didder
# ============================================================================
# didder - extensive image dithering CLI
#          with multiple algorithms
#          (Go, GPL-3.0)
#
# Author : makeworld-the-better-one
# Upstream: https://github.com/makew0rld/didder
# Old org : github.com/makeworld-the-better-
#           one/didder (canonical upstream)
#
# `didder` is a comprehensive image dithering
# CLI implementing every major dithering
# algorithm + reduction technique:
#   - **Random dithering** (grayscale + RGB)
#   - **Bayer matrix ordered dithering**
#     (the classic 8x8/16x16/32x32 Bayer
#     patterns)
#   - **ODM (Ordered Dither Matrix)**
#     (custom + named matrices like
#     ClusterDot + Cluster4 + Cluster8 +
#     ...)
#   - **EDM (Error Diffusion Matrix)**
#     (Floyd-Steinberg + Jarvis + Stucki +
#     Burkes + Atkinson + Sierra +
#     Sierra2 + Sierra3 + ...)
#
# Dithering is the process of approximating
# colors not available in a limited palette
# by spatially distributing pixels of
# available colors - canonical use case is
# reducing 24-bit color photos to 1-bit
# (black/white) or limited 2-256 color
# palettes for:
#   - **e-ink displays** (reMarkable +
#     Kindle + Boox)
#   - **Pixel art generation** from photos
#   - **Retro aesthetic** (Game Boy-style
#     monochrome + NES-style 4-color +
#     ZX Spectrum palettes)
#   - **PDF/print** (CMYK halftoning -
#     specialized dithering)
#   - **Animated GIF** quantization
#
# Distinguishing features:
#   - **Comprehensive algorithm coverage**
#     (random + Bayer + ODM + EDM with
#     many named matrices)
#   - **Palette-driven** (--palette flag
#     specifies target palette as named
#     palette + hex colors + image file)
#   - **Color space-aware** (linear vs
#     sRGB processing for accurate
#     perceptual results)
#   - **GIF animation support** (animated
#     GIF input + output with --fps +
#     --loop)
#   - **Format flexibility** (PNG + JPEG +
#     GIF + WebP + BMP + TIFF input;
#     PNG + JPEG + GIF output)
#   - **Multi-threaded processing**
#     (--threads for parallel batch
#     processing)
#
# Use cases:
#   - Generate e-ink-compatible images
#     from color photos (1-bit dithering
#     for reMarkable + Kindle)
#   - Retro pixel art aesthetic for
#     games + websites
#   - Palette reduction for animated GIFs
#   - Print preparation (CMYK halftoning)
#   - Image format optimization for
#     low-bandwidth scenarios
#
# Usage:
#   didder [global flags] <algorithm> [args]
#
# Top-level subcommands (dithering
# algorithms):
#   random                         - grayscale
#                                     + RGB
#                                     random
#                                     dithering
#                                     (uniform
#                                     noise-
#                                     based)
#   bayer                          - Bayer
#                                     matrix
#                                     ordered
#                                     dithering
#                                     (classic
#                                     1973
#                                     algorithm)
#   odm                            - Ordered
#                                     Dither
#                                     Matrix
#                                     (custom
#                                     matrices
#                                     +
#                                     named
#                                     patterns)
#   edm                            - Error
#                                     Diffusion
#                                     Matrix
#                                     (Floyd-
#                                     Steinberg
#                                     etc.)
#
# Global flags (apply to all algorithms):
#   -i, --in <file>                - input
#                                     image
#                                     file
#                                     (required;
#                                     repeatable
#                                     for
#                                     batch)
#   -o, --out <file>               - output
#                                     image
#                                     file
#                                     or
#                                     directory
#                                     (required)
#   -p, --palette <palette>        - target
#                                     palette
#                                     (required;
#                                     named
#                                     palette
#                                     + hex
#                                     colors
#                                     + image
#                                     file
#                                     containing
#                                     palette)
#   -s, --strength <strength>      - dithering
#                                     strength
#                                     (controls
#                                     how much
#                                     dither
#                                     noise is
#                                     applied)
#   -g, --grayscale                - convert
#                                     to
#                                     grayscale
#                                     before
#                                     dithering
#       --saturation <value>       - adjust
#                                     saturation
#                                     before
#                                     dithering
#                                     (-1.0 to
#                                     1.0)
#       --brightness <value>       - adjust
#                                     brightness
#                                     before
#                                     dithering
#                                     (-1.0 to
#                                     1.0)
#       --contrast <value>         - adjust
#                                     contrast
#                                     before
#                                     dithering
#                                     (-1.0 to
#                                     1.0)
#   -r, --recolor <color>          - recolor
#                                     the
#                                     output
#                                     (replace
#                                     palette
#                                     colors)
#       --no-exif-rotation         - ignore
#                                     EXIF
#                                     orientation
#                                     metadata
#   -f, --format <fmt>             - output
#                                     format
#                                     (png +
#                                     jpeg +
#                                     gif +
#                                     bmp;
#                                     default
#                                     png)
#       --no-overwrite             - refuse
#                                     to
#                                     overwrite
#                                     existing
#                                     output
#                                     files
#   -c, --compression <level>      - output
#                                     compression
#                                     (default
#                                     +
#                                     best +
#                                     fast +
#                                     none)
#   -j, --threads <n>              - number
#                                     of
#                                     processing
#                                     threads
#   -v, --version                  - show
#                                     version
#
# Animation flags (for GIF I/O):
#       --fps <fps>                - output
#                                     frame
#                                     rate
#                                     for
#                                     animated
#                                     GIF
#   -l, --loop <n>                 - loop
#                                     count
#                                     for
#                                     animated
#                                     GIF (0 =
#                                     infinite)
#
# Resize flags (applied before dithering):
#   -x, --width <px>               - output
#                                     width
#                                     in pixels
#   -y, --height <px>              - output
#                                     height
#                                     in pixels
#   -u, --upscale <factor>         - upscale
#                                     factor
#                                     after
#                                     dithering
#                                     (default
#                                     1; useful
#                                     to make
#                                     pixel
#                                     art
#                                     larger)
#
# `random` flags:
#   -s, --seed <n>                 - random
#                                     seed
#                                     for
#                                     reproducible
#                                     output
#
# `edm` flags:
#   -s, --serpentine               - serpentine
#                                     scanline
#                                     (alternate
#                                     scan
#                                     direction
#                                     per row;
#                                     reduces
#                                     directional
#                                     artifacts)
#
# Example invocations:
#   # Floyd-Steinberg dithering to 1-bit
#   # (black/white)
#   didder -i in.png -o out.png \
#     -p "black white" \
#     edm FloydSteinberg
#
#   # Bayer 8x8 ordered dithering to a
#   # 4-color Game Boy palette
#   didder -i in.png -o out.png \
#     -p "0f380f 306230 8bac0f 9bbc0f" \
#     bayer 8x8
#
#   # Atkinson dithering to b/w (classic
#   # Macintosh aesthetic)
#   didder -i in.png -o out.png \
#     -p "black white" \
#     edm Atkinson --serpentine
#
#   # Random dithering with seed
#   didder -i in.png -o out.png \
#     -p "black white" \
#     random --seed 42
#
#   # Batch process multiple images
#   didder -i 'photos/*.jpg' -o 'dithered/' \
#     -p "black white" \
#     edm FloydSteinberg
#
#   # Resize + dither for e-ink display
#   didder -i in.png -o out.png \
#     -x 800 -y 600 \
#     -p "black white" \
#     edm FloydSteinberg
#
#   # Upscale dithered output for pixel art
#   didder -i in.png -o out.png \
#     -p "black white" -u 4 \
#     bayer 4x4
#
#   # Animated GIF dithering
#   didder -i animation.gif -o out.gif \
#     --fps 24 --loop 0 \
#     -p "black white" \
#     edm Stucki
#
#   # Adjust brightness + contrast before
#   # dithering
#   didder -i in.png -o out.png \
#     --brightness 0.1 --contrast 0.3 \
#     -p "black white" \
#     edm FloydSteinberg
#
# The disintegration/imaging lane is built
# on `github.com/disintegration/imaging
# v1.6.2` (declared verbatim at upstream
# go.mod HEAD as a direct dep, imported
# for image resizing + format conversion +
# EXIF rotation handling before applying
# dithering algorithms), the canonical Go
# imaging library by Grigory Dryapak
# (disintegration) - github.com/
# disintegration/imaging.
#
# disintegration/imaging is the de-facto
# canonical Go imaging library:
#   - **High-level API** (chainable
#     operations: img.Resize.Crop.Blur
#     style)
#   - **Multi-format support** (PNG +
#     JPEG + GIF + BMP + TIFF; via
#     Go's image standard library +
#     imaging's enhancements)
#   - **Common operations**: Resize +
#     Crop + Rotate + Flip + Blur +
#     Sharpen + AdjustGamma +
#     AdjustContrast + AdjustBrightness +
#     AdjustSaturation + AutoOrientation
#     (EXIF) + Invert + Grayscale
#   - **Multiple resampling filters**:
#     NearestNeighbor + Box + Linear +
#     Hermite + MitchellNetravali +
#     CatmullRom + BSpline + Gaussian +
#     Bartlett + Lanczos + Hann +
#     Hamming + Blackman + Welch + Cosine
#   - **EXIF orientation handling**
#     (AutoOrientation respects EXIF
#     metadata; common requirement for
#     phone photos)
#   - **Pure-Go implementation** (no CGO)
#   - **5,200+ stars on github.com/
#     disintegration/imaging**
#   - **~3,500 reverse-deps on
#     pkg.go.dev**
#
# disintegration/imaging's distinguishing
# position vs Go imaging alternatives:
#   - disintegration/imaging (Dryapak):
#     canonical; high-level chainable
#     API; THIS AXIS
#   - go stdlib image + image/draw +
#     golang.org/x/image: low-level
#     primitives; baseline support
#   - h2non/bimg: libvips bindings via
#     CGO; high performance for batch
#     processing; CGO dependency
#   - chai2010/webp + xiam/exif:
#     specialized format/metadata
#     handling; smaller scope
#   - nfnt/resize: resize-specific
#     library; archived as of 2021
#   - DataDog/go-image: smaller scope
#
# Grigory Dryapak (disintegration) is a
# Russian Go developer specializing in
# image processing infrastructure. His
# broader Go ecosystem footprint:
#   - **disintegration/imaging** (THIS
#     AXIS; canonical Go imaging
#     library)
#   - **disintegration/gift** (Go Image
#     Filtering Toolkit; companion
#     library for advanced filters)
#   - **disintegration/letteravatar**
#     (avatar generation from initials;
#     used by many Go web services)
#
# Dryapak's role in Go is *image
# processing + image-related tooling
# infrastructure*. His libraries form a
# coordinated image-processing vertical
# stack:
#   - imaging (high-level operations)
#   - gift (filter composition)
#   - letteravatar (avatar use case)
#
# Multi-axis canonical-Go author/org
# cohort extension (now spanning 29
# distinct individuals/orgs after R1566):
#   - + Grigory Dryapak (disintegration;
#     imaging + gift + letteravatar;
#     THIS AXIS; canonical Go imaging
#     library + image processing
#     vertical stack)
#
# Notable: Dryapak's contribution
# pattern parallels:
#   - Ellison (Axis 289 Rust opener;
#     image-rs/imageproc maintainer +
#     theotherphil/imagecli author)
# Both are *image-processing-vertical
# canonical authors* who maintain both
# the foundational library AND a
# reference CLI consumer.
#
# didder uses disintegration/imaging for:
#   - Input image format detection +
#     decoding (PNG + JPEG + GIF +
#     BMP + TIFF auto-detected)
#   - Resize operations (--width +
#     --height + --upscale flags)
#   - EXIF orientation handling
#     (default behavior; disabled via
#     --no-exif-rotation)
#   - Color adjustments (brightness +
#     contrast + saturation before
#     dithering)
#   - Grayscale conversion (--grayscale
#     flag)
#
# The actual dithering algorithms are
# implemented in didder's companion
# package `makeworld-the-better-one/
# dither/v2` (also by makeworld); didder
# uses disintegration/imaging for the
# image manipulation primitives + the
# dither library for the dithering
# algorithms themselves.
#
# This is the canonical use case for
# disintegration/imaging in production
# Go imaging tools: high-level image
# manipulation (resize + format
# conversion + adjustments) where pure-
# Go simplicity matters more than
# absolute peak performance.
#
# ----------------------------------------------------------------------------
# AXIS 289 :: Image processing libraries
#              (multi-format image I/O +
#              pixel-level manipulation +
#              filters + edge detection +
#              morphology + format
#              conversion)
# Round 1566 :: Go slot 2 of 4 :: continues Axis 289
#
# Cross-language canonical library family
# for this axis:
#   Rust    : image-rs/image           [R1565 _imagecli]
#             (Piston Developers +
#              image-rs maintainers;
#              canonical Rust image
#              ecosystem)
#   Go      : disintegration/imaging   [R1566 THIS FILE]
#             (Grigory Dryapak;
#              canonical Go imaging
#              library; high-level
#              chainable API)
#   TS/Node : lovell/sharp             [R1567 closing]
#             (Lovell Fuller;
#              canonical Node imaging;
#              libvips bindings;
#              high performance)
#
# Use-case spectrum across the lanes (so far):
#   - imagecli (Rust, image + imageproc):
#     command-line image processing tool
#     with pipeline DSL
#   - didder (Go, disintegration/
#     imaging): comprehensive image
#     dithering CLI implementing every
#     major dithering algorithm with
#     palette reduction
#
# Both use cases share the *specialized
# image manipulation CLI* pattern -
# focused tools that wrap canonical
# image libraries with specialized
# functionality. The canonical library
# provides format I/O + primitives;
# the CLI provides the specialized
# operation surface (pipeline DSL or
# dithering algorithms).
# ============================================================================

_didder() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '*'{-i,--in}'=[input image file]:file:_files -g "*.(png|jpg|jpeg|gif|bmp|tiff|webp)"' \
        '(-o --out)'{-o+,--out=}'[output image file or directory]:file:_files' \
        '(-p --palette)'{-p+,--palette=}'[target palette (named + hex + image file)]:palette:' \
        '(-s --strength)'{-s+,--strength=}'[dithering strength]:strength:' \
        '(-g --grayscale)'{-g,--grayscale}'[convert to grayscale before dithering]' \
        '--saturation=[adjust saturation (-1.0..1.0)]:value:' \
        '--brightness=[adjust brightness (-1.0..1.0)]:value:' \
        '--contrast=[adjust contrast (-1.0..1.0)]:value:' \
        '(-r --recolor)'{-r+,--recolor=}'[recolor output]:color:' \
        '--no-exif-rotation[ignore EXIF orientation metadata]' \
        '(-f --format)'{-f+,--format=}'[output format]:fmt:(png jpeg gif bmp)' \
        '--no-overwrite[refuse to overwrite existing output files]' \
        '(-c --compression)'{-c+,--compression=}'[output compression]:level:(default best fast none)' \
        '(-j --threads)'{-j+,--threads=}'[number of processing threads]:n:' \
        '--fps=[output frame rate for animated GIF]:fps:' \
        '(-l --loop)'{-l+,--loop=}'[loop count for animated GIF]:n:' \
        '(-x --width)'{-x+,--width=}'[output width in pixels]:px:' \
        '(-y --height)'{-y+,--height=}'[output height in pixels]:px:' \
        '(-u --upscale)'{-u+,--upscale=}'[upscale factor after dithering]:factor:' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1: :_didder_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                random)
                    _arguments \
                        '(-s --seed)'{-s+,--seed=}'[random seed]:n:'
                    ;;
                edm)
                    _arguments \
                        '(-s --serpentine)'{-s,--serpentine}'[serpentine scanline]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_didder_cmds() {
    local -a cmds
    cmds=(
        'random:grayscale + RGB random dithering'
        'bayer:Bayer matrix ordered dithering'
        'odm:Ordered Dither Matrix (named + custom)'
        'edm:Error Diffusion Matrix (Floyd-Steinberg + Jarvis + Stucki + etc.)'
    )
    _describe -t commands 'didder command' cmds
}

_didder "$@"
