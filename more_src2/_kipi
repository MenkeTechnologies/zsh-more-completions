#compdef kipi
# _kipi — keep your OS / display awake (thewh1teagle/kipi)
# upstream: https://github.com/thewh1teagle/kipi
# Flags from src/args.rs (clap).

_kipi() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(-o --os)'{-o,--os}'[keep the OS awake (default: true)]'
        '(-d --display)'{-d,--display}'[also keep the display awake]'
        '--duration=[duration to keep awake (e.g. 1h30m)]:duration:'
        '--schedule=[schedule wakeup from sleep (e.g. 1m)]:duration:'
        '--report-issue[open a pre-filled GitHub issue in the browser]'
        '--update[update kipi and exit]'
    )
    _arguments -s $args
}

_kipi "$@"
