#compdef ddcctl
# Documentation: https://github.com/kfix/ddcctl
# Reference accessed: 2026-05-17
# Verified: kfix/ddcctl upstream README option table. macOS DDC/CI
# brightness/contrast/input/audio control. Value grammar: `?` to
# query, `NN` to set, `NN-`/`NN+` to decrement/increment.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -i (interpreted as brightness — real is `-b`), -V
# (real ddcctl prints supported via -D dump, no -V flag), -p (real
# is `-D` to dump VCPs).

local ret=1
_arguments -s -S \
  '(- *)-h[show help]' \
  '-d+[display number]:n:' \
  '-w+[delay between settings (us)]:us:' \
  '-W+[reply timeout (ns)]:ns:' \
  '-b+[brightness value]:val:' \
  '-c+[contrast value]:val:' \
  '-rbc[reset brightness + contrast]' \
  '-O[enable OSD overlay]' \
  '-m+[mute audio]:m:(1 2)' \
  '-v+[speaker volume]:val:' \
  '-i+[input source 1-18]:src:' \
  '-o[read display orientation]' \
  '-rg+[red gain]:val:' \
  '-gg+[green gain]:val:' \
  '-bg+[blue gain]:val:' \
  '-rrgb[reset color]' \
  '-osd[read OSD]' \
  '-lang[read OSD language]' \
  '-reset[reset display]' \
  '-preset_a+[preset A]:val:' \
  '-preset_b+[preset B]:val:' \
  '-preset_c+[preset C]:val:' \
  '-D[dump VCP capabilities]' \
  '*:unused:_default' && ret=0
return ret
