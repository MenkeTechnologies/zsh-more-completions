#compdef drm_info
# drm_info - Display information about DRM/KMS devices

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-j --json)'{-j,--json}'[output in JSON format]' \
  '*:DRM device:_files -W /dev/dri' \
  && ret=0

return ret
