#compdef ovs-vlan-bug-workaround
# _ovs-vlan-bug-workaround — Open vSwitch ovs-vlan-bug-workaround tool to work around buggy network drivers that send VLAN-tagged packets up unexpectedly (openvswitch team, C); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-vlan-bug-workaround() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:interface:' \
        '2:enable or disable:(on off)'
}

_ovs-vlan-bug-workaround "$@"
