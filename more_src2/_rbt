#compdef rbt
# Documentation: https://www.reviewboard.org/docs/rbtools/latest/rbt/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a commands=(
  'alias:create command aliases'
  'api-get:retrieve API resource payloads'
  'attach:upload file attachments to review request'
  'clear-cache:delete RBTools cache files'
  'close:close review request'
  'diff:display diff that would be sent to Review Board'
  'info:display info about a review request'
  'install:download and install RBTools dependencies'
  'land:land a change from a review request branch'
  'list-repo-types:list available repository types'
  'login:create cached session token from credentials'
  'logout:remove cached session token'
  'patch:apply patch from review request to local tree'
  'post:create or update a review request'
  'publish:publish a review request'
  'review:create reviews and review replies'
  'setup-completion:set up shell completion'
  'setup-repo:create rbtools config file'
  'stamp:stamp commit message with review request URL'
  'status:show pending review requests for current user'
  'status-update:interact with status updates on review request'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->cmd' \
  '*::arg:_default'

case $state in
  cmd) _describe -t commands 'rbt command' commands ;;
esac
