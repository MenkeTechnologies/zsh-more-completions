#compdef mp4art
# _mp4art — manage MP4 file cover-art (covr-boxes) (enzo1982/mp4v2)
# upstream: https://github.com/enzo1982/mp4v2
# Flags from util/mp4art.cpp (_actionGroup + _parmGroup).

_mp4art() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--art-any[act on all covr-boxes (default)]' \
        '--art-index=[act on covr-box index IDX]:idx:' \
        '--list[list all covr-boxes]' \
        '--add=[add covr-box from IMG file]:file:_files -g "*.(jpg|jpeg|png|bmp|gif)"' \
        '--replace=[replace covr-box with IMG file]:file:_files -g "*.(jpg|jpeg|png|bmp|gif)"' \
        '--remove[remove covr-box]' \
        '--extract[extract covr-box]' \
        '*:MP4 file:_files -g "*.(m4a|m4v|mp4)"'
}

_mp4art "$@"
