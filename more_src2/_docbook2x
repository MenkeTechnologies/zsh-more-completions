#compdef docbook2x-man docbook2x-texi db2x_xsltproc db2x_manxml db2x_texixml
# Documentation: https://manpages.debian.org/testing/docbook2x/docbook2x-man.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-e --encoding)'{-e+,--encoding=}'[output encoding]:enc:' \
  '(-o --to-stdout)'{-o,--to-stdout}'[output to stdout]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-d --dump-fos)'{-d,--dump-fos}'[dump FO]' \
  '(-c --catalogs)'{-c+,--catalogs=}'[catalog files]:files:_files' \
  '(-x --xinclude)'{-x,--xinclude}'[xinclude]' \
  '(-s --stylesheet)'{-s+,--stylesheet=}'[stylesheet]:file:_files -g "*.xsl"' \
  '(-D --output-dir)'{-D+,--output-dir=}'[output dir]:dir:_files -/' \
  '(-N --solinks)'{-N,--solinks}'[generate so-links]' \
  '(--string-param)*--string-param=[name=value]:p:' \
  '*: :_files -g "*.xml *.sgml *.dbk"' && ret=0

return ret
