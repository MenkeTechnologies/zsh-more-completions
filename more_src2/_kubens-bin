#compdef kubens
# _kubens-bin — kubens fast k8s namespace switcher (Ahmet Alp Balkan, Go); change default namespace for current context
# upstream: https://github.com/ahmetb/kubectx

_kubens-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-c[print current namespace]' \
        '--current[print current namespace]' \
        '*:namespace:'
}

_kubens-bin "$@"
