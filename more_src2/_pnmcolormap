#compdef pnmcolormap ppmtomap
# Documentation: man pnmcolormap (Netpbm)
# Source: produce a colormap PPM from a Netpbm image (with quantisation).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-center -meancolor -meanpixel)-center[centroid placement]' \
    '(-center -meancolor -meanpixel)-meancolor[mean of color values]' \
    '(-center -meancolor -meanpixel)-meanpixel[mean of pixel values mapped]' \
    '(-spreadbrightness -spreadluminosity)-spreadbrightness[spread in brightness]' \
    '(-spreadbrightness -spreadluminosity)-spreadluminosity[spread in luminosity]' \
    '(-splitpixelct -splitcolorct -splitspread)-splitpixelct[split by pixel count]' \
    '(-splitpixelct -splitcolorct -splitspread)-splitcolorct[split by color count]' \
    '(-splitpixelct -splitcolorct -splitspread)-splitspread[split by color spread]' \
    '-sort[sort palette]' \
    '-square[force square palette image]' \
    '-verbose[verbose output]' \
    '-debug[debug output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ncolors or all:' \
    '2:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
