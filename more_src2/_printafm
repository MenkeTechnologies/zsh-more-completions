#compdef printafm
# Documentation: https://ghostscript.readthedocs.io/en/latest/
# Reference accessed: 2026-05-20
# Verified: local man printafm(1) on Ghostscript 10.04.0.
# Synopsis: printafm fontname (prints AFM metrics for a PostScript font via gs).

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:font name:' && ret=0

return ret
