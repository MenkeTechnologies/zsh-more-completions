#compdef grub-mkrescue
# _grub-mkrescue — GRUB grub-mkrescue (build a bootable hybrid CD/USB image embedding GRUB + the user's kernel + initrd; -o output image, --modules module list, --install-modules modules to install, --themes themes, --fonts fonts, --locales locales, --label volume label, --label-bgcolor, --label-font, --product-name, --product-version, --rom-directory, --xorriso path to xorriso, --core-compress no|xz|gz, -V version, -h help)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mkrescue.in on tip.

_grub-mkrescue() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[output image]:file:_files' \
        '--output+[output image]:file:_files' \
        '--modules+[modules]:modules:' \
        '--install-modules+[install modules]:modules:' \
        '--themes+[themes]:themes:' \
        '--fonts+[fonts]:fonts:' \
        '--locales+[locales]:locales:' \
        '--label+[volume label]:label:' \
        '--label-bgcolor+[label bg color]:color:' \
        '--label-color+[label fg color]:color:' \
        '--label-font+[label font]:file:_files' \
        '--product-name+[product name]:name:' \
        '--product-version+[product version]:version:' \
        '--rom-directory+[ROM dir]:dir:_files -/' \
        '--xorriso+[xorriso path]:file:_files' \
        '--core-compress+[compression]:comp:(no xz gz lzo)' \
        '*:source path:_files'
}

_grub-mkrescue "$@"
