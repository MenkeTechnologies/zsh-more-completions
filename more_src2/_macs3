#compdef macs3 MACS3
# _macs3 — Tao Liu Shirley Liu MACS3 Model-based Analysis of ChIP-Seq peak calling v3 (macs3-project team, Python); argparse subcommands
# upstream: https://github.com/macs3-project/MACS

_macs3() {
    local -a sub=(
        'callpeak:call peaks from alignment results'
        'bdgpeakcall:call peaks from bedGraph signal track'
        'bdgbroadcall:call broad peaks from bedGraph'
        'bdgcmp:compare two signal tracks'
        'bdgopt:apply operation on bedGraph values'
        'cmbreps:combine biological replicates'
        'bdgdiff:differential peak detection'
        'filterdup:remove duplicate reads at single position'
        'predictd:predict read length and fragment size'
        'pileup:pileup aligned reads'
        'randsample:randomly sample reads'
        'refinepeak:refine peak summits'
        'callvar:call variants in peaks'
        'hmmratac:HMMRATAC ATAC-seq peak caller'
        'differential:differential peak calling'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'macs3 subcommand' sub ;;
        args)
            case $words[1] in
                callpeak) _arguments \
                    '-t+[treatment file]:file:_files -g "*.bam *.sam *.bed *.bedpe *.bowtie *.eland"' \
                    '--treatment=+[treatment file]:file:_files' \
                    '-c+[control file]:file:_files -g "*.bam *.sam *.bed *.bedpe"' \
                    '--control=+[control file]:file:_files' \
                    '-f+[format]:f:(AUTO BAM BAMPE SAM BED BEDPE ELAND ELANDMULTI ELANDEXPORT BOWTIE)' \
                    '--format=+[format]:f:(AUTO BAM BAMPE SAM BED BEDPE ELAND ELANDMULTI ELANDEXPORT BOWTIE)' \
                    '-g+[genome size]:g:(hs mm dm ce 2.7e9 1.87e9 1.2e8 9e7)' \
                    '--gsize=+[genome size]:g:(hs mm dm ce 2.7e9 1.87e9 1.2e8 9e7)' \
                    '-n+[experiment name]:str:' \
                    '--name=+[experiment name]:str:' \
                    '--outdir=+[output dir]:dir:_files -/' \
                    '-q+[q-value cutoff]:f:' \
                    '--qvalue=+[q-value cutoff]:f:' \
                    '-p+[p-value cutoff]:f:' \
                    '--pvalue=+[p-value cutoff]:f:' \
                    '--bdg[generate bedGraph]' \
                    '-B[generate bedGraph]' \
                    '--call-summits[call subpeak summits]' \
                    '--broad[broad peak calling]' \
                    '--broad-cutoff=+[F]:f:' \
                    '--nomodel[no shifting model]' \
                    '--shift=+[N]:n:' \
                    '--extsize=+[N]:n:' \
                    '--keep-dup=+[strategy]:s:(auto all 1)' \
                    '--nolambda[no local lambda]' \
                    '--mfold=+[N N]:str:' \
                    '--slocal=+[N]:n:' \
                    '--llocal=+[N]:n:' \
                    '--scale-to=+[mode]:m:(large small)' \
                    '--ratio=+[F]:f:' \
                    '--SPMR[save signal per million reads]' \
                    '--seed=+[N]:n:' \
                    '--tempdir=+[dir]:dir:_files -/' \
                    '--verbose=+[level]:l:(0 1 2 3 4)' \
                    '--trackline[generate trackline]' ;;
                bdgpeakcall|bdgbroadcall|bdgcmp|bdgopt|bdgdiff|pileup) _arguments \
                    '-i+[input bedGraph]:file:_files -g "*.bdg *.bedGraph *.bgr"' \
                    '-o+[output file]:file:_files' ;;
                predictd|filterdup|randsample|refinepeak) _arguments \
                    '-i+[input file]:file:_files' \
                    '-f+[format]:f:(BAM SAM BED BEDPE)' \
                    '-o+[output file]:file:_files' ;;
                hmmratac|callvar|differential) _arguments \
                    '-b+[BAM]:file:_files -g "*.bam"' \
                    '-i+[interval BED]:file:_files -g "*.bed"' \
                    '-o+[output prefix]:str:' ;;
            esac
            ;;
    esac
}

_macs3 "$@"
