#compdef datasette-cli
# _datasette-cli — Simon Willison datasette publish-data-as-API tool CLI alias (simonw team, Python); click
# upstream: https://github.com/simonw/datasette

_datasette-cli() {
    local -a sub=(
        'serve:run web server'
        'inspect:dump metadata about databases'
        'install:install datasette plugin'
        'uninstall:uninstall datasette plugin'
        'plugins:list installed plugins'
        'publish:publish databases to cloud'
        'publish:cloudrun:publish to Google Cloud Run'
        'publish:fly:publish to Fly.io'
        'publish:heroku:publish to Heroku'
        'publish:vercel:publish to Vercel'
        'package:create Dockerfile/package'
        'create-token:create signed API token'
        'codespaces:create datasette codespace'
        'init:initialize new dataset'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--get=+[GET path]:str:' \
        '--post=+[POST path]:str:' \
        '--token=+[API token]:str:' \
        '--load-extension=+[extension path]:file:_files' \
        '--memory[in-memory db]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datasette subcommand' sub ;;
        args)
            case $words[1] in
                serve|"") _arguments \
                    '*:db files:_files -g "*.{db,sqlite,sqlite3}"' \
                    '--host=+[host]:host:_hosts' \
                    '-h+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--uds=+[unix domain socket]:file:_files' \
                    '--reload[auto reload]' \
                    '--cors[enable CORS]' \
                    '--metadata=+[metadata file]:file:_files -g "*.{json,yml,yaml}"' \
                    '-m+[metadata file]:file:_files -g "*.{json,yml,yaml}"' \
                    '--config=+[config file]:file:_files -g "*.{json,yml,yaml}"' \
                    '--template-dir=+[templates dir]:dir:_files -/' \
                    '--plugins-dir=+[plugins dir]:dir:_files -/' \
                    '--static=+[mount static]:str:' \
                    '--inspect-file=+[inspect file]:file:_files' \
                    '-i+[inspect file]:file:_files' \
                    '--memory[in-memory db]' \
                    '--root[print root URL with token]' \
                    '--open[open browser]' \
                    '-o[open browser]' \
                    '--ssl-keyfile=+[ssl key file]:file:_files' \
                    '--ssl-certfile=+[ssl cert file]:file:_files' \
                    '--secret=+[signing secret]:str:' \
                    '--internal=+[internal db path]:file:_files' \
                    '--immutable=+[immutable db]:file:_files' \
                    '-I+[immutable db]:file:_files' \
                    '--setting=+[name value]:str:' \
                    '--no-load-extensions[no extensions]' \
                    '--unix-socket=+[unix socket]:file:_files' ;;
                publish) _arguments \
                    '1:publisher:(cloudrun fly heroku vercel)' \
                    '*:db files:_files -g "*.{db,sqlite,sqlite3}"' \
                    '--name=+[name]:str:' \
                    '--title=+[title]:str:' \
                    '--license=+[license]:str:' \
                    '--license-url=+[license url]:url:_urls' \
                    '--source=+[source]:str:' \
                    '--source-url=+[source url]:url:_urls' \
                    '--metadata=+[metadata]:file:_files' \
                    '-m+[metadata]:file:_files' \
                    '--install=+[plugin]:str:' \
                    '--memory=+[memory]:str:' \
                    '--cpu=+[cpu]:n:' \
                    '--extra-options=+[options]:str:' \
                    '--branch=+[branch]:str:' \
                    '--template-dir=+[template dir]:dir:_files -/' \
                    '--plugins-dir=+[plugins dir]:dir:_files -/' \
                    '--static=+[static mount]:str:' \
                    '--service=+[service]:str:' \
                    '--region=+[region]:str:' \
                    '--port=+[port]:port:' ;;
                inspect) _arguments \
                    '*:db files:_files -g "*.{db,sqlite,sqlite3}"' \
                    '--inspect-file=+[file]:file:_files' ;;
                create-token) _arguments \
                    '1:user id:' \
                    '--secret=+[secret]:str:' \
                    '--expires-after=+[seconds]:n:' \
                    '--alias=+[alias]:str:' \
                    '--all=+[permission]:str:' \
                    '--database=+[database]:str:' \
                    '--debug[debug]' ;;
                install|uninstall) _arguments '*:plugin:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_datasette-cli "$@"
