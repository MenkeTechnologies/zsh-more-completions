#compdef git-delete-squashed

# Zsh completion for git-delete-squashed
# Deletes local branches that have been squash-merged into a target branch

_git-delete-squashed() {
  local curcontext="$curcontext" ret=1

  _arguments -s -S \
    '--dry-run[show what would be deleted without actually deleting]' \
    '--github[also check GitHub for merged PRs (requires gh CLI)]' \
    '--base-branch[specify the base branch]:branch:__git_delete_squashed_branches' \
    '1:target branch:__git_delete_squashed_branches' && ret=0

  return ret
}

__git_delete_squashed_branches() {
  local -a branches
  branches=(${${(f)"$(git branch --format='%(refname:short)' 2>/dev/null)"}})
  _describe -t branches 'local branch' branches
}

_git-delete-squashed "$@"
