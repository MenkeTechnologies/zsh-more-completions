#compdef pigz unpigz
# _pigz-bin — pigz parallel gzip (Mark Adler); SMP gzip-compatible compressor using multiple threads
# upstream: https://github.com/madler/pigz

_pigz-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-l --list)'{-l,--list}'[list contents]' \
        '(-t --test)'{-t,--test}'[test integrity]' \
        '(-c --stdout)'{-c,--stdout}'[write to stdout]' \
        '(-r --recursive)'{-r,--recursive}'[recurse dirs]' \
        '(-k --keep)'{-k,--keep}'[keep input file]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-n --no-name)'{-n,--no-name}'[no original name/time]' \
        '(-N --name)'{-N,--name}'[preserve original name/time]' \
        '(-T --no-time)'{-T,--no-time}'[no time in output]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-1 --fast)'{-1,--fast}'[fast]' \
        '(-9 --best)'{-9,--best}'[best]' \
        '-0[no compression]' \
        '-2[lvl 2]' \
        '-3[lvl 3]' \
        '-4[lvl 4]' \
        '-5[lvl 5]' \
        '-6[lvl 6 (default)]' \
        '-7[lvl 7]' \
        '-8[lvl 8]' \
        '-11[zopfli level (slow)]' \
        '(-p --processes)'{-p,--processes}'+[threads]:n:' \
        '(-b --blocksize)'{-b,--blocksize}'+[block size KiB]:n:' \
        '(-i --independent)'{-i,--independent}'[independent blocks]' \
        '(-K --zip)'{-K,--zip}'[zip wrapper output]' \
        '(-z --zlib)'{-z,--zlib}'[zlib wrapper output]' \
        '(-R --rsyncable)'{-R,--rsyncable}'[rsyncable output]' \
        '(-Y --synchronous)'{-Y,--synchronous}'[force fsync after writes]' \
        '(-s --suffix)'{-s,--suffix}'+[suffix]:suffix:' \
        '*:file:_files'
}

_pigz-bin "$@"
