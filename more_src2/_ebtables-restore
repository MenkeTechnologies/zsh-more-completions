#compdef ebtables-restore
# _ebtables-restore — netfilter ebtables-restore (reload a saved bridge-firewall (ebtables) ruleset; -c restore counters, -n skip per-table flush (additive), -t TABLE limit to one table (filter|nat|broute), -v verbose, -V version; reads input from stdin or a positional file)
# upstream: https://git.netfilter.org/ebtables
# Flags from netfilter/ebtables src/ebtables-restore.c on tip.

_ebtables-restore() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c[restore counters]' \
        '-n[no flush]' \
        '-t+[table]:table:(filter nat broute)' \
        '-v[verbose]' \
        '*:input file:_files'
}

_ebtables-restore "$@"
