#compdef markdown-link-check
# Documentation: https://github.com/tcort/markdown-link-check
# Reference accessed: 2026-05-19
# Verified: tcort/markdown-link-check README OPTIONS table.
# Removed from prior file: bogus man.archlinux.org URL; -p was tagged
# "parallel mode" (real -p/--progress shows progress bar); missing
# -V/--version, -i/--ignore, -a/--alive, -r/--retry, --reporters,
# --projectBaseUrl, --junit-output.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[output version number]' \
  '(-p --progress)'{-p,--progress}'[show progress bar]' \
  '(-q --quiet)'{-q,--quiet}'[display errors only]' \
  '(-v --verbose)'{-v,--verbose}'[display detailed error information]' \
  '(-c --config)'{-c+,--config=}'[apply config file (JSON)]:file:_files -g "*.json"' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore input paths]:paths:' \
  '(-a --alive)'{-a+,--alive=}'[HTTP codes considered alive]:codes:' \
  '(-r --retry)'{-r,--retry}'[retry after Retry-After header on 429]' \
  '--reporters=[reporters to use]:reporters:' \
  '--projectBaseUrl=[URL used for {{BASEURL}} replacement]:url:' \
  '--junit-output=[output file for JUnit XML report]:file:_files' \
  '*:markdown file or URL:_files -g "*.(md|markdown)(-.)"'
