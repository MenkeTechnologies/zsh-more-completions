#compdef doing

_doing() {
  local -a subcmds
  subcmds=(
    'now:add entry to Currently list'
    'later:add entry to Later list'
    'done:add a completed item'
    'finish:mark last entry as finished'
    'last:show last entry'
    'recent:list recent entries'
    'today:list entries from today'
    'yesterday:list entries from yesterday'
    'tag:add tag to current entry'
    'show:list all entries'
    'grep:search entries'
    'note:add note to entry'
    'cancel:remove last entry'
    'archive:move entries to archive'
    'open:open doing file in editor'
    'config:show or edit config'
    'rotate:rotate doing file'
    'undo:undo last change'
    'import:import entries'
    'sections:list sections'
    'views:list views'
    'view:show a view'
    'template:show or edit templates'
    'reset:reset the doing file'
    'select:select from recent entries'
    'since:show entries since date'
  )

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help information]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '1:command:->cmd' \
    '*::arg:->args'

  case "$state" in
    cmd)
      _describe -t commands 'doing command' subcmds
      ;;
    args)
      case "$words[1]" in
        now|later|done|note)
          _arguments '1:entry text'
          ;;
        tag)
          _arguments '1:tag name'
          ;;
        grep)
          _arguments '1:search pattern'
          ;;
        view)
          _arguments '1:view name'
          ;;
        since)
          _arguments '1:date'
          ;;
        import)
          _arguments '1:file:_files'
          ;;
      esac
      ;;
  esac
}

_doing "$@"
