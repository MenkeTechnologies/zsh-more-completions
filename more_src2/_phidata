#compdef phi
# Documentation: https://github.com/phidatahq/phidata
# Reference accessed: 2026-05-23
# Verified: phidata package phi --help (Typer CLI).

# Zsh completion for phi - Phidata AI engineer toolkit CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'phi command' \
      'init[initialize phidata]' \
      'reset[reset phi installation]' \
      'auth[authenticate with phidata.com]' \
      'ping[ping phidata servers]' \
      'config[print phi config]' \
      'set[set cwd as active workspace]' \
      'start[start resources from resources.py]' \
      'stop[stop resources from resources.py]' \
      'patch[patch resources from resources.py]' \
      'restart[restart resources from resources.py]' \
      'ws[manage workspaces]' && ret=0
    ;;
  args)
    case $line[1] in
      ws)
        if (( CURRENT == 2 )); then
          _values 'ws command' \
            'create[create workspace in current directory]' \
            'setup[setup workspace from current directory]' \
            'up[start active workspace resources]' \
            'down[stop active workspace resources]' \
            'patch[patch active workspace resources]' \
            'restart[restart active workspace resources]' \
            'config[print active workspace config]' \
            'delete[delete workspace record]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
