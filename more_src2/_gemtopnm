#compdef gemtopnm
# Documentation: man gemtopnm (Netpbm)
# Source: convert a GEM .img bitmap to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-debug[debug output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:GEM .img file:_files -g "*.img"' \
    && ret=0

return ret
