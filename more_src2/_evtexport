#compdef evtexport
# Documentation: https://github.com/libyal/libevt
# Source: libyal/libevt manuals/evtexport.1 — export Windows NT5 EventLog (.evt) records.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a codepages=(ascii windows-874 windows-932 windows-936 windows-949 windows-950 windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)

_arguments -s \
    "-c[codepage of ASCII strings]:codepage:($codepages)" \
    '-h[show help]' \
    '-l[log file for info about exported items]:log:_files' \
    '-m[export mode]:mode:(all items recovered)' \
    '-p[search PATH for resource files (default: cwd)]:path:_directories' \
    '-r[directory containing SOFTWARE and SYSTEM registry files]:dir:_directories' \
    '-s[SYSTEM registry file]:system:_files' \
    '-S[SOFTWARE registry file]:software:_files' \
    '-t[event log type]:type:(application security system)' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:evt file:_files' \
    && ret=0

return ret
