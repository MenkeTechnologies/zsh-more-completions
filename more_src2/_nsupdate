#compdef nsupdate
# Documentation: man nsupdate(1) (BIND9)
# Source: ISC BIND nsupdate — dynamic DNS update utility (RFC 2136 + TSIG / SIG(0) / GSS-TSIG).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[debug mode (tracing of update requests and replies)]' \
    '-D[extra debug mode]' \
    '(-g -o -l -y -k)-g[GSS-TSIG (Kerberos credentials) mode]' \
    '(-g -o -l -y -k)-o[non-standard Windows 2000 GSS-TSIG variant]' \
    '(-g -o -l -y -k)-l[local-host mode (server forced to localhost)]' \
    '(-g -o -l -y -k)-y+[TSIG shared secret]:hmac:keyname\:secret:' \
    '(-g -o -l -y -k)-k+[TSIG/SIG(0) authentication key file]:keyfile:_files' \
    '-L+[logging debug level (0 disables logging)]:level:' \
    '-p+[port to use for name-server connections]:port:_ports' \
    '-P[print BIND private resource record types]' \
    '-r+[UDP retries (default 3)]:udpretries:' \
    '-R+[randomness device or file (or keyword "keyboard")]:randomdev:_files' \
    '-t+[max request time before abort (s; 0 disables)]:timeout:' \
    '-T[print IANA standard resource record types]' \
    '-u+[UDP retry interval (s)]:udptimeout:' \
    '-v[use TCP instead of UDP]' \
    '(- *)-V[print version and exit]' \
    '*:update script:_files' \
    && ret=0

return ret
