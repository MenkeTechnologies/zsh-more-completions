#compdef krakend-cli
# _krakend-cli — KrakenD ultra-performance API gateway CLI alias (KrakenD / Devops Faith, Go); spf13/cobra
# upstream: https://github.com/krakend/krakend-ce

_krakend-cli() {
    local -a sub=(
        'audit:audit config'
        'check:check config'
        'check-plugin:check plugin compatibility'
        'completion:generate shell completion'
        'help:show help'
        'run:run KrakenD'
        'test-plugin:test plugin'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "*.json *.tmpl *.yaml"' \
        '--config=+[config file]:file:_files -g "*.json *.tmpl *.yaml"' \
        '-d[debug]' \
        '--debug[debug]' \
        '-p+[port]:port:' \
        '--port=+[port]:port:' \
        '--prefix=+[prefix]:str:' \
        '-l+[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '--logLevel=+[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'krakend subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '-c+[config]:file:_files -g "*.json *.tmpl *.yaml"' \
                    '--config=+[config]:file:_files -g "*.json *.tmpl *.yaml"' \
                    '-d[debug]' \
                    '--debug[debug]' \
                    '-p+[port]:port:' \
                    '--port=+[port]:port:' \
                    '--prefix=+[prefix]:str:' ;;
                check) _arguments \
                    '-c+[config]:file:_files -g "*.json *.tmpl *.yaml"' \
                    '--config=+[config]:file:_files -g "*.json *.tmpl *.yaml"' \
                    '-d[debug]' \
                    '--debug[debug]' \
                    '-l+[lint level]:level:(none basic full)' \
                    '--lint-level=+[lint level]:level:(none basic full)' \
                    '-i[ignore declared errors]' ;;
                audit) _arguments \
                    '-c+[config]:file:_files -g "*.json"' \
                    '--config=+[config]:file:_files -g "*.json"' \
                    '-f+[output format]:fmt:(json yaml table)' \
                    '--format=+[output format]:fmt:(json yaml table)' \
                    '-o+[output file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '-I+[ignore rules]:list:' \
                    '--ignore=+[ignore rules]:list:' \
                    '-s+[severity threshold]:s:(NONE WEAK MID HIGH CRITICAL)' \
                    '--severity=+[severity threshold]:s:(NONE WEAK MID HIGH CRITICAL)' ;;
                check-plugin) _arguments \
                    '--go=+[go version]:str:' \
                    '--libc=+[libc version]:str:' \
                    '--symbols=+[symbol list]:list:' ;;
                test-plugin) _arguments \
                    '*:plugin:_files -g "*.so"' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_krakend-cli "$@"
