#compdef eget
# Documentation: https://github.com/zyedidia/eget
# Reference accessed: 2026-05-17
# Verified: upstream README at the URL above.

# Zsh completion for eget (GitHub release binary downloader)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-t --tag)'{-t,--tag=}'[tagged release to use instead of latest]:tag:' \
  '--pre-release[include pre-releases]' \
  '--source[download source code instead of release]' \
  '(-s --system)'{-s,--system=}'[target system in OS/arch format (or "all")]:system:' \
  '--to=[move to given location after extracting]:path:_files' \
  '(-f --file)'{-f,--file=}'[glob to select file from archive]:pattern:' \
  '--all[extract all candidate files]' \
  '(-a --asset)'{-a,--asset=}'[asset substring filter (use ^ for anti-match)]:pattern:' \
  '--sha256[show SHA-256 of downloaded asset]' \
  '--verify-sha256=[verify SHA-256 against provided hash]:hash:' \
  '--rate[show GitHub API rate limit information]' \
  '(-q --quiet)'{-q,--quiet}'[only print essential output]' \
  '(-d --download-only)'{-d,--download-only}'[download without extracting]' \
  '--upgrade-only[only download if newer than current version]' \
  '(-D --download-all)'{-D,--download-all}'[download all projects from config file]' \
  '(-k --disable-ssl)'{-k,--disable-ssl}'[disable SSL verification for download]' \
  '(-r --remove)'{-r,--remove}'[remove file from $EGET_BIN or cwd]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:repository (user/repo or URL):' && ret=0

return ret
