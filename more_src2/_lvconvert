#compdef lvconvert
# _lvconvert — convert logical volume layout (LVM2); add/remove mirror leg, convert to/from thin/cache, snapshot merge, raid takeover
# upstream: https://gitlab.com/lvmteam/lvm2

_lvconvert() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-b --background)'{-b,--background}'[background]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-i --interval)'{-i,--interval}'+[progress interval]:sec:' \
        '(-m --mirrors)'{-m,--mirrors}'+[mirrors]:n:' \
        '(-M --persistent)'{-M,--persistent}'+[persistent minor]:bool:(y n)' \
        '(-n --name)'{-n,--name}'+[name]:name:' \
        '(-R --regionsize)'{-R,--regionsize}'+[region size]:size:' \
        '(-r --readahead)'{-r,--readahead}'+[read-ahead]:n:' \
        '(-s --snapshot)'{-s,--snapshot}'[snapshot]' \
        '(-Z --zero)'{-Z,--zero}'+[zero metadata]:bool:(y n)' \
        '--addtag+[add tag]:tag:' \
        '--deltag+[delete tag]:tag:' \
        '--alloc+[allocation policy]:policy:(contiguous cling normal anywhere inherit)' \
        '--cache[convert to cache]' \
        '--cachemode+[cache mode]:mode:(writethrough writeback passthrough)' \
        '--cachepool+[cache pool]:pool:' \
        '--cachepolicy+[cache policy]:policy:' \
        '--cachesettings+[cache settings]:str:' \
        '--chunksize+[chunk size]:size:' \
        '--corelog[mirror without log device]' \
        '--mirrorlog+[mirror log type]:type:(core disk mirrored)' \
        '--merge[merge snapshot]' \
        '--noudevsync[do not sync udev]' \
        '--originname+[origin name]:name:' \
        '--poolmetadata+[metadata lv]:lv:' \
        '--poolmetadatasize+[metadata size]:size:' \
        '--poolmetadataspare+[spare metadata]:bool:(y n)' \
        '--repair[repair]' \
        '--replace+[replace device]:dev:_files' \
        '--repairwithmissing[repair with missing]' \
        '--snapshot[snapshot]' \
        '--splitcache[split cache]' \
        '--splitmirrors+[split mirror legs]:n:' \
        '--splitsnapshot[split snapshot]' \
        '--stripes+[stripes]:n:' \
        '--stripesize+[stripe size]:size:' \
        '--thin[convert to thin]' \
        '--thinpool+[thin pool]:pool:' \
        '--type+[lv type]:type:(linear striped mirror raid0 raid1 raid4 raid5 raid6 raid10 thin thin-pool cache cache-pool snapshot error zero)' \
        '--uncache[remove cache]' \
        '--use-policies[use policies]' \
        '--zero+[zero metadata]:bool:(y n)' \
        '*:lv:'
}

_lvconvert "$@"
