#compdef phylum
# Documentation: https://docs.phylum.io/cli/commands/phylum
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-c --config)'{-c+,--config=}'[custom configuration file]:file:_files' \
  '--no-config[bypass all configuration files]' \
  '(-t --timeout)'{-t+,--timeout=}'[request timeout in seconds]:seconds:' \
  '--ignore-certs[skip server certificate validation]' \
  '(-o --org)'{-o+,--org=}'[Phylum organization]:org:' \
  '*'{-v,--verbose}'[increase verbosity (up to -vvv)]' \
  '*'{-q,--quiet}'[decrease verbosity (up to -qq)]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'analyze:submit lockfiles/manifests for analysis'
      'auth:authentication helpers'
      'exception:manage suppressions'
      'extension:manage Phylum extensions'
      'firewall:manage Phylum firewall'
      'group:manage groups'
      'history:show analysis history'
      'init:set up Phylum project'
      'org:manage organizations'
      'package:inspect package metadata'
      'parse:parse a lockfile/manifest'
      'ping:ping the Phylum API'
      'project:manage projects'
      'status:show project status'
      'uninstall:uninstall Phylum CLI'
      'update:self-update CLI'
      'version:show CLI version'
    )
    _describe -t commands 'phylum command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
