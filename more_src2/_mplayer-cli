#compdef mplayer-cli
# _mplayer-cli — MPlayer movie player CLI alias (MPlayer team, C); custom argparse
# upstream: https://www.mplayerhq.hu

_mplayer-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-V[verbose]' \
        '-quiet[quiet]' \
        '-really-quiet[really quiet]' \
        '-msglevel=+[level]:str:' \
        '-msgcolor[colored messages]' \
        '-msgmodule[print module name]' \
        '-noconfig=+[type]:t:(all gui system user)' \
        '-include=+[file]:file:_files' \
        '-fs[fullscreen]' \
        '-fullscreen[fullscreen]' \
        '-nofs[no fullscreen]' \
        '-zoom[zoom]' \
        '-aspect=+[ratio]:str:' \
        '-monitoraspect=+[ratio]:str:' \
        '-vo+[video output]:str:' \
        '-ao+[audio output]:str:' \
        '-vc+[video codec]:str:' \
        '-ac+[audio codec]:str:' \
        '-vf+[video filter]:str:' \
        '-af+[audio filter]:str:' \
        '-volume=+[volume]:n:' \
        '-softvol[software volume]' \
        '-softvol-max=+[n]:n:' \
        '-volstep=+[n]:n:' \
        '-mute[mute]' \
        '-noar[no autorepeat]' \
        '-cookies[allow cookies]' \
        '-cookies-file=+[file]:file:_files' \
        '-loop=+[count]:n:' \
        '-shuffle[shuffle]' \
        '-playlist=+[file]:file:_files' \
        '-noresume[no resume]' \
        '-ss+[time]:str:' \
        '-endpos=+[time]:str:' \
        '-frames=+[n]:n:' \
        '-speed=+[n]:str:' \
        '-noautosub[no auto sub]' \
        '-sub=+[file]:file:_files' \
        '-subcp=+[codepage]:str:' \
        '-subfont=+[file]:file:_files' \
        '-subfont-text-scale=+[n]:n:' \
        '-subfps=+[fps]:str:' \
        '-subpos=+[n]:n:' \
        '-subdelay=+[seconds]:str:' \
        '-osdlevel=+[level]:n:' \
        '-font=+[file]:file:_files' \
        '-cache=+[kb]:n:' \
        '-cache-min=+[pct]:n:' \
        '-rtsp-stream-over-tcp[rtsp over tcp]' \
        '-dvd-device=+[device]:file:_files' \
        '-cdrom-device=+[device]:file:_files' \
        '-edl=+[file]:file:_files' \
        '-noframedrop[no framedrop]' \
        '-framedrop[framedrop]' \
        '-hardframedrop[hard framedrop]' \
        '-prefer-ipv4[prefer ipv4]' \
        '-prefer-ipv6[prefer ipv6]' \
        '-tv=+[tv opts]:str:' \
        '-input=+[opts]:str:' \
        '-slave[slave mode]' \
        '-idle[idle mode]' \
        '-rootwin[root window]' \
        '-ontop[stay on top]' \
        '-screen=+[screen]:n:' \
        '-xineramascreen=+[screen]:n:' \
        '-x+[width]:n:' \
        '-y+[height]:n:' \
        '-monitorpixelaspect=+[ratio]:str:' \
        '-dr[direct rendering]' \
        '-double[double buffering]' \
        '-vid=+[id]:str:' \
        '-aid=+[id]:str:' \
        '-sid=+[id]:str:' \
        '-channels=+[count]:n:' \
        '-srate=+[hz]:n:' \
        '*:files urls:_files'
}

_mplayer-cli "$@"
