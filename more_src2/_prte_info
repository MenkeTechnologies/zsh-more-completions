#compdef prte_info
# Documentation: https://docs.prrte.org/en/latest/man/man1/prte_info.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --all)'{-a,--all}'[show all configuration options and MCA parameters]' \
  '--arch[show architecture on which PRRTE was compiled]' \
  '(-c --config)'{-c,--config}'[show configuration options]' \
  '--hostname[show the hostname on which PRRTE was built]' \
  '--internal[show internal MCA parameters]' \
  '*--param[show MCA parameters (framework:components)]:framework:' \
  '--path[show paths]:type:(prefix bindir libdir incdir mandir pkglibdir sysconfdir)' \
  '--show-version[show version of PRRTE or a component]:spec:' && ret=0

return ret
