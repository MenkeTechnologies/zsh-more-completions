#compdef nodeattr libgendersjava
# _genders — LLNL nodeattr genders client; queries the /etc/genders cluster-node attribute database used by pdsh/powerman to enumerate nodes by attribute
# upstream: https://github.com/chaos/genders

_genders() {
    _arguments \
        '-f+[genders file]:file:_files' \
        '-l[list nodes (default if no query)]' \
        '-c[output as comma-separated list]' \
        '-n[output as newline-separated list]' \
        '-s[output as space-separated list]' \
        '-q[quiet (exit status only)]' \
        '-Q[query (return attribute values)]' \
        '-v[verbose]' \
        '-A[print all attributes for node]' \
        '-V+[print all values for attribute]:attribute:' \
        '-X[print extended attributes only]' \
        '-U[print unparsed lines]' \
        '-k[print node-key list]' \
        '-K[print attribute=value list]' \
        '-h[show help]' \
        '*:attribute or query:'
}

_genders "$@"
