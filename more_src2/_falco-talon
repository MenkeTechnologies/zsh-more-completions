#compdef falco-talon
# _falco-talon — Falco Response Engine for Kubernetes (falcosecurity/falco-talon)
# upstream: https://github.com/falcosecurity/falco-talon
# Subcommands + flags from cmd/{root,server,rules,actionners,outputs,notifiers}.go on tip.

_falco-talon() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '*'{-r,--rules=}'[Falco Talon rules file (repeatable)]:file:_files -g "*.(yml|yaml)(-.)"' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                server:'start the Falco Talon response server'
                rules:'manage Falco Talon rules'
                actionners:'list available actionners'
                outputs:'list available outputs'
                notifiers:'list available notifiers'
            )
            _describe -t commands 'falco-talon command' cmds
            ;;
        args)
            case $words[1] in
                server)
                    _arguments \
                        '(-c --config)'{-c,--config=}'[Falco Talon config file]:file:_files'
                    ;;
                rules)
                    local -a sub=(
                        check:'validate the rules files'
                        print:'print the loaded rules'
                    )
                    _describe -t subcommands 'falco-talon rules subcommand' sub
                    _arguments \
                        '(-c --config)'{-c,--config=}'[Falco Talon config file]:file:_files'
                    ;;
                actionners|outputs|notifiers)
                    local -a sub=(list:'list available items')
                    _describe -t subcommands "falco-talon $words[1] subcommand" sub
                    _arguments \
                        '(-c --config)'{-c,--config=}'[Falco Talon config file]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_falco-talon "$@"
