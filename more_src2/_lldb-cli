#compdef lldb-cli
# _lldb-cli — LLVM lldb modern debugger CLI alias (LLVM team, C++); custom argparse
# upstream: https://github.com/llvm/llvm-project

_lldb-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--arch=+[arch]:str:' \
        '-a+[arch]:str:' \
        '--attach-name=+[process name]:str:' \
        '-n+[process name]:str:' \
        '--attach-pid=+[pid]:pid:_pids' \
        '-p+[pid]:pid:_pids' \
        '--batch[batch mode]' \
        '-b[batch mode]' \
        '--core=+[core file]:file:_files' \
        '-c+[core file]:file:_files' \
        '--debug[debug]' \
        '-d[debug]' \
        '--editor[use editor]' \
        '-e[use editor]' \
        '--file=+[file]:file:_files' \
        '-f+[file]:file:_files' \
        '--local-lldbinit[load local .lldbinit]' \
        '-l[load local .lldbinit]' \
        '--no-lldbinit[do not load .lldbinit]' \
        '-x[do not load .lldbinit]' \
        '--no-use-colors[no colors]' \
        '-X[no colors]' \
        '--one-line-before-file=+[command]:str:' \
        '-O+[command]:str:' \
        '--one-line=+[command]:str:' \
        '-o+[command]:str:' \
        '--one-line-on-crash=+[command]:str:' \
        '-k+[command]:str:' \
        '--python-path[show python path]' \
        '-P[show python path]' \
        '--print-script-interpreter-info[show script interpreter info]' \
        '-Q[show script interpreter info]' \
        '--repl[start REPL]' \
        '-r[start REPL]' \
        '--repl-language=+[lang]:l:(c objc objc++ c++ swift)' \
        '-R+[lang]:l:(c objc objc++ c++ swift)' \
        '--source=+[file]:file:_files' \
        '-s+[file]:file:_files' \
        '--source-before-file=+[file]:file:_files' \
        '-S+[file]:file:_files' \
        '--source-on-crash=+[file]:file:_files' \
        '-K+[file]:file:_files' \
        '--source-quietly[source quietly]' \
        '-Q[source quietly]' \
        '--wait-for[wait for process to launch]' \
        '-w[wait for process to launch]' \
        '*:program args:_files'
}

_lldb-cli "$@"
