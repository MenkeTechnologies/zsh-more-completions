#compdef falcosidekick-ui
# _falcosidekick-ui — web UI for falcosidekick events (falcosecurity/falcosidekick-ui)
# upstream: https://github.com/falcosecurity/falcosidekick-ui
# Flags from main.go (flag).

_falcosidekick-ui() {
    _arguments \
        '-a+[listen address]:host:_hosts' \
        '-p+[listen port]:port:' \
        '-r+[Redis server address]:host\:port:' \
        '-y+[Redis username]:user:' \
        '-w+[Redis password]:password:' \
        '-t+[TTL for keys (Xs/Xm/Xh/Xd/XW/XM/Xy)]:duration:' \
        '-l+[log level]:level:(debug info warn error)' \
        '-u+[user in <login>:<password>]:user:' \
        '-d[disable authentication]' \
        '-x[allow CORS for development]' \
        '-v[print version]'
}

_falcosidekick-ui "$@"
