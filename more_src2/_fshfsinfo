#compdef fshfsinfo
# Documentation: https://github.com/libyal/libfshfs
# Source: libyal/libfshfs manuals/fshfsinfo.1 — display info about an HFS / HFS+ / HFSX volume.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B[output file system info as a bodyfile]:bodyfile:_files' \
    '-d[calculate MD5 hash of file entry for bodyfile]' \
    '-E[show info about a specific file system entry or "all"]:entry:' \
    '-f[show info about a specific file system or "all"]:fs index:' \
    '-F[show info about a specific file entry path]:path:' \
    '-h[show help]' \
    '-H[show file system hierarchy]' \
    '-o[volume offset]:offset:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:image or volume:_files' \
    && ret=0

return ret
