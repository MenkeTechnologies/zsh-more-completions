#compdef delly
# Documentation: https://github.com/dellytools/delly
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Delly: structural variant detection from short/long-read BAM
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'call:discover and genotype SVs in BAM files'
  'lr:long-read SV calling (PacBio/ONT)'
  'cnv:copy-number variant discovery'
  'classify:classify CNVs'
  'merge:merge SV sites from multiple samples'
  'filter:filter and annotate SV calls'
  'markdup:mark duplicate reads'
  'tags:add tags to BAM files'
  'compare:compare SV calls'
  'chimera:detect chimeric reads'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-t --type)'{-t,--type=}'[SV type (call/lr)]:type:(DEL DUP INV TRA INS BND)' \
  '(-y --technology)'{-y,--technology=}'[long-read tech]:tech:(ont pb)' \
  '(-g --genome)'{-g,--genome=}'[reference genome FASTA]:file:_files -g "*.(fa|fasta|fna)"' \
  '(-o --outfile)'{-o,--outfile=}'[output BCF/VCF file]:file:_files' \
  '(-q --map-qual)'{-q,--map-qual=}'[minimum mapping quality]:n:' \
  '(-s --min-clique-size)'{-s,--min-clique-size=}'[minimum clique size]:n:' \
  '(-n --noindels)'{-n,--noindels}'[no small indel calling]' \
  '(-x --exclude)'{-x,--exclude=}'[file of excluded regions]:file:_files' \
  '(-c --vcffile)'{-c,--vcffile=}'[input/output VCF]:file:_files' \
  '(-m --mappability)'{-m,--mappability=}'[mappability map]:file:_files' \
  '(-f --filter)'{-f,--filter=}'[filter type]:type:(somatic germline)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'delly command' commands && ret=0 ;;
esac

return ret
