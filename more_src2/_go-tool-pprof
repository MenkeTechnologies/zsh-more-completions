#compdef go-tool-pprof
# _go-tool-pprof — go tool pprof wrapper; pprof launcher with Go-specific defaults
# upstream: https://pkg.go.dev/cmd/go/internal/tool

_go-tool-pprof() {
    _arguments \
        '-text[text report]' \
        '-top[top report]' \
        '-tree[tree report]' \
        '-callgrind[callgrind output]' \
        '-cum[cumulative sort]' \
        '-flat[flat sort]' \
        '-dot[Graphviz dot]' \
        '-svg[SVG]' \
        '-png[PNG]' \
        '-pdf[PDF]' \
        '-list+[list regex]:regex:' \
        '-disasm+[disasm regex]:regex:' \
        '-weblist+[weblist regex]:regex:' \
        '-web[open in browser]' \
        '-http+[serve http]:host:port:' \
        '-output+[output file]:file:_files' \
        '-symbolize+[symbolize mode]:mode:(none local fastlocal remote demangle)' \
        '-base+[base profile]:file:_files' \
        '-diff_base+[diff base profile]:file:_files' \
        '-source_path+[source path]:path:_files' \
        '-trim_path+[trim path]:path:' \
        '-focus+[focus regex]:regex:' \
        '-ignore+[ignore regex]:regex:' \
        '-show+[show regex]:regex:' \
        '-show_from+[show from regex]:regex:' \
        '-hide+[hide regex]:regex:' \
        '-prune_from+[prune from regex]:regex:' \
        '-nodefraction+[node fraction]:f:' \
        '-edgefraction+[edge fraction]:f:' \
        '-nodecount+[max nodes]:n:' \
        '-sample_index+[sample index]:str:' \
        '-mean[mean sample]' \
        '-relative_percentages[relative %]' \
        '-tagfocus+[tag focus]:str:' \
        '-tagignore+[tag ignore]:str:' \
        '*:profile or binary:_files'
}

_go-tool-pprof "$@"
