#compdef move-prover mvp
# Documentation: https://github.com/aptos-labs/aptos-core/blob/main/third_party/move/move-prover/src/cli.rs
# Reference accessed: 2026-05-27
# Verified: upstream aptos-labs/aptos-core third_party/move/move-prover/src/cli.rs Options clap derive

# Zsh completion for move-prover (mvp), the Move language formal verifier
# (Boogie/Z3 backend) from the Aptos / Move Prover project.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --output)'{-o+,--output=}'[path to the boogie output representing the verification problem]:file:_files -g "*.bpl"' \
  '(-v --verbose)'{-v+,--verbose=}'[verbosity level for logging]:level:(error warn info debug)' \
  '*'{-d+,--dependency=}'[path to a Move dependency source or directory]:path:_files' \
  '(-a --named-addresses)'{-a+,--named-addresses=}'[values for named addresses (NAME=ADDR)]:addr:' \
  '(-e --experimental-pipeline)'{-e,--experimental-pipeline}'[run experimental pipeline]' \
  '--language-version=[Move language version]:version:' \
  '(-c --config)'{-c+,--config=}'[path to a TOML configuration file]:file:_files -g "*.toml"' \
  '*'{-C+,--config-str=}'[inline TOML config string]:toml:' \
  '--print-config[print effective TOML configuration and exit]' \
  '--aptos[configure the prover to use Aptos natives]' \
  '(-t --trace)'{-t,--trace}'[enable automatic tracing of expressions in prover errors]' \
  '(-s --severity)'{-s+,--severity=}'[minimal diagnostic severity to report]:level:(bug error warn note)' \
  '--verify=[default scope of verification]:scope:(public all none)' \
  '--verify-only=[only generate VC for the given function]:function:' \
  '--z3-trace=[only verify the given function and emit a z3 trace file]:function:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:move source path:_files' && ret=0

return ret
