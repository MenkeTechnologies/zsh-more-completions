#compdef kdesu kdesudo
# _kdesu — KDE kdesu (run a graphical command as another user via a polkit-style dialog; -u target user, -c command, -t keep terminal, -f file to test write access, -i icon, -p priority, -s stop daemon, -n no keep)
# upstream: https://invent.kde.org/plasma/kde-cli-tools (kdesu)
# Flags from kde-cli-tools kdesu/kdesu.cpp on tip.

_kdesu() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[command]:command:' \
        '-d[no helpful dialogs]' \
        '-f+[file to test for write access]:file:_files' \
        '-i+[icon for dialog]:icon:' \
        '-n[do not keep password]' \
        '-p+[scheduler priority 0-100]:priority:' \
        '-r[realtime scheduling]' \
        '-s[stop the kdesu daemon]' \
        '-t[run terminal session]' \
        '-u+[target user]:user:_users' \
        '--noignorebutton[no ignore button on dialog]' \
        '*::command:_command_names -e'
}

_kdesu "$@"
