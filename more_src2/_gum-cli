#compdef gum-cli
# _gum-cli — Charm gum shell scripting glamour toolkit CLI alias (Charm / charmbracelet, Go); spf13/cobra
# upstream: https://github.com/charmbracelet/gum

_gum-cli() {
    local -a sub=(
        'choose:choose from a list'
        'confirm:show confirmation prompt'
        'file:pick a file'
        'filter:filter items using fuzzy search'
        'format:format markdown/text'
        'input:prompt for input'
        'join:join text horizontally/vertically'
        'log:log a message'
        'pager:scroll through long text'
        'spin:show a spinner while running a command'
        'style:apply lipgloss styles'
        'table:render a styled table'
        'write:multi-line text editor'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gum subcommand' sub ;;
        args)
            case $words[1] in
                choose) _arguments \
                    '--limit=+[max selections]:n:' \
                    '--no-limit[no limit]' \
                    '--height=+[height]:n:' \
                    '--header=+[header]:str:' \
                    '--cursor=+[cursor]:str:' \
                    '--cursor.foreground=+[cursor color]:c:' \
                    '--selected.foreground=+[selected color]:c:' \
                    '--ordered[ordered]' \
                    '--selected=+[selected items csv]:str:' \
                    '*:option:' ;;
                confirm) _arguments \
                    '--default=+[default]:b:(true false)' \
                    '--affirmative=+[affirmative text]:str:' \
                    '--negative=+[negative text]:str:' \
                    '--show-help[show help]' \
                    '--show-output[show output]' \
                    '--timeout=+[timeout]:dur:' \
                    '*:prompt:' ;;
                file) _arguments \
                    '--cursor=+[cursor]:str:' \
                    '--all[show hidden]' \
                    '--file[file only]' \
                    '--directory[dir only]' \
                    '--show-help[show help]' \
                    '--show-size[show size]' \
                    '*:dir:_files -/' ;;
                filter) _arguments \
                    '--placeholder=+[placeholder]:str:' \
                    '--prompt=+[prompt]:str:' \
                    '--width=+[width]:n:' \
                    '--height=+[height]:n:' \
                    '--limit=+[limit]:n:' \
                    '--no-limit[no limit]' \
                    '--strict[strict]' \
                    '--no-strict[no strict]' \
                    '--reverse[reverse]' \
                    '--fuzzy[fuzzy]' \
                    '--no-fuzzy[no fuzzy]' \
                    '--sort[sort]' \
                    '--no-sort[no sort]' ;;
                input) _arguments \
                    '--placeholder=+[placeholder]:str:' \
                    '--prompt=+[prompt]:str:' \
                    '--value=+[default value]:str:' \
                    '--char-limit=+[char limit]:n:' \
                    '--width=+[width]:n:' \
                    '--password[password mode]' \
                    '--timeout=+[timeout]:dur:' ;;
                spin) _arguments \
                    '--show-output[show output]' \
                    '--show-error[show error]' \
                    '--show-stderr[show stderr]' \
                    '--spinner=+[spinner]:s:(line dot minidot jump pulse points globe moon monkey meter hamburger)' \
                    '--title=+[title]:str:' \
                    '--align=+[align]:a:(left right)' \
                    '--timeout=+[timeout]:dur:' \
                    '*:cmd:_command_names -e' ;;
                style) _arguments \
                    '--bold[bold]' \
                    '--italic[italic]' \
                    '--underline[underline]' \
                    '--strikethrough[strikethrough]' \
                    '--blink[blink]' \
                    '--reverse[reverse]' \
                    '--faint[faint]' \
                    '--foreground=+[foreground color]:c:' \
                    '--background=+[background color]:c:' \
                    '--width=+[width]:n:' \
                    '--height=+[height]:n:' \
                    '--align=+[align]:a:(left right center)' \
                    '--border=+[border]:b:(none normal rounded thick double hidden)' \
                    '--border-foreground=+[border fg]:c:' \
                    '--border-background=+[border bg]:c:' \
                    '--padding=+[padding]:str:' \
                    '--margin=+[margin]:str:' \
                    '*:text:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                format|log|pager|write|join|table) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_gum-cli "$@"
