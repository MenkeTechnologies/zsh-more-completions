#compdef detox-cli
# _detox-cli — Wix Detox grey-box mobile testing CLI alias (Wix, Node.js); commander
# upstream: https://github.com/wix/Detox

_detox-cli() {
    local -a sub=(
        'init:scaffold detox config'
        'build:run build command'
        'test:run end-to-end tests'
        'recorder:record actions to test'
        'reset-lock-file:reset cache lock file'
        'rebuild-framework-cache:rebuild ios framework cache'
        'build-framework-cache:build ios framework cache'
        'clean-framework-cache:clean ios framework cache'
        'doctor:diagnose detox env'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug-synchronization=+[ms]:n:' \
        '--loglevel=+[log level]:level:(fatal error warn info verbose trace)' \
        '-l+[log level]:level:(fatal error warn info verbose trace)' \
        '--no-color[no color]' \
        '--config-path=+[config path]:file:_files' \
        '-C+[config path]:file:_files' \
        '--configuration=+[configuration]:str:' \
        '-c+[configuration]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'detox subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--runner=+[runner]:r:(jest jest-circus mocha)' \
                    '-r+[runner]:r:(jest jest-circus mocha)' ;;
                build) _arguments \
                    '--configuration=+[configuration]:str:' \
                    '-c+[configuration]:str:' \
                    '--silent[silent]' \
                    '-s[silent]' \
                    '--if-missing[only if missing]' \
                    '-i[only if missing]' ;;
                test) _arguments \
                    '--configuration=+[configuration]:str:' \
                    '-c+[configuration]:str:' \
                    '--device-name=+[device name]:str:' \
                    '-d+[device name]:str:' \
                    '--device-launch-args=+[device launch args]:str:' \
                    '-l+[device launch args]:str:' \
                    '--app-launch-args=+[app launch args]:str:' \
                    '--app-launch-args-=+[app launch args minus]:str:' \
                    '--cleanup=+[cleanup]:b:(true false)' \
                    '-u+[cleanup]:b:(true false)' \
                    '--inspect-brk[inspect brk]' \
                    '-i[inspect brk]' \
                    '--keepLockFile=+[keep lock file]:b:(true false)' \
                    '--reuse=+[reuse]:b:(true false)' \
                    '-r+[reuse]:b:(true false)' \
                    '--retries=+[retries]:n:' \
                    '--timeout=+[timeout]:n:' \
                    '--maxWorkers=+[max workers]:n:' \
                    '-w+[max workers]:n:' \
                    '--workers=+[workers]:n:' \
                    '--headless=+[headless]:b:(true false)' \
                    '-H+[headless]:b:(true false)' \
                    '--gpu=+[gpu mode]:m:(host swiftshader_indirect angle_indirect guest)' \
                    '-g+[gpu mode]:m:(host swiftshader_indirect angle_indirect guest)' \
                    '--record-logs=+[record logs]:m:(failing all none)' \
                    '--record-videos=+[record videos]:m:(failing all none)' \
                    '--record-performance=+[record performance]:m:(failing all none)' \
                    '--record-timeline=+[record timeline]:m:(failing all none)' \
                    '--take-screenshots=+[take screenshots]:m:(failing all manual none)' \
                    '--capture-view-hierarchy=+[capture view hierarchy]:m:(enabled disabled)' \
                    '--artifacts-location=+[artifacts location]:dir:_files -/' \
                    '-a+[artifacts location]:dir:_files -/' \
                    '*:pattern:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_detox-cli "$@"
