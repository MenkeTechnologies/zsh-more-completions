#compdef gardener-controller-manager
# _gardener-controller-manager — Gardener garden-controller-manager
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-controller-manager/app/options.go on tip.

_gardener-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[controller-manager config file]:file:_files -g "*.(yaml|yml)"' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardener-controller-manager "$@"
