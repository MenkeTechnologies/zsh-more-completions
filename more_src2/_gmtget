#compdef gmtget
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtget.html
# Source: GenericMappingTools/gmt src/gmtget.c — get GMT default parameter values + remote data (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[download remote dataset(s)]:download:_default' \
    '-G+[defaults file]:file:_files' \
    '-I+[increment limit]:inc:_default' \
    '-L[write one parameter per line]' \
    '-N[do not convert JP2 grids to netCDF]' \
    '-Q[with -D, list but do not download]' \
    '*-V[verbose (stackable)]' \
    '*:parameter names:_default' \
    && ret=0

return ret
