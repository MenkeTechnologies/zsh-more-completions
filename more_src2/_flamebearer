#compdef flamebearer
# _flamebearer — turn V8 --prof logs into HTML flamegraphs (mapbox/flamebearer)
# upstream: https://github.com/mapbox/flamebearer
# Usage from bin/flamebearer (positional V8 log file).

_flamebearer() {
    _arguments \
        '1:V8 prof log JSON (or stdin):_files -g "*.(json|log)"'
}

_flamebearer "$@"
