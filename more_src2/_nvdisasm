#compdef nvdisasm
# Documentation: https://docs.nvidia.com/cuda/cuda-binary-utilities/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvdisasm: CUDA SASS disassembler
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(--base-address -base)'{--base-address=,-base=}'[base address]:addr:' \
  '(--binary -b)'{--binary=,-b=}'[binary architecture]:arch:' \
  '(--cuda-function-index -fun)'{--cuda-function-index=,-fun=}'[function index]:n:' \
  '(--emit-json -json)'{--emit-json,-json}'[emit JSON]' \
  '(--life-range-mode -lrm)'{--life-range-mode=,-lrm=}'[life range mode]:mode:' \
  '(--no-dataflow -ndf)'{--no-dataflow,-ndf}'[disable dataflow analysis]' \
  '(--no-vliw -novliw)'{--no-vliw,-novliw}'[disable VLIW handling]' \
  '(--output-control-flow-graph -cfg)'{--output-control-flow-graph,-cfg}'[output CFG]' \
  '(--output-control-flow-graph-with-basic-blocks -bbcfg)'{--output-control-flow-graph-with-basic-blocks,-bbcfg}'[output CFG with basic blocks]' \
  '(--print-code -c)'{--print-code,-c}'[print code]' \
  '(--print-instr-offsets-cfg -poff)'{--print-instr-offsets-cfg,-poff}'[print offsets in CFG]' \
  '(--print-instruction-encoding -hex)'{--print-instruction-encoding,-hex}'[print instruction encoding]' \
  '(--print-life-ranges -plr)'{--print-life-ranges,-plr}'[print life ranges]' \
  '(--print-line-info -g)'{--print-line-info,-g}'[print line info]' \
  '(--print-line-info-inline -gi)'{--print-line-info-inline,-gi}'[print inline line info]' \
  '(--print-line-info-ptx -gp)'{--print-line-info-ptx,-gp}'[print PTX line info]' \
  '(--print-raw -raw)'{--print-raw,-raw}'[print raw bytes]' \
  '(--separate-functions -sf)'{--separate-functions,-sf}'[separate functions]' \
  '(--options-file -optf)'{--options-file=,-optf=}'[read options from file]:file:_files' \
  '*:CUDA cubin or fatbin:_files' && ret=0
return ret
