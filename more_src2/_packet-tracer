#compdef packettracer
# _packet-tracer — Cisco Packet Tracer (closed-source network simulator from Cisco Networking Academy; positional argument is a .pkt or .pka file; --help, --version, --logging level, --auto-cable-detection, --teacher-mode, --no-update, --json options shown by recent builds)
# upstream: closed source (Cisco Systems)
# Common flags verified from Packet Tracer 8+ help output.

_packet-tracer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--logging+[log level]:level:(off error warn info debug trace)' \
        '--auto-cable-detection[auto cable detection]' \
        '--teacher-mode[start in teacher mode]' \
        '--no-update[skip update check]' \
        '--no-network[disable internet features]' \
        '--full-screen[start full screen]' \
        '1:packet tracer file:_files -g "*.(pkt|pka|pkz)"'
}

_packet-tracer "$@"
