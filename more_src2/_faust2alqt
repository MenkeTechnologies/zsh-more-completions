#compdef faust2alqt faust2alsa faust2caqt faust2jaqt
# Documentation: source-direct extraction from upstream
# grame-cncm/faust tools/faust2appls/faust2{alqt,alsa,caqt,jaqt}
# bash scripts + shared tools/faust2appls/usage.sh option-
# documentation helper. All 4 are bash scripts (NOT compiled
# binaries) that wrap `faust` (Faust DSP compiler) with audio-
# backend + GUI-toolkit combinations:
#   faust2alsa  = ALSA + GTK     (Linux)
#   faust2alqt  = ALSA + Qt      (Linux)
#   faust2caqt  = CoreAudio + Qt (macOS)
#   faust2jaqt  = JACK + Qt      (cross-platform)
# Reference accessed: 2026-05-30 via gh api.
# Grame Faust R151 — 4-stem multi-binary harvest of the
# audio-backend/GUI wrapper trio not previously covered. Sister
# tools to the already-covered `faust` Faust DSP compiler and
# the broader `pdsend`/`pdreceive`/`sclang`/`scide`/`sonic-pi`
# audio-synthesis family.

# Shared 8-option base inherited from `usage.sh`'s built-in
# `option` doc helper.
local -a _faust2_shared
_faust2_shared=(
  '-help[show help]'
  '-h[show help (synonym)]'
  '-httpd[activate HTTP control]'
  '-osc[activate OSC control]'
  '-midi[activate MIDI control]'
  '-qrcode[activate QR-code generation]'
  '-soundfile[bundle resources for DSP using the soundfile primitive]'
  '-nvoices+[polyphonic-DSP voice count]:num:'
  '-effect+[effect DSP file or "auto"]:file or auto:_files -g "*.dsp"'
)

case $service in

  faust2alsa)
    # Compiles Faust to ALSA + GTK (Linux). Shared options only.
    _arguments -s -S \
      "${_faust2_shared[@]}" \
      '1:Faust DSP file:_files -g "*.dsp"'
    ;;

  faust2alqt)
    # Compiles Faust to ALSA + Qt (Linux). Shared options only
    # per upstream `elif [ $p = "..." ]` chain (no -resample
    # / -opt extensions).
    _arguments -s -S \
      "${_faust2_shared[@]}" \
      '1:Faust DSP file:_files -g "*.dsp"'
    ;;

  faust2caqt)
    # Compiles Faust to CoreAudio + Qt (macOS). Adds -opt (LLVM
    # opt level), -nodeploy (skip macdeployqt), -I (include path),
    # -resample (sample-rate-conversion mode).
    _arguments -s -S \
      "${_faust2_shared[@]}" \
      '-opt+[LLVM optimization level]:level:(0 1 2 3 s z)' \
      '-nodeploy[skip self-contained app generation (no macdeployqt step)]' \
      '*-I+[Faust include path (repeatable)]:dir:_directories' \
      '-resample+[sample-rate conversion mode]:mode:(0 1 2 3)' \
      '1:Faust DSP file:_files -g "*.dsp"'
    ;;

  faust2jaqt)
    # Compiles Faust to JACK + Qt (cross-platform). Adds -deploy
    # (force self-contained app generation; opposite of caqt's
    # -nodeploy) + -resample (sample-rate-conversion mode).
    _arguments -s -S \
      "${_faust2_shared[@]}" \
      '-deploy[force self-contained app generation (macOS macdeployqt step)]' \
      '-resample+[sample-rate conversion mode]:mode:(0 1 2 3)' \
      '1:Faust DSP file:_files -g "*.dsp"'
    ;;

esac
