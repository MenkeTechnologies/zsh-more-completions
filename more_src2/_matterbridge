#compdef matterbridge
# _matterbridge — chat-protocol bridge daemon (42wim/matterbridge)
# upstream: https://github.com/42wim/matterbridge
# Flags from matterbridge.go (flag).

_matterbridge() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[show version]' \
        '-conf=[config file]:file:_files -g "*.toml"' \
        '-debug[enable debug logging]' \
        '-gops[enable gops agent]'
}

_matterbridge "$@"
