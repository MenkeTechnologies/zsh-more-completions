#compdef falconctl
# Documentation: https://crowdstrike.github.io/ansible_collection_falcon/falconctl_module.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

# CrowdStrike Falcon Sensor configuration utility
# Action flags: -s (set), -g (get), -d (delete), -f (force)

_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-s[set sensor configuration]' \
  '-g[get sensor configuration]' \
  '-d[delete sensor configuration value]' \
  '-f[force]' \
  '--cid=[Customer ID]:cid:' \
  '--aid[agent ID]' \
  '--rfm-state[reduced functionality mode state]' \
  '--rfm-reason[RFM reason]' \
  '--rfm-history[RFM history]' \
  '--apd=[proxy enabled (TRUE/FALSE)]:bool:(TRUE FALSE)' \
  '--aph=[proxy host]:host:_hosts' \
  '--app=[proxy port]:port:' \
  '--tags[get sensor tags]' \
  '--tags=[set sensor tags]:tags:' \
  '--billing=[billing flag]:flag:(metered default)' \
  '--provisioning-token=[provisioning token]:token:' \
  '--maintenance-token=[maintenance token]:token:' \
  '--trace=[tracing level]:level:(none err warn info debug all)' \
  '--feature=[enable/disable feature]:feature:(none enableLog disableLogBuffer)' \
  '--cloud=[cloud region]:region:(us-1 us-2 eu-1 us-gov-1 us-gov-2)' \
  '--backend=[sensor backend]:backend:(auto bpf kernel)' \
  '--metadata-query=[metadata query flag]:flag:' \
  '--message-log=[disk message logging]:bool:(TRUE FALSE)' \
  '--version[print sensor version]' \
  '--license[show license]' \
  '*::passthrough:' && ret=0

return ret
