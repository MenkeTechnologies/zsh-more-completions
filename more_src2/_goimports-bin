#compdef goimports
# _goimports-bin — goimports format Go files and update imports (Brad Fitzpatrick, Go); superset of gofmt with auto-import management
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/goimports

_goimports-bin() {
    _arguments \
        '-d[display diffs]' \
        '-e[show all errors]' \
        '-l[list non-formatted files]' \
        '-w[write to file]' \
        '-format-only[skip import resolution]' \
        '-local+[local imports prefix]:prefix:' \
        '-srcdir+[source dir context]:dir:_files -/' \
        '-v[verbose]' \
        '-cpuprofile+[CPU profile]:file:_files' \
        '-memprofile+[memory profile]:file:_files' \
        '-memrate+[memory profile rate]:n:' \
        '-trace+[trace file]:file:_files' \
        '*:file or dir:_files'
}

_goimports-bin "$@"
