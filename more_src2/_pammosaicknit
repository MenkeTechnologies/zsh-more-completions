#compdef pammosaicknit
# Documentation: man pammosaicknit (Netpbm)
# Source: knit together a mosaic image from a Netpbm tile set.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm tile set:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
