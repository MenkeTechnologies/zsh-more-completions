#compdef keyhead
# _keyhead — rename FITS header keywords (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from keyhead.c (single-letter getopt-style).

_keyhead() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-h+[set HISTORY string]:hist:' \
        '-k+[set KEYHEAD keyword]:keyword:' \
        '-l+[log changed files]:file:_files' \
        '(-n -r)-n[write changes to a new file]' \
        '(-n -r)-r[write changes to a new file]' \
        '-v[verbose output]' \
        '1:FITS file:_files -g "*.(fits|fit|fts)"' \
        '*:OLDKEY=NEWKEY:'
}

_keyhead "$@"
