#compdef gobang
# Documentation: https://github.com/TaKO8Ki/gobang
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config-path)'{-c+,--config-path=}'[config file]:config file:_files' && ret=0

return ret
