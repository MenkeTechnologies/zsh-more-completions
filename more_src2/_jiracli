#compdef jiracli
# Documentation: https://github.com/toabctl/jiracli
# Reference accessed: 2026-05-19
# Verified: upstream jiracli/__init__.py argparse at the URL above.

# jiracli: command-line interface to Atlassian JIRA (toabctl/jiracli).
# Flag-based interface (no subcommands); auth via ~/.jiracli.ini.
local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '--no-verify[do not verify SSL certificate]' \
  '--no-color[disable colored output]' \
  '--issue-type-list[list available issue types]' \
  '--issue-link-types-list[list available issue link types]' \
  '--project-list[list available projects]' \
  '--project-list-components[list components of a project]:project:' \
  '(-m --message)'{-m,--message}'[message text]:message:' \
  '(-d --description)'{-d,--description}'[issue description]:description:' \
  '--filter-list-fav[list favorite filters]' \
  '(-c --issue-create)'{-c,--issue-create}'[create an issue]:args:' \
  '--issues-create[create multiple issues from file]:args:' \
  '(-i --issue)'{-i,--issue}'[show issue(s)]:issue:' \
  '--issue-search[search issues with JQL]:query:' \
  '--issue-search-by-filter[search issues by filter ID]:filter:' \
  '--issue-desc[display issue description]' \
  '--issue-comments[list issue comments]' \
  '--issue-trans[list possible transitions]' \
  '--issue-oneline[short overview format]' \
  '--sprint[show current sprint of a project]:project:' \
  '--issue-comment-add[add a comment to an issue]:issue:' \
  '--issue-label-add[add a label to an issue]:args:' \
  '--issue-label-remove[remove a label from an issue]:args:' \
  '--issue-component-add[add a component to an issue]:args:' \
  '--issue-component-remove[remove a component from an issue]:args:' \
  '--issue-trans-open[transition issue(s) to open]:issue:' \
  '--issue-trans-start[transition issue(s) to start progress]:issue:' \
  '--issue-trans-resolve[transition issue(s) to resolved]:issue:' \
  '--issue-trans-close[transition issue(s) to closed]:issue:' \
  '--issue-trans-custom[run a custom transition on an issue]:args:' \
  '--issue-watch-add[add watcher to issue(s)]:issue:' \
  '--issue-watch-remove[remove watcher from issue(s)]:issue:' \
  '--issue-assign[assign an issue to a user]:args:' \
  '--issue-fix-version-add[add fix version to issue(s)]:issue:' \
  '--issue-fix-version-remove[remove fix version from issue(s)]:issue:' \
  '--issue-parent[parent issue key of a subtask]:parent:' && ret=0
return ret
