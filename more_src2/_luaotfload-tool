#compdef luaotfload-tool
# _luaotfload-tool — Hans Hagen Khaled Hosny luaotfload-tool CLI for managing luaotfload font database used by LuaTeX building cache search formats listing OpenType variation axes (luaotfload team, Lua); custom argparse
# upstream: https://github.com/latex3/luaotfload

_luaotfload-tool() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-u[update database]' \
        '--update[update database]' \
        '-f[force update]' \
        '--force[force update]' \
        '-F[full update]' \
        '--full[full update]' \
        '--list=+[criterion]:c:(name family subfamily fullname psname location size)' \
        '-L+[criterion]:c:(name family subfamily fullname psname location size)' \
        '--find=+[name]:str:' \
        '-i+[name]:str:' \
        '--info=+[name or file]:str:' \
        '-I+[name or file]:str:' \
        '--show-blacklist[show blacklist]' \
        '--diagnose=+[area]:a:(files index format permissions environment locations cache)' \
        '--cache=+[action]:a:(erase clear show purge)' \
        '--max-fonts=+[N]:n:' \
        '--no-reload[no reload]' \
        '--no-strip[no strip]' \
        '--prefer-texmf[prefer texmf]' \
        '--target=+[t]:t:(system local universal)' \
        '--font-filter=+[csv]:str:' \
        '--bisect=+[mode]:m:(run start status terminate reset)' \
        '-D[dry run]' \
        '--dry-run[dry run]' \
        '-l[list installed]' \
        '--log=+[file]:file:_files' \
        '*:name or file:'
}

_luaotfload-tool "$@"
