#compdef ineffassign
# _ineffassign-bin — Go ineffectual assignment detector (Greg Smith); flag dead-store style assignments
# upstream: https://github.com/gordonklaus/ineffassign

_ineffassign-bin() {
    _arguments \
        '-n[print rather than execute]' \
        '*:file or dir:_files'
}

_ineffassign-bin "$@"
