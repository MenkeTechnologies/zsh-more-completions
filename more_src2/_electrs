#compdef electrs
# _electrs — Roman Zeyde electrs efficient Rust implementation of Electrum protocol server backed by bitcoind (romanz team, Rust); clap-derive
# upstream: https://github.com/romanz/electrs

_electrs() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--conf=+[config file]:file:_files -g "*.toml"' \
        '--network=+[bitcoin network]:n:(bitcoin testnet regtest signet)' \
        '--daemon-dir=+[bitcoind dir]:dir:_files -/' \
        '--daemon-rpc-addr=+[bitcoind rpc]:str:' \
        '--daemon-p2p-addr=+[bitcoind p2p]:str:' \
        '--electrum-rpc-addr=+[electrum rpc]:str:' \
        '--monitoring-addr=+[prometheus addr]:str:' \
        '--db-dir=+[db dir]:dir:_files -/' \
        '--auth=+[bitcoind cookie]:file:_files' \
        '--cookie=+[bitcoind cookie file]:file:_files' \
        '--cookie-file=+[bitcoind cookie file]:file:_files' \
        '--reindex-last-blocks=+[N]:n:' \
        '--ignore-mempool[do not index mempool]' \
        '--sync-once[sync once and exit]' \
        '--server-banner=+[banner]:str:' \
        '--signet-magic=+[magic]:str:' \
        '--wait-duration-secs=+[secs]:n:' \
        '--electrum-banner=+[banner]:str:' \
        '--electrum-rpc-logging=+[mode]:m:(none requests responses both)' \
        '--index-batch-size=+[N]:n:' \
        '--index-lookup-limit=+[N]:n:' \
        '--tx-cache-size=+[N]:n:' \
        '--blocktxids-cache-size=+[N]:n:' \
        '--jsonrpc-timeout-ms=+[ms]:n:' \
        '--log-filters=+[filters]:str:' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--timestamp[timestamps in log]'
}

_electrs "$@"
