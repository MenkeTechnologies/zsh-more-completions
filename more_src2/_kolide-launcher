#compdef kolide-launcher kolide_launcher launcher
# _kolide-launcher — Kolide launcher CLI for the cross-platform osquery wrapper extension daemon connecting endpoints to Kolide K2 or Fleet remote-management server via gRPC mTLS notary updates (kolide team, Go); flag
# upstream: https://github.com/kolide/launcher

_kolide-launcher() {
    local -a sub=(
        'version:show version'
        'doctor:run diagnostic checks'
        'flare:upload diagnostic flare'
        'svc:Windows service operations'
        'desktop:run launcher desktop'
        'query:run query'
        'socket:open socket'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-debug[debug]' \
        '--debug[debug]' \
        '-config=+[file]:file:_files -g "*.flags"' \
        '--config=+[file]:file:_files -g "*.flags"' \
        '-hostname=+[host]:h:_hosts' \
        '--hostname=+[host]:h:_hosts' \
        '-enroll_secret=+[secret]:str:' \
        '--enroll_secret=+[secret]:str:' \
        '-enroll_secret_path=+[file]:file:_files' \
        '--enroll_secret_path=+[file]:file:_files' \
        '-root_directory=+[dir]:dir:_files -/' \
        '--root_directory=+[dir]:dir:_files -/' \
        '-osquery_path=+[file]:file:_files' \
        '--osquery_path=+[file]:file:_files' \
        '-insecure[allow self-signed certs]' \
        '--insecure[allow self-signed certs]' \
        '-insecure_transport[insecure transport]' \
        '--insecure_transport[insecure transport]' \
        '-insecure_grpc[insecure grpc]' \
        '--insecure_grpc[insecure grpc]' \
        '-cert_pins=+[csv]:str:' \
        '--cert_pins=+[csv]:str:' \
        '-control[enable control endpoint]' \
        '--control[enable control endpoint]' \
        '-control_hostname=+[host]:h:_hosts' \
        '--control_hostname=+[host]:h:_hosts' \
        '-auto-update[enable auto update]' \
        '--autoupdate[enable auto update]' \
        '-update_channel=+[chan]:c:(stable beta nightly)' \
        '--update_channel=+[chan]:c:(stable beta nightly)' \
        '-notary_url=+[url]:str:' \
        '--notary_url=+[url]:str:' \
        '-disable_control_tls=+[b]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kolide-launcher subcommand' sub ;;
        args) ;;
    esac
}

_kolide-launcher "$@"
