#compdef pepwheel
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/pepwheel.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS pepwheel: alpha-helical wheel projection plot
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[protein sequence]:protein USA:_files' \
  '-steps=[residues per turn (numerator) 2-100]:steps:' \
  '-turns=[residues per turn (denominator) 1-100]:turns:' \
  '-wheel[enable wheel plotting]' \
  '-amphipathic[mark amphipathic residues]' \
  '-squares=[residues to mark with squares]:codes:' \
  '-diamonds=[residues to mark with diamonds]:codes:' \
  '-octags=[residues to mark with octagons]:codes:' \
  '-graph=[graph output format]:format:(x11 png ps cps colourps eps gif pdf svg hp7470 hp7580 meta data none tek tekt xterm text das)' \
  '*:protein USA:_files' && ret=0
return ret
