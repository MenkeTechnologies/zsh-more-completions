#compdef mkdocs-serve
# Documentation: https://www.mkdocs.org/user-guide/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: mkdocs-serve is a wrapper around `mkdocs serve`;
# flags mirror the upstream mkdocs serve subcommand.

_arguments -s -S \
  '(- *)--help[show help]' \
  '-a+[IP and port to listen on]:address' \
  '--dev-addr=[IP and port to listen on]:address' \
  '-f+[config file path]:config:_files -g "*.yml(-.)"' \
  '--config-file=[config file path]:config:_files -g "*.yml(-.)"' \
  '--no-livereload[disable live reloading]' \
  '--dirty[only rebuild changed pages]' \
  '-c[rebuild all pages]' \
  '--clean[rebuild all pages]' \
  '--watch-theme[watch the theme for changes]' \
  '*-w+[watch additional path]:path:_files' \
  '*--watch=[watch additional path]:path:_files' \
  '-t+[theme]:theme:(mkdocs readthedocs material)' \
  '--theme=[theme]:theme:(mkdocs readthedocs material)' \
  '--use-directory-urls[use directory URLs]' \
  '--no-directory-urls[do not use directory URLs]' \
  '-s[enable strict mode]' \
  '--strict[enable strict mode]' \
  '--no-strict[disable strict mode]' \
  '-q[silence warnings]' \
  '--quiet[silence warnings]' \
  '-v[enable verbose output]' \
  '--verbose[enable verbose output]' && return 0
