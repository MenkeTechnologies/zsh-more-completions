#compdef fclones
# Documentation: https://github.com/pkolaczk/fclones
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a commands=(
      'group:find duplicate files'
      'remove:remove duplicate files'
      'link:replace duplicates with links'
      'dedupe:deduplicate files using reflinks/COW'
      'move:move duplicate files'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  args)
    case "$words[1]" in
      group)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--depth=[max recursion depth]:depth:' \
          '(-s --min-size)'{-s+,--min-size=}'[minimum file size]:size:' \
          '--max-size=[maximum file size]:size:' \
          '(-n --name)'{-n+,--name=}'[match by filename pattern]:pattern:' \
          '--path=[match by path pattern]:pattern:' \
          '--exclude=[exclude pattern]:pattern:' \
          '--hidden[include hidden files]' \
          '--no-ignore[ignore .gitignore/.fdignore]' \
          '(-L --follow-links)'{-L,--follow-links}'[follow symbolic links]' \
          '--threads=[thread count configuration]:count:' \
          '--hash-fn=[hash algorithm]:fn:(metro xxhash3 blake3 sha256 sha512 sha3-256 sha3-512)' \
          '(-f --format)'{-f+,--format=}'[output format]:format:(default fdupes csv json)' \
          {-o+,--output=}'[output file]:file:_files' \
          '--isolate[match files across directory trees only]' \
          '--cache[enable hash caching]' \
          '--transform=[apply external preprocessing]:cmd:' \
          '--stdin[read file list from stdin]' \
          '*:path:_files -/' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dry-run[do not actually remove files]' \
          '--priority=[ordering priority]:priority:(newest oldest most-nested least-nested newest-mod oldest-mod)' \
          '--keep-name=[protect files matching name]:pattern:' \
          '--keep-path=[protect files matching path]:pattern:' \
          '-n+[number of replicas to preserve]:n:' \
          '--no-progress[disable progress bar]' \
          '1:input file:_files' && ret=0
        ;;
      link)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dry-run[do not actually link files]' \
          '(-s --soft)'{-s,--soft}'[create soft links instead of hard links]' \
          '--no-progress[disable progress bar]' \
          '1:input file:_files' && ret=0
        ;;
      dedupe)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dry-run[do not actually deduplicate]' \
          '--no-progress[disable progress bar]' \
          '1:input file:_files' && ret=0
        ;;
      move)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--dry-run[do not actually move files]' \
          '--no-progress[disable progress bar]' \
          '--target=[target directory]:dir:_directories' \
          '1:input file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
