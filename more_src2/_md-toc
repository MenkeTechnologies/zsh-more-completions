#compdef md-toc md_toc
# Documentation: https://github.com/frnmst/md-toc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'cmark:CommonMark parser (alias: goldmark)'
  'goldmark:Goldmark parser (alias of cmark)'
  'github:GitHub Flavored Markdown parser (alias: commonmarker)'
  'commonmarker:CommonMarker parser (alias of github)'
  'gitlab:GitLab parser'
  'redcarpet:Redcarpet parser'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-p --in-place)'{-p,--in-place}'[overwrite the input file]' \
  '(-d --diff)'{-d,--diff}'[return 128 if the new TOC differs from current]' \
  '(-l --no-links)'{-l,--no-links}'[do not add links to the TOC]' \
  '(-m --toc-marker)'{-m+,--toc-marker=}'[TOC marker string]:marker:' \
  '(-n --newline-string)'{-n+,--newline-string=}'[line separator]:nl:' \
  '(-s --skip-lines)'{-s+,--skip-lines=}'[skip the first N lines]:n:' \
  '(-c --no-list-coherence -i --no-indentation)'{-c,--no-list-coherence}'[skip list coherence check]' \
  '(-c --no-list-coherence -i --no-indentation)'{-i,--no-indentation}'[omit indentations from TOC]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'md-toc parser' commands && ret=0 ;;
  (args)
    _arguments \
      '(-u --unordered-list-marker -o --ordered-list-marker)'{-u+,--unordered-list-marker=}'[unordered list marker]:char:' \
      '(-u --unordered-list-marker -o --ordered-list-marker)'{-o+,--ordered-list-marker=}'[ordered list closing marker]:char:' \
      '(-c --constant-ordered-list)'{-c,--constant-ordered-list}'[use a single integer for all ordered markers]' \
      '(-l --header-levels)'{-l+,--header-levels=}'[max header depth]:n:(1 2 3 4 5 6)' \
      '*:markdown:_files -g "*.(md|markdown)"' && ret=0
    ;;
esac

return ret
