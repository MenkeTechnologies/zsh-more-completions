#compdef prow-exporter
# _prow-exporter — Prow Prometheus exporter for ProwJob metrics (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/exporter/main.go (flag).

_prow-exporter() {
    _arguments \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files'
}

_prow-exporter "$@"
