#compdef mill-cli
# _mill-cli — Mill Scala/Java build tool CLI alias (Li Haoyi / Mill team, Scala); custom argparse
# upstream: https://github.com/com-lihaoyi/mill

_mill-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--interactive[interactive]' \
        '-i[interactive]' \
        '--no-server[no background server]' \
        '--bsp-install[install BSP]' \
        '--bsp[start BSP server]' \
        '--watch[watch and re-execute]' \
        '-w[watch and re-execute]' \
        '--debug[debug output]' \
        '-d[debug output]' \
        '--ticker=+[show ticker]:b:(true false)' \
        '-t+[show ticker]:b:(true false)' \
        '--keep-going[keep going on errors]' \
        '-k[keep going on errors]' \
        '--jobs=+[parallel jobs]:n:' \
        '-j+[parallel jobs]:n:' \
        '--meta-level=+[meta level]:n:' \
        '--no-default-predef[no default predef]' \
        '--predef-code=+[predef code]:str:' \
        '--define=+[define key=value]:list:' \
        '-D+[define key=value]:list:' \
        '--repl[start repl]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--disable-callgraph[disable callgraph optimisation]' \
        '--system-property=+[system property]:list:' \
        '-J+[system property]:list:' \
        '--rest-of-args[pass args]' \
        '--repl-history=+[repl history file]:file:_files' \
        '--bsp-protocol-version=+[bsp version]:str:' \
        '--allow-positional[allow positional args]' \
        '--allow-empty-args[allow empty args]' \
        '*:task:'
}

_mill-cli "$@"
