#compdef lnk
# Documentation: https://github.com/yarlson/lnk
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# yarlson/lnk — git-native dotfiles (`lnk --help`)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'lnk command' compadd -- init add rm list status diff push pull doctor bootstrap
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
