#compdef git-summary
# Documentation: https://github.com/MirkoLedda/git-summary
# Source: MirkoLedda/git-summary — multi-repo status summary script.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-l[local-only summary; skip remote fetches]' \
    '-d[deep search through the entire directory tree]' \
    '-q[quiet mode (only outdated repos)]' \
    '-s[sorted output (sequential)]' \
    '-f[show full repository paths]' \
    '(- *)-h[show help]' \
    '1:path:_files -/' \
    && ret=0

return ret
