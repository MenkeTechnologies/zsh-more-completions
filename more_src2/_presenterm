#compdef presenterm
# Documentation: https://github.com/mfontanini/presenterm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for presenterm
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-p --present)'{-p,--present}'[use presentation mode]' \
  '--export-pdf[export presentation to PDF]' \
  '--export-html[export presentation to HTML]' \
  '(-o --output)'{-o+,--output=}'[output path for exported file]:file:_files' \
  '--export-temporary-path=[temporary files directory during export]:dir:_files -/' \
  '(-t --theme)'{-t+,--theme=}'[theme name]:theme:' \
  '--force-default-theme[force the default theme]' \
  '--current-theme[print the theme currently in use]' \
  '--list-themes[list available themes]' \
  '(-c --config-file)'{-c+,--config-file=}'[configuration file]:file:_files' \
  '--acknowledgements[show acknowledgements]' \
  '--generate-config-file-schema[output JSON schema for the config file]' \
  '(-x --enable-snippet-execution)'{-x,--enable-snippet-execution}'[allow code snippet execution]' \
  '(-X --enable-snippet-execution-replace)'{-X,--enable-snippet-execution-replace}'[enable auto-execution via blocks]' \
  '--validate-snippets[verify snippets]' \
  '--validate-overflows[verify presentation fits the terminal]' \
  '--image-protocol=[image rendering protocol]:protocol:(auto kitty iterm sixel)' \
  '(-P --publish-speaker-notes)'{-P,--publish-speaker-notes}'[publish speaker notes locally]' \
  '(-l --listen-speaker-notes)'{-l,--listen-speaker-notes}'[listen for speaker notes]' \
  '--list-comment-commands[list available comment commands]' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:markdown file:_files -g "*.md"' && ret=0
return ret
