#compdef dissent
# Documentation: https://github.com/diamondburned/dissent
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dissent is a GTK4 Discord client (formerly gtkcord4) with no documented CLI
# subcommands; only the standard GTK/glib --help options apply.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' && ret=0

return ret
