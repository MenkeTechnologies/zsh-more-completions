#compdef littler r
# Documentation: https://github.com/eddelbuettel/littler
# Reference accessed: 2026-05-27
# Verified: upstream src/littler.c optargs and getopt_long short-option string "+hVve:npl:L:tqid"

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[print help and exit]' \
  '(- *)--usage[print brief usage and exit]' \
  '(- *)'{-V,--version}'[print version and exit]' \
  '(-v --vanilla)'{-v,--vanilla}'[pass --vanilla to R]' \
  '(-e --eval)'{-e+,--eval=}'[evaluate the given R expression]:expression:' \
  '(-l --packages)'{-l+,--packages=}'[comma-separated packages to load]:packages:' \
  '(-p --verbose)'{-p,--verbose}'[print expression values]' \
  '(-t --rtemp)'{-t,--rtemp}'[use a per-session temporary directory]' \
  '(-q --quick)'{-q,--quick}'[skip autoload of default libraries]' \
  '(-i --interactive)'{-i,--interactive}'[set interactive() to return TRUE]' \
  '(-d --datastdin)'{-d,--datastdin}'[prepend command to load stdin as CSV into X]' \
  '(-L --libpath)'{-L+,--libpath=}'[add directory to library search path]:dir:_files -/' \
  '*:file:_files' && ret=0

return ret
