#compdef nuclei
# _nuclei-bin — ProjectDiscovery nuclei template-based vulnerability scanner (Go); YAML-template-driven authorized recon
# upstream: https://github.com/projectdiscovery/nuclei

_nuclei-bin() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-u+[target URL]:url:_urls' \
        '-l+[input list file]:file:_files' \
        '-t+[template file or glob]:str:' \
        '-w+[workflow files]:str:' \
        '-templates+[templates path]:dir:_files -/' \
        '-workflows+[workflows path]:dir:_files -/' \
        '-template-id+[template IDs]:ids:' \
        '-author+[author filter]:author:' \
        '-tags+[tag filter]:tags:' \
        '-severity+[severity filter]:list:(info low medium high critical unknown)' \
        '-include-tags+[force include tags]:tags:' \
        '-exclude-tags+[exclude tags]:tags:' \
        '-include-severity+[force include severity]:list:' \
        '-exclude-severity+[exclude severity]:list:' \
        '-include-templates+[force include templates]:str:' \
        '-exclude-templates+[exclude templates]:str:' \
        '-o+[output file]:file:_files' \
        '-no-color[no color]' \
        '-json[json output]' \
        '-jsonl[json lines]' \
        '-irr[include request/response in json]' \
        '-csv[csv output]' \
        '-sarif-export+[sarif file]:file:_files' \
        '-validate[validate templates]' \
        '-c+[concurrency]:n:' \
        '-bs+[bulk size]:n:' \
        '-headless-bs+[headless bulk size]:n:' \
        '-rl+[rate limit]:n:' \
        '-timeout+[timeout sec]:n:' \
        '-retries+[retries]:n:' \
        '-rate-limit-minute+[rate per min]:n:' \
        '-headless[use chrome]' \
        '-show-browser[show browser]' \
        '-proxy+[proxy URL]:url:_urls' \
        '-r+[resolvers file]:file:_files' \
        '-system-resolvers[use system resolvers]' \
        '-passive[passive scan]' \
        '-fr[follow redirects]' \
        '-mhe+[max host errors]:n:' \
        '-e+[ENV variable]:str:' \
        '-iv+[input vars]:str:' \
        '-stats[show stats]' \
        '-silent[silent]' \
        '-v[verbose]' \
        '-debug[debug]' \
        '-update-templates[update templates]' \
        '-update[update nuclei]' \
        '-validate[validate templates]' \
        '-no-meta[no metadata in output]' \
        '-no-mhe[do not exit on max host errors]' \
        '*:target:'
}

_nuclei-bin "$@"
