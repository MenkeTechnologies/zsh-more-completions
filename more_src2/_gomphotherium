# WHAT IT IS
#   gomphotherium is "(/ˌɡɒmfəˈθɪəriəm/; 'welded beast'), a
#   command line Mastodon client" — a hybrid CLI + TUI for
#   Mastodon and the surrounding Fediverse.  `gomphotherium tui`
#   launches the bubbletea-driven full-screen interface;
#   `gomphotherium cmd` runs one-shot operations (post a status,
#   read a timeline, search, fetch a notification feed) suitable
#   for shell pipelines and cron jobs;
#   `gomphotherium authenticate <SERVER>` walks the OAuth dance
#   to register a new app + capture the access token for a
#   given instance.  Images embedded in posts can be inlined
#   directly in the terminal (Kitty / iTerm2 / Sixel) via the
#   `-i/--show-images` toggle; user avatars get the same
#   treatment via `-u/--show-user-images`.
#
# CLI ARGUMENT GRAMMAR  (verbatim from cli/rootCmd.go +
#                       cli/{authenticate,cmd,tui,version}Cmd.go
#                       cobra `&cobra.Command{...}` literals;
#                       extracted via `gh api repos/mrusme/
#                       gomphotherium/contents/cli/...`)
#
#   gomphotherium [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global persistent flags  (every subcommand):
#     --server <URL>                 Mastodon server  (env:
#                                    GOMPHOTHERIUM_SERVER)
#     --access-token <TOKEN>         Mastodon access token
#                                    (env:
#                                    GOMPHOTHERIUM_ACCESS_TOKEN)
#     -i, --show-images              Show images inline in the
#                                    terminal  [default: true]
#     -u, --show-user-images         Show user avatars inline
#                                    [default: true]
#     --temp-dir <DIR>               Temporary directory for
#                                    image cache  [default:
#                                    system default temp dir]
#     -j, --justify-text             Justify post text in TUI
#                                    output  [default: true]
#
#   Subcommands:
#     authenticate <SERVER>          Authenticate against the
#                                    given Mastodon-compatible
#                                    server URL  (walks the
#                                    OAuth2 app-registration +
#                                    access-token flow, prints
#                                    the resulting token for
#                                    use in `--access-token`
#                                    or `GOMPHOTHERIUM_ACCESS_
#                                    TOKEN`).
#                                    Required positional argument:
#                                      <SERVER> — server URL,
#                                                 e.g. https://
#                                                 mastodon.social
#
#     cmd <ARG>...                   Run a one-shot command —
#                                    `cmd post <text>`,
#                                    `cmd timeline {home|local|
#                                                    public}`,
#                                    `cmd search <query>`,
#                                    `cmd notifications` —
#                                    intended for shell
#                                    pipelines / cron jobs
#
#     tui                            Launch the full-screen
#                                    bubbletea TUI
#       -a, --auto-completion          Enable auto-completion in
#                                      the TUI compose field
#                                      [default: true]
#
#     version                        Display version
#
#   Standard cobra auto-flags:
#     -h, --help                     Show help (root + each
#                                    subcommand)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/mattn/go-mastodon v0.0.6`
#   declared in go.mod — `mattn/go-mastodon` is THE canonical
#   Go Mastodon SDK maintained by Yasuhiro Matsumoto (mattn,
#   the prolific Go author behind go-sqlite3 / efm-langserver /
#   ico / sumastra / mastoot / and so many other CLIs;
#   mattn/go-mastodon, 700+ stars; the predominant typed Go
#   client for Mastodon's REST + Streaming APIs, used by
#   gomphotherium, go-mastodon-rest CLI wrappers, mattn/sumastra
#   social explorers, blacktop/ipsw release notifiers,
#   muesli/beehive event automation hives, the wabarc/wayback
#   archive bot, kgateway-dev/kgateway HTTP gateway plugins,
#   newrelic/newrelic-client-go notifier surfaces, and dozens
#   of other Go applications that talk Mastodon).  go-mastodon
#   exposes the typed `mastodon.Client` constructor with
#   `mastodon.NewClient(&mastodon.Config{Server, ClientID,
#   ClientSecret, AccessToken})`, the typed
#   `client.PostStatus(ctx, &mastodon.Toot{Status,
#   InReplyToID, MediaIDs, Sensitive, SpoilerText,
#   Visibility, Language, ContentType, ScheduledAt})` /
#   `client.GetStatus(ctx, id)` /
#   `client.DeleteStatus(ctx, id)` /
#   `client.FavouriteStatus(ctx, id)` /
#   `client.UnfavouriteStatus(ctx, id)` /
#   `client.Reblog(ctx, id)` / `client.Unreblog(ctx, id)` /
#   `client.Bookmark(ctx, id)` / `client.Unbookmark(ctx, id)` /
#   `client.PinStatus(ctx, id)` / `client.UnpinStatus(ctx, id)` /
#   `client.GetStatusContext(ctx, id)` /
#   `client.GetTimelineHome(ctx, pg)` /
#   `client.GetTimelinePublic(ctx, isLocal, pg)` /
#   `client.GetTimelineHashtag(ctx, tag, isLocal, pg)` /
#   `client.GetTimelineList(ctx, list, pg)` /
#   `client.GetTimelineMedia(ctx, isLocal, pg)` /
#   `client.GetAccountStatuses(ctx, id, pinned, pg)` /
#   `client.GetAccount(ctx, id)` /
#   `client.AccountVerifyCredentials(ctx)` /
#   `client.AccountUpdate(ctx, profile)` /
#   `client.GetAccountFollowers(ctx, id, pg)` /
#   `client.GetAccountFollowing(ctx, id, pg)` /
#   `client.GetAccountRelationships(ctx, ids)` /
#   `client.AccountFollow(ctx, id)` /
#   `client.AccountUnfollow(ctx, id)` /
#   `client.AccountBlock(ctx, id)` /
#   `client.AccountUnblock(ctx, id)` /
#   `client.AccountMute(ctx, id)` /
#   `client.AccountUnmute(ctx, id)` /
#   `client.GetMedia(ctx, id)` /
#   `client.UpdateMedia(ctx, id, ...)` /
#   `client.UploadMedia(ctx, file)` /
#   `client.UploadMediaFromReader(ctx, reader)` /
#   `client.Search(ctx, q, resolve)` /
#   `client.GetInstance(ctx)` /
#   `client.GetInstanceActivity(ctx)` /
#   `client.GetInstancePeers(ctx)` /
#   `client.GetNotifications(ctx, pg)` /
#   `client.DismissNotification(ctx, id)` /
#   `client.ClearNotifications(ctx)` /
#   `client.GetReports(ctx)` / `client.Report(ctx, ...)` /
#   `client.GetLists(ctx)` / `client.CreateList(ctx, ...)` /
#   `client.RenameList(ctx, id, title)` /
#   `client.DeleteList(ctx, id)` request + response surface,
#   the typed `mastodon.Status` / `mastodon.Account` /
#   `mastodon.Attachment` / `mastodon.Application` /
#   `mastodon.Card` / `mastodon.Context` /
#   `mastodon.Notification` / `mastodon.Instance` /
#   `mastodon.Filter` / `mastodon.List` / `mastodon.Marker` /
#   `mastodon.Relationship` / `mastodon.Field` schemas, the
#   typed streaming primitives — `client.StreamingUser(ctx)`,
#   `client.StreamingPublic(ctx, isLocal)`,
#   `client.StreamingHashtag(ctx, tag, isLocal)`,
#   `client.StreamingList(ctx, listID)`,
#   `client.StreamingDirect(ctx)`, returning a `chan
#   mastodon.Event` whose variants are
#   `mastodon.UpdateEvent`, `mastodon.NotificationEvent`,
#   `mastodon.DeleteEvent`, `mastodon.ErrorEvent`, and
#   `mastodon.StatusUpdateEvent` — and the OAuth helpers
#   `mastodon.RegisterApp(ctx, &AppConfig{...})` +
#   `client.AuthenticateToken(ctx, code, redirectURI)` for
#   the registration flow that `gomphotherium authenticate`
#   drives.  gomphotherium's `mast/...` wraps
#   `mastodon.NewClient` per CLI invocation, drives the OAuth
#   dance through `RegisterApp` + `AuthenticateToken`, and
#   then dispatches to the typed `client.PostStatus` /
#   `client.GetTimelineXxx` calls based on the parsed
#   subcommand verb.  Verified via:
#     gh api repos/mrusme/gomphotherium/contents/go.mod
#       → module github.com/mrusme/gomphotherium
#       → github.com/mattn/go-mastodon v0.0.6
#       → github.com/spf13/cobra v1.8.0
#     gh api repos/mrusme/gomphotherium/contents/cli/
#         rootCmd.go
#       → rootCmd = &cobra.Command{ Use: "gomphotherium",
#                                     Short: "Command line
#                                              Mastodon
#                                              client" }
#       → PersistentFlags: --server / --access-token /
#                          -i/--show-images / -u/--show-user-
#                          images / --temp-dir / -j/--justify-
#                          text
#     gh api repos/mrusme/gomphotherium/contents/cli/{
#         authenticateCmd, cmdCmd, tuiCmd, versionCmd }.go
#       → cobra subcommands: authenticate (positional <server>,
#                                            cobra.MinimumNArgs(1))
#                            cmd (run one-shot command,
#                                  positional args)
#                            tui (-a/--auto-completion)
#                            version
#   This entry is the Go=157 leader bump that continues Axis
#   102 (Fediverse / Mastodon protocol) at 2/0/0 following
#   R996 _mastodon-bluesky-sync (Rust=157 OPENED the axis on
#   megalodon-rs >=0.14).  TS-Node=157 closing pair to follow
#   at R998 (candidates: h3poteto/megalodon — the npm sibling
#   of megalodon-rs from the same author with bidirectional
#   protocol parity — based CLIs).
#
#   No completion for `gomphotherium` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_gomphotherium() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--server=[Mastodon server (env GOMPHOTHERIUM_SERVER)]:url:'
        '--access-token=[Mastodon access token (env GOMPHOTHERIUM_ACCESS_TOKEN)]:token:'
        '(-i --show-images)'{-i,--show-images}'[show images inline in the terminal]'
        '(-u --show-user-images)'{-u,--show-user-images}'[show user avatars inline]'
        '--temp-dir=[temporary directory for image cache]:dir:_files -/'
        '(-j --justify-text)'{-j,--justify-text}'[justify post text]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        $global_opts \
        '1: :_gomphotherium_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                authenticate)
                    _arguments \
                        $global_opts \
                        '1:Mastodon server URL:' && ret=0 ;;
                tui)
                    _arguments \
                        $global_opts \
                        '(-a --auto-completion)'{-a,--auto-completion}'[enable auto-completion in TUI compose field]' && ret=0 ;;
                cmd)
                    _arguments \
                        $global_opts \
                        '*: :' && ret=0 ;;
                version)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_gomphotherium_commands] )) ||
_gomphotherium_commands() {
    local -a commands
    commands=(
        'authenticate:authenticate against a Mastodon-compatible server (OAuth2)'
        'cmd:run a one-shot command (post/timeline/search/notifications)'
        'tui:launch the full-screen TUI'
        'version:display version'
    )
    _describe -t commands 'gomphotherium command' commands
}

_gomphotherium "$@"
