#compdef pyres_manager
# Documentation: https://github.com/binarydud/pyres/blob/master/pyres/scripts.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

typeset -A opt_args
local context state line

_arguments -s -S \
  "(- *)"{-h,--help}"[show help]" \
  "--host=[Redis host (default localhost)]:host:" \
  "--port=[Redis port (default 6379)]:port:" \
  "--password=[Redis password]:password:" \
  "(-i --interval)"{-i+,--interval=}"[manager sleep interval]:seconds:" \
  "--minions_interval=[minion sleep interval]:seconds:" \
  "(-l --log-level)"{-l+,--log-level=}"[log level]:level:(debug info warning error critical)" \
  "--pool=[number of minions (default 1)]:n:" \
  "(-j --process_max_jobs)"{-j+,--process_max_jobs=}"[max jobs per process (default 0)]:n:" \
  "-f+[logfile path]:file:_files" \
  "-p+[pidfile path]:file:_files" \
  "--concat_minions_logs[concatenate minion logs]" \
  "*:queue:" && return 0
