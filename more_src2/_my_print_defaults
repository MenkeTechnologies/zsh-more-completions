#compdef my_print_defaults
# Documentation: my_print_defaults --help (MySQL)
# Source: print options that would be read from MySQL config files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--defaults-file=[read this file only]:file:_files' \
    '--defaults-extra-file=[extra config file]:file:_files' \
    {-g+,--defaults-group-suffix=}'[also read groups with this suffix]:suffix:' \
    '--extra-file=[deprecated; --defaults-extra-file synonym]:file:_files' \
    {-n,--no-defaults}'[ignore default option files (except login)]' \
    {-l+,--login-path=}'[login path in login file]:name:' \
    {-s,--show}'[show passwords in plain text]' \
    {-v,--verbose}'[verbose]' \
    '*:option group:' \
    && ret=0

return ret
