#compdef mcrcon
# _mcrcon — Minecraft RCON client (Tiiffi/mcrcon)
# upstream: https://github.com/Tiiffi/mcrcon
# Flags from mcrcon.c.

_mcrcon() {
    local -a args
    args=(
        '-H+[server address (default localhost, also MCRCON_HOST)]:host:'
        '-P+[port (default 25575, also MCRCON_PORT)]:port:'
        '-p+[RCON password (also MCRCON_PASS)]:password:'
        '-t[terminal (interactive) mode]'
        '-s[silent mode]'
        '-c[disable colored output]'
        '-r[output raw packets]'
        '-w+[wait this many seconds between commands (1-600)]:seconds:'
        '-h[show help]'
        '-v[show version]'
        '*:rcon command:'
    )
    _arguments -s -S $args
}

_mcrcon "$@"
