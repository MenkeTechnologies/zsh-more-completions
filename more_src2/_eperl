#compdef eperl
# Documentation: man eperl(1)
# Source: gitpan/eperl eperl_main.c (master) — embedded Perl interpreter (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-d+,--define=}'[define Perl variable NAME=VALUE]:var:_default' \
    '*'{-D+,--setenv=}'[define environment variable NAME=VALUE]:var:_default' \
    '*'{-I+,--includedir=}'[add @INC/#include directory]:dir:_files -/' \
    '(-B --block-begin)'{-B+,--block-begin=}'[begin block delimiter]:str:_default' \
    '(-E --block-end)'{-E+,--block-end=}'[end block delimiter]:str:_default' \
    '(-n --nocase)'{-n,--nocase}'[case-insensitive delimiters]' \
    '(-k --keepcwd)'{-k,--keepcwd}'[keep current working directory]' \
    '(-P --preprocess)'{-P,--preprocess}'[enable ePerl preprocessor]' \
    '(-C --convert-entity)'{-C,--convert-entity}'[convert HTML entities in blocks]' \
    '(-L --line-continue)'{-L,--line-continue}'[enable line continuation via backslashes]' \
    '(-T --tainting)'{-T,--tainting}'[enable Perl tainting]' \
    '(-w --warnings)'{-w,--warnings}'[enable Perl warnings]' \
    '(-x --debug)'{-x,--debug}'[debug output on console]' \
    '(-m --mode)'{-m+,--mode=}'[runtime mode]:mode:(FILTER CGI NPH-CGI f c n)' \
    '(-o --outputfile)'{-o+,--outputfile=}'[output file]:file:_files' \
    '(-c --check)'{-c,--check}'[syntax check only and exit]' \
    '-r[(legacy) raw mode]' \
    '-l[(legacy) line mode]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '-V[show extended version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '*:script:_files -g "*.{pl,phtml,iphtml}"' \
    && ret=0

return ret
