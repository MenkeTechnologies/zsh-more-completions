#compdef pmxab
# Documentation: pmxab — PMX preprocessor (preludial music engraving).
# Source: pmxab BASENAME[.pmx] → BASENAME.tex (MusiXTeX source).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:pmx source basename:_files -g "*.pmx(:r)"' \
    && ret=0

return ret
