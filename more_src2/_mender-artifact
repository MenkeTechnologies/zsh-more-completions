#compdef mender-artifact
# Documentation: https://github.com/mendersoftware/mender-artifact
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mender-artifact

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'write:create an artifact (subcommands)'
  'read:inspect artifact file contents'
  'validate:validate an artifact'
  'sign:add a signature to an artifact'
  'modify:alter image or artifact files'
  'cp:transfer files into/out of artifacts'
  'cat:print artifact file contents to stdout'
  'install:place files/directories into an artifact'
  'rm:delete files from an artifact'
  'dump:extract raw components from an artifact'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'mender-artifact command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (write)
        _arguments '1:subcommand:(rootfs-image module-image bootstrap-artifact)' \
          '*:: :_files' && ret=0
        ;;
      (*) _files && ret=0 ;;
    esac
    ;;
esac

return ret
