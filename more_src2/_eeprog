#compdef eeprog
# Documentation: eeprog
# Source: i2c-tools eepromer/eeprog.c (master) — 24Cxx EEPROM reader/writer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-8 -16)-8[use 8-bit address mode (24c0x-24C16)]' \
    '(-8 -16)-16[use 16-bit address mode (24c32-24C256)]' \
    '(-r -w)-r+[read addr[\:count]]:addr:_default' \
    '(-r -w)-w+[write input at addr]:addr:_default' \
    '-h[show help]' \
    '-x[hex output mode]' \
    '-d[dummy mode (show what would happen)]' \
    '-f[disable warnings, no confirm]' \
    '-q[quiet mode]' \
    '1:I2C device:_files -g "/dev/i2c-*"' \
    '2:I2C address:_default' \
    && ret=0

return ret
