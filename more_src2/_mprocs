#compdef mprocs
# Documentation: https://github.com/pvolok/mprocs
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# Zsh completion for mprocs - run multiple processes in parallel

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--config=[path to config file]:file:_files -g "*.{yaml,yml,json,toml}"' \
  '--npm[run scripts from package.json]' \
  '--server=[remote control server address]:address:' \
  '--ctl=[send command to running instance]:command:' \
  '--on-init=[execute command on startup]:command:' \
  '--procfile=[Procfile to load processes from]:file:_files' \
  '*:command:_command_names -e' && ret=0

return ret
