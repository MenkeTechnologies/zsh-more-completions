#compdef nemoguardrails
# Documentation: https://github.com/NVIDIA-NeMo/Guardrails
# Reference accessed: 2026-05-23
# Verified: nemoguardrails --help (Typer CLI).

# Zsh completion for nemoguardrails - NVIDIA NeMo Guardrails CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'nemoguardrails command' \
      'chat[interactive chat session]' \
      'server[start NeMo Guardrails server]' \
      'convert[convert Colang configs to latest version]' \
      'actions-server[start actions server]' \
      'find-providers[list and select LLM providers]' \
      'eval[evaluate guardrail configuration]' && ret=0
    ;;
  args)
    case $line[1] in
      chat|actions-server)
        _arguments \
          '--config[configuration directory or file]:path:_files -/' \
          '--verbose[verbose logging]' && ret=0
        ;;
      server)
        _arguments \
          '--config[configuration directory or file]:path:_files -/' \
          '--verbose[verbose logging]' \
          '--port[server port]:port:' \
          '--default-config-id[default configuration id]:id:' && ret=0
        ;;
      eval)
        if (( CURRENT == 2 )); then
          _values 'eval command' \
            'run[run evaluation interactions]' \
            'check-compliance[check policy compliance]' \
            'ui[launch evaluation UI]' \
            'rail[run rail evaluation task]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
