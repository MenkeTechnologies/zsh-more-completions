#compdef otfinfo
# Documentation: otfinfo --help (lcdf-typetools)
# Source: report information about an OpenType font.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[print version]' \
    '(-s --scripts)'{-s,--scripts}'[report supported scripts]' \
    '(-f --features)'{-f,--features}'[report GSUB/GPOS features]' \
    '(-z --optical-size)'{-z,--optical-size}'[report optical size info]' \
    '(-p --postscript-name)'{-p,--postscript-name}'[report PostScript name]' \
    '(-a --family)'{-a,--family}'[report family name]' \
    '(-v --font-version)'{-v,--font-version}'[report version info]' \
    '(-i --info)'{-i,--info}'[report names + designer/vendor info]' \
    '(-g --glyphs)'{-g,--glyphs}'[report glyph names]' \
    '(-t --tables)'{-t,--tables}'[report OpenType tables]' \
    '(-u --unicode)'{-u,--unicode}'[report supported Unicode code points]' \
    '--variable[report variable-font info]' \
    '(-T --dump-table)'{-T+,--dump-table=}'[output named table contents]:table:' \
    '--script=[script[.lang] used for --features (default latn)]:script:' \
    '(-V --verbose)'{-V,--verbose}'[print progress info to stderr]' \
    '(-q --quiet)'{-q,--quiet}'[do not generate error messages]' \
    '*:font file:_files -g "*.(otf|ttf|otc|ttc)"' \
    && ret=0

return ret
