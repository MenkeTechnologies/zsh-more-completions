#compdef polipo
# _polipo — Polipo (small caching HTTP/1.1 + Tor SOCKS bridge proxy by Juliusz Chroboczek; -c config file, -h list config variables, -v print version, -e KEY=VAL apply runtime option, -q quiet; reads polipo.conf for cache-size, disk-cache-dir, allowedClients, parentProxy, parentSocks*, dnsQueryIPv6, etc.; deprecated upstream in favour of Privoxy + Tor)
# upstream: https://www.irif.fr/~jch/software/polipo/
# Flags from polipo main.c on tip.

_polipo() {
    _arguments \
        '-h[list config variables]' \
        '-v[show version]' \
        '-c+[config file]:file:_files' \
        '*-e+[KEY=VAL]:setting:' \
        '-q[quiet]'
}

_polipo "$@"
