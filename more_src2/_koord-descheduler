#compdef koord-descheduler
# _koord-descheduler — Koordinator descheduler with custom plugins (koordinator-sh/koordinator)
# upstream: https://github.com/koordinator-sh/koordinator
# Flags from cmd/koord-descheduler/app/options/options.go on tip.

_koord-descheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[descheduler configuration file]:file:_files' \
        '--write-config-to=[write effective config to file and exit]:file:_files' \
        '--master=[apiserver URL override]:url:_urls' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--leader-elect-resource-lock=[leader-election lock type]:lock:(leases configmaps configmapsleases endpoints endpointsleases)' \
        '--secure-port=[HTTPS bind port (0 disables)]:port:' \
        '--bind-address=[HTTPS bind address]:ip:' \
        '--tls-cert-file=[TLS cert file]:file:_files' \
        '--tls-private-key-file=[TLS key file]:file:_files' \
        '--cert-dir=[serving cert directory]:dir:_files -/' \
        '--feature-gates=[feature gate map (key=bool,...)]:gates:' \
        '-v[klog verbosity level]:n:'
}

_koord-descheduler "$@"
