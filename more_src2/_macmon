#compdef macmon
# Documentation: https://github.com/vladkens/macmon
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments \
  '-i[update interval in milliseconds]:ms' \
  '--interval[update interval in milliseconds]:ms' \
  '--color[color theme]:theme:(default dark light)' \
