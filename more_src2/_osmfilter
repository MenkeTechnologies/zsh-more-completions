#compdef osmfilter
# Documentation: https://manpages.debian.org/bookworm/osmctools/osmfilter.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm osmfilter(1) manpage.
# Removed from prior file: fabricated -V/--version and bogus
# man.archlinux.org search URL.

# osmfilter: OpenStreetMap data filter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--keep=[keep matching objects]:tags:' \
  '--keep-nodes=[keep matching nodes]:tags:' \
  '--keep-ways=[keep matching ways]:tags:' \
  '--keep-relations=[keep matching relations]:tags:' \
  '--keep-tags=[keep listed tags]:tags:' \
  '--drop=[drop matching objects]:tags:' \
  '--drop-nodes=[drop matching nodes]:tags:' \
  '--drop-ways=[drop matching ways]:tags:' \
  '--drop-relations=[drop matching relations]:tags:' \
  '--drop-tags=[drop listed tags]:tags:' \
  '--modify-tags=[modify tags]:rules:' \
  '--drop-author[drop author info]' \
  '--drop-version[drop version info]' \
  '--emulate-osmosis[mimic osmosis output]' \
  '--emulate-pbf2osm[mimic pbf2osm output]' \
  '--fake-author[use fake author info]' \
  '--fake-version[use fake version info]' \
  '--fake-lonlat[use fake coordinates]' \
  '--ignore-dependencies[do not preserve refs]' \
  '--out-key[output only object types and keys]' \
  '--out-count[count matching objects]' \
  '(--out-osc --out-osh --out-o5m --out-o5c)--out-osm[output XML format]' \
  '(--out-osm --out-osh --out-o5m --out-o5c)--out-osc[output OSC]' \
  '(--out-osm --out-osc --out-o5m --out-o5c)--out-osh[output OSH]' \
  '(--out-osm --out-osc --out-osh --out-o5c)--out-o5m[output O5M]' \
  '(--out-osm --out-osc --out-osh --out-o5m)--out-o5c[output O5C]' \
  '-o=[output file]:file:_files' \
  '-t=[temporary file prefix]:prefix:' \
  '--parameter-file=[parameter file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--hash-memory=[hash memory in MB]:n:' \
  '*:OSM file:_files -g "*.(osm|pbf|o5m)(-.)"' && ret=0
return ret
