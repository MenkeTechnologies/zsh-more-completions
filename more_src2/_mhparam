#compdef mhparam
# Documentation: man mhparam(1)
# Source: nmh uip/mhparam.c (master) — print nmh profile components (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-components -nocomponents)-components[print component names]' \
    '(-components -nocomponents)-nocomponents[no component names]' \
    '-all[print all components]' \
    '-version[show version]' \
    '-help[show help]' \
    '-debug[debug output]' \
    '*:component:_default' \
    && ret=0

return ret
