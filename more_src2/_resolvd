#compdef resolvd
# _resolvd — OpenBSD resolvd (manages /etc/resolv.conf from learned nameservers; detects running unwind(8) and prepends 127.0.0.1 to route resolution through it before falling back to learned servers)
# upstream: https://github.com/openbsd/src (sbin/resolvd)
# Flags from sbin/resolvd/resolvd.8 on tip.

_resolvd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-v[verbose]'
}

_resolvd "$@"
