#compdef grdimage
# Documentation: https://docs.generic-mapping-tools.org/latest/grdimage.html
# Source: GenericMappingTools/gmt classic-mode grdimage — plot a grid as an image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A+[save as raster instead of PostScript]:file:_files' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT (color palette table)]:cpt:_files -g "*.cpt(-.)"' \
    '-D[read input as image via GDAL]' \
    '-E+[projected-grid resolution (dpi)]:dpi:_default' \
    '-G+[transparent-mask color]:color:_default' \
    '-I+[illumination from file or computed]:opts:_default' \
    '-M[monochrome (YIQ transform)]' \
    '-N[no clip at map boundaries]' \
    '-Q+[transparency / opacity]:opts:_default' \
    '-T[plot as categorical (no interpolation)]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    '-x+[CPU cores limit]:n:_default' \
    '*:grid file:_files -g "*.(grd|nc|tif|tiff|cdf|hgt|jp2|img)(-.)"' \
    && ret=0

return ret
