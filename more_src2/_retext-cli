#compdef retext-cli retext
# _retext-cli — Titus Wormer retext natural-language processor CLI alias (retextjs team, JavaScript); unified
# upstream: https://github.com/retextjs/retext

_retext-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--use=+[plugin]:str:' \
        '-u+[plugin]:str:' \
        '--watch[watch for changes]' \
        '-w[watch for changes]' \
        '--ext=+[extension]:str:' \
        '-e+[extension]:str:' \
        '--rc-name=+[rc name]:str:' \
        '--package-field=+[package field]:str:' \
        '--ignore-name=+[ignore name]:str:' \
        '--ignore-path=+[ignore path]:file:_files' \
        '-i+[ignore path]:file:_files' \
        '--ignore-pattern=+[pattern]:str:' \
        '--ignore-path-resolve-from=+[from]:f:(dir cwd)' \
        '--silently-ignore[silently ignore]' \
        '--report=+[reporter]:r:(vfile-reporter vfile-reporter-pretty vfile-reporter-json)' \
        '-r+[reporter]:r:(vfile-reporter vfile-reporter-pretty vfile-reporter-json)' \
        '--color[force color]' \
        '--no-color[no color]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--frail[exit on warnings]' \
        '--silent[only errors]' \
        '-S[only errors]' \
        '--inspect[inspect tree]' \
        '--stdout[force stdout]' \
        '--no-stdout[no stdout]' \
        '--tree[expect tree input]' \
        '-t[expect tree input]' \
        '--tree-in[expect tree input]' \
        '--tree-out[output tree]' \
        '--file-path=+[path for stdin]:file:_files' \
        '*:files:_files -g "*.{txt,md}"'
}

_retext-cli "$@"
