#compdef prusaslicer prusa-slicer
# Documentation: https://github.com/prusa3d/PrusaSlicer/blob/master/src/libslic3r/PrintConfig.cpp
# Reference accessed: 2026-05-27
# Verified: upstream CLIActionsConfigDef, CLITransformConfigDef, CLIMiscConfigDef in src/libslic3r/PrintConfig.cpp

# Zsh completion for PrusaSlicer (FFF/SLA 3D printing slicer)

_arguments -s -S \
  '(- *)'{-h,--help}'[show this help]' \
  '--help-fff[show the full list of FFF print/G-code configuration options]' \
  '--help-sla[show the full list of SLA print configuration options]' \
  '--query-printer-models[get list of installed printer models as JSON]' \
  '--query-print-filament-profiles=[get print/filament profiles for the selected printer profile]:printer profile:' \
  '--gcodeviewer[visualize an already sliced and saved G-code]' \
  '--save=[save configuration to the specified file]:config file:_files' \
  '--info[write information about the model to the console]' \
  '--export-obj[export the model(s) as OBJ]' \
  '--export-stl[export the model(s) as STL]' \
  '--export-3mf[export the model(s) as 3MF]' \
  '(-s --slice)'{-s,--slice}'[slice the model and export the result]' \
  '(--export-sla --sla)'{--export-sla,--sla}'[slice the model and export SLA printing layers as PNG]' \
  '(-g --gcode --export-gcode)'{-g,--gcode,--export-gcode}'[slice the model and export toolpaths as G-code]' \
  '--align-xy=[align the model to the given point]:x,y coordinates:' \
  '--cut=[cut model at the given Z]:z height:' \
  '--center=[center the print around the given center]:x,y coordinates:' \
  '--dont-arrange[do not rearrange the given models before merging]' \
  '--ensure-on-bed[lift the object above the bed when partially below]' \
  '--no-ensure-on-bed[disable lifting object above the bed]' \
  '--duplicate=[multiply copies by this factor]:count:' \
  '--duplicate-grid=[multiply copies by creating a grid]:x,y grid:' \
  '(-m --merge)'{-m,--merge}'[arrange and merge supplied models in a single model]' \
  '--rotate=[rotation angle around the Z axis in degrees]:angle:' \
  '--rotate-x=[rotation angle around the X axis in degrees]:angle:' \
  '--rotate-y=[rotation angle around the Y axis in degrees]:angle:' \
  '--scale=[scaling factor or percentage]:factor:' \
  '--split[detect unconnected parts and split into separate objects]' \
  '--scale-to-fit=[scale to fit the given volume]:x,y,z dimensions:' \
  '--ignore-nonexistent-config[do not fail if a file supplied to --load does not exist]' \
  '--config-compatibility=[forward-compatibility rule for loading configs]:rule:(disable enable enable_silent)' \
  '(-o --output)'{-o+,--output=}'[file where the output will be written]:file:_files' \
  '--datadir=[load and store settings at the given directory]:directory:_directories' \
  '--threads=[maximum number of threads to use during slicing]:count:' \
  '--loglevel=[logging sensitivity 0:fatal 1:error 2:warning 3:info 4:debug 5:trace]:level:(0 1 2 3 4 5)' \
  '--opengl-aa[automatic OpenGL antialiasing samples number selection]' \
  '--opengl-version=[select a specific version of OpenGL]:version:' \
  '--opengl-compatibility[enable OpenGL compatibility profile]' \
  '--opengl-debug[activate OpenGL debug output]' \
  '--single-instance[send args to existing GUI instance or activate existing window]' \
  '--delete-after-load=[delete the listed files after loading]:files:' \
  '--load=[load configuration from the specified file]:config file:_files' \
  '*:input file:_files'
