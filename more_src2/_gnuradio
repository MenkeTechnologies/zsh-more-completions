#compdef gnuradio gnuradio-companion grc gr_modtool gr_filter_design gr-ctrlport-monitor gr_plot_psd gr_plot_fft
# _gnuradio — Eric Blossom GNU Radio free open-source software development toolkit signal processing blocks for SDR (gnuradio team, Python/C++); custom argparse
# upstream: https://github.com/gnuradio/gnuradio

_gnuradio() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--no-blacklist[no blacklist]' \
        '--update-cached[update flowgraph cache]' \
        '--reset-cache[reset flowgraph cache]' \
        '--rebuild-cache[rebuild flowgraph cache]' \
        '--config-file=+[config file]:file:_files -g "*.conf"' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--platform=+[Qt platform]:str:' \
        '--no-color[disable color]' \
        '--lazy-loading[lazy loading]' \
        '--no-lazy-loading[no lazy loading]' \
        '--show-block-stats[show block stats]' \
        '--profile[profile]' \
        '--gui-mode[GUI mode]' \
        '--no-gui[no GUI]' \
        '--reload[reload on change]' \
        '*:flowgraph file:_files -g "*.grc *.py"'
}

_gnuradio "$@"
