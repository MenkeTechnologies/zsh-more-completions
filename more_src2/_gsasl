#compdef gsasl
# Documentation: gsasl --help (GNU SASL)
# Source: authenticate to an IMAP/SMTP server using SASL.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-c --client -s --server)'{-c,--client}'[act as client (default)]' \
    '(-c --client -s --server)'{-s,--server}'[act as server]' \
    '--client-mechanisms[list supported client mechanisms]' \
    '--server-mechanisms[list supported server mechanisms]' \
    '(-k --mkpasswd)'{-k,--mkpasswd}'[derive password for SCRAM-SHA-1/256]' \
    '--connect=[TCP host[:port]]:host:_hosts' \
    '(-d --application-data)'{-d,--application-data}'[apply mechanism layer to stdin (default on)]' \
    '(--imap --smtp)--imap[IMAP-like logon (client)]' \
    '(--imap --smtp)--smtp[SMTP-like logon (client)]' \
    '(-m --mechanism)'{-m+,--mechanism=}'[mechanism]:mech:(PLAIN LOGIN CRAM-MD5 DIGEST-MD5 SCRAM-SHA-1 SCRAM-SHA-256 GSSAPI EXTERNAL ANONYMOUS NTLM SECURID OPENID20 SAML20)' \
    '--no-client-first[disallow client-first data]' \
    '(-n --anonymous-token)'{-n+,--anonymous-token=}'[anonymous token]:token:' \
    '(-a --authentication-id)'{-a+,--authentication-id=}'[credential owner identity]:authid:' \
    '(-z --authorization-id)'{-z+,--authorization-id=}'[authorisation identity]:authzid:' \
    '(-p --password)'{-p+,--password=}'[password (insecure)]:password:' \
    '(-r --realm)'{-r+,--realm=}'[realm]:realm:' \
    '--passcode=[SECURID passcode]:n:' \
    '--service=[service name]:service:' \
    '--hostname=[server hostname]:host:_hosts' \
    '--service-name=[generic server name (DIGEST-MD5)]:name:' \
    '--enable-cram-md5-validate[validate CRAM-MD5 challenge]' \
    '--disable-cleartext-validate[disable cleartext validate hook]' \
    '--quality-of-protection=[payload protection]:type:(qop-auth qop-int qop-conf)' \
    '--iteration-count=[PBKDF2 iteration count]:n:' \
    '--salt=[PBKDF2 salt (base64)]:b64:' \
    '--scram-salted-password=[salted SCRAM password]:hex:' \
    '(--starttls --no-starttls)--starttls[force STARTTLS]' \
    '(--starttls --no-starttls)--no-starttls[disable STARTTLS]' \
    '--verbose[verbose]' \
    '*:host port:_hosts' \
    && ret=0

return ret
