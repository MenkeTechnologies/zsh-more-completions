#compdef debootsnap
# Documentation: https://manpages.debian.org/debootsnap
# Source: debian/devscripts scripts/debootsnap — build a chroot of specific Debian package versions via snapshot (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(--architecture --nativearch)'{--architecture=-,--nativearch=-}'[chroot architecture]:arch:_default' \
    '--ignore-notfound[continue when packages cannot be found in snapshot]' \
    '(--packages --pkgs)--buildinfo=-[buildinfo file specifying versions]:file:_files -g "*.buildinfo"' \
    '(--buildinfo)'{--packages=-,--pkgs=-}'[explicit package=version list]:packages:_default' \
    '--sources-list-only[only print sources.list; do not build chroot]' \
    '1::output chroot tarball:_files' \
    && ret=0

return ret
