#compdef fast fast-cli
# Documentation: https://github.com/sindresorhus/fast-cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fast-cli - fast.com speed test CLI

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--json[output results as JSON]' \
  '--single-line[reduce spacing and output to a single line]' \
  {-u,--upload}'[measure upload speed in addition to download speed]'
