#compdef influxdb_exporter
# Documentation: https://github.com/prometheus/influxdb_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--influxdb.sample-expiry=[how long a sample is valid for]:duration:' \
  '--udp.listen-address=[address on which to listen for UDP InfluxDB line protocol data]:address:' \
  '--web.listen-address=[address to listen on for web interface and telemetry]:address:' \
  '--web.telemetry-path=[path under which to expose metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
