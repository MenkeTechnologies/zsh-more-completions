#compdef genreflex
# Documentation: https://github.com/root-project/root/blob/master/core/dictgen/src/rootcling_impl.cxx
# Reference accessed: 2026-05-27
# Verified: upstream genreflexUsageDescriptor option table in rootcling_impl.cxx

# genreflex: legacy reflection dictionary generator (delegates to rootcling).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-s --selection_file)'{-s+,--selection_file=}'[selection XML file]:file:_files -g "*.xml"' \
  '(-o --output)'{-o+,--output=}'[output filename or directory]:output:_files' \
  '(-l --library)'{-l+,--library=}'[target library name]:library:' \
  '--rootmap=[generate rootmap file]:file:_files -g "*.rootmap"' \
  '--rootmap-lib=[library name for the rootmap file]:library:' \
  '--multiDict[support for many dictionaries in one library]' \
  '--noGlobalUsingStd[do not declare using namespace std in dictionary scope]' \
  '--interpreteronly[do not generate I/O related information]' \
  '--split[split dictionary into IO and interactivity parts]' \
  '*-m+[Pcm file loaded before any header (repeatable)]:pcm file:_files -g "*.pcm"' \
  '(-v --verbose)'{-v,--verbose}'[print some debug information]' \
  '--debug[print all debug information]' \
  '--quiet[print only warnings and errors (default)]' \
  '--silent[print no information at all]' \
  '--writeEmptyPCM[write an empty ROOT pcm]' \
  '--cxxmodule[generate a PCM for C++ Modules]' \
  '--fail_on_warnings[fail on warnings and errors]' \
  '--selSyntaxOnly[validate selection file without generating the dictionary]' \
  '--noIncludePaths[do not store header directories in the dictionary]' \
  '--print-rootcling-invocation[print equivalent rootcling invocation]' \
  '*-I+[add include directory]:path:_files -/' \
  '*-D+[define preprocessor macro]:macro:' \
  '*-U+[undefine preprocessor macro]:macro:' \
  '*-W+[compiler diagnostics option]:warning:' \
  '*:header file:_files -g "*.(h|hh|hpp|hxx|H)"' && ret=0

return ret
