#compdef poldek
# Documentation: https://raw.githubusercontent.com/poldek-pm/poldek/master/cli/main.c
# Reference accessed: 2026-05-16
# Verified: upstream poldek-pm/poldek cli/main.c argp common_options table.
# Subcommand verbs (install/uninstall/upgrade/search/ls/etc.) live in
# cli/op.c and are reachable as positional args; full enumeration is
# out of scope here.
# Removed from prior file: bogus man.archlinux.org search URL.

# poldek: RPM-based package manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help -\?)'{-h,--help,-\?}'[show help]' \
  '--usage[show usage summary]' \
  '--version[show version]' \
  '--pmcmd=[use FILE as PM (rpm) binary]:file:_files' \
  '--sudocmd=[use FILE as sudo binary]:file:_files' \
  '--cachedir=[directory for downloaded files]:dir:_files -/' \
  '--cmd[run in command mode]' \
  '--ask[confirm installations and equivalent-package choices]' \
  '(-y --noask)'{-y,--noask}'[do not ask about anything]' \
  '--shell[run in interactive shell mode (default)]' \
  '--skip-installed[do not load installed packages at startup]' \
  '--conf=[read configuration from FILE]:file:_files' \
  '--noconf[do not read configuration]' \
  '--upconf[update remote configuration files]' \
  '--log=[log program messages to FILE]:file:_files' \
  '--runas=[run program as user]:user:_users' \
  '*-O+[set configuration option]:OPTION=VALUE:' \
  '--noprogress[do not show progress bar]' \
  '--color[force color on non-tty output]' \
  '-v[verbose output]' \
  '-q[quiet]' \
  '*:command or package:' && ret=0
return ret
