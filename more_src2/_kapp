#compdef kapp
# Documentation: https://github.com/carvel-dev/kapp/blob/develop/pkg/kapp/cmd/kapp.go
# Reference accessed: 2026-05-19
# Verified: upstream docs + source (pkg/kapp/cmd/kapp.go AddCommand) at the
# URL above. Removed invented commands (package-repository/package-installed/
# package-available were fabricated); added real rename/label/list commands.

_kapp_commands() {
  local -a commands=(
    'deploy:Deploy app'
    'delete:Delete app'
    'inspect:Inspect resources'
    'list:List apps'
    'logs:Print app logs'
    'rename:Rename app'
    'label:Set labels on resources'
    'app-change:App change commands'
    'app-group:App group commands'
    'config:Show config'
    'config-map:ConfigMap migration commands'
    'service-account:Service account commands'
    'tools:Tools'
    'completion:Generate shell completion'
    'version:Print version'
  )
  _describe -t commands 'kapp command' commands
}

_kapp() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--column[Filter columns]:columns:' \
    '--color[Enable colorized output]' \
    '--json[Output as JSON]' \
    '--kube-api-burst[Kubernetes API burst]:burst:' \
    '--kube-api-qps[Kubernetes API QPS]:qps:' \
    '--kubeconfig[Path to kubeconfig]:file:_files' \
    '--kubeconfig-context[Kubeconfig context]:context:' \
    '--kubeconfig-yaml[Kubeconfig YAML content]:yaml:' \
    '--yes[Assume yes for prompts]' \
    '-y[Assume yes for prompts]' \
    '1:command:_kapp_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        deploy)
          _arguments \
            '(-a --app)'{-a,--app}'[Application name]:name:' \
            '(-n --namespace)'{-n,--namespace}'[Namespace]:namespace:' \
            '(-f --file)'{-f,--file}'[File or directory]:file:_files' \
            '--into-ns[Place resources into namespace]:namespace:' \
            '--map-ns[Map namespace]:mapping:' \
            '--diff-run[Show diff without applying]' \
            '--diff-exit-status[Set exit status on diff]' \
            '--diff-against-last-applied[Diff against last applied]' \
            '--diff-changes-yaml[Output diff as YAML]' \
            '--apply-timeout[Timeout for apply]:timeout:' \
            '--wait[Wait for reconciliation]' \
            '--wait-timeout[Wait timeout]:timeout:' \
            '--logs[Show logs during deploy]' \
            '--logs-all[Show all logs]' \
            '--filter[Filter resources]:filter:' \
            '-c[Set change type]:change:' \
            '-y[Assume yes]'
          ;;
        delete)
          _arguments \
            '(-a --app)'{-a,--app}'[Application name]:name:' \
            '(-n --namespace)'{-n,--namespace}'[Namespace]:namespace:' \
            '--diff-changes-yaml[Output diff as YAML]' \
            '--apply-timeout[Timeout for apply]:timeout:' \
            '-y[Assume yes]'
          ;;
        inspect)
          _arguments \
            '(-a --app)'{-a,--app}'[Application name]:name:' \
            '(-n --namespace)'{-n,--namespace}'[Namespace]:namespace:' \
            '--raw[Raw output]' \
            '--tree[Tree view]' \
            '--status[Show status]' \
            '--filter[Filter resources]:filter:'
          ;;
        app-change)
          local -a subcommands=(
            'list:List changes'
            'gc:Garbage collect changes'
          )
          _describe -t subcommands 'app-change subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish)'
          ;;
      esac
      ;;
  esac
}

_kapp "$@"
