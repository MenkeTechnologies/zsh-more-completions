#compdef komac
# Documentation: https://raw.githubusercontent.com/russellbanks/Komac/main/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap Commands enum in src/main.rs (russellbanks/Komac).

# Zsh completion for komac (winget-pkgs manifest tool)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-v -V --version)'{-v,-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      'new:create a package from scratch'
      'update:add a version to a pre-existing package'
      'remove:remove a version from winget-pkgs'
      'cleanup:delete branches with merged/closed pull requests'
      'token:manage the stored GitHub token'
      'list:list all versions for a given package'
      'show:show information about a package version'
      'sync:sync your fork to microsoft/winget-pkgs'
      'complete:output autocompletion scripts for your shell'
      'analyze:analyze a file and output information about it'
      'remove-dead-versions:remove versions whose installers are unreachable'
      'submit:submit a package'
    )
    _describe -t commands 'komac command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      token)
        _arguments '1:subcommand:(update remove)' && ret=0
        ;;
      complete)
        _arguments '1:shell:(bash elvish fish nushell powershell zsh)' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
