#compdef llmctl
# _llmctl — kubernetes-llmctl llmctl admin CLI for managing LLM control-plane installs (kubernetes-llmctl team, Go); cobra
# upstream: https://github.com/kubernetes-llmctl/llmctl

_llmctl() {
    local -a sub=(
        'init:initialize installation'
        'install:install components'
        'uninstall:uninstall components'
        'upgrade:upgrade components'
        'status:show status'
        'context:context subcommands'
        'config:configuration subcommands'
        'cluster:cluster subcommands'
        'model:model subcommands'
        'inference:inference subcommands'
        'gateway:gateway subcommands'
        'router:router subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-V[show version]' \
        '--version[show version]' \
        '--kubeconfig=+[kubeconfig file]:file:_files' \
        '--context=+[kube context]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[namespace]:str:' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--output=+[format]:f:(table json yaml wide)' \
        '-o+[format]:f:(table json yaml wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llmctl subcommand' sub ;;
        args)
            case $words[1] in
                model) _arguments '1:model cmd:(list get create delete update deploy logs)' ;;
                inference) _arguments '1:inference cmd:(create list get delete pause resume scale)' ;;
                gateway|router) _arguments '1:cmd:(create list get delete update)' ;;
                cluster) _arguments '1:cluster cmd:(register unregister list get update)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                context) _arguments '1:context cmd:(get set list use delete)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_llmctl "$@"
