#compdef mactelnet
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-l[list available hosts]' \
  '-n[do not use DNS]' \
  '-t[connect timeout]:timeout (seconds)' \
  '-u[username]:username' \
  '-p[password]:password' \
  '-U[unix socket path]:socket path:_files' \
  '-B[batch mode]' \
  '-h[show help]' \
  '-v[show version]' \
  ':MAC address or hostname' && ret=0
return ret
