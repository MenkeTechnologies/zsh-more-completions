#compdef db_tuner
# Documentation: db_tuner usage (Berkeley DB 18.1.40)
# Source: recommend optimal Berkeley DB cache and page sizes.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[cache size in MB]:cachesize:' \
    '-d+[database file]:file:_files' \
    '-h+[environment home]:dir:_files -/' \
    '-s+[subdatabase name]:database:' \
    '-S+[verify ov]:flags:(o v ov)' \
    '-v+[verbose level]:level:(0 1 2)' \
    && ret=0

return ret
