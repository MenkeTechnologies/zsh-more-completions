#compdef fuelup
# Documentation: source-direct extraction from upstream
# FuelLabs/fuelup src/commands/ + src/fuelup_cli.rs
# (clap v4 derive):
#   src/fuelup_cli.rs lines 14-44 (Cli + Commands enum:
#     9 top-level variants; 3 with nested subcommands)
#   src/commands/check.rs lines 6-12 (CheckCommand: 1 flag
#     `--verbose/-v`)
#   src/commands/completions.rs lines 7-12 (CompletionsCommand
#     using `clap_complete::Shell` ValueEnum; `--shell/-S`)
#   src/commands/component.rs lines 5-25 (ComponentCommand
#     enum: Add(AddCommand) / Remove(RemoveCommand) / List)
#   src/commands/default.rs lines 5-9 (DefaultCommand with
#     `Default_` variant name AND optional positional
#     toolchain arg)
#   src/commands/fuelup.rs lines 5-23 (FuelupCommand enum:
#     Update / Uninstall; renamed to CLI "self" via
#     `#[clap(name = "self", subcommand)]`)
#   src/commands/toolchain.rs lines 9-50 (ToolchainCommand
#     enum: Install / New / Uninstall / Export; New uses
#     `name_allowed` custom validator)
#   src/commands/upgrade.rs lines 5-9 (UpgradeCommand: 1
#     flag `--force/-f`)
# Reference accessed: 2026-05-30 via gh api.
#
# fuelup is the **Fuel Network toolchain manager** —
# rustup-style installer + version manager for the Fuel
# blockchain stack (forc compiler, fuel-core node, etc.).
# Fuel is a parallelized execution UTXO-based blockchain
# (sister to Solana's parallel-execution model but with
# Cardano-inspired UTXO storage).  Pivots away from the
# Dojo/Starknet cluster (R247-R252) into the Fuel cluster.
# Sister to forc (Fuel's contract compiler; already in
# corpus).
#
# Critical extraction note: fuelup uses
# **`#[clap(name = "self", subcommand)]`** at
# fuelup_cli.rs:33 on the `Fuelup(FuelupCommand)` variant.
# The Rust enum variant is `Fuelup` (different name from
# CLI) but the CLI surface is `fuelup self update` /
# `fuelup self uninstall`.  Documents the **Rust-keyword-
# avoidance via clap rename pattern** — `self` is a Rust
# keyword and cannot be used as an enum variant name.
# The `#[clap(name = "...")]` attribute lets the CLI name
# differ from the Rust identifier.  This is the corpus's
# **first documented `name = "..."` rename used to bypass
# a Rust keyword conflict** — distinct from R249 cairo-
# profiler's `#[clap(name = "cairo-profiler")]` which was
# purely defensive (Rust ident matched CLI name anyway).
#
# Critical extraction note: fuelup uses **`Default_` with
# trailing underscore** at fuelup_cli.rs:31 — the Rust
# enum variant is `Default_` but clap derive's auto-name
# strips trailing underscores so the CLI sees `default`.
# This dodges the **Rust naming conflict with the `Default`
# trait** (which is in scope in derive macros).  Documents
# the **trailing-underscore variant-name pattern** for
# clap derive — distinct from the `name = "..."` rename
# (which requires explicit attribute).  Subtle: works
# because clap derive's name-stripping logic looks at the
# trailing `_` specifically.  Useful when the CLI name
# you want IS a Rust reserved-ish identifier (default,
# type, ref, etc.).
#
# Critical extraction note: fuelup uses
# **`clap_complete::Shell`** ValueEnum at completions.rs:11
# — when used as an `#[arg]` type, clap auto-detects the
# ValueEnum + emits shell name completions (bash, zsh,
# fish, elvish, powershell).  Documents the **clap-
# integration with clap_complete** for shell-completion
# generators.  Sister to R250 sozo + R251 torii's use of
# `clap_verbosity_flag::Verbosity` flatten — both
# integrate community-maintained clap helper crates.
# Note: fuelup itself USES clap_complete::Shell as a value
# type, but the resulting completion would only be useful
# if a user runs `fuelup completions --shell zsh > _fuelup`
# (which this completion REPLACES because the corpus
# strives for source-direct hand-rolled completions
# rather than autogenerated ones).
#
# Critical extraction note: fuelup uses **`name_allowed`
# custom validator** at toolchain.rs:52-72 for the
# `toolchain new NAME` arg.  The validator:
#   1. Splits NAME at first `-`; if suffix matches host
#      target triple (e.g. `latest-aarch64-apple-darwin`
#      on M1 Mac), strips it
#   2. Bails if the (possibly-stripped) prefix is in
#      `RESERVED_TOOLCHAIN_NAMES` (latest / nightly /
#      testnet / mainnet)
#   3. Returns the ORIGINAL (un-stripped) string on success
# This is a **multi-purpose validator** — both transforms
# (target-triple awareness) AND rejects (reserved-name
# check).  Documents the **stateful validator with host
# detection** — clap value_parsers can call into the host
# OS for context-aware validation.  Distinct from R252
# saya's `validate_non_empty` (pure string check) and
# R248 cairo-coverage's `parse_trace_file` (filesystem
# check).
#
# Critical extraction note: fuelup has **3 top-level
# subcommands with nested Subcommand enums** marked by
# `#[clap(subcommand)]`: `Component`, `Toolchain`,
# `Fuelup`/self.  Plus 2 with arg structs: `Check`,
# `Completions`, `Default_`, `Upgrade`.  Plus 2 with NO
# args at all: `Show`, `Update`.  This is a clean example
# of clap's **3 subcommand-arg patterns**: (a) nested
# subcommand enum, (b) arg struct, (c) bare unit variant.
# Documents the **clap subcommand-shape taxonomy**.

local curcontext="$curcontext" state line ret=1

# 9 top-level subcommands decoded source-direct from
# Commands enum at fuelup_cli.rs lines 21-44.
local -a subcommands=(
  'check:check for updates to Fuel toolchains and fuelup'
  'completions:generate shell completions'
  'component:add or remove components from the currently active toolchain (sub: add / remove / list)'
  'default:set default toolchain (no arg = show current default)'
  'self:manage your fuelup installation (sub: update / uninstall)'
  'toolchain:install new toolchains or modify/query installed toolchains (sub: install / new / uninstall / export)'
  'show:show the active and installed toolchains, host, and fuelup home'
  'update:update the distributable toolchains, if already installed'
  'upgrade:update fuelup itself, switch to `latest` channel, update components in all channels'
)

# Component sub-subcommands at component.rs:5-13.
local -a component_subs=(
  'add:add a component to the currently active custom toolchain'
  'remove:remove a component from the currently active custom toolchain'
  'list:list installed and installable components'
)

# Self (Fuelup) sub-subcommands at fuelup.rs:5-11.
local -a self_subs=(
  'update:update fuelup'
  'uninstall:uninstall fuelup'
)

# Toolchain sub-subcommands at toolchain.rs:9-19.
local -a toolchain_subs=(
  'install:install or update a distributable toolchain (latest / nightly / testnet / mainnet)'
  'new:create a new CUSTOM toolchain (names starting with distributable names are rejected)'
  'uninstall:uninstall a toolchain'
  'export:export a toolchain configuration to fuel-toolchain.toml'
)

# Distributable / reserved toolchain names at toolchain.rs:23
# (visible via `latest, nightly, testnet, mainnet` in the
# `name` field doc comment).
local -a distributable_toolchains=(latest nightly testnet mainnet)

# Component names at component.rs:17 (doc comment list).
local -a component_names=(forc fuel-core)

# Shell types at completions.rs:11 (`clap_complete::Shell`).
local -a shell_types=(bash zsh fish elvish powershell)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'fuelup subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      check)
        _arguments \
          '(-h --help)'{-h,--help}'[show help for `check`]' \
          '(-v --verbose)'{-v,--verbose}'[explicitly show versions of forc plugins (normally bundled with forc)]' && ret=0
        ;;
      completions)
        _arguments \
          '(-h --help)'{-h,--help}'[show help for `completions`]' \
          '(-S --shell)'{-S+,--shell=}'[shell to enable tab-completion for (clap_complete::Shell ValueEnum)]:shell:($shell_types)' && ret=0
        ;;
      component)
        if (( CURRENT == 2 )); then
          _describe -t component-subs 'component verb' component_subs && ret=0
        else
          case $words[2] in
            add)
              _arguments '*:component[@version]:($component_names)' && ret=0
              ;;
            remove)
              _arguments '*:component:($component_names)' && ret=0
              ;;
          esac
        fi
        ;;
      default)
        _arguments \
          '1:toolchain (optional; defaults to showing current):($distributable_toolchains)' && ret=0
        ;;
      self)
        if (( CURRENT == 2 )); then
          _describe -t self-subs 'self verb' self_subs && ret=0
        else
          case $words[2] in
            update|uninstall)
              _arguments \
                '(-f --force)'{-f,--force}'[force the operation]' && ret=0
              ;;
          esac
        fi
        ;;
      toolchain)
        if (( CURRENT == 2 )); then
          _describe -t toolchain-subs 'toolchain verb' toolchain_subs && ret=0
        else
          case $words[2] in
            install)
              _arguments '1:toolchain name:($distributable_toolchains)' && ret=0
              ;;
            new)
              _arguments '1:custom toolchain name (NOT reserved):' && ret=0
              ;;
            uninstall)
              _arguments '1:toolchain to uninstall:' && ret=0
              ;;
            export)
              _arguments \
                '(-o --output)'{-o+,--output=}'[output file path (defaults to fuel-toolchain.toml)]:file:_files -g "*.toml"' \
                '--force[overwrite existing file]' \
                '1:toolchain to export (defaults to active toolchain):' && ret=0
              ;;
          esac
        fi
        ;;
      upgrade)
        _arguments \
          '(-f --force)'{-f,--force}'[force the upgrade]' && ret=0
        ;;
    esac
    ;;
esac

return ret
