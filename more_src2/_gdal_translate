#compdef gdal_translate
# Documentation: https://gdal.org/programs/gdal_translate.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-if+[input format/driver name]:format:' \
  '-of+[output format]:format:(GTiff COG JPEG PNG BMP GIF WEBP JP2OpenJPEG HFA AAIGrid VRT MBTiles GPKG PCRaster netCDF Zarr)' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-ot+[output data type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 UInt64 Int64 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '*-b+[band to select]:band:' \
  '-mask+[mask band]:band:' \
  '-expand+[expand color-indexed to gray/rgb/rgba]:mode:(gray rgb rgba)' \
  '-strict[strict mode]' \
  '-unscale[apply scale/offset metadata]' \
  '-outsize+[output size]:xsize ysize:' \
  '-tr+[target resolution]:xres yres:' \
  '-ovr+[overview level]:level:' \
  '-r+[resampling algorithm]:algorithm:(nearest bilinear cubic cubicspline lanczos average rms mode)' \
  '-srcwin+[source window in pixels]:xoff yoff xsize ysize:' \
  '-projwin+[projection window]:ulx uly lrx lry:' \
  '-projwin_srs+[SRS for projwin]:SRS:' \
  '-epo[error when partially outside]' \
  '-eco[error when completely outside]' \
  '-a_srs+[assign SRS]:SRS:' \
  '-a_coord_epoch+[assign coordinate epoch]:epoch:' \
  '-a_ullr+[assign georeferenced bounds]:ulx uly lrx lry:' \
  '-a_gt+[assign geotransform]:gt0 gt1 gt2 gt3 gt4 gt5:' \
  '-a_scale+[assign scale]:scale:' \
  '-a_offset+[assign offset]:offset:' \
  '-a_nodata+[assign nodata value]:value:' \
  '-colorinterp+[color interpretation]:interp:' \
  '*-mo+[metadata key=value]:NAME=VALUE:' \
  '*-dmo+[domain-scoped metadata]:DOMAIN\:KEY=VALUE:' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '-sds[copy all subdatasets to individual files]' \
  '-stats[force statistics computation]' \
  '-norat[suppress raster attribute table]' \
  '-noxmp[suppress XMP metadata]' \
  '*-oo+[open option]:NAME=VALUE:' \
  '-nogcp[do not copy GCPs]' \
  '*-gcp+[ground control point]:pixel line easting northing:' \
  '-scale+[rescale values]:src_min src_max dst_min dst_max:' \
  '-exponent+[exponent for rescaling]:exponent:' \
  '1:source dataset:_files' \
  '2:destination dataset:_files'
