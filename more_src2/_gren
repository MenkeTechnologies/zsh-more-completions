#compdef gren
# Documentation: https://github.com/gren-lang/compiler/blob/main/src/Terminal/Parser.gren
# Reference accessed: 2026-05-27
# Verified: upstream Terminal/Parser.gren on the main branch (gren-lang/compiler).

local curcontext="$curcontext" state line ret=1

local -a _gren_subcommands _gren_pkg_subcommands _gren_platforms
_gren_subcommands=(
  'init:start a Gren project (creates a starter gren.json)'
  'repl:open an interactive programming session'
  'paths:return paths used for compiling a project'
  'make:compile Gren code into JS or HTML'
  'run:compile and run a Gren module'
  'docs:collect package documentation into JSON'
  'package:package management subcommands (install/uninstall/...)'
)

_gren_pkg_subcommands=(
  'install:fetch packages from github for use in your project'
  'uninstall:remove packages from your project'
  'outdated:list latest versions of dependencies'
  'validate:check that the package is ready for publication'
  'bump:figure out the next version number based on API changes'
  'diff:detect API changes between versions'
)

_gren_platforms=(common browser node)

_arguments -C \
  '--help[show usage]' \
  '--version[print Gren version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'gren subcommand' _gren_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--package[create a package (as opposed to an application)]' \
          '--platform=[platform to target]:platform:('"${_gren_platforms[*]}"')' && ret=0
        ;;
      repl)
        _arguments \
          '--interpreter=[path to an alternate JS interpreter (node|deno|bun)]:interpreter:_files' && ret=0
        ;;
      paths)
        _arguments \
          '--project[output only the path to the project]' \
          '--cache[output only the path to the compiler cache]' \
          '--backend[output only the path to the compiler backend]' \
          '--json[output in JSON format]' && ret=0
        ;;
      make)
        _arguments \
          '--optimize[turn on optimizations to make code smaller and faster]' \
          '--sourcemaps[add sourcemaps to the resulting JS file]' \
          '--output=[name of the resulting JS file (or /dev/stdout, /dev/null)]:output:_files' \
          '--report=[error output format]:report:(json)' \
          '*:module:' && ret=0
        ;;
      run)
        _arguments \
          '--package=[run a module in a particular package]:package:' \
          '1:module name:' && ret=0
        ;;
      docs)
        _arguments \
          '--output=[name of the resulting JSON file]:output:_files' \
          '--report=[error output format]:report:(json)' && ret=0
        ;;
      package)
        local pkg_state pkg_line
        _arguments -C \
          '1: :->pkgcmd' \
          '*:: :->pkgargs' && ret=0
        case $state in
          pkgcmd)
            _describe -t commands 'gren package subcommand' _gren_pkg_subcommands && ret=0
            ;;
          pkgargs)
            case $line[1] in
              install|uninstall)
                _arguments '1:package (author/project):' && ret=0
                ;;
              diff)
                _arguments \
                  '1:package or version:' \
                  '2:version:' \
                  '3:version:' && ret=0
                ;;
              *)
                _files && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
