#compdef gitup

# Zsh completion for gitup - recursively update git repos (pip install gitup)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --add)'{-a,--add}'[add repository bookmark]:path:_directories' \
  '(-d --delete)'{-d,--delete}'[delete repository bookmark]:path:_directories' \
  '(-l --list)'{-l,--list}'[list bookmarked repos]' \
  '(-b --bookmark)'{-b,--bookmark}'[update only bookmarked repos]' \
  '(-c --current-only)'{-c,--current-only}'[only update current branch]' \
  '(-f --fetch-only)'{-f,--fetch-only}'[fetch only, do not merge]' \
  '(-p --prune)'{-p,--prune}'[prune remote branches]' \
  '--depth[directory recursion depth]:depth' \
  '*:directory:_directories'
