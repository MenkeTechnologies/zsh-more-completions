#compdef grub-mkrelpath grub-mkimage grub-mknetdir grub-mkstandalone grub-mkrescue grub-mkfont grub-mklayout grub-script-check grub-editenv grub-file grub-menulst2cfg grub-syslinux2cfg grub-render-label grub-bios-setup grub-glue-efi grub-probe grub-fstest
# _grub-tools — GRUB grub-* utility family (build images, generate netboot/standalone/rescue trees, register fonts, validate scripts, edit envblock, parse menu.lst); each utility has its own flag set; this compdef accepts the common --help/--version/--verbose/--directory/--output options forwarded across the family
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-*.c on tip.

_grub-tools() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[GRUB lib directory]:dir:_files -/' \
        '--directory+[GRUB lib directory]:dir:_files -/' \
        '-o+[output]:file:_files' \
        '--output+[output]:file:_files' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '-O+[target format]:format:' \
        '--format+[target format]:format:' \
        '*:argument:_files'
}

_grub-tools "$@"
