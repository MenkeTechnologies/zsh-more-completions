#compdef ln-cli
# _ln-cli — GNU coreutils ln make links between files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_ln-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--backup[backup]' \
        '--backup=+[control]:c:(none off numbered t existing nil simple never)' \
        '-b[backup]' \
        '-d[allow superuser to attempt to hardlink to dirs]' \
        '-F[allow superuser to attempt to hardlink to dirs]' \
        '--directory[allow superuser to attempt to hardlink to dirs]' \
        '-f[force]' \
        '--force[force]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-L[dereference symlinks]' \
        '--logical[dereference symlinks]' \
        '-n[treat target as normal file]' \
        '--no-dereference[treat target as normal file]' \
        '-P[no follow symlinks]' \
        '--physical[no follow symlinks]' \
        '-r[create relative symlink]' \
        '--relative[create relative symlink]' \
        '-s[symbolic link]' \
        '--symbolic[symbolic link]' \
        '-S+[suffix]:str:' \
        '--suffix=+[suffix]:str:' \
        '-t+[target dir]:dir:_files -/' \
        '--target-directory=+[target dir]:dir:_files -/' \
        '-T[treat dest as normal file]' \
        '--no-target-directory[treat dest as normal file]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:source dest:_files'
}

_ln-cli "$@"
