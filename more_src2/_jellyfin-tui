#compdef jellyfin-tui
# Documentation: https://github.com/dhonus/jellyfin-tui
# Source: dhonus/jellyfin-tui — Rust ratatui music client for Jellyfin servers.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--offline[disable network access; play only downloaded tracks]' \
    '--select-server[force the server picker on startup]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
