#compdef less-cli lessc
# _less-cli — Less.js CSS preprocessor lessc CLI alias (Less.js team / Alexis Sellier, JavaScript); custom argparse
# upstream: https://github.com/less/less.js

_less-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--include-path=+[include path]:list:_files -/' \
        '-I+[include path]:list:_files -/' \
        '--makefile=+[makefile dependency rules]:file:_files' \
        '-M+[makefile dependency rules]:file:_files' \
        '--no-color[no color]' \
        '--no-ie-compat[no IE compatibility]' \
        '--no-js[no inline js]' \
        '--no-css[no css output]' \
        '--lint[lint only]' \
        '-l[lint only]' \
        '--silent[silent]' \
        '-s[silent]' \
        '--strict-imports[strict imports]' \
        '--strict-units[strict units]' \
        '--global-var=+[global variable name=value]:list:' \
        '--modify-var=+[modify variable name=value]:list:' \
        '--url-args=+[URL args]:str:' \
        '--plugin=+[plugin]:list:' \
        '--depends[print dependencies]' \
        '-x[--compress (legacy)]' \
        '--compress[compress output]' \
        '--insecure[insecure imports]' \
        '--source-map[generate source map]' \
        '--source-map-rootpath=+[source map rootpath]:str:' \
        '--source-map-basepath=+[source map basepath]:str:' \
        '--source-map-include-source[include source]' \
        '--source-map-inline[inline source map]' \
        '--source-map-url=+[source map url]:url:_urls' \
        '--source-map-output-map-file=+[source map output file]:file:_files' \
        '--source-map-no-annotation[no source map annotation]' \
        '--rootpath=+[rootpath]:str:' \
        '--rewrite-urls=+[rewrite urls]:m:(all local off)' \
        '--include[--include-path (legacy)]' \
        '--inline-urls[inline urls]' \
        '--math=+[math mode]:m:(always parens-division parens strict strict-legacy)' \
        '--ie-compat[IE compatibility]' \
        '--js[allow inline js]' \
        '--no-color[no color]' \
        '*:less-and-css:_files -g "*.less *.css"'
}

_less-cli "$@"
