#compdef psimage
# Documentation: https://docs.generic-mapping-tools.org/latest/image.html
# Source: GenericMappingTools/gmt classic-mode psimage — place a raster image on a plot.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-D+[reference point + image dims (DPI/width/replication)]:opts:_default' \
    '-F+[rectangular border + fill/rounded/shadow]:opts:_default' \
    '-G+[pixel color / transparency modifier]:opts:_default' \
    '-I[invert 1-bit image colors]' \
    '-J+[projection]:proj:_default' \
    '-M[grayscale (YIQ transform)]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    '*:input image:_files -g "*.(eps|EPS|png|jpg|jpeg|gif|tif|tiff|ppm|bmp)(-.)"' \
    && ret=0

return ret
