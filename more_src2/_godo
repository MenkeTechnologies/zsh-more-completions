#compdef godo
# Documentation: https://github.com/go-godo/godo
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_godo() {
    local line
    local -a commands
    commands=(
        'server:Start the server'
        'build:Build the project'
        'test:Run tests'
        'watch:Watch files and rerun tasks'
    )

    _arguments \
        '--watch[Watch files and rerun tasks]' \
        '--help[Show help]' \
        '1: :->command' \
        '*: :_files'

    case $line[1] in
        server)
            _arguments '--port[Port to listen on]:number:'
            ;;
    esac
}

_godo "$@"
