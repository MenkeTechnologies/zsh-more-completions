#compdef retire
# Documentation: https://github.com/RetireJS/retire.js
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-c --nocache)'{-c,--nocache}'[disable local cache]' \
  '--path=[folder to scan]:path:_files' \
  '--jspath=[folder to scan for JavaScript (deprecated)]:path:_files' \
  '--jsrepo=[local or internal repo (comma-separated)]:url:' \
  '--cachedir=[custom cache directory]:directory:_directories' \
  '--proxy=[proxy URL]:url:' \
  '--outputformat=[output format]:format:(text json jsonsimple depcheck cyclonedx cyclonedxJSON)' \
  '--outputpath=[output file path]:file:_files' \
  '--ignore=[paths to ignore (comma-separated)]:paths:' \
  '--ignorefile=[custom ignore file]:file:_files' \
  '--severity=[severity threshold]:severity:(none low medium high critical)' \
  '--exitwith=[custom exit code on vulnerabilities]:code:' \
  '--colors[enable console color output]' \
  '--insecure[allow insecure TLS]' \
  '--ext=[file extensions for JavaScript]:exts:' \
  '--cacert=[CA certificate file]:file:_files' \
  '--includeOsv[include OSV advisories]' \
  '--deep[deep scan mode (experimental)]' \
  '*:path:_files' && ret=0

return ret
