#compdef envycontrol
# Zsh completion for envycontrol - NVIDIA GPU mode switching on Linux
# https://github.com/bayasdev/envycontrol

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --switch)'{-s,--switch}'[switch GPU mode]:mode:(integrated hybrid nvidia)' \
  '(-q --query)'{-q,--query}'[query current GPU mode]' \
  '--dm=[specify display manager]:display manager:(gdm sddm lightdm)' \
  '--force-comp[force compositor pipeline in nvidia mode]' \
  '--coolbits=[set Coolbits value for nvidia-settings]:value:' \
  '--rtd3=[set Runtime D3 power management]:value:(0 1 2 3)' \
  '--use-nvidia-current[use nvidia-current instead of nvidia]' \
  '--reset[reset to default settings]' \
  '--verbose[enable verbose output]'
