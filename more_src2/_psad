#compdef psad
# Documentation: https://manpages.debian.org/bookworm/psad/psad.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream psad(8) manpage at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--Version}'[show version]' \
  '(-A --Analyze-msgs)'{-A,--Analyze-msgs}'[analyze iptables log and exit]' \
  '(-d --debug)'{-d,--debug}'[run in debug mode]' \
  '(-i --interface)'{-i+,--interface=}'[interface]:if:_net_interfaces' \
  '(-S --Status)'{-S,--Status}'[show running psad status]' \
  '(-F --Flush)'{-F,--Flush}'[remove auto-generated firewall rules]' \
  '(-K --Kill)'{-K,--Kill}'[terminate all psad processes]' \
  '(-R --Restart)'{-R,--Restart}'[restart running psad processes]' \
  '(-H --HUP)'{-H,--HUP}'[reload configuration files]' \
  '(-U --USR1)'{-U,--USR1}'[dump scan hash to file]' \
  '(-O --Override-config)'{-O+,--Override-config=}'[override config from file]:file:_files' \
  '(-D --Dump-conf)'{-D,--Dump-conf}'[dump current configuration]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
  '(-m --messages-file)'{-m+,--messages-file=}'[analyze given log file]:file:_files' \
  '(-B --Benchmark)'{-B,--Benchmark}'[run benchmark]' \
  '--status-ip=[status for given IP]:ip:' \
  '--status-dl=[status at minimum danger level]:level:' \
  '--fw-analyze[analyze local iptables ruleset]' \
  '--fw-block-ip=[add IP to auto-generated rules]:ip:' \
  '--fw-rm-block-ip=[remove IP from auto-generated rules]:ip:' \
  '--fw-dump[display iptables policy]' \
  '--no-daemon[run interactively, alerts to stdout]' \
  '--no-rdns[disable reverse DNS]' \
  '--no-whois[disable whois lookups]' \
  '--no-passive-os[disable passive OS fingerprinting]' \
  '--no-fwcheck[skip firewall check]' \
  '--debug-syslog[debug syslog messages]' \
  '--CSV[CSV output format]' \
  '--CSV-fields=[CSV fields]:fields:' \
  '--CSV-file=[CSV output file]:file:_files' \
  '--gnuplot[generate gnuplot files]' \
  '--Search-domains=[search domains]:list:' \
  '--sig-update[update signatures]' \
  '*: :_files' && ret=0

return ret
