#compdef oxigraph
# Documentation: https://github.com/oxigraph/oxigraph/tree/main/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'serve:start the HTTP SPARQL server'
  'load:bulk load RDF files into a store'
  'query:run a SPARQL query against a store'
  'update:run a SPARQL update against a store'
  'optimize:optimize an existing store'
  'dump:dump store contents to an RDF file'
  'convert:convert between RDF serialization formats'
  'backup:create a consistent backup of a store'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'oxigraph command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (serve)
        _arguments \
          '--location=[directory used to store the database]:dir:_directories' \
          '--bind=[bind address (default localhost:7878)]:address' \
          '--read-only[run server in read-only mode]' && ret=0
        ;;
      (load)
        _arguments \
          '--location=[directory used to store the database]:dir:_directories' \
          '*--file=[RDF file to load]:file:_files' \
          '--format=[input RDF serialization format]:format' && ret=0
        ;;
    esac
    ;;
esac

return ret
