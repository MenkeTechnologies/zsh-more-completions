#compdef obnam-viewprof
# Documentation: man obnam-viewprof(1)
# Source: obnam-mirror/obnam obnam-viewprof (master) — view obnam Python pstats profile (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:profile file:_files -g "*.prof"' \
    '2::sort order:(cumulative ncalls tottime time pcalls cumtime calls filename module name pcalls)' \
    && ret=0

return ret
