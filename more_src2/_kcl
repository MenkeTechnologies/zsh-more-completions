#compdef kcl
# Documentation: https://github.com/kcl-lang/cli/blob/main/cmd/kcl/commands/root.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cobra command/flag defs).

# Zsh completion for kcl (KCL configuration language)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'run:compile and run KCL program'
      'lint:lint KCL files'
      'doc:generate documentation'
      'fmt:format KCL files'
      'test:run tests'
      'vet:validate data files using KCL schema'
      'clean:clean output files'
      'import:import from other formats'
      'mod:module management'
      'registry:registry management'
      'server:start language server'
      'version:show version'
    )
    _describe -t commands 'kcl subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      run)
        _arguments \
          '(-D --argument)'{-D,--argument}'=[top-level argument key=value]:argument' \
          '(-O --overrides)'{-O,--overrides}'=[override values]:overrides' \
          '(-S --path_selector)'{-S,--path_selector}'=[path selector]:selector' \
          '(-Y --setting)'{-Y,--setting}'=[setting file]:file:_files -g "*.yaml"' \
          '(-o --output)'{-o,--output}'=[output file]:file:_files' \
          '(-n --disable_none)'{-n,--disable_none}'[disable None output]' \
          '(-d --debug)'{-d,--debug}'[run in debug mode]' \
          '(-k --sort_keys)'{-k,--sort_keys}'[sort output keys]' \
          '(-H --show_hidden)'{-H,--show_hidden}'[show hidden attributes]' \
          '(-E --external)'{-E,--external}'=[mapping of package name to path]:external' \
          '(-V --vendor)'{-V,--vendor}'[run in vendor mode]' \
          '(-q --quiet)'{-q,--quiet}'[set the quiet mode]' \
          '(-r --strict_range_check)'{-r,--strict_range_check}'[strict numeric range check]' \
          '--format=[output format]:format:(json yaml toml)' \
          '*:KCL file:_files -g "*.k"' && ret=0
        ;;
      fmt|lint)
        _files -g '*.k' && ret=0
        ;;
      vet)
        _arguments \
          '*:file:_files' && ret=0
        ;;
      mod)
        local -a mod_subcmds=(
          'init:initialize a new module'
          'add:add a dependency'
          'pkg:package the current module'
          'metadata:show module metadata'
          'push:push a module to a registry'
          'pull:pull a module from a registry'
          'update:update dependencies'
          'graph:print the module dependency graph'
        )
        _describe -t commands 'mod subcommand' mod_subcmds && ret=0
        ;;
      registry)
        local -a reg_subcmds=(
          'login:login to a registry'
          'logout:logout from a registry'
        )
        _describe -t commands 'registry subcommand' reg_subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
