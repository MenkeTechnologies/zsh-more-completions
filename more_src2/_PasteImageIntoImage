#compdef PasteImageIntoImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/PasteImageIntoImage.cxx — paste a smaller image into a canvas (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:inputCanvasImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:inputImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:outputImage:_files' \
    '5:startIndex (e.g. 10x20x30):_default' \
    '6::backgroundLabel (default 0):_default' \
    '7::paintOverNonBackgroundVoxels (default 0):(0 1)' \
    '8::conflictLabel (default -1):_default' \
    && ret=0

return ret
