#compdef pt-heartbeat
# Documentation: https://docs.percona.com/percona-toolkit/pt-heartbeat.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--charset=[default character set]:charset:' \
  '--check[check replica delay once and exit]' \
  '--check-read-only[skip inserts if read_only enabled]' \
  '--config=[comma-separated config files]:files:_files' \
  '--create-table[create heartbeat table if missing]' \
  '--create-table-engine=[storage engine for heartbeat table]:engine:' \
  '--daemonize[fork to background (POSIX only)]' \
  '--database=[default database]:db:' \
  '--dbi-driver=[database driver]:driver:(mysql Pg)' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--fail-successive-errors=[fail after N successive DBI errors]:n:' \
  '--file=[output monitor results to file]:file:_files' \
  '--frames=[timeframes for moving averages]:frames:' \
  '--host=[MySQL host]:host:_hosts' \
  '(--insert-heartbeat-row --no-insert-heartbeat-row)'{--insert-heartbeat-row,--no-insert-heartbeat-row}'[insert heartbeat row if missing]' \
  '--interval=[update/check frequency seconds]:sec:' \
  '--log=[log file when daemonized]:file:_files' \
  '--monitor[monitor replica delay continuously]' \
  '--mysql_ssl=[create SSL MySQL connection]:n:' \
  '--password=[MySQL password]:pw:' \
  '--pid=[PID file]:file:_files' \
  '--port=[MySQL port]:port:' \
  '--print-source-server-id[print auto-detected source server id]' \
  '--read-only-interval=[sleep interval when read-only]:sec:' \
  '--recurse=[check replicas recursively to depth N]:n:' \
  '--recursion-method=[method to find replicas]:method:(processlist hosts none)' \
  '--replace[use REPLACE instead of UPDATE]' \
  '--replica-password=[replica password]:pw:' \
  '--replica-user=[replica user]:user:' \
  '--run-time=[duration to run before exiting]:dur:' \
  '--sentinel=[exit if this file exists]:file:_files' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--skew=[delay checks by this many seconds]:sec:' \
  '--socket=[MySQL socket]:file:_files' \
  '--source-server-id=[calculate delay from this source id]:id:' \
  '--stop[stop running instances via sentinel]' \
  '--table=[heartbeat table name]:name:' \
  '--update[update replication source heartbeat]' \
  '--user=[MySQL user]:user:' \
  '--utc[use UTC instead of system timezone]' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '*:DSN:' && ret=0

return ret
