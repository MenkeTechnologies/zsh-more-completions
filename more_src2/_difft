#compdef difft
# _difft — Wilfred difftastic structural diff CLI alias (Wilfred Hughes, Rust); clap-rs
# upstream: https://github.com/Wilfred/difftastic

_difft() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--background=+[background]:b:(light dark)' \
        '--color=+[color]:c:(always auto never)' \
        '--check-only[only check]' \
        '--display=+[display style]:d:(side-by-side side-by-side-show-both inline)' \
        '--exit-code[set exit code]' \
        '--graph-limit=+[graph limit nodes]:n:' \
        '--ignore-comments[ignore comments]' \
        '--list-languages[list languages]' \
        '--language=+[language]:l:(actionscript ada apex bash c clojure cmake cobol coffeescript common-lisp commonmark cpp css csharp dart dockerfile elisp elixir elm elvish erlang fish fsharp gleam go graphql groovy hack haskell hcl html janet java javascript json jsx julia kotlin latex lean lua make markdown nix objc ocaml pascal perl php pony powershell python qmldir qmljs r racket ruby rust scala scheme smalltalk sml solidity sql swift terraform toml tsv tsx twig typescript verilog vhdl vimscript visualbasic vue xml yaml zig)' \
        '--missing-as-empty[treat missing as empty]' \
        '--node-context[node context]' \
        '--num-context-lines=+[num context lines]:n:' \
        '--override=+[override]:list:' \
        '--parse-error-limit=+[parse error limit]:n:' \
        '--skip-unchanged[skip unchanged]' \
        '--strip-cr=+[strip cr]:b:(true false)' \
        '--syntax-highlight=+[syntax highlight]:b:(on off)' \
        '--tab-width=+[tab width]:n:' \
        '--width=+[width]:n:' \
        '--byte-limit=+[byte limit]:n:' \
        '--no-graph[no graph]' \
        '--list-themes[list themes]' \
        '--theme=+[theme]:str:' \
        '--ignore-imports[ignore imports]' \
        '--source-mapping=+[source mapping]:str:' \
        '*:file:_files'
}

_difft "$@"
