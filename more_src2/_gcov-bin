#compdef gcov
# _gcov-bin — GNU gcov coverage tool (FSF, C); profile/coverage analysis for GCC-compiled programs
# upstream: https://gcc.gnu.org

_gcov-bin() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-a[all blocks]' \
        '--all-blocks[all blocks]' \
        '-b[branch probabilities]' \
        '--branch-probabilities[branch probabilities]' \
        '-c[branch counts]' \
        '--branch-counts[branch counts]' \
        '-D[print exec counts]' \
        '--debug[debug]' \
        '-f[function summaries]' \
        '--function-summaries[function summaries]' \
        '-H[HTML output]' \
        '--human-readable[human readable]' \
        '-i[intermediate output]' \
        '--intermediate-format[intermediate output]' \
        '-j[json output]' \
        '--json-format[json output]' \
        '-k[use stamp file]' \
        '--use-colors[use colors]' \
        '-l[separate line for each function]' \
        '--long-file-names[long file names]' \
        '-m[mangled names]' \
        '--demangled-names[demangled names]' \
        '-n[no output]' \
        '--no-output[no output]' \
        '-o+[object dir]:dir:_files -/' \
        '--object-directory+[object dir]:dir:_files -/' \
        '-p[preserve path components]' \
        '--preserve-paths[preserve path components]' \
        '-q[quiet]' \
        '--use-hotness-colors[use hotness colors]' \
        '-r[only relative paths]' \
        '--relative-only[only relative paths]' \
        '-s+[source prefix]:path:' \
        '--source-prefix+[source prefix]:path:' \
        '-t[stdout output]' \
        '--stdout[stdout output]' \
        '-u[unconditional branches]' \
        '--unconditional-branches[unconditional branches]' \
        '-w[verbose lines]' \
        '--verbose[verbose]' \
        '-x[hash long filenames]' \
        '--hash-filenames[hash long filenames]' \
        '*:source file:_files'
}

_gcov-bin "$@"
