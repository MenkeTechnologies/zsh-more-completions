#compdef debugfs
# _debugfs — ext2/3/4 filesystem debugger (e2fsprogs); interactive inspector + recovery shell for ext filesystems
# upstream: https://github.com/tytso/e2fsprogs

_debugfs() {
    _arguments \
        '-w[open for writing]' \
        '-c[catastrophic mode (no superblock check)]' \
        '-i[ignore image file]' \
        '-n[disable metadata_csum check]' \
        '-D[directio]' \
        '-b+[block size]:n:' \
        '-s+[superblock block]:n:' \
        '-f+[batch input file]:file:_files' \
        '-R+[batch command]:command:' \
        '-V[show version]' \
        '-z+[undo file]:file:_files' \
        '*:device:_files'
}

_debugfs "$@"
