#compdef pt-secure-collect
# Documentation: https://docs.percona.com/percona-toolkit/pt-secure-collect.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'collect:collect data from server'
  'decrypt:decrypt encrypted collection'
  'encrypt:encrypt a file'
  'sanitize:sanitize a previously collected file'
)

_arguments -C \
  '(- *)--help[show help]' \
  '--debug[enable debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pt-secure-collect command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (collect)
        _arguments \
          '--bin-dir=[directory with Percona Toolkit binaries]:dir:_files -/' \
          '--temp-dir=[temporary directory]:dir:_files -/' \
          '--include-dir=[include directory in sanitized tar]:dir:_files -/' \
          '--config-file=[config file]:file:_files' \
          '--mysql-host=[MySQL host]:host:_hosts' \
          '--mysql-port=[MySQL port]:port:' \
          '--mysql-user=[MySQL user]:user:' \
          '--mysql-password=[MySQL password]:pw:' \
          '--ask-mysql-pass[prompt for MySQL password]' \
          '*--extra-cmd=[additional command to run]:cmd:' \
          '--encrypt-password=[password for output encryption]:pw:' \
          '--no-collect[skip data collection]' \
          '--no-sanitize[skip sanitization]' \
          '--no-encrypt[skip encryption]' \
          '--no-sanitize-hostnames[preserve hostnames]' \
          '--no-sanitize-queries[keep queries unmodified]' \
          '--no-remove-temp-files[retain temporary files]' && ret=0 ;;
      (decrypt)
        _arguments \
          '--outfile=[output file path]:file:_files' \
          '*:input file:_files' && ret=0 ;;
      (encrypt)
        _arguments \
          '--outfile=[output file path]:file:_files' \
          '*:input file:_files' && ret=0 ;;
      (sanitize)
        _arguments \
          '--input-file=[input file]:file:_files' \
          '--output-file=[output file]:file:_files' \
          '--no-sanitize-hostnames[do not sanitize hostnames]' \
          '--no-sanitize-queries[do not sanitize queries]' && ret=0 ;;
    esac ;;
esac

return ret
