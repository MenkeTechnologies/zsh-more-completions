#compdef fisher
# Documentation: https://github.com/jorgebucaran/fisher
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fisher: a plugin manager for the Fish shell

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'install:install plugins from GitHub, GitLab, or local directories'
      'remove:remove plugins'
      'update:update plugins to latest version'
      'list:list installed plugins (supports regex filter)'
    )
    _describe -t commands 'fisher subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      install|remove|update)
        _message 'plugin (owner/repo[@version] or URL)' && ret=0
        ;;
      list)
        _message 'optional regex pattern' && ret=0
        ;;
    esac
    ;;
esac

return ret
