#compdef diffseq
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/diffseq.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS diffseq: compare and report differences between similar sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[first sequence]:sequence USA:_files' \
  '-bsequence=[second sequence]:sequence USA:_files' \
  '-wordsize=[word size for word match]:size:' \
  '-globaldifferences[show global differences]' \
  '-rformat=[report format]:format:(table excel feattable gff3 listfile motif pir simple swiss tagseq)' \
  '-aoutfeat=[feature output for sequence a]:file:_files' \
  '-boutfeat=[feature output for sequence b]:file:_files' \
  '-outfile=[report output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
