#compdef id3tool
# Documentation: https://manpages.debian.org/bookworm/id3tool/id3tool.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm id3tool(1) manpage. ID3v1 only.
# Removed from prior file: bogus man.archlinux.org search URL.

# id3tool: ID3v1 tag editor for MP3 files
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-t --set-title)'{-t+,--set-title=}'[set title]:title:' \
  '(-a --set-album)'{-a+,--set-album=}'[set album]:album:' \
  '(-r --set-artist)'{-r+,--set-artist=}'[set artist]:artist:' \
  '(-y --set-year)'{-y+,--set-year=}'[set year (4 digits)]:year:' \
  '(-n --set-note)'{-n+,--set-note=}'[set note/comment]:note:' \
  '(-g --set-genre)'{-g+,--set-genre=}'[set genre code]:code:' \
  '(-G --set-genre-word)'{-G+,--set-genre-word=}'[set genre by name]:genre:' \
  '(-c --set-track)'{-c+,--set-track=}'[set track number]:track:' \
  '(-l --genre-list)'{-l,--genre-list}'[show genre list]' \
  '*:mp3 file:_files -g "*.mp3(-.)"' && ret=0
return ret
