#compdef portainer
# Documentation: https://github.com/portainer/portainer/blob/develop/api/cli/cli.go
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Portainer - container management UI

_arguments -s -S \
  '--admin-password=[set admin password with provided hash]:hash:' \
  '--admin-password-file=[path to file containing admin password]:file:_files' \
  '(-p --bind)'{-p,--bind}'=[address and port to serve Portainer]:address:' \
  '--bind-https=[address and port to serve Portainer via https]:address:' \
  '(-a --assets)'{-a,--assets}'=[path to assets]:path:_files -/' \
  '(-d --data)'{-d,--data}'=[path to data directory]:directory:_files -/' \
  '(-b --base-url)'{-b,--base-url}'=[base URL parameter]:url' \
  '--edge-compute[enable Edge Compute features]' \
  '*--feat=[feature flags]:flag' \
  '(-l --hide-label)'{-l,--hide-label}'=[hide containers with specific label]:label:' \
  '(-H --host)'{-H,--host}'=[environment URL]:endpoint:' \
  '--http-disabled[disable HTTP]' \
  '--http-enabled[enable HTTP]' \
  '--log-level=[minimum logging level]:level:(DEBUG INFO WARN ERROR)' \
  '--log-mode=[logging output mode]:mode:(PRETTY JSON NOCOLOR)' \
  '--logo=[URL to logo]:url:' \
  '--snapshot-interval=[snapshot interval]:duration:' \
  '(-t --templates)'{-t,--templates}'=[URL to templates definitions]:url:' \
  '--tlsverify[enable TLS support]' \
  '--tlscacert=[TLS CA certificate]:file:_files' \
  '--tlscert=[TLS certificate]:file:_files' \
  '--tlskey=[TLS key]:file:_files' \
  '--tlsskipverify[disable TLS server verification]' \
  '--tunnel-addr=[address to serve tunnel server]:address:' \
  '--tunnel-port=[port to serve tunnel server]:port:' \
  '--no-analytics[disable analytics (deprecated)]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]'
