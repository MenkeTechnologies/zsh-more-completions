#compdef pixi
# Documentation: https://pixi.sh/latest/reference/cli/pixi/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_pixi_commands() {
  local -a commands=(
    'add:add dependencies to the workspace'
    'auth:login to prefix.dev/anaconda.org channels'
    'build:build a conda package from a Pixi package'
    'clean:clean environments'
    'completion:generate shell completion script'
    'config:configuration management'
    'exec:run command in temporary environment'
    'global:global package management'
    'import:import a file into an environment'
    'info:info about system / workspace / environments'
    'init:create a new workspace'
    'install:install an environment'
    'list:list packages of the current workspace'
    'lock:solve environment and update lockfile'
    'publish:build and publish a conda package'
    'reinstall:re-install an environment'
    'remove:remove dependencies'
    'run:run task in the pixi environment'
    'search:search a conda package'
    'self-update:update pixi'
    'shell:start a shell in a pixi environment'
    'shell-hook:print pixi activation script'
    'task:interact with tasks in the workspace'
    'tree:show tree of workspace dependencies'
    'update:check for newer versions and update lockfile'
    'upgrade:upgrade dependencies'
    'upload:upload conda packages'
    'workspace:modify workspace configuration'
  )
  _describe -t commands 'pixi command' commands
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
  '--color[coloring]:when:(always never auto)' \
  '--manifest-path[path to manifest]:file:_files' \
  '1:command:_pixi_commands' \
  '*::arg:->args' && ret=0

case $state in
  args)
    case $words[1] in
      add)
        _arguments -s -S \
          '--channel[channel to use]:channel' \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--feature[feature]:feature' \
          '--host[add as host dependency]' \
          '--build[add as build dependency]' \
          '--no-install[skip install after add]' \
          '--platform[platform]:platform' \
          '--pypi[add as PyPI dependency]' \
          '*:package' && ret=0
        ;;
      init)
        _arguments -s -S \
          '-c[channels]:channel' \
          '--format[manifest format]:format:(pixi conda)' \
          '--import[import from environment file]:file:_files' \
          '--platform[platform]:platform' \
          '*:directory:_directories' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--frozen[install from lockfile only]' \
          '--locked[require lockfile is up-to-date]' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--frozen[use frozen lockfile]' \
          '--locked[require lockfile is up-to-date]' \
          '*:task or command' && ret=0
        ;;
      remove)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' \
          '--feature[feature]:feature' \
          '--host[remove host dependency]' \
          '--build[remove build dependency]' \
          '--pypi[remove PyPI dependency]' \
          '*:package' && ret=0
        ;;
      search)
        _arguments -s -S \
          '-c[channel]:channel' \
          '--limit[max results]:count' \
          '--platform[platform]:platform' \
          '*:query' && ret=0
        ;;
      global)
        _arguments -s -S \
          '1:action:(install remove list upgrade sync)' \
          '*:package' && ret=0
        ;;
      task)
        _arguments -s -S \
          '1:action:(add remove alias list)' \
          '*:task' && ret=0
        ;;
      shell)
        _arguments -s -S \
          '(-e --environment)'{-e,--environment}'[environment]:env' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac
return ret
