#compdef lsd
# Documentation: https://github.com/lsd-rs/lsd
# Reference accessed: 2026-05-19
# Verified: lsd-rs/lsd source src/app.rs clap definitions.

# Zsh completion for lsd - the next-gen ls command (lsd-rs/lsd)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-a --all)'{-a,--all}'[do not ignore entries starting with .]' \
  '(-A --almost-all)'{-A,--almost-all}'[do not list implied . and ..]' \
  '--classic[enable classic mode (output similar to ls)]' \
  '--color=[when to use terminal colors]:mode:(always auto never)' \
  '--config-file=[provide a custom config file]:file:_files' \
  '(-d --directory-only)'{-d,--directory-only}'[only list directories]' \
  '--blocks=[blocks to display in order]:blocks:(permission user group context size date name inode links git)' \
  '--date=[how to display date]:mode:(date locale relative)' \
  '--depth=[recurse depth]:n:' \
  '(-L --dereference)'{-L,--dereference}'[dereference symbolic links]' \
  '(-F --classify)'{-F,--classify}'[append indicator]' \
  '--git[show git status of files]' \
  '--group-dirs=[group directories]:mode:(none first last)' \
  '--group-directories-first[group directories before files]' \
  '--header[display block headers]' \
  '--human-readable[for ls compatibility]' \
  '--hyperlink=[attach hyperlinks]:mode:(always auto never)' \
  '*'{-I,--ignore-glob=}'[do not list entries matching glob]:glob:' \
  '--icon=[when to print icons]:mode:(always auto never)' \
  '--icon-theme=[icon theme]:theme:(fancy unicode)' \
  '(-i --inode)'{-i,--inode}'[display index number]' \
  '(-l --long)'{-l,--long}'[use long format]' \
  '(-1 --oneline)'{-1,--oneline}'[display one entry per line]' \
  '(-R --recursive)'{-R,--recursive}'[recurse into directories]' \
  '(-r --reverse)'{-r,--reverse}'[reverse sort order]' \
  '(-S --sizesort)'{-S,--sizesort}'[sort by size]' \
  '--total-size[display total size of directories]' \
  '--ignore-config[ignore the configuration file]' \
  '--size=[size display format]:format:(default bytes short)' \
  '--sort=[sort by]:word:(size time version extension git name none)' \
  '(-t --timesort)'{-t,--timesort}'[sort by time]' \
  '--tree[recurse into directories as tree]' \
  '(-v --versionsort)'{-v,--versionsort}'[natural sort of version numbers]' \
  '(-X --extensionsort)'{-X,--extensionsort}'[sort by entry extension]' \
  '(-G --gitsort)'{-G,--gitsort}'[sort by git status]' \
  '(-U --no-sort)'{-U,--no-sort}'[no sort, directory order]' \
  '(-Z --context)'{-Z,--context}'[print security context label]' \
  '--no-symlink[do not display symlink target]' \
  '(-N --literal)'{-N,--literal}'[print names without quoting]' \
  '--permission=[permission format]:format:(rwx octal attributes disable)' \
  '--system-protected[include Windows system-protected files]' \
  '--truncate-owner-after=[truncate owner names after N chars]:n:' \
  '--truncate-owner-marker=[truncate marker string]:str:' \
  '--generate-config[output default config to stdout]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--help[show help]' \
  '*:file:_files' && ret=0
return ret
