#compdef linkerd
# Documentation: https://linkerd.io/2/reference/cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '--api-addr=[API address]:address' \
  '--context=[Kubernetes context]:context' \
  '--kubeconfig=[kubeconfig path]:kubeconfig:_files' \
  {-L,--linkerd-namespace}'=[Linkerd namespace]:namespace' \
  '--verbose[verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'authz:list authorizations for a resource'
      'check:verify the Linkerd installation'
      'completion:generate shell completion code'
      'diagnostics:commands for diagnosing Linkerd components'
      'identity:display pod certificate(s)'
      'inject:add the Linkerd proxy to a Kubernetes config'
      'install:output configs to install the Linkerd control plane'
      'install-cni:output configs to install Linkerd CNI'
      'multicluster:manage the multicluster setup'
      'profile:output service profile configuration'
      'prune:identify extraneous control plane resources'
      'uninject:remove the Linkerd proxy from a config'
      'uninstall:output resources to uninstall Linkerd'
      'upgrade:output configs to upgrade the control plane'
      'version:print client/server version info'
      'viz:manage the linkerd-viz extension'
    )
    _describe -t commands 'linkerd command' commands && ret=0
    ;;
  args)
    case $words[1] in
      install)
        _arguments -s -S \
          '*--set=[set a Helm value]:key=value' \
          '*--values=[values file]:values:_files' \
          '--ignore-cluster[ignore cluster connectivity]' \
          '--crds[install CRDs]' \
          '--ha[enable high availability]' \
          '--disable-heartbeat[disable heartbeat]' \
          '--addon-config=[addon config file]:config:_files' \
          && ret=0
        ;;
      inject)
        _arguments -s -S \
          '--manual[output YAML only]' \
          '--proxy-version=[proxy version]:version' \
          '*:file:_files' \
          && ret=0
        ;;
      check)
        _arguments -s -S \
          '--pre[run pre-install checks]' \
          '--proxy[run proxy checks]' \
          {-o,--output}'=[output format]:format:(table json short)' \
          '--wait=[wait time]:duration' \
          && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish)' \
          && ret=0
        ;;
      viz)
        _arguments -s -S -C \
          '1:subcommand:(install stat top tap routes dashboard profile)' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
