#compdef power-profiles-daemon
# _power-profiles-daemon — power profile management daemon (upower/power-profiles-daemon)
# upstream: https://gitlab.freedesktop.org/upower/power-profiles-daemon
# Flags from src/power-profiles-daemon.c (GOptionEntry options[]).

_power-profiles-daemon() {
    _arguments \
        '(-v --verbose)'{-v,--verbose}'[show extra debugging information]' \
        '(-r --replace)'{-r,--replace}'[replace the running instance of power-profiles-daemon]' \
        '--block-driver=[block one or more profile drivers from loading]:driver:' \
        '--block-action=[block one or more profile actions from loading]:action:'
}

_power-profiles-daemon "$@"
