#compdef foundryup
# Documentation: https://getfoundry.sh/getting-started/installation
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# foundryup — installer/version manager for forge/cast/anvil/chisel

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--install=[install nightly, a version, or a commit hash]:version-or-commit' \
  '--branch=[install from a specific branch]:branch' \
  '--path=[build from a local source directory]:path:_directories' \
  '--force[skip verification and force fresh install]' && ret=0

return ret
