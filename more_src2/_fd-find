#compdef fd-find fdfind
# Documentation: https://github.com/sharkdp/fd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fd is packaged as fd-find / fdfind on Debian and Ubuntu because the binary
# name `fd` conflicts with another package. Delegate to the standard `_fd`
# completion when available so flag parity stays in sync with upstream.

local curcontext="$curcontext" state line ret=1

(( $+functions[_fd] )) || autoload -Uz _fd 2>/dev/null
if (( $+functions[_fd] )); then
  _fd "$@"
  return
fi

_arguments \
  '*::fd arg:_files' && ret=0

return ret
