#compdef mdeliver
# Documentation: https://manpages.debian.org/testing/mblaze/mdeliver.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-M[treat stdin as an mbox and import each message]' \
  '-c[deliver messages into cur/ rather than new/]' \
  '-v[print each new message filename after delivery]' \
  '-X+[override maildir flags for the new message]:flags:' \
  '*:maildir:_files -/' && ret=0

return ret
