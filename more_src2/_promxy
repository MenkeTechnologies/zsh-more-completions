#compdef promxy
# _promxy — Prometheus-aware HA proxy/aggregator (jacksontj/promxy)
# upstream: https://github.com/jacksontj/promxy
# Flags from cmd/promxy/main.go (jessevdk/go-flags).

_promxy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--check-config[validate config and exit]' \
        '--bind-addr=[listen address]:addr:' \
        '--config=[config file path]:file:_files -g "*.(yml|yaml)"' \
        '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
        '--log-format=[log format]:fmt:(text json)' \
        '--log-max-form-prefix=[max prefix for form values in logs]:n:' \
        '--web.config.file=[Prometheus-format web config (TLS/auth)]:file:_files' \
        '--web.cors.origin=[CORS origin regex]:regex:' \
        '--web.read-timeout=[max read timeout]:duration:' \
        '--metrics-path=[Prometheus metrics endpoint path]:path:' \
        '*--proxy-headers=[headers to proxy downstream]:header:' \
        '--web.external-url=[external Prometheus URL]:url:' \
        '--web.route-prefix=[prefix for internal routes]:prefix:' \
        '--web.enable-lifecycle[enable shutdown/reload via HTTP]' \
        '--query.timeout=[max query duration]:duration:' \
        '--query.max-samples=[max samples loaded per query]:n:' \
        '--query.lookback-delta=[max lookback duration]:duration:' \
        '--query.max-concurrency=[max concurrent queries]:n:' \
        '--storage.path=[local state directory]:dir:_files -/' \
        '--remote-read.max-concurrency=[max concurrent remote-read calls]:n:' \
        '--alertmanager.notification-queue-capacity=[Alertmanager queue capacity]:n:' \
        '--access-log-destination=[access log destination]:dst:(none stdout stderr)' \
        '--rules.alert.for-outage-tolerance=[max outage to tolerate for FOR state]:duration:' \
        '--rules.alert.for-grace-period=[min grace period between alert & restored FOR state]:duration:' \
        '--rules.alert.resend-delay=[min delay before resending alert]:duration:' \
        '--rules.alertbackfill[recalculate alert state on startup]' \
        '--http.shutdown-delay=[wait before HTTP shutdown]:duration:' \
        '--http.shutdown-timeout=[max graceful shutdown time]:duration:'
}

_promxy "$@"
