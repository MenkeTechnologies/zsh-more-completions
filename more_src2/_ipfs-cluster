#compdef ipfs-cluster-service ipfs-cluster-ctl ipfs-cluster-follow ipfs-cluster
# _ipfs-cluster — Protocol Labs IPFS Cluster service+ctl+follow for multi-peer pinset coordination atop go-ipfs with CRDT replication and trustless follower mode (ipfs-cluster team, Go); urfave/cli
# upstream: https://github.com/ipfs-cluster/ipfs-cluster

_ipfs-cluster() {
    local -a sub=(
        'init:init configuration'
        'daemon:run cluster daemon'
        'state:state operations'
        'version:show version'
        'pin:pin operations'
        'unpin:unpin operations'
        'peers:peer operations'
        'health:health operations'
        'add:add file to cluster'
        'status:show status'
        'recover:recover'
        'sync:sync'
        'ipfs:IPFS operations'
        'commands:list commands'
        'help:show help'
        'follow:follower mode'
        'list:list pins'
        'info:show info'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--config=+[file]:file:_files -g "*.json"' \
        '-c+[file]:file:_files -g "*.json"' \
        '--debug[debug]' \
        '-d[debug]' \
        '-f[force]' \
        '--force[force]' \
        '--host=+[multiaddr]:str:' \
        '--port=+[port]:n:' \
        '--enc=+[fmt]:f:(json text)' \
        '--basic-auth-credentials=+[user:pass]:str:' \
        '--secret=+[hex]:str:' \
        '--consensus=+[c]:c:(crdt raft)' \
        '--datastore=+[d]:d:(leveldb badger badger3 pebble)' \
        '--peer-name=+[name]:str:' \
        '--cluster-secret=+[hex]:str:' \
        '--no-trust[no trust]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ipfs-cluster subcommand' sub ;;
        args)
            case $words[1] in
                pin) _arguments \
                    '1:action:(add rm ls update)' \
                    '*:CID:' ;;
                follow) _arguments \
                    '1:action:(init run list info)' \
                    '*:cluster:' ;;
                add) _arguments '*:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_ipfs-cluster "$@"
