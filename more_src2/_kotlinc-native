#compdef kotlinc-native konanc
# _kotlinc-native — Kotlin/Native AOT compiler (JetBrains); compiles Kotlin to native binaries via LLVM for iOS/macOS/Linux/Windows/Android NDK/WASM
# upstream: https://github.com/JetBrains/kotlin/tree/master/kotlin-native

_kotlinc-native() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-X[show advanced options]' \
        '-output+[output file]:file:_files' \
        '-target+[target triple]:triple:(linux_x64 linux_arm64 macos_x64 macos_arm64 mingw_x64 ios_arm64 ios_x64 ios_simulator_arm64 tvos_arm64 tvos_x64 tvos_simulator_arm64 watchos_arm32 watchos_arm64 watchos_x64 watchos_simulator_arm64 android_x64 android_arm64 wasm32)' \
        '-produce+[output kind]:kind:(program library bitcode dynamic static framework)' \
        '-repo+[library search path]:dir:_files -/' \
        '-library+[library]:lib:' \
        '-l+[library]:lib:' \
        '-linker-option+[linker option]:opt:' \
        '-linker-options+[linker options]:opts:' \
        '-native-library+[native library]:file:_files' \
        '-include-binary+[include binary]:file:_files' \
        '-export-library+[re-export library]:lib:' \
        '-generate-test-runner[generate test runner]' \
        '-Xverify[verify IR]' \
        '-opt[optimize]' \
        '-g[debug info]' \
        '-ea[enable assertions]' \
        '-Werror[warnings as errors]' \
        '-verbose+[verbose phase]:phase:' \
        '-time[print phase timing]' \
        '-memory-model+[memory model]:model:(strict relaxed experimental)' \
        '-friend-modules+[friend module paths]:paths:' \
        '*:source:_files -g "*.(kt|kts)"'
}

_kotlinc-native "$@"
