#compdef djhtml
# Documentation: https://github.com/rtts/djhtml
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for djhtml (Django/Jinja HTML template indenter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --check)'{-c,--check}'[check files without modifying]' \
  '(-t --tabwidth)'{-t,--tabwidth}'+[tab width]:width' \
  '*'{-b,--extra-block}'+[extra non-standard block tag BEGIN,END]:begin,end' \
  '*:template file:_files -g "*.{html,htm,jinja,jinja2,j2,djhtml}"' && ret=0

return ret
