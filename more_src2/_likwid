# _likwid — RRZE LIKWID Like I Knew What I am Doing lightweight performance tools toolset of CLI utilities for HPC (RRZE-HPC team, C); custom argparse
# upstream: https://github.com/RRZE-HPC/likwid

_likwid() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-V+[verbose]:n:' \
        '--verbose=+[verbose]:n:' \
        '-c+[CPU mask]:str:' \
        '--cpus=+[CPU mask]:str:' \
        '-C+[CPU set]:str:' \
        '--cpuset=+[CPU set]:str:' \
        '-g+[performance group]:g:(BRANCH CACHES CBOX CLOCK CYCLE_ACTIVITY DATA DIVIDE ENERGY FALSE_SHARE FLOPS_AVX FLOPS_DP FLOPS_SP HBM ICACHE L2 L2CACHE L3 L3CACHE MEM MEM_DP MEM_SP NUMA PORT_USAGE POWER QPI RECOVERY TLB_DATA TLB_INSTR UNCORE UPI VIEW)' \
        '--group=+[performance group]:g:(BRANCH CACHES CYCLE_ACTIVITY DATA DIVIDE ENERGY FLOPS_AVX FLOPS_DP FLOPS_SP L2 L2CACHE L3 L3CACHE MEM MEM_DP MEM_SP NUMA POWER QPI TLB_DATA TLB_INSTR)' \
        '-M+[memory mode]:m:(0 1 2)' \
        '--access-mode=+[memory mode]:m:(0 1 2)' \
        '-O[CSV output]' \
        '--csv[CSV output]' \
        '-i[runtime info]' \
        '--info[runtime info]' \
        '-m[marker API]' \
        '--marker[marker API]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-S+[duration sec]:f:' \
        '--stethoscope=+[duration sec]:f:' \
        '-t+[interval sec]:f:' \
        '--timestamp=+[interval sec]:f:' \
        '-T+[probe time sec]:f:' \
        '--time-step=+[probe time sec]:f:' \
        '-f[force]' \
        '--force[force]' \
        '-e[list events]' \
        '--list-events[list events]' \
        '-E+[event filter]:str:' \
        '--event-filter=+[event filter]:str:' \
        '-a[list groups]' \
        '--list-groups[list groups]' \
        '-H[help on groups]' \
        '-s[skip mask]' \
        '--skip-mask[skip mask]' \
        '-G+[GPU id]:n:' \
        '--gpus=+[GPU id]:n:' \
        '-W+[CUDA work groups]:str:' \
        '--work-groups=+[CUDA work groups]:str:' \
        '-n+[N iterations]:n:' \
        '--iterations=+[N iterations]:n:' \
        '-l+[list benchmarks]' \
        '--list-benchmarks[list benchmarks]' \
        '-p+[print perfgroup]:str:' \
        '--print[print perfgroup]:str:' \
        '*:executable:_command_names'
}

_likwid "$@"
