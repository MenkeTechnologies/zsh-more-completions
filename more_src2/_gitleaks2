#compdef gitleaks2
# _gitleaks2 — Zachary Rice gitleaks gitleaks2 CLI command-line frontend wrapping the Gitleaks SAST tool for detecting and preventing hardcoded secrets like passwords API keys and tokens in git repos open-source written in Go provides protect mode and detect mode and a pre-commit hook configurable rules TOML allowlist staged scan baseline gitlog log-opts JSON-CSV-SARIF-JUNIT report (Zachary Rice gitleaks team, Go); cobra
# upstream: https://github.com/gitleaks/gitleaks

_gitleaks2() {
    local -a sub=(
        'detect:detect secrets in repo or files'
        'protect:protect secrets (pre-commit)'
        'dir:scan a directory'
        'git:scan a git repo'
        'stdin:scan stdin'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config path]:file:_files -g ".gitleaks.toml *.toml"' \
        '--config=+[file]:file:_files -g ".gitleaks.toml *.toml"' \
        '--exit-code=+[code]:n:' \
        '--source=+[path]:_files' \
        '-s+[source]:_files' \
        '--baseline-path=+[file]:file:_files' \
        '-b+[baseline]:file:_files' \
        '--report-path=+[file]:file:_files' \
        '-r+[report]:file:_files' \
        '--report-format=+[fmt]:f:(json csv junit sarif template)' \
        '-f+[format]:f:(json csv junit sarif template)' \
        '--report-template=+[file]:file:_files -g "*.tmpl"' \
        '--no-color[no color]' \
        '--no-banner[no banner]' \
        '--redact[redact secrets]' \
        '-r+[redact]:str:' \
        '--ignore-gitleaks-allow[ignore allow]' \
        '--gitleaks-ignore-path=+[file]:file:_files' \
        '--max-archive-depth=+[N]:n:' \
        '--log-level=+[level]:l:(trace debug info warn error fatal panic)' \
        '-l+[log level]:l:(trace debug info warn error fatal panic)' \
        '--log-opts=+[opts]:str:' \
        '--no-git[no git scan]' \
        '--pipe[stdin pipe mode]' \
        '--diagnostics=+[d]:str:' \
        '--diagnostics-dir=+[dir]:dir:_files -/' \
        '--enable-experimental-rules[enable experimental]' \
        '--enable-rule=+[rule]:str:' \
        '--disable-rule=+[rule]:str:' \
        '--max-target-megabytes=+[MB]:n:' \
        '--max-decode-depth=+[N]:n:' \
        '--staged[staged only]' \
        '-S[staged only]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitleaks subcommand' sub ;;
        args)
            case $words[1] in
                dir|git) _arguments '*:path:_files -/' ;;
            esac
            ;;
    esac
}

_gitleaks2 "$@"
