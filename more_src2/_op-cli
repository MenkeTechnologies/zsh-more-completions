#compdef op-cli
# _op-cli — 1Password op password manager CLI alias (1Password team, Go); cobra
# upstream: https://developer.1password.com/docs/cli

_op-cli() {
    local -a sub=(
        'account:list:list accounts'
        'account:add:add account'
        'account:get:get account'
        'account:forget:forget account'
        'completion:generate completion'
        'connect:1Password Connect commands'
        'connect:server:create:create connect server'
        'connect:server:get:get connect server'
        'connect:server:list:list connect servers'
        'connect:server:delete:delete connect server'
        'connect:server:edit:edit connect server'
        'connect:token:create:create connect token'
        'connect:token:list:list connect tokens'
        'connect:token:edit:edit connect token'
        'connect:token:delete:delete connect token'
        'connect:vault:list:list connect vaults'
        'connect:vault:grant:grant vault access'
        'connect:vault:revoke:revoke vault access'
        'document:create:create document'
        'document:get:get document'
        'document:delete:delete document'
        'document:edit:edit document'
        'document:list:list documents'
        'document:share:share document'
        'document:replace:replace document'
        'document:trash:trash document'
        'document:restore:restore document'
        'events-api:create:create events api token'
        'events-api:revoke:revoke events api token'
        'group:create:create group'
        'group:delete:delete group'
        'group:edit:edit group'
        'group:get:get group'
        'group:list:list groups'
        'group:user:grant:grant group access'
        'group:user:revoke:revoke group access'
        'group:user:list:list group users'
        'item:create:create item'
        'item:delete:delete item'
        'item:edit:edit item'
        'item:get:get item'
        'item:list:list items'
        'item:share:share item'
        'item:template:get:get item template'
        'item:template:list:list item templates'
        'plugin:init:init plugin'
        'plugin:inspect:inspect plugin'
        'plugin:list:list plugins'
        'plugin:run:run plugin'
        'plugin:clear:clear plugin credentials'
        'read:read secret reference'
        'inject:inject secret references'
        'service-account:create:create service account'
        'service-account:get:get service account'
        'service-account:list:list service accounts'
        'service-account:revoke:revoke service account'
        'signin:sign in'
        'signout:sign out'
        'update:update CLI'
        'user:confirm:confirm user'
        'user:delete:delete user'
        'user:edit:edit user'
        'user:get:get user'
        'user:list:list users'
        'user:provision:provision user'
        'user:reactivate:reactivate user'
        'user:suspend:suspend user'
        'vault:create:create vault'
        'vault:delete:delete vault'
        'vault:edit:edit vault'
        'vault:get:get vault'
        'vault:list:list vaults'
        'vault:user:grant:grant vault access'
        'vault:user:revoke:revoke vault access'
        'vault:user:list:list vault users'
        'vault:group:grant:grant vault access'
        'vault:group:revoke:revoke vault access'
        'vault:group:list:list vault groups'
        'whoami:show current account'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--account=+[account shorthand]:str:' \
        '--cache[enable session cache]' \
        '--config=+[config dir]:dir:_files -/' \
        '--debug[debug]' \
        '--encoding=+[encoding]:e:(utf-8 shift-jis gbk big5)' \
        '--format=+[format]:f:(json plain)' \
        '--iso-timestamps[iso timestamps]' \
        '--no-color[no color]' \
        '--session=+[session token]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'op subcommand' sub ;;
        args)
            case $words[1] in
                item:get|item:edit|item:delete|item:share) _arguments \
                    '1:item name or UUID:' \
                    '--vault=+[vault]:str:' \
                    '--fields=+[fields csv]:str:' \
                    '--reveal[reveal hidden values]' \
                    '--format=+[format]:f:(json table)' ;;
                item:list) _arguments \
                    '--vault=+[vault]:str:' \
                    '--categories=+[categories csv]:str:' \
                    '--favorite[only favorites]' \
                    '--tags=+[tags csv]:str:' \
                    '--include-archive[include archived]' ;;
                item:create) _arguments \
                    '--category=+[category]:c:(Login Password "Secure Note" "Credit Card" Identity Document "Software License" "API Credential" Database Driver License "Outdoor License" Passport "Reward Program" "Social Security Number" "Wireless Router" Server Email Account "Bank Account" Membership "Medical Record")' \
                    '--title=+[title]:str:' \
                    '--vault=+[vault]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '--url=+[url]:url:_urls' \
                    '--generate-password=+[recipe]:str:' \
                    '--dry-run[dry run]' ;;
                signin) _arguments \
                    '--account=+[account shorthand]:str:' \
                    '--raw[raw session token]' \
                    '--cache[enable cache]' ;;
                read|inject) _arguments \
                    '1:reference or file:' \
                    '--no-newline[no newline]' \
                    '--out-file=+[out file]:file:_files' \
                    '--in-file=+[in file]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_op-cli "$@"
