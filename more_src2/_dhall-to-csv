#compdef dhall-to-csv
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-csv
# Source: dhall-lang/dhall-haskell dhall-csv/dhall-to-csv/Main.hs — compile Dhall to CSV.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--explain[explain error messages in detail]' \
    '--file=[read Dhall expression from FILE instead of stdin]:file:_files' \
    '--output=[write CSV to FILE instead of stdout]:file:_files' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
