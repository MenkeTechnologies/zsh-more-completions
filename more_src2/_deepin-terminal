#compdef deepin-terminal
# _deepin-terminal — Deepin deepin-terminal (Qt-based terminal emulator from Deepin; -w workdir, -e/--execute one-shot command, --geometry WxH, -t window title, -q quake-mode (drop-down), -k keep-open after command exits, -s split horizontal, --working-directory)
# upstream: https://github.com/linuxdeepin/deepin-terminal
# Flags from deepin-terminal main.cpp on tip.

_deepin-terminal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '-w+[workdir]:dir:_files -/' \
        '--working-directory=*[workdir]:dir:_files -/' \
        '-e+[execute command]:command:_command_names -e' \
        '--execute+[execute command]:command:_command_names -e' \
        '--geometry=*[WxH]:geom:' \
        '-t+[title]:title:' \
        '-q[quake (drop-down) mode]' \
        '--quake-mode[quake (drop-down) mode]' \
        '-k[keep open after exit]' \
        '--keep-open[keep open after exit]' \
        '-s+[split]:mode:(horizontal vertical)'
}

_deepin-terminal "$@"
