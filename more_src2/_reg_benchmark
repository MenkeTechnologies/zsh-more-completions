#compdef reg_benchmark
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_benchmark.cpp — registration benchmark utility (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '-dim+[image dimension]:n:_default' \
    '-sp+[control-point spacing (mm)]:n:_default' \
    '-bin+[histogram bin count]:n:_default' \
    '-o+[output report file]:file:_files' \
    '-cpu[CPU benchmark]' \
    && ret=0

return ret
