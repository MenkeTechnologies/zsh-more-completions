#compdef grdc
# Documentation: man grdc(6)
# Source: openbsd/src games/grdc/grdc.c — grand digital clock (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-s[scroll the digits when they change]' \
    '1::seconds to run:_default' \
    && ret=0

return ret
