#compdef rootdrawtree
# Documentation: https://github.com/root-project/root/blob/master/main/python/rootdrawtree.py
# Source: root-project/root main/python/rootdrawtree.py — fill histograms from ROOT tree expressions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-o --output)'{-o+,--output=}'[output ROOT file for histograms]:file:_files -g "*.root(-.)"' \
    '*'{-i+,--input=}'[input ROOT file(s)]:file:_files -g "*.root(-.)"' \
    '(-t --tree)'{-t+,--tree=}'[tree name]:name:_default' \
    '*'{-hs+,--histo=}'[histogram expression NAME = EXPR if CUT]:expr:_default' \
    '1:config file:_files' \
    && ret=0

return ret
