#compdef ezmlm-return
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-return.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-d[assume bounce is for digest list]' \
  '-D[assume bounce is for normal list]' \
  '1:dir:_files -/' && ret=0

return ret
