#compdef gmtconnect
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtconnect.html
# Source: GenericMappingTools/gmt classic-mode gmtconnect — join line segments whose endpoints lie within a tolerance.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[output closed polygons to file]:file:_files' \
    '-D+[dump each segment to separate file]:opts:_default' \
    '-L+[link info file (segment connections)]:file:_files' \
    '-Q+[output-filename list (with -D)]:file:_files' \
    '-T+[separation tolerance for joining (+s secondary)]:tolerance:_default' \
    '*-V[verbose (stackable)]' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
