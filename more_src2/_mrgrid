#compdef mrgrid
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrgrid.html
# Source: MRtrix3/mrtrix3 cmd/mrgrid.cpp — modify image grid (regrid/crop/pad) (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-template+[regrid using this template image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-size+[output image size (comma-separated)]:dims:_default' \
    '-voxel+[output voxel size (comma-separated mm)]:size:_default' \
    '-scale+[scale factor per axis]:factor:_default' \
    '-interp+[interpolation method]:method:(nearest linear cubic sinc)' \
    '-oversample+[oversample factor(s)]:factor:_default' \
    '-as+[reference image for crop/pad]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-uniform+[uniform crop/pad margin in voxels]:number:_default' \
    '-mask+[mask used for autocrop]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '*-axis+[per-axis crop/pad spec]:index:_default:spec:_default' \
    '-all_axes[apply uniform margin to all axes]' \
    '-crop_unbound[allow cropping outside image bounds]' \
    '-fill+[out-of-bounds fill value (or nan/inf/-inf)]:number:_default' \
    '-strides+[output data strides]:strides:_default' \
    '-datatype+[output datatype]:dtype:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '2:operation:(regrid crop pad)' \
    '3:output image:_files' \
    && ret=0

return ret
