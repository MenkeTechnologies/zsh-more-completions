#compdef dapr-operator
# _dapr-operator — Dapr CRD/Service operator (dapr/dapr)
# upstream: https://github.com/dapr/dapr
# Flags from cmd/operator/options/options.go on tip.

_dapr-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[Dapr Configuration object name or YAML file]:name:' \
        '--watch-interval=[pod state poll interval (0/once supported)]:dur:' \
        '--max-pod-restarts-per-minute=[max restarts of invalid pods per minute]:n:' \
        '--disable-leader-election[disable leader election]' \
        '--disable-service-reconciler[disable Deployment/StatefulSet Service reconciler]' \
        '--watch-namespace=[watched namespace for Dapr-annotated resources]:ns:' \
        '--enable-argo-rollout-service-reconciler[reconcile Services for Argo Rollouts]' \
        '--watchdog-can-patch-pod-labels[allow watchdog to patch pod labels]' \
        '--trust-anchors-file=[control-plane trust anchors path]:file:_files' \
        '--port=[operator API server bind port]:port:' \
        '--listen-address=[operator API server bind address]:ip:' \
        '--healthz-port=[healthz bind port]:port:' \
        '--healthz-listen-address=[healthz bind address]:ip:' \
        '--webhook-server-port=[admission webhook bind port]:port:' \
        '--webhook-server-listen-address=[admission webhook bind address]:ip:' \
        '--log-level=[log level]:level:(debug info warn error fatal panic)' \
        '--log-as-json[log as JSON]' \
        '--enable-metrics[enable Prometheus metrics endpoint]' \
        '--metrics-port=[Prometheus metrics bind port]:port:' \
        '-v[klog verbosity level]:n:'
}

_dapr-operator "$@"
