#compdef golangci-lint
# _golangci-bin — golangci-lint Go linter aggregator (Denis Isaev et al, Go); runs 70+ linters in parallel
# upstream: https://github.com/golangci/golangci-lint

_golangci-bin() {
    local -a sub=(
        'run:run the linters'
        'linters:list available linters'
        'config:config helpers'
        'cache:cache helpers'
        'version:show version'
        'completion:print shell completion'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--color+[color]:when:(auto always never)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'golangci-lint subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '(-c --config)'{-c,--config}'+[config file]:file:_files -g "*.yml"' \
                    '--no-config[do not load config]' \
                    '-E+[enable linter]:linter:' \
                    '-D+[disable linter]:linter:' \
                    '--enable-all[enable all]' \
                    '--disable-all[disable all]' \
                    '--fast[only fast linters]' \
                    '--presets+[enable presets]:presets:(bugs comment complexity error format import metalinter module performance sql style test unused)' \
                    '--fix[fix issues if possible]' \
                    '--exclude+[exclude regex]:regex:' \
                    '--exclude-use-default+[default exclusions]:bool:(true false)' \
                    '--exclude-files+[exclude files]:files:' \
                    '--exclude-dirs+[exclude dirs]:dirs:' \
                    '--exclude-dirs-use-default+[use default excluded dirs]:bool:(true false)' \
                    '--issues-exit-code+[exit code]:n:' \
                    '--build-tags+[build tags]:tags:' \
                    '--timeout+[timeout]:duration:' \
                    '--tests[include test files]' \
                    '--print-resources-usage[print resources]' \
                    '--out-format+[output format]:fmt:(line-number colored-line-number json tab checkstyle code-climate junit-xml github-actions teamcity sarif)' \
                    '--print-issued-lines+[print issued lines]:bool:(true false)' \
                    '--print-linter-name+[print linter name]:bool:(true false)' \
                    '--allow-parallel-runners[allow parallel runners]' \
                    '--allow-serial-runners[allow serial runners]' \
                    '--new[only show new issues]' \
                    '--new-from-rev+[new since rev]:rev:' \
                    '--new-from-patch+[new from patch file]:file:_files' \
                    '--fix[auto-fix]' \
                    '--concurrency+[max threads]:n:' \
                    '*:dirs:_files -/' ;;
                linters) ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_golangci-bin "$@"
