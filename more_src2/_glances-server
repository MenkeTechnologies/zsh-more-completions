#compdef glances-server
# _glances-server — Glances curses-based monitor in server mode (Nicolas Hennion, Python); custom argparse wrapper
# upstream: https://github.com/nicolargo/glances

_glances-server() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--bind=+[bind address]:host:_hosts' \
        '-B+[bind address]:host:_hosts' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--password[set password]' \
        '-P+[set password]:str:' \
        '--snmp-community=+[snmp community]:str:' \
        '--snmp-port=+[snmp port]:port:' \
        '--snmp-version=+[snmp version]:v:(1 2c 3)' \
        '--snmp-user=+[snmp user]:str:_users' \
        '--snmp-auth=+[snmp auth]:str:' \
        '--config=+[config file]:file:_files -g "*.conf"' \
        '-C+[config file]:file:_files -g "*.conf"' \
        '--cached-time=+[cache time]:n:' \
        '--time=+[refresh time]:n:' \
        '-t+[refresh time]:n:' \
        '--export=+[export module]:list:' \
        '--export-csv-file=+[export csv file]:file:_files' \
        '--export-json-file=+[export json file]:file:_files' \
        '--export-stdout=+[export stdout fields]:list:' \
        '--disable-check-update[disable check update]' \
        '--disable-plugin=+[disable plugin]:list:' \
        '--enable-plugin=+[enable plugin]:list:' \
        '--enable-history[enable history]' \
        '--disable-bg[disable background]' \
        '--enable-irq[enable irq plugin]' \
        '--ssl-certfile=+[ssl cert file]:file:_files' \
        '--ssl-keyfile=+[ssl key file]:file:_files' \
        '--username[require client username/password auth]' \
        '--server[start server]' \
        '-s[start server]' \
        '--webserver[start webserver]' \
        '-w[start webserver]' \
        '--zeroconf[zeroconf]' \
        '-z[zeroconf]' \
        '*:arg:'
}

_glances-server "$@"
