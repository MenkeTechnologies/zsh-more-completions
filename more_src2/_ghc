#compdef ghc ghc-9 ghci runghc runhaskell
# Documentation: https://downloads.haskell.org/ghc/latest/docs/users_guide/flags.html
# Reference accessed: 2026-05-29
# Glasgow Haskell Compiler — top-level flag categories (modes, language,
# optimization, warnings, profiling, packages, codegen, debug). GHC has 600+
# flags; this completion covers the most common day-to-day subset.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help,-?}'[show help]' \
  '(- *)'{-V,--version}'[show GHC version]' \
  '(- *)--print-libdir[print library directory]' \
  '(- *)--print-build-platform[print build platform triple]' \
  '(- *)--print-host-platform[print host platform triple]' \
  '(- *)--print-target-platform[print target platform triple]' \
  '(- *)--print-ghc-version[print GHC version (programmatic)]' \
  '(- *)--print-rts[print built-in RTS settings]' \
  '(- *)--print-supported-languages[list supported language extensions]' \
  '(- *)--info[print key/value GHC info table]' \
  '--make[build a multi-module program, auto-tracking dependencies]' \
  '--interactive[start GHCi interactive mode]' \
  '-e+[evaluate expression and exit]:expr:' \
  '-M[generate Makefile dependency information]' \
  '-c[stop after generating object (.o) files]' \
  '-E[stop after preprocessing (.hspp)]' \
  '-S[stop after generating assembly (.s)]' \
  '-o+[output filename]:file:_files' \
  '-O0[disable optimization]' \
  '-O[enable basic optimization (level 1)]' \
  '-O1[enable basic optimization]' \
  '-O2[enable aggressive optimization]' \
  '-fno-code[skip code generation (typecheck only)]' \
  '-XGHC2024[enable GHC2024 language edition]' \
  '-XGHC2021[enable GHC2021 language edition]' \
  '-XHaskell2010[enable Haskell2010 language edition]' \
  '-XHaskell98[enable Haskell98 language edition]' \
  '*-X+[enable specific language extension]:extension:' \
  '-Wall[enable almost all warnings]' \
  '-Weverything[enable all warnings]' \
  '-Wcompat[enable warnings for forward compatibility]' \
  '-Wincomplete-patterns[warn about incomplete pattern matches]' \
  '-Wincomplete-uni-patterns[warn about incomplete uni patterns]' \
  '-Wunused-imports[flag unnecessary imports]' \
  '-Wmissing-signatures[warn about missing type signatures]' \
  '-Woverlapping-patterns[alert on overlapping patterns]' \
  '-Wunused-local-binds[warn on unused let bindings]' \
  '-Wunused-matches[warn on unused matches]' \
  '-Werror[treat warnings as errors]' \
  '-Werror=+[treat specific warning as error]:warning:' \
  '-w[disable all warnings]' \
  '*-W+[enable specific warning]:warning:' \
  '*-Wno-+[disable specific warning]:warning:' \
  '-fspecialise[turn on specialisation of overloaded functions]' \
  '-finline-generics[apply inline pragmas to Generic instances]' \
  '-fstrictness[enable demand analysis]' \
  '-fcse[common sub-expression elimination]' \
  '-ffull-laziness[float bindings outward]' \
  '-fno-strictness[disable strictness analysis]' \
  '-fno-cse[disable CSE]' \
  '-fwarn-tabs[warn about tab characters]' \
  '-prof[enable cost-centre profiling]' \
  '-fprof-auto[auto-add SCCs to all bindings]' \
  '-fprof-auto-exported[auto-SCC for exported bindings only]' \
  '-fprof-auto-top[auto-SCC for top-level bindings only]' \
  '-fprof-cafs[add profiling to constant applicative forms]' \
  '-fprof-callers[add caller information to cost centres]' \
  '-ticky[ticky-ticky profiling mode]' \
  '-eventlog[enable event logging]' \
  '*-package+[expose a package]:package:' \
  '*-package-id+[expose a specific installed package by id]:unit-id:' \
  '*-hide-package+[hide a package]:package:' \
  '-hide-all-packages[hide all packages by default]' \
  '*-package-db+[add package database]:db path:_files' \
  '-clear-package-db[clear package databases]' \
  '-global-package-db[use global package database]' \
  '-user-package-db[use user package database]' \
  '-no-user-package-db[do not use user package database]' \
  '*-i+[add directory to import search path]:dir:_directories' \
  '*-I+[add directory to C/header search path]:dir:_directories' \
  '*-L+[add directory to library search path]:dir:_directories' \
  '*-l+[link with library]:library:' \
  '-fllvm[compile using LLVM backend]' \
  '-fasm[use native code generator]' \
  '-fbyte-code[use byte-code generator (GHCi)]' \
  '-fPIC[generate position-independent code]' \
  '-dynamic[build dynamically-linked executable]' \
  '-static[force static linking]' \
  '-shared[build a shared library]' \
  '-staticlib[build a static library]' \
  '-no-hs-main[skip default Haskell main wrapper]' \
  '*-D+[define a preprocessor symbol]:macro:' \
  '*-U+[undefine a preprocessor symbol]:macro:' \
  '-cpp[enable C pre-processor]' \
  '-rtsopts[allow setting RTS options on the command line]' \
  '-rtsopts=+[control RTS options]:mode:(none some all ignore ignoreAll)' \
  '-threaded[link with multi-threaded runtime]' \
  '-debug[link with debugging runtime]' \
  '*-v+[verbosity level]:level:(0 1 2 3 4 5)' \
  '-ddump-+[dump compiler intermediate output]:pass:' \
  '-ddump-simpl[dump simplifier output]' \
  '-ddump-cmm[dump Cmm IR]' \
  '-ddump-stg[dump STG IR]' \
  '-ddump-core[dump core IR]' \
  '-fshow-error-context[display error context details]' \
  '-fprint-expanded-synonyms[show expanded type synonyms in errors]' \
  '-fprint-explicit-foralls[display explicit forall quantification]' \
  '-fprint-explicit-kinds[show kind arguments in types]' \
  '-fdiagnostics-color=[when to colorize diagnostics]:mode:(always never auto)' \
  '*--ghc-option=+[forward option to GHC]:opt:' \
  '*+RTS[start RTS options block]' \
  '*-RTS[end RTS options block]' \
  '*:Haskell source file:_files -g "*.(hs|lhs|hsc|c|cmm|ll|S|o)"' && ret=0

return ret
