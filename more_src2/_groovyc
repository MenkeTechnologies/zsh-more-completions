#compdef groovyc
# Documentation: groovyc --help (Apache Groovy)
# Source: compile Groovy source files to JVM bytecode.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    {-cp,-classpath,--classpath=}'[where to find class files]:path:_files' \
    {-sourcepath,--sourcepath=}'[where to find source files]:path:_files' \
    '--temp=[temporary directory]:dir:_files -/' \
    '--encoding=[encoding of source files]:encoding:(UTF-8 ISO-8859-1 US-ASCII)' \
    '-d=[output directory for class files]:dir:_files -/' \
    {-de,--debug}'[verbose output on errors]' \
    {-e,--exception}'[print stack trace on error]' \
    {-w+,--warningLevel=}'[warning level (0-3)]:level:(0 1 2 3)' \
    {-pa,--parameters}'[generate metadata for parameter reflection]' \
    {-pr,--enable-preview}'[enable preview Java features]' \
    {-j,--jointCompilation}'[attach javac to compile .java files]' \
    {-s+,--stubDirectory=}'[directory for Java source stubs]:dir:_files -/' \
    {-ks,--keepStubs}'[keep generated stubs]' \
    {-b+,--basescript=}'[base class name for scripts]:class:' \
    '*-J=[name=value pair for javac]:property=value:' \
    '*-F=[flag to pass to javac]:flag:' \
    {-cf+,--configscript=}'[configuration script]:file:_files' \
    {-t+,--tolerance=}'[non-fatal error tolerance]:n:' \
    '--compile-static[use CompileStatic]' \
    '--type-checked[use TypeChecked]' \
    '--indy[enable invokedynamic]' \
    '--jar=[output a jar of compiled classes]:file:_files -g "*.jar"' \
    '*:source files:_files -g "*.(groovy|java)"' \
    && ret=0

return ret
