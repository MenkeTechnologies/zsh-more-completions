#compdef geogebra geogebra-classic
# Documentation: https://wiki.geogebra.org/en/Reference:Command_Line_Arguments
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--language=+[language code]:lang:' \
  '--showAlgebraInput=+[show algebra input]:flag:(true false)' \
  '--showAlgebraInputTop=+[input top]:flag:(true false)' \
  '--showAlgebraWindow=+[show algebra window]:flag:(true false)' \
  '--showSpreadsheet=+[show spreadsheet]:flag:(true false)' \
  '--showCAS=+[show CAS]:flag:(true false)' \
  '--showStatusBar=+[show status bar]:flag:(true false)' \
  '--showToolBar=+[show toolbar]:flag:(true false)' \
  '--showToolBarHelp=+[show toolbar help]:flag:(true false)' \
  '--showMenuBar=+[show menubar]:flag:(true false)' \
  '--enableUndo=+[enable undo]:flag:(true false)' \
  '--enableRightClick=+[right click]:flag:(true false)' \
  '--enableLabelDrags=+[label drag]:flag:(true false)' \
  '--enableShiftDragZoom=+[shift drag zoom]:flag:(true false)' \
  '--enableErrorDialogs=+[show error dialogs]:flag:(true false)' \
  '--fontSize=+[font size]:n:' \
  '--prerelease[use prerelease]' \
  '--audioOutput[enable audio]' \
  '--export=+[export file]:file:_files' \
  '--exportWidth=+[width]:px:' \
  '--exportHeight=+[height]:px:' \
  '--exportDPI=+[dpi]:dpi:' \
  '--exportTransparent[transparent export]' \
  '*:file:_files -g "*.{ggb,ggt}"' && ret=0

return ret
