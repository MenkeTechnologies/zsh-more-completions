#compdef pamtowinicon
# Documentation: man pamtowinicon (Netpbm)
# Source: convert a Netpbm image to a Windows .ico file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-pngthreshold=[width/height threshold (use PNG above)]:threshold:' \
    '-truetransparent[treat transparent pixels as transparent]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
