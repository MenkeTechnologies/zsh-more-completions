#compdef gh-extension
# _gh-extension — GitHub gh extension subcommand alias (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-extension() {
    local -a sub=(
        'browse:browse installed extensions'
        'create:scaffold a new extension'
        'exec:execute installed extension'
        'install:install an extension'
        'list:list installed extensions'
        'remove:remove installed extension'
        'search:search for extensions'
        'upgrade:upgrade installed extensions'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh-extension subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--force[force]' \
                    '--pin=+[pin to version]:str:' \
                    '*:repo:' ;;
                remove|upgrade) _arguments \
                    '--all[all extensions]' \
                    '--force[force]' \
                    '*:name:' ;;
                create) _arguments \
                    '--precompiled=+[precompiled]:t:(go other)' \
                    '*:name:' ;;
                search) _arguments \
                    '--license=+[license]:list:' \
                    '--limit=+[max items]:n:' \
                    '-L+[max items]:n:' \
                    '--order=+[order]:o:(asc desc)' \
                    '--sort=+[sort]:s:(stars forks updated)' \
                    '--owner=+[owner]:list:' \
                    '--language=+[language]:str:' \
                    '--json=+[json fields]:list:' \
                    '*:query:' ;;
                browse) _arguments \
                    '--debug[debug]' \
                    '--single-column[single column]' ;;
                exec) _arguments \
                    '1:extension:' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_gh-extension "$@"
