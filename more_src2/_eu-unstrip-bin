#compdef eu-unstrip
# _eu-unstrip-bin — elfutils unstrip (Mark Wielaard, Red Hat); merge stripped + debuginfo back into single ELF
# upstream: https://sourceware.org/elfutils

_eu-unstrip-bin() {
    _arguments \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-d --output-directory)'{-d,--output-directory}'+[output dir]:dir:_files -/' \
        '(-m --match-file-names)'{-m,--match-file-names}'[match filename]' \
        '(-n --list-only)'{-n,--list-only}'[only list]' \
        '(-p --force)'{-p,--force}'[force]' \
        '(-i --ignore-missing)'{-i,--ignore-missing}'[ignore missing files]' \
        '(-R --relocate)'{-R,--relocate}'[relocate]' \
        '(-a --all)'{-a,--all}'[all matching]' \
        '--core+[core file]:file:_files' \
        '--debuginfo-path+[debuginfo path]:path:_files -/' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-unstrip-bin "$@"
