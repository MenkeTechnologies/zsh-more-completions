#compdef export_signing_key
# _export_signing_key — export Synapse signing key public component (element-hq/synapse)
# upstream: https://github.com/element-hq/synapse
# Flags from synapse/_scripts/export_signing_key.py (argparse).

_export_signing_key() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-x[export key in version 2 format]' \
        '--expiry-ts=[expiry timestamp (ms since epoch)]:ts:' \
        '*:signing key file:_files -g "*.signing.key"'
}

_export_signing_key "$@"
