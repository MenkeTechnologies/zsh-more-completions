#compdef egctl
# Documentation: https://github.com/easegress-io/easegress/blob/main/docs/02.Tutorials/2.1.egctl-Usage.md
# Reference accessed: 2026-05-17
# Verified: upstream egctl-Usage docs at the URL above (megaease/easegress).

# Easegress egctl (cobra-based CLI)

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands=(
  'create:create resources from YAML manifests'
  'apply:create or update resources'
  'delete:remove resources'
  'get:view and search for resources'
  'describe:show detailed information about resources'
  'edit:modify resources interactively'
  'api-resources:list all available resource types'
  'health:check easegress system status'
  'logs:print easegress-server logs'
  'config:manage contexts and authentication settings'
  'profile:CPU profiling utilities'
  'ai:manage AI Gateway features'
  'completion:generate shell completion script'
  'version:show egctl version'
  'help:show help for a command'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--all-namespaces[access resources across all namespaces]' \
  '--namespace=[target namespace]:namespace:' \
  '--all[operate on all resources of a type]' \
  '-f+[read manifest from file or stdin]:file:_files' \
  '1: :->cmd' \
  '*::arg:->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'egctl command' commands && ret=0
    ;;
  rest)
    case ${line[1]} in
      (config)
        local -a cfg_cmds=(
          'current-context:show current context'
          'get-contexts:list configured contexts'
          'use-context:switch to a context'
          'view:print resolved config'
        )
        _describe -t commands 'config command' cfg_cmds && ret=0
        ;;
      (completion)
        _arguments ':shell:(bash zsh fish powershell)' && ret=0
        ;;
      (logs)
        _arguments \
          '-f[stream logs continuously]' \
          '--tail=[lines to tail]:lines:' && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
