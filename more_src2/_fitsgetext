#compdef fitsgetext
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/fitsgetext.1 — extract an extension from a FITS file (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[output file]:file:_files' \
    '-a[output all extensions]' \
    '-b[write a single binary file (no headers)]' \
    '-M[output only the header]' \
    '-D[output only the data]' \
    '-H[print HDU summary]' \
    '*-e+[FITS extension index]:n:_default' \
    '-v[verbose]' \
    '*:FITS file:_files -g "*.{fits,fit,fts}"' \
    && ret=0

return ret
