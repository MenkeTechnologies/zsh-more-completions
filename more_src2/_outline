#compdef outline outline-cli
# _outline — Outline collaborative team wiki/knowledge-base CLI alias (outline team, TypeScript); commander
# upstream: https://github.com/outline/outline

_outline() {
    local -a sub=(
        'auth:save api key'
        'logout:clear api key'
        'whoami:show current user'
        'collections:list:list collections'
        'collections:get:get collection'
        'collections:create:create collection'
        'collections:update:update collection'
        'collections:delete:delete collection'
        'collections:export:export collection'
        'collections:add-user:add user'
        'collections:remove-user:remove user'
        'collections:add-group:add group'
        'collections:remove-group:remove group'
        'documents:list:list documents'
        'documents:get:get document'
        'documents:create:create document'
        'documents:update:update document'
        'documents:delete:delete document'
        'documents:archive:archive document'
        'documents:unarchive:unarchive document'
        'documents:restore:restore document'
        'documents:move:move document'
        'documents:search:search documents'
        'documents:export:export document'
        'documents:star:star document'
        'documents:unstar:unstar document'
        'documents:pin:pin document'
        'documents:unpin:unpin document'
        'fileOperations:list:list file operations'
        'fileOperations:redirect:redirect to export download'
        'groups:list:list groups'
        'groups:create:create group'
        'groups:update:update group'
        'groups:delete:delete group'
        'groups:add-user:add user to group'
        'groups:remove-user:remove user from group'
        'integrations:list:list integrations'
        'integrations:delete:delete integration'
        'shares:list:list shares'
        'shares:create:create share'
        'shares:revoke:revoke share'
        'users:list:list users'
        'users:invite:invite user'
        'users:promote:promote user'
        'users:demote:demote user'
        'users:suspend:suspend user'
        'users:activate:activate user'
        'users:delete:delete user'
        'team:info:show team info'
        'team:update:update team'
        'views:list:list views'
        'attachments:create:create attachment'
        'attachments:delete:delete attachment'
        'auth:info:show auth info'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[api token]:str:' \
        '--url=+[outline url]:url:_urls' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'outline subcommand' sub ;;
        args)
            case $words[1] in
                documents:create) _arguments \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--text=+[markdown]:str:' \
                    '--file=+[file]:file:_files -g "*.md"' \
                    '--collection-id=+[collection id]:str:' \
                    '--parent-document-id=+[parent doc id]:str:' \
                    '--publish[publish on create]' \
                    '--template-id=+[template id]:str:' ;;
                documents:export) _arguments \
                    '1:document id:' \
                    '--format=+[format]:f:(markdown html json)' \
                    '--output=+[output file]:file:_files' ;;
                collections:export) _arguments \
                    '1:collection id:' \
                    '--format=+[format]:f:(markdown html json outline-markdown)' \
                    '--include-attachments[include attachments]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_outline "$@"
