#compdef prokka
# _prokka — Torsten Seemann tseemann prokka CLI fast bacterial archaeal viral genome annotation pipeline taking FASTA input and producing GFF3 GenBank EMBL FAA FFN FNA TBL TSV SQN annotation files HMM-based BLAST-based scanning Pfam TIGRFAM HAMAP Aragorn Barrnap rRNA tRNA tmRNA CRISPR prediction (Torsten Seemann team, Perl); getopt
# upstream: https://github.com/tseemann/prokka

_prokka() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--citation[show citation]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--outdir=+[output dir]:dir:_files -/' \
        '--force[overwrite outdir]' \
        '--prefix=+[prefix]:str:' \
        '--addgenes[add gene features]' \
        '--locustag=+[tag]:str:' \
        '--increment=+[N]:n:' \
        '--gffver=+[v]:v:(1 2 3)' \
        '--centre=+[centre]:str:' \
        '--compliant[compliant mode]' \
        '--genus=+[genus]:str:' \
        '--species=+[species]:str:' \
        '--strain=+[strain]:str:' \
        '--plasmid=+[name]:str:' \
        '--kingdom=+[kingdom]:k:(Archaea Bacteria Mitochondria Viruses)' \
        '--gcode=+[code]:n:' \
        '--gram=+[g]:g:(pos neg)' \
        '--usegenus[use genus DB]' \
        '--proteins=+[file]:file:_files -g "*.faa *.fa"' \
        '--hmms=+[file]:file:_files -g "*.hmm"' \
        '--metagenome[metagenomic mode]' \
        '--rawproduct[do not clean up product names]' \
        '--cdsrnaolap[allow CDS/rRNA overlap]' \
        '--rnammer[use rnammer]' \
        '--fast[fast mode]' \
        '--noanno[only call genes]' \
        '--mincontiglen=+[N]:n:' \
        '--cpus=+[N]:n:' \
        '--evalue=+[N]:n:' \
        '--rfam[run rfam search]' \
        '--norrna[no rRNA scan]' \
        '--notrna[no tRNA scan]' \
        '*:fasta file:_files -g "*.fa *.fasta *.fna *.fas *.gz"'
}

_prokka "$@"
