#compdef pritunl-cloud
# ============================================================================
# _pritunl-cloud — zsh completion for **pritunl-cloud** — the Pritunl
#                   open-source **private cloud virtualization platform**
#                   (KVM/QEMU instances + libvirt orchestration + IPVLAN/
#                   bridge networking + ZFS/LVM block storage + Let's-
#                   Encrypt ACME TLS + per-organization Authorities,
#                   Authorizers, Firewalls, Vpc, Subnet, Block, Domain,
#                   Pod, Plan, Image, Datacenter, Zone, Storage,
#                   Certificate, Snapshot, Backup, Policy, Secret, Alert
#                   resource model — the open-source equivalent of
#                   ProxmoxVE / OpenNebula / OpenStack Nova written by
#                   the Pritunl team, who also ship pritunl-zero (zero-
#                   trust SSH bastion), pritunl-link (IPsec mesh VPN),
#                   pritunl-client / pritunl-client-electron / pritunl
#                   (the canonical OpenVPN-based VPN server, ~13.5K★)).
#                   Go=167 leader bump continuing Axis 112 (WebAuthn /
#                   FIDO2 / CTAP2 protocol) at 2/0/0 via the canonical
#                   Go WebAuthn library **github.com/go-webauthn/
#                   webauthn**.
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/pritunl/pritunl-cloud
#   Maintainer : Pritunl  (the team behind the Pritunl OpenVPN-based
#                 VPN server, the largest open-source VPN server on
#                 GitHub at 13.5K+ stars — same maintainer also ships
#                 pritunl-zero, pritunl-link, pritunl-client, and
#                 pritunl-client-electron; pritunl-cloud is their
#                 private-cloud virtualization spinoff)
#   License    : Source-available (custom commercial-friendly license)
#   Stars      : 148
#   Language   : Go  (stdlib `flag` package; not cobra)
#   Binary     : pritunl-cloud
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   `pritunl-cloud` is a **single-binary private-cloud virtualization
#   platform** that runs on a fleet of bare-metal or hypervisor
#   nodes and provides:
#
#     • KVM/QEMU virtual-machine instances orchestrated through
#       libvirt with cloud-init userdata, NoVNC web console,
#       configurable vCPU / memory / disk size / OS image, secure-
#       boot toggle, vTPM passthrough, USB / PCI / VFIO device
#       passthrough, GPU passthrough, hugepages allocation, NUMA
#       pinning, CPU pinning, live migration
#
#     • Per-organization VPCs with IPv4 + IPv6 subnets, IPSec
#       site-to-site mesh peering, Vxlan overlay networking,
#       per-instance public IP allocation from configurable
#       pools, IPVLAN / bridge / VFIO SR-IOV NIC modes,
#       per-vNIC traffic shaping, MTU policies, jumbo frame
#       support, host MTU auto-detection (`mtu-check`)
#
#     • Per-organization firewalls with stateful ingress/egress
#       rule sets, named rule chains, role-based rule
#       composition, IPv4 + IPv6 rule families
#
#     • Per-organization Authorities (admin-only),
#       Authorizers (SSH cert-issuing CAs for instance SSH key
#       distribution), Roles, Plans, Pods, Images, Disks,
#       Snapshots, Backups, Datacenters, Zones, Storage
#       (NFSv4, Ceph RBD, ZFS, LVM), Domains, Certificates
#       (with Let's-Encrypt ACME auto-renewal via the dns-01
#       challenge against built-in CloudFlare / Route53 /
#       OracleCloud DNS providers), Secrets (kubernetes-style
#       k/v + connection-string vault), Policies (RBAC + WebAuthn
#       / U2F MFA enforcement), Alerts (event-driven
#       notifications to Pushover / Slack / Email)
#
#     • Built-in IMDS server (the EC2-style 169.254.169.254
#       instance-metadata service exposed inside each VM via
#       the dedicated subcommand `imds-server`), DHCP4 / DHCP6
#       servers (`dhcp4-server` / `dhcp6-server`), NDP server
#       (`ndp-server`), DHCP client (`dhcp-client`)
#
#   Bootstrap workflow:
#     1. `pritunl-cloud mongo`                          set MongoDB URI
#     2. `pritunl-cloud reset-node-web`                 reset web bind
#     3. `pritunl-cloud default-password`               get default pw
#     4. `pritunl-cloud start`                          start node
#     (instance lifecycle: `start-instance <name>` / `stop-instance
#      <name>`; node maintenance: `clear-logs`, `optimize`, `backup`,
#      `disable-policies`, `disable-firewall`, `reset-password`,
#      `mtu-check`)
#
# CLI ARGUMENT GRAMMAR  (verbatim from main.go `switch command {…}`
#                       sub-command dispatcher; extracted via
#                       raw.githubusercontent.com fetch of main.go)
#
#   pritunl-cloud <COMMAND> [ARGS...] [FLAGS...]
#
#   Commands:
#     version                        Show version
#     mongo                          Set MongoDB URI
#     set                            Set a setting
#     unset                          Unset a setting
#     start [--debug] [--debug-web]  Start node
#           [--fast-exit]
#     clear-logs                     Clear logs
#     reset-node-web                 Reset node web server settings
#     optimize                       Optimize system configuration
#     default-password               Get default administrator password
#     reset-password                 Reset administrator password
#     disable-policies               Disable all policies
#     disable-firewall               Disable firewall on this node
#     start-instance <NAME>          Start instance by name
#     stop-instance <NAME>           Stop instance by name
#     mtu-check                      Check and show instance MTUs
#     backup                         Backup local data
#     imds-server                    Run the IMDS (instance metadata)
#                                    service  (internal; spawned by
#                                    the node when starting)
#     dhcp4-server                   Run the DHCPv4 server
#     dhcp6-server                   Run the DHCPv6 server
#     dhcp-client                    Run the DHCP client
#     ndp-server                     Run the IPv6 NDP server
#
# AXIS / CORPUS POSITION
#   `pritunl/pritunl-cloud` declares a **direct** dependency on
#   `github.com/go-webauthn/webauthn v0.12.3` (and the supporting
#   `github.com/go-webauthn/x v0.1.20`) in its `go.mod` (verified
#   via `gh api repos/pritunl/pritunl-cloud/contents/go.mod`).
#   `go-webauthn/webauthn` is **THE canonical Go WebAuthn library**
#   — the relying-party server SDK that powers every serious Go
#   WebAuthn deployment in production:
#
#     • Identity / IAM platforms — go-gitea/gitea (75K+ ★;
#       passkey-based user 2FA), authelia/authelia (24K+ ★;
#       single-sign-on portal's WebAuthn second factor),
#       authgear/authgear-server (1.8K+ ★; the Auth0/Clerk
#       alternative's passkey support), ory/kratos (12K+ ★;
#       the identity-and-user-management Cloud Native server's
#       passkey strategy), casdoor/casdoor (11K+ ★; the IAM/
#       SSO platform), pomerium (the zero-trust access proxy's
#       PassKey authenticator)
#
#     • RSS readers + content platforms — miniflux/v2 (13K+ ★;
#       RSS reader's passkey login)
#
#     • Self-hosted file/photo platforms — ente-io/ente (the
#       end-to-end encrypted photo platform's MFA), 1Panel-dev/
#       1Panel (the server-management web panel), AlistGo/alist
#       (the cloud-storage aggregator's MFA), OpenListTeam/
#       OpenList (alist fork's MFA)
#
#     • Mesh / SSH / VPN platforms — gravitational/teleport
#       (the identity-aware access proxy's WebAuthn 2FA used by
#       every Teleport `tsh login`/`tsh ssh`/`tctl` invocation),
#       netbirdio/netbird (the WireGuard mesh VPN's
#       management-plane passkey login), pritunl/pritunl-cloud
#       (this very project; the VPN team's private-cloud
#       platform)
#
#     • PocketBase, Supabase, Nhost, Spinspire, Lesser (Mastodon
#       reimplementation), router-for-me, pynezz, Drolfothesgnir,
#       openpubkey (the OpenID-Connect-augmented-with-pubkey
#       protocol's reference implementation), and dozens of
#       smaller authn gateways
#
#   `go-webauthn/webauthn` exposes the typed `webauthn.New(config
#   *webauthn.Config)` builder that takes typed `RPDisplayName` /
#   `RPID` / `RPOrigins` / `AttestationPreference` / `AuthenticatorSelection`
#   / `Timeouts.Login{Enforce,Timeout,TimeoutUVD}` /
#   `Timeouts.Registration{Enforce,Timeout,TimeoutUVD}` /
#   `EncodeUserIDAsString` / `Debug` configuration fields; the
#   typed `webauthn.User` interface (with `WebAuthnID() []byte` /
#   `WebAuthnName() string` / `WebAuthnDisplayName() string` /
#   `WebAuthnCredentials() []webauthn.Credential` /
#   `WebAuthnIcon() string` typed methods); the typed
#   `webauthn.BeginRegistration(user, opts...)
#   -> (*protocol.CredentialCreation, *webauthn.SessionData, error)`
#   / `webauthn.FinishRegistration(user, sessionData, request)
#   -> (*webauthn.Credential, error)` typed registration round-trip;
#   the typed `webauthn.BeginLogin(user, opts...) ->
#   (*protocol.CredentialAssertion, *webauthn.SessionData, error)`
#   / `webauthn.FinishLogin(user, sessionData, request)
#   -> (*webauthn.Credential, error)` typed authentication round-
#   trip; the typed `protocol.CredentialCreation` /
#   `CredentialAssertion` / `PublicKeyCredentialCreationOptions` /
#   `PublicKeyCredentialRequestOptions` / `AuthenticatorSelection` /
#   `AuthenticatorAttachment::{Platform, CrossPlatform}` /
#   `UserVerificationRequirement::{Required, Preferred, Discouraged}`
#   / `ResidentKeyRequirement::{Required, Preferred, Discouraged}`
#   / `ConveyancePreference::{None, Indirect, Direct, Enterprise}`
#   discriminated-union WebAuthn Level 3 schemas; the typed
#   `protocol.AttestationObject` parser (with CBOR-decoded
#   `AuthData` / `FmT` / `AttStatement` fields); the typed
#   `protocol.AttestationFormat::{FidoU2F, Packed, PackedSelf,
#   AndroidKey, AndroidSafetyNet, Apple, TPM, None}` attestation-
#   format dispatcher with full per-format verifier (FIDO Metadata
#   Service v3 root-CA chain validation, AAGUID lookup, x5c
#   certificate chain verification, COSEKey ↔ ECDSA / RSA / Ed25519
#   public-key conversion); the typed `protocol.AuthenticatorData`
#   bitfield parser (UP/UV/BE/BS/AT/ED flag decoding); the typed
#   `webauthn.Credential` struct with `Credential.ID` /
#   `Credential.PublicKey` (raw COSE-encoded; convertible to typed
#   `webauthncose.EC2PublicKeyData` / `RSAPublicKeyData` /
#   `OKPPublicKeyData` discriminated union) / `Credential.
#   AttestationType` / `Credential.Transport []Transport` (the
#   list of `usb` / `nfc` / `ble` / `internal` / `hybrid` /
#   `smart-card` transports the credential supports) /
#   `Credential.Flags.UserVerified` /
#   `Credential.Authenticator.AAGUID` /
#   `Credential.Authenticator.SignCount` /
#   `Credential.Authenticator.CloneWarning` /
#   `Credential.Authenticator.Attachment` typed fields; full COSE
#   algorithm registry typed enum (`COSEAlgorithmIdentifier::ES256
#   = -7`, `ES384 = -35`, `ES512 = -36`, `EdDSA = -8`, `PS256 =
#   -37`, `PS384 = -38`, `PS512 = -39`, `RS256 = -257`, `RS384 =
#   -258`, `RS512 = -259`, `RS1 = -65535` etc) with verifier
#   dispatch; and the typed `metadata.Provider` interface for FIDO
#   Metadata Service v3 plug-in.  The `webauthn/x` sister module
#   ships browser-tested helpers + the WebAuthn JS API JSON wire-
#   format types (`PublicKeyCredentialJSON`,
#   `AuthenticatorAttestationResponseJSON`,
#   `AuthenticatorAssertionResponseJSON`) for ergonomic
#   server-side request unmarshaling.
#
#   Verified via:
#     gh api repos/pritunl/pritunl-cloud/contents/go.mod
#       → module github.com/pritunl/pritunl-cloud
#       → require github.com/go-webauthn/webauthn v0.12.3
#         (DIRECT — inside first `require (` block before any
#         closing `)`)
#       → require github.com/go-webauthn/x v0.1.20 (indirect
#         transitive — supports the main webauthn module's
#         JSON wire-format types)
#     raw.githubusercontent.com pritunl/pritunl-cloud master main.go
#       → import "github.com/pritunl/pritunl-cloud/cmd"
#       → const help string lists 16 user-facing subcommands
#       → switch command {…} dispatcher with 21 cases:
#         "start", "version", "mongo", "optimize",
#         "reset-node-web", "default-password", "reset-password",
#         "disable-policies", "disable-firewall", "mtu-check",
#         "set", "unset", "clear-logs", "backup", "imds-server",
#         "dhcp4-server", "dhcp6-server", "dhcp-client",
#         "ndp-server", "start-instance", "stop-instance"
#       → "start" branch parses `--debug` / `--debug-web` /
#         `--fast-exit` flags
#
#   This entry is the Go=167 leader bump that continues Axis 112
#   (WebAuthn / FIDO2 / CTAP2 protocol) at 2/0/0 following R1034
#   _fido-key-manager (Rust=167 OPENED via kanidm/webauthn-rs).
#   TS-Node=167 closing pair on deck for R1036 via the canonical
#   `@simplewebauthn/server` SDK (Matthew Miller's reference
#   TypeScript implementation used by every Node.js WebAuthn
#   server in production).
#
#   No completion for `pritunl-cloud` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_pritunl-cloud() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ptl_commands=(
                'version:show version'
                'mongo:set MongoDB URI'
                'set:set a setting'
                'unset:unset a setting'
                'start:start node'
                'clear-logs:clear logs'
                'reset-node-web:reset node web server settings'
                'optimize:optimize system configuration'
                'default-password:get default administrator password'
                'reset-password:reset administrator password'
                'disable-policies:disable all policies'
                'disable-firewall:disable firewall on this node'
                'start-instance:start instance by name'
                'stop-instance:stop instance by name'
                'mtu-check:check and show instance MTUs'
                'backup:backup local data'
                'imds-server:run the IMDS instance-metadata service'
                'dhcp4-server:run the DHCPv4 server'
                'dhcp6-server:run the DHCPv6 server'
                'dhcp-client:run the DHCP client'
                'ndp-server:run the IPv6 NDP server'
            )
            _describe -t commands 'pritunl-cloud command' _ptl_commands && ret=0
            ;;
        args)
            case $words[1] in
                start)
                    _arguments \
                        '--debug[enable production-debug mode]' \
                        '--debug-web[enable web-server debug mode]' \
                        '--fast-exit[enable fast-exit mode]' && ret=0
                    ;;
                start-instance|stop-instance)
                    _arguments '1:instance name:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_pritunl-cloud "$@"
