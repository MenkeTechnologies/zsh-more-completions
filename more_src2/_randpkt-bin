#compdef randpkt
# _randpkt-bin — Wireshark random packet capture file generator; create synthetic pcap for testing
# upstream: https://gitlab.com/wireshark/wireshark

_randpkt-bin() {
    _arguments \
        '-b+[max payload bytes]:n:' \
        '-c+[packet count]:n:' \
        '-r[reasonable size payload]' \
        '-t+[packet type]:type:(arp bgp bvlc dns eth fddi giop icmp icmpv6 ip ipv6 llc m2m megaco nbns ncp2222 sctp syslog tcp tds tr udp usb usb-linux x25 wlan)' \
        '-F+[output file format]:fmt:(libpcap pcap nseclibpcap nsecpcap aixpcap modpcap nokiapcap rh6_1pcap suse6_3pcap pcapng)' \
        '*:file:_files'
}

_randpkt-bin "$@"
