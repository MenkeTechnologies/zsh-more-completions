#compdef faToTwoBit twoBitToFa twoBitInfo
# _faToTwoBit — UCSC Kent Lab faToTwoBit and twoBitToFa convert FASTA to UCSC 2bit binary genome format (UCSC team, C); getopt
# upstream: https://genome.ucsc.edu/goldenPath/help/twoBit.html

_faToTwoBit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-long[output 64-bit address space sizes]' \
        '-stripVersion[strip version after .]' \
        '-namePrefix=+[prefix]:str:' \
        '-noMask[no masking]' \
        '-ignoreDups[ignore duplicates]' \
        '-bed=+[bed file]:file:_files -g "*.bed"' \
        '-bedPos[bed positions]' \
        '-seq=+[seq name]:str:' \
        '-start=+[start position]:n:' \
        '-end=+[end position]:n:' \
        '-bpt=+[bpt file]:file:_files' \
        '-udcDir=+[UDC dir]:dir:_files -/' \
        '*:in_fa out_2bit:_files -g "*.fa *.fasta *.fa.gz *.fasta.gz *.2bit"'
}

_faToTwoBit "$@"
