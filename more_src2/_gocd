#compdef gocd go-server go-agent
# _gocd — ThoughtWorks GoCD continuous delivery server with pipelines value-stream-mapping (gocd team, Java); custom argparse
# upstream: https://github.com/gocd/gocd

_gocd() {
    local -a sub=(
        'install:install GoCD'
        'start:start service'
        'stop:stop service'
        'restart:restart service'
        'status:show service status'
        'reload:reload configuration'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.xml *.yml *.yaml"' \
        '-c+[config file]:file:_files -g "*.xml *.yml *.yaml"' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '--server-port=+[http port]:port:_ports' \
        '--server-ssl-port=+[https port]:port:_ports' \
        '--server-url=+[server url]:url:_urls' \
        '--agent-url=+[agent registration url]:url:_urls' \
        '--agent-auto-register-key=+[auto register key]:str:' \
        '--agent-environments=+[environments csv]:str:' \
        '--agent-resources=+[resources csv]:str:' \
        '--agent-hostname=+[hostname]:host:_hosts' \
        '--ssl-cert=+[tls cert]:file:_files' \
        '--ssl-key=+[tls key]:file:_files' \
        '--keystore=+[keystore]:file:_files' \
        '--keystore-password=+[password]:str:' \
        '--truststore=+[truststore]:file:_files' \
        '--truststore-password=+[password]:str:' \
        '--log-level=+[level]:l:(TRACE DEBUG INFO WARN ERROR FATAL OFF)' \
        '--gc-policy=+[policy]:p:(G1GC ZGC ParallelGC ConcMarkSweepGC ShenandoahGC)' \
        '--xms=+[memory]:str:' \
        '--xmx=+[memory]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gocd subcommand' sub ;;
    esac
}

_gocd "$@"
