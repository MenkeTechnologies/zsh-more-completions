#compdef mapshaper mapshaper-gui mapshaper-xl
# ---------------------------------------------------------------------------
# mapshaper / mapshaper-gui / mapshaper-xl — Matthew Bloch's GIS data
#                                          processing toolkit: edit
#                                          Shapefile / GeoJSON /
#                                          TopoJSON / KML / GeoParquet
#                                          / GeoPackage / FlatGeobuf /
#                                          CSV / GeoTIFF files
#                                          through a Unix-style
#                                          pipeline syntax where each
#                                          `-command` is a separate
#                                          stage (`mapshaper input.shp
#                                          -filter "POP>1000" -simplify
#                                          5% -join other.csv keys=ID
#                                          -export output.geojson`).
#                                          mapshaper-gui launches the
#                                          web-based interactive
#                                          editor (same engine as
#                                          mapshaper.org); mapshaper-xl
#                                          is the increased-memory
#                                          variant for processing
#                                          larger-than-memory
#                                          datasets via Node's --max-
#                                          old-space-size override
#                                          (JavaScript, 4120★)
#
# upstream: https://github.com/mbloch/mapshaper
# author : Matthew Bloch — operates the mapshaper.org web service
#          that runs the same engine as this CLI as a browser-based
#          tool for journalists, cartographers, GIS analysts who don't
#          want to learn QGIS / ArcGIS desktop tools
# license: MPL-2.0
# npm    : `mapshaper` (provides three bin aliases — `mapshaper` for
#          the canonical CLI, `mapshaper-gui` for the web-based
#          interactive editor, `mapshaper-xl` for the increased-
#          memory CLI variant)
#
# Source-direct completion: every subcommand below is verbatim from
# src/cli/mapshaper-options.mjs on the mbloch/mapshaper tip — the
# `parser.command(...)` registrations on the mapshaper-command-parser
# object parsed exactly as declared.  91 commands in total, covering
# every GIS data-transformation operation mapshaper supports.
#
# Direct deps from package.json (selected):
#   @bokuweb/zstd-wasm   ^0.0.27  ← canonical JS Zstandard compression
#                                    library (this axis) — by bokuweb
#                                    (bokuweb/zstd-wasm); WebAssembly
#                                    port of the upstream zstd C
#                                    library by Yann Collet
#                                    (Facebook/Meta).  Wraps the
#                                    `zstd_compress` / `zstd_decompress`
#                                    + dictionary APIs in a JS-friendly
#                                    Promise-returning interface,
#                                    runs in both Node and browser
#                                    via WebAssembly so the same
#                                    bundle works server-side and
#                                    client-side.  Compares well
#                                    against the alternative `fzstd`
#                                    (pure-JS Zstandard by 101arrowz,
#                                    same author as fflate) which is
#                                    smaller but slower; @bokuweb/
#                                    zstd-wasm is the choice when
#                                    you want C-library performance
#                                    in JS without CGO-style native-
#                                    binding deployment complexity.
#                                    Used by mapshaper for reading +
#                                    writing zstd-compressed
#                                    GeoParquet files (the modern
#                                    geospatial-data interchange
#                                    format that's emerging as a
#                                    cross-language replacement for
#                                    Shapefile in the GIS ecosystem;
#                                    GeoParquet 1.0+ specifies zstd
#                                    as one of the supported per-
#                                    column compression codecs).
#                                    Also used by mapshaper/
#                                    bread-compressor-cli, MTranServer,
#                                    snap-camera-server, waterfall-
#                                    tools, near/abi-example, and
#                                    most JS server-side tools that
#                                    need to read or write
#                                    zstd-compressed data without
#                                    shelling out to a system `zstd`
#                                    binary.
#   @types/d3 + d3 (various)        (D3 modules for projection +
#                                    geometry math + statistical
#                                    summarization)
#   proj4                            (Proj4js cartographic projection
#                                    library — converts between
#                                    coordinate reference systems
#                                    when --proj is invoked)
#   shapefile                        (Shapefile reader/writer — the
#                                    legacy ESRI .shp+.dbf+.shx format
#                                    that's still the GIS lingua-
#                                    franca for vector data
#                                    interchange)
#   @petamoriken/float16             (half-precision float arithmetic
#                                    for storage-efficient
#                                    geographic data)
#   parquet-wasm or @duckdb/duckdb-wasm
#                                    (GeoParquet reading/writing —
#                                    Apache Parquet columnar format
#                                    with geographic extensions)
#   express (mapshaper-gui only)     (HTTP server backing the
#                                    `mapshaper-gui` web editor)
#
# mapshaper's design lineage: data journalists at outlets like the
# Wall Street Journal / NYT / FT / ProPublica need to clean up
# Census Bureau / OpenStreetMap / national-statistics-agency
# shapefiles before publishing — fix invalid geometries, simplify
# coastlines to fit map projections, join CSV demographic data to
# shape attributes, dissolve administrative boundaries up to higher
# levels, project between coordinate systems, etc.  Pre-mapshaper,
# this required QGIS or ArcGIS desktop sessions with scriptable
# Python toolboxes (slow + heavyweight).  Mapshaper's bet: one
# command-line pipeline syntax replaces hundreds of mouse clicks,
# producing reproducible scripts that can live in version control
# alongside the data they process.  The pipeline composes
# arbitrarily: `mapshaper census-tracts.shp -join median-income.csv
# keys=GEOID -filter "median_income>50000" -dissolve fields="state"
# sum-fields="population,median_income" -simplify dp 5% -clip
# coastline.shp -export output.geojson` runs all five operations on
# the same in-memory dataset, only writing the final result to disk.
# The `mapshaper-xl` variant exists because some shapefiles (the
# full US Census tract file is ~600MB on disk, ~6GB expanded) exceed
# Node's default 1.5GB heap; mapshaper-xl bumps the limit via Node's
# `--max-old-space-size=8192` flag.  `mapshaper-gui` boots a local
# Node server that runs the same engine and exposes a browser-based
# interactive editor on localhost — same code path as the public
# mapshaper.org service but with no upload limit and full local
# filesystem access.
#
# ============================================================================
# === AXIS 194 CLOSES — Zstandard compression libraries ====================
# === TRIPLE-249 ROUND-NUMBER LANDMARK · 187th AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=249 CLOSES Axis 194 at slot 1/1/1 — quadruple-clean
# closure of the canonical Zstandard compression library ecosystem
# spanning the three major systems languages.  All three lanes anchor
# on either a wrapper of Yann Collet's reference zstd C library or a
# pure-host-language reimplementation, exposing the full compression-
# level range (-22..=22), streaming encoder/decoder, and dictionary-
# training APIs:
#
#     Rust    : zstd                       by Alexandre Bury (gyscos/
#                                              zstd-rs); cdylib FFI to
#                                              upstream zstd C library
#                                              with optional pure-Rust
#                                              `pure` feature.
#                 → vykar (BorgBase — Rust borgbackup-philosophy
#                           successor; content-defined chunking +
#                           BLAKE2b + AEAD + lz4/zstd compression +
#                           retention policies; 630★ GPL-3.0)
#                 _vykar           [Rust=249 OPENED Axis 194, slot 1/0/0]
#
#     Go      : github.com/klauspost/compress (zstd sub-package)
#                                          by Klaus Post (klauspost/
#                                              compress); UMBRELLA
#                                              package with pure-Go
#                                              reimplementations of
#                                              zstd + gzip + s2 +
#                                              flate, no CGO.
#                 → clickhouse-backup (Altinity — canonical ClickHouse
#                                       backup tool; tarballs streamed
#                                       through zstd encoder before
#                                       upload to S3/GCS/Azure for
#                                       ~3-5x size reduction on
#                                       typical ClickHouse data
#                                       parts; 1606★ Apache-2.0)
#                 _clickhouse-backup [Go=249 CONTINUED Axis 194, slot 2/0/0]
#
#     JS/Node : @bokuweb/zstd-wasm          by bokuweb (bokuweb/
#                                              zstd-wasm); WebAssembly
#                                              port of upstream zstd
#                                              C library.  Promise-
#                                              returning JS interface.
#                                              Runs in both Node and
#                                              browser via WASM so
#                                              same bundle works
#                                              server-side and client-
#                                              side.  Alternative is
#                                              fzstd by 101arrowz
#                                              (pure-JS smaller but
#                                              slower; same author
#                                              as fflate the canonical
#                                              pure-JS gzip).
#                 → mapshaper / mapshaper-gui / mapshaper-xl (Matthew
#                                       Bloch — GIS data processing
#                                       toolkit for Shapefile /
#                                       GeoJSON / TopoJSON / KML /
#                                       GeoParquet / GeoPackage /
#                                       FlatGeobuf / CSV / GeoTIFF
#                                       via Unix-pipeline-style
#                                       command syntax; 91 commands;
#                                       data-journalism standard
#                                       at WSJ / NYT / FT /
#                                       ProPublica; @bokuweb/zstd-wasm
#                                       handles GeoParquet's zstd
#                                       column compression; 4120★
#                                       MPL-2.0)
#                 _mapshaper       [TS-Node=249 CLOSES Axis 194, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 Cross-language design contrast (recap): Rust zstd
#                 is C-FFI binding to upstream library; Go klauspost
#                 is pure-Go umbrella REWRITE; JS @bokuweb/zstd-wasm
#                 is WASM-PORT of the C library to JS-runnable
#                 bytecode.  The WASM approach is unique to the JS
#                 lane — neither Rust nor Go uses WASM as their
#                 canonical-implementation strategy because both have
#                 native compilation targets that match or exceed C
#                 performance.  JS reaches for WASM because (a) it's
#                 the only way to run native-performance compression
#                 in a browser without backend round-trips, and (b)
#                 the same bundle then works in Node — eliminating
#                 the JS ecosystem's traditional pain of "different
#                 packages for browser vs server."
#
# Round-number 249 landmark fires simultaneously across all three lanes:
# Rust completion #249 (_vykar) + Go completion #249 (_clickhouse-backup)
# + TS-Node completion #249 (_mapshaper) = triple-249.  Axis #187 closed
# in the lifetime of the corpus.
# ============================================================================

_mapshaper() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds=(
        'i:import data (positional + flags like format=, encoding=, snap=, no-topology)'
        'o:export data (positional + flags like format=, target=, precision=, no-quotes)'
        'add-shape:add a shape to a layer programmatically'
        'affine:apply affine transformation (translate / scale / rotate / shear)'
        'alpha-shapes:compute alpha shapes (concave hull alternative)'
        'blur:apply blur filter to point data'
        'buffer:create buffer polygons around features'
        'calc:compute summary statistics across features'
        'check-geometry:report on geometric problems (self-intersections, slivers, etc)'
        'classify:assign categorical classes via natural breaks / equal-interval / quantile'
        'clean:fix geometric problems (gaps, overlaps, slivers, dupe vertices)'
        'clip:clip features by a polygon mask'
        'cluster:assign cluster IDs via k-means or DBSCAN-like methods'
        'colorizer:assign per-feature colors from a categorical palette'
        'colors:list available named color palettes'
        'comment:no-op (for readable shell scripts)'
        'dashlines:convert solid lines to dashed lines'
        'data-fill:fill missing data values via spatial interpolation'
        'debug:print internal debug state'
        'defaults:set default command-line option values'
        'define:define a JavaScript variable for later expressions'
        'dissolve:dissolve features by shared attribute (legacy algorithm)'
        'dissolve2:dissolve features (modern algorithm preserving topology)'
        'divide:divide one layer by another'
        'dots:create dot-density representation'
        'drop:drop a layer'
        'each:run a JavaScript expression on each feature'
        'elif:else-if branch inside if/elif/else/endif'
        'else:else branch'
        'encodings:list supported character encodings'
        'endif:end an if-block'
        'erase:erase features overlapping an eraser polygon'
        'explode:explode multipart geometries into singleparts'
        'external:run an external command in the pipeline'
        'filter:filter features by JavaScript expression'
        'filter-fields:filter attribute fields (rename / drop / keep)'
        'filter-geom:filter by geometry type'
        'filter-islands:remove small island polygons (legacy)'
        'filter-islands2:remove small island polygons (modern)'
        'filter-points:filter point features'
        'filter-slivers:remove sliver polygons created by overlay operations'
        'frame:add a frame (bounding box rectangle) to the layer'
        'fuzzy-join:join features with fuzzy attribute matching'
        'graticule:add a graticule (lat/lon grid) layer'
        'grid:create a vector grid layer'
        'grid2:create a vector grid (modern algorithm)'
        'help:show CLI help (or help for a specific command)'
        'if:conditional branch (start of if/elif/else/endif block)'
        'ignore:no-op (silently swallow a command)'
        'include:include a JavaScript file with helper functions'
        'info:print layer info'
        'inlay:create an inset map'
        'innerlines:extract inner boundary lines (shared edges)'
        'inspect:print feature details'
        'join:join external data (CSV/JSON/etc) to features by key'
        'lines:convert polygons to line layers'
        'merge-layers:merge multiple layers into one'
        'mosaic:create polygon mosaic for tessellation'
        'point-grid:create point grid'
        'point-to-grid:rasterize points to a grid'
        'points:convert polygons to points (centroids / interior / etc)'
        'polygons:convert lines to polygons'
        'print:print expression results to stdout'
        'proj:project to a different coordinate reference system'
        'projections:list available projection definitions'
        'quiet:suppress informational output'
        'rectangle:create a rectangle layer from bounding box'
        'rectangles:create rectangles around features'
        'rename-fields:rename attribute fields'
        'rename-layers:rename layers'
        'require:require a Node.js module for use in expressions'
        'rotate:rotate features by angle'
        'run:run a sub-command file (chain mapshaper commands)'
        'scalebar:add a scalebar overlay'
        'shape:create shapes programmatically'
        'simplify:simplify geometry (Douglas-Peucker / Visvalingam variants)'
        'slice:slice features along lines'
        'snap:snap features within tolerance distance'
        'sort:sort features by attribute or expression'
        'split:split one layer into multiple by attribute'
        'split-on-grid:split features by grid cells'
        'stop:stop pipeline execution early'
        'style:apply visual styling (for SVG export)'
        'subdivide:subdivide polygons by an expression'
        'symbols:add point symbols'
        'target:set target layer(s) for following commands'
        'union:union of overlapping polygons'
        'uniq:deduplicate features by attribute or geometry'
        'vars:list defined variables'
        'verbose:enable verbose logging'
        'version:print mapshaper version'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show CLI help (or help for a specific command via `mapshaper help <command>`)]' \
        '--version[show version]' \
        '--verbose[enable verbose logging]' \
        '--quiet[suppress informational output]' \
        '--debug[print internal debug state]' \
        '--encoding=[character encoding for text fields (default utf-8)]:encoding:(utf-8 latin1 latin2 ascii cp1252 shift_jis euc-kr gb2312)' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'mapshaper command' subcmds
            _files && ret=0
            ;;
        args)
            # Each command takes context-specific args; mapshaper's pipeline
            # is `mapshaper <cmd1> [args] -<cmd2> [args] -<cmd3> [args]`
            # so just complete files and dash-prefixed next-commands here.
            _arguments \
                '*: :_files' && ret=0
            ;;
    esac

    return ret
}

_mapshaper "$@"
