#compdef nfacctd
# Documentation: https://github.com/pmacct/pmacct/blob/master/QUICKSTART
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. nfacctd is the NetFlow/IPFIX
# accounting daemon from the pmacct project; most options live in config
# files (see CONFIG-KEYS), the CLI exposes a subset for bootstrap.

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-L[bind IP address]:addr:' \
  '-l[UDP port]:port:' \
  '-f[config file]:file:_files' \
  '-a[list primitives]' \
  '-c[primitives]:primitive:' \
  '-D[daemonize]' \
  '-n[networks file]:file:_files' \
  '-t[ports file]:file:_files' \
  '-P[plugin]:plugin:(memory print mysql pgsql sqlite3 amqp kafka tee)' \
  '-d[debug]' \
  '-S[syslog facility]:facility:(daemon user local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-F[pid file]:file:_files' \
  '-R[renormalize sampled data]' \
  '-u[numeric protocols]' \
  '-I[savefile]:file:_files' \
  '-Z[seconds]:s:' \
  '-W[sleep at EOF]' \
  '-Y[replays]:n:' \
  '-T[dry run target]:target:(config setup)' \
  '-p[memory socket]:socket:' \
  '-b[memory buckets]:n:' \
  '-m[memory pools]:n:' \
  '-s[memory pool size]:n:' \
  '-r[print refresh]:s:' \
  '-O[print output format]:fmt:(formatted csv json avro)' \
  '-o[print output file]:file:_files' \
  '-M[print markers]' \
  '-A[print append]' \
  '-E[print separator]:char:'
