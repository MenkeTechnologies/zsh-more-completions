#compdef dh_installexamples
# Documentation: https://manpages.debian.org/dh_installexamples
# Source: Debian/debhelper dh_installexamples — install example files (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '-A[apply files to all -p packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '--sourcedir=-[source directory]:dir:_files -/' \
    '--doc-main-package=-[main package for examples]:pkg:_default' \
    '*-O+[passthrough option]:opt:_default' \
    '*:example file:_files' \
    && ret=0

return ret
