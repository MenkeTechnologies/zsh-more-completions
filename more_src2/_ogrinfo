#compdef ogrinfo
# Documentation: https://gdal.org/programs/ogrinfo.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--help-general[show generic GDAL options]' \
  '(- *)--formats[list supported vector formats]' \
  '-json[output in JSON format]' \
  '-ro[open datasource read-only]' \
  '-update[open in update mode]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '-where+[attribute query]:WHERE clause' \
  '-sql+[SQL statement or @file]:SQL' \
  '-dialect+[SQL dialect]:dialect:(OGRSQL SQLITE)' \
  '-spat+[spatial filter xmin ymin xmax ymax]:xmin' \
  '-geomfield+[geometry field for spatial filter]:field name' \
  '-fid+[only fetch feature with this FID]:FID' \
  '-al[list all features of all layers]' \
  '-rl[enable random layer reading]' \
  '-so[summary only]' \
  '-features[enable feature listing]' \
  '-fields+[control field display]:mode:(YES NO)' \
  '-geom+[control geometry display]:mode:(YES NO SUMMARY WKT ISO_WKT)' \
  '-oo+[open option]:NAME=VALUE' \
  '-noextent[do not compute extent]' \
  '-extent3D[request 3D extent reporting]' \
  '-nocount[do not compute feature count]' \
  '-nogeomtype[suppress geometry type printing]' \
  '-nomd[suppress metadata printing]' \
  '-listmdd[list all metadata domains]' \
  '-mdd+[metadata domain]:domain' \
  '-fielddomain+[field domain details]:name' \
  '-limit+[max features per layer]:n' \
  '-wkt_format+[WKT format]:format:(WKT1 WKT2 WKT2_2015 WKT2_2018)' \
  '-if+[input format]:format' \
  '1:datasource:_files' \
  '*:layer name:'
