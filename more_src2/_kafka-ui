#compdef kafka-ui
# _kafka-ui — Provectus kafka-ui CLI command-line frontend wrapping the Kafka-UI open-source web GUI for managing Apache Kafka clusters topics brokers consumers consumer-groups acls schemas connect ksqldb authentication-OIDC-OAuth-LDAP roles metrics-Prometheus configuration import-export (Provectus team, Java); custom argparse
# upstream: https://github.com/provectus/kafka-ui

_kafka-ui() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.properties"' \
        '-c+[file]:file:_files -g "*.yml *.yaml *.properties"' \
        '--server.port=+[port]:n:' \
        '--server.address=+[host]:_hosts' \
        '--logging.level.root=+[level]:l:(trace debug info warn error)' \
        '--kafka.clusters[0].name=+[name]:str:' \
        '--kafka.clusters[0].bootstrapServers=+[hosts]:_hosts' \
        '--kafka.clusters[0].schemaRegistry=+[url]:str:' \
        '--kafka.clusters[0].properties.security.protocol=+[p]:p:(PLAINTEXT SSL SASL_PLAINTEXT SASL_SSL)' \
        '--kafka.clusters[0].properties.sasl.mechanism=+[m]:m:(PLAIN SCRAM-SHA-256 SCRAM-SHA-512 GSSAPI OAUTHBEARER)' \
        '--auth.type=+[t]:t:(DISABLED OAUTH2 LOGIN_FORM LDAP)' \
        '--management.endpoints.web.exposure.include=+[ep]:str:' \
        '--spring.config.location=+[file]:file:_files' \
        '--debug[debug]' \
        '*:args:'
}

_kafka-ui "$@"
