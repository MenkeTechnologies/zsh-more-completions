#compdef kopilot
# Documentation: https://github.com/knight42/kopilot
# Reference accessed: 2026-05-19
# Verified: upstream README — AI Kubernetes tool with diagnose/audit
# subcommands; configured via env vars (KOPILOT_TOKEN/KOPILOT_LANG).

local curcontext="$curcontext" state line ret=1

_kopilot_commands() {
  local -a commands=(
    'diagnose:diagnose any unhealthy workload in your cluster'
    'audit:audit a Kubernetes resource for security misconfigurations'
  )
  _describe -t commands 'kopilot command' commands
}

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :_kopilot_commands' \
  '*::arg:_default' && ret=0

return ret
