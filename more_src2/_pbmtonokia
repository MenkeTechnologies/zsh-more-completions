#compdef pbmtonokia
# Documentation: man pbmtonokia (Netpbm)
# Source: convert a PBM to Nokia Smart Messaging (logo/picture/screensaver) format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-fmt=[output format]:format:(HEX_NOL HEX_NGG HEX_NPM NOL NGG NPM)' \
    '-net=[mobile network code]:networkcode:' \
    '-txt=[caption text]:text:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
