#compdef leo-editor leo
# Documentation: https://leo-editor.github.io/leo-editor/running.html
# Reference accessed: 2026-05-16
# Verified: upstream Leo Editor "Running Leo" docs page.
# Removed from prior file: bogus man.archlinux.org search URL.

# leo-editor: literate programming outline editor (Python)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-b --black-sentinels)'{-b,--black-sentinels}'[write black-compatible sentinel comments]' \
  '--diff[use Leo as an external git diff]' \
  '--fail-fast[stop unit tests after the first failure]' \
  '(--maximized --minimized)--fullscreen[start in fullscreen]' \
  '(--fullscreen --minimized)--maximized[start maximized]' \
  '(--fullscreen --maximized)--minimized[start minimized]' \
  '--gui=[GUI backend]:gui:(console curses qt text null)' \
  '--listen-to-log[start log_listener.py on startup]' \
  '--no-plugins[disable all plugins]' \
  '--no-splash[disable the splash screen]' \
  '--quit[quit immediately after loading]' \
  '--save-session[always save session data on close]' \
  '--script=[execute script and exit]:script:_files' \
  '--script-window[execute script using default GUI]' \
  '--select=[headline or gnx of node to select]:id:' \
  '--silent[disable all log messages]' \
  '--theme=[named theme file]:name:' \
  '--trace=[enable debug tracing]:list:' \
  '--trace-binding=[trace a key binding]:key:' \
  '--trace-setting=[trace a setting]:name:' \
  '--window-size=[window size]:size:' \
  '--window-spot=[window position]:spot:' \
  '*:leo file:_files -g "*.leo(-.)"' && ret=0
return ret
