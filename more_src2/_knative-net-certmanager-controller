#compdef knative-net-certmanager-controller
# _knative-net-certmanager-controller — Knative Serving cert-manager Certificate integration (sharedmain)
# upstream: https://github.com/knative-extensions/net-certmanager
# Flags from cmd/controller/main.go + knative.dev/pkg sharedmain on tip.

_knative-net-certmanager-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-net-certmanager-controller "$@"
