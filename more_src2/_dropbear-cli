#compdef dropbear-cli
# _dropbear-cli — Matt Johnston Dropbear small SSH server/client CLI alias (mkj team, C); custom argparse
# upstream: https://github.com/mkj/dropbear

_dropbear-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b+[banner file]:file:_files' \
        '-d+[dss host key]:file:_files' \
        '-r+[rsa host key]:file:_files' \
        '-R[create host keys as required]' \
        '-F[do not fork to background]' \
        '-E[log to stderr]' \
        '-m[do not display motd]' \
        '-w[disallow root logins]' \
        '-s[disable password logins]' \
        '-g[disable password logins for root]' \
        '-B[allow blank password logins]' \
        '-j[disable local port forwarding]' \
        '-k[disable remote port forwarding]' \
        '-K+[keepalive seconds]:n:' \
        '-I+[idle timeout seconds]:n:' \
        '-p+[port]:port:' \
        '-P+[pid file]:file:_files' \
        '-T+[max auth tries]:n:' \
        '-W+[receive window size]:n:' \
        '*:arg:'
}

_dropbear-cli "$@"
