#compdef knot-revoke
# _knot-revoke — CZ.NIC Knot DNS knot-revoke helper (one-shot wrapper around keymgr to mark a managed KSK as revoked per RFC 5011 in the Knot kasp database; -c config file, -C kasp dir, -v verbose, -V version; positional argument is the zone name and the key tag to revoke)
# upstream: https://gitlab.nic.cz/knot/knot-dns
# Flags from knot-dns src/utils/keymgr (revoke action) on tip.

_knot-revoke() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[config file]:file:_files' \
        '-C+[kasp dir]:dir:_files -/' \
        '-v[verbose]' \
        '1:zone:' \
        '2:key tag:'
}

_knot-revoke "$@"
