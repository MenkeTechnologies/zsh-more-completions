#compdef gdal_proximity gdal_proximity.py
# Documentation: https://gdal.org/programs/gdal_proximity.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-srcband+[source band (default 1)]:band:' \
  '-dstband+[destination band (default 1)]:band:' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-ot+[output type]:type:(Byte UInt16 Int16 UInt32 Int32 Float32 Float64)' \
  '-values+[target pixel values]:n,n,n:' \
  '-distunits+[distance units]:units:(PIXEL GEO)' \
  '-maxdist+[maximum distance]:value:' \
  '-nodata+[nodata value]:value:' \
  '-use_input_nodata+[use input nodata]:flag:(YES NO)' \
  '-fixed-buf-val+[fixed buffer value]:value:' \
  '1:source raster:_files' \
  '2:destination raster:_files' && ret=0

return ret
