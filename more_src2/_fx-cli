#compdef fx-cli
# _fx-cli — Anton Medvedev fx interactive JSON CLI alias (Anton Medvedev / antonmedv, Go); custom argparse
# upstream: https://github.com/antonmedv/fx

_fx-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--raw[raw input strings]' \
        '-r[raw input strings]' \
        '--slurp[slurp inputs]' \
        '-s[slurp inputs]' \
        '--no-color[disable color]' \
        '-C[disable color]' \
        '--quote=+[output quote]:str:' \
        '--themes=+[theme]:t:(1 2 3 4 5 6 7 8)' \
        '--print[print and exit]' \
        '-p[print and exit]' \
        '--yaml[parse as YAML]' \
        '-y[parse as YAML]' \
        '--toml[parse as TOML]' \
        '-t[parse as TOML]' \
        '--csv[parse as CSV]' \
        '-c[parse as CSV]' \
        '--xml[parse as XML]' \
        '-x[parse as XML]' \
        '--reduce[reduce mode]' \
        '-R[reduce mode]' \
        '--editor=+[editor]:str:' \
        '--style=+[style]:s:(0 1 2 3 4 5 6 7 8)' \
        '--max-keys=+[max keys to show]:n:' \
        '--no-cursor[no cursor]' \
        '--debug[debug]' \
        '*:file-or-arg:_files'
}

_fx-cli "$@"
