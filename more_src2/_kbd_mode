#compdef kbd_mode
# _kbd_mode — kbd kbd-tools kbd_mode CLI reading or setting the keyboard input scancode mode for a Linux console raw scancode mediumraw keycode XLATE ascii UNICODE utf-8 mode switching between cooked and raw byte streams from the kernel TTY layer (kbd team, C); getopt
# upstream: https://kbd-project.org/

_kbd_mode() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a[ASCII XLATE mode]' \
        '-u[Unicode UTF-8 mode]' \
        '-k[medium-raw keycode mode]' \
        '-s[raw scancode mode]' \
        '-f[force]' \
        '-C+[console]:file:_files -g "/dev/tty* /dev/vc/*"' \
        '*::'
}

_kbd_mode "$@"
