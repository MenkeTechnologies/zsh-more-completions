#compdef emqx_ctl
# Documentation: https://docs.emqx.com/en/emqx/latest/admin/cli.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'status:verify broker status'
  'broker:inspect broker metrics'
  'cluster:manage cluster membership'
  'clients:monitor connected clients'
  'topics:view subscribed topics'
  'subscriptions:manage topic subscriptions'
  'plugins:install/start/manage plugins'
  'vm:Erlang VM performance data'
  'mnesia:database status'
  'log:configure logging'
  'trace:debug clients/topics/IPs'
  'traces:cluster-wide tracing'
  'listeners:manage MQTT listeners'
  'authz:clear authorization caches'
  'pem_cache:reload TLS certificate files'
  'olp:overload protection'
  'data:export/import config'
  'ds:durable storage'
  'exclusive:exclusive topics'
  'retainer:retained messages'
  'observer:debug node'
  'conf:cluster configuration'
  'eviction:node evacuation'
  'rebalance:migrate connections'
  'gateway:protocol gateways'
  'license:enterprise license'
  'admins:dashboard accounts'
  'api_keys:REST API credentials'
  'rules:rule engine rules'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'emqx_ctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (broker)
        _values 'broker action' 'stats' 'metrics' && ret=0
        ;;
      (cluster)
        _values 'cluster action' 'join' 'leave' 'force-leave' 'status' 'discovery' && ret=0
        ;;
      (clients)
        _values 'clients action' 'list' 'show' 'kick' 'stats' && ret=0
        ;;
      (topics)
        _values 'topics action' 'list' 'show' && ret=0
        ;;
      (subscriptions)
        _values 'subscriptions action' 'list' 'show' 'add' 'del' && ret=0
        ;;
      (plugins)
        _values 'plugins action' \
          'list' 'describe' 'allow' 'disallow' 'install' 'uninstall' \
          'start' 'stop' 'restart' 'disable' 'enable' && ret=0
        ;;
      (vm)
        _values 'vm action' 'all' 'load' 'memory' 'process' 'io' 'ports' && ret=0
        ;;
      (log)
        _values 'log action' 'set-level' 'primary-level' 'handlers' && ret=0
        ;;
      (trace)
        _values 'trace action' 'list' 'start' 'stop' && ret=0
        ;;
      (listeners)
        _values 'listeners action' 'stop' 'start' 'restart' 'enable' && ret=0
        ;;
    esac
    ;;
esac

return ret
