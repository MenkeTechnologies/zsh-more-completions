#compdef msbuild MSBuild.exe
# _msbuild — Microsoft Build Engine (Microsoft, C#); cross-platform XML-based build system for .NET
# upstream: https://github.com/dotnet/msbuild

_msbuild() {
    _arguments \
        '-h[show help]' \
        '/help[show help]' \
        '-version[show version]' \
        '/ver[show version]' \
        '-target:+[target list]:targets:' \
        '/t:+[target list]:targets:' \
        '-property:+[property]:KEY=VAL:' \
        '/p:+[property]:KEY=VAL:' \
        '-maxCpuCount+[parallel cores]:n:' \
        '-m+[parallel cores]:n:' \
        '/m+[parallel cores]:n:' \
        '-toolsversion:+[tools version]:ver:' \
        '/tv:+[tools version]:ver:' \
        '-verbosity:+[verbosity]:level:(quiet minimal normal detailed diagnostic)' \
        '/v:+[verbosity]:level:(quiet minimal normal detailed diagnostic)' \
        '-consoleLoggerParameters:+[console logger params]:str:' \
        '-noConsoleLogger[no console logger]' \
        '/noconlog[no console logger]' \
        '-fileLogger[file logger]' \
        '/fl[file logger]' \
        '-fileLoggerParameters:+[file logger params]:str:' \
        '/flp:+[file logger params]:str:' \
        '-binaryLogger:+[binary logger]:file:_files' \
        '/bl:+[binary logger]:file:_files' \
        '-distributedLogger:+[distributed logger]:str:' \
        '/dl:+[distributed logger]:str:' \
        '-logger:+[logger]:str:' \
        '/logger:+[logger]:str:' \
        '-distributedFileLogger[distributed file logger]' \
        '-noAutoResponse[no auto response]' \
        '/noautorsp[no auto response]' \
        '-nologo[no logo]' \
        '/nologo[no logo]' \
        '-restore[restore]' \
        '-restoreProperty:+[restore prop]:KEY=VAL:' \
        '-targetsDirectory:+[targets dir]:dir:_files -/' \
        '-nodeReuse:+[node reuse]:bool:(true false)' \
        '-validate[validate]' \
        '-preprocess:+[preprocess output]:file:_files' \
        '-detailedSummary[detailed summary]' \
        '-ds[detailed summary]' \
        '-warnAsError:+[warn as error]:str:' \
        '-warnNotAsError:+[warn not as error]:str:' \
        '-ignoreProjectExtensions:+[ignore extensions]:str:' \
        '-isolate[isolate]' \
        '-graph[graph build]' \
        '-inputResultsCaches:+[input caches]:str:' \
        '-outputResultsCache:+[output cache]:file:_files' \
        '-interactive[interactive]' \
        '*:project:_files'
}

_msbuild "$@"
