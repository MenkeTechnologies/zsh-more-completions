#compdef nbdkit-cli
# _nbdkit-cli — Richard W.M. Jones nbdkit pluggable NBD server CLI alias (libguestfs team, C); custom argparse
# upstream: https://gitlab.com/nbdkit/nbdkit

_nbdkit-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--dump-config[dump compiled config]' \
        '--dump-plugin[dump plugin info]' \
        '--exit-with-parent[exit with parent]' \
        '--filter=+[filter]:str:' \
        '--foreground[foreground]' \
        '-f[foreground]' \
        '--group=+[group]:_groups' \
        '-g+[group]:_groups' \
        '--user=+[user]:_users' \
        '-u+[user]:_users' \
        '--ipaddr=+[bind address]:host:_hosts' \
        '-i+[bind address]:host:_hosts' \
        '--log=+[log type]:t:(stderr syslog null)' \
        '--mask-handshake=+[mask]:str:' \
        '--newstyle[newstyle protocol]' \
        '-n[newstyle protocol]' \
        '--no-fork[do not fork]' \
        '--no-mc[no MC handshake]' \
        '--no-sr[no SR handshake]' \
        '--oldstyle[oldstyle protocol]' \
        '-o[oldstyle protocol]' \
        '--pidfile=+[pid file]:file:_files' \
        '-P+[pid file]:file:_files' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--readonly[readonly]' \
        '-r[readonly]' \
        '--rundir=+[run dir]:dir:_files -/' \
        '--selinux-label=+[label]:str:' \
        '--single[handle one connection]' \
        '-s[handle one connection]' \
        '--swap[mark as swap]' \
        '--threads=+[threads]:n:' \
        '-t+[threads]:n:' \
        '--tls=+[tls]:t:(off on require)' \
        '--tls-certificates=+[cert dir]:dir:_files -/' \
        '--tls-psk=+[psk file]:file:_files' \
        '--tls-verify-peer[verify peer]' \
        '--unix=+[unix socket]:file:_files' \
        '-U+[unix socket]:file:_files' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--vsock[vsock]' \
        '--socket-activation[socket activation]' \
        '-D+[debug flag]:str:' \
        '--debug=+[debug flag]:str:' \
        '*:plugin args:'
}

_nbdkit-cli "$@"
