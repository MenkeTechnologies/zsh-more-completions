#compdef dotlock
# Documentation: dotlock --help (GNU Mailutils)
# Source: lock mail spool files using the dotlock convention.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-d --debug)'{-d,--debug}'[print failure-reason details to stderr]' \
    '--no-debug[disable debug]' \
    '(-f --force)'{-f+,--force=-}'[break stale lock older than MINUTES]::minutes:' \
    '(-p --pid-check)'{-p,--pid-check}'[check if lock-owner PID is active]' \
    '--no-pid-check[disable PID check]' \
    '(-r --retry)'{-r+,--retry=}'[retry the lock N times]:retries:' \
    '(-t --delay)'{-t+,--delay=}'[delay between retries (seconds)]:secs:' \
    '(-u --unlock)'{-u,--unlock}'[unlock]' \
    '--no-unlock[do not unlock]' \
    '--debug-level=[Mailutils debugging level]:level:' \
    '--debug-line-info[show source info with debug messages]' \
    '--no-debug-line-info[hide source info]' \
    '--config-file=[configuration file]:file:_files' \
    '--config-lint[check configuration syntax and exit]' \
    '--config-verbose[verbosely log config parsing]' \
    '1:lock file:_files' \
    && ret=0

return ret
