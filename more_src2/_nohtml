#compdef nohtml
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/nohtml.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# EMBOSS nohtml: remove HTML tags from an ASCII text file.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-infile=[input ASCII text with HTML]:file:_files' \
  '-outfile=[output file]:file:_files' \
  '*:input file:_files' && ret=0
return ret
