#compdef nbqa
# Documentation: https://nbqa.readthedocs.io/en/latest/configuration.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local linters=(
  'ruff' 'isort' 'pyupgrade' 'mypy' 'pylint' 'flake8'
  'black' 'blacken-docs' 'autopep8' 'pydocstyle' 'yapf' 'doctest'
)

_arguments -s \
  '--nbqa-md[process markdown cells]' \
  '--nbqa-diff[show changes without applying]' \
  '--nbqa-shell[run as shell command rather than via python -m]' \
  '--nbqa-dont-skip-bad-cells[process cells with syntax errors]' \
  '--nbqa-process-cells=[process specified cell magics]:magic:' \
  '--nbqa-skip-celltags=[skip cells with specified tags]:tags:' \
  '*--nbqa-files=[files regex pattern]:pattern:' \
  '*--nbqa-exclude=[exclude regex pattern]:pattern:' \
  '(- *)'{-h,--help}'[show help]' \
  "1:linter:(${linters[*]})" \
  '*:notebook or arg:_files -g "*.(ipynb|py)"'
