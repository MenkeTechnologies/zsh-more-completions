_muxi_commands() {
    local commands; commands=(
'init:Register within Tmux and add bindings' \
'config:See and edit your settings' \
'c:See and edit your settings' \
'ls:List sessions' \
'sessions:See and manage your muxi sessions' \
's:See and manage your muxi sessions' \
'plugins:See and manage your tmux plugins' \
'p:See and manage your tmux plugins' \
'completions:Generate completions for your shell' \
'fzf:Spawn a FZF popup to manage your muxi sessions' \
'f:Spawn a FZF popup to manage your muxi sessions' \
'fzf-keybindings:' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'muxi commands' commands "$@"
}
