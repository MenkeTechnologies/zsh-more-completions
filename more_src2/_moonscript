#compdef moonscript moonc
# _moonscript — Leaf Corcoran MoonScript Lua-targeting language CLI (Leaf Corcoran / leafo, Lua/MoonScript); custom argparse
# upstream: https://github.com/leafo/moonscript

_moonscript() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--print[print compiled lua to stdout]' \
        '-p[print compiled lua to stdout]' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-t+[output dir]:dir:_files -/' \
        '--tree=+[output dir tree]:dir:_files -/' \
        '-T[tree mode]' \
        '--watch[watch and recompile]' \
        '-w[watch and recompile]' \
        '--ast[print parse tree]' \
        '-X[print parse tree]' \
        '--lint[lint]' \
        '-l[lint]' \
        '--no-color[no color]' \
        '-d[force recompile]' \
        '-q[quiet]' \
        '*:file:_files -g "*.moon"'
}

_moonscript "$@"
