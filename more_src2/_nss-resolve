#compdef nss-resolve
# _nss-resolve — systemd nss-resolve libnss_resolve GNU C library NSS Name Service Switch module CLI helper resolving hostnames via the systemd-resolved varlink bus org.freedesktop.resolve1 DNS-over-TLS DNSSEC LLMNR mDNS unified resolver instead of legacy nss-dns nss-files (systemd team, C); getopt
# upstream: https://www.freedesktop.org/wiki/Software/systemd/resolved/

_nss-resolve() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '--cache[force cache]' \
        '--no-cache[no cache]' \
        '--protocol=+[p]:p:(dns mdns llmnr)' \
        '--type=+[type]:t:(A AAAA CNAME MX TXT SRV PTR NS SOA CAA TLSA OPENPGPKEY)' \
        '--interface=+[iface]:_net_interfaces' \
        '*:hostname or address:_hosts'
}

_nss-resolve "$@"
