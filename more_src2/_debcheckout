#compdef debcheckout
# Documentation: https://manpages.debian.org/debcheckout
# Source: debian/devscripts scripts/debcheckout.pl — checkout the development version of a Debian package (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-a,--auth}'[use authenticated URL when checking out]' \
    '(-d --details)'{-p,--print}'[print VCS URL and quit]' \
    '(-p --print)'{-d,--details}'[show VCS details]' \
    {-P+,--package=}'[treat argument as a package name]:package:_default' \
    {-t+,--type=}'[VCS type]:type:(arch bzr cvs darcs git hg svn)' \
    {-u+,--user=}'[VCS username]:user:_users' \
    '*'{-f+,--file=}'[file to checkout]:file:_default' \
    '--git-track=-[branches to track (comma-separated)]:branches:_default' \
    '--source=-[unpack source mode]:mode:(never auto download-only always)' \
    '1:package or URL:_default' \
    '2::destination directory:_files -/' \
    && ret=0

return ret
