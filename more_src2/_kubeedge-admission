#compdef kubeedge-admission admission
# _kubeedge-admission — KubeEdge admission webhook (validates Device/Rule/Resource CRDs from cloudcore)
# upstream: https://github.com/kubeedge/kubeedge
# Flags from cloud/cmd/admission/app/{server,options/options}.go on tip.

_kubeedge-admission() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--master=[Kubernetes API URL (overrides kubeconfig)]:url:_urls' \
        '--kubeconfig=[path to kubeconfig file]:file:_files' \
        '--tls-cert-file=[default x509 TLS certificate file]:file:_files' \
        '--tls-private-key-file=[default x509 TLS private key file]:file:_files' \
        '--ca-cert-file=[CA certificate file for HTTPS]:file:_files' \
        '--webhook-namespace=[namespace this webhook lives in]:ns:' \
        '--webhook-service-name=[admission service name]:name:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)'
}

_kubeedge-admission "$@"
