#compdef gh-ec2 gh-init gh-rate-limit-status gh-reviewers-graph gh-secrets-migrator
# Documentation: upstream READMEs at github.com/{matsui528/gh-ec2,fsncps/gh-init,gh-tui-tools/gh-rate-limit-status,gh-tui-tools/gh-reviewers-graph,renan-alm/gh-secrets-migrator}
# Reference accessed: 2026-05-30
# gh-extension family round 13. Python slice page-2 harvest.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-ec2)
    # matsui528/gh-ec2 — AWS EC2 management via gh CLI.
    # 8 subcommands; all instance-targeted ones take INSTANCE_NAME positional.
    local -a _subcmds
    _subcmds=(
      'config:register instance details to ~/.instance_list.json (interactive)'
      'list:display all configured instances'
      'status:check instance status'
      'start:launch an instance'
      'stop:halt an instance'
      'ssh:open SSH connection'
      'nautilus:access home directory via file manager'
      'ip:retrieve the instance IP address'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-ec2 subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          config)
            _arguments \
              '--config=[alternate config file]:file:_files' && ret=0
            ;;
          status|start|stop|ssh|nautilus|ip)
            _arguments \
              '1:instance name:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-init)
    # fsncps/gh-init — create local + remote GitHub repo in one shot.
    _arguments -s -S \
      '(-p --path)-p+[local directory to initialize]:dir:_files -/' \
      '(-p --path)--path=[local directory to initialize]:dir:_files -/' \
      '(-n --name)-n+[custom repository name]:name:' \
      '(-n --name)--name=[custom repository name]:name:' \
      '--no-gitignore[skip .gitignore creation]' \
      '--no-readme[skip README generation]' \
      '(-P --public)-P[create as public repo (default private)]' \
      '(-P --public)--public[create as public repo (default private)]' \
      '(-d --description)-d+[repository description]:description:' \
      '(-d --description)--description=[repository description]:description:' \
      && ret=0
    ;;

  gh-rate-limit-status)
    # gh-tui-tools/gh-rate-limit-status — gh API rate-limit status display.
    _arguments -s -S \
      '(- *)-h[show help]' \
      '-a[show all limits including low-volume + enterprise-only]' \
      '--json[machine-readable JSON output]' \
      '-w[watch mode (continuous display)]' \
      '--warn=[exit 1 if any limit drops below N percent]:percent:' \
      && ret=0
    ;;

  gh-reviewers-graph)
    # gh-tui-tools/gh-reviewers-graph — visualize PR reviewer activity as HTML.
    _arguments -s -S \
      '--top=[limit to top N reviewers (default 100)]:N:' \
      '--exclude=[filter out specific accounts (comma-separated)]:logins:' \
      '--refresh[bypass cache for fresh data]' \
      '--output=[report directory]:dir:_files -/' \
      '1:OWNER/REPO:' \
      && ret=0
    ;;

  gh-secrets-migrator)
    # renan-alm/gh-secrets-migrator — migrate secrets between GitHub orgs.
    # Required: --source-org, --source-repo, --target-org.
    # Conditionally required: --target-repo (defaults to source-repo).
    _arguments -s -S \
      '--source-org=[source organization name]:org:' \
      '--source-repo=[source repository name]:repo:' \
      '--target-org=[target organization name]:org:' \
      '--target-repo=[target repository name]:repo:' \
      '--source-pat=[source PAT (defaults to GITHUB_TOKEN)]:pat:' \
      '--target-pat=[target PAT (defaults to GITHUB_TOKEN)]:pat:' \
      '--github-source-pat=[gh-gei compatible source token]:pat:' \
      '--github-target-pat=[gh-gei compatible target token]:pat:' \
      '--verbose[debug logging]' \
      '--skip-envs[skip environment recreation]' \
      '--skip-overwrite[skip existing secrets in target]' \
      '--org-to-org[migrate only organization-level secrets]' \
      '--source-endpoint=[custom GitHub API endpoint for source]:url:' \
      '--target-endpoint=[custom GitHub API endpoint for target]:url:' \
      && ret=0
    ;;

esac

return ret
