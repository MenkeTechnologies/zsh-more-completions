#compdef flumina
# Documentation: https://fireworks.ai
# Reference accessed: 2026-05-23
# Verified: fireworks.flumina.cli build_command_tree() in fireworks-ai PyPI package.

# Zsh completion for flumina - Fireworks Flumina model deploy CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'flumina command' \
      'set-api-key[set Fireworks API key]' \
      'init[initialize Flumina app]' \
      'validate[validate Flumina repo in current directory]' \
      'deploy[validate upload deploy and return schema]' \
      'get[get Flumina resources]' \
      'list[list Flumina resources]' \
      'create[create Flumina resources]' \
      'delete[delete Flumina resources]' && ret=0
    ;;
  args)
    case $line[1] in
      set-api-key)
        _arguments '1:api_key:api key:' && ret=0
        ;;
      init)
        _arguments -C \
          '1:subcommand:->init_cmds' \
          '*:: :->init_args' && ret=0
        case $state in
          init_cmds)
            _values 'flumina init command' \
              'app[initialize empty Flumina app]' \
              'from_hf[initialize from Hugging Face repo]' \
              'addon[initialize Flumina addon repo]' && ret=0
            ;;
          init_args)
            case $line[2] in
              app|from_hf|addon)
                _arguments '--allow-non-empty[allow non-empty directory]' \
                  '(:from_hf -)' '(:from_hf *)model_repo:model repo:' \
                  '(:addon -)' '(:addon *)addon_type:addon type:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      validate)
        _arguments '--world-size[distributed world size for validation]:size:' && ret=0
        ;;
      deploy)
        _arguments \
          '1:model_name:model name:' \
          '--public[make model public]' \
          '--base-model[base model resource id]:model:' \
          '--world-size[distributed world size]:size:' \
          '--min-replica-count[minimum replicas]:count:' \
          '--max-replica-count[maximum replicas]:count:' \
          '--accelerator-type[GPU type]:(H100 A100)' \
          '--format[schema output format]:(openapi curl)' \
          '--skip-validation[skip app validation]' && ret=0
        ;;
      get)
        _arguments -C \
          '1:subcommand:->get_cmds' \
          '*:: :->get_args' && ret=0
        case $state in
          get_cmds)
            _values 'flumina get command' \
              'model[get Flumina model]' \
              'deployment[get Flumina deployment]' \
              'schema[get deployment schema]' && ret=0
            ;;
          get_args)
            case $line[2] in
              model|deployment)
                _arguments '1:name:resource name:' && ret=0
                ;;
              schema)
                _arguments \
                  '1:deployment_name:deployment name:' \
                  '--format[schema format]:(openapi curl)' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      list)
        _arguments -C \
          '1:subcommand:->list_cmds' \
          '*:: :->list_args' && ret=0
        case $state in
          list_cmds)
            _values 'flumina list command' \
              'models[list Flumina models]' \
              'deployments[list Flumina deployments]' \
              'endpoints[list endpoints]' && ret=0
            ;;
          list_args)
            _arguments '--account_id[Fireworks account ID]:account:' && ret=0
            ;;
        esac
        ;;
      create)
        _arguments -C \
          '1:subcommand:->create_cmds' \
          '*:: :->create_args' && ret=0
        case $state in
          create_cmds)
            _values 'flumina create command' \
              'model[upload directory as Flumina model]' \
              'deployment[deploy existing Flumina model]' \
              'deployed_addon[deploy addon to deployment]' && ret=0
            ;;
          create_args)
            case $line[2] in
              model)
                _arguments \
                  '1:model_name:model name:' \
                  '--base-model[base model resource id]:model:' \
                  '--public[make model public]' \
                  '--world-size[distributed world size]:size:' && ret=0
                ;;
              deployment)
                _arguments \
                  '1:model_name:model name:' \
                  '--min-replica-count[minimum replicas]:count:' \
                  '--max-replica-count[maximum replicas]:count:' \
                  '--accelerator-type[GPU type]:(H100 A100)' && ret=0
                ;;
              deployed_addon)
                _arguments \
                  '1:addon_name:addon name:' \
                  '2:deployment_name:deployment name:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      delete)
        _arguments -C \
          '1:subcommand:->delete_cmds' \
          '*:: :->delete_args' && ret=0
        case $state in
          delete_cmds)
            _values 'flumina delete command' \
              'model[delete Flumina model]' \
              'deployment[delete Flumina deployment]' && ret=0
            ;;
          delete_args)
            _arguments '1:name:resource name:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
