#compdef emulator
# _emulator — Android emulator binary (Google AOSP, C++); custom argparse
# upstream: https://android.googlesource.com/platform/external/qemu/

_emulator() {
    _arguments \
        '-help[show help]' \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '-list-avds[list AVDs]' \
        '-avd+[AVD name]:str:' \
        '-sysdir+[system images dir]:dir:_files -/' \
        '-system+[system image file]:file:_files' \
        '-vendor+[vendor image file]:file:_files' \
        '-writable-system[writable system]' \
        '-delay-adb[delay adb]' \
        '-datadir+[data dir]:dir:_files -/' \
        '-kernel+[kernel image]:file:_files' \
        '-ramdisk+[ramdisk image]:file:_files' \
        '-image+[obsolete system image]:file:_files' \
        '-initdata+[init data img]:file:_files' \
        '-data+[user data img]:file:_files' \
        '-encryption-key+[encryption key img]:file:_files' \
        '-logcat+[logcat filter]:str:' \
        '-logcat-output+[logcat output]:file:_files' \
        '-shell[serial shell]' \
        '-no-jni[no jni checks]' \
        '-nojni[no jni checks]' \
        '-dalvik-vm-checkjni[checkjni]' \
        '-show-kernel[show kernel logs]' \
        '-virtio-console[virtio console]' \
        '-trace+[trace events list]:str:' \
        '-skip-adb-auth[skip adb auth]' \
        '-no-snapshot[no snapshots]' \
        '-no-snapshot-save[no snapshot save]' \
        '-no-snapshot-load[no snapshot load]' \
        '-snapshot=+[snapshot name]:str:' \
        '-snapstorage+[snapshot storage img]:file:_files' \
        '-skin+[skin name]:str:' \
        '-no-skin[no skin]' \
        '-noskin[no skin]' \
        '-dpi-device+[device dpi]:n:' \
        '-scale+[window scale]:n:' \
        '-netspeed=+[netspeed]:str:(gsm hscsd gprs edge umts hsdpa lte evdo full)' \
        '-netdelay=+[netdelay]:str:(gsm hscsd gprs edge umts hsdpa lte evdo none)' \
        '-netfast[netfast]' \
        '-net-tap+[tap iface]:str:_net_interfaces' \
        '-net-tap-script-up+[tap up script]:file:_files' \
        '-tcpdump+[tcpdump file]:file:_files' \
        '-port=+[adb port]:port:' \
        '-ports=+[adb console+adb port]:str:' \
        '-adb-port=+[adb port]:port:' \
        '-grpc=+[grpc port]:port:' \
        '-grpc-tls-key=+[grpc tls key]:file:_files' \
        '-grpc-tls-cer=+[grpc tls cert]:file:_files' \
        '-grpc-tls-ca=+[grpc tls ca]:file:_files' \
        '-no-window[no window]' \
        '-window[show window]' \
        '-gpu=+[gpu mode]:mode:(auto host swiftshader_indirect angle_indirect guest)' \
        '-feature=+[feature flag]:str:' \
        '-no-passive-gps[no passive gps]' \
        '-no-cache[no cache img]' \
        '-cache+[cache img]:file:_files' \
        '-no-audio[no audio]' \
        '-audio+[audio backend]:str:' \
        '-debug=+[debug tags]:tags:' \
        '-no-boot-anim[no boot animation]' \
        '-quit-after-boot=+[seconds]:n:' \
        '-qt-hide-window[hide qt window]' \
        '-no-metrics[no metrics]' \
        '-metrics-collection[metrics collection]' \
        '-metrics-to-console[metrics to console]' \
        '-metrics-to-file+[metrics file]:file:_files' \
        '-no-direct-adb[no direct adb]' \
        '-restart-when-stalled[restart when stalled]' \
        '-quit-after-boot+[seconds]:n:' \
        '-qemu+[qemu args]:str:' \
        '*:arg:'
}

_emulator "$@"
