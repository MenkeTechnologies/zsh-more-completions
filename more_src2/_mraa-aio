#compdef mraa-aio
# _mraa-aio — Intel mraa-aio CLI command-line wrapper around Intel libmraa I/O abstraction library reading analog input pin values bit-depth selection oversampling on Intel Galileo Edison Joule MinnowBoard ARM SBC ADCs via sysfs IIO subsystem (Intel team, C); custom argparse
# upstream: https://github.com/intel-iot-devkit/mraa

_mraa-aio() {
    local -a sub=(
        'list:list available aio pins'
        'version:print versions'
        'read:read raw analog value'
        'read_float:read normalized float value'
        'set-bit:set ADC bit width'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mraa-aio subcommand' sub ;;
        args)
            case $words[1] in
                read|read_float) _arguments '1:pin:' ;;
                set-bit) _arguments '1:pin:' '2:bits:(8 10 12 14 16)' ;;
            esac
            ;;
    esac
}

_mraa-aio "$@"
