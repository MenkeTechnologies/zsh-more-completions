#compdef easydiffusion easy-diffusion easydiff
# _easydiffusion — Easy Diffusion newbie-friendly Stable Diffusion installer CLI alias (cmdr2 / easydiffusion team, Python); custom argparse
# upstream: https://github.com/easydiffusion/easydiffusion

_easydiffusion() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--host=+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '--cuda-device=+[CUDA device]:n:' \
        '--use-cpu[use CPU]' \
        '--low-vram[low VRAM]' \
        '--med-vram[medium VRAM]' \
        '--enable-developer-mode[enable developer mode]' \
        '--bind-key=+[bind key]:str:' \
        '--allow-noauth[allow no auth]' \
        '--allow-remote[allow remote connections]' \
        '--max-image-size=+[max image size]:n:' \
        '--max-batches=+[max batches]:n:' \
        '--reinstall[reinstall]' \
        '--reset-config[reset config]' \
        '--reset-models[reset models]' \
        '--prefer-fp16[prefer FP16]' \
        '--prefer-bf16[prefer BF16]' \
        '--upgrade[upgrade installation]' \
        '--ui=+[UI port]:port:' \
        '--api[enable API]' \
        '--data-dir=+[data dir]:dir:_files -/' \
        '--models-dir=+[models dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--debug[debug]' \
        '--log=+[log file]:file:_files' \
        '*:arg:'
}

_easydiffusion "$@"
