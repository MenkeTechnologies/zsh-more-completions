# ---------------------------------------------------------------------------
# geek-life — TODO list / task manager for geeks in command line (Go, 556★)
#
# upstream: https://github.com/ajaxray/geek-life
# author : Anis Uddin Ahmad (ajaxray) — Bangladeshi software engineer
# license: MIT
#
# Source-direct completion: every flag and the positional `migrate` command
# is verbatim from app/cli.go on the geek-life tip — `init()` registers
# `-d/--db-file` via spf13/pflag, and `main()` dispatches `migrate` via
# `flag.NArg() > 0 && flag.Arg(0) == "migrate"`.
#
# Direct deps from go.mod (selected):
#   github.com/gdamore/tcell/v2   ← canonical Go cross-platform terminal
#                                   library (this axis) — by Garrett D'Amore
#   github.com/rivo/tview         (TUI widgets built on tcell — flex/list/
#                                  text input/modal/pages/table)
#   github.com/asdine/storm/v3    (BoltDB ORM for embedded local storage)
#   github.com/spf13/pflag        (POSIX/GNU-style flag parser)
#
# geek-life renders project columns + task lists + task detail in a
# tview-driven multi-pane TUI with vim-style keyboard navigation (`p` for
# projects, `t` for tasks, `q` to quit).  Local-only by default — storm
# wraps BoltDB for embedded persistence.
#
# === AXIS 167 CONTINUES — cross-platform terminal primitives ecosystem ===
# Axis position: Go=222 continues Axis 167 (slot 2/0/0).  Canonical Go
# cross-platform terminal library is `gdamore/tcell` (v2) by Garrett D'Amore
# — a pure-Go terminal cell-grid abstraction that handles Unicode, mouse,
# resize events, and TrueColor uniformly across Unix terminals and Windows
# console.  Used by termshark (network protocol analyzer), termdash (Google
# Kubernetes dashboards), itchyny/bed (hex editor), tut (Mastodon TUI),
# amfora (Gemini browser), ligolo-mp (pivoting), gomphotherium (Mastodon),
# and most modern Go TUIs that pre-date or coexist with bubbletea.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=222   _rust_kanban         ← previous round (axis 167 OPENS at 1/0/0)
#   Go=222     ← THIS FILE          (axis 167 continues, slot 2/0/0)
#   TS-Node=222 ← next round        (axis 167 CLOSES at triple-222, slot 1/1/1)
# ---------------------------------------------------------------------------

_geek-life() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-d --db-file)'{-d,--db-file=}'[specify DB file path manually (default: $HOME/.geek-life.db)]:db file:_files -g "*.(db|bolt)"' \
        '(- *)'{-h,--help}'[print help]' \
        '1: :->cmds' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'migrate:re-index BoltDB indexes for Projects and Tasks then exit (run after upgrade)'
            )
            _describe -t commands 'geek-life command' subcmds && ret=0
            ;;
    esac

    return ret
}

_geek-life "$@"
