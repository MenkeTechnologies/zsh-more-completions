#compdef fileslower fileslower-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/fileslower.py argparse)
# Reference accessed: 2026-05-29
# fileslower — trace slow synchronous file I/O via VFS read/write (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-a --all-files)'{-a,--all-files}'[include non-regular file types (sockets, FIFOs, etc.)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:min_ms (minimum I/O duration to trace, default 10):' \
  && ret=0

return ret
