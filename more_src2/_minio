#compdef minio
# Documentation: https://docs.min.io/enterprise/aistor-object-store/reference/aistor-server/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; gateway subcommand was
# deprecated and removed from the minio binary in 2022 (see
# https://blog.min.io/deprecation-of-the-minio-gateway/), so it is no
# longer offered as a completion target. Only "server" remains.

_minio() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    local -a commands=(
        'server:start MinIO object storage server'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1:command:->command' \
        '*::arg:->args'

    case $state in
        command)
            _describe -t commands 'minio command' commands
            ;;
        args)
            case $words[1] in
                server)
                    _arguments -s -S \
                        '(- *)'{-h,--help}'[show help]' \
                        '--address=[bind to a specific ADDRESS:PORT]:address:' \
                        '--console-address=[bind console to a specific ADDRESS:PORT]:address:' \
                        '(-S --certs-dir)'{-S,--certs-dir=}'[path to certs directory]:directory:_directories' \
                        '--config=[path to startup configuration file]:file:_files' \
                        '--interface=[bind to a specific interface]:iface:' \
                        '--quiet[disable startup and info messages]' \
                        '--anonymous[hide sensitive information from logging]' \
                        '--json[output logs in JSON format]' \
                        '--ftp=[enable FTP/FTPS server (address, passive-port-range, TLS opts)]:opts:' \
                        '*--sftp=[enable SFTP server (address, ssh-key, algorithms)]:opts:' \
                        '*:data directory:_directories'
                    ;;
            esac
            ;;
    esac
}

_minio "$@"
