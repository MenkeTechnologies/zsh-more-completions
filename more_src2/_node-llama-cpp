#compdef node-llama-cpp safe-cli safe-creator
# Documentation: upstream READMEs + docs at github.com/{withcatai/node-llama-cpp,safe-global/safe-cli}
# Reference accessed: 2026-05-30
# Mixed-theme R29 — local-LLM Node.js bindings (withcatai/node-llama-cpp)
# + Ethereum Safe-contract management (safe-global/safe-cli) sister-binary
# pair.

local curcontext="$curcontext" state line ret=1

case $service in

  node-llama-cpp)
    # withcatai/node-llama-cpp — Node.js bindings for llama.cpp.
    # Binary typically invoked via `npx --no node-llama-cpp <cmd>`.
    local -a _subcmds
    _subcmds=(
      'pull:download models from URLs'
      'chat:interactive conversation with a model'
      'init:scaffold a new project from a template'
      'complete:generate text completion'
      'infill:create infill completions between prefix and suffix'
      'inspect:examine system details (GPU/GGUF/perf)'
      'source:manage the underlying llama.cpp codebase'
    )
    _arguments -C -s -S \
      '(- *)-h[show help]' \
      '(- *)--help[show help]' \
      '(- *)-v[show version]' \
      '(- *)--version[show version]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'node-llama-cpp subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

  safe-cli)
    # safe-global/safe-cli — manage Safe smart-contract accounts.
    # First two positionals: SAFE_ADDRESS NODE_URL (or owner address +
    # NODE_URL with --get-safes-from-owner).
    local -a _unattended
    _unattended=(
      'send-ether:transfer ETH from Safe'
      'send-erc20:transfer ERC20 tokens'
      'send-erc721:transfer NFTs'
      'send-custom:execute custom transaction data'
      'tx-builder:execute transactions from exported JSON files'
      'version:display version information'
    )
    _arguments -C -s -S \
      '--history[enable transaction history]' \
      '--no-history[disable transaction history (default for security)]' \
      '--get-safes-from-owner[treat address as owner account]' \
      '--no-get-safes-from-owner[do not treat address as owner account]' \
      '--non-interactive[unattended execution]' \
      '--help[show help]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      '1:Safe address or owner address (checksum):' \
      '2:Ethereum node URL:' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'safe-cli unattended command' _unattended && ret=0
        ;;
    esac
    ;;

  safe-creator)
    # safe-global/safe-creator — deploy new Safe contracts.
    # Positionals: NODE_URL PRIVATE_KEY.
    _arguments -s -S \
      '--threshold=[required owner signatures (default: deployer only)]:N:' \
      '--owners=[list of owner addresses]:addresses:' \
      '--safe-contract=[custom Safe master-copy address]:address:' \
      '--proxy-factory=[custom proxy-factory address]:address:' \
      '--callback-handler=[custom fallback handler]:address:' \
      '--salt-nonce=[custom deployment nonce (deterministic addresses)]:nonce:' \
      '--without-events[deploy without events (gas saving)]' \
      '--generate-vanity-addresses[generate addresses without deploying]' \
      '--no-confirm[skip confirmation prompts]' \
      '(-v --version)-v[show version]' \
      '(-v --version)--version[show version]' \
      '--help[show help]' \
      '1:Ethereum node URL:' \
      '2:deployer private key:' \
      && ret=0
    ;;

esac

return ret
