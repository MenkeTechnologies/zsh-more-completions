#compdef falco-cli
# _falco-cli — Falco runtime security CLI alias (Falco Project, C++/Go); spf13/cobra wrappers for falco binary
# upstream: https://github.com/falcosecurity/falco

_falco-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml"' \
        '-c+[config file]:file:_files' \
        '--rules=+[rules file]:file:_files -g "*.yaml *.yml"' \
        '-r+[rules file]:file:_files -g "*.yaml *.yml"' \
        '--validate=+[validate file]:file:_files' \
        '-V+[validate file]:file:_files' \
        '--list-syscall-events[list syscall events]' \
        '--list-fields[list output fields]' \
        '-N[no field names in output]' \
        '--list-events[list events]' \
        '--list-plugins[list plugins]' \
        '--enable-source=+[enable source]:src:(syscall k8s_audit)' \
        '--disable-source=+[disable source]:src:(syscall k8s_audit)' \
        '-d[daemon]' \
        '--daemon[daemon]' \
        '--pidfile=+[pid file]:file:_files' \
        '-p+[printout format]:fmt:' \
        '-u[unbuffered output]' \
        '-A[all events including buggy ones]' \
        '-b[print events as base64]' \
        '-i[ignore unsupported events]' \
        '-k+[k8s api server]:url:_urls' \
        '-K+[k8s bearer token]:str:' \
        '-o+[output option]:opt:' \
        '-s+[stats file interval seconds]:n:' \
        '-T+[disable tag]:tag:' \
        '-t+[enable tag]:tag:' \
        '-v[verbose]' \
        '--all-events[all events]' \
        '--cri=+[cri socket]:sock:_files' \
        '--gvisor-config=+[gvisor config]:file:_files' \
        '--gvisor-generate-config[generate gvisor config]' \
        '--gvisor-root=+[gvisor root]:dir:_files -/' \
        '--modern-bpf[modern eBPF]' \
        '--cpus-for-each-syscall-buffer=+[cpus per syscall buffer]:n:' \
        '--dry-run[dry run]' \
        '*:arg:'
}

_falco-cli "$@"
