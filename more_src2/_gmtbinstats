#compdef gmtbinstats
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtbinstats.html
# Source: GenericMappingTools/gmt classic-mode gmtbinstats — bin (x,y,z) data and compute per-node statistic.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[per-node statistic (mean/median/range/stddev/count/sum/quantile...)]:stat:_default' \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-E+[empty-node value (default NaN)]:value:_default' \
    '-N[normalize by search-circle area]' \
    '-S+[search radius]:radius:_default' \
    '-T+[non-overlapping tiling]:tiling:(h r)' \
    '*-V[verbose (stackable)]' \
    '-W+[weighted data (+s for sigmas)]:opts:_default' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
