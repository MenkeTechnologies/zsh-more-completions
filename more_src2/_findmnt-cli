#compdef findmnt-cli
# _findmnt-cli — util-linux findmnt mount point search CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_findmnt-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A[disable all built-in filters]' \
        '--all[disable all built-in filters]' \
        '-a[print all]' \
        '--ascii[ascii output]' \
        '-b[bytes (sizes in bytes)]' \
        '--bytes[bytes (sizes in bytes)]' \
        '-C[no canonicalize]' \
        '--nocanonicalize[no canonicalize]' \
        '-c[canonicalize]' \
        '--canonicalize[canonicalize]' \
        '-D[df-like output]' \
        '--df[df-like output]' \
        '-d+[direction]:d:(forward backward)' \
        '--direction=+[direction]:d:(forward backward)' \
        '-e[evaluate /etc/mtab]' \
        '--evaluate[evaluate /etc/mtab]' \
        '-F+[fstab file]:file:_files -g "fstab"' \
        '--tab-file=+[fstab file]:file:_files -g "fstab"' \
        '-f[only first]' \
        '--first-only[only first]' \
        '-I+[invert tags]:str:' \
        '--invert=+[invert tags]:str:' \
        '-i[invert sense of filtering]' \
        '-J[json output]' \
        '--json[json output]' \
        '-k[use /proc/self/mountinfo]' \
        '--kernel[use /proc/self/mountinfo]' \
        '-l[list mode]' \
        '--list[list mode]' \
        '-M+[mountpoint]:_files -/' \
        '--mountpoint=+[mountpoint]:_files -/' \
        '-m[use /etc/mtab]' \
        '--mtab[use /etc/mtab]' \
        '-N+[namespace]:str:' \
        '--task=+[namespace]:str:' \
        '-n[no headings]' \
        '--noheadings[no headings]' \
        '-O+[options]:str:' \
        '--options=+[options]:str:' \
        '-o+[output cols]:str:' \
        '--output=+[output cols]:str:' \
        '--output-all[output all cols]' \
        '-P[pairs output]' \
        '--pairs[pairs output]' \
        '-p[poll]' \
        '--poll=+[events]:str:' \
        '-R[recursive]' \
        '--submounts[recursive]' \
        '-r[raw output]' \
        '--raw[raw output]' \
        '-S+[source]:str:' \
        '--source=+[source]:str:' \
        '-s[use fstab]' \
        '--fstab[use fstab]' \
        '-T+[target]:_files -/' \
        '--target=+[target]:_files -/' \
        '-t+[fstype]:str:' \
        '--types=+[fstype]:str:' \
        '-U[unique]' \
        '--uniq[unique]' \
        '-u[ignore unmounts]' \
        '--notruncate[no truncate]' \
        '-w+[timeout ms]:n:' \
        '--timeout=+[timeout ms]:n:' \
        '-x[verify mount table]' \
        '--verify[verify mount table]' \
        '-y[shell-friendly raw mode]' \
        '*:device or mountpoint:_files'
}

_findmnt-cli "$@"
