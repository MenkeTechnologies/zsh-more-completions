#compdef rotconverter
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/spotter/rotconverter.html
# Source: GenericMappingTools/gmt supplements/spotter — convert between rotation pole representations.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[interpret times as opening angles (deg) not Myr]' \
    '-D[use -180/+180 longitude range (default 0/360)]' \
    '-F+[output format]:fmt:(s t)' \
    '-G[output GPlates Plates4 format]' \
    '-M+[opening-angle scale (default 0.5)]:factor:_default' \
    '(-N -S -W)-N[force northern hemisphere poles]' \
    '(-N -S -W)-S[force southern hemisphere poles]' \
    '(-N -S -W)-W[force negative opening angles]' \
    '-T[negate rotation angles (transpose)]' \
    '*-V[verbose (stackable)]' \
    '-h+[header records]:n:_default' \
    '*:rotation file:_files' \
    && ret=0

return ret
