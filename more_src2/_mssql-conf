#compdef mssql-conf
# Documentation: https://learn.microsoft.com/en-us/sql/linux/sql-server-linux-configure-mssql-conf
# Reference accessed: 2026-05-27
# Verified: upstream Microsoft Learn page sql-server-linux-configure-mssql-conf
# (subcommands setup, set, unset, traceflag, set-collation, set-edition,
# setup-ad-keytab, validate-ad-config; --help global flag).

# mssql-conf: Microsoft SQL Server on Linux configuration tool.
local curcontext="$curcontext" state line ret=1
local -a _mssqlconf_subcommands
_mssqlconf_subcommands=(
  'setup:initial setup (edition, sa password, EULA)'
  'set:set a configuration setting (e.g. network.tcpport <value>)'
  'unset:remove a configuration setting (revert to default)'
  'traceflag:enable or disable SQL Server trace flags'
  'set-collation:change the SQL Server collation'
  'set-edition:change the SQL Server edition'
  'setup-ad-keytab:configure Active Directory authentication keytab'
  'validate-ad-config:validate Active Directory authentication configuration'
)

# Common SQL Server settings used as arguments to "set" / "unset".
local -a _mssqlconf_settings
_mssqlconf_settings=(
  'coredump.captureminiandfull:capture both mini and full core dumps'
  'coredump.coredumptype:core dump type'
  'coredump.disablecoredump:disable core dumps'
  'distributedtransaction.servertcpport:MSDTC server TCP port'
  'EULA.accepteula:accept SQL Server EULA'
  'EULA.accepteulaml:accept Machine Learning Services EULAs'
  'extensibility.outboundnetworkaccess:enable outbound network access for external languages'
  'filelocation.defaultbackupdir:default backup directory'
  'filelocation.defaultdatadir:default data directory'
  'filelocation.defaultdumpdir:default dump directory'
  'filelocation.defaultlogdir:default log directory'
  'filelocation.errorlogfile:error log file path'
  'filelocation.masterdatafile:master data file location'
  'filelocation.masterlogfile:master log file location'
  'filelocation.mastlogfile:master log file location'
  'hadr.hadrenabled:enable HADR / Always On'
  'language.lcid:locale (LCID)'
  'memory.memorylimitmb:memory limit in MB'
  'network.aadcertificatefilepath:Microsoft Entra ID certificate path'
  'network.forceencryption:force encryption on connections'
  'network.ipaddress:IP address SQL Server listens on'
  'network.kerberoskeytabfile:Kerberos keytab file'
  'network.rpcport:RPC port (MSDTC)'
  'network.tcpport:TCP port (default 1433)'
  'network.tlscert:TLS certificate path'
  'network.tlsciphers:allowed TLS ciphers'
  'network.tlskey:TLS private key path'
  'network.tlsprotocols:comma-separated list of allowed TLS protocols'
  'sqlagent.databasemailprofile:default Database Mail profile'
  'sqlagent.enabled:enable SQL Server Agent'
  'sqlagent.errorlogfile:SQL Agent error log file path'
  'sqlagent.errorlogginglevel:SQL Agent error logging level'
  'sqlconnector.logginglevel:Azure Key Vault connector logging level'
  'telemetry.customerfeedback:send customer feedback'
  'telemetry.userrequestedlocalauditdirectory:local audit directory'
  'uncmapping:map a UNC path to a local path'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'mssql-conf subcommand' _mssqlconf_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      set)
        if (( CURRENT == 2 )); then
          _describe -t settings 'mssql-conf setting' _mssqlconf_settings && ret=0
        else
          _message 'value' && ret=0
        fi
        ;;
      unset)
        _describe -t settings 'mssql-conf setting' _mssqlconf_settings && ret=0
        ;;
      traceflag)
        _arguments \
          '*: :_alternative
            "flags:trace flag number: "
            "states:state:(on off)"' && ret=0
        ;;
      setup)
        _values 'setup component' \
          'accept-eula-ml[accept the Machine Learning Services EULA]' && ret=0
        ;;
      set-collation|set-edition|setup-ad-keytab|validate-ad-config)
        _message 'arguments' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
