#compdef manim
# Documentation: https://docs.manim.community/en/stable/guides/configuration.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'render:render a scene'
      'cfg:manage configuration'
      'init:set up a new project'
      'new:create a new scene file'
      'plugins:manage plugins'
      'checkhealth:check if manim is installed correctly'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (render)
        _arguments \
          '(-p --preview)'{-p,--preview}'[preview the animation]' \
          '(-f --format)'{-f,--format}'=[output format]:format:(png gif mp4 webm mov)' \
          '(-r --resolution)'{-r,--resolution}'=[resolution (W,H)]:resolution:' \
          '--fps=[frames per second]:fps:' \
          '(-n --from_animation_number)'{-n,--from_animation_number}'=[start from animation number]:number:' \
          '(-s --save_last_frame)'{-s,--save_last_frame}'[save only the last frame]' \
          '(-q --quality)'{-q,--quality}'=[quality level]:quality:(l m h p k)' \
          '(-o --output_file)'{-o,--output_file}'=[output file name]:file:' \
          '--media_dir=[media output directory]:dir:_files -/' \
          '--log_dir=[log directory]:dir:_files -/' \
          '(-c --config_file)'{-c,--config_file}'=[config file]:file:_files' \
          '(-v --verbosity)'{-v,--verbosity}'=[verbosity level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
          '--seed=[random seed]:n:' \
          '-a[render all scenes in the file]' \
          '--write_all[render all scenes in the file]' \
          '--disable_caching[disable file caching]' \
          '--flush_cache[flush the cache]' \
          '(-t --transparent)'{-t,--transparent}'[render with transparent background]' \
          '1:scene file:_files -g "*.py"' \
          '2:scene name:' && ret=0
        ;;
      (cfg)
        _arguments \
          '1:action:(show write export)' \
          '--level=[config level]:level:(user cwd)' && ret=0
        ;;
      (init)
        _arguments '*:project directory:_files -/' && ret=0
        ;;
      (new)
        _arguments '1:scene file name:' && ret=0
        ;;
      (plugins)
        _arguments '1:action:(list install)' && ret=0
        ;;
    esac
    ;;
esac

return ret
