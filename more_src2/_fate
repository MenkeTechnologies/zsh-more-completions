_fate() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_fate_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--path=[output directory for config file]:dir:_files -/'
                    ;;
                name)
                    _arguments \
                        '(-l --last)'{-l+,--last=}'[Chinese surname character]:surname:' \
                        '(-b --born)'{-b+,--born=}'[birth date/time YYYY/MM/DD HH:MM]:datetime:' \
                        '(-p --path)'{-p+,--path=}'[input config path]:dir:_files -/' \
                        '(-o --outout)'{-o+,--outout=}'[output directory]:dir:_files -/' \
                        '(-s --sex)'{-s,--sex}'[sex flag (true = male, false = female)]'
                    ;;
            esac
            ;;
    esac

    return ret
}

_fate_cmds() {
    local -a cmds
    cmds=(
        'init:generate default configuration file'
        'name:generate names based on birth details'
        'check:verify environment correctness (timezone data etc.)'
        'version:show fate version'
    )
    _describe -t commands 'fate command' cmds
}

_fate "$@"
