#compdef dahdi_cfg
# dahdi_cfg — configure DAHDI telephony hardware

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-c,--config}'=[specify config file]:config file:_files' \
  {-s,--stop}'[stop/shutdown DAHDI]' \
  {-t,--test}'[test mode, do not apply changes]' \
  {-v,--verbose}'[verbose output]' \
  {-f,--force}'[force configuration]' \
  {-S,--span}'=[configure specific span number]:span number:' && ret=0

return ret
