#compdef radwho
# _radwho — FreeRADIUS radwho (show currently logged-in PPP / WLAN clients by reading sessions.dbm; -d data dir, -f session file, -F format string, -L lock file, -n NAS-Identifier filter, -s short output, -i interpret bytes as MB, -h help, -v version)
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radwho.c on tip.

_radwho() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-d+[data dir]:dir:_files -/' \
        '-f+[session file]:file:_files' \
        '-F+[format string]:format:' \
        '-L+[lock file]:file:_files' \
        '-n+[NAS-Identifier]:nas:' \
        '-s[short output]' \
        '-i[interpret bytes as MB]' \
        '-N[no header]' \
        '-S[show secrets]'
}

_radwho "$@"
