#compdef mount.davfs
# Documentation: https://manpages.debian.org/testing/davfs2/mount.davfs.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*-o[mount option]:opt:' \
  ':webdav server:' \
  ':mountpoint:_files -/'
