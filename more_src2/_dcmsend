#compdef dcmsend
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmsend.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmnet/apps/dcmsend.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmnet/apps/dcmsend.cc OFCommandLine setup + dcmnet/docs/dcmsend.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--list-decoders[list transfer syntaxes of decoders and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+v --verbose-pc)'{+v,--verbose-pc}'[show presentation contexts in verbose mode]' \
  '(+f --read-file +fo --read-file-only -f --read-dataset)'{+f,--read-file}'[read file format or data set]' \
  '(+f --read-file +fo --read-file-only -f --read-dataset)'{+fo,--read-file-only}'[read file format only (default)]' \
  '(+f --read-file +fo --read-file-only -f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(+rd --read-from-dicomdir)'{+rd,--read-from-dicomdir}'[read information on input files from DICOMDIR]' \
  '(+sd --scan-directories)'{+sd,--scan-directories}'[scan directories for input files]' \
  '(+sp --scan-pattern)'{+sp+,--scan-pattern=}'[pattern for filename matching (wildcards)]:pattern:' \
  '(-r --no-recurse +r --recurse)'{-r,--no-recurse}'[do not recurse within directories (default)]' \
  '(-r --no-recurse +r --recurse)'{+r,--recurse}'[recurse within specified directories]' \
  '(-dn --decompress-never +dls --decompress-lossless +dly --decompress-lossy)'{-dn,--decompress-never}'[never decompress compressed data sets]' \
  '(-dn --decompress-never +dls --decompress-lossless +dly --decompress-lossy)'{+dls,--decompress-lossless}'[only decompress lossless compression (default)]' \
  '(-dn --decompress-never +dls --decompress-lossless +dly --decompress-lossy)'{+dly,--decompress-lossy}'[decompress both lossy and lossless compression]' \
  '(+cl --compression-level)'{+cl+,--compression-level=}'[deflate compression level (0..9, default: 6)]:level:' \
  '(-nh --no-halt)'{-nh,--no-halt}'[do not halt on first invalid input file or unsuccessful store]' \
  '(-nip --no-illegal-proposal)'{-nip,--no-illegal-proposal}'[do not propose presentation contexts without default transfer syntax]' \
  '(-nuc --no-uid-checks)'{-nuc,--no-uid-checks}'[do not check UID values of input files]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i4,--ipv4}'[use IPv4 only (default)]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i6,--ipv6}'[use IPv6 only]' \
  '(-i4 --ipv4 -i6 --ipv6 -i0 --ip-auto)'{-i0,--ip-auto}'[use DNS lookup to determine IP protocol]' \
  '(-aet --aetitle)'{-aet+,--aetitle=}'[set my calling AE title (default: DCMSEND)]:aetitle:' \
  '(-aec --call)'{-aec+,--call=}'[set called AE title of peer (default: ANY-SCP)]:aetitle:' \
  '(+ma --multi-associations -ma --single-association)'{+ma,--multi-associations}'[use multiple associations if needed (default)]' \
  '(+ma --multi-associations -ma --single-association)'{-ma,--single-association}'[always use a single association]' \
  '(-to --timeout)'{-to+,--timeout=}'[timeout for connection requests]:seconds:' \
  '(-ta --acse-timeout)'{-ta+,--acse-timeout=}'[timeout for ACSE messages (default: 30)]:seconds:' \
  '(-td --dimse-timeout)'{-td+,--dimse-timeout=}'[timeout for DIMSE messages]:seconds:' \
  '(-pdu --max-pdu)'{-pdu+,--max-pdu=}'[set max receive PDU (4096..131072, default: 16384)]:bytes:' \
  '--max-send-pdu=[restrict max send PDU (4096..131072)]:bytes:' \
  '(+crf --create-report-file)'{+crf+,--create-report-file=}'[create detailed transfer report as text file]:file:_files' \
  ':peer:_hosts' \
  ':port:' \
  '*:dcmfile-in:_files'
