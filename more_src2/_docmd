#compdef docmd
# Documentation: https://github.com/docmd-io/docmd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Minimal Markdown documentation generator (@docmd/core).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'dev:start development server'
  'build:generate static HTML for production'
  'migrate:convert from Docusaurus/VitePress/MkDocs'
  'deploy:generate docker/nginx/caddy deploy configs'
  'add:install optional plugin'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    _describe -t commands 'docmd command' commands && ret=0
    ;;
esac

return ret
