#compdef reg_resample
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_resample.cpp — image resampler (C++; single-dash long opts).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '-voff[suppress verbose output]' \
    '(-omp --omp)'{-omp+,--omp=}'[OpenMP threads]:n:_default' \
    '(-ref -target)-ref+[reference (fixed) image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-flo -source)-flo+[floating (source) image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '(-res -result)-res+[output resampled file]:file:_files' \
    '-trans+[input transformation (or -aff/-def/-cpp aliases)]:file:_files' \
    '-aff+[input affine transformation (alias)]:file:_files' \
    '-def+[input deformation field (alias)]:file:_files' \
    '-cpp+[input control-point grid (alias)]:file:_files' \
    '(-inter)-inter+[interpolation order]:n:(0 1 3 4)' \
    '-NN[nearest-neighbour interpolation]' \
    '(-LIN -TRI)-LIN[linear/trilinear interpolation]' \
    '(-LIN -TRI)-TRI[trilinear interpolation (alias)]' \
    '(-CUB -SPL)-CUB[cubic/spline interpolation]' \
    '(-CUB -SPL)-SPL[cubic/spline interpolation (alias)]' \
    '-SINC[sinc interpolation]' \
    '-tensor[input is tensor]' \
    '-pad+[padding value (default 0)]:n:_default' \
    '-psf[partial-volume / PSF resampling]' \
    && ret=0

return ret
