#compdef langchain langchain-cli
# _langchain — LangChain AI langchain CLI for scaffolding LangChain template apps and serving chains with LangServe (langchain-ai team, Python); typer
# upstream: https://github.com/langchain-ai/langchain

_langchain() {
    local -a sub=(
        'app:application subcommands'
        'integration:integration subcommands'
        'migrate:migrate code between versions'
        'serve:serve chains with LangServe'
        'template:template subcommands'
        'create:create a new app or template'
        'init:init configuration'
        'docs:open documentation'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--install-completion=+[shell]:s:(bash zsh fish)' \
        '--show-completion=+[shell]:s:(bash zsh fish)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'langchain subcommand' sub ;;
        args)
            case $words[1] in
                app) _arguments '1:app cmd:(new add remove list serve)' ;;
                template) _arguments '1:template cmd:(new list)' ;;
                integration) _arguments '1:integration cmd:(new create-doc create)' ;;
                migrate) _arguments \
                    '--include-ipynb[include notebooks]' \
                    '--diff[print diff]' \
                    '--interactive[interactive]' \
                    '--disable=+[rules csv]:str:' \
                    '--exclude=+[paths csv]:str:' \
                    '*:path:_files' ;;
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--app-dir=+[app dir]:dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_langchain "$@"
