#compdef riot
# Documentation: https://jena.apache.org/documentation/io/index.html
# Source: apache/jena RIOT (RDF I/O Tool) — parse, serialize, validate RDF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--syntax=[explicitly set input syntax for all files]:syntax:(turtle nt nq trig rdf/xml json-ld n-triples n-quads rdfthrift)' \
    '--validate[checking mode (= --strict --sink --check=true)]' \
    '--check=[validate literals and IRIs]:value:(true false)' \
    '--strict[strict syntax checking]' \
    '--time[output timing info]' \
    '--sink[no output]' \
    '--output=[output format (streaming if possible)]:format:(turtle nt nq trig rdf/xml json-ld jsonld11 trix)' \
    '--formatted=[output format with pretty printing]:format:(turtle nt nq trig rdf/xml json-ld)' \
    '--stream=[output format streaming]:format:(turtle nt nq trig rdf/xml json-ld)' \
    '--base=[set base IRI]:iri:_urls' \
    '--rdfs=[apply RDFS inference (riotcmd.infer)]:file:_files' \
    '--count[count triples/quads]' \
    '*:rdf file:_files -g "*.(ttl|nt|nq|trig|rdf|xml|jsonld|json|trix)(-.)"' \
    && ret=0

return ret
