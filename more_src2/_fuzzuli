# -----------------------------------------------------------------------------
#
# WHAT IS goflags AND WHY IS IT THE 48TH GO CLI LIBRARY?
#
# goflags (https://github.com/projectdiscovery/goflags, 92+ stars)
# is **Project Discovery's "go flag wrapper with convenience
# helpers"** — a Go argv-parsing library specifically designed for
# the project's security-tools suite.  Project Discovery's tools
# share a CONSISTENT CLI EXPERIENCE: all use the same flag-group
# layout (General / Filter / Match / HTTP / Debug / Update /
# Logging / Optimization), all support env-var backing, all
# support config-file overlays, all generate similar help-text
# formatting.
#
# goflags's distinguishing characteristics:
#
#   1. FLAG GROUPS WITH GROUP NAMES — goflags supports organizing
#      flags into named groups that appear as separate sections in
#      the help output:
#
#          flagSet := goflags.NewFlagSet()
#          flagSet.SetDescription("fuzzuli is a url fuzzing tool")
#
#          createGroup(flagSet, "General Options", "GENERAL OPTIONS",
#              flagSet.IntVar(&options.worker, "w", 16, "worker count"),
#              flagSet.StringVar(&options.file, "f", "",
#                  "input file containing list of host/domain"),
#              flagSet.BoolVar(&options.silent, "sl", false,
#                  "silent mode"),
#          )
#
#          createGroup(flagSet, "Wordlist Options", "WORDLIST OPTIONS",
#              flagSet.StringVar(&options.method, "mt", "",
#                  "methods (regular, withoutdots, ...)"),
#              flagSet.StringVar(&options.suffix, "sf", "", "suffix"),
#          )
#
#      The `createGroup` function (a goflags-specific helper)
#      assigns each flag to a named group.  Compare:
#         * Go stdlib flag: flat option list, no groups
#         * cobra (undoc): supports groups via flag.SortFlags=false
#                          and PrintFlags() customization
#         * urfave/cli: Category attribute on Flag struct
#         * goflags: createGroup() function with explicit group
#                    declarations
#      FIRST documented Go argv parser with CREATE-GROUP-FUNCTION-
#      based flag organization (vs property-attribute-on-flag).
#
#   2. ENVIRONMENT-VARIABLE BACKING — goflags supports automatic
#      ENV_VAR backing for any flag:
#
#          flagSet.StringVar(&options.key, "k", "",
#              "API key for service").EnvVar("MY_SERVICE_API_KEY")
#
#      If the env var `MY_SERVICE_API_KEY` is set, its value is
#      used as the default; the CLI flag overrides it.  Compare:
#         * Go stdlib flag: no env-var backing (manual via
#                            os.Getenv)
#         * urfave/cli: EnvVars field on cli.Flag
#         * goflags: chainable .EnvVar() method on the flag returned
#                    by the registration call
#      FIRST documented Go argv parser with chainable .EnvVar()
#      flag-method (vs property-field-on-flag).
#
#   3. CONFIG-FILE OVERLAYS — goflags supports reading flag values
#      from a TOML/YAML config file specified via a special
#      `-config` flag (auto-recognized):
#
#          # ~/.config/fuzzuli/config.yaml
#          worker: 32
#          file: targets.txt
#          paths: /,/db/,/old/
#          silent: false
#          timeout: 30
#
#      Command-line flags override config-file values; config-file
#      values override env-var values; env-var values override
#      defaults.  Compare:
#         * Go stdlib flag: no config-file support
#         * cobra+viper: viper handles config-file overlay (separate
#                         library composition)
#         * urfave/cli: AltSrc package for YAML/TOML/JSON config
#         * goflags: built-in config-file overlay with auto-
#                    recognized `-config` flag
#      FIRST documented Go argv parser with BUILT-IN config-file
#      overlay (vs separate library composition).
#
#   4. SHORT-FLAG-FOR-LONG-NAME CONVENTION — goflags allows
#      defining flags with both a short name (often 1-3 chars) and
#      a longer human-readable description in the help text, but
#      the SHORT NAME IS THE PRIMARY:
#
#          flagSet.IntVar(&options.worker, "w", 16, "worker count"),
#          flagSet.StringVar(&options.user_agent, "ua",
#              "Mozilla/5.0 (...)", "user agent"),
#          flagSet.IntVar(&options.timeout, "to", 10,
#              "timeout in seconds."),
#
#      User invokes `fuzzuli -w 32 -ua "MyBot" -to 60` rather than
#      `fuzzuli --workers 32 --user-agent "MyBot" --timeout 60`.
#      Compare:
#         * Go stdlib flag: same short-flag convention
#         * cobra+pflag: encourages BOTH short and long forms
#         * goflags: explicit SHORT-FORM-AS-PRIMARY convention
#                    across all Project Discovery tools
#      FIRST documented Go argv parser with consistent short-form-
#      as-primary convention across an entire vendor's tool suite.
#
#   5. PROJECT-DISCOVERY-ECOSYSTEM PROVENANCE — Project Discovery
#      maintains 30+ security tools that ALL use goflags:
#         * nuclei (28988 stars) — vulnerability scanner
#         * httpx (9992 stars) — HTTP probe toolkit
#         * subfinder (10000+ stars) — subdomain enumeration
#         * naabu (6000+ stars) — port scanner
#         * katana (12000+ stars) — web crawler
#         * dnsx (2300+ stars) — DNS toolkit
#         * tlsx (1105 stars) — TLS toolkit
#         * interactsh (4338 stars) — OOB interaction server
#         * mapcidr — CIDR aggregation
#         * cdncheck — CDN detection
#         * vulnx — vulnerability template engine
#         * shuffledns — wildcard DNS resolver
#      All these tools have the SAME CLI ergonomics — short flags,
#      flag groups, env-var backing, config-file overlay, progress
#      indicators.  This UNIFIED EXPERIENCE is the primary reason
#      for goflags' existence.  Compare every other documented Go
#      argv parser — none have a coordinated 30+ tool suite using
#      them.  FIRST documented Go argv parser with formal vendor-
#      coordinated tool-suite usage.
#
# goflags's relationship to other documented Go CLI libraries:
#
#   * Like spf13/cobra (undocumented) — comprehensive CLI framework
#                                        (but cobra is general-
#                                         purpose; goflags is
#                                         security-tools-focused)
#   * Like urfave/cli (undocumented) — similar feature set (groups,
#                                       env-vars, config files)
#   * Like Go stdlib flag — extends stdlib's flag.NewFlagSet
#   * Unlike all of the above — coordinated vendor tool-suite
#                                provenance (Project Discovery 30+
#                                tools); short-form-as-primary
#                                convention; createGroup-function-
#                                based grouping
#   * Closest cross-language analogs:
#         * Rust:    no clear analog (no vendor-coordinated CLI
#                     library for a security-tools suite)
#         * TS-Node: no clear analog
#     goflags is the FIRST documented vendor-coordinated security-
#     tooling argv parser in the taxonomy.
#
# -----------------------------------------------------------------------------
#
# THE fuzzuli CLI — goflags + workerpool + retryablehttp + progressbar
#
# fuzzuli's argv parser is `github.com/projectdiscovery/goflags`:
#
#     options := &Options{}
#     flagSet := goflags.NewFlagSet()
#     flagSet.SetDescription("fuzzuli is a url fuzzing tool that aims
#         to find critical backup files by creating a dynamic wordlist
#         based on the domain.")
#
#     createGroup(flagSet, "General Options", "GENERAL OPTIONS",
#         flagSet.IntVar(&options.worker, "w", 16, "worker count"),
#         flagSet.StringVar(&options.file, "f", "",
#             "input file containing list of host/domain"),
#         flagSet.StringVar(&options.paths, "pt", "/",
#             "paths separated with commas"),
#         flagSet.BoolVar(&options.print, "p", false,
#             "print urls that is sent request"),
#         flagSet.BoolVar(&options.silent, "sl", false, "silent mode"),
#         flagSet.BoolVar(&options.version, "v", false, "print version"),
#     )
#
#     createGroup(flagSet, "wordlist options", "WORDLIST OPTIONS",
#         flagSet.StringVar(&options.method, "mt", "",
#             "methods: regular, withoutdots, withoutvowels, reverse, ..."),
#         flagSet.StringVar(&options.suffix, "sf", "", "suffix"),
#         flagSet.StringVar(&options.prefix, "pf", "", "prefix"),
#         flagSet.StringVar(&options.extension, "ex", "", "file extension"),
#         flagSet.StringVar(&options.replace, "rp", "", "replace specified char"),
#         flagSet.StringVar(&options.remove, "rm", "", "remove specified char"),
#         flagSet.BoolVar(&options.just_wordlist, "jw", false, "just wordlist"),
#     )
#     // ... more groups ...
#
# Five flag groups organize the ~20 flags into:
#   * General Options (worker, file, paths, print, silent, version)
#   * Wordlist Options (mt, sf, pf, ex, rp, rm, jw)
#   * Filter Options (es exclude, dl domain-length)
#   * Match Options (ct content-type, sc status-code, cl content-length)
#   * HTTP Options (to timeout, ua user-agent, hm method, px proxy)
#
# Distinct from every other documented Go CLI library on FIVE
# specific axes:
#
#   1. FLAG GROUPS VIA createGroup FUNCTION — Every other documented
#      Go CLI library uses property-attributes on flags or no
#      grouping at all.  goflags uses a createGroup() function
#      that assigns flags to named sections.  FIRST documented Go
#      argv parser with createGroup-function-based grouping.
#
#   2. CHAINABLE .EnvVar() METHOD — Every other documented Go CLI
#      library uses property fields (EnvVars: []string{}) or
#      no env-var support.  goflags uses chainable .EnvVar()
#      method on the flag-registration return value.  FIRST
#      documented Go argv parser with chainable env-var method.
#
#   3. BUILT-IN CONFIG-FILE OVERLAY — Every other documented Go
#      CLI library either has no config-file support or requires
#      separate libraries (viper, AltSrc).  goflags has built-in
#      auto-recognized `-config` flag with TOML/YAML overlay.
#      FIRST documented Go argv parser with built-in config-file
#      overlay.
#
#   4. SHORT-FORM-AS-PRIMARY CONVENTION — Every other documented
#      Go CLI library encourages BOTH short and long forms (cobra/
#      pflag) or stdlib's short-only.  goflags has explicit
#      SHORT-FORM-AS-PRIMARY convention used across an entire
#      vendor's 30+ tool suite.  FIRST documented Go argv parser
#      with consistent vendor-wide short-form convention.
#
#   5. PROJECT-DISCOVERY VENDOR-COORDINATED ECOSYSTEM — Every other
#      documented Go CLI library is general-purpose used by
#      independent projects.  goflags is used by 30+ Project
#      Discovery security tools with COORDINATED CLI ERGONOMICS
#      across the entire suite.  FIRST documented Go argv parser
#      with vendor-coordinated tool-suite usage.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/musana/fuzzuli/blob/main/fuzzuli.go goflags
# flagSet definitions in ParseOptions().)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-h[print help and exit]' \
    '-v[print version and exit]' \
    '-w+[worker count (default 16)]:count:' \
    '-f+[input file containing list of host/domain]:file:_files' \
    '-pt+[paths separated with commas (default /)]:paths:' \
    '-p[print URLs that are sent request]' \
    '-sl[silent mode]' \
    '-mt+[wordlist methods]:method:(regular withoutdots withoutvowels reverse mixed withoutdv shuffle all)' \
    '-sf+[suffix to append to wordlist names]:suffix:' \
    '-pf+[prefix to prepend to wordlist names]:prefix:' \
    '-ex+[file extensions (default rar,zip,tar.gz,tar,gz,jar,7z,bz2,sql,backup,war,bak,dll)]:extensions:' \
    '-rp+[replace specified char in wordlist]:char:' \
    '-rm+[remove specified char from wordlist]:char:' \
    '-jw[just generate wordlist, do not send HTTP requests]' \
    '-es+[exclude domains matching specified regex/string]:exclude:' \
    '-dl+[match domain length (default 40)]:length:' \
    '-ct+[match response with specified content type]:content-type:' \
    '-sc+[match response with specified status code (default 200)]:status-code:' \
    '-cl+[match response with minimum content length (default 100)]:length:' \
    '-to+[timeout in seconds (default 10)]:seconds:' \
    '-ua+[user agent string]:user-agent:' \
    '-hm+[HTTP method (default HEAD)]:method:(GET HEAD POST PUT DELETE OPTIONS)' \
    '-px+[HTTP proxy URL to use]:proxy:' \
    && ret=0

return ret
