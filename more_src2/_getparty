#compdef getparty
# Documentation: https://github.com/vbauerster/getparty
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# vbauerster/getparty - HTTP multipart downloader (go-flags struct tags in getparty.go).

local ret=1
_arguments -s -S \
  '(-p --parts)'{-p+,--parts=}'[number of parts]:n:' \
  '(-r --max-retry)'{-r+,--max-retry=}'[max retries per part (0=infinite)]:n:' \
  '--max-redirect=[max HTTP redirects (0=infinite)]:n:' \
  '(-t --timeout)'{-t+,--timeout=}'[initial buffer timeout (seconds)]:sec:' \
  '(-b --buf-size)'{-b+,--buf-size=}'[buffer KiB]:kb:(2 4 8 16)' \
  '(-l --speed-limit)'{-l+,--speed-limit=}'[speed limit level (1-5)]:lvl:(1 2 3 4 5)' \
  '(-s --session)'{-s+,--session=}'[auto-saved session JSON file]:session:_files' \
  '(-U --user-agent)'{-U+,--user-agent=}'[User-Agent preset]:ua:(chrome firefox safari edge)' \
  '--username=[HTTP basic auth user]:user:' \
  '--password=[HTTP basic auth password]:password:' \
  '*'{-H+,--header=}'[extra header key:value]:header:' \
  '(-x --proxy)'{-x+,--proxy=}'[HTTP/HTTPS proxy URL]:proxy:' \
  '(-q --quiet)'{-q,--quiet}'[quiet: no progress UI]' \
  '(-d --debug)'{-d,--debug}'[debug to stderr]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-c --certs-file)'{-c+,--certs-file=}'[custom root CA bundle]:certs:_files' \
  '--no-check-cert[skip TLS verification]' \
  '(-o --output.name)'{-o+,--output.name=}'[output filename]:file:_files' \
  '(-f --output.overwrite)'{-f,--output.overwrite}'[overwrite output silently]' \
  '--output.use-path[derive filename from URL path first]' \
  '(-m --mirror.list)'{-m+,--mirror.list=}'[mirror list file or -]:mirrors:_files' \
  '(-g --mirror.max)'{-g+,--mirror.max=}'[max concurrent mirror probes]:n:' \
  '--mirror.top=[keep top N mirrors]:n:' \
  '--mirror.pass=[mirror timing passes]:n:' \
  '1:URL:_urls' && ret=0
return ret
