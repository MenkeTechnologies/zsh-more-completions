#compdef lcdtest
# Documentation: https://www.freshports.org/graphics/lcdtest/
# Reference accessed: 2026-05-19
# Verified: brouhaha.com lcdtest (LCD monitor test pattern generator, SDL).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show key list]' \
  '--list-modes[list available video resolutions]' \
  '--window[display in window rather than full screen]' \
  '-x+[horizontal resolution]:x:' \
  '-y+[vertical resolution]:y:' && ret=0

return ret
