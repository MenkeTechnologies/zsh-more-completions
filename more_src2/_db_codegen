#compdef db_codegen
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/db_codegen.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Berkeley DB db_codegen: generate application code

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-V[write library version number and exit]' \
  '-v[run in verbose mode]' \
  '-a+[target API (only "c" supported)]:api:(c)' \
  '-i+[input description file (default stdin)]:file:_files' \
  '-o+[output filename prefix (default "application")]:prefix:' && ret=0

return ret
