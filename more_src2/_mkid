#compdef mkid
# Documentation: man mkid(1)
# Source: GNU idutils mkid (man) — build an identifier database (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --output -f --file)'{-o+,--output=}'[output ID database file]:file:_files' \
    '(-o --output -f --file)'{-f+,--file=}'[output ID database file (synonym)]:file:_files' \
    '(-i --include -x --exclude)'{-i+,--include=}'[include languages]:langs:_default' \
    '(-i --include -x --exclude)'{-x+,--exclude=}'[exclude languages]:langs:_default' \
    '*'{-l+,--lang-option=}'[language-specific option L:OPT]:L\:OPT:_default' \
    '(-m --lang-map)'{-m+,--lang-map=}'[language map file]:mapfile:_files' \
    '(-d --default-lang)'{-d+,--default-lang=}'[default source language]:lang:(C C++ asm Java text perl)' \
    '*'{-p+,--prune=}'[exclude named files/directories]:names:_default' \
    '(-v --verbose)'{-v,--verbose}'[per-file statistics]' \
    '(-s --statistics)'{-s,--statistics}'[end-of-run statistics]' \
    '--files0-from=[NUL-terminated names file]:file:_files' \
    '--help[show help]' \
    '--version[show version]' \
    '*:file or directory:_files' \
    && ret=0

return ret
