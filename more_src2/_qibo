#compdef qibo qibojit qibocal qibolab
# _qibo — Quantum Research Center Qibo full-stack quantum computing framework with backends and characterization tools (qiboteam team, Python); argparse
# upstream: https://github.com/qiboteam/qibo

_qibo() {
    local -a sub=(
        'simulate:run a quantum simulation'
        'circuit:circuit subcommands'
        'execute:execute circuit on backend'
        'calibrate:run device calibration'
        'compile:compile pulse schedule'
        'backend:backend subcommands'
        'visualize:render circuit'
        'parameters:parameters subcommands'
        'characterization:run device characterization'
        'optimization:run optimization'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--backend=+[backend]:b:(numpy tensorflow pytorch qibojit qiboml qibolab clifford qulacs jax cupy cuquantum cuda)' \
        '-b+[backend]:b:(numpy tensorflow pytorch qibojit qiboml qibolab clifford)' \
        '--platform=+[platform]:str:' \
        '-p+[platform]:str:' \
        '--precision=+[precision]:p:(single double)' \
        '--device=+[device]:d:(cpu gpu auto)' \
        '--threads=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--noise-model=+[noise model]:str:' \
        '--initial-state=+[file]:file:_files' \
        '--no-progress-bar[no progress bar]' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qibo subcommand' sub ;;
        args)
            case $words[1] in
                circuit) _arguments '1:circuit cmd:(load draw print qasm to-qiskit copy compile)' ;;
                backend) _arguments '1:backend cmd:(list set show)' ;;
                calibrate|characterization) _arguments \
                    '--routine=+[routine]:str:' \
                    '--qubits=+[qubits csv]:str:' \
                    '--platform=+[platform]:str:' \
                    '*:config:_files -g "*.yml *.yaml *.json"' ;;
                execute) _arguments \
                    '--platform=+[platform]:str:' \
                    '*:circuit:_files -g "*.qasm *.json *.py"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_qibo "$@"
