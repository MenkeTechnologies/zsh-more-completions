#compdef jxlinfo
# Documentation: jxlinfo --help (libjxl)
# Source: print JPEG XL image structural information.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help,-\?}'[show help]' \
    '(-v --verbose)'{-v,--verbose}'[more verbose output]' \
    '*:jxl file:_files -g "*.jxl"' \
    && ret=0

return ret
