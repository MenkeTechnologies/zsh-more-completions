#compdef gsar
# Documentation: https://github.com/abronte/gsar
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gsar - General Search And Replace (Tjaberg / Verne).
# Flags use the BSD-style -X<value> packing pattern, so they are not amenable
# to (-s -r) grouping; each flag is listed independently.
local curcontext="$curcontext" ret=1

_arguments -s \
  '-s+[search string (supports :hex / :ctrl notation)]:pattern:' \
  '-r+[replacement string (omit value to delete matches)]:replacement:' \
  '-i[case-insensitive match]' \
  '-B[show search/replace buffers for testing]' \
  '-f[force overwrite of existing output file]' \
  '-o[overwrite input files in place (multi-file mode)]' \
  '-c+[show context bytes around matches in text]:bytes:' \
  '-x+[show context bytes around matches as hex dump]:bytes:' \
  '-b[display byte offset of matches in hex]' \
  '-l[list filenames and match counts only (default)]' \
  '-h[suppress filename when showing context or offsets]' \
  '-du[convert DOS ASCII files to UNIX format]' \
  '-ud[convert UNIX ASCII files to DOS format]' \
  '-F[filter mode: read stdin, write stdout]' \
  '-G[display GNU GPL]' \
  '*:file:_files' && ret=0

return ret
