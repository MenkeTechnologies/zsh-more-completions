#compdef nezha-agent
# Documentation: https://github.com/nezhahq/agent
# Source: nezhahq/agent cmd/agent/main.go — Nezha monitoring Go agent (urfave/cli).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _nezha_cmds
_nezha_cmds=(
    'edit:edit configuration'
    'service:service operation (install/uninstall/start/stop/restart)'
)

_arguments -C \
    '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'nezha-agent command' _nezha_cmds && ret=0
        ;;
    args)
        case $line[1] in
            edit)
                _arguments \
                    '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
                    && ret=0
                ;;
            service)
                _arguments \
                    '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
                    '1:action:(install uninstall start stop restart)' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
