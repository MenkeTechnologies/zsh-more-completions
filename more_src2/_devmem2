#compdef devmem2 devmem
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/devmem2.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# devmem2 address [type [data]]  -- type is b (byte), h (halfword), w (word)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:address (hex):' \
  '2:type:(b h w)' \
  '3:data:' && ret=0

return ret
