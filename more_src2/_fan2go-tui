#compdef fan2go-tui
# _fan2go-tui — terminal UI for fan2go (markusressel/fan2go-tui)
# upstream: https://github.com/markusressel/fan2go-tui
# Flags from cmd/root.go (cobra).

_fan2go-tui() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(yml|yaml)"' \
        '--no-color[disable terminal color]' \
        '--no-style[disable terminal styling]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '1:subcommand:(version)'
}

_fan2go-tui "$@"
