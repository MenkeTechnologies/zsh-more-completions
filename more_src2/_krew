#compdef krew
# Documentation: https://krew.sigs.k8s.io/docs/user-guide/
# Reference accessed: 2026-05-19
# Verified: upstream docs + kubernetes-sigs/krew cmd source.
# Removed invented `install --no-upgrade`; real install flags are
# --manifest/--manifest-url/--archive/--no-update-index/
# --enable-netrc/--netrc-file.

# Zsh completion for krew (kubectl plugin manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'help:help about any command'
  'index:manage custom plugin indexes'
  'info:show information about a kubectl plugin'
  'install:install kubectl plugins'
  'list:list installed kubectl plugins'
  'search:discover kubectl plugins'
  'uninstall:uninstall kubectl plugins'
  'update:update the local copy of the plugin index'
  'upgrade:upgrade installed plugins to newer versions'
  'version:show krew version'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v)'-v'[verbosity level]:level:' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'krew command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (install)
        _arguments \
          '--manifest=[(dev-only) specify local plugin manifest file]:file:_files' \
          '--manifest-url=[(dev-only) plugin manifest file from URL]:url:' \
          '--archive=[(dev-only) force all downloads to use the specified file]:file:_files' \
          '--no-update-index[(experimental) do not update local plugin index before installing]' \
          '--enable-netrc[read .netrc file for login credentials]' \
          '--netrc-file=[path to .netrc file for authentication]:file:_files' \
          '*:plugin:' && ret=0
        ;;
      (uninstall)
        local -a installed
        installed=(${(f)"$(kubectl krew list 2>/dev/null | awk '{print $1}')"})
        _describe -t plugins 'installed plugin' installed && ret=0
        ;;
      (search)
        _arguments '1:query:' && ret=0
        ;;
      (info)
        _arguments '1:plugin:' && ret=0
        ;;
      (upgrade)
        _arguments \
          '--no-update-index[(experimental) do not update local plugin index before upgrading]' \
          '--enable-netrc[read .netrc file for login credentials]' \
          '--netrc-file=[path to .netrc file for authentication]:file:_files' \
          '*:plugin:' && ret=0
        ;;
      (index)
        local -a index_cmds=('add:add a custom index' 'delete:delete a custom index' 'list:list configured indexes')
        _arguments '1:index command:((${(j: :)${index_cmds// /\\:}}))' '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
