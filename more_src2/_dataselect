#compdef dataselect
# Documentation: https://github.com/EarthScope/dataselect
# Source: EarthScope/dataselect src/dataselect.c — extract and sort subsets of miniSEED seismic data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '(- *)-h[show help]' \
    '-H[show extended help (-A format details)]' \
    '*-v[verbose (stackable)]' \
    '-tt+[time tolerance for continuous traces]:secs:_default' \
    '-rt+[sample rate tolerance for continuous traces]:diff:_default' \
    '-snd[skip non-miniSEED content]' \
    '-E[treat all versions/qualities as equal]' \
    '-F[use input file ordering for priority]' \
    '-s+[load selection criteria from file]:file:_files' \
    '-ts+[retain records starting on/after time]:time:_default' \
    '-te+[retain records ending before time]:time:_default' \
    '-m+[match FDSN source pattern]:pattern:_default' \
    '-o+[output file (overwrite)]:file:_files' \
    '+o+[output file (append)]:file:_files' \
    '-A+[custom output archive format]:format:_default' \
    '-Pr[remove redundant data at record granularity]' \
    '-Ps[remove redundant data at sample granularity]' \
    '-Pe[trim only specified edges]' \
    '-Q+[set publication version]:flag:(D R Q M \#)' \
    '-out+[write output record summary to file]:file:_files' \
    '-outprefix+[prefix for summary lines]:prefix:_default' \
    '-CHAN+[Net.Sta.Loc.Chan archive dir]:dir:_directories' \
    '-VCHAN+[Net.Sta.Loc.Chan.PubVersion archive dir]:dir:_directories' \
    '-QCHAN+[Net.Sta.Loc.Chan.Quality archive dir]:dir:_directories' \
    '-CDAY+[Net.Sta.Loc.Chan.Year:Yday archive dir]:dir:_directories' \
    '-SDAY+[Net.Sta.Year:Yday archive dir]:dir:_directories' \
    '-BUD+[BUD archive directory]:dir:_directories' \
    '-SDS+[SDS archive directory]:dir:_directories' \
    '-CSS+[CSS-like archive directory]:dir:_directories' \
    '*:miniseed file:_files' \
    && ret=0

return ret
