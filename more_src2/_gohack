#compdef gohack
# _gohack — gohack make Go module deps writable in-place (Roger Peppe); replaces module with editable checkout
# upstream: https://github.com/rogpeppe/gohack

_gohack() {
    local -a sub=(
        'get:make modules writable'
        'undo:revert gohack changes'
        'status:show what is hacked'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gohack subcommand' sub ;;
        args)
            case $words[1] in
                get) _arguments \
                    '-vcs[clone via VCS]' \
                    '-u[update existing hack]' \
                    '*:module:' ;;
                undo) _arguments '*:module:' ;;
            esac
            ;;
    esac
}

_gohack "$@"
