#compdef rauc-hawkbit-updater
# Documentation: source-direct extraction from upstream
# rauc/rauc-hawkbit-updater src/rauc-hawkbit-updater.c lines
# 29-39 (the `static GOptionEntry entries[]` array).
# Reference accessed: 2026-05-30 via gh api.
#
# rauc-hawkbit-updater is the Pengutronix HawkBit (Eclipse
# hawkBit fleet-update server) client for R212's RAUC.  Runs as
# a long-lived daemon that polls a HawkBit server for new
# deployments, downloads RAUC `.raucb` bundles, and drives the
# RAUC D-Bus service to install them.  Companion to R212's
# `rauc service` mode.  Configured via /etc/rauc-hawkbit-
# updater/config.conf which holds the HawkBit URL + tenant +
# device ID + auth token + polling interval.

# Critical extraction note: rauc-hawkbit-updater uses GLib
# GOptionEntry (like R212 rauc).  All 5 flags have BOTH short
# and long forms.  --output-systemd is conditionally compiled
# behind WITH_SYSTEMD; listed unconditionally since installed
# binary build flags are opaque (most distros build with
# systemd integration).

_arguments -s -S \
  '(-c --config-file)'{-c+,--config-file=}'[configuration file path (default /etc/rauc-hawkbit-updater/config.conf)]:file:_files -g "*.conf"' \
  '(-v --version)'{-v,--version}'[print version information and exit]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-r --run-once)'{-r,--run-once}'[check for, install new software, and exit (one-shot mode)]' \
  '(-s --output-systemd)'{-s,--output-systemd}'[(WITH_SYSTEMD) enable structured journald output]' \
  '(-h --help)'{-h,--help}'[show help and exit]'
