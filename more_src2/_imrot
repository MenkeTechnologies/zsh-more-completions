#compdef imrot imresize imsmooth imstack imsize imstar getfits newfits skycoor
# Documentation: source-direct extraction from upstream
# olebole/wcstools (Jessica Mink WCSTools 3.9.7 series).  Each
# binary uses the same `for (av++; --ac > 0 && (*(str = *av)
# =='-' || *str == '@' || *str == '+'); av++)` argv-walking
# loop + per-binary case-arm switch documented in R180's
# HARVEST_LOG entry.  Per-binary case-arm counts:
#   imrot.c    -> 14 short flags
#   imresize.c -> 12 short flags
#   imsmooth.c ->  7 short flags
#   imstack.c  ->  6 short flags
#   imsize.c   -> 13 short flags
#   imstar.c   -> 26 short flags (incl. -q nested SAOimage sub-arm)
#   getfits.c  ->  8 short flags
#   newfits.c  -> 15 short flags
#   skycoor.c  -> 23 short flags
# Reference accessed: 2026-05-30 via gh api.
# olebole wcstools R181 — follow-up to R180's hunt-skip on "the
# remaining 8+ WCSTools binaries deserve a future round".  This
# round covers the image-manipulation set (imrot/imresize/
# imsmooth/imstack/imsize/imstar) + the FITS-extraction pair
# (getfits/newfits) + the standalone sky-coordinate calculator
# (skycoor).  9 binaries, completes the most-used WCSTools
# binaries in the corpus (alongside R180's imhead/delhead/
# gethead/sethead/sky2xy/xy2sky).

case $service in

  imrot)
    # FITS image rotation + reflection + extension splitter.
    _arguments -s -S \
      '-a[mirror if IRAF image WCS says to]' \
      '-e[delete FITS WCS keywords in image]' \
      '-f[write FITS image from IRAF input]' \
      '-i[do not append primary header to extension header]' \
      '-l[reflect image across horizontal axis]' \
      '-m[reflect image across vertical axis]' \
      '-n[use extension number instead of EXTNAME for output filename]' \
      '-o[allow overwriting input image (else write new)]' \
      '-p[make positive from negative image]' \
      '-r+[image rotation angle in degrees (default 0)]:deg:' \
      '-s+[split n-extension FITS file]:n:' \
      '-v[verbose]' \
      '-w[rotate FITS WCS keywords in image]' \
      '-x+[output pixel size in bits (FITS code, default=input)]:bits:' \
      '*:FITS file [xshift yshift]:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  imresize)
    # Image down-sampling via mean/median/Gaussian filters.
    _arguments -s -S \
      '-a+[mean (average) filter NxN]:dx[,dy]:' \
      '-b+[number of output bits per pixel]:bits:' \
      '-f+[horizontal+vertical reduction factor]:factor:' \
      '-g+[Gaussian filter NxN]:dx[,dy]:' \
      '-h+[Gaussian filter half-width at half-height]:hwhm:' \
      '-l+[number of lines to log]:n:' \
      '-m+[median filter NxN]:dx[,dy]:' \
      '-n[rotate to North Up East Left]' \
      '-o[allow overwriting input image]' \
      '-v[verbose]' \
      '-x+[horizontal reduction factor]:factor:' \
      '-y+[vertical reduction factor]:factor:' \
      '*:FITS file:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  imsmooth)
    # Image smoothing via mean/median/Gaussian filters (in-place).
    _arguments -s -S \
      '-a+[mean (average) filter NxN]:dx:dy:' \
      '-g+[Gaussian filter NxN]:dx:dy:' \
      '-h+[Gaussian filter half-width at half-height]:hwhm:' \
      '-l+[number of lines to log]:n:' \
      '-m+[median filter NxN]:dx:dy:' \
      '-o[allow overwriting input image]' \
      '-v[verbose]' \
      '*:FITS file:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  imstack)
    # Stack multiple FITS images into one IRAF multispec file.
    _arguments -s -S \
      '-i[do not put FITS header in output file]' \
      '-m[write IRAF multispec file]' \
      '-n+[use each input file this many times]:n:' \
      '-o+[output filename]:file:_files' \
      '-v[verbose]' \
      '-x+[set FITS extension EXTNAME root]:name:' \
      '*:FITS files to stack:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  imsize)
    # Print FITS image size + WCS sky bounds.
    _arguments -s -S \
      '-b[output B1950 (B1950) coordinates (optional center)]' \
      '-c[format output without pixel dimensions]' \
      '-d[output center in degrees]' \
      '-e[add epoch of image to output line]' \
      '-j[output J2000 (J2000) coordinates (optional center)]' \
      '-n+[number of decimal places in output (default 3)]:n:' \
      '-p+[initial plate scale in arcsec/pixel (default 0)]:scale:' \
      '-r[print range in RA and Dec]' \
      '-s[format output as input to DSS getimage]' \
      '-v[verbose]' \
      '-x+[FITS extensions to read]:ext:' \
      '-y[add FITS date of image to output line]' \
      '-z[use AIPS classic projections instead of WCSLIB]' \
      '*:FITS or IRAF file:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  imstar)
    # Star-finder + photometry CLI.
    _arguments -s -S \
      '-a+[initial rotation angle (degrees, default 0)]:deg:' \
      '-b[output B1950 (FK4) coordinates]' \
      '-c[output total flux in counts instead of magnitudes]' \
      '-d+[read DAOFIND output catalog instead of search]:file:_files' \
      '-e+[pixels to ignore around image edge]:n:' \
      '-f[output simple ASCII catalog format]' \
      '-g[do not rotate image WCS with image]' \
      '-h[print heading]' \
      '-i+[minimum peak value for star (<0 = -sigma)]:val:' \
      '-j[output J2000 (FK5) coordinates]' \
      '-k[print each star as found (debugging)]' \
      '-l[reflect left<->right before rotating and searching]' \
      '-m+[magnitude offset]:offset:' \
      '-n+[number of brightest stars to print]:n:' \
      '-o[output DAOFIND format star list]' \
      '-p+[plate scale in arcsec/pixel]:scale:' \
      '-q+[SAOimage region shape (c=circle, d=diamond, s=square, x=cross, v=variable, o=oval)]:shape:(c d s x v o)' \
      '-r+[max acceptable radius for a star]:n:' \
      '-t[output tab table]' \
      '-v[verbose]' \
      '*:FITS file:_files -g "*.(fits|fit|fts|imh|FIT)"'
    ;;

  getfits)
    # Extract a sub-image from a FITS file by sky or pixel coords.
    _arguments -s -S \
      '-c+[center coordinates for extraction (ra dec)]:ra:dec:' \
      '-d+[output directory]:dir:_files -/' \
      '-i+[logging interval]:n:' \
      '-k+[file of keywords to delete]:file:_files' \
      '-o+[output filename]:file:_files' \
      '-s[write output to standard output]' \
      '-v[verbose]' \
      '-x+[width and height for extraction]:w:h:' \
      '*:FITS file + xrange yrange:_files -g "*.(fits|fit|fts|FIT)"'
    ;;

  newfits)
    # Create a new (often empty) FITS file with given WCS.
    _arguments -s -S \
      '-a+[initial rotation angle (degrees)]:deg:' \
      '-b+[reference pixel coordinates in B1950 (ra dec)]:ra:dec:' \
      '-d[set CDELTn, CROTAn instead of CD matrix]' \
      '-e[make an extended FITS file]' \
      '-g+[reference pixel coordinates in Galactic (long lat)]:long:lat:' \
      '-i+[input pixel file]:file:_files' \
      '-j+[reference pixel coordinates in J2000 (ra dec)]:ra:dec:' \
      '-o+[number of bits per pixel]:bits:' \
      '-p+[initial plate scale in arcsec/pixel]:scale:' \
      '-s+[size of image in X and Y pixels]:nx:ny:' \
      '-t+[FITS projection code for output image]:code:' \
      '-v[verbose]' \
      '-w+[input FITS WCS file]:file:_files -g "*.(fits|fit|fts|FIT)"' \
      '-x+[reference pixel X and Y coordinates]:x:y:' \
      '-z[use AIPS classic WCS]' \
      ':output file:_files'
    ;;

  skycoor)
    # Standalone sky-coordinate calculator (RA/Dec, ecliptic,
    # galactic, B1950/J2000, x,y,z, separations, proper motions).
    _arguments -s -S \
      '-a+[position angle (N->E) between two RA Dec pairs]:ra1:dec1:ra2:dec2:' \
      '-b[output in B1950/FK4 coordinates]' \
      '-d[output always in degrees]' \
      '-e[output in ecliptic coordinates]' \
      '-f+[file with list of positions]:file:_files' \
      '-g[output in galactic coordinates]' \
      '-h[input RA in fractional hours, not degrees]' \
      '-i+[input units (r=radians, d=degrees, s=hours-or-dms)]:unit:(r d s)' \
      '-j[output in J2000/FK5 coordinates]' \
      '-k+[RA and Dec angular separation between two RA Dec pairs]:ra1:dec1:ra2:dec2:' \
      '-n+[number of decimal places in output]:n:' \
      '-o+[offset in seconds to add to coordinates]:sec:' \
      '-p+[proper motions in mas/year (mu_ra mu_dec)]:mu_ra:mu_dec:' \
      '-q+[output coordinate system]:sys:' \
      '-r+[angular separation between two RA Dec pairs]:ra1:dec1:ra2:dec2:' \
      '-s[output ra= dec= epoch= radecsys= for sethead]' \
      '-t+[separation between two times]:t1:t2:' \
      '-u+[less accurate angular separation between two RA Dec pairs]:ra1:dec1:ra2:dec2:' \
      '-v[verbose]' \
      '-w[convert RA, Dec to X, Y, Z]' \
      '-x[convert cartesian X, Y, Z coordinates to RA Dec]' \
      '-y+[epoch of coordinates]:epoch:' \
      '*:RA Dec system positional / @listfile:'
    ;;

esac
