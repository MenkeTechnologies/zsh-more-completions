#compdef kubefed-controller-manager controller-manager
# _kubefed-controller-manager — KubeFed v1beta1 controller manager (reconciles FederatedTypeConfigs across member clusters)
# upstream: https://github.com/kubernetes-sigs/kubefed
# Flags from cmd/controller-manager/app/controller-manager.go + cmd/controller-manager/app/options/options.go on tip.

_kubefed-controller-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print controller-manager version]' \
        '--kubefed-namespace=[namespace where the KubeFed control plane is deployed]:ns:' \
        '--kubefed-config=[path to a KubeFedConfig yaml file (test only)]:file:_files' \
        '--kubeconfig=[path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--master=[Kubernetes API server URL (overrides kubeconfig)]:url:_urls' \
        '--healthz-addr=[healthz endpoint bind address]:addr:' \
        '--metrics-addr=[metrics endpoint bind address]:addr:' \
        '--rest-config-qps=[max QPS to the API server]:qps:' \
        '--rest-config-burst=[max burst to the API server]:n:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_kubefed-controller-manager "$@"
