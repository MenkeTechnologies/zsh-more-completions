#compdef isakmpd
# _isakmpd — OpenBSD isakmpd (IKEv1 daemon for IPsec; establishes SAs per RFC 2408/2409; can be driven by legacy isakmpd.conf or modern ipsec.conf via the ipsecctl(8) frontend)
# upstream: https://github.com/openbsd/src (sbin/isakmpd)
# Flags from sbin/isakmpd/isakmpd.8 on tip.

_isakmpd() {
    _arguments \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-a[allow only authentication, no encryption]' \
        '-d[debug (foreground + stderr)]' \
        '-K[disable key search via NIC/keynote]' \
        '-L[log encrypted/decrypted traffic to packetlog]' \
        '-n[validate config + exit]' \
        '-S[do nothing for SIGHUP]' \
        '-T[disable NAT-T]' \
        '-v[verbose log_msg]' \
        '-c+[config file]:file:_files' \
        '*-D+[debug class=level]:class=level:' \
        '-f+[fifo control channel]:file:_files' \
        '-i+[pid file]:file:_files' \
        '-l+[packet log file]:file:_files' \
        '-N+[UDP-encapsulation port]:port:' \
        '-p+[listen port]:port:' \
        '-R+[report file]:file:_files'
}

_isakmpd "$@"
