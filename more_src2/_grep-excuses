#compdef grep-excuses
# Documentation: https://manpages.debian.org/grep-excuses
# Source: debian/devscripts scripts/grep-excuses.pl — grep Debian testing migration excuses (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '(-w --wipnity)'{-w,--wipnity}'[use qa.debian.org/excuses.php instead]' \
    '--autopkgtests[show autopkgtest failures]' \
    '--no-autoremovals[skip autoremoval information]' \
    '(-e --experimental)'{-e,--experimental}'[pseudo-excuses for experimental]' \
    '--debug[debug output to stderr]' \
    '*:package or maintainer:_default' \
    && ret=0

return ret
