#compdef joystream-node
# Documentation: https://github.com/Joystream/substrate-node-joystream
# Reference accessed: 2026-05-19
# Verified: Joystream full node (Substrate) + Substrate node CLI reference
# https://www.howtosolutions.net/2021/04/substrate-command-line-arguments-options-and-subcommands-list/
# Corrected from prior file: flag is --no-hardware-benchmarks
# (hyphens), not the invented --no_hardware_benchmarks.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'inspect:Decode a block or extrinsic with the native runtime'
  'benchmark:FRAME benchmarking commands'
  'try-runtime:Try-runtime integration tests'
  'key:Substrate key utilities'
  'verify:Verify stdin message signature'
  'vanity:Generate a vanity address seed'
  'sign:Sign a stdin message'
  'build-spec:Emit a chain specification JSON'
  'check-block:Validate blocks from disk'
  'export-blocks:Write raw blocks to disk'
  'export-state:Dump chain state into a spec'
  'import-blocks:Load blocks from disk'
  'purge-chain:Delete on-disk chain data'
  'revert:Roll canonical chain back'
  'chain-info:Print auxiliary DB metadata'
)

_arguments -C -s -S \
  '--no-hardware-benchmarks[Disable automatic hardware benchmarks]' \
  '--chain=[Select chain specification id or path]:chain:_files' \
  '--dev[Shortcut for a local development chain]' \
  '(-d --base-path)'{-d,--base-path=}'[Node data directory]:directory:_directories' \
  '*--bootnodes=[Extra bootnode multiaddrs]:peer:' \
  '--port=[Override libp2p listening port]:port:' \
  '--rpc-port=[HTTP JSON-RPC TCP port]:port:' \
  '--prometheus-port=[Prometheus exporter port]:port:' \
  '--validator[Start with validator authority keys]' \
  '--pruning=[State pruning mode]:mode:(archive)' \
  '(- *)--help[Show help]' \
  '(- *)'{-V,--version}'[Show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'joystream-node subcommand' subcommands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
