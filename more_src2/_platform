#compdef platform
# Documentation: https://developer.upsun.com/cli/reference
# Reference accessed: 2026-05-20
# Verified: upstream Upsun/Platform.sh CLI reference at the URL above.

local -a subcommands

subcommands=(
  'list:list commands'
  'help:show help'
  'docs:open docs'
  'console:open management console'
  'decode:decode PLATFORM_RELATIONSHIPS'
  'clear-cache:clear local CLI cache'
  'multi:run command on multiple environments'
  'auth:login auth:browser-login auth:logout auth:info auth:api-token-login'
  'app:app:config-get app:config-validate app:list'
  'project:project:list project:info project:create project:delete project:set-remote project:get project:clear-build-cache project:curl'
  'environment:environment:list environment:info environment:branch environment:checkout environment:delete environment:merge environment:activate environment:deactivate environment:redeploy environment:url environment:relationships environment:logs environment:set-remote environment:push environment:synchronize environment:http-access environment:scp environment:ssh environment:logs:tail'
  'activity:activity:list activity:get activity:log activity:cancel'
  'backup:backup:create backup:list backup:get backup:restore backup:delete'
  'certificate:certificate:list certificate:get certificate:add certificate:delete'
  'commit:commit:list commit:get'
  'db:db:dump db:size'
  'sql:run SQL queries'
  'domain:domain:list domain:get domain:add domain:delete domain:update'
  'integration:integration:list integration:get integration:add integration:delete integration:update integration:activity'
  'local:local:build local:dir local:drush'
  'metrics:metrics:cpu metrics:disk metrics:memory metrics:all'
  'mount:mount:list mount:upload mount:download'
  'operation:operation:list operation:run'
  'organization:organization:list organization:info organization:create organization:billing organization:user:add organization:user:list'
  'repo:repo:cat repo:ls repo:read'
  'route:route:list route:get'
  'service:service:list'
  'snapshot:snapshot:list snapshot:create snapshot:get'
  'source-operation:source-operation:list source-operation:run'
  'ssh:ssh into application'
  'ssh-cert:ssh-cert:load ssh-cert:info'
  'ssh-key:ssh-key:list ssh-key:add ssh-key:delete'
  'subscription:subscription:info'
  'team:team:list team:info team:create team:delete'
  'tunnel:tunnel:list tunnel:close tunnel:info tunnel:open tunnel:single'
  'user:user:list user:add user:get user:delete user:role'
  'variable:variable:list variable:get variable:create variable:update variable:delete variable:disable variable:enable'
  'worker:worker:list'
  'autoscaling:autoscaling:show autoscaling:enable autoscaling:disable'
)

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-y --yes)'{-y,--yes}'[assume yes]' \
  '--no-interaction[non-interactive]' \
  "*: :{_describe -t subcommands 'platform subcommand' subcommands}"
