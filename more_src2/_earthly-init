#compdef earthly-init
# _earthly-init — Earthly Earthfile scaffolder subcommand alias (Earthly Technologies, Go); urfave/cli
# upstream: https://github.com/earthly/earthly

_earthly-init() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--clone[clone repo if necessary]' \
        '--git=+[git remote]:url:_urls' \
        '--update[update existing Earthfile]' \
        '--all[all detected languages]' \
        '*:path:_files -/'
}

_earthly-init "$@"
