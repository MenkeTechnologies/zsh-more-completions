#compdef grib_dump
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_dump
# Source: ecmwf/eccodes tools/grib_dump.dox — dump full content of GRIB messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-O[octet mode (WMO documentation style)]' \
    '-D[debug mode]' \
    '-d[print all data values]' \
    '-j[JSON mode]' \
    '-t[print type information]' \
    '-H[print octet content in hex]' \
    '-a[dump aliases]' \
    '-w+[where clause filter]:filter:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '-M[turn off multi-field support]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '(- *)-V[show version]' \
    '-X+[input file offset in bytes]:offset:_default' \
    '-x[fast parsing (headers only)]' \
    '*:grib file:_files' \
    && ret=0

return ret
