#compdef glib-mkenums
# Documentation: glib-mkenums --help (GLib)
# Source: GLib glib-mkenums — generate enum/flags GType registration from C headers.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(- *)'{-v,--version}'[show version and exit]' \
    '--identifier-prefix=[identifier prefix]:idprefix:' \
    '--symbol-prefix=[symbol prefix]:symprefix:' \
    '--fhead=[output file header template]:text:' \
    '--ftail=[output file footer template]:text:' \
    '--fprod=[per-input-file production template]:text:' \
    '--eprod=[per-enum production template]:text:' \
    '--vhead=[value-header production template]:text:' \
    '--vprod=[per-value production template]:text:' \
    '--vtail=[value-tail production template]:text:' \
    '--comments=[comment structure template]:text:' \
    '--template=[full template file]:file:_files' \
    '--output=[output file]:file:_files' \
    '*:C header (or @rspfile_path):_files -g "*.{h,hpp,@,rsp}"' \
    && ret=0

return ret
