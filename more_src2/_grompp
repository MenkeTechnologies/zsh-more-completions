#compdef grompp gmx-grompp
# Documentation: https://manual.gromacs.org/current/onlinehelp/gmx-grompp.html
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-f+[input run parameter file (.mdp)]:mdp file:_files -g "*.mdp"' \
  '-c+[input structure file (.gro/.pdb)]:structure file:_files -g "*.(gro|pdb|g96|tpr)"' \
  '-r+[input reference structure file]:reference file:_files -g "*.(gro|pdb|g96|tpr)"' \
  '-rb+[input reference structure for position restraints]:reference file:_files -g "*.(gro|pdb|g96|tpr)"' \
  '-p+[input topology file (.top)]:topology file:_files -g "*.top"' \
  '-n+[input index file (.ndx)]:index file:_files -g "*.ndx"' \
  '-o+[output run input file (.tpr)]:tpr file:_files -g "*.tpr"' \
  '-po+[output mdp file with all settings]:mdp file:_files -g "*.mdp"' \
  '-pp+[output processed topology file]:topology file:_files -g "*.top"' \
  '-t+[input trajectory file for continuation]:trajectory file:_files -g "*.(trr|cpt)"' \
  '-e+[input energy file]:energy file:_files -g "*.edr"' \
  '-maxwarn+[maximum number of warnings allowed]:number:' \
  '-zero[set initial velocities to zero]' \
  '-renum[renumber atomtypes and minimize]' \
  '-h[show help]' \
  '-version[show version]' \
  '-nice+[set nice level]:level:' && ret=0

return ret
