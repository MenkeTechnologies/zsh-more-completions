#compdef mops
# _mops — Motoko Package Manager for Internet Computer (caffeinelabs/mops)
# upstream: https://github.com/caffeinelabs/mops
# Subcommands from cli/cli.ts (commander.js).

_mops() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-v --version)'{-v,--version}'[show version]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_mops_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '(-y --yes)'{-y,--yes}'[accept all defaults]' && ret=0 ;;
                add)
                    _arguments \
                        '--dev[add to dev-dependencies section]' \
                        '--verbose[verbose output]' \
                        '--lock=[lockfile action]:action:(update ignore)' \
                        '1:package name:' && ret=0 ;;
                remove|rm)
                    _arguments \
                        '--dev[remove from dev-dependencies instead]' \
                        '--verbose[verbose output]' \
                        '--dry-run[do not actually remove anything]' \
                        '--lock=[lockfile action]:action:(update ignore)' \
                        '1:package name:' && ret=0 ;;
                install|i)
                    _arguments \
                        '--no-toolchain[do not install toolchain]' \
                        '--verbose[verbose output]' \
                        '--lock=[lockfile action]:action:(check update ignore)' && ret=0 ;;
                publish)
                    _arguments \
                        '--no-docs[do not generate docs]' \
                        '--no-test[do not run tests before publishing]' \
                        '--verbose[verbose output]' && ret=0 ;;
                search)
                    _arguments \
                        '1:query:' && ret=0 ;;
                info)
                    _arguments \
                        '1:package name:' && ret=0 ;;
                update)
                    _arguments \
                        '1:package name (optional):' && ret=0 ;;
                bump)
                    _arguments \
                        '1:version bump:(major minor patch prerelease)' && ret=0 ;;
                test)
                    _arguments \
                        '--reporter=[test reporter]:reporter:(verbose compact silent files)' \
                        '--mode=[test mode]:mode:(interpreter wasi)' \
                        '--watch[re-run on file change]' && ret=0 ;;
                bench)
                    _arguments \
                        '--gc=[garbage-collector strategy]:gc:(copying compacting generational incremental)' \
                        '--save[save baseline results]' \
                        '--compare[compare against saved baseline]' && ret=0 ;;
                docs)
                    _arguments \
                        '--source[include source code in docs]' \
                        '--output=[output directory]:dir:_files -/' && ret=0 ;;
                format)
                    _arguments \
                        '--check[check formatting without writing files]' && ret=0 ;;
                lint)
                    _arguments \
                        '--fix[apply suggested fixes]' && ret=0 ;;
                migrate)
                    _arguments \
                        '1: :(new freeze)' && ret=0 ;;
                template)
                    _arguments \
                        '1:template name:(library actor empty)' && ret=0 ;;
                owner|maintainer)
                    _arguments \
                        '1: :(list add remove)' \
                        '2:principal or pem path:_files' && ret=0 ;;
                toolchain)
                    _arguments \
                        '1: :(init use bin reset)' \
                        '2:tool:(moc wasmtime pocket-ic)' \
                        '3:version:' && ret=0 ;;
                self)
                    _arguments \
                        '1: :(update uninstall)' && ret=0 ;;
                user)
                    _arguments \
                        '1: :(get-principal set-prop get-prop import-pem)' && ret=0 ;;
                watch)
                    _arguments \
                        '--check[type-check only]' \
                        '--test[also run tests]' && ret=0 ;;
                check|check-candid|check-stable|build|outdated|sources|sync|docs-coverage) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_mops_commands] )) ||
_mops_commands() {
    local -a commands
    commands=(
        'init:initialize a new project or package'
        'add:install the package and save it to mops.toml'
        'remove:remove a package and update mops.toml'
        'rm:alias for remove'
        'install:install all dependencies in mops.toml'
        'i:alias for install'
        'publish:publish package to the mops registry'
        'search:search the mops registry'
        'info:show package metadata from the registry'
        'sources:print compiler --package flags for the installed deps'
        'sync:re-sync deps from mops.toml'
        'update:update one or all packages to the latest version'
        'outdated:list outdated dependencies'
        'bump:bump the package version in mops.toml'
        'build:build the project'
        'check:type-check the project'
        'check-candid:check the generated candid interface'
        'check-stable:check stable-variable compatibility'
        'format:format Motoko source files'
        'lint:lint Motoko source files'
        'docs:generate Motoko documentation'
        'docs-coverage:report docstring coverage'
        'bench:run benchmarks'
        'test:run package tests'
        'watch:re-build / re-check on file change'
        'template:scaffold from a template'
        'migrate:migrate mops.toml across format versions'
        'owner:manage package owners'
        'maintainer:manage package maintainers'
        'toolchain:manage the moc / wasmtime / pocket-ic toolchain'
        'self:update or uninstall mops itself'
        'user:manage local identity (principal / pem)'
    )
    _describe -t commands 'mops command' commands
}

_mops "$@"
