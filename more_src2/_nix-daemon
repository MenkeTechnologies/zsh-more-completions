#compdef nix-daemon
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-daemon
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--stdio[attach to stdio instead of binding to a UNIX socket]' \
  '--force-trusted[force the daemon to trust connecting clients]' \
  '--force-untrusted[force the daemon to not trust connecting clients]' \
  '--default-trust[use default trust]' \
  '--process-ops[process received commands itself rather than forwarding]' && ret=0

return ret
