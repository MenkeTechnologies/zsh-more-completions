#compdef ppmtobmp
# Documentation: man ppmtobmp (Netpbm)
# Source: convert a PPM image to a Windows or OS/2 BMP file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-windows -os2)-windows[Windows BMP format]' \
    '(-windows -os2)-os2[OS/2 BMP format]' \
    '-bpp=[bits per pixel]:n:(1 4 8 24)' \
    '-mapfile=[colormap file]:file:_files -g "*.(ppm|pnm|pam)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
