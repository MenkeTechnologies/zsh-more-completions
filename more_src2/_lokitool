#compdef lokitool
# _lokitool — manage Loki rules and audit indexes (grafana/loki)
# upstream: https://github.com/grafana/loki
# Subcommands from pkg/tool/commands/{rules,audit}.go (kingpin/v2).

_lokitool() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                rules:'view and edit rules stored in Loki'
                audit:'audit Loki state'
                version:'show version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                rules)
                    _arguments \
                        '--authToken=[bearer/JWT auth token]:token:' \
                        '--user=[Loki API user]:user:' \
                        '--key=[Loki API key]:key:' \
                        '--address=[Loki cluster address]:url:_urls' \
                        '--id=[Loki tenant id]:id:' \
                        '--use-legacy-routes[use legacy /api/prom routes]' \
                        '--tls-ca-path=[TLS CA cert]:file:_files' \
                        '--tls-cert-path=[TLS client cert]:file:_files' \
                        '--tls-key-path=[TLS client key]:file:_files' \
                        '1:subcommand:(list print get delete load diff sync prepare format check)' \
                        '*::: :_files' ;;
                audit)
                    _arguments \
                        '1:subcommand:(index)' \
                        '--config.file=[auditing/storage config]:file:_files' \
                        '--index.file=[index file to audit]:file:_files' ;;
            esac
            ;;
    esac
}

_lokitool "$@"
