#compdef glava
# _glava — GLava OpenGL audio visualizer (C); GLSL spectrum visualizer with desktop-window or root-window rendering
# upstream: https://github.com/jarcode-foss/glava

_glava() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '(-d --desktop)'{-d,--desktop}'[render to root window]' \
        '(-c --copy-config)'{-c,--copy-config}'[copy config to user dir]' \
        '(-e --entry)'{-e,--entry}'+[entry glsl]:file:_files' \
        '(-C --config)'{-C,--config}'+[config dir]:dir:_files -/' \
        '(-m --force-mod)'{-m,--force-mod}'+[force module]:module:(radial bars wave circle)' \
        '(-b --backend)'{-b,--backend}'+[audio backend]:backend:(pulseaudio pipewire alsa portaudio)' \
        '(-r --request)'{-r,--request}'+[request]:str:' \
        '(-a --audio)'{-a,--audio}'+[audio source]:src:'
}

_glava "$@"
