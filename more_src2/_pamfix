#compdef pamfix
# Documentation: man pamfix (Netpbm)
# Source: fix common defects in a Netpbm image (truncation / out-of-range samples).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-truncate[truncate trailing partial scanlines]' \
    '-changemaxval[adjust maxval to fit actual samples]' \
    '-clip[clip out-of-range samples to maxval]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
