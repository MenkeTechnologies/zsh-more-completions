#compdef dud
# Documentation: https://github.com/kevin-hanselman/dud
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# kevin-hanselman/dud — data-version-control tool (cobra CLI)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--profile[activate profiling mode]' \
  '--trace[activate tracing mode]' \
  '(-v --verbose)'{-v,--verbose}'[increase output verbosity]' \
  '(-h --help)'{-h,--help}'[display help]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  local -a _dud_cmds
  _dud_cmds=(
    'init:set up a new dud project'
    'checkout:load committed artifacts from cache'
    'commit:save artifacts to cache and record checksums'
    'fetch:retrieve committed artifacts from remote cache'
    'pull:fetch from remote and checkout artifacts'
    'push:upload committed artifacts to remote cache'
    'run:execute stages or pipelines'
    'graph:output stage graph in graphviz DOT format'
    'status:display state of one or more stages'
    'stage:interact with stages and the index'
    'checksum:calculate checksums for files or STDIN'
    'config:manage configuration settings'
    'completion:generate shell completion scripts'
    'version:display version information'
  )
  _describe -t commands 'dud command' _dud_cmds && ret=0
  ;;
rest)
  case $line[1] in
    completion)
      _arguments '2:shell:(bash zsh fish powershell)' && ret=0
      ;;
    config)
      _arguments '2:action:(get set)' '*::key or value:_default' && ret=0
      ;;
    stage)
      _arguments '2:action:(add gen remove)' '*::stage:_default' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
