#compdef nearneighbor
# Documentation: https://docs.generic-mapping-tools.org/latest/nearneighbor.html
# Source: GenericMappingTools/gmt classic-mode nearneighbor — sector-based nearest-neighbor gridding.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[search radius]:radius:_default' \
    '-E+[empty-node value (default NaN)]:value:_default' \
    '-N+[number of search sectors]:n:_default' \
    '-W[input has 4th column with observation weights]' \
    '*-V[verbose (stackable)]' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata→NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-n+[interpolation boundary conditions]:opts:_default' \
    '-r[pixel registration (default gridline)]' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
