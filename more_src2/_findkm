#compdef findkm
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/findkm.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# EMBOSS findkm: compute Lineweaver-Burk Km / Vmax from enzyme kinetics data.
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-infile=[kinetics data file (substrate vs velocity)]:file:_files' \
  '-plot[produce graph output]' \
  '-graphlb=[Lineweaver-Burk plot graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-graphmm=[Michaelis-Menten plot graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfile=[report output file]:file:_files' \
  '*:kinetics file:_files' && ret=0
return ret
