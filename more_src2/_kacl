#compdef kacl-cli kacl
# _kacl — kacl-cli (Keep A Changelog enforcer; new initializes CHANGELOG.md, verify parses/validates structure, release stamps unreleased section as a new version, add appends an entry under [Unreleased], current prints latest version, log prints rendered changelog)
# upstream: https://github.com/dpoettker/kacl
# Subcommands from kacl src/kacl_cli/cli.py on tip.

_kacl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--config+[config file]:file:_files' \
        '--file+[changelog file]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'kacl command' '(new verify release add current get log)' ;;
        args)
            case $line[1] in
                add) _arguments '1:section:(Added Changed Deprecated Removed Fixed Security)' '*:message:' ;;
                release) _arguments '*:version:' ;;
            esac
            ;;
    esac
}

_kacl "$@"
