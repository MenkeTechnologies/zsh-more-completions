#compdef kafdrop
# _kafdrop — Obsidian Dynamics kafdrop CLI command-line frontend wrapping the Kafdrop open-source web UI for viewing Apache Kafka topics partitions consumer-groups brokers ACLs adding-removing-creating-deleting-topics messages-json-avro-protobuf schema-registry truststore TLS SASL JAAS keycloak Helm chart (Obsidian Dynamics team Emil Koutanov, Java); Spring Boot argparse
# upstream: https://github.com/obsidiandynamics/kafdrop

_kafdrop() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server.port=+[port]:n:' \
        '--server.address=+[host]:_hosts' \
        '--management.server.port=+[port]:n:' \
        '--kafka.brokerConnect=+[hosts]:_hosts' \
        '--kafka.properties=+[file]:file:_files -g "*.properties"' \
        '--kafka.truststore=+[file]:file:_files -g "*.jks *.p12"' \
        '--kafka.keystore=+[file]:file:_files -g "*.jks *.p12"' \
        '--schemaregistry.connect=+[url]:str:' \
        '--schemaregistry.auth=+[creds]:str:' \
        '--message.format=+[fmt]:f:(DEFAULT AVRO PROTOBUF MSGPACK)' \
        '--message.keyFormat=+[fmt]:f:(DEFAULT AVRO PROTOBUF)' \
        '--protobufdesc.directory=+[dir]:dir:_files -/' \
        '--cmd.enabled[enable command]' \
        '--logging.level.root=+[level]:l:(trace debug info warn error)' \
        '--logging.file.name=+[file]:file:_files' \
        '--spring.config.location=+[file]:file:_files -g "*.yml *.yaml *.properties"' \
        '--spring.profiles.active=+[p]:p:(default dev prod)' \
        '*:args:'
}

_kafdrop "$@"
