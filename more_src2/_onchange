#compdef onchange
# Documentation: https://github.com/Qard/onchange
# Reference accessed: 2026-05-20
# Verified: upstream onchange README on GitHub.

# Zsh completion for onchange - run a command when files change

_arguments -s -S \
  '(-i --initial)'{-i,--initial}'[execute the command once on load without any event]' \
  '(-a --add)'{-a,--add}'[execute the command for all initially added paths]' \
  '(-k --kill)'{-k,--kill}'[kill current and pending processes between changes]' \
  '(-d --delay)'{-d+,--delay=}'[delay between executions in milliseconds]:ms:' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '--await-write-finish=[await stable file size in ms before triggering]:ms:' \
  '(-e --exclude)*'{-e+,--exclude=}'[exclude matches]:pattern:' \
  '--exclude-path=[gitignore-style file with exclusion patterns]:file:_files' \
  '--no-exclude[disable default exclusions for node_modules and .git]' \
  '(-f --filter)*'{-f+,--filter=}'[restrict monitoring to specific event types]:filter:' \
  '(-p --poll)'{-p+,--poll=}'[use polling for file changes with interval ms]:ms:' \
  '(-j --jobs)'{-j+,--jobs=}'[maximum concurrent processes to run]:count:' \
  '(-o --outpipe)'{-o+,--outpipe=}'[shell command to execute on every change]:cmd:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:pattern:_files'
