#compdef dwz
# Documentation: man dwz(1)
# Source: marxin/dwz dwz.c (master) — DWARF optimization and duplicate removal tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-? --help)'{-\\?,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
    '(-h --hardlink)'{-h,--hardlink}'[hardlink identical input files]' \
    '(-o --output)'{-o+,--output=}'[output file (single-input mode)]:file:_files' \
    '(-m --multifile)'{-m+,--multifile=}'[common multifile output]:file:_files' \
    '(-M --multifile-name)'{-M+,--multifile-name=}'[multifile reference name]:name:_default' \
    '(-l --low-mem-die-limit)'{-l+,--low-mem-die-limit=}'[low-memory DIE count threshold]:N:_default' \
    '(-L --max-die-limit)'{-L+,--max-die-limit=}'[max DIE count]:N:_default' \
    '(-r --relative)'{-r,--relative}'[use relative path for multifile reference]' \
    '*:object file:_files -g "*.{so,a,o}"' \
    && ret=0

return ret
