#compdef db_checkpoint
# Documentation: db_checkpoint usage (Berkeley DB 18.1.40)
# Source: take Berkeley DB environment checkpoints.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-1[take a single checkpoint and exit]' \
    '-v[verbose]' \
    '-h+[environment home]:dir:_files -/' \
    '-k+[checkpoint every K kilobytes]:kbytes:' \
    '-L+[log file]:file:_files' \
    '-m+[message prefix]:msg_pfx:' \
    '-P+[password]:password:' \
    '-p+[checkpoint every N minutes]:min:' \
    && ret=0

return ret
