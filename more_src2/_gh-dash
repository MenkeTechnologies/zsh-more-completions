#compdef gh-dash
# Documentation: https://github.com/dlvhdr/gh-dash
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# dlvhdr/gh-dash - GitHub dashboard TUI. Flags from cmd/root.go.

_arguments -s -S \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.yml *.yaml"' \
  '--debug[enable debug logging to debug.log]' \
  '--cpuprofile=[write CPU profile to file]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' && return 0
