#compdef retype retype-cli
# _retype — Object.NET Retype static site generator CLI for converting Markdown into modern documentation sites with search dark-mode versioning and built-in API reference (retypeapp team, .NET); System.CommandLine
# upstream: https://github.com/retypeapp/retype

_retype() {
    local -a sub=(
        'init:initialize a new project'
        'build:build static site'
        'watch:run dev server'
        'serve:serve a built site'
        'config:print resolved config'
        'help:show help'
        'version:show version'
        'completion:generate shell completion'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--license=+[file]:file:_files' \
        '--cwd=+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'retype subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--name=+[name]:str:' \
                    '--template=+[t]:t:(default blank blog wiki documentation api)' \
                    '*:project dir:_files -/' ;;
                build) _arguments \
                    '--output=+[dir]:dir:_files -/' \
                    '-o+[dir]:dir:_files -/' \
                    '--override=+[json]:str:' \
                    '--clean[clean output]' \
                    '--strict[strict]' \
                    '--no-strict[no strict]' \
                    '*:config file or dir:_files' ;;
                watch) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--no-browser[no browser]' \
                    '--secret=+[secret]:str:' \
                    '--override=+[json]:str:' ;;
                serve) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '*:dir:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_retype "$@"
