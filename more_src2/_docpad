#compdef docpad
# _docpad — DocPad streaming static site generator (Node.js); pre-Eleventy-era SSG with plugin ecosystem
# upstream: https://github.com/docpad/docpad

_docpad() {
    local -a sub=(
        'init:initialize a new project'
        'run:install + generate + watch + serve'
        'install:install plugins'
        'uninstall:uninstall plugin'
        'update:update plugins'
        'upgrade:upgrade docpad itself'
        'generate:generate the site'
        'watch:watch + regenerate'
        'server:run server only'
        'clean:remove out + cache'
        'render:render a file'
        'deploy:deploy via deploy plugin'
        'info:show project info'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '(-f --force)'{-f,--force}'[force action]' \
        '(-p --port)'{-p,--port}'+[port]:port:' \
        '(-e --env)'{-e,--env}'+[environment]:env:' \
        '(-o --out)'{-o,--out}'+[output dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'docpad subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall) _arguments '*:plugin:' ;;
            esac
            ;;
    esac
}

_docpad "$@"
