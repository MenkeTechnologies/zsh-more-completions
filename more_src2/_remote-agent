#compdef remote-agent
# Documentation: https://github.com/d-kimuson/remote-agent
# Reference accessed: 2026-05-22
# Verified: src/cli/cli-program.pure.ts Commander program.

# Zsh completion for remote-agent - web UI bridge for ACP-compatible agents

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'remote-agent command' \
      'serve[start remote-agent server]' \
      'generate-api-key[generate API key for RA_API_KEY]' && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '--server-only[start without serving client build]' \
          '--port[local server port]:port:' \
          '--same-lan[publish via HTTPS/mDNS on LAN]' \
          '--tailscale[publish via Tailscale Serve]' \
          '--ra-dir[SQLite and app state directory]:directory:_directories' \
          '--ra-api-key[bearer token for /api requests]:key:' \
          '--ra-allowed-ips[comma-separated IP allowlist]:ips:' \
          '--ra-allowed-origins[comma-separated CORS origins]:origins:' && ret=0
        ;;
    esac
    ;;
esac

return ret
