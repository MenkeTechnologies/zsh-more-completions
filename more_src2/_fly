#compdef fly
# Documentation: https://github.com/concourse/concourse/tree/master/fly
# Source: concourse/concourse fly/commands/fly.go — Concourse CI fly CLI.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _fly_cmds
_fly_cmds=(
    'help:print this help message'
    'targets:list saved targets'
    'delete-target:delete target'
    'edit-target:edit a target'
    'login:authenticate with the target'
    'logout:release authentication with the target'
    'status:login status'
    'sync:download and replace the current fly from the target'
    'active-users:list active users since a date or for the past 2 months'
    'userinfo:user information'
    'teams:list configured teams'
    'get-team:show team configuration'
    'set-team:create or modify a team'
    'rename-team:rename a team'
    'destroy-team:destroy a team and delete its data'
    'checklist:print a Checkfile of the given pipeline'
    'execute:execute a one-off build using local bits'
    'watch:stream a build output'
    'containers:print the active containers'
    'hijack:execute a command in a container'
    'jobs:list jobs in the pipelines'
    'paused-jobs:list paused jobs in the pipelines'
    'pause-job:pause a job'
    'unpause-job:unpause a job'
    'schedule-job:request the scheduler to run for a job'
    'pipelines:list configured pipelines'
    'paused-pipelines:list configured paused pipelines'
    'destroy-pipeline:destroy a pipeline'
    'get-pipeline:get a pipeline current configuration'
    'set-pipeline:create or update a pipeline configuration'
    'pause-pipeline:pause a pipeline'
    'archive-pipeline:archive a pipeline'
    'unpause-pipeline:un-pause a pipeline'
    'expose-pipeline:make a pipeline publicly viewable'
    'hide-pipeline:hide a pipeline from the public'
    'rename-pipeline:rename a pipeline'
    'validate-pipeline:validate a pipeline config'
    'format-pipeline:format a pipeline config'
    'order-pipelines:order pipelines'
    'order-instanced-pipelines:order instanced pipelines within an instance group'
    'resources:list resources in the pipeline'
    'resource-versions:list versions of a resource'
    'check-resource:check a resource'
    'pin-resource:pin a version to a resource'
    'unpin-resource:unpin a resource'
    'enable-resource-version:enable a version of a resource'
    'disable-resource-version:disable a version of a resource'
    'clear-resource-cache:clear cache of a resource'
    'clear-versions:clear versions of a resource or resource type'
    'check-resource-type:check a resource type'
    'clear-task-cache:clears cache from a task container'
    'builds:list builds data'
    'abort-build:abort a build'
    'rerun-build:rerun a build'
    'trigger-job:start a job in a pipeline'
    'volumes:list active volumes'
    'workers:list registered workers'
    'land-worker:land a worker'
    'prune-worker:prune a stalled/landing/landed/retiring worker'
    'curl:curl the API'
    'get-wall:get the current wall message'
    'set-wall:set a wall message'
    'clear-wall:clear the wall message'
    'get-components:get details about all web components'
    'pause-component:pause one or more web components'
    'unpause-component:unpause one or more web components'
    'completion:generate shell completion script'
)

_arguments -C \
    '(-t --target)'{-t+,--target=}'[Concourse target name]:target:_default' \
    '(- *)'{-v,--version}'[print the version of fly and exit]' \
    '--verbose[print API requests and responses]' \
    '--print-table-headers[print table headers even for redirected output]' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'fly command' _fly_cmds && ret=0
        ;;
esac

return ret
