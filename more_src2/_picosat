#compdef picosat picomus
# Documentation: https://manpages.debian.org/testing/picosat/picosat.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream Debian picosat(1) man page.

local curcontext="$curcontext" state line ret=1

case $service in
  (picosat)
    _arguments -C \
      '-h[show help]' \
      '--version[show version]' \
      '--config[print build configuration]' \
      '-v[verbose output]' \
      '-f[ignore invalid header]' \
      '-n[do not print satisfying assignment]' \
      '-p[print formula in DIMACS format and exit]' \
      '-i+[force FALSE or TRUE as default phase]:n:(0 1)' \
      '-a+[start with an assumption]:lit:' \
      '-l+[decision limit]:n:' \
      '-s+[random seed]:n:' \
      '-o+[output file]:file:_files' \
      '-t+[compact proof trace file]:file:_files' \
      '-T+[extended proof trace file]:file:_files' \
      '-r+[reverse unit propagation proof file]:file:_files' \
      '-c+[clausal core file]:file:_files' \
      '-V+[file listing core variables]:file:_files' \
      '-U+[file listing used variables]:file:_files' \
      '*: :_files -g "*.cnf *.dimacs"' && ret=0 ;;
  (picomus)
    _arguments -C \
      '-h[show help]' \
      '-v[verbose]' \
      '*: :_files -g "*.cnf *.dimacs"' && ret=0 ;;
esac

return ret
