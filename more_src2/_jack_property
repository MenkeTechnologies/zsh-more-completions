#compdef jack_property
# Documentation: https://jackaudio.org/
# Source: manpages.debian.org/jack_property.1 — list/set/delete JACK port/client metadata properties.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-l -d -D -s)-l[list all metadata currently defined]' \
    '(-l -d -D -s)-d[delete metadata for identifier / key]' \
    '(-l -d -D -s)-D[delete all currently defined metadata]' \
    '(-l -d -D -s)-s[set metadata key=value (with type) for identifier]' \
    '(-c -p)-c[interpret identifier as a client name (not UUID)]' \
    '(-c -p)-p[interpret identifier as a port name (not UUID)]' \
    '*:identifier / key / value:' \
    && ret=0

return ret
