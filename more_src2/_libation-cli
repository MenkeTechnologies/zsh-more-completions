#compdef libation-cli LibationCli
# _libation-cli — Libation Audible audiobook manager CLI (rmcrackan/Libation)
# upstream: https://github.com/rmcrackan/Libation
# Subcommands from Source/LibationCli/Options/.

_libation-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'convert:convert audiobooks to other formats'
                'copy-db:copy library database'
                'export:export library to file (xlsx/csv/json)'
                'get-license:get license for a book'
                'get-setting:get a Libation setting value'
                'import-account:import Audible account'
                'liberate:liberate (download/decrypt) books'
                'list-accounts:list configured Audible accounts'
                'login-external:run external login flow'
                'scan:scan library for new books'
                'search:search the library'
                'set-download-status:update download status of books'
                'version:show version'
                'help:show command help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                export)
                    _arguments \
                        '(-p --path)'{-p+,--path=}'[output file path]:file:_files' \
                        '(-x --xlsx -c --csv -j --json)'{-x,--xlsx}'[Microsoft Excel spreadsheet]' \
                        '(-x --xlsx -c --csv -j --json)'{-c,--csv}'[comma-separated values]' \
                        '(-x --xlsx -c --csv -j --json)'{-j,--json}'[JSON output]' \
                        '*:ASIN:'
                    ;;
            esac
            ;;
    esac
}

_libation-cli "$@"
