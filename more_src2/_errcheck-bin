#compdef errcheck
# _errcheck-bin — Go errcheck unchecked-error linter (Kamil Kisiel, Go); reports unchecked errors in source
# upstream: https://github.com/kisielk/errcheck

_errcheck-bin() {
    _arguments \
        '-abspath[print abs paths]' \
        '-asserts[check type assertions]' \
        '-blank[check assignments to blank ident]' \
        '-exclude+[exclude file]:file:_files' \
        '-excludeonly[exclusions override defaults]' \
        '-ignore+[ignore pkg:regex]:str:' \
        '-ignorepkg+[ignore packages]:pkgs:' \
        '-ignoretests[skip test files]' \
        '-tags+[build tags]:tags:' \
        '-mod+[module mode]:mode:(mod readonly vendor)' \
        '-verbose[verbose]' \
        '*:packages:'
}

_errcheck-bin "$@"
