#compdef registry-server configmap-server initializer
# Documentation: https://github.com/operator-framework/operator-registry
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above
# (cmd/registry-server/main.go cobra flag definitions).

# The operator-registry project provides several stand-alone binaries
# (opm, registry-server, configmap-server, initializer). opm has its
# own completion file (_opm); this file covers the legacy binaries.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

case $service in
  registry-server)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(-d --database)'{-d+,--database=}'[relative path to sqlite db]:file:_files' \
      '(-p --port)'{-p+,--port=}'[port number to serve on]:port:' \
      '(-t --termination-log)'{-t+,--termination-log=}'[container termination log file]:file:_files' \
      '--skip-migrate[do not migrate to latest db revision on start]' && ret=0
    ;;
  configmap-server)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '--kubeconfig=[path to kubeconfig]:file:_files' \
      '--configmap-name=[configmap name]:name:' \
      '--configmap-namespace=[configmap namespace]:ns:' \
      '*:arg:' && ret=0
    ;;
  initializer)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(-m --manifests)'{-m+,--manifests=}'[directory of operator manifests]:dir:_directories' \
      '(-o --output)'{-o+,--output=}'[output sqlite database file]:file:_files' \
      '--permissive[allow registry load errors]' && ret=0
    ;;
esac
return ret
