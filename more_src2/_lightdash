_lightdash() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print CLI + skills versions]' \
        '--non-interactive[disable all interactive prompts]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ld_cmds=(
                'login:OAuth 2.0 / OIDC PKCE login to a Lightdash instance'
                'config:sets configuration'
                'dbt:runs dbt commands'
                'compile:compiles Lightdash resources'
                'preview:create ephemeral preview project (waits for keypress)'
                'start-preview:create persistent preview project'
                'stop-preview:stop a persistent preview project'
                'download:download dashboards + charts as YAML'
                'upload:upload dashboards + charts from YAML'
                'deploy:compile + deploy explores to active project'
                'refresh:trigger project refresh'
                'validate:run server-side validation on active project'
                'generate:auto-generate Lightdash blocks in dbt schema.yml'
                'rename:bulk rename metric/dimension/explore identifiers'
                'generate-exposures:emit dbt exposures from Lightdash charts'
                'diagnostics:environment-introspection bug-report bundle'
                'lint:static-validate Lightdash block YAML'
                'pre-aggregate-audit:detect queries that benefit from pre-aggregates'
                'sql:execute SQL against the Lightdash warehouse connection'
                'run-chart:execute a saved chart headlessly'
                'set-warehouse:reconfigure project warehouse credentials'
                'export-chart-image:render chart to PNG/SVG'
                'install-skills:install the Lightdash AI skills plugin set'
                'help:show help for command'
            )
            _describe -t commands 'lightdash command' _ld_cmds && ret=0
            ;;
        args)
            case $words[1] in
                login)
                    _arguments \
                        '1:Lightdash URL:' \
                        '--token=[API access token]:token:' \
                        '--project=[project UUID after login]:uuid:' \
                        '--email=[login with email + password]:email:' \
                        '--oauth-port=[port for local OAuth callback (1-65535)]:port:' \
                        '--verbose[verbose output]' && ret=0
                    ;;
                config)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'config sub-command' \
                          '(set-project list-projects get-project unset-project)' && ret=0
                    else
                        case $words[2] in
                            set-project)
                                _arguments \
                                    '--name=[project name]:name:' \
                                    '--uuid=[project UUID]:uuid:' \
                                    '--verbose[verbose output]' && ret=0
                                ;;
                            *)
                                _arguments '--verbose[verbose output]' && ret=0
                                ;;
                        esac
                    fi
                    ;;
                dbt)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'dbt sub-command' '(run)' && ret=0
                    else
                        _arguments \
                            '--project-dir=[dbt project directory]:dir:_files -/' \
                            '--profiles-dir=[dbt profiles directory]:dir:_files -/' \
                            '--profile=[profile name]:name:' \
                            '(-t --target)'{-t,--target}'=[target in profiles.yml]:target:' \
                            '(-x --fail-fast)'{-x,--fail-fast}'[fail fast]' \
                            '--threads=[dbt threads]:n:' \
                            '--no-version-check[skip dbt version check]' \
                            '(-s --select)'{-s,--select}'=[dbt selection syntax]:select:' \
                            '--state=[dbt --state directory]:state:_files -/' \
                            '--defer[dbt defer]' \
                            '--no-defer[disable dbt defer]' \
                            '--favor-state[prioritize state-dir definitions]' \
                            '--full-refresh[dbt full refresh]' \
                            '--exclude-meta[exclude Lightdash metadata]' \
                            '--verbose[verbose output]' \
                            '(-y --assume-yes)'{-y,--assume-yes}'[assume yes to prompts]' \
                            '(-no --assume-no)'{-no,--assume-no}'[assume no to prompts]' \
                            '--preserve-column-case[preserve original column casing]' && ret=0
                    fi
                    ;;
                compile|preview|start-preview)
                    _arguments \
                        '--project-dir=[dbt project directory]:dir:_files -/' \
                        '--profiles-dir=[dbt profiles directory]:dir:_files -/' \
                        '--profile=[profile name]:name:' \
                        '--target=[target in profiles.yml]:target:' \
                        '--target-path=[dbt target directory]:dir:_files -/' \
                        '--vars=[dbt vars]:vars:' \
                        '--threads=[dbt threads]:n:' \
                        '--no-version-check[skip dbt version check]' \
                        '(-s --select)'{-s,--select}'=[dbt selection syntax]:select:' \
                        '(-m --models)'{-m,--models}'=[dbt selection syntax]:models:' \
                        '--exclude=[dbt exclude]:exclude:' \
                        '--selector=[dbt selector name]:name:' \
                        '--state=[dbt --state directory]:state:_files -/' \
                        '--full-refresh[dbt full refresh]' \
                        '--verbose[verbose output]' \
                        '--name=[preview name]:name:' \
                        '--use-dbt-list=[use dbt list (true|false)]:bool:(true false)' \
                        '--skip-warehouse-catalog[skip warehouse catalog fetch]' \
                        '--skip-dbt-compile[skip dbt compile step]' \
                        '--no-warehouse-credentials[compile without warehouse creds]' \
                        '--start-of-week=[first day of week (0=Mon..6=Sun)]:n:' \
                        '--disable-timestamp-conversion=[disable UTC conversion]:bool:(true false)' \
                        '--organization-credentials=[org warehouse creds name (EE)]:name:' \
                        '--use-batched-deploy[batched explore upload]' \
                        '--batch-size=[explores per batch]:n:' \
                        '--parallel-batches=[parallel batch count]:n:' \
                        '--ignore-errors[allow deploy with compile errors]' \
                        '--combine-manifest=[additional dbt manifest.json]:path:_files -g "*.json"' \
                        '--table-configuration=[prod|all]:mode:(prod all)' \
                        '--skip-copy-content[skip copying content]' \
                        '--expires-in=[preview lifetime in hours]:hours:' \
                        '(-y --assume-yes)'{-y,--assume-yes}'[assume yes to prompts]' && ret=0
                    ;;
                stop-preview)
                    _arguments \
                        '--name=[preview project name]:name:' \
                        '--verbose[verbose output]' && ret=0
                    ;;
                download|upload)
                    _arguments \
                        '--path=[YAML path]:path:_files -/' \
                        '--charts=[chart slugs]:slugs:' \
                        '--dashboards=[dashboard slugs]:slugs:' \
                        '--force[force overwrite]' \
                        '--verbose[verbose output]' && ret=0
                    ;;
                lint)
                    _arguments \
                        '(-f --file)*'{-f,--file}'=[YAML file]:path:_files -g "*.yml *.yaml"' \
                        '(-d --directory)'{-d,--directory}'=[YAML directory]:dir:_files -/' \
                        '--verbose[verbose output]' && ret=0
                    ;;
                sql)
                    _arguments \
                        '(-q --query)'{-q,--query}'=[SQL query]:sql:' \
                        '(-l --limit)'{-l,--limit}'=[row limit]:n:' \
                        '--verbose[verbose output]' && ret=0
                    ;;
                run-chart|export-chart-image)
                    _arguments \
                        '(-u --uuid)'{-u,--uuid}'=[chart UUID]:uuid:' \
                        '(-o --output)'{-o,--output}'=[output path]:path:_files' \
                        '--verbose[verbose output]' && ret=0
                    ;;
                help)
                    _arguments '1:command:(login config dbt compile preview start-preview stop-preview download upload deploy refresh validate generate rename generate-exposures diagnostics lint pre-aggregate-audit sql run-chart set-warehouse export-chart-image install-skills)' && ret=0
                    ;;
                *)
                    _arguments '--verbose[verbose output]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_lightdash "$@"
