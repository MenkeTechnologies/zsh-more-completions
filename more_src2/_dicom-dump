_dicom-dump() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--until=[read the file only up to this DICOM Tag]:tag:' \
        '(-o --odd-length-strategy)'{-o,--odd-length-strategy}'=[strategy for handling odd-length text values (default accept)]:strategy:(accept next_even fail)' \
        '--no-text-limit[print text values to the end (limited to --width by default)]' \
        '--no-limit[print all values to the end]' \
        '(-w --width)'{-w,--width}'=[display width (auto by default)]:n:' \
        '--color=[color mode (default auto)]:mode:(auto always never)' \
        '--fail-first[fail if any errors are encountered]' \
        '(-f --format)'{-f,--format}'=[output format (default text)]:format:(text json)' \
        '*:DICOM file:_files -g "*.dcm *.dicom"'
}

_dicom-dump "$@"
