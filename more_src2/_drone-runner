#compdef drone-runner drone-runner-docker drone-runner-exec drone-runner-kube drone-runner-ssh
# _drone-runner — Drone CI runner family (Harness/Drone, Go); custom argparse via DRONE_ envs + subcommands
# upstream: https://github.com/drone-runners

_drone-runner() {
    local -a sub=(
        'service:run runner service (default)'
        'config:print computed runner config'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files -g "*.env"' \
        '--rpc-host=+[rpc server host]:host:_hosts' \
        '--rpc-proto=+[rpc protocol]:proto:(http https)' \
        '--rpc-secret=+[rpc secret]:str:' \
        '--rpc-skip-verify[skip rpc tls verify]' \
        '--ui-username=+[runner ui user]:str:_users' \
        '--ui-password=+[runner ui password]:str:' \
        '--ui-realm=+[ui realm]:str:' \
        '--runner-name=+[runner name]:str:' \
        '--runner-capacity=+[runner capacity]:n:' \
        '--runner-os=+[runner os]:os:(linux darwin windows)' \
        '--runner-arch=+[runner arch]:arch:(amd64 arm64 arm)' \
        '--runner-labels=+[runner labels]:str:' \
        '--runner-environ=+[runner environment]:str:' \
        '--runner-volumes=+[runner volumes]:str:' \
        '--runner-networks=+[runner networks]:str:' \
        '--http-bind=+[http bind addr]:addr:' \
        '--http-host=+[http host]:host:_hosts' \
        '--http-proto=+[http proto]:proto:(http https)' \
        '--debug[debug]' \
        '--trace[trace]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'drone-runner subcommand' sub ;;
    esac
}

_drone-runner "$@"
