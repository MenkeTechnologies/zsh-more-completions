#compdef epub epub-tools epub-cli
# _epub — IDPF epub-tools command-line manipulation of EPUB 2.0/3.0/3.2 publications validate inspect extract package and create from XHTML sources (idpf team, Python); argparse
# upstream: https://github.com/IDPF/epubcheck

_epub() {
    local -a sub=(
        'check:run epubcheck'
        'create:create new EPUB'
        'validate:validate EPUB'
        'extract:extract contents'
        'pack:pack directory into EPUB'
        'unpack:unpack EPUB'
        'info:show EPUB info'
        'meta:show metadata'
        'set-meta:set metadata'
        'list:list manifest'
        'preview:preview in browser'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '--profile=+[p]:p:(default epub2 epub3 epub3.2)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'epub subcommand' sub ;;
        args)
            case $words[1] in
                check|validate) _arguments \
                    '--mode=+[m]:m:(opf nav ncx mediaoverlays svg xhtml)' \
                    '--save[save reports]' \
                    '--report=+[file]:file:_files -g "*.xml *.json *.xmp *.html"' \
                    '--locale=+[locale]:str:' \
                    '*:epub file or dir:_files -g "*.epub"' ;;
                create|pack) _arguments \
                    '--title=+[title]:str:' \
                    '--author=+[author]:str:' \
                    '--language=+[lang]:l:(en en-US es fr de it ja zh ru pt nl ko pl tr ar)' \
                    '--cover=+[file]:file:_files -g "*.jpg *.jpeg *.png *.svg"' \
                    '--output=+[file]:file:_files -g "*.epub"' \
                    '*:input dir or files:_files' ;;
                extract|unpack) _arguments \
                    '--output-dir=+[dir]:dir:_files -/' \
                    '*:epub file:_files -g "*.epub"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_epub "$@"
