#compdef kubeconform
# Documentation: https://github.com/yannh/kubeconform#usage
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubeconform - Kubernetes manifest validator

_arguments -s -S \
  '-cache[cache schemas downloaded via HTTP to this folder]:directory:_directories' \
  '-debug[print debug information]' \
  '-exit-on-error[stop execution when the first error is encountered]' \
  '*-ignore-filename-pattern[regex specifying paths to ignore]:pattern' \
  '-ignore-missing-schemas[skip files with missing schemas instead of failing]' \
  '-insecure-skip-tls-verify[disable verification of the server SSL certificate]' \
  '-kubernetes-version[version of Kubernetes to validate against]:version' \
  '-n[number of goroutines to run concurrently]:number' \
  '-output[output format]:format:(json junit pretty tap text)' \
  '-reject[comma-separated list of kinds or GVKs to reject]:kinds' \
  '*-schema-location[override schemas location search path]:location' \
  '-skip[comma-separated list of kinds or GVKs to ignore]:kinds' \
  '-strict[disallow additional properties not in schema or duplicated keys]' \
  '-summary[print a summary at the end]' \
  '(- *)-v[show version information]' \
  '(- *)-h[show help information]' \
  '*:file:_files'
