#compdef ppumove
# Documentation: https://www.freepascal.org/docs-html/current/user/userap5.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (and local `ppumove` usage output).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-q[quiet]' \
  '-h[show help]' \
  '-v[verbose]' \
  '-b[create BSD style ld script]' \
  '-s[statically link the unit]' \
  '-S[same as -s for compatibility]' \
  '-e+[extension for unit files]:ext:' \
  '-o+[output filename]:file:_files' \
  '-d+[output directory]:dir:_files -/' \
  '*:ppu file:_files -g "*.ppu"' && ret=0

return ret
