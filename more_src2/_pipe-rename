#compdef renamer pipe-rename
# Documentation: https://github.com/marcusbuffett/pipe-rename
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: binary is `renamer`; project package is `pipe-rename`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[answer all prompts with yes]' \
  '(-c --rename-command)'{-c+,--rename-command=}'[use a custom rename command]:command:' \
  '(-d --pretty-diff)'{-d,--pretty-diff}'[prettify diffs]' \
  '(-e --editor)'{-e+,--editor=}'[editor to use]:editor:_command_names' \
  '(-f --force)'{-f,--force}'[overwrite existing files]' \
  '(-n --filenames-only)'{-n,--filenames-only}'[only rename filenames, not paths]' \
  '(-p --parents)'{-p,--parents}'[create parent directories if needed]' \
  '(-q --quiet)'{-q,--quiet}'[skip printing replacement filenames]' \
  '(-u --undo)'{-u,--undo}'[undo the previous renaming operation]' \
  '*:files:_files'
