#compdef psbook
# Documentation: psbook usage (psutils 1.23)
# Source: rearrange PostScript pages into signatures for printing as a booklet.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-q[quiet operation]' \
    '-s+[signature size (must be positive and divisible by 4)]:signature:' \
    '1:input ps:_files -g "*.ps"' \
    '2:output ps:_files -g "*.ps"' \
    && ret=0

return ret
