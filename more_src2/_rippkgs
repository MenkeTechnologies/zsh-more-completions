#compdef rippkgs
# Documentation: https://github.com/replit/rippkgs/blob/main/src/bin/search/main.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for rippkgs - fast Nix package searcher

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --index)'{-i,--index}'+[location of the rippkgs index to use]:file:_files' \
  '(-m --max-results)'{-m,--max-results}'+[maximum number of results to return]:number:' \
  '--exact[return information about an exact attribute]' \
  '--filter-built[filter results by whether /nix/store path exists]' \
  '--json[print results as JSON]' \
  '*:query:' && return 0
