#compdef ecl
# Documentation: https://ecl.common-lisp.dev/
# Documentation: https://gitlab.common-lisp.net/ecl/ecl/-/blob/develop/src/lsp/cmdline.lsp
# Reference accessed: 2026-05-27
# Verified: upstream +default-command-arg-rules+ in src/lsp/cmdline.lsp and src/doc/ecl.man.in

# Zsh completion for ECL (Embeddable Common-Lisp)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(--help -?)'{--help,-\?}'[print help message and exit]' \
  '--version[print ECL version and exit]' \
  '-norc[do not load ~/.ecl or ~/.eclrc at startup]' \
  '-debug[enable command-line break (debugger on error)]' \
  '-nodebug[disable command-line break]' \
  '*-eval+[evaluate expression before entering REPL]:expr:' \
  '-shell+[execute file and exit (script mode)]:file:_files' \
  '*-load+[load file before entering REPL]:file:_files' \
  '-dir+[use directory as system directory]:dir:_files -/' \
  '--heap-size=[set heap size limit]:size:' \
  '--lisp-stack=[set lisp stack size limit]:size:' \
  '--frame-stack=[set frame stack size limit]:size:' \
  '--c-stack=[set C stack size limit]:size:' \
  '--trap-fpe[trap floating-point exceptions]' \
  '--no-trap-fpe[do not trap floating-point exceptions]' \
  '--encoding=[set external format for all standard streams]:format:' \
  '--input-encoding=[set external format for *standard-input*]:format:' \
  '--output-encoding=[set external format for *standard-output*]:format:' \
  '--error-encoding=[set external format for *error-output*]:format:' \
  '-compile+[translate file to C and build a .fas shared library]:file:_files' \
  '*-link+[link given lisp files into an executable]:file:_files' \
  '-o+[output file name (with -compile or -link)]:file:_files' \
  '-c+[name the intermediary C file (with -compile)]:cfile:_files' \
  '-h+[name the intermediary C header (with -compile)]:hfile:_files' \
  '-data+[dump compiler data to file (with -compile)]:datafile:_files' \
  '-q[produce fewer notes when compiling]' \
  '-hp[enable relative package names]' \
  '-nohp[disable relative package names]' \
  '-s[produce a linkable object file]' \
  '*:script:_files' && ret=0

return ret
