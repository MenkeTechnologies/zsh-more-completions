#compdef movim
# Documentation: https://github.com/movim/movim
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (Movim is a Symfony Console app;
#   uses the standard Symfony 5.4+ `_complete` dynamic completion protocol).

# Zsh completion for movim — Symfony Console based daemon launcher.
#
# Based on the Symfony Console zsh completion template:
#   https://github.com/symfony/symfony/blob/6.4/src/Symfony/Component/Console/Resources/completion.zsh

_movim() {
    local lastParam flagPrefix requestComp out comp
    local -a completions

    # The user could have moved the cursor backwards on the command-line.
    # Truncate the command-line ($words) up to the $CURRENT location.
    words=("${=words[1,CURRENT]}") lastParam=${words[-1]}

    # For zsh, when completing a flag with an = (e.g., movim -n=<TAB>)
    # completions must be prefixed with the flag.
    setopt local_options BASH_REMATCH
    if [[ "${lastParam}" =~ '-.*=' ]]; then
        flagPrefix="-P ${BASH_REMATCH}"
    fi

    # Prepare the command to obtain completions
    requestComp="${words[0]} _complete --no-interaction -szsh -a1 -c$((CURRENT-1))"
    local i=""
    local w quote
    for w in ${words[@]}; do
        w=$(printf -- '%b' "$w")
        quote="${w:0:1}"
        if [ "$quote" = \' ]; then
            w="${w%\'}"
            w="${w#\'}"
        elif [ "$quote" = \" ]; then
            w="${w%\"}"
            w="${w#\"}"
        fi
        if [ ! -z "$w" ]; then
            i="${i}-i${w} "
        fi
    done

    if [ "${i}" = "" ]; then
        requestComp="${requestComp} -i\" \""
    else
        requestComp="${requestComp} ${i}"
    fi

    out=$(eval ${requestComp} 2>/dev/null)

    while IFS='\n' read -r comp; do
        if [ -n "$comp" ]; then
            comp=${comp//:/\\:}
            local tab=$(printf '\t')
            comp=${comp//$tab/:}
            completions+=${comp}
        fi
    done < <(printf "%s\n" "${out[@]}")

    eval _describe "completions" completions $flagPrefix
    return $?
}

compdef _movim movim
