#compdef pbmreduce
# Documentation: man pbmreduce (Netpbm)
# Source: shrink a PBM image by a factor of N with a chosen dither algorithm.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-floyd -fs -threshold)-floyd[Floyd-Steinberg dithering]' \
    '(-floyd -fs -threshold)-fs[Floyd-Steinberg dithering]' \
    '(-floyd -fs -threshold)-threshold[simple thresholding]' \
    '-value=[threshold value 0..1]:val:' \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:reduction factor N:' \
    '2:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
