#compdef jira
# Documentation: https://github.com/chrislo/jira
# Reference accessed: 2026-05-19
# Verified: upstream lib/jira/cli.rb at the URL above (RubyGem "jira" by chrislo).
# Note: only `list` or a ticket key (e.g. PROJ-123) are accepted; no other options.

local -a _1st_arguments
_1st_arguments=(
  'list:list all open issues assigned to you'
)

_arguments -C \
  ':command:->command' \
  '*::options:->options'

case $state in
  (command)
    _describe -t commands "jira action" _1st_arguments
    return
   ;;
esac
