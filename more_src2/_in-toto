#compdef in-toto
# _in-toto — secure software-supply-chain framework CLI (in-toto/in-toto-golang)
# upstream: https://github.com/in-toto/in-toto-golang
# Subcommands + flags from cmd/*.go (cobra).

_in-toto() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--spiffe-workload-api-path=[SPIFFE workload API UNIX socket path]:path:' \
        '--follow-symlink-dirs[follow symbolic links to directories]' \
        '--use-dsse[use DSSE envelope format for produced metadata]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_in-toto_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                run)
                    _arguments \
                        '(-n --name)'{-n+,--name=}'[name of the step (required)]:name:' \
                        '(-d --run-dir)'{-d+,--run-dir=}'[directory to run the command in]:dir:_files -/' \
                        '(-k --key)'{-k+,--key=}'[functionary private key file]:file:_files' \
                        '(-c --cert)'{-c+,--cert=}'[functionary X.509 certificate]:file:_files' \
                        '*'{-m+,--materials=}'[material paths (glob, repeatable)]:material:' \
                        '*'{-p+,--products=}'[product paths (glob, repeatable)]:product:' \
                        '--metadata-directory=[directory to write link metadata to]:dir:_files -/' \
                        '*--lstrip-paths=[prefixes to strip from recorded paths]:prefix:' \
                        '*--exclude=[glob patterns to exclude from artifact recording]:glob:' \
                        '--normalize-line-endings[normalize CRLF/CR to LF before hashing]' \
                        '--no-command[record materials/products without executing a command]' \
                        '*::cmd: _normal' && ret=0
                    ;;
                sign)
                    _arguments \
                        '(-f --file)'{-f+,--file=}'[layout or link file to sign]:file:_files' \
                        '(-k --key)'{-k+,--key=}'[signing key file]:file:_files' \
                        '(-o --output)'{-o+,--output=}'[output path for signed file]:file:_files' \
                        '--verify[verify the signature instead of signing]' && ret=0
                    ;;
                verify)
                    _arguments \
                        '(-l --layout)'{-l+,--layout=}'[layout file to verify]:file:_files' \
                        '*'{-k+,--layout-keys=}'[layout-signing public-key files]:file:_files' \
                        '(-d --link-dir)'{-d+,--link-dir=}'[directory containing link metadata]:dir:_files -/' \
                        '*'{-i+,--intermediate-certs=}'[intermediate-cert PEM files]:file:_files -g "*.pem"' \
                        '--normalize-line-endings[normalize CRLF/CR to LF before hashing]' && ret=0
                    ;;
                key)
                    local -a sub
                    sub=(
                        'id:print the key ID for a given key file'
                        'layout:emit a json pubkey suitable for embedding in a layout'
                    )
                    _describe -t key-subcommands 'in-toto key subcommand' sub
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_in-toto_commands] )) ||
_in-toto_commands() {
    local -a commands
    commands=(
        'run:execute a command, record materials/products, sign the link'
        'sign:sign an existing layout or link metadata file'
        'verify:verify the in-toto layout and its links'
        'key:key-management commands (id, layout)'
        'record:record materials/products manually without running a command'
        'match-products:match recorded products against the working directory'
        'gendoc:generate cobra command documentation'
        'completion:generate shell completion script'
        'help:help about any command'
    )
    _describe -t commands 'in-toto command' commands
}

_in-toto "$@"
