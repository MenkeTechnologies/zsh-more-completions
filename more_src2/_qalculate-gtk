#compdef qalculate-gtk
# _qalculate-gtk — GTK frontend for the Qalculate calculator (Qalculate/qalculate-gtk)
# upstream: https://github.com/Qalculate/qalculate-gtk
# Flags from src/main.cc (GOptionEntry).

_qalculate-gtk() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '(-f --file)'{-f+,--file=}'[execute expressions/commands from this file]:file:_files'
        '(-n --new-instance)'{-n,--new-instance}'[start a new application instance]'
        '--title=[set the window title]:title:'
        '--update-exchange-rates[update exchange rates and exit]'
        '*:expression:'
    )
    _arguments -s $args
}

_qalculate-gtk "$@"
