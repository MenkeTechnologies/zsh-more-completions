#compdef ffuf
# _ffuf-bin — Fast web fuzzer (Joohoi, Go); used for web app fuzzing, directory discovery in authorized pentests
# upstream: https://github.com/ffuf/ffuf

_ffuf-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-u+[target URL]:url:_urls' \
        '-w+[wordlist FILE\[:KEYWORD\]]:str:' \
        '-mode+[multi-wordlist mode]:mode:(clusterbomb pitchfork sniper)' \
        '-X+[HTTP method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
        '-H+[header]:str:' \
        '-b+[cookie]:str:' \
        '-d+[POST data]:data:' \
        '-D[output dir per host]' \
        '-recursion[recursive scan]' \
        '-recursion-depth+[max depth]:n:' \
        '-recursion-strategy+[strategy]:strategy:(default greedy)' \
        '-replay-proxy+[replay proxy]:proxy:' \
        '-x+[proxy URL]:url:_urls' \
        '-r[follow redirects]' \
        '-c[color output]' \
        '-o+[output file]:file:_files' \
        '-of+[output format]:fmt:(all json ejson html md csv ecsv)' \
        '-or+[only on response]:str:' \
        '-od+[output dir]:dir:_files -/' \
        '-mc+[match HTTP code]:codes:' \
        '-ml+[match line count]:n:' \
        '-ms+[match size]:n:' \
        '-mw+[match word count]:n:' \
        '-mr+[match regex]:regex:' \
        '-mt+[match response time]:duration:' \
        '-fc+[filter HTTP code]:codes:' \
        '-fl+[filter line count]:n:' \
        '-fs+[filter size]:n:' \
        '-fw+[filter word count]:n:' \
        '-fr+[filter regex]:regex:' \
        '-ft+[filter response time]:duration:' \
        '-rate+[req per second]:n:' \
        '-t+[concurrency]:n:' \
        '-timeout+[HTTP timeout]:sec:' \
        '-p+[seconds delay]:duration:' \
        '-maxtime+[max scan time]:sec:' \
        '-maxtime-job+[max time per job]:sec:' \
        '-s[silent]' \
        '-sa[stop on all error code]' \
        '-sf[stop on too many errors]' \
        '-se[stop on spurious errors]' \
        '-ic[ignore wordlist comments]' \
        '-input-cmd+[input command]:cmd:' \
        '-input-num+[number of inputs]:n:' \
        '-input-shell+[shell]:shell:_command_names -e' \
        '-config+[config file]:file:_files' \
        '-v[verbose]' \
        '-noninteractive[disable interactive]' \
        '*:URL:_urls'
}

_ffuf-bin "$@"
