#compdef rootrm
# Documentation: https://github.com/root-project/root/blob/master/main/src/rootrm.cxx
# Reference accessed: 2026-05-27
# Verified: upstream RCmdLineOpts AddFlag calls in main/src/rootrm.cxx

# rootrm: remove objects from ROOT files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-f --force)'{-f,--force}'[ignore nonexistent files; never prompt]' \
  '(-i --interactive)'{-i,--interactive}'[prompt before every removal]' \
  '(-n --dry-run)'{-n,--dry-run}'[preview removals without executing them]' \
  '(-r --recursive)'{-r,--recursive}'[recurse inside directories]' \
  '*'{-v,--verbose}'[verbose output (repeatable)]' \
  '*:file:_files -g "*.root"' && ret=0

return ret
