#compdef iwpriv
# Documentation: https://manpages.debian.org/iwpriv
# Source: HewlettPackard wireless-tools iwpriv.c — configure private 802.11 driver params (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--all[list private commands on all interfaces]' \
    '--help[show help]' \
    '--version[show version]' \
    '--roam[set roaming mode (on|off|auto)]' \
    '--port[set port type / connection type]' \
    '1::interface:_net_interfaces' \
    '2::private command:_default' \
    '*::param:_default' \
    && ret=0

return ret
