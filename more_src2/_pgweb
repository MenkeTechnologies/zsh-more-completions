#compdef pgweb
# Documentation: https://github.com/sosedoff/pgweb
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pgweb - web-based PostgreSQL browser

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-v,--version}'[print version]' \
  '(-d --debug)'{-d,--debug}'[enable debugging mode]' \
  '--log-level=[logging level]:level:(debug info warn error)' \
  '--log-format=[logging output format]:format:(text json)' \
  '--log-forwarded-user[log user from X-Forwarded headers]' \
  '--url=[database connection URL]:url:' \
  '--host=[database host]:host:_hosts' \
  '--port=[database port]:port:' \
  '--user=[database user]:user:' \
  '--pass=[password for user]:password:' \
  '--passfile=[passwords file location]:file:_files' \
  '--db=[database name]:database:' \
  '--ssl=[SSL mode]:mode:(disable allow prefer require verify-ca verify-full)' \
  '--ssl-rootcert=[SSL CA file]:file:_files' \
  '--ssl-cert=[SSL client cert file]:file:_files' \
  '--ssl-key=[SSL client cert key file]:file:_files' \
  '--open-timeout=[max wait for connection in sec]:seconds:' \
  '--open-retry-delay=[wait sec before retry]:seconds:' \
  '--open-retry=[number of retries]:n:' \
  '--bind=[HTTP server host]:host:' \
  '--listen=[HTTP server listen port]:port:' \
  '--auth-user=[HTTP basic auth user]:user:' \
  '--auth-pass=[HTTP basic auth password]:password:' \
  '(-s --skip-open)'{-s,--skip-open}'[do not open browser on start]' \
  '--sessions[enable multiple database sessions]' \
  '--prefix=[URL prefix]:prefix:' \
  '--readonly[run in read-only mode]' \
  '--lock-session[lock session to single connection]' \
  '(-b --bookmark)'{-b,--bookmark=}'[bookmark to use]:bookmark:' \
  '--bookmarks-dir=[bookmarks directory]:directory:_directories' \
  '--bookmarks-only[allow only bookmarks connections]' \
  '--queries-dir=[local queries directory]:directory:_directories' \
  '--no-pretty-json[disable JSON pretty formatting]' \
  '--no-ssh[disable SSH connections]' \
  '--connect-backend=[third-party connect backend URL]:url:' \
  '--connect-token=[third-party connect token]:token:' \
  '--connect-headers=[headers to pass to backend]:headers:' \
  '--no-idle-timeout[disable idle timeout]' \
  '--idle-timeout=[idle timeout in minutes]:minutes:' \
  '--query-timeout=[query timeout in seconds]:seconds:' \
  '--cors[enable CORS]' \
  '--cors-origin=[CORS allowed origin]:origin:' \
  '--binary-codec=[binary data codec]:codec:(none hex base58 base64)' \
  '--metrics[enable Prometheus metrics]' \
  '--metrics-path=[Prometheus metrics path]:path:' \
  '--metrics-addr=[Prometheus listen addr]:addr:' && ret=0

return ret
