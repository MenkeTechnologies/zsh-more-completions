# -----------------------------------------------------------------------------
#
# WHAT IS fsnotify AND WHY IS IT THE 71ST Go CLI LIBRARY?
#
# fsnotify is the canonical Go filesystem-event library — so
# widely adopted that "use fsnotify" is the de facto Go answer
# to "how do I watch a file for changes?"  Distinct from Go's
# stdlib which has NO file-watching API (unlike Node.js's
# fs.watch which exists but is unreliable across platforms).
#
# Five distinguishing characteristics from notify (R653):
#
#   1. CHANNEL-FIRST API — Watcher exposes two channels:
#         watcher.Events <-chan fsnotify.Event
#         watcher.Errors <-chan error
#      Distinct from notify's closure-passing constructor.
#      Channel-based design integrates naturally with Go's
#      select{} idiom:
#         for {
#           select {
#           case ev, ok := <-watcher.Events:
#             if !ok { return }
#             switch {
#             case ev.Op&fsnotify.Create != 0:  handleCreate(ev)
#             case ev.Op&fsnotify.Write  != 0:  handleWrite(ev)
#             case ev.Op&fsnotify.Remove != 0:  handleRemove(ev)
#             case ev.Op&fsnotify.Rename != 0:  handleRename(ev)
#             case ev.Op&fsnotify.Chmod  != 0:  handleChmod(ev)
#             }
#           case err := <-watcher.Errors:
#             log.Printf("watch err: %v", err)
#           }
#         }
#
#   2. BIT-FLAG Op INSTEAD OF ENUM — single fsnotify.Op type
#      with bit-flag constants (Create | Write | Remove | Rename
#      | Chmod) reportable in a single Event.  Distinct from
#      notify's EventKind enum + nested subkinds.
#
#   3. NO RECURSIVE WATCH IN CORE — caller manually walks
#      directories.  Distinct from notify's RecursiveMode flag.
#      Design choice: keep core minimal; supplementary packages
#      (fsnotify/fsnotify recursive subpackages) optional.
#
#   4. SOLARIS FEN SUPPORT — beyond Linux/macOS/Windows/BSDs,
#      fsnotify supports Solaris's File Events Notification
#      (FEN) syscall.  notify does NOT (only Linux/macOS/Windows/
#      BSDs).
#
#   5. FSNOTIFY-ORG / COMMUNITY-MAINTAINED — distinct from
#      Sean McArthur (Hyperium / reqwest), Mathew Roy (go-resty),
#      Tolnay (serde), Sindre Sorhus.  fsnotify is owned by a
#      multi-maintainer community organization (originally
#      Chris Howey + Nathan Youngman, now various contributors).
#
# -----------------------------------------------------------------------------
#
# THE mbtileserver CLI — cobra + fsnotify + echo + autocert
#
# mbtileserver's CLI is in main.go.  Uses spf13/cobra with
# rootCmd + flag definitions.
#
# Flags:
#       --host HOST              IP to listen on (default 0.0.0.0)
#   -p, --port PORT              server port (default 443 if --tls/--cert,
#                                else 8000)
#   -d, --dir DIR                directory with .mbtiles files (default
#                                ./tilesets, comma-delimited list)
#       --generate-ids           auto-generate tileset IDs
#   -c, --cert FILE              X.509 TLS certificate
#   -k, --key FILE               TLS private key
#       --root-url URL           root URL of services endpoint
#                                (default /services)
#       --domain DOMAIN          domain name (for Auto TLS only)
#   -s, --secret-key KEY         HMAC shared secret for auth
#   -t, --tls                    Auto TLS via Let's Encrypt
#   -r, --redirect               redirect HTTP to HTTPS
#       --enable-arcgis          enable ArcGIS Mapserver endpoints
#       --enable-fs-watch        enable filesystem watching of tileset dir
#       --enable-reload-signal   enable HUP-signal graceful reload
#       --disable-preview        disable map preview page
#       --disable-tilejson       disable TileJSON endpoint
#       --disable-svc-list       disable services list endpoint
#       --tiles-only             only enable tile endpoints (combo)
#       --dsn DSN                Sentry DSN
#       --basemap-style-url URL  basemap style URL for preview
#       --basemap-tiles-url URL  basemap raster tiles URL pattern
#       --missing-image-tile-404 return 404 instead of blank PNG
#                                for missing tiles
#   -v, --verbose                verbose logging
#
# fsnotify is used in watch.go:
#     watcher, err := fsnotify.NewWatcher()
#     for { select {
#       case event := <-watcher.Events:
#         if event.Op&fsnotify.Create == fsnotify.Create ||
#            event.Op&fsnotify.Write  == fsnotify.Write  ||
#            event.Op&fsnotify.Remove == fsnotify.Remove ||
#            event.Op&fsnotify.Rename == fsnotify.Rename {
#           reloadTilesets(event.Name)
#         }
#       case err := <-watcher.Errors:
#         log.Printf("watch err: %v", err)
#     } }
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/consbio/mbtileserver/blob/master/main.go
# cobra flags.StringVar / BoolVarP / IntVarP definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--host=[IP address to listen on]:host:_default' \
    '(-p --port)'{-p+,--port=}'[server port]:port:_default' \
    '(-d --dir)'{-d+,--dir=}'[directory containing mbtiles files (comma-delimited)]:directory:_files -/' \
    '--generate-ids[automatically generate tileset IDs]' \
    '(-c --cert)'{-c+,--cert=}'[X.509 TLS certificate filename]:cert:_files' \
    '(-k --key)'{-k+,--key=}'[TLS private key]:key:_files' \
    '--root-url=[root URL of services endpoint]:url:_default' \
    '--domain=[domain name (for Auto TLS)]:domain:_default' \
    '(-s --secret-key)'{-s+,--secret-key=}'[HMAC shared secret key]:key:_default' \
    '(-t --tls)'{-t,--tls}'[Auto TLS via Lets Encrypt (requires --domain)]' \
    '(-r --redirect)'{-r,--redirect}'[redirect HTTP to HTTPS]' \
    '--enable-arcgis[enable ArcGIS Mapserver endpoints]' \
    '--enable-fs-watch[enable reloading of tilesets by watching filesystem (uses fsnotify)]' \
    '--enable-reload-signal[enable graceful reload via SIGHUP]' \
    '--disable-preview[disable map preview page]' \
    '--disable-tilejson[disable TileJSON endpoint]' \
    '--disable-svc-list[disable services list endpoint]' \
    '--tiles-only[only enable tile endpoints]' \
    '--dsn=[Sentry DSN]:dsn:_default' \
    '--basemap-style-url=[basemap style URL for preview]:url:_default' \
    '--basemap-tiles-url=[basemap raster tiles URL pattern]:url:_default' \
    '--missing-image-tile-404[return HTTP 404 for missing image tiles]' \
    '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
