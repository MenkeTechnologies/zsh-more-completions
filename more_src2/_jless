#compdef jless
# Documentation: https://github.com/PaulJuliusMartinez/jless/blob/main/src/options.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for jless - A command-line JSON viewer.
# Added the four line-number flags and the -m short form for --mode
# per the upstream clap option definitions; -V is the version short.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-m --mode)'{-m,--mode}'=[initial viewing mode]:mode:(line data)' \
  '(-n --line-numbers)'{-n,--line-numbers}'[show absolute line numbers]' \
  '(-N --no-line-numbers)'{-N,--no-line-numbers}'[do not show absolute line numbers]' \
  '(-r --relative-line-numbers)'{-r,--relative-line-numbers}'[show relative line numbers]' \
  '(-R --no-relative-line-numbers)'{-R,--no-relative-line-numbers}'[do not show relative line numbers]' \
  '--scrolloff=[number of lines to maintain as padding]:lines:' \
  '--json[force interpretation of input as JSON]' \
  '--yaml[force interpretation of input as YAML]' \
  '*:file:_files -g "*.{json,yaml,yml}"' && ret=0

return ret
