#compdef dcmicmp
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmicmp.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmimage/apps/dcmicmp.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmimage/apps/dcmicmp.cc OFCommandLine setup + docs/man/dcmicmp.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(-M --no-modality)'{-M,--no-modality}'[ignore stored modality LUT transformation]' \
  '(+M --use-modality)'{+M,--use-modality}'[use modality LUT transformation (default)]' \
  '(-W --no-windowing)'{-W,--no-windowing}'[no VOI windowing (default)]' \
  '(+Wi --use-window)'{+Wi+,--use-window=}'[use n-th VOI window from image file]:n:' \
  '(+Wl --use-voi-lut)'{+Wl+,--use-voi-lut=}'[use n-th VOI look up table from image file]:n:' \
  '(+Wm --min-max-window)'{+Wm,--min-max-window}'[compute VOI window using min-max algorithm]' \
  '(+Wn --min-max-window-n)'{+Wn,--min-max-window-n}'[compute VOI window using min-max, ignoring extremes]' \
  '(+Wr --min-max-ref)'{+Wr,--min-max-ref}'[compute VOI window and use same window for test image]' \
  '(+Wq --min-max-n-ref)'{+Wq,--min-max-n-ref}'[compute VOI window ignoring extremes, use for test image]' \
  '(+Ww --set-window)'{+Ww+,--set-window=}'[compute VOI window using center c and width w]:center width:' \
  '(+Wfl --linear-function)'{+Wfl,--linear-function}'[set VOI LUT function to LINEAR]' \
  '(+Wfs --sigmoid-function)'{+Wfs,--sigmoid-function}'[set VOI LUT function to SIGMOID]' \
  '(+Pid --identity-shape)'{+Pid,--identity-shape}'[set presentation LUT shape to IDENTITY]' \
  '(+Piv --inverse-shape)'{+Piv,--inverse-shape}'[set presentation LUT shape to INVERSE]' \
  '(+Pod --lin-od-shape)'{+Pod,--lin-od-shape}'[set presentation LUT shape to LIN OD]' \
  '(+ce --check-error)'{+ce+,--check-error=}'[check if max absolute error <= limit]:limit:' \
  '(+cm --check-mae)'{+cm+,--check-mae=}'[check if mean absolute error <= limit]:limit:' \
  '(+cr --check-rmse)'{+cr+,--check-rmse=}'[check if root mean square error <= limit]:limit:' \
  '(+cp --check-psnr)'{+cp+,--check-psnr=}'[check if PSNR >= limit]:limit:' \
  '(+cs --check-snr)'{+cs+,--check-snr=}'[check if SNR >= limit]:limit:' \
  '(+sd --save-diff)'{+sd+,--save-diff=}'[write secondary capture difference image]:filename:_files' \
  '(+a --amplify)'{+a+,--amplify=}'[multiply diff image pixel values by f]:factor:' \
  '1:dcmfile-in-1:_files' \
  '2:dcmfile-in-2:_files'
