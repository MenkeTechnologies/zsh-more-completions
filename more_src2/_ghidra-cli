#compdef ghidra-cli
# _ghidra-cli — NSA Ghidra software reverse engineering framework CLI alias (NationalSecurityAgency team, Java); custom argparse
# upstream: https://github.com/NationalSecurityAgency/ghidra

_ghidra-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-import+[file to import]:file:_files' \
        '-process[run scripts on already imported file]' \
        '-recursive[recurse into directories]' \
        '-readOnly[read-only mode]' \
        '-deleteProject[delete project after run]' \
        '-noanalysis[skip auto analysis]' \
        '-processor=+[language]:str:' \
        '-cspec=+[compiler spec]:str:' \
        '-loader=+[loader name]:str:' \
        '-loaderArgs=+[loader args]:str:' \
        '-prescript=+[pre-script]:str:' \
        '-postscript=+[post-script]:str:' \
        '-script=+[script name]:str:' \
        '-scriptPath=+[path]:dir:_files -/' \
        '-propertiesPath=+[path]:file:_files' \
        '-scriptlog=+[log file]:file:_files' \
        '-log=+[log file]:file:_files' \
        '-overwrite[overwrite existing]' \
        '-keystore=+[keystore file]:file:_files' \
        '-connect=+[user@host]:str:' \
        '-p+[password]:str:' \
        '-commit=+[message]:str:' \
        '-okToDelete[ok to delete]' \
        '-max-cpu=+[cpu count]:n:' \
        '-analysisTimeoutPerFile=+[seconds]:n:' \
        '-okToDeleteOnNoAnalysis[ok to delete on no analysis]' \
        '-loaderHash=+[hash]:str:' \
        '-jvm-args=+[args]:str:' \
        '*:project path:_files -g "*.gpr"'
}

_ghidra-cli "$@"
