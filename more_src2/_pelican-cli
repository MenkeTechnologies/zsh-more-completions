#compdef pelican-cli pelican
# _pelican-cli — Pelican static site generator CLI alias (getpelican team, Python); argparse
# upstream: https://github.com/getpelican/pelican

_pelican-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--print-settings[print settings]' \
        '-p+[settings]:str:' \
        '-t+[theme path]:dir:_files -/' \
        '--theme-path=+[theme path]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-s+[settings file]:file:_files -g "*.py"' \
        '--settings=+[settings file]:file:_files -g "*.py"' \
        '-d[delete output dir]' \
        '--delete-output-directory[delete output dir]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-D[debug]' \
        '--debug[debug]' \
        '-r[autoreload]' \
        '--autoreload[autoreload]' \
        '--ignore-cache[ignore cache]' \
        '--relative-urls[relative urls]' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '-l[listen]' \
        '--listen[listen]' \
        '-b+[bind address]:host:_hosts' \
        '--bind=+[bind address]:host:_hosts' \
        '-P+[port]:port:' \
        '--port=+[port]:port:' \
        '--server[run dev server]' \
        '--fatal=+[fatal warnings]:f:(errors warnings)' \
        '-n+[fatal warnings]:f:(errors warnings)' \
        '--logs-dedup-min-level=+[log level]:l:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '-w+[write selected]:str:' \
        '--write-selected=+[write selected]:str:' \
        '-M[lookup mode]' \
        '--no-respect-no-index[ignore noindex]' \
        '--respect-no-index[respect noindex]' \
        '*:content path:_files'
}

_pelican-cli "$@"
