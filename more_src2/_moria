#compdef moria
# Documentation: https://manpages.debian.org/buster/moria/moria.6.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Moria: classic roguelike (mines of Moria)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-o[force VMS-style command set]' \
  '-r[rogue-style movement]' \
  '-s[print all scores and exit]' \
  '-S[print only your scores and exit]' \
  '-n[create new game, ignoring any savefile]' \
  '-w[wizard mode]' \
  '*:savefile:_files' && ret=0
return ret
