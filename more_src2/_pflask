#compdef pflask
# Documentation: https://ghedo.github.io/pflask/pflask.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --chroot)'{-r+,--chroot=}'[change root directory inside container]:dir:_files -/' \
  '(-c --chdir)'{-c+,--chdir=}'[change working directory inside container]:dir:_files -/' \
  '(-t --hostname)'{-t+,--hostname=}'[set container hostname]:hostname:' \
  '(-u --user)'{-u+,--user=}'[user inside container]:user:_users' \
  '(-e --user-map)'{-e+,--user-map=}'[user/group map]:map:' \
  '(-w --ephemeral)'{-w,--ephemeral}'[discard / changes on container exit]' \
  '(-d --detach)'{-d,--detach}'[detach from current terminal]' \
  '(-a --attach)'{-a+,--attach=}'[attach to detached container]:pid:' \
  '*'{-s+,--setenv=}'[set env var]:var:' \
  '(-k --keepenv)'{-k,--keepenv}'[preserve existing environment]' \
  '*'{-m+,--mount=}'[mount type:opts]:mount:' \
  '(-n --netif)'{-n+,--netif=}'[isolate container networking]:opts:' \
  '*'{-g+,--cgroup=}'[create new cgroup]:controller:' \
  '(-U --no-userns)'{-U,--no-userns}'[disable user namespace]' \
  '(-M --no-mountns)'{-M,--no-mountns}'[disable mount namespace]' \
  '(-N --no-netns)'{-N,--no-netns}'[disable net namespace]' \
  '(-I --no-ipcns)'{-I,--no-ipcns}'[disable IPC namespace]' \
  '(-H --no-utsns)'{-H,--no-utsns}'[disable UTS namespace]' \
  '(-P --no-pidns)'{-P,--no-pidns}'[disable PID namespace]' \
  '*:: command :_command_names' && ret=0

return ret
