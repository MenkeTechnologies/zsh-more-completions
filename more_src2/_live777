#compdef live777 liveman livenil livecam livevod whepfrom net4mqtt
# ============================================================================
# _live777 — zsh completion for binbat/live777, "a very simple, high
#             performance, edge WebRTC SFU".  Covers the 7 live777-workspace
#             binaries not already wired via _whipinto: live777 (the SFU
#             server), liveman (multi-instance cluster manager), livenil
#             (lightweight standalone), livecam (camera ingest with
#             gen-hash subcommand), livevod (VOD playback server),
#             whepfrom (WHEP → RTSP/RTP egress), net4mqtt (MQTT-tunneled
#             SOCKS5/forward stack).
#             Rust=154 leader bump OPENING Axis 99 WebRTC / webrtc-rs.
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/binbat/live777
#   Maintainer : BinBat Ltd <hey@binbat.com>
#   License    : MPL-2.0
#   Stars      : 305
#   Language   : Rust (workspace, edition 2024)
#   Crate      : live777  (workspace root)
#   Binaries   : live777   (SFU server — `src/main.rs`)
#                liveman   (multi-instance manager — `src/liveman.rs`)
#                livenil   (lightweight standalone — `src/livenil.rs`)
#                livecam   (camera ingest — `src/livecam.rs`)
#                livevod   (VOD playback server — `src/livevod.rs`)
#                whepfrom  (WHEP → RTSP/RTP egress — `src/whepfrom.rs`)
#                whipinto  (RTSP/RTP → WHIP ingest — `src/whipinto.rs`;
#                           already covered by `_whipinto`)
#                net4mqtt  (MQTT-tunneled forwarder — `src/net4mqtt.rs`)
#   Last push  : 2026-05-29
#
# WHAT IT IS
#   live777 is a Selective Forwarding Unit for WebRTC media that
#   speaks WHIP/WHEP — the two HTTP-Ingestion / HTTP-Egress
#   Protocols that pair plain HTTP signaling with WebRTC media.
#   The workspace ships a complete edge media stack:
#
#     live777   — the SFU itself; accepts WHIP ingest, fans out to
#                 WHEP subscribers, exposes a `/admin` API, and
#                 publishes liveion-cluster metrics.
#     liveman   — a multi-instance manager that schedules SFU
#                 streams across a cluster of live777 nodes.
#     livenil   — a single-stream lightweight SFU for embedded /
#                 IoT deployments.
#     livecam   — RTSP/USB camera ingest endpoint, with a
#                 `gen-hash` subcommand for offline credential
#                 generation.
#     livevod   — a VOD playback server speaking the same WHEP
#                 egress protocol against recorded files.
#     whepfrom  — egress: subscribe to a WHEP URL, emit
#                 RTSP/RTP/SDP locally; optional DataChannel ↔
#                 UDP forwarding.
#     whipinto  — ingest counterpart (separately wired via
#                 `_whipinto`).
#     net4mqtt  — independent MQTT-based SOCKS5/proxy stack
#                 reused by the WebRTC datachannel side of the
#                 live777 control plane.
#
# CLI ARGUMENT GRAMMAR  (verbatim from per-binary `src/*.rs`
#                       clap-derive `Args` structs, extracted
#                       via `gh api repos/binbat/live777/
#                       contents/src/*.rs`)
#
#   live777 [OPTIONS]
#     -v...                          Verbose mode  (count;
#                                    default warn, -v info,
#                                    -vv debug, -vvv trace)
#     -c, --config <PATH>            Config file path
#                                    [default: live777.toml]
#     --help                         Show help
#     --version                      Show version
#
#   liveman [OPTIONS]                  Same surface as live777,
#                                    but the default config name
#                                    is `liveman.toml`.
#     -v...
#     -c, --config <PATH>            [default: liveman.toml]
#     --help
#     --version
#
#   livenil [OPTIONS]                  Standalone mode — no
#                                    verbosity flag, single
#                                    config option.
#     -c, --config <PATH>            [default: livenil]
#     --help
#     --version
#
#   livecam [OPTIONS] [SUBCOMMAND]   Camera ingest with one
#                                    offline subcommand.
#     -c, --config <PATH>            [default: livecam.toml]
#     --help
#     --version
#
#     gen-hash                       Generate a password hash
#                                    for inclusion in
#                                    livecam.toml
#       -p, --password <PASS>          Plaintext password
#                                      (optional — will prompt
#                                      if absent)
#
#   livevod                            VOD playback server —
#                                    fully config-file driven
#                                    (no clap Args struct;
#                                    listens on
#                                    `0.0.0.0:8899` by default).
#     --help
#     --version
#
#   whepfrom --whep <URL> [OPTIONS]
#     -v...                          Verbose mode
#     -o, --output <URI>             RTSP/RTP/SDP egress URI
#                                    [default: rtsp://0.0.0.0:8555]
#     -w, --whep <URL>               WHEP server endpoint to
#                                    POST SDP offer to
#                                    (required)
#     --sdp-file <PATH>              SDP filename to write to
#                                    (used in RTP mode)
#                                    [default: output.sdp]
#     -t, --token <TOKEN>            Bearer token for the WHEP
#                                    endpoint
#     --command <CMD>                Run a command as a
#                                    childprocess
#     --channel <URL>                Channel URL for DataChannel
#                                    ↔ UDP forwarding
#
#   net4mqtt [OPTIONS] <SUBCOMMAND>
#     -v...                          Verbose mode
#     -c, --config <PATH>            Config file path
#
#     Subcommands:
#       local-socks                  Local SOCKS5 proxy mode
#         -m, --mqtt-url <URL>         MQTT broker URL
#                                      [default:
#                                      mqtt://localhost:1883/
#                                      net4mqtt]
#         -l, --listen <ADDR>          SOCKS5 listen address
#                                      [default: 127.0.0.1:4444]
#         -d, --domain <DOMAIN>        Built-in DNS suffix
#                                      [default:
#                                      net4mqtt.local]
#         -a, --agent-id <ID>          Default agent id used
#                                      when DNS lookup fails
#                                      [default: -]
#         -i, --id <ID>                Current local id
#                                      [default: -]
#       local-ports                  Local port-forwarding mode
#       agent                        Agent (server) mode
#       proxy                        Bridge between two MQTT
#                                    brokers
#
#   Standard clap auto-flags  (all binaries):
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `webrtc` (from git
#   `https://github.com/webrtc-rs/webrtc`, rev `4da5280`) and
#   `sdp` (same rev) declared in `[workspace.dependencies]` of
#   Cargo.toml — `webrtc-rs/webrtc` is THE canonical Rust
#   WebRTC stack (webrtc-rs/webrtc, 4,600+ stars; a pure-Rust
#   reimplementation of the WebRTC protocol stack that the
#   Pion Go reference implementation pioneered).  webrtc-rs
#   exposes the typed `webrtc::api::API` factory with
#   `APIBuilder::new().with_media_engine(m).with_interceptor_
#   registry(i).build()`, the typed `RTCPeerConnection`
#   constructor + every standards-compliant
#   `peer_connection.create_offer` /
#   `peer_connection.create_answer` /
#   `peer_connection.set_local_description` /
#   `peer_connection.set_remote_description` /
#   `peer_connection.add_ice_candidate` /
#   `peer_connection.add_transceiver_from_kind` /
#   `peer_connection.add_track` /
#   `peer_connection.create_data_channel` /
#   `peer_connection.close` request + response model, the
#   typed `RTCDataChannel` with
#   `data_channel.on_message`/`on_open`/`on_close`/`send`,
#   the typed `RTCSessionDescription` /
#   `RTCSessionDescriptionInit` / `RTCIceCandidate` /
#   `RTCIceServer` / `RTCConfiguration` /
#   `RTCRtpTransceiver` / `RTCRtpSender` /
#   `RTCRtpReceiver` / `RTCRtpCodecParameters` /
#   `RTCRtpCodecCapability` / `RTPCodecType` /
#   `RTPCodecParameters` / `RTPHeaderExtensionCapability`
#   schemas, the `webrtc::media::*` Sample/Track primitives
#   (`TrackLocal`, `TrackLocalStaticSample`,
#   `TrackLocalStaticRTP`, `TrackRemote`), the
#   `webrtc::interceptor::*` registry (NACK, TWCC, REMB, ULPFEC,
#   RTX), the `webrtc::ice_transport::*` ICE stack with
#   trickle ICE and Half-Trickle, the `webrtc::data_channel::*`
#   SCTP transport, the `webrtc::dtls_transport::*` DTLS-SRTP
#   transport, the SRTP/SRTCP `webrtc::srtp::*` ciphers, the
#   stats API (`peer_connection.get_stats`), and the bundled
#   `sdp` crate for parsing + serializing Session Description
#   Protocol payloads.  live777's `liveion::serve(cfg,
#   listener, shutdown_signal)` constructs a per-stream
#   `APIBuilder` + `RTCPeerConnection`, handles the WHIP POST
#   to install the publisher transceivers, and fans out tracks
#   to each WHEP subscriber via cloned `TrackLocalStaticRTP`
#   instances.  Verified via:
#     gh api repos/binbat/live777/contents/Cargo.toml
#       → [workspace.dependencies]
#         webrtc = { git = "https://github.com/webrtc-rs/
#                            webrtc", rev = "4da5280" }
#         sdp = { git = "https://github.com/webrtc-rs/webrtc",
#                  rev = "4da5280" }
#       → clap = "4.5"
#       → axum = "0.8"
#       → tokio = "1.47"
#       → [[bin]] live777 / liveman / livenil / livecam /
#                  whipinto / whepfrom / livevod / net4mqtt
#     gh api repos/binbat/live777/contents/src/main.rs
#       → #[derive(Parser)] struct Args { verbose: u8,
#                                          config: String }
#     gh api repos/binbat/live777/contents/src/{liveman,
#         livenil,livecam,whepfrom,net4mqtt}.rs
#       → per-binary clap-derive Args + subcommands as
#         documented above
#   This entry is the Rust=154 leader bump that OPENS Axis 99
#   (WebRTC / webrtc-rs protocol stack) at 1/0/0.  Pairing Go
#   and TS-Node bumps will follow at R986 and R987 (Go=154
#   candidates pion/webrtc-based CLIs; TS-Node=154 candidates
#   simple-peer / wrtc / @roamhq/wrtc users).
#
#   No completion for live777 / liveman / livenil / livecam /
#   livevod / whepfrom / net4mqtt ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_live777() {
    case "${service:-${words[1]}}" in
        live777)
            _arguments -s \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*-v[verbose mode (-v info, -vv debug, -vvv trace)]' \
                '(-c --config)'{-c,--config}'=[config file path (default live777.toml)]:config:_files -g "*.toml"' ;;
        liveman)
            _arguments -s \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*-v[verbose mode]' \
                '(-c --config)'{-c,--config}'=[config file path (default liveman.toml)]:config:_files -g "*.toml"' ;;
        livenil)
            _arguments -s \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '(-c --config)'{-c,--config}'=[config file path (default livenil)]:config:_files' ;;
        livecam)
            _arguments -C \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '(-c --config)'{-c,--config}'=[config file path (default livecam.toml)]:config:_files -g "*.toml"' \
                '1::subcommand:(gen-hash)' \
                '*::arg:->args'
            case $state in
                args)
                    case $words[1] in
                        gen-hash)
                            _arguments \
                                '(-p --password)'{-p,--password}'=[plaintext password]:password:' ;;
                    esac ;;
            esac ;;
        livevod)
            _arguments -s \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' ;;
        whepfrom)
            _arguments -s \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*-v[verbose mode]' \
                '(-o --output)'{-o,--output}'=[RTSP/RTP/SDP egress URI (default rtsp://0.0.0.0:8555)]:uri:' \
                '(-w --whep)'{-w,--whep}'=[WHEP server endpoint to POST SDP offer to]:url:' \
                '--sdp-file=[SDP filename to write to (RTP mode, default output.sdp)]:sdp:_files -g "*.sdp"' \
                '(-t --token)'{-t,--token}'=[Bearer token for WHEP endpoint]:token:' \
                '--command=[run a command as a childprocess]:command:_command_names -e' \
                '--channel=[channel URL for DataChannel <-> UDP forwarding]:url:' ;;
        net4mqtt)
            _arguments -C \
                '(- *)--help[show help]' \
                '(- *)'{-V,--version}'[show version]' \
                '*-v[verbose mode]' \
                '(-c --config)'{-c,--config}'=[config file path]:config:_files' \
                '1: :_net4mqtt_commands' \
                '*::arg:->args'
            case $state in
                args)
                    case $words[1] in
                        local-socks)
                            _arguments \
                                '(-m --mqtt-url)'{-m,--mqtt-url}'=[MQTT broker URL (default mqtt://localhost:1883/net4mqtt)]:url:' \
                                '(-l --listen)'{-l,--listen}'=[SOCKS5 listen address (default 127.0.0.1:4444)]:addr:' \
                                '(-d --domain)'{-d,--domain}'=[built-in DNS suffix (default net4mqtt.local)]:domain:' \
                                '(-a --agent-id)'{-a,--agent-id}'=[default agent id used when DNS lookup fails]:id:' \
                                '(-i --id)'{-i,--id}'=[current local id]:id:' ;;
                        local-ports|agent|proxy)
                            _arguments '*: :' ;;
                    esac ;;
            esac ;;
    esac
}

(( $+functions[_net4mqtt_commands] )) ||
_net4mqtt_commands() {
    local -a commands
    commands=(
        'local-socks:local SOCKS5 proxy mode'
        'local-ports:local port-forwarding mode'
        'agent:agent (server) mode'
        'proxy:bridge between two MQTT brokers'
    )
    _describe -t commands 'net4mqtt command' commands
}

_live777 "$@"
