#compdef reprotest
# Documentation: https://manpages.debian.org/reprotest
# Source: SantiagoTorres/reprotest reprotest/__init__.py — reproducible-builds test runner (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help-[show help (or per-virtual-server help)]::server:(null adt-virt-chroot adt-virt-lxc adt-virt-lxd adt-virt-qemu adt-virt-ssh adt-virt-schroot)' \
    '--verbosity=-[verbosity level (integer)]:level:_default' \
    '--config-file=-[config file]:file:_files' \
    '--source-root=-[source tree root]:path:_files -/' \
    '--store-dir=-[directory to save artifacts]:dir:_files -/' \
    '--testbed-pre=-[shell commands before starting testbed]:cmds:_default' \
    '--testbed-init=-[shell commands after starting testbed]:cmds:_default' \
    '--auto-preset-expr=-[python expression to transform presets]:expr:_default' \
    '--variations=-[comma-separated variations to test]:variations:_default' \
    '--dont-vary=-[comma-separated variations not to test]:variations:_default' \
    '*--diffoscope-arg=-[pass extra arg to diffoscope]:arg:_default' \
    '--no-diffoscope[use diff(1) instead of diffoscope]' \
    '--no-clean-on-error[do not clean virtual_server on error]' \
    '1::build command (or "auto"):_default' \
    '2::artifact pattern:_files' \
    '*::virtual_server args:_default' \
    && ret=0

return ret
