#compdef node-pg-migrate
# ============================================================================
# node-pg-migrate - PostgreSQL database migration
#                    management tool for Node.js
#                    (TypeScript -> Node, MIT)
#
# Author : Salsita Software (salsita)
# Upstream: https://github.com/salsita/node-pg-migrate
# npm    : node-pg-migrate (binary:
#           node-pg-migrate)
#
# `node-pg-migrate` is the canonical Node.js
# Postgres migration management tool. It tracks
# migrations in a per-application table
# (default `pgmigrations`), supports up/down/redo
# operations, lets users author migrations in JS /
# TS / SQL / CJS / MJS / CTS / MTS, and uses
# brianc/node-postgres (`pg`) for the underlying
# Postgres protocol connection. Users typically
# pair node-pg-migrate with a CI/CD pipeline that
# runs `node-pg-migrate up` on deploy + a developer
# workflow that uses `node-pg-migrate create` to
# scaffold new migration files.
#
# Usage:
#   node-pg-migrate <command> [migration-name]
#                   [options]
#
# Commands (yargs):
#   up [N]               - apply N pending migrations
#                           (default: all pending)
#   down [N]             - revert N applied migrations
#                           (default: 1)
#   create <name>        - scaffold a new migration
#                           file
#   redo [N]             - down + up the last N
#                           migrations
#
# Common flags (yargs):
#   -d, --database-url-var <name>      - env var
#                                         holding the
#                                         database URL
#                                         (default
#                                         DATABASE_URL)
#   -m, --migrations-dir <dir>         - migrations
#                                         directory
#                                         (default
#                                         "migrations")
#       --use-glob                     - treat
#                                         --migrations-
#                                         dir as a
#                                         glob pattern
#   -t, --migrations-table <name>      - migrations
#                                         tracking
#                                         table name
#                                         (default
#                                         "pgmigrations")
#   -s, --schema <name>                - target
#                                         schema(s)
#                                         (default
#                                         "public";
#                                         repeatable)
#       --create-schema                - create the
#                                         target schema
#                                         if missing
#       --migrations-schema <name>     - schema for
#                                         the tracking
#                                         table
#                                         (default:
#                                         same as
#                                         --schema)
#       --create-migrations-schema     - create the
#                                         migrations
#                                         schema if
#                                         missing
#       --check-order                  - verify
#                                         migration
#                                         order
#                                         (default
#                                         true)
#       --verbose                      - print all DB
#                                         statements
#                                         executed
#                                         (default
#                                         true)
#       --ignore-pattern <regex>       - skip files
#                                         matching
#                                         regex/glob
#                                         (default
#                                         "\..*")
#       --decamelize                   - run
#                                         decamelize
#                                         on object
#                                         names
#       --config-value <name>          - config
#                                         section
#                                         name
#                                         (default
#                                         "db")
#   -f, --config-file <file>           - external
#                                         config file
#                                         path
#   -j, --migration-file-language <l>  - new
#                                         migration
#                                         language:
#                                         js/ts/sql/
#                                         cjs/mjs/cts/
#                                         mts (only
#                                         with create)
#       --migration-filename-format <fmt>
#                                       - timestamp /
#                                         utc / index
#                                         (only with
#                                         create)
#       --template-file-name <path>    - migration
#                                         file template
#       --envPath <file>               - path to
#                                         .env file
#       --dry-run                      - print SQL
#                                         without
#                                         running
#       --fake                         - mark
#                                         migrations
#                                         as run
#                                         without
#                                         executing
#       --single-transaction           - wrap all
#                                         pending
#                                         migrations
#                                         in one
#                                         transaction
#                                         (default
#                                         true)
#       --lock                         - take a
#                                         pg_advisory_lock
#                                         around the
#                                         run (default
#                                         true)
#       --lock-value <value>           - advisory lock
#                                         ID (default
#                                         PG_MIGRATE_LOCK_ID)
#       --reject-unauthorized          - validate TLS
#                                         certificate
#                                         chain
#       --timestamp                    - print
#                                         resolved
#                                         migration
#                                         timestamp +
#                                         exit
#   -h, --help                         - print help
#       --version                      - print version
#
# Environment:
#   DATABASE_URL          - default Postgres connection
#                            URL (or override via
#                            --database-url-var)
#   PGHOST / PGPORT / ... - standard libpq vars (used
#                            by pg's
#                            ConnectionParameters
#                            fallback)
#
# The brianc/node-postgres (`pg`) lane is built on
# the `pg` npm package (declared at upstream
# package.json HEAD as a peer dependency `pg: >=4.3.0
# <9.0.0`, used as the underlying Postgres protocol
# driver via the `Client` + `Pool` + transaction APIs),
# the canonical Node Postgres client by Brian Carlson
# (brianc) - github.com/brianc/node-postgres, 12500+
# stars on the `pg` repo.
#
# Brian Carlson started `pg` in 2010 + has
# maintained it continuously since. The library is
# the foundational Node Postgres client - virtually
# every Node ORM (Sequelize, TypeORM, Prisma's pg
# adapter, Drizzle, Kysely), every connection pool
# (pg-pool is part of the `pg` umbrella), every
# migration tool (node-pg-migrate, db-migrate-pg,
# umzug-pg), and every Postgres-backed web framework
# (Strapi, KeystoneJS, Hasura's pg adapter) either
# uses `pg` directly OR is interoperable with it via
# the `pg-protocol` low-level codec submodule.
#
# Carlson's umbrella under brianc/node-postgres covers:
#   - `pg` (top-level package): Client + Pool +
#     transaction APIs + cursor + query streams
#   - `pg-protocol`: low-level RESP-style codec for
#     Postgres protocol v3 messages (the canonical
#     Node implementation of the PostgreSQL frontend/
#     backend wire format)
#   - `pg-pool`: connection-pooling primitive that's
#     also reusable by other Postgres drivers
#   - `pg-types`: PostgreSQL <-> JS type marshaling
#     with extensible custom-type registration
#   - `pg-cursor`: server-side cursor for streaming
#     large result sets without buffering in memory
#   - `pg-query-stream`: Node Streams API wrapper
#     around pg-cursor
#   - `pg-connection-string`: standard libpq
#     connection-URL parser
#
# `pg` is by far the highest-volume Node Postgres
# client by weekly downloads (~16M weekly), having
# been the de-facto canonical for 15 years (since
# Carlson started it in 2010). Unlike the Go Postgres
# canonical transition (lib/pq -> jackc/pgx around
# 2020), the Node Postgres canonical has stayed
# stable at `pg` for the entire JS-Postgres ecosystem
# lifetime.
#
# Carlson is a multi-axis canonical-Node author
# alongside Matt Ranney (NodeRedis/node-redis at
# Axis 255), Paul Miller (noble umbrella), Mathias
# Buus (the Node streams + bittorrent + DHT
# umbrella), and Sindre Sorhus (the ~1000-npm-
# package microlib umbrella).
#
# node-pg-migrate uses `pg`'s `Client` + transaction
# APIs to:
#   - acquire a Postgres connection from the
#     database URL (or configured connection params)
#   - take a pg_advisory_lock to prevent concurrent
#     migration runs on the same database
#   - execute the migration's up() / down() function
#     within a single transaction
#   - update the `pgmigrations` tracking table on
#     successful migration completion
#   - release the advisory lock + commit the
#     transaction
#
# ----------------------------------------------------------------------------
# AXIS 256 :: Postgres protocol (frontend/backend
#              wire-protocol v3) client libraries
# Round 1468 :: TS-Node slot 3 of 4 :: CLOSES Axis 256
#                                       (249th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : sfackler/rust-postgres      [R1466 _reth-database-reader]
#             umbrella
#   Go      : jackc/pgx                   [R1467 _sqrible]
#             (replaced lib/pq ~2020)
#   TS/Node : brianc/node-postgres        [R1468 THIS FILE]
#             (`pg` since 2010; uninterrupted
#              15-year canonical)
#
# brianc/node-postgres closes Axis 256 with the
# *uninterrupted-15-year-canonical* pattern. The
# three lanes form a clean spectrum of Postgres-
# client canonical stability:
#
#   - Rust (sfackler/rust-postgres umbrella):
#     Fackler's canonical position since 2015;
#     uninterrupted 10-year canonical (no displacement)
#   - Go (jackc/pgx): jackc/pgx replaced lib/pq as
#     canonical ~2020 after lib/pq stopped accepting
#     new features; the only canonical transition
#     in this axis
#   - Node (brianc/node-postgres): Carlson's `pg`
#     since 2010; uninterrupted 15-year canonical
#     (no displacement); the longest-running
#     canonical in this axis cluster
#
# Cross-language interop at the wire format level - a
# PostgreSQL protocol v3 frontend message stream
# produced by rust-postgres + pgx + node-postgres is
# byte-identical to PostgreSQL server's expected
# wire format. All three lanes pass the same
# PostgreSQL protocol conformance test corpus.
#
# Use-case spectrum across the three lanes:
#   - reth-database-reader (Rust, rust-postgres):
#     Ethereum-DB indexer streaming decoded events to
#     Postgres + BigQuery + Parquet sinks
#   - sqrible (Go, jackc/pgx): Postgres schema to Go
#     struct codegen
#   - node-pg-migrate (Node, brianc/node-postgres):
#     PostgreSQL migration management tool with
#     up/down/create/redo operations
#
# Three lanes, three use-case shapes (event-indexing
# pipeline / schema codegen / migration manager),
# three canonical-stability patterns (Fackler's
# 10-year umbrella / pgx-replaces-lib/pq transition /
# Carlson's 15-year uninterrupted), all converging on
# Postgres protocol v3 wire format.
#
# Axis 256 closes the round 1468 cycle - 249th axis
# closed total.
# ============================================================================

_node-pg-migrate() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-d --database-url-var)'{-d,--database-url-var}'[env var holding database URL]:name:' \
        '(-m --migrations-dir)'{-m,--migrations-dir}'[migrations directory]:dir:_files -/' \
        '--use-glob[treat migrations-dir as glob pattern]' \
        '(-t --migrations-table)'{-t,--migrations-table}'[migrations tracking table]:name:' \
        '*'{-s,--schema}'[target schema (repeatable)]:name:' \
        '--create-schema[create the target schema if missing]' \
        '--migrations-schema[schema for tracking table]:name:' \
        '--create-migrations-schema[create migrations schema if missing]' \
        '--check-order[verify migration order]' \
        '--verbose[print all DB statements executed]' \
        '--ignore-pattern[skip files matching regex/glob]:pattern:' \
        '--decamelize[run decamelize on object names]' \
        '--config-value[config section name]:name:' \
        '(-f --config-file)'{-f,--config-file}'[external config file path]:file:_files' \
        '(-j --migration-file-language)'{-j,--migration-file-language}'[new migration language]:lang:(js ts sql cjs mjs cts mts)' \
        '--migration-filename-format[migration filename format]:fmt:(timestamp utc index)' \
        '--template-file-name[migration file template]:path:_files' \
        '--envPath[path to .env file]:file:_files -g "*.env*"' \
        '--dry-run[print SQL without running]' \
        '--fake[mark migrations as run without executing]' \
        '--single-transaction[wrap migrations in one transaction]' \
        '--lock[take pg_advisory_lock around run]' \
        '--lock-value[advisory lock ID]:value:' \
        '--reject-unauthorized[validate TLS certificate chain]' \
        '--timestamp[print resolved migration timestamp + exit]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :_npm_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                up|down|redo)
                    _arguments \
                        '(- *)'{-h,--help}'[print subcommand help]' \
                        '1:N (migration count):'
                    ;;
                create)
                    _arguments \
                        '(- *)'{-h,--help}'[print subcommand help]' \
                        '1:migration name:'
                    ;;
            esac
            ;;
    esac

    return ret
}

_npm_cmds() {
    local -a cmds
    cmds=(
        'up:apply N pending migrations (default: all pending)'
        'down:revert N applied migrations (default: 1)'
        'create:scaffold a new migration file'
        'redo:down + up the last N migrations'
    )
    _describe -t commands 'node-pg-migrate command' cmds
}

_node-pg-migrate "$@"
