#compdef dmenu-wl
# _dmenu-wl — dmenu-wl CLI Wayland-native port of the suckless dmenu dynamic menu reading lines from stdin presenting them as a horizontal bar at top or bottom of the screen for the user to select with keyboard filter accepting one and printing on stdout for shell scripting (nyyManni team, C); getopt
# upstream: https://github.com/nyyManni/dmenu-wayland

_dmenu-wl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-b[place at bottom]' \
        '-c[centered]' \
        '-i[case insensitive]' \
        '-f[grab keyboard before reading stdin]' \
        '-l+[number of lines]:n:' \
        '-m+[monitor]:str:' \
        '-p+[prompt]:str:' \
        '-fn+[font]:str:' \
        '-nb+[normal bg]:str:' \
        '-nf+[normal fg]:str:' \
        '-sb+[selected bg]:str:' \
        '-sf+[selected fg]:str:' \
        '-x+[x offset]:n:' \
        '-y+[y offset]:n:' \
        '-w+[width]:n:' \
        '-P[password mode]' \
        '*::'
}

_dmenu-wl "$@"
