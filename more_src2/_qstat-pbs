#compdef qstat
# _qstat-pbs — PBS qstat (PBS job status; -f full per-job detail, -a alternate display, -t include subjobs of arrays, -i waiting list only, -n include node usage, -B server status, -Q queue status, -q queue list, -u user filter, -W extended status (e.g. show_completed), -s extended status with comments, -F format json|xml; positional argument is the job ID, queue or @server)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qstat.c on tip.

_qstat-pbs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f[full]' \
        '-a[alt display]' \
        '-t[include subjobs]' \
        '-i[waiting only]' \
        '-n[include node usage]' \
        '-B[server status]' \
        '-Q[queue status (short)]' \
        '-q[queue list]' \
        '-r[running only]' \
        '-x[finished jobs too]' \
        '-s[extended w/ comments]' \
        '-u+[user filter]:user:_users' \
        '-W+[extended status]:flag:(show_completed json xml)' \
        '-F+[format]:format:(json xml)' \
        '-T[wall time]' \
        '-G[group view]' \
        '*::job/queue/server:'
}

_qstat-pbs "$@"
