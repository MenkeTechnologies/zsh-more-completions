#compdef kubeconfig-generator kubeconfig_generator
# _kubeconfig-generator — Multus per-node kubeconfig + cert generator (k8snetworkplumbingwg/multus-cni)
# upstream: https://github.com/k8snetworkplumbingwg/multus-cni
# Flags from cmd/kubeconfig_generator/main.go on tip.

_kubeconfig-generator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--certdir=[certificate directory]:dir:_files -/' \
        '--bootstrap-config=[bootstrap kubeconfig file]:file:_files' \
        '--kubeconfig=[output kubeconfig path]:file:_files' \
        '--cert-duration=[issued certificate duration]:dur:'
}

_kubeconfig-generator "$@"
