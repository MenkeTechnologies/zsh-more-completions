#compdef kdesudo
# Documentation: https://manpages.debian.org/stretch/kdesudo/kdesudo.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kdesudo: legacy KDE wrapper around sudo (replaced by kdesu)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help about options]' \
  '(- *)--help-all[show all options]' \
  '(- *)'{-v,--version}'[show version information]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '-c+[command to run]:cmd:_command_names' \
  '-u+[target uid (default root)]:user:_users' \
  '-n[do not keep password]' \
  '-s[forget all passwords]' \
  '-p+[priority value 0-100 (default 50)]:priority:' \
  '--nonewdcop[let command use existing dcopserver]' \
  '--comment=[comment to display in the dialog box]:comment:' \
  '--noignorebutton[do not display ignore button]' \
  '--attach=[make the dialog transient for X app winid]:window_id:' \
  '-i+[icon to use in the password dialog]:icon_name:' \
  '-d[do not show the command in the dialog]' \
  '-r[use realtime scheduling]' \
  '-f+[use target UID if file is not writeable]:file:_files' \
  '-t[enable terminal output (no password keeping)]' \
  '*:command:_command_names' && ret=0
return ret
