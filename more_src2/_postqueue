#compdef postqueue
# Documentation: https://www.postfix.org/postqueue.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-c[config directory]:dir:_files -/' \
  '(-f -i -j -p -s)-f[flush the queue, deliver all queued mail]' \
  '(-f -i -j -p -s)-i[schedule immediate delivery of deferred mail]:queue_id:' \
  '(-f -i -j -p -s)-j[produce queue listing in JSON format]' \
  '(-f -i -j -p -s)-p[produce traditional sendmail-style queue listing]' \
  '(-f -i -j -p -s)-s[schedule immediate delivery for site]:site:' \
  '-v[enable verbose logging]'
