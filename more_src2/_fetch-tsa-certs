#compdef fetch-tsa-certs
# _fetch-tsa-certs — generate a TSA cert chain for the timestamp authority (sigstore/timestamp-authority)
# upstream: https://github.com/sigstore/timestamp-authority
# Flags from cmd/fetch-tsa-certs/fetch_tsa_certs.go (flag).

_fetch-tsa-certs() {
    _arguments \
        '-gcp-ca-root=[resource path to GCP CA Service CA]:path:' \
        '-parent-kms-resource=[KMS key for parent certificate]:path:' \
        '-parent-validity=[parent certificate validity (days)]:days:' \
        '-leaf-kms-resource=[KMS key for leaf certificate]:path:' \
        '-tink-keyset-path=[path to Tink keyset]:file:_files' \
        '-tink-kms-resource=[KMS key for decrypting Tink keyset]:path:' \
        '-org-name=[issuer organization name]:name:' \
        '-output=[output certificate chain file]:file:_files'
}

_fetch-tsa-certs "$@"
