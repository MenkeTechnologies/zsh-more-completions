#compdef Mathematica mathematica MathKernel WolframKernel
# _mathematica — Wolfram Research Mathematica interactive computational platform with symbolic and numerical computation (wolfram team, C++); custom argparse
# upstream: https://www.wolfram.com/mathematica/

_mathematica() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-license=+[license type]:l:(student educational professional commercial trial)' \
        '-machineid[print machine id]' \
        '-mathlink[run in mathlink server mode]' \
        '-noinit[no kernel init]' \
        '-noprompt[no prompts]' \
        '-pwfile=+[password file]:file:_files' \
        '-pwgenoutput=+[output file]:file:_files' \
        '-rpwflag=+[remote password flag]:str:' \
        '-rsh=+[remote shell]:str:' \
        '-script=+[script file]:file:_files -g "*.wls *.wl *.m *.nb *.cdf"' \
        '-run=+[expression]:str:' \
        '-noicon[no dock icon]' \
        '-singlelaunch[single launch]' \
        '-installfontfile=+[font file]:file:_files' \
        '-defaultframepalette=+[palette]:str:' \
        '-nogui[no GUI]' \
        '-mailbox=+[mailbox]:str:' \
        '-bypassparen[bypass paren]' \
        '-evalonkernelstart=+[expression]:str:' \
        '-uninstall[uninstall]' \
        '-activate[activate]' \
        '-deactivate[deactivate]' \
        '-cleanstart[clean start]' \
        '-restorestart[restore start]' \
        '-loginprompt[login prompt]' \
        '-style=+[Qt style]:str:' \
        '-display=+[X display]:str:' \
        '-geometry=+[WxH+X+Y]:str:' \
        '*:notebook file:_files -g "*.nb *.cdf *.wls *.wl *.m *.mx"'
}

_mathematica "$@"
