#compdef qbittorrent-cli qbt
# _qbittorrent-cli — autobrr qbittorrent-cli unofficial qBittorrent CLI alias (autobrr team, Go); cobra
# upstream: https://github.com/ludviglundgren/qbittorrent-cli

_qbittorrent-cli() {
    local -a sub=(
        'app:application commands'
        'app version:show version'
        'app webapi:show webapi version'
        'category:category commands'
        'category add:add category'
        'category delete:delete category'
        'category edit:edit category'
        'category list:list categories'
        'config:config commands'
        'edit:edit torrent'
        'export:export torrent files'
        'help:show help'
        'import:import torrent files'
        'list:list torrents'
        'login:login'
        'pause:pause torrent'
        'reannounce:reannounce torrent'
        'resume:resume torrent'
        'rename:rename torrent file'
        'set-location:set save location'
        'tag:tag commands'
        'tag add:add tag'
        'tag delete:delete tag'
        'tag list:list tags'
        'torrent:torrent commands'
        'torrent add:add torrent'
        'torrent remove:remove torrent'
        'torrent properties:show properties'
        'torrent peers:show peers'
        'torrent files:list files'
        'torrent trackers:show trackers'
        'torrent recheck:recheck torrent'
        'transfer:transfer info'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file]:file:_files' \
        '--host=+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--debug[debug]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qbt subcommand' sub ;;
        args)
            case $words[1] in
                torrent:add) _arguments \
                    '*:torrent file:_files -g "*.torrent"' \
                    '--category=+[category]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '--paused[add paused]' \
                    '--skip-checking[skip checking]' \
                    '--save-path=+[path]:dir:_files -/' \
                    '--rename=+[name]:str:' \
                    '--upload-limit=+[bytes/s]:n:' \
                    '--download-limit=+[bytes/s]:n:' \
                    '--ratio-limit=+[ratio]:str:' \
                    '--seeding-time-limit=+[minutes]:n:' \
                    '--auto-tmm[auto torrent management]' \
                    '--magnet=+[magnet url]:str:' \
                    '--sequential[sequential download]' \
                    '--first-last-piece[prioritize first and last piece]' ;;
            esac
            ;;
    esac
}

_qbittorrent-cli "$@"
