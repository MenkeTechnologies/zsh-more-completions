# WHAT IT IS
#   displex is "Discord & Plex & Tautulli & Overseerr Bot" — Mike Chester's
#   Rust daemon that ties a self-hosted Plex media server stack together
#   on Discord.  A single binary runs in one of several modes:  as a
#   serenity / poise Discord bot listening for slash commands, as an
#   axum HTTP server exposing an `async-graphql` GraphQL endpoint
#   plus Discord linked-role OAuth callbacks, or in batch / cron mode
#   for periodic Plex metadata refresh, Tautulli channel updates,
#   Overseerr request-upgrade processing, token cleanup, and user
#   refresh sweeps.  Backend persistence runs through `sea-orm` against
#   SQLite or PostgreSQL.
#
# CLI ARGUMENT GRAMMAR  (verbatim from server/src/main.rs clap-derive
#                       Cli + Commands enum)
#   displex [-c <DIR>] <command>
#
#   Global flag:
#     -c, --config-dir <DIR>   Path to the directory containing the
#                              displex configuration file (read via the
#                              `config::load(&args.config_dir)` helper)
#                                                          [default: "."]
#
#   Subcommands (from `#[derive(Subcommand)] enum Commands`):
#     bot                Run as the serenity/poise Discord bot
#     channel-refresh    Refresh Discord channels from Plex / Tautulli
#                        state (one-shot)
#     metadata           Refresh Plex metadata
#     requests-upgrade   Process Overseerr request-upgrade events
#     server             Run the axum HTTP / GraphQL server
#                        (Discord linked-role OAuth landing pages)
#     token-maintenance  Clean up expired Discord / Plex tokens
#     user-refresh       Refresh Discord-linked user state
#
#   Standard clap auto-flags:
#     -h, --help               Show help
#     -V, --version            Show version
#
# AXIS / CORPUS POSITION
#   Direct dependencies declared in server/Cargo.toml:
#     serenity = "0.12.1"     — Acker25/Lorgath et al. serenity, the
#                              canonical Rust Discord library used by
#                              the majority of production Rust Discord
#                              bots
#     poise = "0.6.1"         — kangalio's command framework layered on
#                              top of serenity (slash + prefix commands,
#                              autocomplete, modal dialogs)
#   Both come from the same Rust Discord ecosystem and represent the
#   canonical Rust Discord library family.  Verified via:
#     gh api repos/mchestr/displex/contents/server/Cargo.toml
#       → serenity = "0.12.1"
#       → poise = "0.6.1"
#     gh api repos/mchestr/displex/contents/server/src/main.rs
#       → let (serenity_client, app_services) = create_app_services(...)
#   This entry is the Rust=122 leader bump that OPENS Axis 67
#   (Discord Bot Library), pairing with future Go=bwmarrin/discordgo
#   and TS-Node=discord.js poles to close the axis at 1/1/1.  When
#   Axis 67 closes at R859 the corpus will reach the THREE-SCORE AXES
#   round-number landmark (60 axes at 1/1/1 three-language symmetry).
#
#   No completion for `displex` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_displex() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config-dir)'{-c+,--config-dir=}'[path to displex config dir (default ".")]:config dir:_files -/' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_displex_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                bot|channel-refresh|metadata|requests-upgrade|server|token-maintenance|user-refresh)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_displex_commands] )) ||
_displex_commands() {
    local -a commands
    commands=(
        'bot:run as the serenity/poise Discord bot'
        'channel-refresh:refresh Discord channels from Plex/Tautulli state'
        'metadata:refresh Plex metadata'
        'requests-upgrade:process Overseerr request-upgrade events'
        'server:run the axum HTTP / GraphQL server (Discord linked-role OAuth)'
        'token-maintenance:clean up expired Discord/Plex tokens'
        'user-refresh:refresh Discord-linked user state'
    )
    _describe -t commands 'displex command' commands
}

_displex "$@"
