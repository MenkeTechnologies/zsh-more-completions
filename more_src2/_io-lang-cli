#compdef io-lang-cli io-lang io2
# _io-lang-cli — Steve Dekorte Io Lang io-lang-cli CLI command-line frontend wrapping the Io small prototype-based programming language written in C originally Steve Dekorte 2002 inspired by Smalltalk Self Lua Lisp Act1 Lisp NewtonScript prototype-based object-oriented dynamic message-passing all values are objects all expressions are messages including assignment-arithmetic-operators-control-flow Io-Coroutines Io-Actor Io-Sockets Io-Database Io-Distributed-Object Vector REPL-mode interpret -e -i -c -b -f -h -? -v -V (Steve Dekorte Io Lang team, C); custom argparse
# upstream: https://iolanguage.org/

_io-lang-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[show version]' \
        '-?[show help]' \
        '-e+[expression]:str:' \
        '*-e+[expression]:str:' \
        '-i+[interactive script]:file:_files -g "*.io"' \
        '-c+[command]:str:' \
        '*-c+[command]:str:' \
        '-b[binary mode]' \
        '-f+[file]:file:_files -g "*.io"' \
        '*-f+[file]:file:_files -g "*.io"' \
        '-load+[file]:file:_files -g "*.io"' \
        '*-load+[file]:file:_files -g "*.io"' \
        '-l+[file]:file:_files -g "*.io"' \
        '*-l+[file]:file:_files -g "*.io"' \
        '--license[show license]' \
        '--init=+[file]:file:_files' \
        '--bootstrap=+[dir]:dir:_files -/' \
        '--no-bootstrap[no bootstrap]' \
        '-prof[enable profiling]' \
        '-debug[debug mode]' \
        '*:io file:_files -g "*.io"'
}

_io-lang-cli "$@"
