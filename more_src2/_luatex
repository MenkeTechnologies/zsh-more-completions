#compdef luatex luahbtex
# Documentation: luatex --help
# Source: LuaTeX — TeX engine with Lua scripting.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*--cnf-line=[parse STRING as a configuration line]:string:' \
    '(- *)--credits[show credits]' \
    '--debug-format[enable format debugging]' \
    '--draftmode[switch on draft mode (no output PDF)]' \
    '(--check-dvi-total-pages --no-check-dvi-total-pages)--check-dvi-total-pages[exit when DVI > 65535 pages (default)]' \
    '(--check-dvi-total-pages --no-check-dvi-total-pages)--no-check-dvi-total-pages[do not exit on DVI > 65535 pages]' \
    '(--file-line-error --no-file-line-error)--file-line-error[file\:line\:error style messages]' \
    '(--file-line-error --no-file-line-error)--no-file-line-error[do not use file\:line\:error style]' \
    '--file-line-error-style[alias for --file-line-error]' \
    '--no-file-line-error-style[alias for --no-file-line-error]' \
    '--fmt=[format file]:format:' \
    '--halt-on-error[stop at first error]' \
    '(- *)--help[show help]' \
    '--ini[be iniluatex (dumping formats)]' \
    '--interaction=[interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
    '--jobname=[job name]:name:' \
    '--kpathsea-debug=[kpathsea debug bitmask]:n:' \
    '--lua=[Lua initialization script]:file:_files -g "*.lua"' \
    '--luadebug[enable lua debug library]' \
    '(--mktex --no-mktex)--mktex=[enable mktexFMT]:fmt:(tex tfm fmt)' \
    '(--mktex --no-mktex)--no-mktex=[disable mktexFMT]:fmt:(tex tfm fmt)' \
    '(--nosocket --no-socket --socket)--nosocket[disable lua socket library]' \
    '(--nosocket --no-socket --socket)--no-socket[disable lua socket library]' \
    '(--nosocket --no-socket --socket)--socket[enable lua socket library]' \
    '--output-comment=[DVI file comment string]:string:' \
    '--output-directory=[output directory]:dir:_files -/' \
    '--output-format=[output format]:format:(dvi pdf)' \
    '--progname=[program name]:string:' \
    '--recorder[enable filename recorder]' \
    '--safer[disable easily exploitable lua commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)--shell-escape[enable system commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)--no-shell-escape[disable system commands]' \
    '(--shell-escape --no-shell-escape --shell-restricted)--shell-restricted[restrict system commands per texmf.cnf]' \
    '--synctex=[enable SyncTeX (bitmask)]:n:' \
    '--utc[init time to UTC]' \
    '(- *)--version[show version]' \
    '(- *)--luaonly[run a Lua file then exit]' \
    '(- *)--luaconly[byte-compile Lua file then exit]' \
    '(- *)--luahashchars[show Lua string-hash bit count]' \
    '*:TeX or Lua source:_files -g "*.{tex,lua}"' \
    && ret=0

return ret
