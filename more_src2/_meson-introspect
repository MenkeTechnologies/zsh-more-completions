#compdef meson-introspect
# _meson-introspect — Meson build system meson-introspect CLI alias (Meson team / Jussi Pakkanen, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-introspect() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--all[show all info]' \
        '-a[show all info]' \
        '--ast[show parsed AST]' \
        '--benchmarks[list benchmarks]' \
        '--buildoptions[show build options]' \
        '--buildsystem-files[list buildsystem files]' \
        '--dependencies[show dependencies]' \
        '--scan-dependencies[scan dependencies]' \
        '--installed[show installed files]' \
        '--install-plan[show install plan]' \
        '--projectinfo[show project info]' \
        '--targets[show targets]' \
        '--tests[list tests]' \
        '--backend=+[backend]:b:(ninja vs vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 xcode none)' \
        '--indent[indent json]' \
        '-i[indent json]' \
        '--force-object-output[force object output]' \
        '*:source-or-build-dir:_files -/'
}

_meson-introspect "$@"
