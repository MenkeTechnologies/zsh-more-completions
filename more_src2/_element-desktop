#compdef element-desktop element
# _element-desktop — Element Matrix client (Electron wrapper around Element Web); flagship Matrix.org client
# upstream: https://github.com/element-hq/element-desktop

_element-desktop() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--profile+[profile name]:name:' \
        '--profile-dir+[profile dir]:dir:_files -/' \
        '--hidden[start hidden in tray]' \
        '--no-update[disable auto updater]' \
        '--proxy-server+[proxy server]:host:port:' \
        '--inspector[open chromium devtools]' \
        '--disable-gpu[disable GPU acceleration]' \
        '*:matrix URI:_urls'
}

_element-desktop "$@"
