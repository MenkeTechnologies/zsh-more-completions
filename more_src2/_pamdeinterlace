#compdef pamdeinterlace
# Documentation: man pamdeinterlace (Netpbm)
# Source: discard alternate rows from a PAM image (extract odd or even fields).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-takeodd -takeeven)-takeodd[keep odd rows]' \
    '(-takeodd -takeeven)-takeeven[keep even rows]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
