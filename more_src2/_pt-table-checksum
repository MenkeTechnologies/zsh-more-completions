#compdef pt-table-checksum
# Documentation: https://docs.percona.com/percona-toolkit/pt-table-checksum.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--binary-index[use BLOB for boundary columns in replicate table]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--channel=[replication channel name]:channel:' \
  '--charset=[default character set]:charset:' \
  '(--check-binlog-format --no-check-binlog-format)'{--check-binlog-format,--no-check-binlog-format}'[check binlog format]' \
  '--check-interval=[sleep between lag checks]:sec:' \
  '(--check-plan --no-check-plan)'{--check-plan,--no-check-plan}'[check query plan]' \
  '--check-replica-lag=[specific replica to monitor for lag]:DSN:' \
  '(--check-replica-tables --no-check-replica-tables)'{--check-replica-tables,--no-check-replica-tables}'[verify replica table structure]' \
  '(--check-replication-filters --no-check-replication-filters)'{--check-replication-filters,--no-check-replication-filters}'[check replication filters]' \
  '--chunk-index=[index for chunking]:index:' \
  '--chunk-index-columns=[N leftmost columns of chunk index]:n:' \
  '--chunk-size=[rows per chunk]:rows:' \
  '--chunk-size-limit=[max chunk size factor]:factor:' \
  '--chunk-time=[time per chunk]:seconds:' \
  '--columns=[columns to checksum]:cols:' \
  '--config=[comma-separated config files]:files:_files' \
  '(--create-replicate-table --no-create-replicate-table)'{--create-replicate-table,--no-create-replicate-table}'[auto-create replicate table]' \
  '--databases=[databases to check]:databases:' \
  '--databases-regex=[regex for databases]:regex:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--disable-qrt-plugin[disable Query Response Time plugin]' \
  '(--empty-replicate-table --no-empty-replicate-table)'{--empty-replicate-table,--no-empty-replicate-table}'[delete previous checksums per table]' \
  '--engines=[only these storage engines]:engines:' \
  '*--explain[show checksums without executing (cumulative)]' \
  '--fail-on-stopped-replication[exit on stopped replication]' \
  '--float-precision=[float precision]:digits:' \
  '--function=[hash function]:fn:' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--ignore-columns=[columns to exclude]:cols:' \
  '--ignore-databases=[databases to ignore]:databases:' \
  '--ignore-databases-regex=[regex for databases to ignore]:regex:' \
  '--ignore-engines=[storage engines to exclude]:engines:' \
  '--ignore-tables=[tables to ignore]:tables:' \
  '--ignore-tables-regex=[regex for tables to ignore]:regex:' \
  '--max-lag=[max replica lag]:seconds:' \
  '--max-load=[max load before throttling]:load spec:' \
  '--mysql_ssl=[create SSL connection]:n:' \
  '--password=[MySQL password]:password:' \
  '--pause-file=[pause while file exists]:file:_files' \
  '--pid=[PID file]:pid file:_files' \
  '--plugin=[Perl module for custom hooks]:file:_files' \
  '--port=[MySQL port]:port:' \
  '--progress=[progress reporting spec]:spec:' \
  '*--quiet[reduce verbosity (cumulative)]' \
  '--recurse=[recurse depth for replica discovery]:depth:' \
  '--recursion-method=[method to find replicas]:method:(processlist hosts cluster dsn none)' \
  '--replica-password=[replica password]:pw:' \
  '--replica-skip-tolerance=[replica size excess tolerance]:val:' \
  '--replica-user=[replica user]:user:' \
  '--replicate=[replicate table]:table:' \
  '(--replicate-check --no-replicate-check)'{--replicate-check,--no-replicate-check}'[check replicas for differences]' \
  '--replicate-check-only[only check do not checksum]' \
  '--replicate-check-retries=[retry count for checksum comparison]:n:' \
  '--replicate-database=[database for replicate table]:database:' \
  '--resume[resume interrupted checksum]' \
  '--retries=[retry count]:count:' \
  '--run-time=[maximum run time]:duration:' \
  '--separator=[column separator]:separator:' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--tables=[tables to check]:tables:' \
  '--tables-regex=[regex for tables]:regex:' \
  '--truncate-replicate-table[truncate replicate table at start]' \
  '--user=[MySQL user]:username:' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '--where=[WHERE clause for filtering]:where clause:' \
  '*:DSN:' && ret=0

return ret
