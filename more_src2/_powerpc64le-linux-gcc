#compdef powerpc64le-linux-gcc powerpc64le-linux-gnu-gcc ppc64le-linux-gnu-gcc
# _powerpc64le-linux-gcc — GNU GCC powerpc64le-linux-gcc CLI cross-compiler build targeting IBM POWER8 POWER9 POWER10 little-endian Linux ELFv2 generating ELF64 DWARF VSX VMX AltiVec MMA Matrix Multiply Accelerator HTM transactional memory PIE PIC LTO mcpu mtune mvsx mhtm (GNU team, C); custom argparse
# upstream: https://gcc.gnu.org/

_powerpc64le-linux-gcc() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-E[stop after preprocessor]' \
        '-S[stop after compilation]' \
        '-c[compile or assemble only]' \
        '-o+[output file]:file:_files' \
        '-O+[optimization level]:l:(0 1 2 3 s g fast)' \
        '-g[debug info]' \
        '-Wall[enable common warnings]' \
        '-Wextra[enable extra warnings]' \
        '-Werror[treat warnings as errors]' \
        '-fPIC[position independent code]' \
        '-fPIE[position independent executable]' \
        '-pie[link as PIE]' \
        '-static[link statically]' \
        '-shared[link as shared object]' \
        '-mcpu=+[cpu]:c:(power7 power8 power9 power10 native ppc64le default)' \
        '-mtune=+[tune]:str:' \
        '-mvsx[enable VSX]' \
        '-mno-vsx[disable VSX]' \
        '-maltivec[enable AltiVec]' \
        '-mno-altivec[disable AltiVec]' \
        '-mhtm[hardware transactional memory]' \
        '-mno-htm[no HTM]' \
        '-mfloat128[enable IEEE 128-bit float]' \
        '-mfloat128-hardware[hardware float128]' \
        '-mlong-double-128[128-bit long double]' \
        '-mlong-double-64[64-bit long double]' \
        '-mabi=+[abi]:a:(altivec no-altivec ibmlongdouble ieeelongdouble elfv1 elfv2)' \
        '-D+[macro]:str:' \
        '-U+[macro]:str:' \
        '-I+[include dir]:dir:_files -/' \
        '-isystem+[system include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l+[library]:str:' \
        '-Wl,+[linker option]:str:' \
        '-flto[link time optimization]' \
        '-std=+[std]:s:(c89 c99 c11 c17 c23 gnu89 gnu99 gnu11 gnu17 gnu23 c++98 c++11 c++14 c++17 c++20 c++23)' \
        '-MD[generate dependency .d file]' \
        '-MMD[generate dependency .d file no system]' \
        '-MP[add phony rules]' \
        '-MF+[file]:file:_files' \
        '-x+[lang]:l:(c c-header c++ c++-header assembler assembler-with-cpp none)' \
        '--sysroot=+[dir]:dir:_files -/' \
        '*:source file:_files -g "*.c *.cc *.cpp *.cxx *.h *.hpp *.hxx *.s *.S *.o *.a *.so"'
}

_powerpc64le-linux-gcc "$@"
