#compdef reg_average
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_average.cpp — average images/transformations (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '-omp+[OpenMP threads]:n:_default' \
    '(-NN -nn -LIN -lin)-NN[nearest-neighbour resampling]' \
    '(-NN -nn -LIN -lin)-nn[nearest-neighbour resampling]' \
    '(-NN -nn -LIN -lin)-LIN[linear resampling]' \
    '(-NN -nn -LIN -lin)-lin[linear resampling]' \
    '1:output image:_files' \
    '2:operation:(-avg -avg_lts -lts_avg -avg_tran -demean -demean1 -demean2 -demean_noaff -demean3)' \
    '*:image or transform file:_files' \
    && ret=0

return ret
