#compdef qwen
# Documentation: https://github.com/QwenLM/qwen-code/blob/main/README.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Qwen Code CLI (Alibaba agentic coding tool)
# Note: most commands (/help, /clear, /auth, /model, /stats, /compress, /bug, /quit)
# are slash-commands typed inside the interactive session, not shell args.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-p[run a single prompt in headless mode]:prompt' \
  '--yolo[approval-free mode]' \
  '*:: : _message "see qwen --help"' && return 0
