#compdef ppsspp ppsspp-sdl ppsspp-headless ppsspp-qt
# Documentation: https://www.ppsspp.org/docs/reference/command-line/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-d[set log level to debug]' \
  '-v[set log level to verbose]' \
  '-j[use JIT CPU backend]' \
  '-i[use Interpreter CPU backend]' \
  '-r[use IR Interpreter CPU backend]' \
  '-J[use JIT IR CPU backend]' \
  '--pause-menu-exit[change pause menu exit choice]' \
  '--escape-exit[exit on Escape key]' \
  '--fullscreen[force fullscreen mode]' \
  '--windowed[force windowed mode]' \
  '--gamesettings[launch directly into game settings]' \
  '--touchscreentest[open touchscreen test interface]' \
  '--appendconfig=[merge alternate config file]:file:_files' \
  '-l[activate log console (Windows)]' \
  '-s[prevent settings from saving (Windows)]' \
  '-direct3d11[use Direct3D 11 GPU backend (Windows)]' \
  '-vulkan[use Vulkan GPU backend (Windows)]' \
  '-gles[use OpenGL ES GPU backend (Windows)]' \
  '-software[use software GPU backend (Windows)]' \
  '*: :_files -g "*.iso *.cso *.pbp *.elf *.prx *.zip *.ppdmp"' && ret=0

return ret
