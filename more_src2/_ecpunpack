#compdef ecpunpack
# Documentation: https://manpages.debian.org/testing/fpga-trellis/ecpunpack.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--input=[input bitstream file]:file:_files -g "*.bit"' \
  '--textcfg=[output textual configuration file]:file:_files -g "*.config"' \
  '--db=[Trellis database folder location]:dir:_directories' \
  '--idcode=[override IDCODE in bitstream]:idcode:' && ret=0

return ret
