#compdef falco-exporter
# Documentation: https://github.com/falcosecurity/falco-exporter
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# falco-exporter: Prometheus exporter for Falco events
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--listen-address=[Prometheus metrics endpoint address]:host:port:' \
  '--probes-listen-address=[readiness/liveness probes endpoint]:host:port:' \
  '--client-ca=[CA root file for Falco gRPC server]:file:_files' \
  '--client-cert=[certificate file for Falco gRPC server]:file:_files' \
  '--client-key=[key file for Falco gRPC server]:file:_files' \
  '--client-hostname=[hostname for Falco gRPC]:host:' \
  '--client-port=[port for gRPC connection]:port:' \
  '--client-socket=[unix socket path]:file:_files' \
  '--server-ca=[CA root file for metrics HTTPS server]:file:_files' \
  '--server-cert=[certificate file for metrics HTTPS server]:file:_files' \
  '--server-key=[key file for metrics HTTPS server]:file:_files' \
  '--timeout=[initial gRPC connection timeout]:duration:' \
  '*::falco-exporter args:_files' && ret=0
return ret
