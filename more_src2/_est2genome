#compdef est2genome
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/est2genome.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS est2genome: align EST/cDNA to genome, finding splice sites
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-auto[no prompts]' \
  '-stdout[output to stdout]' \
  '-filter[stdin/stdout filter]' \
  '-options[interactive prompts]' \
  '-debug[debug]' \
  '-verbose[verbose]' \
  '-warning[warnings]' \
  '-error[errors]' \
  '-fatal[fatal]' \
  '-die[dying messages]' \
  '-version[version]' \
  '-estsequence=[EST/cDNA sequence(s)]:USA:_files' \
  '-genomesequence=[genomic DNA sequence]:USA:_files' \
  '-match=[match score]:score' \
  '-mismatch=[mismatch penalty]:score' \
  '-gappenalty=[gap penalty]:score' \
  '-intronpenalty=[intron penalty]:score' \
  '-splicepenalty=[splice site penalty]:score' \
  '-minscore=[minimum alignment score]:score' \
  '-reverse[reverse EST sequence orientation]' \
  '-usesplice[use donor/acceptor splice site detection]' \
  '-mode=[alignment mode]:mode:(both forward reverse)' \
  '-best[only report best alignment]' \
  '-space=[memory limit (MB)]:mb' \
  '-shuffle=[number of shuffles]:n' \
  '-seed=[random seed]:seed' \
  '-align[output full alignment]' \
  '-width=[alignment output width]:cols' \
  '-outfile=[output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
