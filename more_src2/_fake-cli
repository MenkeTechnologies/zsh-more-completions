#compdef fake-cli
# Documentation: https://github.com/fsprojects/FAKE/blob/master/src/app/Fake.netcore/Cli.fs
# Reference accessed: 2026-05-27
# Verified: upstream Cli.fs `fakeUsage` docopt block in fsprojects/FAKE
#
# Note: `fake-cli` is the dotnet global tool package name. The actual
# binary installed by `dotnet tool install -g fake-cli` is named `fake`
# (which is covered separately and is in this repo's blacklist). This
# file exists for users who alias or symlink the tool under the
# `fake-cli` name. Flags below are the top-level options accepted by
# the `fake` entry point.

local curcontext="$curcontext" state line ret=1

local -a _fake_cli_subcommands
_fake_cli_subcommands=(
  'run:execute an .fsx script with FAKE'
  'build:execute build.fsx (alias for run build.fsx)'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show FAKE version]' \
  '*'{-v,--verbose}'[verbose output; repeat for more verbosity]' \
  '(-s --silent)'{-s,--silent}'[silent mode]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'fake-cli subcommand' _fake_cli_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '(-d --debug)'{-d,--debug}'[debug the script]' \
          '(-n --nocache)'{-n,--nocache}'[disable FAKE cache for this run]' \
          '(-p --partial-restore)'{-p,--partial-restore}'[only restore required Paket group]' \
          '*--fsiargs=[arguments passed to F# interactive]:fsi-args:' \
          '*:script:_files -g "*.fsx"' && ret=0
        ;;
      build)
        _arguments \
          '(-d --debug)'{-d,--debug}'[debug the script]' \
          '(-n --nocache)'{-n,--nocache}'[disable FAKE cache for this run]' \
          '(-p --partial-restore)'{-p,--partial-restore}'[only restore required Paket group]' \
          '*--fsiargs=[arguments passed to F# interactive]:fsi-args:' \
          '(-f --script)'{-f+,--script=}'[script to execute (defaults to build.fsx)]:script:_files -g "*.fsx"' \
          '*:script-arg:' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
