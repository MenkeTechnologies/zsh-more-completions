#compdef porsmo
# Documentation: https://github.com/ColorCookie-dev/porsmo
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::args:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'pomodoro:start a pomodoro timer'
      'p:start a pomodoro timer'
      'timer:start a countdown timer'
      't:start a countdown timer'
      'stopwatch:start a stopwatch'
      's:start a stopwatch'
    )
    _describe -t commands 'porsmo command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      pomodoro|p)
        local -a modes=(
          'short:short pomodoro session'
          's:short pomodoro session'
          'long:long pomodoro session'
          'l:long pomodoro session'
          'custom:custom durations'
          'c:custom durations'
        )
        if (( CURRENT == 2 )); then
          _describe -t modes 'pomodoro mode' modes && ret=0
        fi
        _arguments -s -S '-e[exit message]' && ret=0
        ;;
      timer|t)
        _arguments -s -S ':target time:' && ret=0
        ;;
    esac
    ;;
esac

return ret
