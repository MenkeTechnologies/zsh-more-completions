#compdef defaults
# Documentation: https://www.unix.com/man-page/osx/1/defaults/
# Source: Apple macOS — user-defaults (preferences) CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '-currentHost[restrict to current host only]' \
    '-host[restrict to specific hostname]:host:_hosts' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'read:print all defaults / by domain / by key'
            'read-type:print property-list type of a key'
            'write:store value for key in domain'
            'rename:rename a key within a domain'
            'delete:remove defaults information'
            'domains:print all domain names'
            'find:search word in domains/keys/values'
            'export:export domain as XML plist file'
            'import:import XML plist file into domain'
            'help:print available command formats'
        )
        _describe -t subcmds 'defaults command' subcmds && ret=0
        ;;
    args)
        _arguments \
            '-app[application name (instead of domain)]:app:' \
            '(-g -globalDomain NSGlobalDomain)-g[global domain]' \
            '(-g -globalDomain NSGlobalDomain)-globalDomain[global domain]' \
            '(-g -globalDomain NSGlobalDomain)NSGlobalDomain[global domain]' \
            '-string[string value]' \
            '-data[raw hex bytes]' \
            '(-int -integer)-int[integer value]' \
            '(-int -integer)-integer[integer value]' \
            '-float[float value]' \
            '(-bool -boolean)-bool[boolean (TRUE/FALSE/YES/NO)]' \
            '(-bool -boolean)-boolean[boolean (TRUE/FALSE/YES/NO)]' \
            '-date[date value]' \
            '-array[array value]' \
            '-array-add[append elements to existing array]' \
            '-dict[dictionary value]' \
            '-dict-add[add key/value pairs to dictionary]' \
            '*:domain or key or value:' \
            && ret=0
        ;;
esac

return ret
