#compdef po-fetch
# Documentation: https://www.gnu.org/software/gettext/manual/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (po-fetch ships with gettext).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help text]' \
  '(- *)--version[show version and authorship information]' \
  '--git[make changes in the git index, to prepare for a git commit]' \
  '1:project type:(TP Weblate git)' \
  '*:project args:' && ret=0

return ret
