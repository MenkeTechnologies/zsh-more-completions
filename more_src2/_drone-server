#compdef drone-server
# _drone-server — Harness Drone drone-server CI/CD pipeline server daemon binary (drone team, Go); custom argparse via env or flags
# upstream: https://github.com/harness/drone

_drone-server() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug logging]' \
        '--trace[trace logging]' \
        '--server-host=+[server host]:host:_hosts' \
        '--server-port=+[server port]:port:_ports' \
        '--server-proto=+[proto]:p:(http https)' \
        '--rpc-secret=+[rpc shared secret]:str:' \
        '--rpc-host=+[rpc host]:host:_hosts' \
        '--rpc-proto=+[rpc proto]:p:(http https grpc)' \
        '--rpc-port=+[rpc port]:port:_ports' \
        '--http-bind=+[bind address]:str:' \
        '--http-acme-cache=+[acme cache]:dir:_files -/' \
        '--http-acme-mail=+[acme email]:str:' \
        '--http-acme-host=+[acme host]:host:_hosts' \
        '--tls-cert=+[tls cert]:file:_files' \
        '--tls-key=+[tls key]:file:_files' \
        '--database-driver=+[driver]:d:(sqlite3 postgres mysql)' \
        '--database-datasource=+[dsn]:str:' \
        '--user-create=+[username:admin spec]:str:' \
        '--user-filter=+[users csv]:str:' \
        '--admin=+[admin users csv]:str:' \
        '--registration-closed=+[bool]:b:(true false)' \
        '--session-secret=+[session secret]:str:' \
        '--session-expired=+[duration]:str:' \
        '--gitea-server=+[gitea url]:url:_urls' \
        '--gitea-client-id=+[client id]:str:' \
        '--gitea-client-secret=+[secret]:str:' \
        '--github-server=+[github url]:url:_urls' \
        '--github-client-id=+[client id]:str:' \
        '--github-client-secret=+[secret]:str:' \
        '--gitlab-server=+[gitlab url]:url:_urls' \
        '--gitlab-client-id=+[client id]:str:' \
        '--gitlab-client-secret=+[secret]:str:' \
        '--bitbucket-server=+[bitbucket url]:url:_urls' \
        '--bitbucket-client-id=+[client id]:str:' \
        '--bitbucket-client-secret=+[secret]:str:' \
        '--stash-server=+[stash url]:url:_urls' \
        '--gogs-server=+[gogs url]:url:_urls' \
        '--prometheus-anonymous-access=+[bool]:b:(true false)' \
        '--metrics-port=+[port]:port:_ports' \
        '--http-allow-pprof=+[bool]:b:(true false)' \
        '--logs-debug[debug logs]' \
        '--logs-trace[trace logs]' \
        '--logs-text[log as text]' \
        '--logs-color[colored logs]'
}

_drone-server "$@"
