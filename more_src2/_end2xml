#compdef end2xml
# _end2xml — Chris Putnam bibutils end2xml CLI converting Endnote Refer-style tagged citation files into MODS XML Library of Congress Metadata Object Description Schema cross-walk format for downstream conversion into BibTeX RIS ADS ISI Word UTF-8 encoded entity-aware (Chris Putnam team, C); getopt
# upstream: https://sourceforge.net/projects/bibutils/

_end2xml() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[debug level]:l:(0 1 2 3 4 5)' \
        '-i+[input encoding]:e:(utf8 latin1 cp1250 cp1251 cp1252 koi8-r euc-jp gb2312 big5 shift-jis iso-8859-1 iso-8859-2 iso-8859-15)' \
        '--input-encoding=+[enc]:str:' \
        '-o+[output encoding]:e:(utf8 latin1 cp1252 iso-8859-1 iso-8859-2 iso-8859-15)' \
        '--output-encoding=+[enc]:str:' \
        '-u[input UTF-8 with BOM]' \
        '-un[input UTF-8 no BOM]' \
        '-x[output XML]' \
        '-nb[no BOM]' \
        '-w[wrap output]' \
        '-s[output single entry mode]' \
        '-c+[corporation tag]:str:' \
        '*:end file:_files -g "*.end *.endnote *.txt"'
}

_end2xml "$@"
