#compdef nest-cli
# Documentation: https://www.npmjs.com/package/nest-cli
# Reference accessed: 2026-05-23
# Verified: npx nest-cli --help.

# Zsh completion for nest-cli - Nest thermostat CLI (legacy nest-cli package)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:login via OAuth'
  'config:get or set configuration'
  'devices:list known devices'
  'default-thermostat:set default thermostat id'
  'away:set away mode'
  'off:turn off HVAC'
  'read:read thermostat state'
  'state:set HVAC mode'
  'structures:list account structures'
  'temp:set target temperature'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'nest-cli command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
