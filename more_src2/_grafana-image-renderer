#compdef grafana-image-renderer
# Documentation: https://grafana.com/docs/grafana/latest/setup-grafana/image-rendering/flags/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# grafana-image-renderer: render plugin for Grafana panels (server / print-config subcommands)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'server:run as render server'
  'print-config:print effective configuration'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--server.addr=[server listen address]:addr:' \
  '--server.auth-token=[auth token]:token:' \
  '--server.cert-file=[TLS cert file]:file:_files' \
  '--server.key-file=[TLS key file]:file:_files' \
  '--browser.min-width=[min viewport width]:n:' \
  '--browser.max-width=[max viewport width]:n:' \
  '--browser.min-height=[min viewport height]:n:' \
  '--browser.max-height=[max viewport height]:n:' \
  '--browser.time-zone=[default browser time zone]:tz:' \
  '--browser.path=[chromium binary path]:file:_files' \
  '--api.default-encoding=[default image encoding]:enc:(png jpeg)' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:fmt:(logfmt json)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'grafana-image-renderer command' commands && ret=0 ;;
esac
return ret
