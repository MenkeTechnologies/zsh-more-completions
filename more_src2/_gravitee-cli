#compdef gravitee-cli gravitee gravitee-management
# _gravitee-cli — Gravitee Source gravitee-cli CLI command-line frontend wrapping the Gravitee API Management open-source enterprise-grade lightweight high-performance fast easy-to-use highly customizable API platform written in Java/TypeScript helps your organization secure publish and analyze your APIs apis applications users plans pages portal-pages categories tags entrypoints subscriptions logs analytics tenants groups roles dictionaries identity-providers policies notifications quality-rules audit configuration health-checks dashboards rating notification-templates (Gravitee Source team Antoine Crouzet Olivier Couapel David Brassely, Java/TypeScript); custom argparse
# upstream: https://www.gravitee.io/

_gravitee-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'api:API operations'
        'application:application operations'
        'plan:plan operations'
        'subscription:subscription operations'
        'user:user operations'
        'group:group operations'
        'role:role operations'
        'category:category operations'
        'tag:tag operations'
        'entrypoint:entrypoint operations'
        'page:page operations'
        'portal-page:portal page operations'
        'policy:policy operations'
        'notification:notification operations'
        'dictionary:dictionary operations'
        'identity-provider:IDP operations'
        'quality-rule:quality rule operations'
        'audit:audit operations'
        'tenant:tenant operations'
        'health:health check ops'
        'analytics:analytics operations'
        'dashboard:dashboard operations'
        'configuration:configuration ops'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--bearer-token=+[token]:str:' \
        '--username=+[user]:_users' \
        '--password=+[password]:str:' \
        '--organization=+[id]:str:' \
        '--environment=+[id]:str:' \
        '--tenant-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "gravitee.yml *.yml *.yaml"' \
        '--config=+[file]:file:_files -g "gravitee.yml *.yml *.yaml"' \
        '-o+[output format]:f:(json yaml table)' \
        '--output=+[fmt]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gravitee subcommand' sub ;;
        args)
            case $words[1] in
                api|application|plan|subscription|user|group|role|category|tag|entrypoint|page|portal-page|policy|notification|dictionary|identity-provider|quality-rule|audit|tenant|dashboard) _arguments '1:op:(list get create update delete start stop publish unpublish enable disable deploy)' '*:id:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gravitee-cli "$@"
