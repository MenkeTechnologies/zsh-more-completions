#compdef ktruss
# Documentation: man ktrace(1) (documents ktruss)
# Source: netbsd/src usr.bin/ktruss — kernel trace with readable output (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[append to trace file]' \
    '-C[clear tracing on all user processes]' \
    '-c[clear tracepoints on file or processes]' \
    '-d[apply to all current children]' \
    '-e+[system call emulation (default netbsd)]:emulation:_default' \
    '-f+[read trace records from file]:infile:_files' \
    '-g+[trace all processes in process group]:pgrp:_default' \
    '-i[inherit trace flags to future children]' \
    '-l[poll trace file, print new data]' \
    '-m+[max bytes of pointer data to print]:maxdata:_default' \
    '-n[stop tracing if writes would block]' \
    '-o+[log trace records to file]:outfile:_files' \
    '-p+[trace process ID]:pid:_pids' \
    '-R[relative timestamps]' \
    '-T[absolute timestamps]' \
    '-t+[tracepoints (c=syscalls, i=I/O, n=namei, s=signals)]:trstr:_default' \
    '-v+[trace file format version]:version:(0 1)' \
    '*:::command:_normal' \
    && ret=0

return ret
