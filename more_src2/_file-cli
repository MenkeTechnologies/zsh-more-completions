#compdef file-cli
# _file-cli — file file type guesser CLI alias (file-team, C); custom argparse
# upstream: https://github.com/file/file

_file-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-b[brief output]' \
        '--brief[brief output]' \
        '-C[compile magic file]' \
        '--compile[compile magic file]' \
        '-c[check magic file]' \
        '--checking-printout[check magic file]' \
        '-d[debug magic]' \
        '--debug[debug magic]' \
        '-E[exit on first non-existent]' \
        '-e+[exclude test]:e:(apptype text encoding tokens elf soft tar json simh csv)' \
        '--exclude=+[exclude test]:e:(apptype text encoding tokens elf soft tar json simh csv)' \
        '--exclude-quiet=+[exclude test]:str:' \
        '-F+[separator]:str:' \
        '--separator=+[separator]:str:' \
        '-f+[file with names]:file:_files' \
        '--files-from=+[file with names]:file:_files' \
        '-i[mime type]' \
        '-I[mime type]' \
        '--mime[mime type]' \
        '--mime-type[mime type]' \
        '--mime-encoding[mime encoding]' \
        '-k[keep going on error]' \
        '--keep-going[keep going on error]' \
        '-l[show list of patterns]' \
        '--list[show list of patterns]' \
        '-L[follow symlinks]' \
        '--dereference[follow symlinks]' \
        '-m+[magic file]:file:_files' \
        '--magic-file=+[magic file]:file:_files' \
        '-N[no pad output]' \
        '--no-pad[no pad output]' \
        '-n[no buffer stdout]' \
        '--no-buffer[no buffer stdout]' \
        '-P+[param=value]:str:' \
        '--parameter=+[param=value]:str:' \
        '-p[do not change atime]' \
        '--preserve-date[do not change atime]' \
        '-r[print raw without backslash]' \
        '--raw[print raw without backslash]' \
        '-s[read special files]' \
        '--special-files[read special files]' \
        '-S[no use seccomp]' \
        '--no-sandbox[no use seccomp]' \
        '-z[try to look inside compressed]' \
        '--uncompress[try to look inside compressed]' \
        '-Z[try to look inside compressed]' \
        '--uncompress-noreport[try to look inside compressed]' \
        '*:files:_files'
}

_file-cli "$@"
