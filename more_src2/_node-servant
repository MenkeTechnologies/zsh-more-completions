#compdef node-servant yurt-node-servant
# _node-servant — OpenYurt per-node converter/reverter (openyurtio/openyurt)
# upstream: https://github.com/openyurtio/openyurt
# Subcommands from cmd/yurt-node-servant/node-servant.go (cobra).

_node-servant() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                convert:'convert a node to an OpenYurt edge/cloud node'
                revert:'revert OpenYurt changes on a node'
                config:'configure node-servant'
                static-pod-upgrade:'upgrade an OpenYurt-managed static pod'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_node-servant "$@"
