#compdef feedgnuplot
# Documentation: https://github.com/dkogan/feedgnuplot
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for feedgnuplot (dkogan/feedgnuplot).

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--domain[first element of each line is X variable]' \
  '--nodomain[disable --domain]' \
  '--dataid[each data point preceded by dataset ID]' \
  '--nodataid[disable --dataid]' \
  '--vnlog[read column labels from vnlog headers]' \
  '--3d[enable 3D plotting]' \
  '--no3d[disable 3D plotting]' \
  '--lines[draw lines connecting points]' \
  '--nolines[omit lines]' \
  '--points[draw individual points]' \
  '--nopoints[omit points]' \
  '--circles[plot with circles (requires radius)]' \
  '*--histogram=[create histogram for curve]:curveID:' \
  '--with=[set global plotting style]:style:' \
  '*--style=[apply style to specific curve]:curveID style:' \
  '--stream=[plot in real time with optional period]:period:' \
  '--xlen=[scrolling window size]:size:' \
  '--xlabel=[X axis label]:label:' \
  '--ylabel=[Y axis label]:label:' \
  '--zlabel=[Z axis label]:label:' \
  '--xmin=[X axis minimum]:value:' \
  '--xmax=[X axis maximum]:value:' \
  '--ymin=[Y axis minimum]:value:' \
  '--ymax=[Y axis maximum]:value:' \
  '--y2[plot against secondary Y axis]' \
  '--x2[plot against secondary X axis]' \
  '--timefmt=[parse X data as time/date]:format:' \
  '--hardcopy=[output file (format from extension)]:file:_files' \
  '--terminal=[gnuplot terminal]:term:' \
  '--dump[dump gnuplot script to stdout]' \
  '--title=[plot title]:title:' \
  '*--legend=[curve legend]:curveID label:' \
  '--autolegend[use curve IDs as legend]' \
  '*--set=[pass gnuplot set command]:expr:' \
  '*--unset=[pass gnuplot unset command]:expr:' \
  '*:data file:_files' && ret=0

return ret
