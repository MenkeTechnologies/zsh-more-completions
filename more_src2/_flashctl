#compdef flashctl
# Documentation: man flashctl(8)
# Source: netbsd/src usr.sbin/flashctl — low-level flash device operations (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:flash device:_default' \
    '2::command:(badblocks erase identify markbad)' \
    '*::offset or size:_default' \
    && ret=0

return ret
