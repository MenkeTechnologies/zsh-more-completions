#compdef florestad
# Documentation: https://github.com/vinteumorg/Floresta/blob/master/bin/florestad/src/cli.rs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# florestad: lightweight Bitcoin client (Utreexo)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--disable-dns-seeds[disable DNS seeds]' \
  '(-c --config-file)'{-c,--config-file=}'[custom config file]:file:_files' \
  '(-n --network)'{-n,--network=}'[network]:network:(bitcoin testnet testnet4 signet regtest)' \
  '(-d --debug)'{-d,--debug}'[enable debug logging]' \
  '--log-to-file[save log to $DATA_DIR/debug.log]' \
  '--data-dir=[data directory]:path:_files -/' \
  '--no-cfilters[disable Compact Block Filters]' \
  '(-p --proxy)'{-p,--proxy=}'[proxy URL e.g. 127.0.0.1:9050]:address:' \
  '*--wallet-xpub=[add xpub to wallet]:xpub:' \
  '*--wallet-descriptor=[add output descriptor to wallet]:descriptor:' \
  '--assume-valid=[assume-valid block hash or 0]:hash:' \
  '(-z --zmq-address)'{-z,--zmq-address=}'[ZeroMQ listen address]:addr:' \
  '--connect=[connect only to this node]:addr:' \
  '--rpc-address=[JSON-RPC listen address]:addr:' \
  '--filters-start-height=[block filters start height]:height:' \
  '--no-assume-utreexo[disable assume utreexo]' \
  '--electrum-address=[Electrum server listen address]:addr:' \
  '--enable-electrum-tls[enable Electrum TLS server]' \
  '--electrum-address-tls=[Electrum TLS server listen address]:addr:' \
  '--generate-cert[generate self-signed TLS cert on start]' \
  '--tls-key-path=[TLS private key path]:path:_files' \
  '--tls-cert-path=[TLS certificate path]:path:_files' \
  '--allow-v1-fallback[allow falling back to unencrypted V1 P2P]' \
  '--daemon[run as daemon (Unix)]' \
  '--pid-file=[PID file path (Unix)]:path:_files' \
  '--no-backfill[disable backfill of skipped blocks]' && ret=0

return ret
