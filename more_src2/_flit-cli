#compdef flit-cli
# _flit-cli — Flit pure-Python build/publish tool CLI alias (PyPA, Python); argparse
# upstream: https://github.com/pypa/flit

_flit-cli() {
    local -a sub=(
        'build:build sdist + wheel'
        'install:install package + deps'
        'publish:upload to PyPI'
        'init:scaffold pyproject.toml'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--debug[debug]' \
        '--ini-file=+[ini file]:file:_files' \
        '-f+[ini file]:file:_files' \
        '--ini-path=+[ini path]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flit subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--format=+[format]:fmt:(sdist wheel)' \
                    '--setup-py[also generate setup.py]' \
                    '--no-setup-py[no setup.py]' \
                    '--no-use-vcs[no vcs files]' ;;
                install) _arguments \
                    '--symlink[symlink]' \
                    '-s[symlink]' \
                    '--pth-file[pth file]' \
                    '--deps=+[deps]:d:(all develop production none)' \
                    '--extras=+[extras]:list:' \
                    '--only-deps[only deps]' \
                    '--user[user install]' \
                    '--python=+[python]:str:' \
                    '--env=+[env]:str:' ;;
                publish) _arguments \
                    '--format=+[format]:fmt:(sdist wheel)' \
                    '--repository=+[repository]:r:' \
                    '--username=+[username]:str:_users' \
                    '--password=+[password]:str:' \
                    '--setup-py[also generate setup.py]' ;;
                init) _arguments \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_flit-cli "$@"
