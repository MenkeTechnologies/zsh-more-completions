#compdef luactl
# Documentation: man luactl(8)
# Source: netbsd/src sbin/luactl — kernel Lua state control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[create Lua state before require/load]' \
    '-q[quiet, no stdout output]' \
    '1::command:(create destroy load require)' \
    '2::state name:_default' \
    '3::desc, path, or module:_files' \
    && ret=0

return ret
