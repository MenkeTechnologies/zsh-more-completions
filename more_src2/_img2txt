#compdef img2txt
# Documentation: img2txt --help (libcaca)
# Source: convert images to text in various color formats.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    {-W+,--width=}'[width of resulting image]:cols:' \
    {-H+,--height=}'[height of resulting image]:rows:' \
    {-x+,--font-width=}'[width of output font]:pixels:' \
    {-y+,--font-height=}'[height of output font]:pixels:' \
    {-b+,--brightness=}'[brightness]:value:' \
    {-c+,--contrast=}'[contrast]:value:' \
    {-g+,--gamma=}'[gamma]:value:' \
    {-d+,--dither=}'[dithering algorithm]:algo:(none ordered2 ordered4 ordered8 random fstein)' \
    {-f+,--format=}'[output format]:fmt:(caca ansi utf8 utf8cr html html3 bbfr irc tga troff ps svg)' \
    ':image:_files' \
    && ret=0

return ret
