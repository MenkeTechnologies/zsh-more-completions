#compdef mhwd-kernel
# _mhwd-kernel — Manjaro kernel management helper (manjaro/mhwd)
# upstream: https://github.com/manjaro/mhwd
# Flags from scripts/mhwd-kernel.

_mhwd-kernel() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-i --install)'{-i,--install}'[install one or more kernels]' \
        '(-l --list)'{-l,--list}'[list available kernels]' \
        '(-li --listinstalled)'{-li,--listinstalled}'[list installed kernels]' \
        '(-r --remove)'{-r,--remove}'[remove one or more kernels]' \
        '*:kernel:'
}

_mhwd-kernel "$@"
