#compdef doh-client
# _doh-client — DNS-over-HTTPS client (m13253/dns-over-https)
# upstream: https://github.com/m13253/dns-over-https
# Flags from doh-client/main.go (flag).

_doh-client() {
    _arguments \
        '(- *)-version[show version]' \
        '-conf+[config file]:file:_files -g "*.(conf|toml)"' \
        '-verbose[enable logging]' \
        '-pid-file+[PID file path]:file:_files'
}

_doh-client "$@"
