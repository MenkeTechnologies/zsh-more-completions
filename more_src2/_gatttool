#compdef gatttool
# _gatttool — BlueZ gatttool (interactive GATT (Generic Attribute Profile) client for Bluetooth Low Energy; -b/--device target BD_ADDR, -t/--addr-type random|public, -I interactive shell, --primary discover primary services, --characteristics, --char-read/--char-write[-req], --listen)
# upstream: https://github.com/bluez/bluez (attrib/gatttool.c)
# Flags from bluez attrib/gatttool.c on tip.

_gatttool() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX source]:device:' \
        '-b+[target BD_ADDR]:address:' \
        '--device+[target BD_ADDR]:address:' \
        '-t+[address type]:type:(public random)' \
        '--addr-type+[address type]:type:(public random)' \
        '-m+[MTU]:mtu:' \
        '--mtu+[MTU]:mtu:' \
        '-l+[link security]:level:(low medium high)' \
        '--sec-level+[link security]:level:(low medium high)' \
        '-I[interactive REPL]' \
        '--interactive[interactive REPL]' \
        '--primary[discover primary services]' \
        '--characteristics[discover characteristics]' \
        '--char-read[read characteristic]' \
        '--char-write[write characteristic w/o response]' \
        '--char-write-req[write characteristic w/ response]' \
        '--char-desc[discover descriptors]' \
        '-a+[handle]:handle:' \
        '--handle+[handle]:handle:' \
        '-s+[start handle]:start:' \
        '--start+[start handle]:start:' \
        '-e+[end handle]:end:' \
        '--end+[end handle]:end:' \
        '-u+[UUID]:uuid:' \
        '--uuid+[UUID]:uuid:' \
        '-n+[value to write]:value:' \
        '--value+[value to write]:value:' \
        '--listen[listen for notifications/indications]'
}

_gatttool "$@"
