#compdef opsgenie-cli lamp
# _opsgenie-cli — Atlassian Opsgenie opsgenie-cli CLI command-line frontend wrapping the Opsgenie incident management on-call paging platform REST API providing alert team schedule rotation escalation policy integration heartbeat user contact maintenance OEC marid LAMP-Java alerting closeAlert acknowledgeAlert addNote getRequestStatus assignAlert addResponder addTags addTeam createAlert deleteAlert (Atlassian Opsgenie team, Java); custom argparse
# upstream: https://www.atlassian.com/software/opsgenie

_opsgenie-cli() {
    local -a sub=(
        'createAlert:create an alert'
        'getAlert:get an alert'
        'closeAlert:close an alert'
        'acknowledgeAlert:acknowledge an alert'
        'unacknowledgeAlert:unacknowledge an alert'
        'listAlerts:list alerts'
        'addNote:add a note'
        'addTags:add tags'
        'removeTags:remove tags'
        'assignAlert:assign an alert'
        'addResponder:add responder'
        'addTeam:add team'
        'snoozeAlert:snooze an alert'
        'escalateToNext:escalate to next'
        'deleteAlert:delete an alert'
        'executeAction:execute action'
        'getRequestStatus:get request status'
        'heartbeat:heartbeat operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--apiKey=+[key]:str:' \
        '--apiUrl=+[url]:str:' \
        '-config+[file]:file:_files -g "*.conf opsgenie-integration.conf"' \
        '--config=+[file]:file:_files -g "*.conf opsgenie-integration.conf"' \
        '--id=+[alert id]:str:' \
        '--alias=+[alias]:str:' \
        '--message=+[msg]:str:' \
        '--description=+[desc]:str:' \
        '--source=+[name]:str:' \
        '--entity=+[name]:str:' \
        '--user=+[name]:str:' \
        '--note=+[text]:str:' \
        '--tags=+[tags]:str:' \
        '--actions=+[actions]:str:' \
        '--details=+[k=v]:str:' \
        '--responders=+[r]:str:' \
        '--teams=+[teams]:str:' \
        '--visibleTo=+[v]:str:' \
        '--priority=+[p]:p:(P1 P2 P3 P4 P5)' \
        '--snoozeUntil=+[ts]:str:' \
        '--asynchronous[asynchronous]' \
        '--output-format=+[fmt]:f:(json yaml table plain)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opsgenie subcommand' sub ;;
        args)
            case $words[1] in
                heartbeat) _arguments '1:op:(send list create delete enable disable)' '*:name:' ;;
            esac
            ;;
    esac
}

_opsgenie-cli "$@"
