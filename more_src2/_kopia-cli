#compdef kopia-cli kopia
# _kopia-cli — Jaroslaw Kowalski Kopia fast secure encrypted backup tool CLI alias (kopia team, Go); kingpin
# upstream: https://github.com/kopia/kopia

_kopia-cli() {
    local -a sub=(
        'benchmark:run benchmarks'
        'benchmark:compression:benchmark compression'
        'benchmark:crypto:benchmark crypto'
        'benchmark:encryption:benchmark encryption'
        'benchmark:hashing:benchmark hashing'
        'benchmark:splitters:benchmark splitters'
        'blob:list:list blob objects'
        'blob:gc:run blob GC'
        'blob:show:show blob contents'
        'blob:delete:delete blob'
        'blob:stats:show blob statistics'
        'cache:clear:clear local cache'
        'cache:info:show cache info'
        'cache:set:set cache size'
        'cache:sync:sync cache'
        'content:list:list content blocks'
        'content:show:show content'
        'content:rewrite:rewrite content'
        'content:stats:show content stats'
        'content:verify:verify content'
        'diff:diff two snapshots'
        'diff-snapshot:diff snapshots'
        'help:show help'
        'index:epoch:advance:advance epoch'
        'index:epoch:list:list epochs'
        'index:list:list index files'
        'index:optimize:optimize index'
        'index:recover:recover index'
        'index:show:show index'
        'index:verify:verify index'
        'logs:cleanup:cleanup logs'
        'logs:list:list logs'
        'logs:show:show logs'
        'manifest:delete:delete manifest'
        'manifest:list:list manifests'
        'manifest:show:show manifest'
        'mount:mount snapshot'
        'object:show:show object'
        'object:verify:verify object'
        'policy:edit:edit policy'
        'policy:export:export policy'
        'policy:import:import policy'
        'policy:list:list policies'
        'policy:remove:remove policy'
        'policy:set:set policy'
        'policy:show:show policy'
        'repository:change-password:change repo password'
        'repository:connect:connect to repo'
        'repository:create:create repo'
        'repository:disconnect:disconnect'
        'repository:set-client:configure client'
        'repository:set-parameters:set repo parameters'
        'repository:status:repo status'
        'repository:sync-to:sync repo'
        'repository:throttle:throttle repo'
        'repository:upgrade:upgrade repo'
        'restore:restore from snapshot'
        'server:start:start UI server'
        'server:user:list:list server users'
        'server:user:add:add server user'
        'server:user:set:set server user'
        'server:user:delete:delete server user'
        'snapshot:copy:copy snapshot'
        'snapshot:create:create snapshot'
        'snapshot:delete:delete snapshot'
        'snapshot:expire:expire old snapshots'
        'snapshot:fix:fix snapshot'
        'snapshot:list:list snapshots'
        'snapshot:migrate:migrate snapshot'
        'snapshot:move-history:move history'
        'snapshot:pin:pin snapshot'
        'snapshot:verify:verify snapshot'
        'show:show object'
        'task:list:list tasks'
        'task:show:show task'
        'task:cancel:cancel task'
        'theme:set:set theme'
        'ui:run UI'
        'maintenance:info:show maintenance info'
        'maintenance:run:run maintenance'
        'maintenance:set:set maintenance config'
        'completion:generate completion'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-file=+[config file]:file:_files -g "*.config"' \
        '--log-dir=+[log dir]:dir:_files -/' \
        '--persist-credentials[persist credentials]' \
        '--no-persist-credentials[no persist credentials]' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--cache-directory=+[cache dir]:dir:_files -/' \
        '--metrics-listen-addr=+[addr]:str:' \
        '--metrics-push-addr=+[addr]:str:' \
        '--no-progress[no progress]' \
        '--enable-pprof[enable pprof]' \
        '--profile-dir=+[profile dir]:dir:_files -/' \
        '--profile-cpu=+[duration]:str:' \
        '--profile-mem=+[seconds]:n:' \
        '--profile-block=+[seconds]:n:' \
        '--trace-storage[trace storage]' \
        '--track-memory-usage[track memory usage]' \
        '--log-level=+[level]:l:(debug info warning error)' \
        '--file-log-level=+[level]:l:(debug info warning error)' \
        '--log-file=+[log file]:file:_files' \
        '--log-file-max-size=+[mb]:n:' \
        '--log-file-max-count=+[count]:n:' \
        '--log-file-max-age=+[duration]:str:' \
        '--auto-update[enable auto update]' \
        '--no-auto-update[disable auto update]' \
        '--update-channel=+[channel]:c:(stable testing edge)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kopia subcommand' sub ;;
        args)
            case $words[1] in
                snapshot:create) _arguments \
                    '*:path:_files' \
                    '--description=+[description]:str:' \
                    '--tags=+[tag csv]:str:' \
                    '--start-time=+[time]:str:' \
                    '--end-time=+[time]:str:' \
                    '--manual[manual snapshot]' \
                    '--checkpoint-interval=+[duration]:str:' \
                    '--force-hash-percentage=+[percent]:n:' ;;
                snapshot:list) _arguments \
                    '*:path:_files' \
                    '--all[all snapshots]' \
                    '-a[all snapshots]' \
                    '--max-results=+[n]:n:' \
                    '-n+[n]:n:' \
                    '--show-identical[show identical]' \
                    '-l[long format]' \
                    '--show-summary[show summary]' \
                    '--show-stats[show stats]' \
                    '-s[show stats]' \
                    '--show-human-readable[human readable sizes]' \
                    '-h[human readable sizes]' \
                    '--reverse[reverse]' ;;
                restore) _arguments \
                    '1:source:' \
                    '2:target:_files -/' \
                    '--overwrite-files[overwrite files]' \
                    '--overwrite-directories[overwrite dirs]' \
                    '--overwrite-symlinks[overwrite symlinks]' \
                    '--skip-existing[skip existing]' \
                    '--skip-owners[skip owners]' \
                    '--skip-permissions[skip permissions]' \
                    '--skip-times[skip times]' \
                    '--restore-direct-actions[restore direct actions]' \
                    '--restore-deleted[restore deleted]' \
                    '--restore-symlinks[restore symlinks]' \
                    '--parallel=+[parallel]:n:' \
                    '--write-files-atomically[write atomic]' \
                    '--write-sparse-files[write sparse]' \
                    '--shallow=+[depth]:n:' \
                    '--shallow-minsize=+[bytes]:n:' \
                    '--ignore-permission-errors[ignore permission errors]' ;;
                repository:create) _arguments \
                    '1:provider:(filesystem s3 azure b2 gcs sftp webdav rclone)' \
                    '--description=+[description]:str:' \
                    '--encryption=+[algorithm]:a:(AES256-GCM-HMAC-SHA256 CHACHA20-POLY1305-HMAC-SHA256)' \
                    '--hashing=+[algorithm]:a:(HMAC-SHA256 HMAC-SHA256-128 HMAC-SHA224 BLAKE2B-256-128 BLAKE2S-128 BLAKE3-256)' \
                    '--splitter=+[splitter]:s:(FIXED-4M FIXED-8M DYNAMIC-2M-BUZHASH DYNAMIC-4M-BUZHASH DYNAMIC-8M-BUZHASH DYNAMIC-2M-RABINKARP DYNAMIC-4M-RABINKARP DYNAMIC-8M-RABINKARP)' \
                    '--object-format-version=+[version]:n:' \
                    '--ecc=+[ecc algorithm]:str:' \
                    '--ecc-overhead-percent=+[percent]:n:' ;;
                completion) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_kopia-cli "$@"
