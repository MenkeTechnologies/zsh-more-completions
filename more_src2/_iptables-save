#compdef iptables-save ip6tables-save
# Documentation: https://man.archlinux.org/man/iptables-save.8.en
# Reference accessed: 2026-05-30
# iptables-save / ip6tables-save — dump current iptables rules to a file or stdout. Multi-stem.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-M --modprobe)'{-M,--modprobe=}'[path to modprobe (default reads /proc/sys/kernel/modprobe)]:path:_files' \
  '(-f --file)'{-f,--file=}'[output filename (default stdout)]:file:_files' \
  '(-c --counters)'{-c,--counters}'[include current packet + byte counter values]' \
  '(-t --table)'{-t,--table=}'[restrict output to a single table]:table:(filter nat mangle raw security)' \
  && ret=0

return ret
