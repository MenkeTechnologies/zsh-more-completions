#compdef nvidia-installer
# Documentation: https://github.com/NVIDIA/nvidia-installer/blob/main/option_table.h
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvidia-installer: NVIDIA proprietary driver installer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-A,--advanced-options}'[show advanced help]' \
  '(-a --accept-license)'{-a,--accept-license}'[accept license non-interactively]' \
  '(-i --driver-info)'{-i,--driver-info}'[print driver info and exit]' \
  '--uninstall[uninstall driver]' \
  '--sanity[run sanity test]' \
  '(-e --expert)'{-e,--expert}'[expert mode]' \
  '(-q --no-questions)'{-q,--no-questions}'[do not prompt user]' \
  '(-s --silent)'{-s,--silent}'[silent install]' \
  '--skip-module-unload[skip module unload]' \
  '--skip-module-load[skip module load]' \
  '--x-prefix=[X install prefix]:dir:_files -/' \
  '--x-module-path=[X module path]:dir:_files -/' \
  '--x-library-path=[X library path]:dir:_files -/' \
  '--x-sysconfig-path=[X sysconfig path]:dir:_files -/' \
  '--opengl-prefix=[OpenGL install prefix]:dir:_files -/' \
  '--opengl-libdir=[OpenGL libdir]:dir:_files -/' \
  '--wine-prefix=[Wine prefix]:dir:_files -/' \
  '--wine-libdir=[Wine libdir]:dir:_files -/' \
  '--utility-prefix=[utility prefix]:dir:_files -/' \
  '--utility-libdir=[utility libdir]:dir:_files -/' \
  '--documentation-prefix=[documentation prefix]:dir:_files -/' \
  '--application-profile-path=[app profile path]:dir:_files -/' \
  '--xdg-data-dir=[XDG data directory]:dir:_files -/' \
  '--gbm-backend-dir=[GBM backend dir]:dir:_files -/' \
  '--gbm-backend-dir32=[32-bit GBM backend dir]:dir:_files -/' \
  '--kernel-source-path=[kernel source path]:dir:_files -/' \
  '--kernel-output-path=[kernel output path]:dir:_files -/' \
  '--kernel-install-path=[kernel install path]:dir:_files -/' \
  '(-k --kernel-name)'{-k+,--kernel-name=}'[kernel name]:ver:' \
  '(-n --no-precompiled-interface)'{-n,--no-precompiled-interface}'[disable precompiled kernel interface]' \
  '--no-kernel-modules[skip kernel module install]' \
  '(-K --kernel-modules-only)'{-K,--kernel-modules-only}'[install only kernel modules]' \
  '--no-kernel-module-source[no kernel module source]' \
  '--kernel-module-source-prefix=[kernel module source prefix]:dir:_files -/' \
  '--kernel-module-source-dir=[kernel module source dir]:dir:_files -/' \
  '(-M --kernel-module-type)'{-M+,--kernel-module-type=}'[kernel module type]:type:' \
  '(-m --kernel-module-build-directory)'{-m+,--kernel-module-build-directory=}'[build directory]:dir:_files -/' \
  '--module-signing-secret-key=[module signing private key]:file:_files' \
  '--module-signing-public-key=[module signing public key]:file:_files' \
  '--module-signing-script=[module signing script]:file:_files' \
  '--module-signing-key-path=[module signing key path]:dir:_files -/' \
  '--module-signing-hash=[module signing hash]:algo:' \
  '--module-signing-x509-hash=[module signing X.509 hash]:algo:' \
  '--dkms[install via DKMS]' \
  '--no-dkms[skip DKMS]' \
  '--ui=[user interface]:ui:(stdio ncurses none)' \
  '(-c --no-ncurses-color)'{-c,--no-ncurses-color}'[disable ncurses colors]' \
  '--proc-mount-point=[proc mount point]:dir:_files -/' \
  '--tmpdir=[temp directory]:dir:_files -/' \
  '--log-file-name=[log file]:file:_files' \
  '--systemd[enable systemd integration]' \
  '--no-systemd[disable systemd integration]' \
  '--systemd-unit-prefix=[systemd unit prefix]:dir:_files -/' \
  '--systemd-sleep-prefix=[systemd sleep prefix]:dir:_files -/' \
  '--systemd-sysconf-prefix=[systemd sysconf prefix]:dir:_files -/' \
  '--skip-depmod[skip running depmod]' \
  '--no-nvidia-modprobe[do not install nvidia-modprobe]' \
  '--no-abi-note[skip ABI note]' \
  '--no-rpms[skip RPM operations]' \
  '(-b --no-backup)'{-b,--no-backup}'[no backup of overwritten files]' \
  '(-r --no-recursion)'{-r,--no-recursion}'[no recursive file ops]' \
  '--no-x-check[skip X running check]' \
  '--no-opengl-files[skip OpenGL files]' \
  '--no-wine-files[skip Wine files]' \
  '--no-distro-scripts[skip distro scripts]' \
  '--no-unified-memory[skip unified memory module]' \
  '--no-drm[skip DRM kernel module]' \
  '--no-peermem[skip nvidia-peermem module]' \
  '(-X --run-nvidia-xconfig)'{-X,--run-nvidia-xconfig}'[run nvidia-xconfig after install]' \
  '--force-libglx-indirect[force libglx indirect rendering]' \
  '--no-libglx-indirect[do not force libglx indirect]' \
  '--install-libglvnd[install libglvnd]' \
  '--no-install-libglvnd[skip libglvnd]' \
  '--glvnd-egl-config-path=[GLVND EGL config path]:dir:_files -/' \
  '--egl-external-platform-config-path=[EGL external platform config path]:dir:_files -/' \
  '--force-selinux=[force SELinux handling]:mode:(yes no default)' \
  '--selinux-chcon-type=[SELinux chcon type]:type:' \
  '--no-sigwinch-workaround[disable SIGWINCH workaround]' \
  '(-z --no-nouveau-check)'{-z,--no-nouveau-check}'[skip nouveau check]' \
  '(-Z --disable-nouveau)'{-Z,--disable-nouveau}'[disable nouveau]' \
  '--no-disable-nouveau[do not disable nouveau]' \
  '--no-cc-version-check[skip cc version check]' \
  '--no-check-for-alternate-installs[skip alternate install check]' \
  '--compat32-chroot=[compat32 chroot path]:dir:_files -/' \
  '--compat32-prefix=[compat32 prefix]:dir:_files -/' \
  '--compat32-libdir=[compat32 libdir]:dir:_files -/' \
  '--install-compat32-libs[install 32-bit compat libs]' \
  '--no-install-compat32-libs[skip 32-bit compat libs]' \
  '--override-file-type-destination=[override file type destination]:spec:' \
  '(-j --concurrency-level)'{-j+,--concurrency-level=}'[parallel build jobs]:n:' \
  '--precompiled-kernel-interfaces-path=[precompiled kernel interfaces path]:dir:_files -/' \
  '--allow-installation-with-running-driver[install with running driver]' \
  '--release-fb-console[release framebuffer console]' \
  '--rebuild-initramfs[rebuild initramfs]' \
  '--no-rebuild-initramfs[skip initramfs rebuild]' \
  '--print-recommended-kernel-module-type[print recommended kernel module type]' \
  '--update[update installer]' \
  '(-d --debug)'{-d,--debug}'[enable debug output]' \
  '(-N --no-network)'{-N,--no-network}'[disable network operations]' \
  '*::nvidia-installer args:_files' && ret=0
return ret
