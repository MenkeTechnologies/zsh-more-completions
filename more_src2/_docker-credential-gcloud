#compdef docker-credential-gcloud
# Documentation: https://docs.cloud.google.com/artifact-registry/docs/docker/authentication
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Docker credential helper protocol: store, get, erase, list
# (see github.com/docker/docker-credential-helpers)
local -a arguments

arguments=(
    '1:action:(store get erase list version)'
)

_arguments -s -S $arguments
