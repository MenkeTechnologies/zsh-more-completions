#compdef etcdutl
# Documentation: https://github.com/etcd-io/etcd/blob/main/etcdutl/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--write-out=[output format]:format:(simple json table fields protobuf)' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'defrag:defragment an etcd data directory'
      'snapshot:manage etcd snapshots'
      'hashkv:print hash of keys and values up to a given revision'
      'version:print version of etcdutl and API'
      'list-bucket:list all bucket names'
      'iterate-bucket:list key-value pairs in a bucket in reverse order'
      'hash:print hash of the database file'
      'completion:generate shell completion script'
    )
    _describe -t commands 'etcdutl command' commands && ret=0
    ;;
  args)
    case $line[1] in
      defrag)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--data-dir=[path to etcd data directory]:directory:_directories' && ret=0
        ;;
      snapshot)
        local -a snap_commands=(
          'restore:restore an etcd data directory from a snapshot'
          'status:show snapshot status (hash, revision, totalKey, totalSize)'
        )
        _describe -t commands 'snapshot command' snap_commands && ret=0
        ;;
      hashkv)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--rev=[maximum revision to hash]:revision:' \
          '1:snapshot file:_files' && ret=0
        ;;
      iterate-bucket)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--limit=[max entries to print]:n:' \
          '--decode[decode keys/values]' \
          '1:snapshot file:_files' \
          '2:bucket name:' && ret=0
        ;;
      list-bucket|hash)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:snapshot file:_files' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
