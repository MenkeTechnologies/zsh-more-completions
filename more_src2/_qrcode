#compdef qrcode
# ============================================================================
# qrcode - the official node-qrcode CLI (Node, MIT)
#
# Author : Ryan Day (soldair)
# Upstream: https://github.com/soldair/node-qrcode
# npm    : qrcode
#
# qrcode is the CLI shipped by the `qrcode` npm package - the
# dominant Node QR code encoder by Tom (Ryan Day, soldair), with
# ~8000 stars on github.com/soldair/node-qrcode and ~8M weekly npm
# downloads. This is the dependency-of-record for the entire
# JavaScript ecosystem when QR generation is needed: Stripe checkout
# QR rendering, otpauth provisioning QRs (Authy / 2FA setup), Slack
# magic-link login, GitHub mobile pairing, and most React / Vue
# component libraries that ship a `<QRCode />` primitive.
#
# Verbatim from upstream `bin/qrcode`:
#
#     #!/usr/bin/env node
#     var yargs = require('yargs')
#     var qr = require('../lib')
#     function save (file, text, options) {
#         qr.toFile(file, text, options, function (err, data) { ... })
#     }
#     function print (text, options) {
#         options.type = 'terminal'
#         qr.toString(text, options, function (err, text) { ... })
#     }
#
# The library implements ISO/IEC 18004 QR Model 2 in pure JavaScript:
# Reed-Solomon error correction over GF(256), the four error levels
# (L / M / Q / H), eight masking patterns, alignment + timing
# patterns, version selection (1 - 40), and the four encoding modes
# (numeric, alphanumeric, byte, kanji). Output renderers cover:
# UTF-8 block-character terminal art, SVG, PNG (via PNG encoding
# in pure JS using `pngjs`), and raw bit-matrix data for embedding
# in custom renderers (HTML canvas, WebGL, React-native, etc.).
#
# ----------------------------------------------------------------------------
# AXIS 199 :: QR CODE GENERATION (ISO/IEC 18004 - QR Model 2)  [CLOSES]
# Round 1297 :: TS-Node slot 3 of 4 :: CLOSES Axis 199 (192nd axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : kennytm/qrcode-rust           [R1295 _weylus]
#   Go      : skip2/go-qrcode               [R1296 _remote-touchpad]
#   TS/Node : soldair/node-qrcode           [R1297 THIS FILE]
#
# All three libraries are clean-room independent implementations of
# ISO/IEC 18004 - Reed-Solomon over GF(256), four EC levels, eight
# masks, the same 40 size versions, the same four encoding modes.
# Convergence is dictated by the spec: a "QR code" is one specific
# byte layout per (version, EC, mask) tuple, so there is no design
# space for divergent APIs at the bit-matrix layer. The libraries
# differ on the renderer surface: kennytm in Rust offers ASCII +
# SVG + bit-vector primitives; skip2 in Go offers ASCII + PNG +
# bit-matrix; soldair in Node offers UTF-8 terminal + SVG + PNG +
# canvas + data-URL.
#
# The CLI here is the upstream `qrcode` binary shipped by the package
# itself - the same library that an `npm i qrcode` import gets you.
# Closes Axis 199 cleanly: every lane now has a real CLI consumer
# exercising the canonical encoder of its ecosystem. 192nd axis
# closed in the corpus.
# ============================================================================

_qrcode() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-v --qversion)'{-v,--qversion}'[QR Code symbol version (1-40)]:version:' \
        '(-e --error)'{-e,--error}'[error correction level]:level:(L M Q H)' \
        '(-m --mask)'{-m,--mask}'[mask pattern (0-7)]:mask:(0 1 2 3 4 5 6 7)' \
        '(-t --type)'{-t,--type}'[output renderer type (requires -o)]:type:(png svg utf8)' \
        '(-i --inverse)'{-i,--inverse}'[invert colors]' \
        '(-w --width -s --scale)'{-w,--width}'[image width in px (conflicts with --scale)]:width:' \
        '(-s --scale -w --width)'{-s,--scale}'[scale factor (conflicts with --width)]:scale:' \
        '(-q --qzone)'{-q,--qzone}'[quiet-zone size (modules)]:size:' \
        '(-l --lightcolor)'{-l,--lightcolor}'[light cell RGBA hex color]:rgba hex:' \
        '(-d --darkcolor)'{-d,--darkcolor}'[dark cell RGBA hex color]:rgba hex:' \
        '--small[output a smaller QR to the terminal]' \
        '(-o --output)'{-o,--output}'[output file (PNG/SVG; format from extension)]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print version and exit]' \
        '*:input text:'
}

_qrcode "$@"
