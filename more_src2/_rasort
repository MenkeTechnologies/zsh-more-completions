#compdef rasort
# _rasort — Carter Bullard QoSient Argus rasort CLI for sorting Argus flow records by per-field keys bytes packets duration source destination supporting tuple-aware ascending descending orderings (qosient team, C); getopt
# upstream: https://github.com/openargus/clients

_rasort() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-m+[key list]:str:' \
        '--match=+[key list]:str:' \
        '-M+[match mode]:m:(ip vlan mpls icmp tcp udp arp dns dhcp http https ssh ftp smtp pop3 imap ntp snmp ldap radius diameter sctp telnet)' \
        '-r+[read file]:file:_files -g "*.argus *.arg"' \
        '--read=+[read file]:file:_files -g "*.argus *.arg"' \
        '-w+[write file]:file:_files -g "*.argus *.arg"' \
        '--write=+[write file]:file:_files -g "*.argus *.arg"' \
        '-F+[fields]:str:' \
        '--fields=+[fields]:str:' \
        '-s+[sort fields]:str:' \
        '--sort=+[sort fields]:str:' \
        '-A+[reverse sort]' \
        '--reverse[reverse sort]' \
        '-N+[N records]:n:' \
        '--limit=+[N records]:n:' \
        '-c+[csv]:str:' \
        '--csv[csv output]' \
        '-X+[hex output]' \
        '-e+[encoding]:e:(ascii encoded)' \
        '*:files:_files -g "*.argus *.arg *.bin *.dat"'
}

_rasort "$@"
