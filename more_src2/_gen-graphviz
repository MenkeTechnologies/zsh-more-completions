#compdef gen-graphviz
# _gen-graphviz — render a LinkML schema as a Graphviz dot graph (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/dotgen.py (click).

_gen-graphviz() {
    local -a args
    args=(
        '--directory=[output directory (one graph per class)]:dir:_files -/'
        '(-o --out)'{-o+,--out=}'[single output file (overrides --directory)]:file:_files -g "*.(dot|png|svg|pdf)"'
        '*'{-c+,--classname=}'[class to render (repeatable)]:class:'
        '(-f --format)'{-f+,--format=}'[output format]:format:(dot png svg pdf jpg)'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-graphviz "$@"
