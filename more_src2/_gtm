#compdef gtm
# _gtm — git-time-metric gtm (lightweight automatic time tracker for git: records time spent per file in commit notes; subcommands: init, uninit, status, commit, record, report, verify, clean, plumbing; flags depend on subcommand (--tags, --terminal, --total-only, --format))
# upstream: https://github.com/git-time-metric/gtm
# Subcommands from gtm cli/main.go on tip.

_gtm() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gtm command' '(init uninit status commit record report verify clean plumbing help version)' ;;
        args)
            case $line[1] in
                report) _arguments \
                    '--format=*[output format]:format:(json text long short timeline summary)' \
                    '--total-only[summary only]' \
                    '--terminal-only[show terminal time only]' \
                    '*:commit:' ;;
                init|uninit) _arguments '--auto-log[enable auto-log]' '--terminal[track terminal]' ;;
                record) _arguments '--terminal[record terminal time]' '--status[print status]' '*:file:_files' ;;
                status) _arguments '--total-only[print total only]' '--terminal-only[terminal only]' '--profile[profile output]' ;;
            esac
            ;;
    esac
}

_gtm "$@"
