#compdef mysqld_exporter
# Documentation: https://github.com/prometheus/mysqld_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--mysqld.address=[MySQL server address]:address:' \
  '--mysqld.username=[MySQL username]:username:' \
  '--config.my-cnf=[path to .my.cnf file]:file:_files' \
  '--exporter.lock_wait_timeout=[timeout for acquiring metadata locks]:seconds:' \
  '--collect.info_schema.tables[enable info_schema.tables collector]' \
  '--no-collect.info_schema.tables[disable info_schema.tables collector]' \
  '--collect.info_schema.innodb_tablespaces[enable info_schema.innodb_tablespaces collector]' \
  '--no-collect.info_schema.innodb_tablespaces[disable info_schema.innodb_tablespaces collector]' \
  '--collect.info_schema.innodb_metrics[enable info_schema.innodb_metrics collector]' \
  '--no-collect.info_schema.innodb_metrics[disable info_schema.innodb_metrics collector]' \
  '--collect.global_status[enable global_status collector]' \
  '--no-collect.global_status[disable global_status collector]' \
  '--collect.global_variables[enable global_variables collector]' \
  '--no-collect.global_variables[disable global_variables collector]' \
  '--collect.slave_status[enable slave_status collector]' \
  '--no-collect.slave_status[disable slave_status collector]' \
  '--collect.binlog_size[enable binlog_size collector]' \
  '--no-collect.binlog_size[disable binlog_size collector]' \
  '--collect.perf_schema.tableiowaits[enable perf_schema.tableiowaits collector]' \
  '--no-collect.perf_schema.tableiowaits[disable perf_schema.tableiowaits collector]' \
  '--collect.perf_schema.indexiowaits[enable perf_schema.indexiowaits collector]' \
  '--no-collect.perf_schema.indexiowaits[disable perf_schema.indexiowaits collector]' \
  '--collect.perf_schema.tablelocks[enable perf_schema.tablelocks collector]' \
  '--no-collect.perf_schema.tablelocks[disable perf_schema.tablelocks collector]' \
  '--collect.perf_schema.eventsstatements[enable perf_schema.eventsstatements collector]' \
  '--no-collect.perf_schema.eventsstatements[disable perf_schema.eventsstatements collector]' \
  '--collect.perf_schema.eventsstatementssum[enable perf_schema.eventsstatementssum collector]' \
  '--no-collect.perf_schema.eventsstatementssum[disable perf_schema.eventsstatementssum collector]' \
  '--collect.perf_schema.eventswaits[enable perf_schema.eventswaits collector]' \
  '--no-collect.perf_schema.eventswaits[disable perf_schema.eventswaits collector]' \
  '--collect.perf_schema.file_events[enable perf_schema.file_events collector]' \
  '--no-collect.perf_schema.file_events[disable perf_schema.file_events collector]' \
  '--collect.perf_schema.file_instances[enable perf_schema.file_instances collector]' \
  '--no-collect.perf_schema.file_instances[disable perf_schema.file_instances collector]' \
  '--collect.perf_schema.memory_events[enable perf_schema.memory_events collector]' \
  '--no-collect.perf_schema.memory_events[disable perf_schema.memory_events collector]' \
  '--collect.auto_increment.columns[enable auto_increment.columns collector]' \
  '--no-collect.auto_increment.columns[disable auto_increment.columns collector]' \
  '--collect.heartbeat[enable heartbeat collector]' \
  '--no-collect.heartbeat[disable heartbeat collector]' \
  '--collect.mysql.user[enable mysql.user collector]' \
  '--no-collect.mysql.user[disable mysql.user collector]' && ret=0

return ret
