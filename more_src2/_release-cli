#compdef release-cli
# Documentation: https://gitlab.com/gitlab-org/release-cli
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above. NOTE: deprecated in
# GitLab 18.0, planned for removal in 20.0 — users directed to glab.
# Added missing get/update/create-from-file subcommands and global
# flags (server-url, project-id, job-token, private-token, timeout,
# additional-ca-cert-bundle, insecure-https, debug).

# release-cli: GitLab release automation (deprecated, use glab)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'create:create a release'
  'create-from-file:create a release from a YAML config file'
  'get:get a release'
  'update:update an existing release'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--server-url=[GitLab instance base URL]:url:' \
  '--job-token=[CI job token]:token:' \
  '--project-id=[GitLab project ID]:id:' \
  '--private-token=[personal access token]:token:' \
  '--timeout=[HTTP client timeout]:duration:' \
  '--additional-ca-cert-bundle=[custom CA cert bundle]:bundle:' \
  '--insecure-https[skip TLS verification]' \
  '--debug[enable debug output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'release-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--name=[release name]:name:' \
          '--tag-name=[tag name]:tag:' \
          '--tag-message=[message for new annotated tags]:message:' \
          '--description=[description (file or string)]:desc:' \
          '--ref=[commit SHA, tag, or branch name]:ref:' \
          '--released-at=[released-at timestamp (ISO 8601)]:ts:' \
          '*--milestone=[milestone (repeatable)]:milestone:' \
          '*--assets-link=[asset link JSON (repeatable)]:json:' && ret=0
        ;;
      (create-from-file)
        _arguments \
          '--file=[YAML configuration file]:file:_files' && ret=0
        ;;
      (get)
        _arguments \
          '--tag-name=[associated git tag]:tag:' \
          '--include-html-description[return HTML-rendered description]' && ret=0
        ;;
      (update)
        _arguments \
          '--tag-name=[associated git tag]:tag:' \
          '--name=[release name]:name:' \
          '--description=[description (file or string)]:desc:' \
          '*--milestone=[milestone (pass empty string to clear all)]:milestone:' \
          '--released-at=[released-at timestamp (ISO 8601)]:ts:' && ret=0
        ;;
    esac
    ;;
esac
return ret
