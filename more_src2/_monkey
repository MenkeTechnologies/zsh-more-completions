#compdef monkey
# Documentation: https://developer.android.com/studio/test/monkey
# Source: Android SDK — pseudo-random user-event stress tester (run inside `adb shell monkey`).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[print usage]' \
    '*-v[increase verbosity (repeat for more)]' \
    '-s[seed for pseudo-random generator]:seed:' \
    '--throttle=[fixed delay between events (ms)]:ms:' \
    '--pct-touch=[percentage of touch events]:pct:' \
    '--pct-motion=[percentage of motion events]:pct:' \
    '--pct-trackball=[percentage of trackball events]:pct:' \
    '--pct-nav=[percentage of basic navigation events]:pct:' \
    '--pct-majornav=[percentage of major navigation events]:pct:' \
    '--pct-syskeys=[percentage of system key events]:pct:' \
    '--pct-appswitch=[percentage of activity launches]:pct:' \
    '--pct-anyevent=[percentage of other events]:pct:' \
    '*-p[allowed package name (repeat for more)]:package:' \
    '*-c[allowed Intent category (repeat for more)]:category:' \
    '--dbg-no-events[launch initial activity but emit no events]' \
    '--hprof[generate profiling reports before and after run]' \
    '--ignore-crashes[continue on application crash]' \
    '--ignore-timeouts[continue on ANR timeout]' \
    '--ignore-security-exceptions[continue on permission error]' \
    '--kill-process-after-error[kill the failing process on error]' \
    '--monitor-native-crashes[watch + report native code crashes]' \
    '--wait-dbg[wait until a debugger attaches]' \
    '*:event count:' \
    && ret=0

return ret
