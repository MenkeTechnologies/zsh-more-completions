#compdef kpat
# Documentation: https://man.archlinux.org/man/kpat.6
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# KPatience: KDE solitaire card game. Corrected from prior file:
# removed invented --game/--solvable/--solver-quick/--solver/
# --solverstats; real options are --solvegame, --solve, --start,
# --end, --gametype, --testdir, --generate, --author, --license,
# --desktopfile (plus standard KDE/Qt switches).
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show available command-line options]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-qt[show Qt options]' \
  '(- *)--help-kde[show KDE options]' \
  '(- *)'{-v,--version}'[show version information]' \
  '(- *)--author[show author information]' \
  '(- *)--license[show license information]' \
  '--solvegame=[try to solve a given savegame]:file:_files' \
  '--solve=[solve a specific dealer (debug)]:num:' \
  '--start=[set game range start]:num:' \
  '--end=[set game range end]:num:' \
  '--gametype=[load specific game type]:game:' \
  '--testdir=[directory containing test cases]:dir:_files -/' \
  '--generate[create random test cases]' \
  '--desktopfile=[base file name of the desktop entry]:name:' \
  '*:file:_files' && ret=0

return ret
