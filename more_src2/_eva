#compdef eva
# Documentation: https://github.com/NerdyPepper/eva
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for eva - calculator REPL

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-b --base)'{-b,--base}'=[set output radix 1-36]:radix:' \
  '(-f --fix)'{-f,--fix}'=[number of decimal places 1-64]:places:' \
  '(-r --radian)'{-r,--radian}'[use radian mode for trig functions]' \
  '*:expression:'
