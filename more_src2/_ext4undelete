#compdef ext4undelete ext4-undelete
# _ext4undelete — ext4undelete CLI for recovering deleted files from ext4 filesystems by scanning the journal extent tree inode table for orphan inodes restoring intact data block ranges target output directory (jadudm team, C); getopt
# upstream: https://github.com/jadudm/ext4undelete

_ext4undelete() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-o+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-a[restore all]' \
        '--all[restore all]' \
        '-d[deleted only]' \
        '--deleted-only[deleted only]' \
        '-t+[start time]:str:' \
        '--time-start=+[start time]:str:' \
        '-T+[end time]:str:' \
        '--time-end=+[end time]:str:' \
        '-i+[inode]:n:' \
        '--inode=+[inode]:n:' \
        '-n+[name pattern]:str:' \
        '--name=+[name pattern]:str:' \
        '-s+[size min:max]:str:' \
        '--size=+[size min:max]:str:' \
        '-x[follow extents]' \
        '--follow-extents[follow extents]' \
        '-j[journal scan]' \
        '--journal-scan[journal scan]' \
        '-y[yes confirm]' \
        '--yes[yes confirm]' \
        '*:device:_files'
}

_ext4undelete "$@"
