#compdef quorum geth-quorum
# _quorum — ConsenSys GoQuorum Ethereum-compatible enterprise blockchain client fork of go-ethereum adding QuorumLight Istanbul BFT QBFT consensus and private state (ConsenSys team, Go); urfave/cli
# upstream: https://github.com/ConsenSys/quorum

_quorum() {
    local -a sub=(
        'attach:attach to running node'
        'console:start interactive console'
        'init:init genesis block'
        'export:export blocks'
        'import:import blocks'
        'export-preimages:export preimages'
        'import-preimages:import preimages'
        'dumpconfig:dump config'
        'js:execute JS file'
        'license:show license'
        'monitor:monitor metrics'
        'removedb:remove blockchain db'
        'snapshot:snapshot operations'
        'version:show version'
        'help:show help'
        'account:account operations'
        'wallet:wallet operations'
        'makecache:make ethash cache'
        'makedag:make ethash DAG'
        'db:db operations'
        'show-deprecated-flags:show deprecated flags'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--datadir=+[dir]:dir:_files -/' \
        '--keystore=+[dir]:dir:_files -/' \
        '--networkid=+[id]:n:' \
        '--port=+[port]:n:' \
        '--rpc[enable HTTP RPC]' \
        '--http[enable HTTP RPC]' \
        '--http.addr=+[addr]:str:' \
        '--http.port=+[port]:n:' \
        '--http.api=+[apis]:str:' \
        '--http.corsdomain=+[csv]:str:' \
        '--http.vhosts=+[csv]:str:' \
        '--ws[enable WebSocket]' \
        '--ws.addr=+[addr]:str:' \
        '--ws.port=+[port]:n:' \
        '--ws.api=+[apis]:str:' \
        '--ws.origins=+[csv]:str:' \
        '--ipcdisable[disable IPC]' \
        '--ipcpath=+[file]:file:_files' \
        '--mine[enable mining]' \
        '--miner.threads=+[N]:n:' \
        '--miner.etherbase=+[addr]:str:' \
        '--miner.gasprice=+[gwei]:n:' \
        '--syncmode=+[mode]:m:(fast full light snap)' \
        '--gcmode=+[mode]:m:(full archive)' \
        '--cache=+[mb]:n:' \
        '--cache.database=+[%]:n:' \
        '--cache.gc=+[%]:n:' \
        '--cache.trie=+[%]:n:' \
        '--password=+[file]:file:_files' \
        '--unlock=+[addresses]:str:' \
        '--allow-insecure-unlock[allow insecure unlock]' \
        '--lightserv=+[%]:n:' \
        '--lightpeers=+[N]:n:' \
        '--maxpeers=+[N]:n:' \
        '--nat=+[setting]:s:(any none upnp pmp extip)' \
        '--nodiscover[no discovery]' \
        '--v5disc[v5 discovery]' \
        '--nodekey=+[file]:file:_files' \
        '--nodekeyhex=+[hex]:str:' \
        '--bootnodes=+[csv]:str:' \
        '--metrics[enable metrics]' \
        '--metrics.influxdb[enable influxdb]' \
        '--metrics.influxdb.endpoint=+[url]:str:' \
        '--istanbul.blockperiod=+[s]:n:' \
        '--istanbul.requesttimeout=+[ms]:n:' \
        '--emitcheckpoints[emit checkpoints]' \
        '--permissioned[enable permissioned]' \
        '--raftport=+[port]:n:' \
        '--raft[enable Raft]' \
        '--raftblocktime=+[ms]:n:' \
        '--raftjoinexisting=+[N]:n:' \
        '--privatetransactionmanager=+[url]:str:' \
        '--ptm.url=+[url]:str:' \
        '--ptm.dialtimeout=+[ms]:n:' \
        '--ptm.timeout=+[ms]:n:' \
        '--ptm.socket=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quorum subcommand' sub ;;
        args) ;;
    esac
}

_quorum "$@"
