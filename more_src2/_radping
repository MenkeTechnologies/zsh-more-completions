#compdef radping
# _radping — FreeRADIUS radping (ping(1)-style helper that periodically sends Status-Server packets to a RADIUS server and prints round-trip times; -c count, -i interval seconds, -t timeout, -s shared secret, -d dictionary dir, -h help, -v version; positional argument is server[:port])
# upstream: https://github.com/FreeRADIUS/freeradius-server
# Flags from FreeRADIUS/freeradius-server src/main/radping.c on tip.

_radping() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[count]:n:' \
        '-i+[interval seconds]:seconds:' \
        '-t+[timeout]:seconds:' \
        '-s+[shared secret]:secret:' \
        '-d+[dictionary dir]:dir:_files -/' \
        '1:server[:port]:_hosts'
}

_radping "$@"
