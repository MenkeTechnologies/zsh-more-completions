#compdef markdownlint
# Documentation: https://github.com/igorshubovych/markdownlint-cli
# Reference accessed: 2026-05-16
# Verified: igorshubovych/markdownlint-cli README OPTIONS table.
# Removed from prior file: bogus man.archlinux.org search URL;
# `mdl` is a different Ruby tool (mivok/markdownlint), not this CLI
# (which is the Node CLI for DavidAnson/markdownlint).

# markdownlint: CLI for DavidAnson/markdownlint (Node)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(json|jsonc|js|yaml|yml|toml)(-.)"' \
  '--configPointer=[JSON Pointer into config]:pointer:' \
  '(-d --dot)'{-d,--dot}'[include dot files/dirs]' \
  '(-f --fix)'{-f,--fix}'[fix violations in place]' \
  '(-i --ignore)'{-i+,--ignore=}'[ignore file/dir/glob]:pattern:' \
  '(-j --json)'{-j,--json}'[output as JSON]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-p --ignore-path)'{-p+,--ignore-path=}'[ignore-path file]:file:_files' \
  '(-q --quiet)'{-q,--quiet}'[suppress all output]' \
  '(-r --rules)'{-r+,--rules=}'[include custom rules]:rules:_files' \
  '(-s --stdin)'{-s,--stdin}'[read from stdin]' \
  '*--enable=[enable rules]:rules:' \
  '*--disable=[disable rules]:rules:' \
  '*:file or glob:_files -g "*.(md|markdown)(-.)"' && ret=0
return ret
