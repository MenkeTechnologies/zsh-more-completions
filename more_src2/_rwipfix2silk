#compdef rwipfix2silk rwsilk2ipfix rwpmapbuild rwpmapcat rwpmaplookup rwsiteinfo rwswapbytes rwtuc rwsplit
# Documentation: https://tools.netsa.cert.org/silk/rw{ipfix2silk,silk2ipfix,pmap*,siteinfo,swapbytes,tuc,split}.html
# Reference accessed: 2026-05-30
# SiLK Round 3 — companion to round-135 _rwfilter (analysis: 8 stems) and
# round-136 _rwsetbuild (sets/bags: 9 stems). This file adds 9 more tools
# covering IPFIX↔SiLK conversion, prefix-map handling, site introspection,
# byte-order swap, text↔SiLK, and file splitting.

local curcontext="$curcontext" state line ret=1

# Shared metadata flags.
local -a _meta
_meta=(
  '--note-add=[annotation for header]:text:'
  '--note-file-add=[annotation file]:file:_files'
  '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)'
  '(- *)--help[show help]'
  '(- *)--version[show version]'
)

# Shared display flags (cat tools).
local -a _disp
_disp=(
  '--no-titles[suppress column headers]'
  '--no-columns[disable fixed-width columns]'
  '--column-separator=[column delimiter]:char:'
  '--no-final-delimiter[omit trailing separator]'
  '--delimited=-[pipe-delimited (custom char)]:char:'
  '--output-path=[output path]:path:_files'
  '--pager=[pager program]:program:_command_names -e'
  '--ip-format=[IP address display]:fmt:(canonical decimal hex zero-padded any-cidr force-ipv6)'
)

case $service in

  rwipfix2silk)
    _arguments -s -S \
      $_meta \
      '--silk-output=[binary SiLK Flow output]:path:_files' \
      '--interface-values=[input/output interface meaning]:val:(snmp vlan)' \
      '--log-destination=[log destination]:dest:(none stdout stderr)' \
      '--log-flags=[log message types]:flags:(sampling show-templates record-timestamps)' \
      '--print-statistics[print record count to stderr]' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '*:IPFIX file:_files -g "*.(ipfix|nfcap*)"' \
      && ret=0
    ;;

  rwsilk2ipfix)
    _arguments -s -S \
      $_meta \
      '--ipfix-output=[IPFIX output file]:path:_files' \
      '--single-template[legacy single-template output]' \
      '--no-site-name-elements[exclude flowtype/class/type/sensor]' \
      '--print-statistics[print written record count]' \
      '--site-config-file=[SiLK site config]:file:_files' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '*:SiLK file:_files' \
      && ret=0
    ;;

  rwpmapbuild)
    _arguments -s -S \
      $_meta \
      '--input-path=[textual input (stdin if omitted)]:file:_files' \
      '--output-path=[binary prefix-map output]:file:_files -g "*.pmap"' \
      '--mode=[input data type]:type:(ipv4 ipv6 proto-port)' \
      '--dry-run[validate syntax without writing]' \
      '--ignore-errors[write output despite parse errors]' \
      '--invocation-strip[omit command line from header]' \
      && ret=0
    ;;

  rwpmapcat)
    _arguments -s -S \
      $_meta \
      $_disp \
      '(--map-file --address-types --country-codes)--map-file=[prefix-map file]:file:_files -g "*.pmap"' \
      '(--map-file --address-types --country-codes)--address-types=-[address-types map]:file:_files' \
      '(--map-file --address-types --country-codes)--country-codes=-[country-codes map]:file:_files' \
      '--output-types=[what to display]:fields:_values -s , "field" mapname type ranges labels' \
      '--ignore-label=[exclude specific label]:label:' \
      '--ip-label-to-ignore=[exclude ranges matching label of IP]:ip:' \
      '--no-cidr-blocks[print start/end instead of CIDR]' \
      '--integer-ips[deprecated: IPs as decimal]' \
      '--zero-pad-ips[deprecated: zero-padded IPs]' \
      '--left-justify-labels[left-align label column]' \
      && ret=0
    ;;

  rwpmaplookup)
    _arguments -s -S \
      $_meta \
      $_disp \
      '(--map-file --address-types --country-codes)--map-file=[prefix-map file]:file:_files -g "*.pmap"' \
      '(--map-file --address-types --country-codes)--address-types=-[address-types map]:file:_files' \
      '(--map-file --address-types --country-codes)--country-codes=-[country-codes map]:file:_files' \
      '(--no-files --ipset-files)--no-files[treat args as keys, not file names]' \
      '(--no-files --ipset-files)--ipset-files[read keys from IPset files]' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '--fields=[output columns]:fields:_values -s , "field" key value block' \
      '--integer-ips[deprecated]' \
      '--zero-pad-ips[deprecated]' \
      '--no-errors[suppress parse errors]' \
      '*:input file or key:_files' \
      && ret=0
    ;;

  rwsiteinfo)
    _arguments -s -S \
      $_meta \
      $_disp \
      '--fields=[fields to print]:fields:_values -s , "field" class type flowtype sensor sensor-id sensor-description default-class default-type repo-start-date repo-end-date file-size group default-class-type-list class-type-list class-list sensor-list' \
      '--classes=[limit to classes]:classes:' \
      '--types=[limit to types]:types:' \
      '--flowtypes=[limit to class/type pairs]:flowtypes:' \
      '--sensors=[limit to sensors]:sensors:' \
      '--groups=[limit to sensor groups]:groups:' \
      '--data-rootdir=[repository root]:dir:_files -/' \
      '--site-config-file=[silk.conf]:file:_files' \
      '--timestamp-format=[timestamp display]:fmt:' \
      '--list-delimiter=[":list" field separator]:char:' \
      '(- *)--help-fields[show field descriptions]' \
      && ret=0
    ;;

  rwswapbytes)
    _arguments -s -S \
      $_meta \
      '(--big-endian --little-endian --native-endian --swap-endian)--big-endian[output big-endian]' \
      '(--big-endian --little-endian --native-endian --swap-endian)--little-endian[output little-endian]' \
      '(--big-endian --little-endian --native-endian --swap-endian)--native-endian[output native byte order]' \
      '(--big-endian --little-endian --native-endian --swap-endian)--swap-endian[unconditional byte swap]' \
      '1:input SiLK file:_files' \
      '2:output SiLK file:_files' \
      && ret=0
    ;;

  rwtuc)
    _arguments -s -S \
      $_meta \
      '--fields=[columns to parse]:fields:' \
      '--column-separator=[field delimiter (default |)]:char:' \
      '--output-path=[binary SiLK output]:file:_files' \
      '--bad-input-lines=[copy unparseable lines to FILE]:file:_files' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '--verbose[report parsing errors]' \
      '--stop-on-error[exit on first error]' \
      '--no-titles[treat first line as data]' \
      '--site-config-file=[silk.conf]:file:_files' \
      '--saddress=[fixed source IP]:ip:' \
      '--daddress=[fixed destination IP]:ip:' \
      '--sport=[fixed source port]:port:' \
      '--dport=[fixed destination port]:port:' \
      '--protocol=[fixed protocol]:proto:' \
      '--packets=[fixed packet count]:N:' \
      '--bytes=[fixed byte count]:N:' \
      '--flags-all=[fixed flags-all]:flags:' \
      '--flags-initial=[fixed flags-initial]:flags:' \
      '--flags-session=[fixed flags-session]:flags:' \
      '--stime=[fixed start time]:time:' \
      '--etime=[fixed end time]:time:' \
      '--duration=[fixed duration]:seconds:' \
      '--sensor=[fixed sensor]:sensor:' \
      '--input-index=[fixed input SNMP index]:N:' \
      '--output-index=[fixed output SNMP index]:N:' \
      '--application=[fixed application]:app:' \
      '--class=[fixed class]:class:' \
      '--type=[fixed type]:type:' \
      '--icmp-type=[fixed ICMP type]:N:' \
      '--icmp-code=[fixed ICMP code]:N:' \
      '--attributes=[fixed attributes]:attrs:' \
      '--next-hop-ip=[fixed next-hop IP]:ip:' \
      '*:text file:_files' \
      && ret=0
    ;;

  rwsplit)
    _arguments -s -S \
      $_meta \
      '(--ip-limit --flow-limit --packet-limit --byte-limit)--ip-limit=[split by unique IP count]:N:' \
      '(--ip-limit --flow-limit --packet-limit --byte-limit)--flow-limit=[split by flow-record count]:N:' \
      '(--ip-limit --flow-limit --packet-limit --byte-limit)--packet-limit=[split by total packet count]:N:' \
      '(--ip-limit --flow-limit --packet-limit --byte-limit)--byte-limit=[split by total byte count]:N:' \
      '--basename=[output filename prefix]:prefix:' \
      '--seed=[RNG seed]:N:' \
      '--sample-ratio=[sample 1 per N flows]:N:' \
      '--file-ratio=[randomly select output files]:N:' \
      '--max-outputs=[limit file count]:N:' \
      '--print-filenames[print input files to stderr]' \
      '--site-config-file=[silk.conf]:file:_files' \
      '*--xargs=-[read filenames from file/stdin]:file:_files' \
      '*:input SiLK file:_files' \
      && ret=0
    ;;

esac

return ret
