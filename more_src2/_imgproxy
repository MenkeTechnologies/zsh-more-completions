#compdef imgproxy
# Documentation: https://github.com/imgproxy/imgproxy
# Source: imgproxy/imgproxy cli/main.go — fast standalone image-processing HTTP server.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _ip_cmds
_ip_cmds=(
    'version:print the imgproxy version'
    'health:perform a healthcheck on a running imgproxy instance'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1: :->command' \
    && ret=0

case $state in
    command)
        _describe -t commands 'imgproxy command' _ip_cmds && ret=0
        ;;
esac

return ret
