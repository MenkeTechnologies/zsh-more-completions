#compdef deps-new
# _deps-new — Sean Corfield deps-new modern project generator CLI alias (seancorfield team, Clojure); tools.deps function CLI
# upstream: https://github.com/seancorfield/deps-new

_deps-new() {
    local -a sub=(
        'app:scaffold a Clojure application'
        'lib:scaffold a Clojure library'
        'scratch:create a scratch project'
        'template:scaffold a new template'
        'pom:scaffold pom.xml only'
        'create:scaffold from custom template'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'deps-new subcommand' sub ;;
        args)
            case $words[1] in
                app|lib|scratch|template|pom|create) _arguments \
                    ':name=+[project name]:str:' \
                    ':template=+[template]:str:' \
                    ':target-dir=+[target dir]:dir:_files -/' \
                    ':overwrite=+[overwrite]:o:(true delete false)' \
                    ':data=+[data edn]:str:' \
                    ':local-root=+[local template dir]:dir:_files -/' \
                    ':git=+[git template url]:url:_urls' \
                    ':git-branch=+[git branch]:str:' \
                    ':sha=+[git sha]:str:' \
                    ':tag=+[git tag]:str:' \
                    ':verbose=+[verbose]:b:(true false)' \
                    ':env=+[env edn]:str:' ;;
            esac
            ;;
    esac
}

_deps-new "$@"
