#compdef nethermind
# Documentation: https://docs.nethermind.io/get-started/running-node/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-c --config)'{-c,--config}'=[network preset]:config:(mainnet mainnet_archive sepolia sepolia_archive hoodi hoodi_archive gnosis gnosis_archive chiado chiado_archive op-mainnet op-sepolia base-mainnet base-sepolia worldchain-mainnet worldchain-sepolia taiko-alethia taiko-hoodi linea-mainnet linea-sepolia energyweb energyweb_archive volta volta_archive)' \
  '(-dd --datadir)'{-dd,--datadir}'=[database directory]:directory:_directories' \
  '--data-dir=[database directory]:directory:_directories' \
  '(-l --log)'{-l,--log}'=[log level]:level:(TRACE DEBUG INFO WARN ERROR OFF)' \
  '(- *)'{-h,--help,-?}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--JsonRpc.Enabled[enable JSON-RPC server]' \
  '--JsonRpc.EngineHost=[Engine API listen host]:host:' \
  '--JsonRpc.EnginePort=[Engine API port]:port:' \
  '--JsonRpc.JwtSecretFile=[JWT secret path]:file:_files' \
  '--jsonrpc-jwtsecretfile=[JWT secret path]:file:_files' \
  '--HealthChecks.Enabled[expose health probes]' \
  '--Metrics.Enabled[expose Prometheus metrics]' \
  '--Pruning.CacheMb=[in-memory pruning cache size MB]:size:' \
  '*::arguments: _default'
