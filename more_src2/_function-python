#compdef function-python
# _function-python — Crossplane Python composition function runner (gRPC server that executes user-supplied fn.py logic)
# upstream: https://github.com/crossplane-contrib/function-python
# Flags from function/main.py on tip (click).

_function-python() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[emit debug logs]' \
        '--address=[address to listen on for gRPC]:addr:' \
        '--tls-certs-dir=[directory containing mTLS certs (TLS_SERVER_CERTS_DIR env var)]:dir:_files -/' \
        '--insecure[run without mTLS (--tls-certs-dir is ignored)]' \
        '--max-recv-message-size=[max received message size (MB)]:n:' \
        '--max-send-message-size=[max sent message size (MB)]:n:'
}

_function-python "$@"
