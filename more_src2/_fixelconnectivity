#compdef fixelconnectivity
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/fixelconnectivity.html
# Source: MRtrix3/mrtrix3 cmd/fixelconnectivity.cpp — compute fixel-fixel connectivity matrix from streamlines (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-threshold+[required shared-connection fraction (default 0.01)]:value:_default' \
    '-angle+[max angle threshold in degrees (default 45)]:value:_default' \
    '-mask+[fixel data file mask]:file:_files' \
    '1:fixel_directory:_files -/' \
    '2:tracks (input streamlines):_files -g "*.{tck,trk}"' \
    '3:matrix (output directory):_files -/' \
    && ret=0

return ret
