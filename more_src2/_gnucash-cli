#compdef gnucash-cli
# Documentation: https://manpages.debian.org/gnucash-cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gnucash-cli: GnuCash command-line tool.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-Q --quotes)'{-Q+,--quotes=}'[quotes-related command]:command:(info get dump)' \
  '(-R --report)'{-R+,--report=}'[report-related command]:command:(list run show)' \
  '--name=[report name]:name:' \
  '--export-type=[report export type]:type:(html pdf csv json xml)' \
  '--output-file=[report output file]:file:_files' \
  '--namespace=[regex of commodity namespace]:regex:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--debug[debug logging]' \
  '--extra[show extra logs]' \
  '--log=[log domain to enable]:domain:' \
  '--logto=[log target]:target:(stdout stderr file)' \
  '--gsettings-prefix=[gsettings schema prefix]:prefix:' \
  '--add-price-quotes[fetch online price quotes (deprecated)]' \
  '--no-file-gui[skip startup file GUI]' \
  '*::file:_files -g "*.gnucash"' && ret=0

return ret
