#compdef git-quick-stats
# Documentation: https://github.com/arzzen/git-quick-stats
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Real flags from arzzen/git-quick-stats `--help`

_arguments -s -S \
  '(-T --detailed-git-stats)'{-T,--detailed-git-stats}'[detailed git stats]' \
  '(-R --git-stats-by-branch)'{-R,--git-stats-by-branch}'[git stats by branch]' \
  '(-c --changelogs)'{-c,--changelogs}'[show changelogs]' \
  '(-L --changelogs-by-author)'{-L,--changelogs-by-author}'[changelogs grouped by author]:author:' \
  '(-S --changelogs-since)'{-S,--changelogs-since}'[changelogs since a date]:date:' \
  '(-U --changelogs-until)'{-U,--changelogs-until}'[changelogs until a date]:date:' \
  '(-V --my-daily-status)'{-V,--my-daily-status}'[my daily stats]' \
  '(-b --branch-tree)'{-b,--branch-tree}'[show branch tree]' \
  '(-D --branches-by-date)'{-D,--branches-by-date}'[list branches by date]' \
  '(-C --contributors)'{-C,--contributors}'[list contributors]' \
  '(-a --commits-per-author)'{-a,--commits-per-author}'[commits per author]' \
  '(-d --commits-per-day)'{-d,--commits-per-day}'[commits per day]' \
  '(-Y --commits-by-year)'{-Y,--commits-by-year}'[commits by year]' \
  '(-m --commits-by-month)'{-m,--commits-by-month}'[commits by month]' \
  '(-w --commits-by-weekday)'{-w,--commits-by-weekday}'[commits by weekday]' \
  '(-o --commits-by-hour)'{-o,--commits-by-hour}'[commits by hour]' \
  '(-A --commits-by-author-by-hour)'{-A,--commits-by-author-by-hour}'[commits by author by hour]' \
  '(-k --commits-calendar-by-author)'{-k,--commits-calendar-by-author}'[commits calendar by author]' \
  '(-H --commits-heatmap)'{-H,--commits-heatmap}'[commits heatmap]' \
  '(-r --suggest-reviewers)'{-r,--suggest-reviewers}'[suggest reviewers]' \
  '(-s --csv-commits-per-author)'{-s,--csv-commits-per-author}'[CSV of commits per author]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::args:_default'
