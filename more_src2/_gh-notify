#compdef gh-notify
# Documentation: https://github.com/meiji163/gh-notify
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_gh-notify() {
    _arguments \
        '-a[show all notifications (read and unread)]' \
        '-e+[exclude notifications matching string (regex)]:pattern:' \
        '-f+[filter notifications matching string (regex)]:pattern:' \
        '-h[show help]' \
        '-n+[max number of notifications to display]:number:' \
        '-p[show only participating/mentioned notifications]' \
        '-r[mark all as read]' \
        '-s[print static (non-interactive) list]' \
        '-u+[subscribe/unsubscribe to specific issue or PR URL]:url:' \
        '-w[open preview window in interactive mode]'
}

_gh-notify "$@"
