#compdef pypykatz
# Documentation: https://github.com/skelsec/pypykatz
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'lsa:Parse LSASS dump'
      'registry:Parse registry hives'
      'crypto:Cryptographic operations'
      'dpapi:DPAPI operations'
      'ldap:LDAP client'
      'kerberos:Kerberos operations'
      'live:Live system operations'
      'version:Show version'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (lsa)
        _arguments \
          '1:subcommand:(minidump rekall)' \
          '2:dump file:_files' \
          '(-o --outfile)'{-o,--outfile}'=[output file]:file:_files' \
          '(-k --kerberos-dir)'{-k,--kerberos-dir}'=[kerberos tickets directory]:dir:_files -/' \
          '(-g --grep)'{-g,--grep}'[grep-friendly output]' \
          '(-j --json)'{-j,--json}'[JSON output]' && ret=0
        ;;
      (registry)
        _arguments \
          '1:subcommand:(sam security system software)' \
          '2:hive file:_files' \
          '(-o --outfile)'{-o,--outfile}'=[output file]:file:_files' \
          '(-j --json)'{-j,--json}'[JSON output]' && ret=0
        ;;
      (dpapi)
        _arguments \
          '1:subcommand:(prekey minidump blob vault credential masterkey describe)' \
          '*:file:_files' && ret=0
        ;;
      (kerberos)
        _arguments \
          '1:subcommand:(tgt tgs brute asreproast kerberoast s4u)' \
          '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
