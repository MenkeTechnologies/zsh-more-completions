#compdef functionbeat
# Documentation: https://www.elastic.co/guide/en/beats/functionbeat/current/command-line-options.html
# Reference accessed: 2026-05-17
# Verified: Elastic Beats functionbeat upstream command surface
# (deploy, export, help, package, remove, run, setup, test, update,
# version) and global flags (-E, -c, -d, -e, --environment,
# --path.config, --path.data, --path.home, --path.logs,
# --strict.perms, -v). NOTE: functionbeat reached EOL 2023-10-18;
# users should migrate to Elastic Serverless Forwarder.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:deploy a function to a serverless environment'
  'remove:remove a function from a serverless environment'
  'update:update an existing serverless function'
  'package:package the configuration and executable as a zip'
  'export:export config/template/ilm-policy/function'
  'setup:set up index template and ILM policy'
  'test:test config or output connectivity'
  'help:show help'
  'version:show version'
  'run:run functionbeat'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*'{-E+,--E=}'[override config setting]:setting:' \
  '(-c)'{-c+,--c=}'[config file]:file:_files -g "*.yml"' \
  '(-d)'{-d+,--d=}'[debug selectors]:selectors:' \
  '(-e)'{-e,--e}'[log to stderr]' \
  '--environment=[runtime environment]:env:(systemd container macos windows_service)' \
  '--path.config=[config directory]:dir:_files -/' \
  '--path.data=[data directory]:dir:_files -/' \
  '--path.home=[home directory]:dir:_files -/' \
  '--path.logs=[logs directory]:dir:_files -/' \
  '--strict.perms[strict permission checking]' \
  '(-v)'{-v,--v}'[INFO-level logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'functionbeat command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (export)
        _arguments '*::sub:(config template ilm-policy function)' && ret=0 ;;
      (test)
        _arguments '*::sub:(config output)' && ret=0 ;;
      (deploy|remove|update)
        _arguments '*::function_name:' && ret=0 ;;
    esac ;;
esac

return ret
