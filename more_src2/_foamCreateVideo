#compdef foamCreateVideo
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamCreateVideo — encode a PNG image sequence into a video using ffmpeg.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-begin-pause -b)'{-begin-pause,-b}'[pause at beginning of video by N seconds]:time:' \
    '(-dir -d)'{-dir,-d}'[directory containing png images (default cwd)]:dir:_directories' \
    '(-end-pause -e)'{-end-pause,-e}'[pause at the end of video by N seconds]:time:' \
    '(-fps -f)'{-fps,-f}'[frames per second (default 10)]:fps:' \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-image -i)'{-image,-i}'[name of image sequence (default "image")]:name:' \
    '(-out -o)'{-out,-o}'[name of output video file (default "video")]:name:' \
    '(-start -s)'{-start,-s}'[start image frame]:frame:' \
    '(-webm -w)'{-webm,-w}'[WebM output video file format]' \
    && ret=0

return ret
