#compdef qemu-trace-stap
# _qemu-trace — QEMU qemu-trace-stap (helper invoking SystemTap with the trace event list distributed with qemu; subcommand list dumps available events, run executes a real-time trace, --binary picks alt qemu binary, --pid attaches to a running qemu pid)
# upstream: https://gitlab.com/qemu-project/qemu (scripts/qemu-trace-stap)
# Flags from qemu scripts/qemu-trace-stap on tip.

_qemu-trace() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--binary+[qemu binary]:file:_files' \
        '--pid+[attached pid]:pid:_pids' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'qemu-trace command' '(list run)' ;;
        args) _arguments '*:event:' ;;
    esac
}

_qemu-trace "$@"
