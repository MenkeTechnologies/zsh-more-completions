#compdef mcelog-cli mcelog
# Documentation: https://manpages.debian.org/testing/mcelog/mcelog.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mcelog: Machine Check Exception logger (Linux x86)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--version[display version and exit]' \
  '--daemon[run as daemon in background]' \
  '--client[query a running daemon for errors]' \
  '--ignorenodev[exit silently if device unavailable]' \
  '--filter[filter known broken events (default)]' \
  '--no-filter[disable broken-event filtering]' \
  '--dmi[look up DIMMs in BIOS SMBIOS/DMI tables]' \
  '--cpu=[set CPU type for decoding]:cpu:(generic p4 core2 nehalem westmere xeon74xx tulsa dunnington sandybridge ivybridge haswell broadwell skylake)' \
  '--cpumhz=[assume CPU frequency for time decoding]:mhz' \
  '--logfile=[append output to specified file]:file:_files' \
  '--syslog[redirect output to system log]' \
  '--syslog-error[log machine checks as LOG_ERR]' \
  '--no-syslog[never log to syslog]' \
  '--pidfile[write daemon process ID to file]:file:_files' \
  '--no-imc-log[disable extended memory controller reporting]' \
  '--foreground[prevent daemon from backgrounding]' \
  '--config-file[read specified config file]:file:_files' \
  '--is-cpu-supported[check if CPU is supported]' \
  '--raw[dump mcelog in raw hex format without decoding]' \
  '--ascii[decode fatal machine check panic from ASCII input]' \
  '--file[read ASCII record from file]:file:_files' \
  '*::mcelog args:_files' && ret=0
return ret
