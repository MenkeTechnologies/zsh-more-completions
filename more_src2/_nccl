#compdef nccl nccl-config
# _nccl — NVIDIA NCCL Collective Communications Library helper CLIs for inspecting the NCCL inter-GPU communications library (NVIDIA team, C++); custom argparse
# upstream: https://github.com/NVIDIA/nccl

_nccl() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--includedir[print include dir]' \
        '--libdir[print library dir]' \
        '--cflags[print CFLAGS]' \
        '--libs[print LIBS]' \
        '--cmake-prefix-path[print CMAKE prefix path]' \
        '--info[print build info]' \
        '--debug=+[debug level]:l:(VERSION WARN INFO TRACE)' \
        '--debug-subsys=+[subsys]:s:(INIT COLL P2P SHM NET GRAPH TUNING ENV ALLOC CALL ALL)' \
        '--debug-file=+[file]:file:_files' \
        '--algo=+[algorithm]:a:(Ring Tree CollnetDirect CollnetChain NVLSTree NVLS)' \
        '--proto=+[protocol]:p:(LL LL128 Simple)' \
        '--max-channels=+[N]:n:' \
        '--socket-ifname=+[interface]:str:' \
        '--socket-nthreads=+[N]:n:' \
        '--ib-gid-index=+[N]:n:' \
        '--ib-hca=+[device]:str:' \
        '--p2p-disable=+[bool]:b:(0 1)' \
        '--shm-disable=+[bool]:b:(0 1)' \
        '--cumem-enable=+[bool]:b:(0 1)' \
        '--num-rings=+[N]:n:' \
        '--max-cta-count=+[N]:n:' \
        '--check-pointers=+[bool]:b:(0 1)' \
        '--enable-asym-bw=+[bool]:b:(0 1)' \
        '--graph-register=+[bool]:b:(0 1)'
}

_nccl "$@"
