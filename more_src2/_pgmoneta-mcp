#compdef pgmoneta-mcp
# _pgmoneta-mcp — Model Context Protocol server for pgmoneta (pgmoneta/pgmoneta_mcp)
# upstream: https://github.com/pgmoneta/pgmoneta_mcp
# Flags from src/bin/server/server.rs (clap derive).

_pgmoneta-mcp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --conf)'{-c+,--conf=}'[MCP server configuration file]:file:_files -g "*.conf"' \
        '(-u --users)'{-u+,--users=}'[users configuration file]:file:_files -g "*.conf"'
}

_pgmoneta-mcp "$@"
