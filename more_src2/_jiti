#compdef jiti
# Documentation: https://github.com/unjs/jiti
# Reference accessed: 2026-05-19
# Verified: upstream lib/jiti-cli.mjs at the URL above.
# CLI signature is `jiti <path> [...arguments]` only; no flags. Behavior
# is configured via JITI_* environment variables, not command options.

local ret=1
_arguments -s -S \
  '1:script:_files -g "*.(ts|tsx|js|jsx|mjs|mts|cjs|cts)(-.)"' \
  '*:args:' && ret=0
return ret
