#compdef flowrs
# Documentation: https://github.com/jvanbuel/flowrs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# https://github.com/jvanbuel/flowrs — Apache Airflow TUI (clap; `flowrs --help`)
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '-V[version]' \
  '--version[version]' \
  '--config=-[config file]:file:_files' \
  '--airflow-url=-[Airflow API base]:url:' \
  '*:ignored:_default'
