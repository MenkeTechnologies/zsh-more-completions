#compdef ibchecknode
# Documentation: https://man7.org/linux/man-pages/man8/ibchecknode.8.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ibchecknode: validate connectivity and sanity-check an IB node.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[increase verbosity level]' \
  '-G[use GUID address argument (Port GUID)]' \
  '-N[use mono rather than color mode]' \
  '-nocolor[use mono rather than color mode]' \
  '-C+[channel adapter name]:ca name:' \
  '-P+[channel adapter port]:ca port:' \
  '-t+[override default timeout for solicited MADs]:timeout (ms):' \
  '*:lid/guid:' && ret=0
return ret
