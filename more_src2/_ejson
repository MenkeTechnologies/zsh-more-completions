#compdef ejson
# _ejson — Shopify ejson CLI for asymmetric public-key envelope-encryption of JSON files in source control with NaCl box keypair for storing secrets safely in repositories (Shopify team, Go); kingpin
# upstream: https://github.com/Shopify/ejson

_ejson() {
    local -a sub=(
        'encrypt:encrypt a JSON file'
        'decrypt:decrypt a JSON file'
        'keygen:generate new keypair'
        'rotate:rotate keypair'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--keydir=+[dir]:dir:_files -/' \
        '-k+[dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ejson subcommand' sub ;;
        args)
            case $words[1] in
                encrypt) _arguments \
                    '-i[in-place]' \
                    '--in-place[in-place]' \
                    '*:ejson file:_files -g "*.ejson *.json"' ;;
                decrypt) _arguments \
                    '-o+[output file]:file:_files -g "*.json"' \
                    '--output=+[output file]:file:_files -g "*.json"' \
                    '--private-key=+[hex]:str:' \
                    '*:ejson file:_files -g "*.ejson"' ;;
                keygen) _arguments \
                    '-w[write to disk]' \
                    '--write[write to disk]' ;;
            esac
            ;;
    esac
}

_ejson "$@"
