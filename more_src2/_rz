#compdef rz rb rx
# Documentation: https://manpages.debian.org/bookworm/lrzsz/rz.1.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.
# lrzsz: receive files over ZMODEM/YMODEM/XMODEM.

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-+[append received data to existing file]' \
  '-a[convert files to Unix conventions (strip CR, ^Z)]' \
  '-b[binary file transfer override]' \
  '-B+[buffer size]:size' \
  '-c[use 16 bit CRC (XMODEM)]' \
  '-C[allow remote command execution]' \
  '-D[output file data to /dev/null (for testing)]' \
  '-e[escape all control characters]' \
  '-E[rename if target exists]' \
  '-h[show help]' \
  '-m+[minimum BPS rate threshold]:bps' \
  '-M+[minimum BPS time duration]:seconds' \
  '-O[disable timeouts]' \
  '-p[protect existing files]' \
  '-q[quiet mode]' \
  '-r[resume / crash recovery]' \
  '-R[restricted mode]' \
  '-s+[stop transmission at specified time]:time' \
  '-S[request timesync packet]' \
  '-t+[change timeout]:tenths-of-seconds' \
  '-U[turn off restricted mode]' \
  '-v[verbose mode]' \
  '-w+[set window size]:size' \
  '-X[use XMODEM protocol]' \
  '-y[overwrite existing files]' \
  '-Z[use ZMODEM protocol]' && return 0
