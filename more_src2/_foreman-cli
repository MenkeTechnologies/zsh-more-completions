#compdef foreman-cli
# _foreman-cli — Foreman lifecycle management for VMs, hosts, containers CLI alias (theforeman team, Ruby); custom argparse via hammer
# upstream: https://github.com/theforeman/foreman

_foreman-cli() {
    local -a sub=(
        'activation-key:activation key commands'
        'admin:admin commands'
        'admin logging:logging commands'
        'admin sync-plans:sync plan commands'
        'arf-report:arf reports'
        'audit:audit log'
        'auth:auth commands'
        'auth login:login'
        'auth logout:logout'
        'auth status:show status'
        'auth login basic:basic login'
        'auth login oauth:oauth login'
        'auth-source:auth source commands'
        'auth-source external:external auth source'
        'auth-source ldap:LDAP auth source'
        'auto-attach-job:auto-attach job'
        'bookmark:bookmark commands'
        'capsule:capsule commands'
        'compute-profile:compute profile commands'
        'compute-resource:compute resource commands'
        'config-report:config report commands'
        'content-credentials:content credentials'
        'content-export:content export commands'
        'content-import:content import commands'
        'content-units:content units'
        'content-view:content view commands'
        'defaults:defaults commands'
        'discovery:discovery commands'
        'discovery-rule:discovery rule commands'
        'domain:domain commands'
        'erratum:errata commands'
        'fact:facts'
        'file:file commands'
        'filter:filter commands'
        'foreign-input-set:foreign input set'
        'global-parameter:global parameter commands'
        'health-check:run health check'
        'host:host commands'
        'host create:create host'
        'host delete:delete host'
        'host list:list hosts'
        'host info:host info'
        'host update:update host'
        'host start:start host'
        'host stop:stop host'
        'host reboot:reboot host'
        'host reset:reset host'
        'host status:host status'
        'host-collection:host collection commands'
        'host-group:host group commands'
        'host-registration:host registration'
        'hostgroup:host group commands'
        'http-proxy:http proxy commands'
        'image:image commands'
        'job-invocation:job invocation commands'
        'job-template:job template commands'
        'lifecycle-environment:lifecycle environment commands'
        'location:location commands'
        'mail-notification:mail notification commands'
        'medium:installation medium commands'
        'model:model commands'
        'organization:organization commands'
        'os:operating system commands'
        'package:package commands'
        'package-group:package group commands'
        'partition-table:partition table commands'
        'ping:server ping'
        'policy:openscap policy commands'
        'product:product commands'
        'proxy:smart proxy commands'
        'puppet-class:puppet class commands'
        'puppet-environment:puppet environment commands'
        'realm:realm commands'
        'recurring-logic:recurring logic commands'
        'remote-execution-feature:remote execution features'
        'report-template:report template commands'
        'repository:repository commands'
        'repository-set:repository set commands'
        'role:role commands'
        'sc-param:smart class parameter commands'
        'settings:settings commands'
        'shell:open shell'
        'simple-content-access:simple content access'
        'srpm:source rpm commands'
        'status:status commands'
        'subnet:subnet commands'
        'subscription:subscription commands'
        'sync-plan:sync plan commands'
        'task:task commands'
        'template:template commands'
        'user:user commands'
        'user-group:user group commands'
        'webhook:webhook commands'
        'help:show help'
        'version:show version'
        'shell:interactive shell'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--show-ids[show ids]' \
        '--csv[csv output]' \
        '--csv-separator=+[char]:str:' \
        '--output=+[output format]:f:(base table silent csv yaml json)' \
        '--server=+[server URL]:url:_urls' \
        '-s+[server URL]:url:_urls' \
        '--username=+[user]:_users' \
        '-u+[user]:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--config=+[config file]:file:_files' \
        '--no-headers[no headers]' \
        '--no-color[no color]' \
        '--no-ssl[no ssl]' \
        '--reload-cache[reload cache]' \
        '--interactive[interactive]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'foreman subcommand' sub ;;
    esac
}

_foreman-cli "$@"
