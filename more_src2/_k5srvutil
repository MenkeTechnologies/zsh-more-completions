#compdef k5srvutil
# Documentation: https://web.mit.edu/kerberos/krb5-latest/doc/admin/admin_commands/k5srvutil.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list keys in a keytab (version + principal)'
  'change:update keys to new random values and sync keytab'
  'delold:delete keys that are not the most recent version'
  'delete:remove specific keys from the keytab'
)

_arguments -C \
  '-i[prompt for confirmation before each key/principal]' \
  '-f+[keytab file to use instead of default]:file:_files' \
  '-k[display old and new keys during change]' \
  '-e+[override default enctypes and key salts]:keysalts:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'k5srvutil command' commands && ret=0 ;;
esac

return ret
