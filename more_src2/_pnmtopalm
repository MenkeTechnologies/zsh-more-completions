#compdef pnmtopalm
# Documentation: man pnmtopalm (Netpbm)
# Source: convert a Netpbm image to a Palm OS bitmap.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-depth=[bit depth]:n:(1 2 4 8 16)' \
    '-maxdepth=[max bit depth]:n:(1 2 4 8 16)' \
    '-colormap[include color map]' \
    '-transparent=[transparent color]:colorspec:' \
    '-density=[pixel density]:n:' \
    '-offset[add image offset]' \
    '-withdummy[include dummy byte for older Palm OS]' \
    '(-scanline_compression -rle_compression -packbits_compression)-scanline_compression[scanline compression]' \
    '(-scanline_compression -rle_compression -packbits_compression)-rle_compression[RLE compression]' \
    '(-scanline_compression -rle_compression -packbits_compression)-packbits_compression[PackBits compression]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
