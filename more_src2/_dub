#compdef dub
# Documentation: dub --help (DUB 1.41)
# Source: D programming language DUB — package manager + build tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'init:initialize empty package skeleton'
    'run:build and run a package (default)'
    'build:build a package'
    'test:execute tests of selected package'
    'lint:execute linter tests'
    'generate:generate project files via generator'
    'describe:print JSON description of project'
    'clean:remove intermediate build files'
    'dustmite:create reduced test cases for build errors'
    'fetch:retrieve and cache packages'
    'add:add dependency to package file'
    'remove:remove cached package'
    'upgrade:force upgrade of dependencies'
    'add-path:add default package search path'
    'remove-path:remove package search path'
    'add-local:add local package directory'
    'remove-local:remove local package directory'
    'list:list local packages dub is aware of'
    'search:search for available packages'
    'clean-caches:remove cached metadata'
    'convert:convert format of package recipe'
)

local -a common_opts
common_opts=(
    '(-h --help)'{-h,--help}'[show help]'
    '--root=[directory to operate in]:dir:_files -/'
    '--recipe=[custom recipe path (dub.json or dub.sdl)]:file:_files'
    '*--registry=[registry URL]:url:'
    '--skip-registry=[skip search on certain registries]:mode:(none standard configured all)'
    '--annotate[print what would be done; do nothing]'
    '--bare[only packages in current directory]'
    '(-v --verbose --vverbose -q --quiet --verror --vquiet)'{-v,--verbose}'[diagnostic output]'
    '(-v --verbose --vverbose -q --quiet --verror --vquiet)--vverbose[debug output]'
    '(-v --verbose --vverbose -q --quiet --verror --vquiet)'{-q,--quiet}'[warnings + errors only]'
    '(-v --verbose --vverbose -q --quiet --verror --vquiet)--verror[errors only]'
    '(-v --verbose --vverbose -q --quiet --verror --vquiet)--vquiet[no messages]'
    '--color=[colored output]:when:(auto always never)'
    '--cache=[location for fetched packages]:where:(local system user)'
    '(- *)--version[display version]'
)

_arguments -C \
    $common_opts \
    '1: :->verb' \
    '*:: :->args' \
    && ret=0

case $state in
    verb)
        _describe -t dub-verbs 'dub subcommand' verbs && ret=0
        ;;
    args)
        _arguments $common_opts '*:argument:_files' && ret=0
        ;;
esac

return ret
