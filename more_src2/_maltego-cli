#compdef maltego maltego-cli mtg
# _maltego-cli — Maltego Technologies maltego-cli CLI client orchestrating Maltego graph-based investigation transforms for OSINT cyber-threat-intelligence link-analysis person organization domain DNS WHOIS social-media certificate Shodan Censys Have-I-Been-Pwned VirusTotal-transform-hub graph-import-export (Maltego team, Java); custom argparse
# upstream: https://www.maltego.com/

_maltego-cli() {
    local -a sub=(
        'graph:graph operations'
        'transform:transform invocation'
        'entity:entity operations'
        'hub:transform hub management'
        'export:export graph'
        'import:import graph'
        'iTDS:iTDS server interaction'
        'login:authenticate'
        'logout:logout'
        'config:configuration'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[user]:str:' \
        '--user=+[user]:str:' \
        '-k+[api key]:str:' \
        '--api-key=+[key]:str:' \
        '-s+[server]:_hosts' \
        '--server=+[server]:_hosts' \
        '-f+[format]:f:(mtgx json yaml csv stix2 graphml graphson)' \
        '--format=+[format]:f:(mtgx json yaml csv stix2 graphml graphson)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'maltego-cli subcommand' sub ;;
        args)
            case $words[1] in
                graph) _arguments '1:op:(create open save export merge analyze)' '*:file:_files -g "*.mtgx"' ;;
                transform) _arguments \
                    '--name=+[name]:str:' \
                    '--input=+[value]:str:' \
                    '--seed=+[seed]:str:' ;;
                export|import) _arguments '*:file:_files' ;;
            esac
            ;;
    esac
}

_maltego-cli "$@"
