#compdef ejabberdctl
# Documentation: https://docs.ejabberd.im/admin/guide/managing/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start ejabberd in background mode'
  'debug:attach interactive Erlang shell to running ejabberd'
  'live:start ejabberd in live mode'
  'help:show help'
  'status:check ejabberd server status'
  'stop:stop ejabberd server'
  'restart:restart ejabberd server'
  'mnesia:get Mnesia database info'
  'register:register a user'
  'unregister:unregister a user'
  'change_password:change a user password'
  'kick_user:kick user sessions'
  'backup:backup ejabberd database'
  'restore:restore database from backup'
  'dump_table:dump Mnesia table'
  'install_fallback:install fallback'
  'mnesia_change_nodename:change Mnesia node name'
  'set_loglevel:set loglevel'
  'get_loglevel:get loglevel'
)

# Flags accepted before the command (see ejabberdctl shell script)
_arguments -C \
  '--node=[Erlang node name]:node:' \
  '--spool=[spool dir]:dir:_files -/' \
  '--logs=[log dir]:dir:_files -/' \
  '--config=[ejabberd config]:file:_files' \
  '--ctl-config=[ejabberdctl config]:file:_files' \
  '--config-dir=[config dir]:dir:_files -/' \
  '--no-timeout[no command timeout]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'ejabberdctl subcommand' subcommands && ret=0
    ;;
esac

return ret
