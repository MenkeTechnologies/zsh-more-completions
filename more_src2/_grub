#compdef grub
# _grub — legacy GNU GRUB Legacy shell (interactive grub command-line wrapper around the GRUB Legacy stage2; --batch reads commands from stdin, --boot-drive sets BIOS boot drive, --config-file picks an alternate menu.lst, --device-map remaps BIOS<->Linux device names)
# upstream: https://git.savannah.gnu.org/cgit/grub.git (legacy)
# Flags from grub legacy util/grub-md5-crypt + grub shell on tip.

_grub() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--batch[batch mode (no rescue prompt)]' \
        '--boot-drive=*[BIOS drive]:n:' \
        '--config-file=*[menu.lst]:file:_files' \
        '--device-map=*[device map file]:file:_files' \
        '--hold[hold for gdb attach]' \
        '--install-partition=*[partition number]:n:' \
        '--no-config-file[skip config file]' \
        '--no-curses[disable curses UI]' \
        '--no-pager[no pager]' \
        '--no-floppy[no floppy probing]' \
        '--probe-second-floppy[probe second floppy]' \
        '--read-only[read-only]' \
        '--verbose[verbose]' \
        '*::command:'
}

_grub "$@"
