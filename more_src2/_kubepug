#compdef kubepug
# Documentation: https://github.com/rikatz/kubepug
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--as-uid=[UID to impersonate for the operation]:uid' \
  '--cluster=[kubeconfig cluster name]:cluster' \
  '--context=[kubeconfig context name]:context' \
  '--database=[database location]:url' \
  '--disable-compression[opt-out of response compression]' \
  '--error-on-deleted[exit with code 1 if deleted APIs are found]' \
  '--error-on-deprecated[exit with code 1 if deprecated APIs are found]' \
  '--filename=[save results to file]:file:_files' \
  '--format=[output format]:format:(stdout plain json yaml)' \
  '--input-file=[manifest file or directory location]:file:_files' \
  '--k8s-version=[target Kubernetes version]:version' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--tls-server-name=[server certificate validation name]:name' \
  '(-v --verbosity)'{-v+,--verbosity=}'[log level verbosity]:level' && ret=0

return ret
