#compdef kubectl-debug_pvc
# Documentation: https://github.com/zwindler/kubectl-debug-pvc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-debug_pvc (zwindler/kubectl-debug-pvc): krew replaces `-` with
# `_` in the binary name; invoked as `kubectl debug-pvc` via krew.
local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '(-p --pod)'{-p+,--pod=}'[target pod name]:pod:' \
  '*'{-v+,--volume=}'[volume mount as name:mountpath (repeatable)]:volume:' \
  '(-i --image)'{-i+,--image=}'[debug container image (default ubuntu:latest)]:image:' \
  '--mount-base=[base mount path in interactive mode (default /debug)]:path:' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '*:extra args:_default' && ret=0
return ret
