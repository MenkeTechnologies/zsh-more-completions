#compdef deepwiki-rs
# Documentation: https://github.com/sopaco/deepwiki-rs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# deepwiki-rs ("Litho") — LLM-assisted architecture doc generator

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'sync-knowledge:process external documentation cache'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-p --path)'{-p,--path}'=[project directory to analyze]:dir:_files -/' \
  '(-o --output)'{-o,--output}'=[output directory]:dir:_files -/' \
  '--target-language=[documentation language]:lang:(en ja zh fr de es)' \
  '--skip-preprocessing[bypass preprocessing stage]' \
  '--skip-research[skip research phase]' \
  '--disable-preset-tools[turn off ReAct preset tools]' \
  '--llm-api-base-url=[LLM provider base URL]:url' \
  '--llm-api-key=[LLM authentication key]:key' \
  '--model-efficient=[lightweight model name]:model' \
  '--model-powerful=[advanced model name]:model' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'deepwiki-rs command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (sync-knowledge)
        _arguments '--force[force refresh cached knowledge]' && ret=0 ;;
    esac ;;
esac

return ret
