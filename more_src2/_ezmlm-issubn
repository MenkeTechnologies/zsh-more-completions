#compdef ezmlm-issubn
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-issubn.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-n[negate exit code (99 if subscriber)]' \
  '-N[normal exit codes (default)]' \
  '1:dir:_files -/' \
  '2:address:' && ret=0

return ret
