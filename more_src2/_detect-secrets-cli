# _detect-secrets-cli — Yelp detect-secrets-cli CLI command-line frontend wrapping the detect-secrets enterprise friendly way of detecting and preventing secrets in code open-source written in Python the Yelp internally developed tool open-sourced uses-pluggable-engine-with-distinct-plugins-for-detecting-secrets-of-various-types audit scan baseline-management YAML-baseline-state-store includes-Hashed-baseline-secrets word-list custom-plugins exclude-files exclude-lines (Yelp Aaron Loo team, Python); argparse
# upstream: https://github.com/Yelp/detect-secrets

_detect-secrets-cli() {
    local -a sub=(
        'scan:scan for secrets'
        'audit:audit a baseline'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[colors]:str:' \
        '--color=+[c]:c:(auto always never)' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n+[N]:n:' \
        '--n-ghost-lines=+[N]:n:' \
        '--baseline=+[file]:file:_files -g ".secrets.baseline"' \
        '--exclude-files=+[regex]:str:' \
        '--exclude-lines=+[regex]:str:' \
        '--exclude-secrets=+[regex]:str:' \
        '--word-list=+[file]:file:_files' \
        '--custom-plugins=+[path]:_files' \
        '--disable-plugin=+[name]:str:' \
        '--filter=+[name]:str:' \
        '--no-verify[no verify]' \
        '--only-verified[only verified]' \
        '--force-use-all-plugins[use all plugins]' \
        '--update[update baseline]' \
        '--list-all-plugins[list plugins]' \
        '--list-default-plugins[list default plugins]' \
        '--all-files[all files]' \
        '-s+[slim]' \
        '--slim[slim output]' \
        '--string=+[s]:str:' \
        '--show-secrets[show secrets]' \
        '--report[report]' \
        '--only-real[only real]' \
        '--only-false[only false]' \
        '--json[JSON output]' \
        '--diff=+[file]:file:_files' \
        '--display-results[display results]' \
        '--statistics[statistics]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'detect-secrets subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments '*:path:_files -/' ;;
                audit) _arguments '*:baseline:_files -g ".secrets.baseline"' ;;
            esac
            ;;
    esac
}

_detect-secrets-cli "$@"
