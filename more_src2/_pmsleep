#compdef pmsleep
# _pmsleep — PCP-aware sleep (accepts PCP time-interval syntax) (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Usage from src/pmsleep/pmsleep.c: pmsleep [-?|--help] interval

_pmsleep() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '1:interval (e.g. 1s, 500msec, 2hour):'
}

_pmsleep "$@"
