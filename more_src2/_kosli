#compdef kosli
# Documentation: https://docs.kosli.com/client_reference/kosli/
# Reference accessed: 2026-05-19
# Verified: upstream Kosli CLI client reference (global flags).

# kosli — Kosli CLI (cobra). Added verified global flags from the
# client reference; previous file only had -h/--version.
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[show version]' \
  '(-a --api-token)'{-a+,--api-token=}'[the Kosli API token]:token:' \
  '(-c --config-file)'{-c+,--config-file=}'[optional configuration file path]:file:_files' \
  '--debug[print diagnostic information to stdout]' \
  '(-H --host)'{-H+,--host=}'[the Kosli API endpoint]:url:' \
  '--http-proxy=[HTTP proxy with protocol and port]:proxy:' \
  '(-r --max-api-retries)'{-r+,--max-api-retries=}'[API retry count when host unreachable]:n:' \
  '--org=[the Kosli organization]:org:' \
  '(-q --quiet)'{-q,--quiet}'[suppress non-critical warning messages]' \
  '*::arguments:_default'
