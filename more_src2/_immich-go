#compdef immich-go
# Documentation: https://github.com/simulot/immich-go
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# immich-go: Go-based bulk uploader for Immich (no Node/Docker required).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'upload:upload assets to an Immich server'
  'archive:archive assets from an Immich server'
  'version:show version information'
  'help:show help for a command'
)

local -a upload_subcommands=(
  'from-folder:upload from a local folder'
  'from-google-photos:upload from Google Photos Takeout archive'
  'from-immich:server-to-server migration'
  'from-picasa:upload Picasa albums via .picasa.ini'
  'from-icloud:upload iCloud Photos takeout'
)

_arguments -s -S -C \
  '--server=[Immich server URL]:url:' \
  '--api-key=[API key]:key:' \
  '--config=[config file]:file:_files' \
  '--save-config[write immich-go.yaml with current flags]' \
  '--dry-run[dry run]' \
  '--on-errors=[error policy]:policy:(stop continue)' \
  '--concurrent-tasks=[parallel tasks (1-20)]:count:' \
  '--log-level=[log level]:level:(DEBUG INFO WARN ERROR)' \
  '(-l --log-file)'{-l+,--log-file=}'[log file path]:file:_files' \
  '--log-type=[log format]:type:(text json)' \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'immich-go command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (upload)
        if (( CURRENT == 2 )); then
          _describe -t subcommands 'upload source' upload_subcommands && ret=0
        else
          _files && ret=0
        fi
        ;;
      (archive)
        _arguments '1:source:(from-immich)' '*:: :->aargs' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
