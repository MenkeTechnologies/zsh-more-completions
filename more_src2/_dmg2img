#compdef dmg2img
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-i[input DMG file]:input file:_files -g "*.dmg(-.)"' \
  '-o[output IMG file]:output file:_files' \
  '-p[partition number to extract]:partition number' \
  '-s[list partitions]' \
  '-v[verbose mode]' \
  '-d[debug mode]' \
  '-l[list all blocks]' \
  '-h[show help]' && ret=0
return ret
