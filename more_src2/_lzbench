#compdef lzbench
# Documentation: https://github.com/inikep/lzbench/blob/master/doc/lzbench.7.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help and exit]' \
  '-b+[set block/chunk size in KB]:kb:' \
  '-c+[sort results by column]:column:(1 2 3 4)' \
  '-e+[compressors separated by slash with params after comma]:codecs:' \
  '-i+[set min number of compression and decompression iterations]:X,Y:' \
  '-j[join files in memory but compress independently]' \
  '-l[list available compressors and aliases]' \
  '-m+[set memory limit in MB]:mb:' \
  '-o+[output text format]:format:(1 2 3 4)' \
  '-p+[print time for all iterations]:mode:(1 2 3)' \
  '-q[suppress progress information]' \
  '-R[read block/chunk size from random blocks]' \
  '-r[operate recursively on directories]' \
  '-s+[only compressors with compression speed over MB]:mb:' \
  '-T+[use threads]:threads:' \
  '-t+[set min time in seconds for compression and decompression]:X,Y:' \
  '-v[verbose (-vv gives more)]' \
  '-V[output version information and exit]' \
  '-x[disable real-time process priority]' \
  '-z[show (de)compression times instead of speed]' \
  '*:file:_files' && ret=0

return ret
