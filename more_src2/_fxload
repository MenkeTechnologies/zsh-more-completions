#compdef fxload
# Documentation: man fxload(8)
# Source: libusb/libusb examples/fxload.c (master) — Cypress EZ-USB firmware loader (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[target device by VID:PID]:vid\:pid:_default' \
    '-p+[target device by bus,addr]:bus\,addr:_default' \
    '(-i -I)'{-i+,-I+}'[firmware file (Intel hex / ihx / iic / bix / img)]:firmware:_files -g "*.{ihx,iic,bix,img,hex}"' \
    '(-s -S)'{-s+,-S+}'[second-stage loader file]:loader:_files -g "*.{ihx,iic,bix,img,hex}"' \
    '-t+[device type]:type:(an21 fx fx2 fx2lp fx3)' \
    '*-v[verbose (stackable)]' \
    '*-q[quiet (decrement verbose)]' \
    '-V[show version]' \
    '(-h -\\?)'{-h,-\\?}'[show help]' \
    && ret=0

return ret
