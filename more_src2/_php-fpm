#compdef php-fpm
# Documentation: php-fpm -h
# Source: PHP FastCGI Process Manager.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-v[show version]' \
    '(- *)-i[PHP information]' \
    '(- *)-m[show compiled-in modules]' \
    '(-n)-c+[php.ini directory or file]:path:_files' \
    '(-c)-n[no php.ini]' \
    '*-d+[define INI entry foo[=bar]]:assignment:' \
    '-e[generate extended debug/profile info]' \
    {-p+,--prefix=}'[alternative FPM prefix path]:dir:_files -/' \
    {-g+,--pid=}'[PID file location]:file:_files' \
    {-y+,--fpm-config=}'[FPM config file path]:file:_files -g "*.conf"' \
    {-t,--test}'[test FPM configuration and exit]' \
    {-tt,--testtest}'[test FPM configuration and dump full config]' \
    {-D,--daemonize}'[force background, ignore config daemonize]' \
    {-F,--nodaemonize}'[force foreground, ignore config daemonize]' \
    {-O,--force-stderr}'[force stderr output in nodaemonize]' \
    {-R,--allow-to-run-as-root}'[allow pool to run as root]' \
    && ret=0

return ret
