#compdef firecrawl-cli
# Documentation: https://github.com/mendableai/firecrawl-cli
# Reference accessed: 2026-05-23
# Verified: npx firecrawl-cli --help.

# Zsh completion for firecrawl-cli - Firecrawl web scraping CLI (npm firecrawl-cli)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-k --api-key)'{-k+,--api-key=}'[Firecrawl API key]:key:' \
  '--api-url[API base URL]:url:' \
  '--status[show auth status and credits]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'firecrawl command' \
      'scrape[scrape one or more URLs]' \
      'crawl[crawl a website]' \
      'map[map site URLs]' \
      'parse[parse local file to markdown/HTML/JSON]' \
      'monitor[schedule recurring scrapes]' \
      'search[web search via Firecrawl]' \
      'search-feedback[feedback on search results]' \
      'agent[AI agent web extraction]' \
      'interact[interact with scraped page in browser]' \
      'experimental[experimental commands]' \
      'config[configure and authenticate]' \
      'view-config[view configuration]' \
      'login[login to Firecrawl]' \
      'logout[logout and clear credentials]' \
      'init[setup CLI and scaffold template]' \
      'setup[setup integrations skills workflows mcp]' \
      'env[pull API key into .env]' \
      'credit-usage[team credit usage]' \
      'version[display version]' \
      'help[command help]' && ret=0
    ;;
  args)
    case $line[1] in
      scrape)
        _arguments \
          '(-u --url)'{-u+,--url=}'[URL to scrape]:url:_urls' \
          '(-H --html)'{-H,--html}'[output raw HTML]' \
          '(-f --format)'{-f+,--format=}'[output format(s)]:formats:' \
          '--only-main-content[extract main content only]' \
          '--wait-for[wait before scrape in ms]:ms:' \
          '(-S --summary)'{-S,--summary}'[output summary]' \
          '*:url:_urls' && ret=0
        ;;
      crawl)
        _arguments \
          '(-u --url)'{-u+,--url=}'[URL to crawl]:url:_urls' \
          '--status[check crawl job status]' \
          '--wait[wait for crawl to complete]' \
          '--poll-interval[poll interval seconds]:n:' \
          '--timeout[wait timeout seconds]:n:' \
          '--progress[show progress while waiting]' \
          '--limit[max pages]:n:' \
          '--max-depth[max depth]:n:' \
          ':url-or-job-id:' && ret=0
        ;;
      search)
        _arguments '*:query:' && ret=0
        ;;
      agent)
        _arguments ':prompt-or-job-id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
