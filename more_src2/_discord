#compdef discord Discord
# _discord — Discord (Electron-based desktop client; --start-minimized launches into tray, --no-sandbox disables Electron sandbox (use only when forced), --disable-gpu, --proxy-server=, --user-data-dir overrides profile location, --enable-features=UseOzonePlatform for Wayland)
# upstream: official Discord client (closed source Electron app)
# Common Electron / Chromium flags Discord respects on current builds.

_discord() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--start-minimized[start into tray]' \
        '--no-sandbox[disable Electron sandbox]' \
        '--disable-gpu[disable GPU compositing]' \
        '--disable-gpu-sandbox[disable GPU sandbox]' \
        '--disable-software-rasterizer[disable software rasterizer]' \
        '--disable-features=*[disable Chromium features]:features:' \
        '--enable-features=*[enable Chromium features]:features:' \
        '--proxy-server=*[proxy server URI]:proxy:' \
        '--proxy-bypass-list=*[bypass list]:list:' \
        '--proxy-pac-url=*[PAC URL]:url:' \
        '--user-data-dir=*[user data dir]:dir:_files -/' \
        '--remote-debugging-port=*[devtools port]:port:' \
        '--ozone-platform=*[ozone backend]:platform:(x11 wayland)' \
        '--ozone-platform-hint=*[ozone hint]:hint:(auto x11 wayland)' \
        '*::url:'
}

_discord "$@"
