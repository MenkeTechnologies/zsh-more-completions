_emailengine() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a _ee_global_opts=(
        '(- *)'{-h,--help}'[show help]'
        '--dbs.redis=[Redis connection URL]:url:'
        '--workers.imap=[IMAP worker threads (default 4)]:n:'
        '--workers.webhooks=[webhook worker threads (default 1)]:n:'
        '--settings=[pre-configured settings JSON]:json:'
        '--service.secret=[secret for stored credential encryption]:key:'
        '--service.commandTimeout=[max time for IMAP commands (default 10s)]:duration:'
        '--service.setupDelay=[delay between worker connect assignments (default 0ms)]:duration:'
        '--log.level=[logging level (default trace)]:level:(trace debug info warn error fatal)'
        '--log.raw[log raw IMAP protocol traffic]'
        '--api.host=[API server bind address (default 127.0.0.1)]:host:'
        '--api.port=[API server port (default 3000)]:port:'
        '--api.maxSize=[max attachment size (default 5M)]:size:'
        '--queues.notify=[concurrent webhook deliveries (default 1)]:n:'
        '--queues.submit=[concurrent email submissions (default 1)]:n:'
        '--smtp.enabled[enable SMTP submission server]'
        '--smtp.secret=[shared SMTP password for all accounts]:pass:'
        '--smtp.host=[SMTP server bind address (default 127.0.0.1)]:host:'
        '--smtp.port=[SMTP server port (default 2525)]:port:'
        '--smtp.proxy[enable HAProxy PROXY protocol]'
        '--smtp.maxMessageSize=[max email size (default 25M)]:size:'
    )

    _arguments -C \
        $_ee_global_opts \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _ee_commands=(
                'help:show help for a command'
                'version:show version number'
                'license:manage license information'
                'password:set or reset admin password'
                'scan:scan Redis keyspace and output as CSV'
                'encrypt:manage field-level encryption for stored credentials'
                'tokens:manage API access tokens'
                'export:export account data including OAuth credentials'
                'check-bounce:analyze a bounce email and classify it'
            )
            _describe -t commands 'emailengine command' _ee_commands && ret=0
            ;;
        args)
            case $words[1] in
                help)
                    _arguments '1:command:(help version license password scan encrypt tokens export check-bounce)' && ret=0
                    ;;
                license)
                    if (( CURRENT == 2 )); then
                        local -a _lic=(
                            'export:export license key for backup'
                            'import:import license key'
                        )
                        _describe -t sub 'license sub' _lic && ret=0
                    elif [[ $words[2] == import ]]; then
                        _arguments '(-l --license)'{-l,--license}'=[encoded license key]:key:' && ret=0
                    fi
                    ;;
                password)
                    _arguments \
                        '(-p --password)'{-p,--password}'=[password to set (auto-generated if absent)]:password:' \
                        '(-r --hash)'{-r,--hash}'[output password hash instead of plaintext]' && ret=0
                    ;;
                encrypt)
                    _arguments '*--decrypt=[previous secret for re-encryption (repeatable)]:secret:' && ret=0
                    ;;
                tokens)
                    if (( CURRENT == 2 )); then
                        local -a _tk=(
                            'issue:create a new access token'
                            'export:export token for backup'
                            'import:import a previously exported token'
                        )
                        _describe -t sub 'tokens sub' _tk && ret=0
                    else
                        case $words[2] in
                            issue)
                                _arguments \
                                    '(-d --description)'{-d,--description}'=[token description]:desc:' \
                                    '(-s --scope)'{-s,--scope}'=[access scope (default *)]:scope:' \
                                    '(-a --account)'{-a,--account}'=[limit token to specific account]:account:' && ret=0
                                ;;
                            export|import)
                                _arguments '(-t --token)'{-t,--token}'=[token data]:data:' && ret=0
                                ;;
                        esac
                    fi
                    ;;
                export)
                    _arguments '(-a --account)'{-a,--account}'=[account ID to export]:account:' && ret=0
                    ;;
                check-bounce)
                    _arguments '(-f --file)'{-f,--file}'=[path to EML file]:file:_files -g "*.eml"' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_emailengine "$@"
