_node-opcua-pki() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _pki_cmds=(
                'help:print top-level usage'
                'version:print version'
                'demo:create default certificates for node-opcua demos'
                'createCA:create a Certificate Authority'
                'createPKI:create a Public Key Infrastructure folder layout'
                'certificate:create a new application certificate'
                'revoke:revoke an existing certificate'
                'csr:create a certificate signing request'
                'sign:validate a CSR and generate a certificate'
                'dump:display a certificate'
                'toder:convert PEM certificate to DER (and print fingerprint)'
                'fingerprint:print the certificate fingerprint'
            )
            _describe -t commands 'node-opcua-pki command' _pki_cmds && ret=0
            ;;
        args)
            case $words[1] in
                demo)
                    _arguments \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--silent[silent mode]' \
                        '--dev[also create fancy/edge-case dev-test certificates]' \
                        '--clean[purge existing PKI directory (use with care!)]' && ret=0
                    ;;
                createCA)
                    _arguments \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--CAFolder=[override CA folder location]:dir:_files -/' \
                        '--keySize=[RSA key size]:bits:(1024 2048 3072 4096)' \
                        '--silent[silent mode]' \
                        '--subject=[CA certificate subject DN]:dn:' && ret=0
                    ;;
                createPKI)
                    _arguments \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--PKIFolder=[override PKI folder location]:dir:_files -/' \
                        '--keySize=[RSA key size]:bits:(1024 2048 3072 4096)' \
                        '--silent[silent mode]' && ret=0
                    ;;
                certificate)
                    _arguments \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--CAFolder=[CA folder location]:dir:_files -/' \
                        '--PKIFolder=[PKI folder location]:dir:_files -/' \
                        '--privateKey=[override the private-key file]:path:_files -g "*.pem *.key"' \
                        '--silent[silent mode]' \
                        '(-a --applicationUri)'{-a,--applicationUri}'=[application URI]:uri:' \
                        '(-o --output)'{-o,--output}'=[output certificate path]:path:_files -g "*.pem"' \
                        '(-s --selfSigned)'{-s,--selfSigned}'[issue a self-signed cert (skip the CA)]' \
                        '(-v --validity)'{-v,--validity}'=[certificate validity in days]:n:' \
                        '--dns=[comma-separated DNS SANs]:list:' \
                        '--ip=[comma-separated IP SANs]:list:' \
                        '--subject=[certificate subject DN]:dn:' && ret=0
                    ;;
                revoke)
                    _arguments \
                        '1:certificate file:_files -g "*.pem *.crt *.cer"' \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--CAFolder=[CA folder location]:dir:_files -/' && ret=0
                    ;;
                csr)
                    _arguments \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--PKIFolder=[PKI folder location]:dir:_files -/' \
                        '--privateKey=[private-key file]:path:_files -g "*.pem *.key"' \
                        '--silent[silent mode]' \
                        '(-a --applicationUri)'{-a,--applicationUri}'=[application URI]:uri:' \
                        '(-o --output)'{-o,--output}'=[output CSR path]:path:_files -g "*.csr"' \
                        '--dns=[comma-separated DNS SANs]:list:' \
                        '--ip=[comma-separated IP SANs]:list:' \
                        '--subject=[certificate subject DN]:dn:' && ret=0
                    ;;
                sign)
                    _arguments \
                        '1:CSR file:_files -g "*.csr"' \
                        '--root=[PKI root directory]:dir:_files -/' \
                        '--CAFolder=[CA folder location]:dir:_files -/' \
                        '--output=[output certificate path]:path:_files -g "*.pem"' && ret=0
                    ;;
                dump)
                    _arguments '1:certificate file:_files -g "*.pem *.crt *.cer *.der"' && ret=0
                    ;;
                toder)
                    _arguments '1:PEM certificate:_files -g "*.pem"' && ret=0
                    ;;
                fingerprint)
                    _arguments '1:certificate file:_files -g "*.pem *.crt *.cer *.der"' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_node-opcua-pki "$@"
