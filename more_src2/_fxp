_fxp() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'val:Validate XML'
        'x2j:Convert XML to JSON'
        'j2x:Convert JSON to XML'
        'help:display help for a command'
    )

    # supported i18n message languages — verbatim from fxp-cli/lang/*.json
    local -a langs=(
        'ar:Arabic'
        'en:English (default)'
        'es:Spanish'
        'fr:French'
        'hi:Hindi'
        'js:Japanese'
        'ta:Tamil'
        'zh:Chinese'
    )

    _arguments -C \
        '(- *)--version[output the version number]' \
        '(- *)'{-h,--help}'[display help for command]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'fxp command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                val) _fxp_val && ret=0 ;;
                x2j) _fxp_x2j && ret=0 ;;
                j2x) _fxp_j2x && ret=0 ;;
                help)
                    _describe -t commands 'fxp command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

# Supported -lang values, used in nested completers
_fxp_langs() {
    local -a langs
    langs=(
        'ar:Arabic'
        'en:English'
        'es:Spanish'
        'fr:French'
        'hi:Hindi'
        'js:Japanese'
        'ta:Tamil'
        'zh:Chinese'
    )
    _describe -t langs 'message language' langs
}

# `fxp val` — validate XML files (or stdin)
_fxp_val() {
    _arguments \
        '*'{-f,--file=}'[input XML file(s) or - for stdin]:file:_files -g "*.(xml|XML)"' \
        '-b[allow boolean attributes]' \
        '--config=[custom configuration file]:config:_files -g "*.(json|cjs|mjs|js)"' \
        '--lang=[language for error messages]:language:_fxp_langs' \
        '--lang-file=[custom language file path]:path:_files -g "*.json"' \
        '(-h --help)'{-h,--help}'[display help for command]'
}

# `fxp x2j` — convert XML to JSON
_fxp_x2j() {
    _arguments \
        '*'{-f,--file=}'[input XML file(s) or - for stdin]:file:_files -g "*.(xml|XML)"' \
        '*'{-o,--output=}'[output JSON file(s)]:output:_files -g "*.(json|JSON)"' \
        '-b[allow boolean attributes]' \
        '-p[pretty-print JSON]' \
        '-v[parse values to native types]' \
        '-s+[stop parsing at tags (comma-separated)]:tags:' \
        '--order[preserve tag order]' \
        '--config=[custom configuration file]:config:_files -g "*.(json|cjs|mjs|js)"' \
        '--lang=[language for error messages]:language:_fxp_langs' \
        '--lang-file=[custom language file path]:path:_files -g "*.json"' \
        '(-h --help)'{-h,--help}'[display help for command]'
}

# `fxp j2x` — convert JSON to XML
_fxp_j2x() {
    _arguments \
        '*'{-f,--file=}'[input JSON file(s) or - for stdin]:file:_files -g "*.(json|JSON)"' \
        '*'{-o,--output=}'[output XML file(s)]:output:_files -g "*.(xml|XML)"' \
        '-p[enable formatted output]' \
        '-e[suppress empty elements]' \
        '-b[allow boolean attributes]' \
        '-s+[stop parsing at tags (comma-separated)]:tags:' \
        '--order[preserve tag order]' \
        '--config=[custom configuration file]:config:_files -g "*.(json|cjs|mjs|js)"' \
        '--lang=[language for error messages]:language:_fxp_langs' \
        '--lang-file=[custom language file path]:path:_files -g "*.json"' \
        '(-h --help)'{-h,--help}'[display help for command]'
}

_fxp "$@"
