#compdef ovs_exporter ovs-exporter
# _ovs_exporter — Open vSwitch metrics for Prometheus (greenpau/ovs_exporter)
# upstream: https://github.com/greenpau/ovs_exporter
# Flags from cmd/ovs_exporter/main.go (flag).

_ovs_exporter() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-version[show version]' \
        '-web.listen-address=[HTTP bind address]:addr:' \
        '-web.telemetry-path=[metrics URL path]:path:' \
        '-ovs.timeout=[OVS JSON-RPC timeout (s)]:secs:' \
        '-ovs.poll-interval=[min collection interval (s)]:secs:' \
        '-log.level=[log level]:level:(debug info warn error)' \
        '-system.run.dir=[OVS run directory]:dir:_files -/' \
        '-database.vswitch.name=[OVS db name]:name:' \
        '-database.vswitch.socket.remote=[OVS db JSON-RPC socket]:addr:' \
        '-database.vswitch.file.data.path=[OVS db file]:file:_files' \
        '-database.vswitch.file.log.path=[OVS db log file]:file:_files' \
        '-database.vswitch.file.pid.path=[OVS db PID file]:file:_files' \
        '-database.vswitch.file.system.id.path=[OVS system-id file]:file:_files' \
        '-service.vswitchd.file.log.path=[ovs-vswitchd log file]:file:_files' \
        '-service.vswitchd.file.pid.path=[ovs-vswitchd PID file]:file:_files' \
        '-service.ovncontroller.file.log.path=[OVN controller log file]:file:_files' \
        '-service.ovncontroller.file.pid.path=[OVN controller PID file]:file:_files'
}

_ovs_exporter "$@"
