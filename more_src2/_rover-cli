#compdef rover-cli
# _rover-cli — Apollo GraphOS Rover CLI alias for managing graphs (Apollo GraphQL, Rust); clap-rs
# upstream: https://github.com/apollographql/rover

_rover-cli() {
    local -a sub=(
        'config:Rover config'
        'contract:contract commands'
        'dev:start local Rover dev'
        'fed2:Federation 2 utilities'
        'graph:graph commands'
        'install:install Rover'
        'license:license commands'
        'pq:persisted queries'
        'readme:readme commands'
        'subgraph:subgraph commands'
        'supergraph:supergraph commands'
        'template:scaffold templates'
        'update:update Rover'
        'docs:open documentation'
        'explain:explain a graph schema'
        'cloud:GraphOS cloud config'
        'lsp:Apollo Language Server'
        'help:show help'
        'completion:generate shell completion'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--log=+[log level]:level:(error warn info debug trace)' \
        '-l+[log level]:level:(error warn info debug trace)' \
        '--format=+[output format]:fmt:(plain json)' \
        '--insecure-accept-invalid-certs[insecure accept invalid certs]' \
        '--insecure-accept-invalid-hostnames[insecure accept invalid hostnames]' \
        '--client-timeout=+[client timeout]:n:' \
        '--skip-update-check[skip update check]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rover subcommand' sub ;;
        args)
            case $words[1] in
                graph) _arguments \
                    '1:cmd:(check fetch publish lint introspect delete)' \
                    '--profile=+[profile]:str:' \
                    '--routing-url=+[routing url]:url:_urls' \
                    '--schema=+[schema file]:file:_files' \
                    '*:graph-ref:' ;;
                subgraph) _arguments \
                    '1:cmd:(check delete fetch fetch-all introspect lint list publish)' \
                    '--name=+[subgraph name]:str:' \
                    '--profile=+[profile]:str:' \
                    '--routing-url=+[routing url]:url:_urls' \
                    '--schema=+[schema file]:file:_files' \
                    '--allow-invalid-routing-url[allow invalid routing url]' \
                    '*:graph-ref:' ;;
                supergraph) _arguments \
                    '1:cmd:(compose fetch)' \
                    '--config=+[config file]:file:_files' \
                    '-c+[config file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--federation-version=+[federation version]:v:(1 2)' \
                    '--profile=+[profile]:str:' \
                    '*:graph-ref:' ;;
                dev) _arguments \
                    '--supergraph-config=+[supergraph config]:file:_files' \
                    '--router-config=+[router config]:file:_files' \
                    '--port=+[port]:port:' \
                    '--supergraph-port=+[supergraph port]:port:' \
                    '--name=+[subgraph name]:str:' \
                    '--url=+[subgraph url]:url:_urls' \
                    '--schema=+[subgraph schema]:file:_files' \
                    '--polling-interval=+[polling interval]:dur:' \
                    '--license=+[license file]:file:_files' \
                    '--profile=+[profile]:str:' ;;
                config) _arguments \
                    '1:cmd:(auth clear delete list whoami)' \
                    '--profile=+[profile]:str:' \
                    '*:arg:' ;;
                template) _arguments \
                    '1:cmd:(list use)' \
                    '*:arg:' ;;
                cloud) _arguments \
                    '1:cmd:(config)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                lsp) _arguments \
                    '--config=+[config file]:file:_files' \
                    '--supergraph-config=+[supergraph config]:file:_files' ;;
            esac
            ;;
    esac
}

_rover-cli "$@"
