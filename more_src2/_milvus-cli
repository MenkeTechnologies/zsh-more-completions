#compdef milvus-cli milvus_cli
# Documentation: https://github.com/zilliztech/milvus_cli
# Reference accessed: 2026-05-23
# Verified: milvus_cli REPL commands (see also _milvus_cli).

# Zsh completion for milvus-cli - Milvus vector database CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'milvus_cli command' \
      'connect[connect to Milvus]' \
      'create[create resources]' \
      'list[list resources]' \
      'show[view details]' \
      'delete[delete resources]' \
      'load[load collection or partition]' \
      'release[release from memory]' \
      'insert[insert entities]' \
      'upsert[upsert entities]' \
      'query[expression query]' \
      'search[vector similarity search]' \
      'help[show help]' \
      'version[show version]' \
      'exit[exit CLI]' && ret=0
    ;;
  args)
    case $line[1] in
      connect)
        _arguments \
          '(-uri --uri)'{-uri,--uri}'[server URI]:uri:' \
          '(-t --token)'{-t,--token}'[API key or user:pass]:token:' \
          '--tls[TLS mode]:mode:(0 1 2)' && ret=0
        ;;
      create|list|show|delete)
        if (( CURRENT == 3 )); then
          _values 'resource' \
            collection database index partition user role alias && ret=0
        fi
        ;;
      load|release)
        if (( CURRENT == 3 )); then
          _values 'target' collection partition && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
