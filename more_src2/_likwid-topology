#compdef likwid-topology likwid-perfctr likwid-pin likwid-powermeter likwid-mpirun likwid-setFrequencies likwid-features likwid-genTopoCfg
# Documentation: https://manpages.debian.org/bookworm/likwid/*.1.en.html
# Reference accessed: 2026-05-30
# LIKWID — RRZE-HPC's performance toolkit for x86/ARM/POWER multi-core systems.
# 8 binaries share a `likwid-` prefix and a common short-flag style (-c cpu-list,
# -V verbosity 0..3, -v/--version, -h/--help). This multi-stem file dispatches
# on $service and covers the 6 source-verified members of the family plus stub
# coverage for the remaining 2.

local curcontext="$curcontext" state line ret=1

case $service in

  likwid-topology)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-V --verbose)'{-V,--verbose=}'[topology-backend verbosity (0..3)]:level:(0 1 2 3)' \
      '-g[print topology as ASCII art (no GPU)]' \
      '(-c --caches)'{-c,--caches}'[detailed cache hierarchy]' \
      '(-C --clock)'{-C,--clock}'[measure + report processor clock]' \
      '(-G --gpus)'{-G,--gpus}'[detailed Nvidia GPU topology]' \
      '(-o --output)'{-o,--output=}'[output file (.csv/.xml/.json triggers a filter)]:file:_files' \
      && ret=0
    ;;

  likwid-perfctr)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '-H[group help (use with -g)]' \
      '(-V --verbose)'{-V,--verbose=}'[verbosity (0..3)]:level:(0 1 2 3)' \
      '(-m --marker)'{-m,--marker}'[run in marker-API mode]' \
      '(- *)-a[print available performance groups, exit]' \
      '(- *)-e[print available counters + events, exit]' \
      '(-o --output)'{-o,--output=}'[output file (suffix-driven filter)]:file:_files' \
      '-O[output as CSV]' \
      '(-i --info)'{-i,--info}'[print cpuid + Intel PMU info]' \
      '-c+[CPU expression to measure (no pinning)]:cpu-expr:' \
      '-C+[CPU expression + pin threads]:cpu-expr:' \
      '(-g --group)'{-g,--group=}'[performance group to measure]:group:' \
      '-t+[timeline mode period]:frequency:' \
      '-S+[end-to-end measurement (sleep)]:waittime:' \
      '-T+[group-switch period]:time:' \
      '(-s --skip)'{-s,--skip=}'[skip mask (hex)]:hex-mask:' \
      '(-f --force)'{-f,--force}'[force writing of registers]' \
      '-E+[filter events by search string]:search:' \
      '(-G --gpus)'{-G,--gpus=}'[GPU id list]:gpu-list:' \
      '(-W --gpugroup)'{-W,--gpugroup=}'[GPU performance group]:group:' \
      '--stats[always print statistics table]' \
      '*:::command:_command_names -e' \
      && ret=0
    ;;

  likwid-pin)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-V --verbose)'{-V,--verbose=}'[verbosity (0..3)]:level:(0 1 2 3)' \
      '-c+[CPU expression]:cpu-expr:' \
      '-C+[CPU expression + pin]:cpu-expr:' \
      '(-s --skip)'{-s,--skip=}'[skip mask (hex)]:hex-mask:' \
      '(-S --sweep)'{-S,--sweep}'[clean ccNUMA domains before run]' \
      '-p[print available thread domains for logical pinning]' \
      '(-i -m)-i[NUMA policy: interleave across pinned nodes]' \
      '(-i -m)-m[NUMA policy: membind to pinned nodes]' \
      '-d+[CPU delimiter (with -p)]:delim:' \
      '(-q --quiet)'{-q,--quiet}'[silent execution]' \
      '*:::command:_command_names -e' \
      && ret=0
    ;;

  likwid-powermeter)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-V --verbose)'{-V,--verbose=}'[verbosity (0..3)]:level:(0 1 2 3)' \
      '-c+[socket list (0,1,2 or 0-2)]:sockets:' \
      '-M+[MSR access mode]:mode:(0 1)' \
      '-s+[measure duration (e.g. 2s, 500ms)]:duration:' \
      '-p[print dynamic clocks + CPI per socket]' \
      '(-i --info)'{-i,--info}'[show TDP + Turbo steps for RAPL domains]' \
      '(-t -f)-t[print CPU temperature (Celsius)]' \
      '(-t -f)-f[print CPU temperature (Fahrenheit)]' \
      && ret=0
    ;;

  likwid-mpirun)
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-d --debug)'{-d,--debug}'[debug messages]' \
      '(-n -np --n --np)'{-n,-np,--n,--np=}'[MPI process count]:N:' \
      '-hostfile=[host list file]:file:_files' \
      '-nperdomain=[processes per affinity domain]:N:' \
      '-pin=[pinning expression for hybrid execution]:expr:' \
      '(-s --skip)'{-s,--skip=}'[skip mask (hex)]:hex-mask:' \
      '-omp=[OMP runtime]:type:(intel gnu)' \
      '-mpi=[MPI implementation]:impl:(intelmpi openmpi slurm mvapich2)' \
      '(-m --marker)'{-m,--marker}'[enable marker API for MPI processes]' \
      '-O[CSV output]' \
      '--mpiopts=[opts forwarded to MPI implementation]:opts:' \
      '*:::command:_command_names -e' \
      && ret=0
    ;;

  likwid-setFrequencies)
    _arguments -s -S \
      '(- *)-h[show help]' \
      '-p[print current frequencies for all HW threads]' \
      '-l[print all configurable frequencies]' \
      '-m[print all configurable governors]' \
      '-c+[affinity domain CPU list]:cpu-list:' \
      '-g+[governor for HW threads]:governor:(performance powersave ondemand conservative schedutil userspace)' \
      '(-f --freq)'{-f,--freq=}'[apply fixed frequency]:freq:' \
      '(-x --min)'{-x,--min=}'[minimum frequency constraint]:freq:' \
      '(-y --max)'{-y,--max=}'[maximum frequency constraint]:freq:' \
      '(-t --turbo)'{-t,--turbo=}'[Turbo mode]:state:(0 1)' \
      '--umin=[minimum Uncore frequency (Intel only)]:freq:' \
      '--umax=[maximum Uncore frequency (Intel only)]:freq:' \
      '--reset[restore default settings + performance governor]' \
      '--ureset[reset Uncore to max range]' \
      && ret=0
    ;;

  likwid-features|likwid-genTopoCfg)
    # Stub coverage — both members of the likwid family share the common
    # short-flag conventions but their man pages are not source-verified for
    # this round. Cover the universal options only.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-V --verbose)'{-V,--verbose=}'[verbosity (0..3)]:level:(0 1 2 3)' \
      '-c+[CPU expression]:cpu-expr:' \
      '(-o --output)'{-o,--output=}'[output file]:file:_files' \
      && ret=0
    ;;

esac

return ret
