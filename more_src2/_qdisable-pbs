#compdef qdisable
# _qdisable-pbs — PBS qdisable (server-side queue control: set queue's enabled attribute false so new jobs cannot be queued into it but already-queued jobs continue to run; positional argument is a list of queue names; admin-only command — runs as the PBS server's manager identity)
# upstream: https://github.com/openpbs/openpbs
# Argument shape from openpbs src/cmds/qdisable.c on tip.

_qdisable-pbs() {
    _arguments \
        '*:queue:'
}

_qdisable-pbs "$@"
