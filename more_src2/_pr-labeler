#compdef pr-labeler
# _pr-labeler — apply ok-to-test labels to PRs from trusted authors (kubernetes/test-infra)
# upstream: https://github.com/kubernetes/test-infra
# Flags from robots/pr-labeler/main.go (flag).

_pr-labeler() {
    _arguments \
        '-graphql-endpoint=[GitHub GraphQL endpoint]:url:_urls' \
        '-confirm[mutate GitHub]' \
        '-org=[GitHub org]:org:' \
        '-repo=[GitHub repo]:repo:' \
        '-token-path=[GitHub token file]:file:_files' \
        '-trust-collaborators[also trust PRs from collaborators]'
}

_pr-labeler "$@"
