# -----------------------------------------------------------------------------
#
# WHAT IS go-resty/resty AND WHY IS IT THE 70TH Go CLI LIBRARY?
#
# resty is the most-popular high-level HTTP client for Go.  Where
# Go's stdlib net/http provides primitive http.Client + http.Request
# + http.Response types requiring extensive manual marshaling,
# resty wraps these in a fluent Request-builder API with automatic
# serialization, retry, middleware, and many convenience helpers.
#
# Five distinguishing characteristics from reqwest (R649):
#
#   1. FLUENT BUILDER vs CONSTRUCTOR — reqwest uses ClientBuilder
#      + RequestBuilder where each call sets one option then
#      sends.  resty uses client.R() (Request) chained with
#      SetX(...) methods, then terminal Get/Post/Put/Delete/
#      Patch/Head/Options that returns Response:
#         client := resty.New()
#         resp, err := client.R().
#             SetHeader("Accept", "application/json").
#             SetAuthToken(token).
#             SetQueryParam("q", "search term").
#             SetResult(&Result{}).
#             Get("https://api.example.com/search")
#      Distinct from reqwest's chained builder which terminates
#      with .send() rather than returning the response directly.
#
#   2. AUTOMATIC JSON/XML — resty's SetResult(&v) populates a
#      struct from response body; SetBody(&v) serializes a
#      struct into request body.  Content-Type detection is
#      automatic.  reqwest requires `.json::<T>()` explicit
#      typed extraction.
#
#   3. RETRY WITH BACKOFF BUILT-IN — client.SetRetryCount(5).
#      SetRetryWaitTime(time.Second).
#      SetRetryMaxWaitTime(10*time.Second).
#      AddRetryCondition(func(r *resty.Response, err error) bool {
#        return r.StatusCode() == 429
#      }).  reqwest requires external retry middleware (reqwest-
#      retry crate).
#
#   4. MIDDLEWARE HOOKS — OnBeforeRequest + OnAfterResponse +
#      OnError hooks for logging, metrics, auth refresh.
#      reqwest requires external middleware infrastructure.
#
#   5. MATHEW-ROY / GO-RESTY ECOSYSTEM PROVENANCE — distinct
#      from Sean McArthur (Hyperium / reqwest), Russ Cox / Go
#      team (net/http stdlib), Steve Francia (cobra/viper/
#      afero), David Tolnay (serde).  Mathew Roy maintains
#      go-resty as a community-driven foundational HTTP client.
#
# -----------------------------------------------------------------------------
#
# THE intercept CLI — cobra + resty + zerolog + ksuid + embedded binaries
#
# intercept's CLI is in cmd/root.go.  Uses cobra.Command with
# Persistent flags at root level + child commands.
#
# Persistent flags (apply to all subcommands):
#   -v, --verbose          Count flag — increase verbosity level
#   -o, --output-dir DIR   Directory to write output files
#       --experimental     Enable unreleased experimental features
#       --debug            Enable extra dev debug output
#       --silent           Enable log to file intercept.log
#       --nolog            Disable all logging
#       --output-type T    Output types: SARIF,LOG (comma list)
#       --log-type T       Compliance log types:
#                          MINIMAL,RESULTS,POLICY,REPORT (comma)
#
# Subcommands:
#   audit                  Run optimized parallelized audit
#   observe                Schedule + path-monitor policy triggering
#   sys                    Test embedded core binaries (rg + goss)
#   remote <op> [HOST...]  Execute remote ops via gossh
#   version                Print build info
#
# Remote ops (under `intercept remote`):
#   run [HOST...]          Execute commands on target hosts
#   push [HOST...]         Copy local files + dirs to target hosts
#   fetch [HOST...]        Copy files from target hosts to local
#   script [HOST...]       Execute local shell script on hosts
#
# go-resty is used in cmd/api.go for HTTP dispatch to remote
# policy endpoints + result POST.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/xfhg/intercept/blob/master/cmd/root.go
# cobra PersistentFlags + AddCommand registrations.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _intercept_cmds _intercept_remote_cmds _intercept_outputs _intercept_logs
_intercept_cmds=(
    'audit:Run an optimized audit through all loaded policies'
    'observe:Observe and trigger realtime policies (schedule + path monitoring)'
    'sys:Test intercept embedded core binaries (rg + goss)'
    'remote:Execute remote operations using gossh'
    'version:Print the build info of intercept'
    'help:Show help for a subcommand'
)
_intercept_remote_cmds=(
    'run:Execute commands on target hosts'
    'push:Copy local files and dirs to target hosts'
    'fetch:Copy files from target hosts to local'
    'script:Execute a local shell script on target hosts'
)
_intercept_outputs=(
    'SARIF:SARIF output format'
    'LOG:LOG output format'
    'SARIF,LOG:both SARIF and LOG'
)
_intercept_logs=(
    'MINIMAL:minimal log'
    'RESULTS:results log'
    'POLICY:policy log'
    'REPORT:report log'
)

_arguments -C \
    '*'{-v,--verbose}'[increase verbosity level (count)]' \
    '(-o --output-dir)'{-o+,--output-dir=}'[directory to write output files]:directory:_files -/' \
    '--experimental[enable unreleased experimental features]' \
    '--debug[enable extra dev debug output]' \
    '--silent[enable log to file intercept.log]' \
    '--nolog[disable all logging]' \
    '--output-type=[output types (SARIF,LOG)]:type:->output_type' \
    '--log-type=[compliance log types (MINIMAL,RESULTS,POLICY,REPORT)]:type:->log_type' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    output_type)
        _describe -t outputs 'output type' _intercept_outputs && ret=0
        ;;
    log_type)
        _describe -t logs 'log type' _intercept_logs && ret=0
        ;;
    cmd)
        _describe -t commands 'intercept subcommand' _intercept_cmds && ret=0
        ;;
    args)
        case $words[1] in
            remote)
                if (( CURRENT == 2 )); then
                    _describe -t commands 'remote subcommand' _intercept_remote_cmds && ret=0
                else
                    _message 'host (hostname or IP)' && ret=0
                fi
                ;;
            help)
                _describe -t commands 'subcommand' _intercept_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
