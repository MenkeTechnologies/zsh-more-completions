#compdef gdcmanon
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmanon.cxx — DICOM PS 3.15 anonymizer (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-e --de-identify -d --re-identify)'{-e,--de-identify}'[de-identify DICOM (default, encrypt)]' \
    '(-e --de-identify -d --re-identify)'{-d,--re-identify}'[re-identify DICOM (decrypt)]' \
    '--dumb[dumb mode anonymizer]' \
    '(-i --input)'{-i+,--input=}'[input DICOM file or directory]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output DICOM file or directory]:file:_files' \
    '(-r --recursive)'{-r,--recursive}'[recursive]' \
    '--continue[do not stop on non-DICOM files]' \
    '--root-uid=[Root UID]:uid:_default' \
    '--resources-path=[resources path]:dir:_files -/' \
    '(-k --key)'{-k+,--key=}'[path to RSA private key]:file:_files' \
    '(-c --certificate)'{-c+,--certificate=}'[path to certificate]:file:_files' \
    '(-p --password)'{-p+,--password=}'[encryption passphrase]:passphrase:_default' \
    '--crypto=[crypto library]:lib:(openssl capi openssl-p7)' \
    '--des3[Triple-DES encryption]' \
    '--aes128[AES-128 encryption]' \
    '--aes192[AES-192 encryption]' \
    '--aes256[AES-256 encryption (default)]' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '*:DICOM file:_files -g "*.{dcm,DCM,dicom}"' \
    && ret=0

return ret
