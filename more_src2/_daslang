#         `-log-compile-time`, `--` arg-separator, and all
#         `--das-profiler-*` / `--track-*` variants
#
#   No completion for `daslang` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_daslang() {
    _arguments -s \
        '(- *)'{-version,--version}'[print daslang version and exit]' \
        '(- *)-h[show help]' \
        '-main+[set entry function name (default main)]:fn:' \
        '-jit[enable Just-In-Time compilation]' \
        '-jit-no-cache[with -jit: skip per-script DLL cache]' \
        '-exe[JIT compile to standalone executable (implies -dry-run)]' \
        '-output+[set JIT output path]:path:_files' \
        '-aot[AOT compile <in.das> <out.das.cpp>]:input:_files -g "*.das":output:_files' \
        '-aotlib[AOT library mode]:input:_files -g "*.das":output:_files' \
        '-use-aot[enable AOT linking (requires AOT stubs linked into the binary)]' \
        '-aot-macros[AOT compile macros too]' \
        '-run-fmt[run formatter]' \
        '-project+[path to project file]:project:_files -g "*.das_project"' \
        '-project_root+[root directory of the project]:dir:_files -/' \
        '-project-root+[root directory of the project]:dir:_files -/' \
        '*-load_module+[load a single dynamic-module folder (repeatable)]:dir:_files -/' \
        '*-load-module+[load a single dynamic-module folder (repeatable)]:dir:_files -/' \
        '-dasroot+[set path to daslang root folder (with daslib)]:dir:_files -/' \
        '-v2syntax[v2 syntax (braces, default)]' \
        '-v1syntax[v1 syntax (Python-style indentation)]' \
        '-v2makeSyntax[v1 syntax with v2 constructor syntax]' \
        '-log[output program code]' \
        '-log-compile-time[log per-module compile-time breakdown]' \
        '-pause[pause after errors and before exit]' \
        '-dry-run[compile + simulate without execution]' \
        '-compile-only[compile without simulate + execute]' \
        '-cross-platform[AOT cross-platform mode]' \
        '-no-dynamic-modules[skip loading dynamic modules]' \
        '-no-lint[skip the lint pass]' \
        '-q[quiet]' \
        '-p[pause after errors]' \
        '--linear-stack-allocator[disable scoped stack allocator]' \
        '--no-dump-leaks[silence leak dumps at exit (default dump)]' \
        '--das-wait-debugger[wait for debugger to attach]' \
        '--das-profiler[enable profiler]' \
        '--das-profiler-log-file+[set profiler log file]:file:_files' \
        '--das-profiler-manual[manual profiler control]' \
        '--das-profiler-memory[memory profiler]' \
        '--das-profiler-time-unit+[time unit for profiler output]:unit:(ns us ms s)' \
        '--das-profiler-thread-local[per-thread profiler agent]' \
        '--das-profiler-global[singleton profiler agent]' \
        '--das-profiler-leaks[track live heap allocations]' \
        '--track-smart-ptr+[track smart pointer with id]:id:' \
        '--track-job-status+[track JobStatus/Channel/LockBox with id]:id:' \
        '--list-shared-modules+[with -exe: write JSON of shared modules]:file:_files' \
        '*--force-shared-module+[with -exe: force-include shared module by name (repeatable)]:name:' \
        '*:daslang script (.das):_files -g "*.das"'
}

_daslang "$@"
