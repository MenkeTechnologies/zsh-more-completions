#compdef pyflakes
# Documentation: pyflakes --help (PyCQA pyflakes)
# Source: pyflakes — checks Python source files for errors (parse-not-import).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '*:Python file (or - for stdin):_files -g "*.py"' \
    && ret=0

return ret
