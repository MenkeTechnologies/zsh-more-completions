#
# THE git-proxy CLI
#
# git-proxy is a single-command server-launcher CLI
# built on yargs.  Invocation:
#   git-proxy [-v] [-c <path>]
#
# By default, git-proxy validates its configuration
# file + starts the HTTP proxy server + the React
# admin UI; the `-v / --validate` flag short-circuits
# to validation-only mode useful for CI config-checks.
#
# Flags:
#   -v, --validate                    check
#                                     proxy.config.json
#                                     for validation
#                                     errors without
#                                     starting server
#   -c, --config <path>               path to custom
#                                     git-proxy
#                                     configuration file
#                                     (default:
#                                     proxy.config.json
#                                     next to install)
#   -h, --help                        show yargs help
#       --version                     show version
#
# Companion binary:
#   git-proxy-all                     concurrent runner
#                                     that launches
#                                     the server + UI
#                                     dev server (uses
#                                     `concurrently
#                                     'npm run server'
#                                     'npm run client'`)
#
# Common invocations:
#   # Launch git-proxy with default config (proxy.config.json
#   # in install dir)
#   git-proxy
#
#   # Launch with a custom config file
#   git-proxy -c /etc/git-proxy/proxy.config.json
#   git-proxy --config /etc/git-proxy/proxy.config.json
#
#   # Validate the default config (CI lint check)
#   git-proxy -v
#   git-proxy --validate
#
#   # Validate a custom config file
#   git-proxy -v -c ./test-proxy.config.json
#   git-proxy --validate --config ./test-proxy.config.json
#
#   # systemd service launcher
#   ExecStart=/usr/bin/git-proxy -c /etc/git-proxy/proxy.config.json
#
#   # Docker container CMD
#   CMD ["git-proxy", "-c", "/config/proxy.config.json"]
#
#   # During development, launch BOTH server + UI together
#   git-proxy-all
#
# OPTIONS (sourced directly from
# https://github.com/finos/git-proxy/blob/main/index.ts):
#
#   -v, --validate                    validate-only mode
#   -c, --config <PATH>               config file path
#                                     (default
#                                     proxy.config.json
#                                     next to bin)
#
# Configuration file (proxy.config.json):
#   The full schema is documented in the repo + the
#   `validate()` helper from src/config/file.ts;
#   key top-level keys include `proxyUrl`, `cookieSecret`,
#   `sessionMaxAgeHours`, `tls`, `plugins`, `authorizedList`,
#   `domains`.  See repo for the full schema.
#
# Required environment variables (when not provided
# via config file):
#   JWT_SECRET                        signing secret
#                                     for admin JWTs
#   COOKIE_SECRET                     express-session
#                                     cookie secret
#   GIT_PROXY_USER_PASSWORD           initial admin
#                                     user password
#                                     (bcrypt-hashed
#                                     before storage)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-v --validate)'{-v,--validate}'[validate proxy.config.json without starting server]' \
    '(-c --config)'{-c,--config}'=[path to custom git-proxy configuration file]:config:_files -g "*.json"' \
    && ret=0

return ret
