#compdef gitlab-shell gitlab-shell-authorized-keys-check gitlab-shell-authorized-principals-check
# _gitlab-shell — GitLab Inc gitlab-shell SSH access entry point for the GitLab Git service (gitlab team, Go); custom argparse
# upstream: https://gitlab.com/gitlab-org/gitlab-shell

_gitlab-shell() {
    local -a sub=(
        'check:verify configuration'
        'discover:discover authenticated user'
        'lfs:lfs subcommands'
        'lfs-authenticate:authenticate for LFS'
        'two-factor-recover:2FA recovery codes'
        'two-factor-verify:2FA verify code'
        'personal-access-token:create personal access token'
        'authorized-keys-check:check authorized keys'
        'authorized-principals-check:check principals'
        'audit-events:audit events'
        'healthcheck:health check'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-config-dir+[config dir]:dir:_files -/' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '-log-format+[format]:f:(json text logfmt)' \
        '-log-level+[level]:l:(trace debug info warn error fatal panic)' \
        '-log-file+[log file]:file:_files' \
        '-namespace+[namespace]:str:' \
        '-config-file+[config file]:file:_files -g "config.yml *.yml"' \
        '-readonly[read-only mode]' \
        '-quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitlab-shell subcommand' sub ;;
        args)
            case $words[1] in
                lfs) _arguments '1:lfs cmd:(upload download verify)' ;;
                personal-access-token) _arguments \
                    '*:scopes csv:' ;;
            esac
            ;;
    esac
}

_gitlab-shell "$@"
