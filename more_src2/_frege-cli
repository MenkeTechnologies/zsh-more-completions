#compdef frege-cli frege2 fregec
# _frege-cli — Ingo Wechsung Frege Lang frege-cli CLI command-line frontend wrapping the Frege pure non-strict statically typed functional programming language inspired by Haskell that compiles to Java bytecode and runs on the Java Virtual Machine open-source written in Frege originally Ingo Wechsung now Frege Lang team Frege is a non-strict pure functional programming language a Haskell-like language for the Java Virtual Machine Frege-Java-Interop type classes higher-kinded types Maybe Either monads do notation type inference Haskell-syntax fregec Frege REPL FregIDE Frege-Compiler-Maven-plugin Gradle-plugin -d -fp -sp -j -nocp -hints -inline -nowarn -comments -prefix -gen -O -v -V (Ingo Wechsung Frege Lang team, Frege/Java); custom argparse
# upstream: https://github.com/Frege/frege

_frege-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[output dir]:dir:_files -/' \
        '-fp+[fpath]:str:' \
        '-sp+[source path]:dir:_files -/' \
        '*-sp+[source path]:dir:_files -/' \
        '-encoding=+[enc]:str:' \
        '-enc+[enc]:str:' \
        '-explain[explain]' \
        '-O+[optimization]:n:(0 1 2)' \
        '-inline[enable inlining]' \
        '-noinline[no inline]' \
        '-target=+[target]:str:' \
        '-j+[jvm args]:str:' \
        '*-j+[jvm args]:str:' \
        '-cp+[classpath]:str:' \
        '-classpath+[classpath]:str:' \
        '-nocp[no classpath]' \
        '-hints[hints]' \
        '-nowarn[no warnings]' \
        '-comments[comments]' \
        '-prefix+[prefix]:str:' \
        '-gen[gen documents]' \
        '-make[make if needed]' \
        '-fjp+[fpath]:str:' \
        '-stdlib+[dir]:dir:_files -/' \
        '-runpath+[paths]:str:' \
        '-libpath+[paths]:str:' \
        '-targets+[targets]:str:' \
        '-stats[print stats]' \
        '-strict[strict mode]' \
        '-print[print]' \
        '-source[source level]' \
        '-source+[level]:str:' \
        '-typeclass[typeclass]' \
        '-norun[no run]' \
        '-supr[supr]' \
        '-fast[fast]' \
        '-greek[greek]' \
        '-ascii[ASCII]' \
        '-special[special]' \
        '-warnings=+[w]:str:' \
        '-Wno-unused[no unused warn]' \
        '-Wno-error[no warn error]' \
        '-Werror[warn as error]' \
        '*:frege file:_files -g "*.fr *.frege *.class"'
}

_frege-cli "$@"
