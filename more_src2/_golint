#compdef golint
# Documentation: https://github.com/golang/lint
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for golint (Go linter)

_arguments -s -S \
  '-min_confidence[minimum confidence for issues]:confidence:' \
  '-set_exit_status[set exit status to 1 if issues found]' \
  '*:go file or package:_files -g "*.go"' && return 0
