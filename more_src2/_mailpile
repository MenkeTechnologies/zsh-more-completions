#compdef mailpile
# Documentation: https://github.com/mailpile/Mailpile
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. STUB — no formal CLI
# flag specification is published upstream; mailpile drives behaviour
# through an interactive shell, not flag-parsed argv.

# mailpile: free, secure, web-based mail client
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
