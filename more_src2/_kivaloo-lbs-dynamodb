#compdef kivaloo-lbs-dynamodb
# _kivaloo-lbs-dynamodb — LBS daemon backed by DynamoDB (Tarsnap/kivaloo)
# upstream: https://github.com/Tarsnap/kivaloo
# Flags from lbs-dynamodb/main.c (libcperciva GETOPT).

_kivaloo-lbs-dynamodb() {
    _arguments \
        '(- *)--version[print version]' \
        '-s+[LBS listen socket]:socket:' \
        '-t+[dynamodb-kv data socket]:socket:' \
        '-m+[dynamodb-kv metadata socket]:socket:' \
        '-1[run one request at a time]' \
        '-p+[pidfile]:file:_files'
}

_kivaloo-lbs-dynamodb "$@"
