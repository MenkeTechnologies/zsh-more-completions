#compdef rec2csv
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --delim)'{-d,--delim=}'[field delimiter]:delimiter character' \
  '(-S --strict)'{-S,--strict}'[strict mode]' \
  '(-t --type)'{-t,--type=}'[record type]:type name' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0
return ret
