#compdef dsctl
# Documentation: https://github.com/389ds/389-ds-base/blob/main/src/lib389/cli/dsctl
# Reference accessed: 2026-05-16
# Verified: upstream src/lib389/cli/dsctl.

# dsctl: 389-DS instance management CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'instance:instance management'
  'dbtasks:database tasks'
  'tls:TLS management'
  'health:health checks'
  'nsstate:NS state'
  'dbgen:database generation'
  'dsrc:dsrc file management'
  'cockpit:cockpit integration'
  'dblib:database library'
)
_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose tracing]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(-l --list)'{-l,--list}'[list available DS instances]' \
  '1:instance:' \
  '2: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'dsctl command' commands && ret=0 ;;
esac
return ret
