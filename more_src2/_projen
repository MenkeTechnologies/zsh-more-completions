#compdef projen
# Documentation: https://github.com/projen/projen/blob/main/src/cli/index.ts
# Reference accessed: 2026-05-20
# Verified: upstream projen src/cli/index.ts. When invoked without a
# subcommand the CLI runs synthesis. The only built-in subcommand is
# `new`; task commands are discovered dynamically from the project's
# Tasks runtime. Global yargs options: --post/--no-post, --watch/-w,
# --debug, --rc, --version.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--post[run post-synthesis steps such as installing dependencies]' \
  '--no-post[skip post-synthesis steps]' \
  '(-w --watch)'{-w,--watch}'[resynthesize when projenrc changes]' \
  '--debug[enable debug logging]' \
  '--rc=[path to .projenrc.js (deprecated)]:file:_files' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'new:Create a new projen project'
    )
    _describe -t commands 'projen command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      new)
        _arguments -s -S \
          '--from=[create project from external module]:module' \
          '--help[show help]' \
          '1:project type' && ret=0
        ;;
    esac
    ;;
esac

return ret
