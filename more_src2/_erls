#compdef erls
# _erls — erls CLI Erlang shell launcher utility for the Erlang OTP runtime providing version selection auto-detection of installed Erlang versions kerl-managed installations asdf-managed installations setting per-project ERLANG_VSN environment integration with rebar3-mix-task-runner for BEAM development workflows (erls authors team, shell); getopt
# upstream: https://github.com/erlang-ls/erls

_erls() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-l[list available versions]' \
        '--list[list available versions]' \
        '-i+[install version]:str:' \
        '--install=+[version]:str:' \
        '-r+[remove version]:str:' \
        '--remove=+[version]:str:' \
        '-d+[default version]:str:' \
        '--default=+[version]:str:' \
        '-u+[use version]:str:' \
        '--use=+[version]:str:' \
        '--prefix=+[dir]:dir:_files -/' \
        '--with=+[opts]:str:' \
        '*::'
}

_erls "$@"
