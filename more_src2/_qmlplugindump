#compdef qmlplugindump
# Documentation: https://github.com/qt/qtdeclarative/blob/dev/tools/qmlplugindump/main.cpp
# Reference accessed: 2026-05-20
# Verified: upstream source (tools/qmlplugindump/main.cpp) and local `qmlplugindump` usage line.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-v[verbose]' \
  '-qapp[use QApplication instead of QGuiApplication]' \
  '-noinstantiate[do not instantiate types during discovery]' \
  '-defaultplatform[require window manager]' \
  '(-relocatable -notrelocatable -nonrelocatable)-relocatable[emit relocatable plugin]' \
  '(-relocatable -notrelocatable -nonrelocatable)-notrelocatable[emit non-relocatable plugin]' \
  '(-relocatable -notrelocatable -nonrelocatable)-nonrelocatable[emit non-relocatable plugin]' \
  '-dependencies[dependencies JSON file]:file:_files -g "*.json"' \
  '-merge[merge with existing qmltypes file]:file:_files -g "*.qmltypes"' \
  '-output[output qmltypes file]:file:_files' \
  '-noforceqtquick[do not force QtQuick dependency]' \
  '-path[use directory mode]:qmldir directory:_files -/' \
  '-builtins[dump only builtin types]' \
  '1:module URI:' \
  '2:major.minor version:' \
  '3::import path:_files -/' && ret=0

return ret
