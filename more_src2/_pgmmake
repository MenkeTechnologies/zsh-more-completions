#compdef pgmmake
# Documentation: man pgmmake (Netpbm)
# Source: produce a PGM image of given dimensions filled with one gray level.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:gray level (0.0..1.0):' \
    '2:width:' \
    '3:height:' \
    && ret=0

return ret
