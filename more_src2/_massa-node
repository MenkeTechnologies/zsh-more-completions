#compdef massa-node
# _massa-node — Massa Labs massa-node Rust full node for the Massa multi-thread autonomous smart-contract blockchain implementing parallel block graph PoS consensus (massalabs team, Rust); clap
# upstream: https://github.com/massalabs/massa

_massa-node() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w+[wallet password]:str:' \
        '--wallet-password=+[wallet password]:str:' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-a+[node address]:str:' \
        '--node-address=+[node address]:str:' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-s+[bootstrap servers]:str:' \
        '--bootstrap-server=+[bootstrap servers]:str:' \
        '-i+[node id]:str:' \
        '--node-id=+[node id]:str:' \
        '-r+[restart-from-snapshot]:b:(true false)' \
        '--restart-from-snapshot[restart from snapshot]' \
        '-A+[api]:m:(public private)' \
        '--api=+[api]:m:(public private)' \
        '--keep-ledger[keep ledger]' \
        '--reset-ledger[reset ledger]' \
        '--disable-block-production[disable block production]' \
        '--disable-rolling-window[disable rolling window]'
}

_massa-node "$@"
