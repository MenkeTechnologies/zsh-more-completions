#compdef rfcomm
# _rfcomm — BlueZ rfcomm (legacy CLI to bind /dev/rfcommN char devices to remote BD_ADDR over the Bluetooth RFCOMM transport; subcommands bind, release, show, connect, listen, watch; -i hciX source, -A authentication, -E encryption, -S secure, -L set linger)
# upstream: https://github.com/bluez/bluez (tools/rfcomm.c)
# Flags from bluez tools/rfcomm.c on tip.

_rfcomm() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-i+[hciX source]:device:' \
        '-A[require authentication]' \
        '-E[require encryption]' \
        '-S[secure]' \
        '-M[master role]' \
        '-L+[linger seconds]:seconds:' \
        '-r[raw mode]' \
        '-a[show all devices]' \
        '-f+[config file]:file:_files' \
        '1:command:(bind release show connect listen watch)' \
        '*::arg:'
}

_rfcomm "$@"
