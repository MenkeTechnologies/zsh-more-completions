#compdef mole
# Documentation: https://github.com/davrodpin/mole
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Repository: https://github.com/davrodpin/mole

# Zsh completion for mole — CLI to create SSH tunnels.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:add an alias for a ssh tunneling configuration'
  'delete:delete an alias for a ssh tunneling configuration'
  'help:show help for a command'
  'misc:miscellaneous commands'
  'show:show configuration details about a tunnel alias'
  'start:start an ssh tunnel'
  'stop:stop an instance of mole'
  'version:show mole version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'mole command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '--verbose[verbose logging]' \
          '--insecure[skip SSH host key verification]' \
          '--detach[run in background]' \
          '--source=[local endpoint(s)]:source:' \
          '--destination=[remote endpoint(s)]:destination:' \
          '--server=[ssh server]:server:' \
          '--key=[ssh identity file]:file:_files' \
          '--keep-alive-interval=[ssh keep-alive interval]:duration:' \
          '--connection-retries=[connection retry count]:n:' \
          '--wait-and-retry=[wait between retries]:duration:' \
          '--ssh-agent-forwarding[forward ssh agent]' \
          '--config-file=[mole config file]:file:_files' \
          '*::alias:' && ret=0 ;;
      (add)
        _arguments \
          '--alias=[alias name]:name:' \
          '--source=[local endpoint(s)]:source:' \
          '--destination=[remote endpoint(s)]:destination:' \
          '--server=[ssh server]:server:' \
          '--key=[ssh identity file]:file:_files' \
          '--verbose[verbose logging]' \
          '*::arg:' && ret=0 ;;
      (delete|show)
        _arguments '*::alias:' && ret=0 ;;
      (stop)
        _arguments '*::alias:' && ret=0 ;;
    esac
    ;;
esac

return ret
