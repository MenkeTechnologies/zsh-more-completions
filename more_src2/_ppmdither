#compdef ppmdither
# Documentation: man ppmdither (Netpbm)
# Source: apply ordered (Bayer-matrix) dither to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dim=[matrix size as power of 2]:power:' \
    '-red=[number of red levels]:n:' \
    '-green=[number of green levels]:n:' \
    '-blue=[number of blue levels]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
