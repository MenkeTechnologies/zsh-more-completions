#compdef kubetest2-tester-node
# _kubetest2-tester-node — kubetest2 tester for Kubernetes node e2e tests (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from pkg/testers/node/node.go (gpflag).

_kubetest2-tester-node() {
    _arguments \
        '--repo-root=[absolute path to kubernetes or provider-aws-test-infra repo]:dir:_files -/' \
        '--gcp-project=[GCP project to create VMs in]:project:' \
        '--gcp-zone=[GCP zone to create VMs in]:zone:' \
        '--skip-regex=[regex of jobs to skip]:regex:' \
        '--focus-regex=[regex of jobs to focus on]:regex:' \
        '--test-args=[space-separated arguments for node e2e test]:args:' \
        '--label-filter=[ginkgo label filter]:expr:' \
        '--boskos-acquire-timeout-seconds=[Boskos acquire timeout]:s:' \
        '--boskos-heartbeat-interval-seconds=[Boskos heartbeat interval]:s:' \
        '--boskos-location=[Boskos server URL]:url:_urls' \
        '--image-config-file=[image configuration file]:file:_files' \
        '--images=[comma-separated list of images]:images:' \
        '--image-project=[GCP project containing image]:project:' \
        '--instance-type=[machine/instance type]:type:' \
        '--instance-metadata=[GCE instance metadata]:metadata:' \
        '--user-data-file=[EC2 user-data file]:file:_files' \
        '--provider=[cloud provider]:provider:(ec2 gce)' \
        '--use-dockerized-build[use dockerized build for test artifacts]' \
        '--target-build-arch=[target architecture for dockerized build]:arch:(amd64 arm64)' \
        '--image-config-dir=[directory containing image config files]:dir:_files -/'
}

_kubetest2-tester-node "$@"
