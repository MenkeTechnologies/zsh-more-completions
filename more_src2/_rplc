_rplc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '--color=[color override]:mode:(always never)' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _rplc_cmds=(
                'list:list PLCs'
                'test:test a PLC (run-once mode)'
                'info:print PLC info (registered tags, IO, OPC-UA endpoints)'
                'stat:print per-task statistics (cycle time, jitter)'
                'reset:reset per-task statistics'
                'register:register a rPLC binary as a systemd unit'
                'unregister:unregister PLC binary from systemd (stops if running)'
                'start:start PLC with systemd'
                'stop:stop PLC with systemd'
                'restart:restart PLC with systemd'
                'status:print PLC systemd status'
            )
            _describe -t commands 'rplc command' _rplc_cmds && ret=0
            ;;
        args)
            case $words[1] in
                test|info|stat|reset|unregister|start|stop|restart|status)
                    _arguments '1:PLC name:' && ret=0
                    ;;
                register)
                    _arguments \
                        '1:rPLC binary path:_files' \
                        '*-a[thread affinity NAME=CPU,PRIORITY (repeatable)]:affinity:' \
                        '(-e --eapi)'{-e,--eapi}'=[EVA ICS bus connection (path\[,timeout=Xs\]\[,buf_size=X\]\[,queue_size=X\]\[,buf_ttl=Xms\])]:conn:' \
                        '*--var=[custom environment variable NAME=VALUE]:envvar:' \
                        '--force[overwrite existing registration]' \
                        '(-s --start)'{-s,--start}'[start PLC after registration]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_rplc "$@"
