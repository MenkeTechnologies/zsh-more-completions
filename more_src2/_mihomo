#compdef mihomo
# Documentation: https://github.com/MetaCubeX/mihomo
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'convert-ruleset:convert a ruleset file'
  'generate:generate configurations'
)

_arguments -C \
  '-d=[working directory]:dir:_files -/' \
  '-f=[config file]:file:_files -g "*.(yaml|yml)"' \
  '-config=[base64 config string]:b64:' \
  '-ext-ui=[external UI directory]:dir:_files -/' \
  '-ext-ctl=[external controller address]:addr:' \
  '-ext-ctl-unix=[external controller unix socket]:path:_files' \
  '-ext-ctl-pipe=[external controller pipe]:name:' \
  '-secret=[RESTful API secret]:secret:' \
  '-post-up=[post-startup command]:cmd:' \
  '-post-down=[post-shutdown command]:cmd:' \
  '-m[geodata mode]' \
  '-v[show version]' \
  '-t[test config and exit]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mihomo subcommand' subcommands && ret=0
    ;;
esac

return ret
