#compdef grype-db
# Documentation: source-direct extraction from upstream
# anchore/grype-db cmd/grype-db/cli/cli.go `root.AddCommand(...)`
# chain + cmd/grype-db/cli/commands/{build,cache,cache_status,
# cache_delete,cache_backup,cache_restore,list_providers,package,
# pull,root,version}.go `Use:`/`Short:` fields. Sister tool to
# the heavily-covered grype/syft/cosign supply-chain family.
# Reference accessed: 2026-05-30 via gh api.
# Anchore grype-db R147a — backend tool that builds the Grype
# vulnerability database from upstream feeds (NVD/MSRC/OS
# vendor advisories) into the SQLite shape Grype consumes at
# scan-time. Typically run in CI rather than at scan-time.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '(-c --config)'{-c+,--config=}'[path to application config]:file:_files -g "*.(yaml|yml)"' \
  '--dry-run[parse config + CLI flags then exit]' \
  '(-q --quiet)'{-q,--quiet}'[suppress all logging output]' \
  '1:subcommand:((build\:build-SQLite-DB-from-feeds-for-schema-version cache\:manage-the-local-feed-cache list-providers\:list-supported-data-providers package\:tar-and-checksum-a-built-DB-for-distribution pull\:pull-and-process-all-upstream-vulnerability-data version\:print-version))' \
  '*::: :->subcmd' && ret=0

case "$state" in
  subcmd)
    case "${line[1]}" in
      cache)
        _arguments -C -s -S \
          '1:cache-subcommand:((backup\:backup-the-cache-to-an-archive delete\:delete-the-cache restore\:restore-the-cache-from-an-archive status\:show-cache-status))' \
          '*::: :_default' && ret=0
        ;;
      build|list-providers|package|pull|version)
        _arguments -s -S '*::: :_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
