#compdef ezmlm-get
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-get.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-b[copy admin info to bottom of replies (default)]' \
  '-B[suppress admin info]' \
  '-c[process commands (default)]' \
  '-C[ignore commands except digest]' \
  '-f+[default reply format]:format:(r m x v n)' \
  '-p[allow archive retrieval to all]' \
  '-P[restrict archive retrieval to moderators]' \
  '-s[only process requests from subscribers]' \
  '-S[allow anyone to request archive]' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' && ret=0

return ret
