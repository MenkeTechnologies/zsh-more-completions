#compdef pamtotga ppmtotga
# Documentation: man pamtotga (Netpbm)
# Source: convert a Netpbm PAM/PPM to Truevision Targa (TGA).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-mono -cmap -cmap16 -rgb)-mono[monochrome 8-bit TGA]' \
    '(-mono -cmap -cmap16 -rgb)-cmap[256-color colormapped TGA]' \
    '(-mono -cmap -cmap16 -rgb)-cmap16[16-color colormapped TGA]' \
    '(-mono -cmap -cmap16 -rgb)-rgb[true-color RGB TGA]' \
    '-norle[do not use run-length encoding]' \
    '-name=[image name (NAME field)]:name:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam/ppm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
