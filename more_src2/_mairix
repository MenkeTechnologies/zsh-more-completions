#compdef mairix
# Documentation: man mairix(1)
# Source: rc0/mairix mairix.c — index and search maildir/mbox/MH (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-f+,--rcfile=}'[alternative rc file]:rcfile:_files' \
    {-v,--verbose}'[verbose]' \
    {-p,--purge}'[purge messages that no longer exist]' \
    {-F,--fast-index}'[fast scan for maildir and MH folders]' \
    {-a,--augment}'[add new matches to match folder]' \
    {-x,--excerpt-output}'[display excerpt of message headers]' \
    {-t,--threads}'[include all messages in same threads]' \
    {-o+,--mfolder=}'[override mfolder from rc file]:mfolder:_default' \
    {-r,--raw-output}'[force raw output]' \
    {-H,--force-hardlinks}'[force hard links rather than symbolic]' \
    {-Q,--no-integrity-checks}'[skip integrity checks]' \
    '--unlock[remove stale lockfile]' \
    {-d,--dump}'[dump database contents]' \
    '--force-hash-key-new-database[force hash key for new database]' \
    '*:search-expr:_default' \
    && ret=0

return ret
