#compdef ionos ionos-cli
# _ionos — IONOS public cloud ionos legacy Compute Engine commandline shell predecessor to ionosctl (ionos team, Python); argparse
# upstream: https://github.com/ionos-cloud/sdk-python

_ionos() {
    local -a sub=(
        'login:login to IONOS'
        'logout:remove credentials'
        'datacenter:datacenter subcommands'
        'server:server subcommands'
        'volume:volume subcommands'
        'image:image subcommands'
        'snapshot:snapshot subcommands'
        'lan:LAN subcommands'
        'nic:NIC subcommands'
        'firewallrule:firewall rule subcommands'
        'loadbalancer:load balancer subcommands'
        'ipblock:ip block subcommands'
        'request:request subcommands'
        'user:user subcommands'
        'group:group subcommands'
        'share:share subcommands'
        'resource:resource subcommands'
        'k8s:Kubernetes subcommands'
        'backupunit:backup unit subcommands'
        'pcc:Cross Connect subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-u+[username]:user:_users' \
        '--username=+[username]:user:_users' \
        '-p+[password]:str:' \
        '--password=+[password]:str:' \
        '-t+[token]:str:' \
        '--token=+[token]:str:' \
        '--api-url=+[api url]:url:_urls' \
        '--region=+[region]:str:' \
        '--output=+[format]:f:(text json yaml)' \
        '-o+[format]:f:(text json yaml)' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ionos subcommand' sub ;;
        args)
            case $words[1] in
                datacenter|server|volume|image|snapshot|lan|nic|firewallrule|loadbalancer|ipblock|user|group|share|resource|backupunit|pcc) _arguments '1:cmd:(create list get update delete attach detach start stop reboot reset)' ;;
                k8s) _arguments '1:k8s cmd:(create list get update delete kubeconfig nodepool)' ;;
                request) _arguments '1:request cmd:(get list wait status)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_ionos "$@"
