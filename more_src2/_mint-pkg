#compdef mint
# _mint-pkg — Mint Swift Package Manager-based CLI installer; clones, builds, caches SPM-shipped tools
# upstream: https://github.com/yonaskolb/Mint

_mint-pkg() {
    local -a sub=(
        'bootstrap:install all in Mintfile'
        'install:install a package'
        'list:list installed packages'
        'outdated:show outdated installs'
        'uninstall:uninstall package'
        'update:update installed package'
        'upgrade:update mint itself'
        'run:run an installed CLI'
        'which:print path to installed CLI'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mint subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|update|run|which) _arguments \
                    '--executable+[executable name]:name:' \
                    '--no-link[skip linking]' \
                    '--force[reinstall]' \
                    '--mint-path+[mint dir]:dir:_files -/' \
                    '1:repo/version:' ;;
                bootstrap) _arguments \
                    '--link[link executables]' \
                    '--overwrite[overwrite existing]' \
                    '--mintfile+[Mintfile path]:file:_files' ;;
            esac
            ;;
    esac
}

_mint-pkg "$@"
