#compdef elasticsearch-node
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/node-tool.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elasticsearch-node: low-level node troubleshooting (repurpose / unsafe ops)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'repurpose:re-purpose this node'
  'unsafe-bootstrap:unsafe bootstrap a new cluster from this node'
  'detach-cluster:detach this node from its cluster'
  'remove-customs:remove cluster custom metadata'
  'remove-settings:remove cluster persistent settings'
  'remove-index-settings:remove index settings that prevent cluster formation'
  'override-version:override node version metadata'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-E[config setting key=value]:kv:' \
  '-d[data path]:dir:_files -/' \
  '--ordinal=[node ordinal]:n:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'elasticsearch-node command' commands && ret=0 ;;
esac
return ret
