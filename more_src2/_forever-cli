#compdef forever-cli
# _forever-cli — Charlie Robbins forever simple CLI to keep Node script running CLI alias (foreversd team, JavaScript); custom argparse
# upstream: https://github.com/foreversd/forever

_forever-cli() {
    local -a sub=(
        'start:start script'
        'stop:stop script'
        'stopall:stop all'
        'restart:restart script'
        'restartall:restart all'
        'list:list running'
        'columns:set columns shown'
        'columns add:add column'
        'columns rm:remove column'
        'columns set:set columns'
        'columns reset:reset columns'
        'config:show config'
        'set:set config option'
        'clear:clear config option'
        'logs:show logs'
        'cleanlogs:clean logs'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-p+[path]:dir:_files -/' \
        '--pidfile=+[pid file]:file:_files' \
        '-l+[log file]:file:_files' \
        '-o+[stdout file]:file:_files' \
        '-e+[stderr file]:file:_files' \
        '-a[append logs]' \
        '-f[run in foreground]' \
        '--fifo[run in fifo mode]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-w[watch for changes]' \
        '--watch[watch for changes]' \
        '--watchIgnore=+[pattern]:str:' \
        '--watchDirectory=+[dir]:dir:_files -/' \
        '-d+[crash delay ms]:n:' \
        '--minUptime=+[ms]:n:' \
        '--spinSleepTime=+[ms]:n:' \
        '-c+[command]:str:' \
        '--command=+[command]:str:' \
        '--workingDir=+[dir]:dir:_files -/' \
        '--sourceDir=+[dir]:dir:_files -/' \
        '--id=+[id]:str:' \
        '--uid=+[uid]:str:' \
        '-m+[max restarts]:n:' \
        '--colors[use colors]' \
        '--no-colors[no colors]' \
        '--plain[plain output]' \
        '--killSignal=+[signal]:s:(SIGTERM SIGKILL SIGINT)' \
        '--killTree[kill child processes]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'forever subcommand' sub ;;
        args)
            case $words[1] in
                start|stop|restart|logs) _arguments '*:script:_files' ;;
                set|clear) _arguments '1:key:' '*:value:' ;;
            esac
            ;;
    esac
}

_forever-cli "$@"
