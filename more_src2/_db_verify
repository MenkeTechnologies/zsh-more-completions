#compdef db_verify
# Documentation: db_verify usage (Berkeley DB 18.1.40)
# Source: verify integrity of Berkeley DB database files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-m[verify named in-memory subdatabases]' \
    '-N[silent: do not acquire DB env lock]' \
    '-o[salvage mode]' \
    '-q[quiet]' \
    '-b+[blob directory]:dir:_files -/' \
    '-h+[environment home]:dir:_files -/' \
    '-P+[password]:password:' \
    '*:db file:_files' \
    && ret=0

return ret
