#compdef nginx
# Documentation: https://nginx.org/en/docs/switches.html
# Source: nginx/nginx src/core/nginx.c — nginx HTTP server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-? -h)'{-\?,-h}'[show help]' \
    '-v[show version]' \
    '-V[show version + configure options]' \
    '-t[test configuration]' \
    '-T[test + dump configuration]' \
    '-q[suppress non-error messages during test]' \
    '-s+[send signal to master process]:signal:(stop quit reopen reload)' \
    '-p+[prefix path]:prefix:_files -/' \
    '-e+[error log file]:file:_files' \
    '-c+[configuration file]:file:_files' \
    '-g+[inline config directives]:directives:_default' \
    && ret=0

return ret
