#compdef filelife filelife-bpfcc
# _filelife — trace short-lived files (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/filelife.py (argparse).

_filelife() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-p --pid)'{-p+,--pid=}'[trace this PID only]:pid:'
    )
    _arguments $args
}

_filelife "$@"
