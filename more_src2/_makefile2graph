#compdef makefile2graph
# Documentation: https://github.com/lindenb/makefile2graph
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. makefile2graph is a thin
# shell wrapper that runs `make -nd "$@" | make2graph`; its arguments
# are forwarded to make rather than parsed by makefile2graph itself.

# makefile2graph: render Makefile dependency graph (wrapper for make + make2graph)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '*:make target:{ _message "make target name (passed to make)" }' && ret=0

return ret
