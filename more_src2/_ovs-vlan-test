#compdef ovs-vlan-test
# _ovs-vlan-test — Open vSwitch ovs-vlan-test test VLAN connectivity between two hosts for misconfiguration (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-vlan-test() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-s[run server]' \
        '--server[run server]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-p+[port]:port:_ports' \
        '--port=+[port]:port:_ports' \
        '*:client target IP:_hosts'
}

_ovs-vlan-test "$@"
