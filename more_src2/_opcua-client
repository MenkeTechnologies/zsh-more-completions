# ============================================================================
# _opcua-client — zsh completion for the tuiopcclient OPC-UA TUI client
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/jkrivoru/tuiopcclient
#   Crate      : opcua-client v0.1.0
#   Binary     : opcua-client  (Cargo.toml [package] name, no [[bin]] override)
#   License    : (unspecified)
#   Stars      : 21
#   Language   : Rust
#   Last push  : 2025-07-01
#
# WHAT IT IS
#   tuiopcclient is "OPC UA TUI Client with command line support" — a Rust
#   ratatui-based terminal UI client for the OPC Unified Architecture (OPC UA,
#   IEC 62541) industrial automation protocol.  Connect to an OPC UA server,
#   browse its address space, inspect node attributes, subscribe to value
#   changes, and exercise the full security model:  message security policies
#   (Basic128Rsa15 / Basic256 / Basic256Sha256 / Aes128Sha256RsaOaep /
#   Aes256Sha256RsaPss), message security modes (None / Sign / SignAndEncrypt),
#   X.509 client and user certificates, username/password auth, and trusted
#   certificate stores.  All connection state is configurable from the CLI;
#   missing values are filled in via the interactive TUI on connect.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap-derive Args struct)
#   opcua-client [OPTIONS]
#
#   Options (all long-form, single token value):
#     --server-url <URL>           OPC UA server URL
#                                  (e.g. opc.tcp://localhost:4840)
#     --security-policy <POLICY>   None | Basic128Rsa15 | Basic256
#                                  | Basic256Sha256 | Aes128Sha256RsaOaep
#                                  | Aes256Sha256RsaPss        [default: None]
#     --security-mode <MODE>       None | Sign | SignAndEncrypt [default: None]
#     --client-certificate <PATH>  client X.509 certificate (PEM/DER)
#     --client-private-key <PATH>  client private key (PEM/DER)
#     --auto-trust                 auto-trust server certificate
#     --trusted-store <PATH>       trusted certificate store directory
#                                  (required when --auto-trust is not set)
#     --user-name <USER>           username for authentication
#     --password <PASS>            password for authentication
#     --user-certificate <PATH>    user X.509 certificate (for X.509 auth)
#     --user-private-key <PATH>    user private key (for X.509 auth)
#     --use-original-url           ignore server-provided endpoint URLs
#     --log-level <LEVEL>          Error | Warn | Info | Debug | Trace
#                                                            [default: Info]
#     -h, --help                   print help
#     -V, --version                print version
#
# AXIS / CORPUS POSITION
#   Direct dependency on the canonical `opcua` crate (locka99/opcua), pinned
#   in Cargo.toml as:
#     opcua = { version = "0.12", features = ["client"] }
#   This is the Rust pole of the OPC-UA industrial-automation library family,
#   parallel to:
#     Go      = gopcua/opcua    (https://github.com/gopcua/opcua)
#     TS-Node = node-opcua/node-opcua  (https://github.com/node-opcua/node-opcua)
#   Verified via:
#     gh api repos/jkrivoru/tuiopcclient/contents/Cargo.toml + src/main.rs
#   This entry is the Rust=112 leader bump that OPENS Axis 57
#   (OPC-UA Industrial Automation Library), pairing with future Go=gopcua
#   and TS-Node=node-opcua poles to close the axis at 1/1/1.
#
#   No completion for `opcua-client` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_opcua-client() {
    _arguments -s \
        '--server-url=[OPC UA server URL (e.g. opc.tcp://localhost:4840)]:server URL:_opcua_server_urls' \
        '--security-policy=[message security policy]:policy:(None Basic128Rsa15 Basic256 Basic256Sha256 Aes128Sha256RsaOaep Aes256Sha256RsaPss)' \
        '--security-mode=[message security mode]:mode:(None Sign SignAndEncrypt)' \
        '--client-certificate=[path to client X.509 certificate]:cert file:_files -g "*.(pem|der|crt|cer)"' \
        '--client-private-key=[path to client private key]:key file:_files -g "*.(pem|der|key)"' \
        '--auto-trust[auto-trust server certificate]' \
        '--trusted-store=[path to trusted certificate store directory]:trust store:_files -/' \
        '--user-name=[username for authentication]:username:_users' \
        '--password=[password for authentication]:password:' \
        '--user-certificate=[path to user X.509 certificate]:cert file:_files -g "*.(pem|der|crt|cer)"' \
        '--user-private-key=[path to user private key]:key file:_files -g "*.(pem|der|key)"' \
        '--use-original-url[use original URL instead of server-provided endpoint URLs]' \
        '--log-level=[log level]:level:(Error Warn Info Debug Trace)' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

(( $+functions[_opcua_server_urls] )) ||
_opcua_server_urls() {
    if [[ -prefix opc.tcp:// || -prefix opc.https:// || -prefix opc.wss:// ]]; then
        _message 'OPC UA endpoint URL'
    else
        _alternative \
            'examples:OPC UA endpoint:(opc.tcp://localhost:4840 opc.tcp://localhost:48010 opc.tcp://localhost:4842)'
    fi
}

_opcua-client "$@"
