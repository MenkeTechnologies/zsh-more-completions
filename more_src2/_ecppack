#compdef ecppack
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/ecppack.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--version[show current version and exit]' \
  '--db=[Trellis database folder location]:dir:_directories' \
  '--input=[input textual configuration]:file:_files -g "*.config"' \
  '--bit=[output bitstream file]:file:_files -g "*.bit"' \
  '--svf=[output SVF file]:file:_files -g "*.svf"' \
  '--svf-rowsize=[SVF row size in bits (default 8000)]:rowsize:' \
  '--usercode=[USERCODE to set in bitstream]:code:' \
  '--idcode=[IDCODE to override in bitstream]:idcode:' \
  '--freq=[config frequency in MHz]:mhz:(2.4 4.8 9.7 19.4 38.8 62)' \
  '--compress[compress bitstream to reduce size]' \
  '--bootaddr=[set next BOOTADDR in bitstream and enable multi-boot]:addr:' \
  '--background[enable background reconfiguration in bitstream]' \
  '--delta=[create a delta partial bitstream given a reference config]:file:_files' \
  '--spimode=[SPI mode]:mode:(fast-read dual-spi qspi)' \
  '*:file:_files' && ret=0

return ret
