#compdef mopidy
# Documentation: https://github.com/mopidy/mopidy/blob/main/src/mopidy/_app/cli.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Mopidy global parameters per src/mopidy/_app/cli.py launcher().
_arguments -s \
  '*--config=[config file path; repeat or colon-separate]:path:_files' \
  '*'{-o+,--option=}'[override config SECTION/KEY=VALUE]:override' \
  '(-q --quiet)'{-q,--quiet}'[decrease amount of output to minimum]' \
  '*'{-v,--verbose}'[increase verbosity; repeat up to four times]' \
  ':subcommand:(config deps)'
