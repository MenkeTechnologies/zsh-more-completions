#compdef mdbook-alerts
# _mdbook-alerts — GFM Alerts preprocessor for mdBook (lambdalisue/rs-mdbook-alerts)
# upstream: https://github.com/lambdalisue/rs-mdbook-alerts
# Subcommand from src/main.rs (clap derive).

_mdbook-alerts() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1:command:(supports)' \
        '2:renderer:(html epub markdown latex)'
}

_mdbook-alerts "$@"
