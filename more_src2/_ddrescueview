#compdef ddrescueview
# Documentation: https://sourceforge.net/projects/ddrescueview/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:mapfile:_files -g "*.{map,log,ddrescue}"' && ret=0

return ret
