#compdef radicle-cli rad
# _radicle-cli — Radicle peer-to-peer code collaboration CLI alias (Radicle Foundation, Rust); clap-rs
# upstream: https://github.com/radicle-dev/heartwood

_radicle-cli() {
    local -a sub=(
        'auth:authenticate to local node'
        'block:block a peer'
        'browse:open repository in browser'
        'clone:clone a repository'
        'cob:run COB operations'
        'config:edit/view config'
        'diff:diff commits'
        'fork:fork a repository'
        'help:show help'
        'home:print radicle home'
        'id:identity commands'
        'init:initialize a repository'
        'inspect:inspect repository internals'
        'issue:issue commands'
        'job:run job'
        'ls:list local repositories'
        'merge:merge a patch'
        'node:node management'
        'patch:patch (PR) commands'
        'path:show paths'
        'remote:remote management'
        'review:review a patch'
        'rm:remove a repository'
        'self:current identity'
        'seed:seed/unseed repositories'
        'stats:show stats'
        'sync:sync with the network'
        'tag:tag commands'
        'thread:thread commands'
        'unseed:unseed repository'
        'version:show version'
        'watch:watch repository'
        'web:open web UI'
        'completion:generate shell completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rad subcommand' sub ;;
        args)
            case $words[1] in
                clone|fork|seed|unseed|rm|browse|web|watch) _arguments \
                    '*:rid:' ;;
                init) _arguments \
                    '--name=+[name]:str:' \
                    '--description=+[description]:str:' \
                    '--default-branch=+[branch]:str:' \
                    '--public[public]' \
                    '--private[private]' ;;
                issue|patch|tag) _arguments \
                    '1:cmd:(open list show edit comment close ready archive delete react)' \
                    '*:arg:' ;;
                node) _arguments \
                    '1:cmd:(start stop status connect disconnect logs config events sessions inventory routing announce)' \
                    '*:arg:' ;;
                self) _arguments \
                    '--did[show DID]' \
                    '--nid[show NID]' \
                    '--ssh-key[show SSH key]' \
                    '--profile[show profile]' \
                    '--alias[show alias]' ;;
                auth) _arguments \
                    '--stdin[read from stdin]' \
                    '--alias=+[alias]:str:' ;;
                inspect) _arguments \
                    '--refs[show refs]' \
                    '--id[show identity]' \
                    '--payload[show payload]' \
                    '--remotes[show remotes]' \
                    '*:rid:' ;;
                cob) _arguments \
                    '1:cmd:(show list update delete)' \
                    '*:arg:' ;;
                config) _arguments \
                    '1:cmd:(get set unset list reset)' \
                    '*:arg:' ;;
                sync) _arguments \
                    '--seed=+[seed]:str:' \
                    '--connect[connect to peers]' \
                    '--fetch[fetch only]' \
                    '--announce[announce only]' \
                    '--timeout=+[timeout]:dur:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_radicle-cli "$@"
