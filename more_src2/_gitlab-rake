#compdef gitlab-rake
# _gitlab-rake — GitLab Inc gitlab-rake wrapper that runs Rake tasks in the omnibus GitLab Rails environment (gitlab team, Ruby); rake CLI
# upstream: https://gitlab.com/gitlab-org/gitlab

_gitlab-rake() {
    local -a sub=(
        'gitlab:check:run installation checks'
        'gitlab:env:info:show environment info'
        'gitlab:backup:create:create a backup'
        'gitlab:backup:restore:restore from backup'
        'gitlab:cleanup:dirs:cleanup repository dirs'
        'gitlab:cleanup:repos:cleanup repos'
        'gitlab:cleanup:project_uploads:cleanup uploads'
        'gitlab:doctor:secrets:check secret integrity'
        'gitlab:doctor:reset_token:reset token'
        'gitlab:storage:list_legacy_projects:list legacy projects'
        'gitlab:storage:list_hashed_projects:list hashed projects'
        'gitlab:storage:migrate_to_hashed:migrate to hashed storage'
        'gitlab:assets:compile:compile assets'
        'gitlab:db:configure:configure database'
        'gitlab:db:create:create database'
        'gitlab:db:drop:drop database'
        'gitlab:db:migrate:run migrations'
        'gitlab:db:seed_fu:seed database'
        'gitlab:gitaly:install:install gitaly'
        'gitlab:setup:run setup'
        'gitlab:shell:setup:run shell setup'
        'gitlab:ldap:check:check LDAP'
        'gitlab:two_factor:disable:disable 2FA for all users'
        'gitlab:incoming_email:check:check incoming email'
        'gitlab:service_desk:check:check service desk'
        'cache:clear:clear cache'
        'tmp:clear:clear tmp dirs'
        'db:migrate:run rails migrations'
        'db:reset:reset database'
        'db:setup:setup database'
        'log:clear:clear log files'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-f+[Rakefile]:file:_files' \
        '--rakefile=+[Rakefile]:file:_files' \
        '-T[list tasks]' \
        '--tasks[list tasks]' \
        '-D[describe tasks]' \
        '--describe[describe tasks]' \
        '-A[show all tasks]' \
        '--all[show all tasks]' \
        '-W+[task name]:str:' \
        '--where=+[task name]:str:' \
        '-r+[require lib]:str:' \
        '--require=+[require lib]:str:' \
        '-I+[lib path]:dir:_files -/' \
        '--libdir=+[lib path]:dir:_files -/' \
        '-N[no search]' \
        '--no-search[no search]' \
        '-n[do nothing]' \
        '--dry-run[do nothing]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-t[trace]' \
        '--trace[trace]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitlab-rake subcommand' sub ;;
    esac
}

_gitlab-rake "$@"
