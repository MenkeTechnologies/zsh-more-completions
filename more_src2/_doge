#compdef doge
# Documentation: https://github.com/Olivia5k/doge
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# doge — a MOTD script that prints Shibe ASCII with random phrases.
# argparse-based; verified against src/doge/core.py and wow.py.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--shibe=[shibe ASCII file]:file:' \
  '--no-shibe[do not render the shibe]' \
  '--season=[seasonal override]:season:(valentine halloween thanksgiving xmas easter earth kabosu moon none)' \
  '(-f --frequency)'{-f,--frequency}'[frequency-based phrase mode]' \
  '--step=[step value]:step:' \
  '--min_length=[minimum word length]:n:' \
  '(-s --filter_stopwords)'{-s,--filter_stopwords}'[filter common stopwords]' \
  '(-mh --max-height)'{-mh,--max-height}'=[maximum height]:rows:' \
  '(-mw --max-width)'{-mw,--max-width}'=[maximum width]:cols:' \
  '(-d --density)'{-d,--density}'=[word density]:density:' \
  '*:words:' && ret=0

return ret
