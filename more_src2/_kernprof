#compdef kernprof
# _kernprof — Python profiling wrapper for line_profiler (pyutils/line_profiler)
# upstream: https://github.com/pyutils/line_profiler
# Flags from kernprof.py (argparse add_argument).

_kernprof() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--config=[config file]:file:_files' \
        '--no-config[ignore config files]' \
        '(-l --line-by-line)'{-l,--line-by-line}'[use line_profiler instead of cProfile]' \
        '(-b --builtin)'{-b,--builtin}'[install @profile as builtin]' \
        '(-s --setup)'{-s+,--setup=}'[setup script run once before profiling]:file:_files' \
        '(-p --prof-mod)'{-p+,--prof-mod=}'[modules/functions to profile]:list:' \
        '--preimports=[modules to import before profiling]:list:' \
        '--prof-imports[also profile imports]' \
        '(-o --outfile)'{-o+,--outfile=}'[output file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-q --quiet)'{-q,--quiet}'[quiet output]' \
        '(-r --rich)'{-r,--rich}'[rich text output]' \
        '(-u --unit)'{-u+,--unit=}'[time unit (s, ms, us, ns)]:unit:(s ms us ns)' \
        '(-z --skip-zero)'{-z,--skip-zero}'[skip zero-hit lines]' \
        '(-i --output-interval)'{-i+,--output-interval=}'[periodic dump interval (s)]:secs:' \
        '--summarize[print a per-function summary]' \
        '--view[view results immediately]' \
        '*:python script:_files -g "*.py"'
}

_kernprof "$@"
