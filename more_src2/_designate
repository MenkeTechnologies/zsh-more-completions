#compdef designate openstack-designate
# _designate — OpenStack Designate multi-tenant DNS-as-a-Service via openstack designate subcommand (openstack team, Python); cliff
# upstream: https://github.com/openstack/designate

_designate() {
    local -a sub=(
        'zone list:list zones'
        'zone create:create zone'
        'zone show:show zone'
        'zone delete:delete zone'
        'zone set:update zone'
        'zone export:export zone'
        'zone import:import zone'
        'zone transfer accept create:accept transfer'
        'zone transfer accept list:list accepts'
        'zone transfer request create:create transfer'
        'zone transfer request list:list transfers'
        'recordset list:list recordsets'
        'recordset create:create recordset'
        'recordset show:show recordset'
        'recordset delete:delete recordset'
        'recordset set:update recordset'
        'tld list:list tlds'
        'tld create:create tld'
        'tld delete:delete tld'
        'tsigkey list:list tsig keys'
        'tsigkey create:create tsig key'
        'tsigkey delete:delete tsig key'
        'blacklist list:list blacklists'
        'blacklist create:create blacklist'
        'blacklist delete:delete blacklist'
        'quota list:show quotas'
        'quota set:set quota'
        'quota reset:reset quota'
        'pool list:list pools'
        'pool show:show pool'
        'service list:list services'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--os-cloud=+[cloud]:str:' \
        '--os-region-name=+[region]:str:' \
        '--os-username=+[username]:user:_users' \
        '--os-password=+[password]:str:' \
        '--os-project-name=+[project]:str:' \
        '--os-auth-url=+[auth url]:url:_urls' \
        '--os-identity-api-version=+[version]:v:(3)' \
        '--os-token=+[token]:str:' \
        '--os-cacert=+[cacert]:file:_files' \
        '--insecure[skip tls verify]' \
        '--debug[debug]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--format=+[output format]:f:(table json yaml csv value)' \
        '*:subcommand:->sub'

    case $state in
        sub) _describe -t commands 'designate subcommand' sub ;;
    esac
}

_designate "$@"
