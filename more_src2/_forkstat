#compdef forkstat
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-d[sample delay in seconds]:seconds:' \
  '-D[run duration in seconds]:seconds:' \
  '-e[events to monitor]:events:_values -s , event fork exec exit core comm clone ptrce uid sid all' \
  '-l[long format output]' \
  '-q[quiet mode]' \
  '-r[use realtime priority]' \
  '-s[short format output]' \
  '-S[show statistics at end]' \
  '-x[show extra information]' \
  '-X[show process arguments]' \
  '-g[show gid]' \
  '-p[filter by PID]:pid:_pids' \
  '-u[filter by UID]:uid:_users' \
  '-h[show help]' \
  '-v[show version]' && ret=0
return ret
