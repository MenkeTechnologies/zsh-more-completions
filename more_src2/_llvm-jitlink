#compdef llvm-jitlink
# _llvm-jitlink — LLVM JIT linker (LLVM project, C++); JIT-link and execute object files using OrcV2
# upstream: https://github.com/llvm/llvm-project

_llvm-jitlink() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--entry=+[entry symbol]:sym:' \
        '-entry=+[entry symbol]:sym:' \
        '--harness=+[harness file]:file:_files' \
        '--noexec[skip execution]' \
        '--num-threads=+[threads]:n:' \
        '-j+[threads]:n:' \
        '--num-jit-dylibs=+[number jit dylibs]:n:' \
        '--jd=+[jit dylib]:str:' \
        '--abs=+[absolute symbol value]:str:' \
        '-abs=+[absolute symbol value]:str:' \
        '--lib=+[load shared library]:file:_files' \
        '-l+[load shared library]:file:_files' \
        '--debugger-support[debugger support]' \
        '--show-init-es[show initial es]' \
        '--show-relocated-section-contents[show relocated section contents]' \
        '--show-stats[show stats]' \
        '--alias=+[symbol alias]:str:' \
        '-A+[symbol alias]:str:' \
        '--check=+[checks file]:file:_files' \
        '-check=+[checks file]:file:_files' \
        '--check-name=+[check name]:str:' \
        '--load-jitcode=+[jitcode]:file:_files' \
        '--orc-runtime=+[ORC runtime]:str:' \
        '--shared-library=+[shared library]:file:_files' \
        '--no-process-syms[no process symbols]' \
        '--define-orc-runtime[define ORC runtime]' \
        '--no-define-orc-runtime[no define ORC runtime]' \
        '--triple=+[triple]:triple:' \
        '*:file:_files'
}

_llvm-jitlink "$@"
