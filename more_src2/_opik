#compdef opik
# Documentation: https://github.com/comet-ml/opik
# Reference accessed: 2026-05-22
# Verified: opik --help Click CLI.

# Zsh completion for opik - Comet Opik LLM observability CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-key[Opik API key]:key:' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'opik command' \
      'configure[create Opik SDK configuration]' \
      'connect[run or stop local bridge daemon]' \
      'endpoint[run or stop local endpoint process]' \
      'export[export workspace data]' \
      'import[import data to workspace]' \
      'migrate[migrate entities between projects]' \
      'proxy[start Opik server]' \
      'harbor[run Harbor benchmarks with Opik tracking]' \
      'healthcheck[application health check]' \
      'usage-report[extract usage data for workspaces]' && ret=0
    ;;
esac

return ret
