#compdef pffinfo pffexport pffmount
# _libpff — libpff tools (libyal Microsoft Personal Folder File parser used by Outlook .pst / .ost archives; pffinfo prints metadata, pffexport walks folders + items into a per-message directory tree, pffmount FUSE-mounts a .pst read-only with each folder as a directory; -h help, -V version, -v verbose, -p password, -m mode (debug|all|recovered), -t target dir, -X exclusive)
# upstream: https://github.com/libyal/libpff
# Flags from libyal/libpff pfftools/pffexport.c on tip.

_libpff() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-p+[password]:password:' \
        '-m+[mode]:mode:(items recovered all debug)' \
        '-t+[target dir]:dir:_files -/' \
        '-X[exclusive]' \
        '*:PST/OST file:_files -g "*.(pst|ost)"'
}

_libpff "$@"
