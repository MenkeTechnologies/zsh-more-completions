#compdef esl-selectn
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-selectn.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-selectn: select N random lines from input
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '--seed=[random seed (0 = random)]:n' \
  '*:N and input file:_files' && ret=0
return ret
