#compdef fc-list
# Documentation: fc-list --help (fontconfig)
# Source: fontconfig fc-list — list fonts matching [pattern].
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose -b --brief)'{-v,--verbose}'[display entire font pattern verbosely]' \
    '(-v --verbose -b --brief)'{-b,--brief}'[display entire font pattern briefly]' \
    '(-f --format)'{-f,--format=}'[output format string]:format:' \
    '(-q --quiet)'{-q,--quiet}'[no normal output; exit 1 if no fonts matched]' \
    '(- *)'{-V,--version}'[display fontconfig version and exit]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '*:pattern or element:' \
    && ret=0

return ret
