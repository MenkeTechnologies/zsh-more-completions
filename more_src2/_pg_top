#compdef pg_top
# Documentation: pg_top --help
# Source: top(1)-style PostgreSQL cluster monitor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-\?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-b --batch)'{-b,--batch}'[batch mode]' \
    '(-c --show-command)'{-c,--show-command}'[display command name]' \
    '(-C --color-mode)'{-C,--color-mode}'[turn off color mode]' \
    '(-i --interactive -n --non-interactive)'{-i,--interactive}'[interactive mode]' \
    '(-I --hide-idle)'{-I,--hide-idle}'[hide idle processes]' \
    '(-i --interactive -n --non-interactive)'{-n,--non-interactive}'[non-interactive mode]' \
    '(-o --order-field)'{-o+,--order-field=}'[sort order field]:field:' \
    '(-q --quick-mode)'{-q,--quick-mode}'[modify schedule priority (root)]' \
    '(-r --remote-mode)'{-r,--remote-mode}'[remote mode]' \
    '(-s --set-delay)'{-s+,--set-delay=}'[delay seconds between updates]:secs:' \
    '(-T --show-tags)'{-T,--show-tags}'[show color tags]' \
    '(-u --show-uid)'{-u,--show-uid}'[show UID instead of username]' \
    '(-x --set-display)'{-x+,--set-display=}'[max number of displays]:count:' \
    '(-z --show-username)'{-z+,--show-username=}'[show only processes of user]:user:_users' \
    '(-d --dbname)'{-d+,--dbname=}'[database to connect to]:db:' \
    '(-h --host)'{-h+,--host=}'[server host/socket dir]:host:_hosts' \
    '(-p --port)'{-p+,--port=}'[server port]:port:' \
    '(-U --username)'{-U+,--username=}'[connection user]:user:_users' \
    '(-W --password)'{-W,--password}'[force password prompt]' \
    '*:N:' \
    && ret=0

return ret
