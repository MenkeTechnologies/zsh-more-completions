#compdef ldcli
# Documentation: https://github.com/launchdarkly/ldcli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# LaunchDarkly feature-flag CLI (cobra)

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'setup:guided flag and SDK setup'
  'dev-server:start local dev server for flag values'
  'config:manage CLI settings'
  'completion:generate shell completions'
  'help:help about any command'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '--access-token=[LaunchDarkly API token]:token:' \
  '--analytics-opt-out[disable analytics tracking]' \
  '--base-uri=[custom LaunchDarkly endpoint]:uri:' \
  '--environment=[default environment key]:env:' \
  '--flag=[default feature flag key]:flag:' \
  '--output=[output format]:format:(json plaintext)' \
  '--project=[default project key]:project:' \
  '--data=[JSON data for resource operations]:json:' \
  '--json[force JSON output format]' \
  '1: :->cmd' \
  '*::arg:_default' && ret=0

case $state in
  (cmd) _describe -t commands 'ldcli command' commands && ret=0 ;;
esac

return ret
