#compdef daemonlogger
# Documentation: https://manpages.debian.org/trixie/daemonlogger/daemonlogger.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# daemonlogger: Sourcefire packet capture daemon

_arguments -s -S \
  '-h[show help summary]' \
  '-v[show program version]' \
  '-c+[capture N packets then exit]:count:' \
  '-d[enable daemon mode at startup]' \
  '-f+[BPF filter file]:file:_files' \
  '-F[flush packet buffer after each write]' \
  '-g+[process group ID]:group:_groups' \
  '-i+[capture interface]:interface:' \
  '-l+[pcap log file directory]:directory:_directories' \
  '-m+[generate this many log files]:count:' \
  '-M+[disk utilization percent for ringbuffer rollover]:percent:' \
  '-n+[output filename prefix]:prefix:' \
  '-o+[software tap output interface]:interface:' \
  '-p+[PID filename]:file:_files' \
  '-P+[PID file directory]:directory:_directories' \
  '-r[enable ringbuffer mode]' \
  '-R+[read from pcap file]:file:_files' \
  '-s+[log file rollover size in bytes]:bytes:' \
  '-S+[snaplen (bytes per packet)]:bytes:' \
  '-t+[time-based log rollover interval]:seconds:' \
  '-T+[chroot directory]:directory:_directories' \
  '-u+[process user when daemonized]:user:_users' \
  '-z[modify log file pruning behavior]'
