#compdef fluxion
# _fluxion — Wi-Fi WPA captive portal attack framework (FluxionNetwork/fluxion)
# upstream: https://github.com/FluxionNetwork/fluxion
# Flags from fluxion.sh getopt --longoptions list.

_fluxion() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[enable debug]' \
        '--debug-log=[debug log path]:file:_files' \
        '(-k --killer)'{-k,--killer}'[kill conflicting processes]' \
        '(-r --reloader)'{-r,--reloader}'[reload mode]' \
        '(-i --installer)'{-i,--installer}'[install missing deps]' \
        '(-n --airmon-ng)'{-n,--airmon-ng}'[use airmon-ng]' \
        '(-m --multiplexer)'{-m,--multiplexer}'[use tmux multiplexer]' \
        '(-t --target)'{-t,--target}'[target attack mode]' \
        '--test[test mode]' \
        '--auto[fully automated mode]' \
        '--bssid=[target BSSID]:bssid:' \
        '--essid=[target ESSID]:essid:' \
        '--channel=[target channel]:n:' \
        '--language=[UI language]:lang:' \
        '--attack=[attack type]:type:' \
        '--ratio[adjust window ratio]' \
        '--skip-dependencies[skip dep checks]' \
        '--scan-time=[scan duration (s)]:secs:' \
        '--scan-only[scan and exit]' \
        '--list-interfaces[list wireless interfaces]' \
        '--interface=[main interface]:iface:' \
        '--jammer-interface=[jammer interface]:iface:' \
        '--ap-interface=[AP interface]:iface:' \
        '--tracker-interface=[tracker interface]:iface:' \
        '--ap-service=[AP service backend]:svc:' \
        '--timeout=[session timeout (s)]:secs:' \
        '--reg-domain=[regulatory domain]:cc:' \
        '(-b --band)'{-b+,--band=}'[wireless band]:band:(2.4 5)'
}

_fluxion "$@"
