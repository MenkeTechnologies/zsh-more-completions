#compdef get-healpix
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/get-healpix.1 — convert between RA/Dec and HEALPix index (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r[print healpix range mode (multiple healpixes containing a point)]' \
    '-H+[healpix number for reverse mode]:n:_default' \
    '-N+[healpix Nside (default 1)]:n:_default' \
    '-n[print healpix neighbors]' \
    '-R+[search radius (arcmin)]:n:_default' \
    '-p[print healpix center as RA,Dec]' \
    '*:RA Dec:_default' \
    && ret=0

return ret
