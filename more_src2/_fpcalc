#compdef fpcalc
# Documentation: fpcalc usage (Chromaprint AcoustID)
# Source: AcoustID Chromaprint audio fingerprint generator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-version[show version]' \
    '-format+[input format name]:name:' \
    '-rate+[input sample rate]:rate:' \
    '-channels+[input channel count]:n:' \
    '-length+[process duration seconds (default 120)]:secs:' \
    '-chunk+[chunk duration seconds]:secs:' \
    '-algorithm+[algorithm number (default 2)]:n:(1 2 3 4 5)' \
    '-overlap[slightly overlap chunks]' \
    '-ts[output UNIX timestamps for chunked results]' \
    '(-raw -signed)-raw[uncompressed format output]' \
    '(-raw -signed)-signed[signed raw output (pg_acoustid)]' \
    '(-json -text -plain)-json[JSON output]' \
    '(-json -text -plain)-text[text output]' \
    '(-json -text -plain)-plain[only fingerprint in text]' \
    '*:audio file:_files -g "*.(mp3|flac|ogg|wav|m4a|aac|opus)"' \
    && ret=0

return ret
