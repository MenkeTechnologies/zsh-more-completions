#compdef quartus_sh
# _quartus_sh — Intel Altera Quartus quartus_sh CLI for the Tcl shell driving the Quartus Prime FPGA toolchain executing flow scripts launching synthesis fitting timing programmer compilation report generation (Intel team, C++); Tcl shell
# upstream: https://www.intel.com/content/www/us/en/products/details/fpga/development-tools/quartus-prime.html

_quartus_sh() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-t+[script]:file:_files -g "*.tcl"' \
        '--tcl=+[script]:file:_files -g "*.tcl"' \
        '-f+[command file]:file:_files' \
        '--command-file=+[command file]:file:_files' \
        '-s[interactive shell]' \
        '--shell[interactive shell]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[command]:str:' \
        '--cmd=+[command]:str:' \
        '--flow=+[flow]:f:(compile compile_all compile_modular_partition simple early_timing_estimate quick_compile incremental_compilation)' \
        '--prepare-archive[prepare archive]' \
        '--archive=+[file]:file:_files -g "*.qar"' \
        '--restore=+[file]:file:_files -g "*.qar"' \
        '--report-summary[report summary]' \
        '--list-extensions[list extensions]' \
        '--list-projects[list projects]' \
        '*:script args:'
}

_quartus_sh "$@"
