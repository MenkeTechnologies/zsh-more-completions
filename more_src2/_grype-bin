#compdef grype
# _grype-bin — Grype vulnerability scanner (Anchore, Go); scan container images and filesystems against NVD/GHSA/etc.
# upstream: https://github.com/anchore/grype

_grype-bin() {
    local -a sub=(
        'completion:print shell completion'
        'db:vulnerability database operations'
        'explain:print explanations for a vuln id'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '-o+[output format]:fmt:(table json cyclonedx cyclonedx-json sarif template)' \
        '--output+[output format]:fmt:' \
        '--add-cpes-if-none[add CPEs if missing]' \
        '--by-cve[match by CVE]' \
        '--distro+[distro]:str:' \
        '--exclude+[exclude path glob]:glob:' \
        '--fail-on+[severity threshold]:level:(negligible low medium high critical)' \
        '--file+[output file]:file:_files' \
        '-f+[fail-on severity]:level:(negligible low medium high critical)' \
        '--name+[image name]:name:' \
        '--only-fixed[only fixed]' \
        '--only-notfixed[only not-fixed]' \
        '--platform+[image platform]:platform:' \
        '-s+[search scope]:scope:(Squashed AllLayers)' \
        '--scope+[search scope]:scope:(Squashed AllLayers)' \
        '--show-suppressed[show suppressed]' \
        '-t+[output template]:file:_files' \
        '--template+[output template]:file:_files' \
        '--vex+[VEX file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grype subcommand' sub ;;
        args)
            case $words[1] in
                db) _arguments '1:db cmd:(check delete diff import list status update)' '*:args:' ;;
                explain) _arguments '*:CVE ID:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_grype-bin "$@"
