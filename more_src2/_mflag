#compdef mflag
# Documentation: https://manpages.debian.org/testing/mblaze/mflag.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian man page at the URL above.
# mflag (mblaze): manipulate Maildir message flags.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-D[mark messages as draft]' \
  '-F[mark messages as flagged]' \
  '-P[mark messages as passed (resent/forwarded/bounced)]' \
  '-R[mark messages as replied]' \
  '-S[mark messages as seen]' \
  '-T[mark messages as trashed]' \
  '-X+[mark messages with custom flag characters]:chars:' \
  '-d[unmark draft]' \
  '-f[unmark flagged]' \
  '-p[unmark passed]' \
  '-r[unmark replied]' \
  '-s[unmark seen]' \
  '-t[unmark trashed]' \
  '-x+[unmark custom flag characters]:chars:' \
  '-v[print transformed filenames preserving sequence]' \
  '*:message:_files' && ret=0

return ret
