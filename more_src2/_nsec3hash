#compdef nsec3hash
# Documentation: https://bind9.readthedocs.io/en/latest/manpages.html
# Source: isc-projects/bind9 bin/tools/nsec3hash.c — generate NSEC3 hash for a domain name.
# Reference accessed: 2026-06-10
#
# Forms:
#   nsec3hash {salt} {algorithm} {iterations} {domain}
#   nsec3hash -r {algorithm} {flags} {iterations} {salt} {domain}

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r[use rdata presentation order: algorithm flags iterations salt domain]' \
    '*:hash spec (salt algorithm iterations domain | algorithm flags iterations salt domain):_default' \
    && ret=0

return ret
