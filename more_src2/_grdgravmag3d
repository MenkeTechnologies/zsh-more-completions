#compdef grdgravmag3d
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/grdgravmag3d.html
# Source: GenericMappingTools/gmt supplements/potential — gravity / magnetic anomaly from a grid-defined body (Okabe).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C+[body density (SI; constant or grid)]:opts:_default' \
    '-E+[layer thickness (m, default 500)]:m:_default' \
    '-F+[xy locations for anomaly computation]:file:_files' \
    '-G+[output grid file]:file:_files' \
    '-H+[magnetic params (orientation/intensity/grid)]:opts:_default' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-L+[observation level/height (default 0)]:level:_default' \
    '-Q+[extend computation past output region]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[search radius (km)]:radius:_default' \
    '*-V[verbose (stackable)]' \
    '-Z+[reference plane (+ close top/bottom)]:opts:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-x+[CPU cores limit]:n:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
