#compdef linera
# Documentation: https://github.com/linera-io/linera-protocol/blob/main/CLI.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'transfer:Transfer funds'
      'open-chain:Open a new chain from an existing one'
      'open-multi-owner-chain:Open a new multi-owner chain'
      'show-ownership:Show chain ownership configuration'
      'change-ownership:Change chain ownership'
      'set-preferred-owner:Set the preferred owner of a chain'
      'change-application-permissions:Change application permissions for a chain'
      'close-chain:Close a chain'
      'show-network-description:Print network description'
      'local-balance:Read local native-token balance'
      'query-balance:Simulate next block and read balance'
      'sync-balance:Deprecated; sync chain and read balance'
      'sync:Synchronize local state with validators'
      'process-inbox:Process pending inbox messages for a chain'
      'query-shard-info:Query validators for shard information'
      'revoke-epochs:Deprecate committees up to an epoch'
      'resource-control-policy:View or update resource control policy'
      'benchmark:Run network benchmarks'
      'create-genesis-config:Create genesis configuration for a deployment'
      'watch:Watch the network for notifications'
      'service:Run GraphQL node service for the wallet'
      'query-application:GraphQL query against an application'
      'faucet:Run a GraphQL faucet server'
      'publish-module:Publish application Wasm modules'
      'list-events-from-index:Print events from a chain stream'
      'publish-data-blob:Publish a binary data blob'
      'read-data-blob:Verify a data blob is readable'
      'create-application:Create an application from a module'
      'publish-and-create:Publish module and create application'
      'keygen:Create an unassigned key pair'
      'assign:Link an owner to a chain'
      'retry-pending-block:Retry a failed pending block'
      'execute-operation:Execute a raw user operation'
      'wallet:Show wallet contents'
      'chain:Show information about a chain'
      'project:Manage Linera projects'
      'net:Manage a local Linera network'
      'validator:Manage validators in the committee'
      'storage:Storage operations'
      'completion:Generate shell completion scripts'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
