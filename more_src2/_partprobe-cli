#compdef partprobe-cli
# _partprobe-cli — GNU parted partprobe inform OS of partition changes CLI alias (parted team, C); custom argparse
# upstream: https://www.gnu.org/software/parted/

_partprobe-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-d[no act]' \
        '--no-update[no act]' \
        '-s[show layout]' \
        '--summary[show layout]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper}*"'
}

_partprobe-cli "$@"
