#compdef kcalc
# Documentation: https://github.com/KDE/kcalc/blob/master/kcalc.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. KCalc only calls
# KAboutData::setupCommandLine (kcoreaddons kaboutdata.cpp) — no
# app-specific options. STUB: standard KAboutData options only.
# Removed from prior file: fabricated --style/--stylesheet/--platform/
# --display/--platformpluginpath/--graphicssystem/--reverse/--help-qt/
# --help-kde and bogus man.archlinux.org search URL.

# KCalc: KDE scientific calculator (GUI-only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt-specific options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--desktopfile=[the base file name of the desktop entry]:file:_files' && ret=0
return ret
