#compdef gator
# Documentation: https://open-policy-agent.github.io/gatekeeper/website/docs/gator/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gator: Gatekeeper (Open Policy Agent) CLI for testing ConstraintTemplates and Constraints.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'test:test Kubernetes objects against Templates and Constraints'
      'verify:run gator test suite (Suites/Tests/Cases)'
      'expand:expand resources matching ExpansionTemplates'
      'policy:manage Gatekeeper policies (gatekeeper-library)'
      'bench:benchmark Gatekeeper policy evaluation'
      'sync:sync configuration tooling'
    )
    _describe -t commands 'gator command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      test)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --filename)'{-f+,--filename=}'[manifest file or directory]:file:_files' \
          '(-i --image)'{-i+,--image=}'[OCI artifact image]:image:' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(yaml json)' \
          '--tempdir=[temp directory for image extract]:dir:_files -/' \
          '--enforcement-action=[enforcement action filter]:action:' \
          '--deny-only[only output denied violations]' \
          '*: : _default' \
          && ret=0
        ;;
      verify|expand|policy|bench|sync)
        _arguments -s -S '*: : _default' && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
