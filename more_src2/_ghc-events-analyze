#compdef ghc-events-analyze
# _ghc-events-analyze — quantize & visualize a GHC eventlog (well-typed/ghc-events-analyze)
# upstream: https://github.com/well-typed/ghc-events-analyze
# Flags from src/GHC/RTS/Events/Analyze/Options.hs (optparse-applicative).

_ghc-events-analyze() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--help-script[detailed information about scripts]' \
        '--timed[generate timed report (SVG)]' \
        '--timed-txt[generate timed report (text)]' \
        '--totals[generate totals report]' \
        '--window=[event name marking visualization window bounds]:name:' \
        '(-b --buckets)'{-b+,--buckets=}'[number of quantization buckets]:n:' \
        '--start=[prefix for start of user events]:prefix:' \
        '--stop=[prefix for end of user events]:prefix:' \
        '--script-totals=[script path for totals report]:file:_files' \
        '--script-timed=[script path for timed report]:file:_files' \
        '--ms[render SVG timeline in milliseconds]' \
        '--tick-every=[render tick every N buckets]:n:' \
        '--bucket-width=[width of each bucket]:px:' \
        '--bucket-height=[height of each bucket]:px:' \
        '--border-width=[border width around each bucket]:px:' \
        '1:eventlog:_files -g "*.eventlog"'
}

_ghc-events-analyze "$@"
