#compdef omni
# _omni — XaF/omni (per-repo command launcher and dependency manager; builtin: clone/cd/help/status/up/down/scope/tidy/config/hook/reload/trigger; suggestions are auto-discovered from the omni.yaml in each git work tree)
# upstream: https://github.com/XaF/omni
# Subcommands from omni src/commands on tip.

_omni() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'omni command' \
                '(clone cd help status up down scope tidy config hook reload trigger sync source self-update doctor history watch cwd)'
            ;;
        args) _arguments '*:argument:' ;;
    esac
}

_omni "$@"
