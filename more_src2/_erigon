#compdef erigon
# Documentation: https://github.com/erigontech/erigon
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:bootstrap an empty data dir from genesis'
  'snapshots:snapshots utilities'
  'support:provide support diagnostics'
  'seg:operate on .seg files'
  'integration:internal db tools'
  'serve:serve gRPC node'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--datadir=[data directory]:dir:_files -/' \
  '--chain=[chain]:chain:(mainnet sepolia holesky hoodi gnosis chiado bor-mainnet amoy mumbai mordor classic)' \
  '--prune.mode=[prune mode]:mode:(archive full minimal)' \
  '--prune.distance=[blocks to keep history]:n:' \
  '--prune.distance.blocks=[blocks history distance]:n:' \
  '--syncmode=[sync mode]:mode:(snap full)' \
  '--snapshots[enable snapshots]' \
  '--torrent.port=[torrent port]:port:' \
  '--torrent.upload.rate=[upload rate]:rate:' \
  '--torrent.download.rate=[download rate]:rate:' \
  '--db.size.limit=[DB size limit]:size:' \
  '--http[enable HTTP-RPC]' \
  '--http.addr=[HTTP RPC addr]:addr:' \
  '--http.port=[HTTP RPC port]:port:' \
  '--http.api=[HTTP APIs csv]:apis:' \
  '--http.corsdomain=[CORS domains]:domains:' \
  '--http.vhosts=[allowed vhosts]:vhosts:' \
  '--ws[enable WS-RPC]' \
  '--ws.port=[WS port]:port:' \
  '--ws.compression[enable WS compression]' \
  '--graphql[enable GraphQL]' \
  '--rpc.gascap=[gas cap for eth_call]:gas:' \
  '--rpc.batch.concurrency=[batch concurrency]:n:' \
  '--rpc.batch.limit=[batch limit]:n:' \
  '--rpc.returndata.limit=[returndata limit]:n:' \
  '--rpc.evmtimeout=[EVM timeout]:dur:' \
  '--rpc.txfeecap=[max tx fee cap]:eth:' \
  '--rpc.allow-unprotected-txs[allow unprotected (legacy) tx]' \
  '--authrpc.addr=[auth RPC addr]:addr:' \
  '--authrpc.port=[auth RPC port]:port:' \
  '--authrpc.jwtsecret=[JWT secret file]:file:_files' \
  '--authrpc.vhosts=[auth vhosts]:vhosts:' \
  '--port=[P2P listen port]:port:' \
  '--p2p.allowed-ports=[allowed P2P ports]:ports:' \
  '--nat=[NAT spec]:nat:' \
  '--nodiscover[disable peer discovery]' \
  '--bootnodes=[bootnodes csv]:list:' \
  '--staticpeers=[static peers csv]:list:' \
  '--trustedpeers=[trusted peers csv]:list:' \
  '--maxpeers=[max peers]:n:' \
  '--mine[enable mining]' \
  '--miner.etherbase=[etherbase address]:addr:' \
  '--miner.gaslimit=[target gas limit]:n:' \
  '--miner.gasprice=[min gas price]:wei:' \
  '--miner.extradata=[block extra data]:data:' \
  '--metrics[enable metrics]' \
  '--metrics.addr=[metrics addr]:addr:' \
  '--metrics.port=[metrics port]:port:' \
  '--pprof[enable pprof]' \
  '--pprof.addr=[pprof addr]:addr:' \
  '--pprof.port=[pprof port]:port:' \
  '--log.console.verbosity=[console log level]:lvl:(crit error warn info debug trace)' \
  '--log.dir.path=[log directory]:dir:_files -/' \
  '--log.json[JSON logs]' \
  '--config=[config TOML]:file:_files' \
  '--externalcl[disable embedded consensus layer]' \
  '--internalcl[force internal consensus layer]' \
  '--caplin.discovery.addr=[Caplin discovery addr]:addr:' \
  '--caplin.discovery.port=[Caplin discovery port]:port:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'erigon command' commands && ret=0 ;;
esac

return ret
