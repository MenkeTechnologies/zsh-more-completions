#compdef pamwipeout
# Documentation: man pamwipeout (Netpbm)
# Source: fade a Netpbm image to white from left-to-right or top-to-bottom.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-lr -tb)-lr[left-to-right wipeout]' \
    '(-lr -tb)-tb[top-to-bottom wipeout]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
