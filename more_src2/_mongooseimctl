#compdef mongooseimctl
# _mongooseimctl — MongooseIM XMPP server controller (esl/MongooseIM)
# upstream: https://github.com/esl/MongooseIM
# Subcommands from rel/files/mongooseimctl (bash case $1 dispatch).

_mongooseimctl() {
    _arguments \
        '1:command:(
            bootstrap start stop force_stop
            join_cluster leave_cluster remove_from_cluster
            debug live foreground
            started stopped print_install_dir
            escript status reload_cluster_acl restart help
        )' \
        '*::args:'
}

_mongooseimctl "$@"
