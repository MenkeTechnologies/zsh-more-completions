#compdef create-elysia
# Documentation: https://github.com/bogeychan/create-elysia
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# create-elysia: scaffolding tool for ElysiaJS (Bun web framework).
# Note: there is no `elysia` binary - the framework is used as a library.
# Project scaffolding is done via `bun create elysia <name>` or `npx create-elysia <name>`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(-t --template)'{-t,--template}'[project template]:template:' \
  '1:project directory:_directories' && ret=0

return ret
