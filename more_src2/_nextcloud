#compdef nextcloud
# Documentation: https://github.com/nextcloud/desktop/blob/master/src/gui/application.cpp
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above (help text in application.cpp).

# Zsh completion for nextcloud - Nextcloud GUI desktop client

_arguments -s -S \
  '(- *)'{-h,--help}'[show this help screen]' \
  '(- *)'{-v,--version}'[show version information]' \
  '(-q --quit)'{-q,--quit}'[quit the running instance]' \
  '(-l --logwindow)'{-l,--logwindow}'[open a window to show log output]' \
  '--logfile=[write log output to file]:file:_files' \
  '--logdir=[write each sync log to a new file in folder]:dir:_files -/' \
  '--logexpire=[remove logs older than n hours (use with --logdir)]:hours:' \
  '--logflush[flush the log file after every write]' \
  '--logdebug[output debug-level messages in the log]' \
  '--confdir=[use the given configuration folder]:dir:_files -/' \
  '--background[launch the application in the background]' \
  '--overrideserverurl=[server URL force override in account setup wizard]:url:' \
  '--overridelocaldir=[local dir for the account setup wizard]:dir:_files -/' \
  '--userid=[userId to pass when creating account via command-line]:userid:' \
  '--apppassword=[appPassword to pass when creating account via command-line]:password:' \
  '--set-language=[language to use regardless of OS language]:lang:' \
  '--localdirpath=[local sync folder path for command-line account creation]:path:_files -/' \
  '--isvfsenabled=[VFS or non-VFS folder for command-line account creation]:enabled:(0 1)' \
  '--remotedirpath=[remote subfolder path for command-line account creation]:path:' \
  '--serverurl=[server URL for command-line account creation]:url:'
