#compdef db_deadlock
# Documentation: db_deadlock usage (Berkeley DB 18.1.40)
# Source: detect deadlocks in Berkeley DB environment.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-v[verbose]' \
    '-a+[deadlock-resolution policy]:policy:(e m n o W w y)' \
    '-h+[environment home]:dir:_files -/' \
    '-L+[log file]:file:_files' \
    '-P+[password]:password:' \
    '-t+[interval seconds.microseconds]:sec.usec:' \
    && ret=0

return ret
