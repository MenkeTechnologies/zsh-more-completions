#compdef portal
# Documentation: https://github.com/SpatiumPortae/portal
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands
    commands=(
      'send:send files through the portal'
      'receive:receive files from the portal'
      'serve:run a relay server'
      'config:manage portal configuration'
      'version:show version info'
    )
    _describe -t commands 'portal command' commands && ret=0
    ;;
  args)
    case $line[1] in
      send)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-r --relay)'{-r,--relay}'=[relay server address]:address:' \
          '(-s --tui-style)'{-s,--tui-style}'=[TUI style]:style:' \
          '*:files:_files' && ret=0
        ;;
      receive)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-r --relay)'{-r,--relay}'=[relay server address]:address:' \
          '(-y --yes)'{-y,--yes}'[overwrite existing files without prompts]' \
          '(-s --tui-style)'{-s,--tui-style}'=[TUI style]:style:' \
          '1:password:' && ret=0
        ;;
    esac
    ;;
esac

return ret
