#compdef dbus-cleanup-sockets
# Documentation: https://dbus.freedesktop.org/doc/dbus-cleanup-sockets.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)--version[show version]' \
  '(- *)--help[show help]' \
  '1::socket directory:_files -/' && ret=0

return ret
