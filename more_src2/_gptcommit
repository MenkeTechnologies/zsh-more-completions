#compdef gptcommit
# Documentation: https://github.com/zurawiki/gptcommit
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:install the git prepare-commit-msg hook in a repository'
  'uninstall:remove the git hook'
  'config:manage gptcommit settings and configuration values'
  'prepare-commit-msg:run the git prepare-commit-msg hook'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gptcommit subcommand' commands && ret=0 ;;
  (args)
    case $words[1] in
      (config)
        local -a subcmds
        subcmds=(
          'keys:list available configuration keys'
          'list:display current configuration values'
          'get:retrieve a specific setting'
          'set:assign a new configuration value'
          'delete:remove a configuration setting'
        )
        _describe -t subcmds 'config subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
