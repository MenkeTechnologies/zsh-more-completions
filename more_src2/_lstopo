#compdef lstopo lstopo-no-graphics
# Documentation: lstopo --help (Portable Hardware Locality)
# Source: visualize / dump hardware topology.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    {-l,--logical}'[hwloc logical indexes]' \
    {-p,--physical}'[OS/physical indexes]' \
    '--output-format=[force output format]:format:(console ascii tikz fig svg xml synthetic)' \
    '--of=[force output format]:format:(console ascii tikz fig svg xml synthetic)' \
    {-f,--force}'[overwrite existing output file]' \
    '--only=[only show given object type]:type:' \
    {-v,--verbose}'[additional details]' \
    {-q,--quiet,-s}'[reduce detail]' \
    '--distances[only distance matrices]' \
    '--distances-transform=[transform distances]:kind:(links merge-switch-ports transitive-closure)' \
    '--memattrs[only memory attributes]' \
    '--cpukinds[only CPU kinds]' \
    {-c,--cpuset}'[show cpuset of each object]' \
    {-C,--cpuset-only}'[only cpuset of each object]' \
    '--cpuset-output-format=[cpuset output format]:fmt:(hwloc list taskset)' \
    '--cof=[cpuset output format]:fmt:(hwloc list taskset)' \
    '--filter=[filter type:knd]:filter:' \
    '--ignore=[ignore objects of type]:type:' \
    '--no-smt[ignore PUs]' \
    '--no-caches[do not show caches]' \
    '--no-useless-caches[hide caches without hierarchy impact]' \
    '--no-icaches[do not show instruction caches]' \
    '--merge[hide levels without hierarchy impact]' \
    '--no-collapse[do not collapse identical PCI devices]' \
    '--restrict=[restrict topology bitmap]:bitmap:' \
    '--restrict-flags=[restrict flags]:n:' \
    '--no-io[do not show I/O devices/bridges]' \
    '--no-bridges[do not show I/O bridges except hostbridges]' \
    '--whole-io[show all I/O devices and bridges]' \
    {-i+,--input=}'[read topology from XML/synthetic]:input:_files' \
    '--input-format=[input format]:fmt:(xml fsroot synthetic cpuid)' \
    '--pid=[query process pid topology]:pid:_pids' \
    '--top[show top processes overlay]' \
    '--horiz[force horizontal layout]' \
    '--vert[force vertical layout]' \
    '--rect[force rectangular layout]' \
    '--no-legend[hide legend in graphical output]' \
    '--append-legend=[append legend line]:text:' \
    '--palette=[palette]:palette:(default colors greyscale white none)' \
    '--export-xml-flags=[XML export flags]:n:' \
    '--export-synthetic-flags=[synthetic export flags]:n:' \
    ':output file:_files' \
    && ret=0

return ret
