#compdef fastchess
# _fastchess — engine-vs-engine match runner for UCI chess engines (Disservin/fastchess)
# upstream: https://github.com/Disservin/fastchess
# Flags from app/src/cli/cli.cpp.

_fastchess() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '*-engine[engine definition]:opts:' \
        '-each[options applied to each engine]:opts:' \
        '-pgnout[PGN output spec]:spec:' \
        '-epdout[EPD output spec]:spec:' \
        '-openings[openings spec]:spec:' \
        '-sprt[SPRT test spec]:spec:' \
        '-draw[draw adjudication spec]:spec:' \
        '-resign[resign adjudication spec]:spec:' \
        '-maxmoves[max moves before draw]:n:' \
        '-tb[tablebases path]:path:_files -/' \
        '-tbpieces[max TB pieces]:n:' \
        '-tbignore50[ignore TB 50-move rule]' \
        '-tbadjudicate[TB adjudication threshold]:n:' \
        '-autosaveinterval[auto-save interval seconds]:s:' \
        '-log[engine log spec]:spec:' \
        '-config[config JSON file]:file:_files -g "*.json"' \
        '-report[report spec]:spec:' \
        '-output[output spec]:spec:' \
        '-concurrency[max concurrent games]:n:' \
        '-crc32[CRC32 spec]:spec:' \
        '-force-concurrency[ignore CPU thread cap]' \
        '-event[event name]:name:' \
        '-site[site name]:name:' \
        '-games[games per encounter]:n:' \
        '-rounds[round multiplier]:n:' \
        '-wait[wait between games (s)]:s:' \
        '-noswap[do not swap colors]' \
        '-reverse[reverse pair order]' \
        '-ratinginterval[rating report interval]:n:' \
        '-scoreinterval[score report interval]:n:' \
        '-srand[random seed]:n:' \
        '-seeds[number of seeds]:n:' \
        '-recover[recover from engine crashes]' \
        '-repeat[repeat each opening]' \
        '-variant[chess variant]:variant:(standard fischerandom)' \
        '-tournament[tournament type]:type:(roundrobin gauntlet)' \
        '-quick[quick match spec]:spec:' \
        '-use-affinity[use CPU affinity]' \
        '-check-mate-pvs[check mate PVs]' \
        '-show-latency[show measured latency]' \
        '-debug[debug mode]' \
        '-startup-ms[engine startup timeout ms]:ms:' \
        '-ucinewgame-ms[ucinewgame timeout ms]:ms:' \
        '-ping-ms[ping timeout ms]:ms:'
}

_fastchess "$@"
