#compdef ngtcp2-client ngtcp2-server
# Documentation: https://github.com/ngtcp2/ngtcp2/blob/main/examples/client.cc
# Documentation: https://github.com/ngtcp2/ngtcp2/blob/main/examples/server.cc
# Reference accessed: 2026-05-27
# Verified: upstream examples/client.cc and examples/server.cc getopt_long tables (ngtcp2/ngtcp2)

local curcontext="$curcontext" state line ret=1

_ngtcp2_client() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '(-d --data)'{-d+,--data=}'[stream data file]:file:_files' \
    '(-m --http-method)'{-m+,--http-method=}'[HTTP request method]:method:(GET POST PUT DELETE HEAD OPTIONS PATCH)' \
    '(-n --nstreams)'{-n+,--nstreams=}'[number of requests]:count:' \
    '(-q --quiet)'{-q,--quiet}'[suppress debug output]' \
    '(-r --rx-loss)'{-r+,--rx-loss=}'[incoming packet loss probability]:probability:' \
    '(-s --show-secret)'{-s,--show-secret}'[print TLS secrets]' \
    '(-t --tx-loss)'{-t+,--tx-loss=}'[outgoing packet loss probability]:probability:' \
    '(-v --version)'{-v+,--version=}'[QUIC version (hex)]:version:' \
    '--ciphers=[TLS cipher suite list]:ciphers:' \
    '--groups=[TLS supported groups]:groups:' \
    '--timeout=[idle timeout]:duration:' \
    '--session-file=[TLS session storage file]:file:_files' \
    '--tp-file=[transport parameters storage file]:file:_files' \
    '--dcid=[destination connection ID]:dcid:' \
    '--scid=[source connection ID]:scid:' \
    '--change-local-addr=[delay before local address change]:duration:' \
    '--nat-rebinding[simulate NAT rebinding]' \
    '--key-update=[delay before triggering key update]:duration:' \
    '--delay-stream=[delay before sending stream data]:duration:' \
    '--no-preferred-addr[ignore server preferred addresses]' \
    '--key=[client private key file]:file:_files' \
    '--cert=[client certificate file]:file:_files' \
    '--download=[directory to save downloaded content]:directory:_files -/' \
    '--no-quic-dump[disable QUIC frame logging]' \
    '--no-http-dump[disable HTTP body logging]' \
    '--qlog-file=[qlog output file]:file:_files' \
    '--qlog-dir=[qlog output directory]:directory:_files -/' \
    '--max-data=[connection flow control window]:size:' \
    '--max-stream-data-bidi-local=[local bidi stream window]:size:' \
    '--max-stream-data-bidi-remote=[remote bidi stream window]:size:' \
    '--max-stream-data-uni=[unidirectional stream window]:size:' \
    '--max-streams-bidi=[concurrent bidi streams]:count:' \
    '--max-streams-uni=[concurrent uni streams]:count:' \
    '--exit-on-first-stream-close[exit after first stream closes]' \
    '--exit-on-all-streams-close[exit after all streams close]' \
    '--disable-early-data[disable 0-RTT]' \
    '--cc=[congestion controller]:algorithm:(cubic reno bbr)' \
    '--token-file=[token storage file]:file:_files' \
    '--sni=[TLS SNI override]:hostname:' \
    '--initial-rtt=[initial RTT estimate]:duration:' \
    '--max-window=[maximum connection window]:size:' \
    '--max-stream-window=[maximum stream window]:size:' \
    '--max-udp-payload-size=[UDP payload limit]:size:' \
    '--handshake-timeout=[handshake timeout]:duration:' \
    '--available-versions=[advertised QUIC versions (hex)]:versions:' \
    '--no-pmtud[disable path MTU discovery]' \
    '--preferred-versions=[preferred QUIC versions (hex)]:versions:' \
    '--ack-thresh=[ACK threshold]:count:' \
    '--wait-for-ticket[wait for TLS session ticket]' \
    '--initial-pkt-num=[initial packet number]:number:' \
    '--pmtud-probes=[PMTU probe sizes]:sizes:' \
    '--ech-config-list-file=[ECH config list file]:file:_files' \
    '--no-gso[disable GSO]' \
    '--show-stat[display connection statistics]' \
    '--gso-burst=[maximum GSO packet aggregation]:count:' \
    '1:host:_hosts' \
    '2:port:' \
    '*:url:_urls' && ret=0
}

_ngtcp2_server() {
  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '(-t --tx-loss)'{-t+,--tx-loss=}'[outgoing packet loss probability]:probability:' \
    '(-r --rx-loss)'{-r+,--rx-loss=}'[incoming packet loss probability]:probability:' \
    '(-d --htdocs)'{-d+,--htdocs=}'[document root directory]:directory:_files -/' \
    '(-q --quiet)'{-q,--quiet}'[suppress debug output]' \
    '(-s --show-secret)'{-s,--show-secret}'[print TLS secrets]' \
    '(-V --validate-addr)'{-V,--validate-addr}'[validate client address]' \
    '--ciphers=[TLS cipher suite list]:ciphers:' \
    '--groups=[TLS supported groups]:groups:' \
    '--timeout=[idle timeout]:duration:' \
    '--preferred-ipv4-addr=[preferred IPv4 address]:addr\:port:' \
    '--preferred-ipv6-addr=[preferred IPv6 address]:addr\:port:' \
    '--mime-types-file=[MIME types file]:file:_files' \
    '--early-response[send response in 0-RTT]' \
    '--verify-client[request client certificate]' \
    '--qlog-dir=[qlog output directory]:directory:_files -/' \
    '--no-quic-dump[disable QUIC frame logging]' \
    '--no-http-dump[disable HTTP body logging]' \
    '--max-data=[connection flow control window]:size:' \
    '--max-stream-data-bidi-local=[local bidi stream window]:size:' \
    '--max-stream-data-bidi-remote=[remote bidi stream window]:size:' \
    '--max-stream-data-uni=[unidirectional stream window]:size:' \
    '--max-streams-bidi=[concurrent bidi streams]:count:' \
    '--max-streams-uni=[concurrent uni streams]:count:' \
    '--max-dyn-length=[max dynamic content length]:size:' \
    '--cc=[congestion controller]:algorithm:(cubic reno bbr)' \
    '--initial-rtt=[initial RTT estimate]:duration:' \
    '--max-udp-payload-size=[UDP payload limit]:size:' \
    '--send-trailers[send HTTP/3 trailers]' \
    '--max-window=[maximum connection window]:size:' \
    '--max-stream-window=[maximum stream window]:size:' \
    '--handshake-timeout=[handshake timeout]:duration:' \
    '--preferred-versions=[preferred QUIC versions (hex)]:versions:' \
    '--available-versions=[advertised QUIC versions (hex)]:versions:' \
    '--no-pmtud[disable path MTU discovery]' \
    '--ack-thresh=[ACK threshold]:count:' \
    '--initial-pkt-num=[initial packet number]:number:' \
    '--pmtud-probes=[PMTU probe sizes]:sizes:' \
    '--ech-config-file=[ECH config file]:file:_files' \
    '--origin=[advertised origin]:origin:' \
    '--no-gso[disable GSO]' \
    '--show-stat[display connection statistics]' \
    '--gso-burst=[maximum GSO packet aggregation]:count:' \
    '1:address:' \
    '2:port:' \
    '3:private-key:_files' \
    '4:certificate:_files' && ret=0
}

case $service in
  ngtcp2-client)
    _ngtcp2_client
    ;;
  ngtcp2-server)
    _ngtcp2_server
    ;;
esac

return ret
