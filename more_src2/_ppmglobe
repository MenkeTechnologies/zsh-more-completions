#compdef ppmglobe
# Documentation: man ppmglobe (Netpbm)
# Source: cut a PPM image into globe strips for assembly into a model globe.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-background=[background color]:color:' \
    '-closeok[allow closing seam without warning]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:strip count:' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
