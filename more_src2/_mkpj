#compdef mkpj
# _mkpj — create a ProwJob from a Prow config for ad-hoc execution (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/mkpj/main.go (flag).

_mkpj() {
    _arguments \
        '-job=[job to run]:job:' \
        '-base-ref=[git base ref under test]:ref:' \
        '-base-sha=[git base SHA under test]:sha:' \
        '-pull-number=[git pull number under test]:n:' \
        '-pull-sha=[git pull SHA under test]:sha:' \
        '-pull-author=[git pull author under test]:user:' \
        '-pull-head-ref=[git branch name of proposed change]:ref:' \
        '-trigger-job[submit job to Prow and wait for results]' \
        '-fail-with-job[exit with non-zero code if job fails]' \
        '-config-path=[config file]:file:_files' \
        '-job-config-path=[job config file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files'
}

_mkpj "$@"
