#compdef ndm-exporter exporter
# _ndm-exporter — OpenEBS Node Disk Manager Prometheus exporter (exposes BlockDevice metrics)
# upstream: https://github.com/openebs/node-disk-manager
# Subcommand + flags from cmd/ndm-exporter/cmd/{root,start}.go on tip (cobra).

_ndm-exporter() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '-v[klog verbosity level]:n:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                start:'start the exporter'
            )
            _describe -t commands 'ndm-exporter subcommand' subs
            ;;
        args)
            case $line[1] in
                start)
                    _arguments \
                        '--mode=[exporter mode]:mode:(cluster node)' \
                        '--port=[port to listen on]:port:' \
                        '--metrics=[HTTP path for Prometheus metrics]:path:'
                    ;;
            esac
            ;;
    esac
}

_ndm-exporter "$@"
