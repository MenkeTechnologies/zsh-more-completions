# rocm-bandwidth-test: AMD ROCm bandwidth benchmark
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--builtin-help[show built-in help]' \
  '--pcie-info[show PCIe info]' \
  '(-c --legacy)'{-c,--legacy}'[legacy mode]' \
  '(-l --list)'{-l,--list}'[list plugins]' \
  '(-i --info)'{-i,--info}'[get plugin info]' \
  '(-r --run)'{-r,--run}'[run a plugin]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:plugin:' && ret=0
return ret
