#compdef graphqlmap

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-u --url)'{-u,--url}'[GraphQL endpoint URL]:url:' \
  '--method[HTTP method to use]:method:(GET POST)' \
  '--headers[Custom HTTP headers]:headers:' \
  '-json[Use JSON content type]' \
  '--proxy[Proxy URL]:proxy:' \
  '--verify[Verify SSL certificates]' \
  '--introspection[Run introspection query]' \
  '--field-fuzzing[Enable field fuzzing]' \
  '--no-cache[Disable caching]' \
  '--dos[Test for denial of service via deep nesting]' \
  '(- *)--help[Show help message]' \
  && ret=0

return ret
