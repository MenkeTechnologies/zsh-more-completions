#compdef fixit
# Documentation: https://fixit.readthedocs.io/en/latest/guide.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Instagram/Meta Fixit: Python linting framework with auto-fixes built on LibCST.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(--quiet)--debug[verbose logging]' \
  '(--debug)--quiet[reduce logging]' \
  '--config-file=[override configuration file]:file:_files' \
  '--tags=[filter lint rules by tags]:tags:' \
  '(-o --output-format)'{-o+,--output-format=}'[terminal output style]:format:' \
  '--output-template=[custom formatting template]:template:' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'lint:lint paths and print errors (optionally show diff)'
      'fix:apply suggested fixes interactively or automatically'
      'test:validate lint rules using test cases'
      'lsp:launch a language server for IDE integration'
      'upgrade:apply fixes from deprecation rules'
      'debug:validate Fixit configuration'
    )
    _describe -t commands 'fixit command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (lint)
        _arguments -s -S \
          '(-d --diff)'{-d,--diff}'[show suggested fixes as unified diff]' \
          '*:path:_files' && ret=0
        ;;
      (fix)
        _arguments -s -S \
          '(-i --interactive -a --automatic)'{-i,--interactive}'[prompt for each fix (default)]' \
          '(-a --automatic -i --interactive)'{-a,--automatic}'[apply all fixes without prompting]' \
          '(-d --diff)'{-d,--diff}'[show applied changes as unified diff]' \
          '*:path:_files' && ret=0
        ;;
      (test)
        _arguments -s -S \
          '*:rule:' && ret=0
        ;;
      (lsp)
        _arguments -s -S \
          '(--tcp --ws)--stdio[use stdio transport]' \
          '(--stdio --ws)--tcp=[use TCP transport on port]:port:' \
          '(--stdio --tcp)--ws=[use websocket transport on port]:port:' \
          '--debounce-interval=[server-side debounce delay in seconds]:seconds:' && ret=0
        ;;
    esac
    ;;
esac

return ret
