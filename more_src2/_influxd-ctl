#compdef influxd-ctl
# Documentation: https://docs.influxdata.com/enterprise_influxdb/v1/tools/influxd-ctl/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# influxd-ctl: control plane CLI for InfluxDB Enterprise
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '-config=[config file]:file:_files' \
  '-pidfile=[pid file]:file:_files' \
  '-cpuprofile=[CPU profile]:file:_files' \
  '-memprofile=[memory profile]:file:_files' \
  '-hostname=[hostname]:host:_hosts' \
  '-bind=[bind addr]:addr:' \
  '-auth-type=[auth type]:type:(none basic jwt)' \
  '-user=[user]:user:_users' \
  '-password=[password]:pass:' \
  '*::influxd-ctl args:_files' && ret=0
return ret
