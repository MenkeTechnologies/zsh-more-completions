#compdef generate_signing_key
# _generate_signing_key — generate a Synapse signing key (element-hq/synapse)
# upstream: https://github.com/element-hq/synapse
# Flags from synapse/_scripts/generate_signing_key.py (argparse).

_generate_signing_key() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-o --output_file)'{-o+,--output_file=}'[signing key output file (- for stdout)]:file:_files'
}

_generate_signing_key "$@"
