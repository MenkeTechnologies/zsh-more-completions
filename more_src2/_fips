#compdef fips
# _fips — high-level build system for distributed C/C++ projects (floooh/fips)
# upstream: https://github.com/floooh/fips
# Subcommands from verbs/*.py.

_fips() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)help[show help]' \
        '1: :_fips_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build|make|run|gen|clean|open)
                    _arguments '1:fips config:' '*:target:' && ret=0 ;;
                set|unset)
                    _arguments '1: :(config target)' '2:value:' && ret=0 ;;
                config)
                    _arguments '1: :(list set unset)' '*:config arg:' && ret=0 ;;
                cache)
                    _arguments '1: :(list info clear)' && ret=0 ;;
                diag)
                    _arguments '1: :(all tools fips imports)' && ret=0 ;;
                init|fetch|clone|update)
                    _arguments '1:project / url:' && ret=0 ;;
                list)
                    _arguments '1: :(targets configs registry build-tools deps imports settings)' && ret=0 ;;
                clion|vscode)
                    _arguments '*:project args:' && ret=0 ;;
                setup|emsdk|wasisdk)
                    _arguments '1: :(install update list activate uninstall)' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_fips_commands] )) ||
_fips_commands() {
    local -a commands
    commands=(
        'build:build the active fips configuration'
        'make:build a specific target'
        'run:build and run a target'
        'gen:re-run CMake on the active configuration'
        'clean:remove build outputs'
        'open:open the build directory in the system browser'
        'set:set a config / target option'
        'unset:unset a config / target option'
        'config:manage saved fips configurations'
        'cache:inspect / clear the fips build cache'
        'diag:diagnose fips / tooling / project state'
        'init:initialize a new fips project in the current directory'
        'fetch:fetch dependencies declared in fips.yml'
        'clone:clone a project from the fips registry'
        'update:update the active dependency tree'
        'list:list configurations / targets / registry / settings'
        'clion:generate and open a CLion project'
        'vscode:generate and open a VS Code workspace'
        'setup:install build tools'
        'emsdk:manage the Emscripten SDK'
        'wasisdk:manage the WASI SDK'
        'help:show help for a subcommand'
    )
    _describe -t commands 'fips command' commands
}

_fips "$@"
