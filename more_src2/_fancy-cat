#compdef fancy-cat
# Documentation: https://github.com/freref/fancy-cat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fancy-cat takes positional args only: <path-to-pdf> <optional-page-number>
# Configuration via $XDG_CONFIG_HOME/fancy-cat/config.json

local ret=1
_arguments \
  '1:PDF file:_files -g "*.pdf"' \
  '2:starting page (optional):' && ret=0

return ret
