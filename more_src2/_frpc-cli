#compdef frpc-cli frps-cli
# _frpc-cli — fatedier frp fast reverse proxy CLI alias (fatedier team, Go); cobra
# upstream: https://github.com/fatedier/frp

_frpc-cli() {
    local -a sub=(
        'http:run http proxy'
        'https:run https proxy'
        'reload:reload config'
        'status:show status'
        'stop:stop running frpc'
        'tcp:run tcp proxy'
        'tcpmux:run tcpmux proxy'
        'udp:run udp proxy'
        'completion:generate completion'
        'help:show help'
        'verify:verify config'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c+[config file]:file:_files -g "frpc.{ini,toml,yaml,yml,json}"' \
        '--config=+[config file]:file:_files -g "frpc.{ini,toml,yaml,yml,json}"' \
        '--server-addr=+[server addr]:str:' \
        '--token=+[token]:str:' \
        '--user=+[user]:_users' \
        '--log-file=+[file]:file:_files' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--log-max-days=+[days]:n:' \
        '--disable-log-color[disable log color]' \
        '--proxy-name=+[name]:str:' \
        '--local-ip=+[ip]:str:' \
        '--local-port=+[port]:port:' \
        '--remote-port=+[port]:port:' \
        '--use-encryption[use encryption]' \
        '--use-compression[use compression]' \
        '--custom-domains=+[domains csv]:str:' \
        '--subdomain=+[subdomain]:str:' \
        '--http-user=+[user]:_users' \
        '--http-pwd=+[pass]:str:' \
        '--host-header-rewrite=+[host]:str:' \
        '--strict-config[strict config validation]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'frp subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_frpc-cli "$@"
