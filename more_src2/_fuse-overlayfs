#compdef fuse-overlayfs
# _fuse-overlayfs — userspace overlay filesystem for rootless containers (containers/fuse-overlayfs)
# upstream: https://github.com/containers/fuse-overlayfs
# Flags from src/config.rs + fuse-overlayfs.1.md on tip.

_fuse-overlayfs() {
    local -a fopts
    fopts=(
        'lowerdir=[colon-separated list of lower layers]'
        'upperdir=[writable upper layer]'
        'workdir=[work directory on same FS as upperdir]'
        'uidmapping=[UID:MAPPED-UID:LEN[,...]]'
        'gidmapping=[GID:MAPPED-GID:LEN[,...]]'
        'squash_to_root[map all files to root (0:0)]'
        'squash_to_uid=[map all files to uid]'
        'squash_to_gid=[map all files to gid]'
        'static_nlink[report nlink=1 for all dirs]'
        'noacl[disable POSIX ACLs]'
        'xino=[stable inode mode (off|auto|on)]'
        'ino32_t[truncate st_ino to 32 bits]'
        'redirect_dir=[must be off; emulated otherwise]'
        'debug[enable debugging]'
    )

    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '-f[run in foreground]' \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '*-o[overlay mount option]:opt:->oopt' \
        ':mountpoint:_files -/'

    if [[ $state == oopt ]]; then
        _values -s , 'fuse-overlayfs -o option' $fopts
    fi
}

_fuse-overlayfs "$@"
