#compdef racluster radump rahisto ranonymize rapath rastream rastrip rasqlinsert
# Documentation: https://manpages.debian.org/testing/argus-client/
# Reference accessed: 2026-05-30
# Argus client family round 2 — extends the existing _ra multi-stem
# (ra/ratop/ralabel/rasort/racount/rasplit) and _rabins (rabins/rabins2)
# with 8 more QoSient ra* clients. All inherit the ra(1) common option
# set plus tool-specific surfaces.
# Deferred this round: radium + ragator + raservices + ratimerange
# (manpages.debian.org dynamic redirects 404).

local curcontext="$curcontext" state line ret=1

# ra(1) common option set inherited by every client below. Mirrors
# the canonical inventory in more_src/_ra. Kept local to this function
# so it does not conflict with _ra when both are loaded.
local -a _ra_common
_ra_common=(
  '(- *)-h[print explanation of all arguments]'
  '-A[print aggregate statistics on termination]'
  '-b[dump compiled transaction-matching code]'
  '-c+[delimiter character for output columns]:char:'
  '-D+[debug level to stderr (1-8)]:level:(1 2 3 4 5 6 7 8)'
  '-d[toggle running as a daemon]'
  '-e+[match regular expression in flow user data]:regex:'
  '-E+[append filter-rejected records to file]:file:_files'
  '-F+[configuration source file]:file:_files -g "*.conf"'
  '-H[abbreviate numeric metrics]'
  '-L+[header label printing frequency]:n:'
  '-n[modify number-to-name conversion]'
  '-N+[process first N records]:N:'
  '-p+[digits of precision for floats]:digits:'
  '-q[run in quiet mode]'
  '*-r+[read argus data from file]:file:_files -g "*.(argus|arg)"'
  '-R+[recursively process directory]:dir:_directories'
  '*-s+[fields to print]:field:'
  '-S+[remote flow data source URI]:uri:'
  '-t+[time range for matching records]:timerange:'
  '-T+[remote server read seconds]:secs:'
  '-u[print time values using Unix time format]'
  '-w+[append matching data to file]:file:_files -g "*.(argus|arg)"'
  '-X[reset all options to default]'
  '-z[modify status field to represent TCP state changes]'
  '-Z+[modify status field to TCP flag values]:which:(s d b)'
)

# racluster -m aggregation objects (24 values).
local -a _agg
_agg=(
  none all srcid smac dmac soui doui smpls dmpls svlan dvlan
  saddr daddr matrix proto sport dport stos dtos sttl dttl
  stcpb dtcpb inode sco dco sas das ias
)

# rahisto -H metrics (per upstream).
local -a _hist_metrics
_hist_metrics=(
  dur avgdur proto sport dport stos dtos sttl dttl
  sbytes dbytes sappbytes dappbytes spkts dpkts
  smeansz dmeansz sload dload sloss dloss
  sploss dploss srate drate
)

# rastrip -M dsr names (canonical Argus DSR list).
local -a _strip_dsr
_strip_dsr=(
  flow time metric agr net vlan mpls jitter
  ipattr suser duser mac icmp encaps
)

case $service in

  racluster)
    _arguments -s -S \
      $_ra_common \
      '-f+[racluster.conf aggregation definition]:file:_files -g "*.conf"' \
      '*-m+[aggregation object]:object:($_agg)' \
      '*-M+[aggregation behavior mode]:mode:(correct nocorrect norep rmon ind replace)' \
      '-P+[parallel processors for aggregation (default 1)]:N:' \
      '-V[verbose: one line per input file]' \
      '*::filter expression:' \
      && ret=0
    ;;

  radump)
    _arguments -s -S \
      $_ra_common \
      '*::filter expression:' \
      && ret=0
    ;;

  rahisto)
    _arguments -s -S \
      $_ra_common \
      '*-M+[histogram mode]:mode:(nozero outlayer perflow)' \
      '*-H+[histogram spec: [abs] metric bin[L]:range|size]:spec:($_hist_metrics)' \
      '*-m+[aggregation object]:object:($_agg)' \
      '*::filter expression:' \
      && ret=0
    ;;

  ranonymize)
    _arguments -s -S \
      $_ra_common \
      '-f+[anonymization.conf]:file:_files -g "*.conf"' \
      '*::filter expression:' \
      && ret=0
    ;;

  rapath)
    _arguments -s -S \
      $_ra_common \
      '-A[draw path description with legend]' \
      '*-M+[path display mode]:mode:(node addr aspath asnode)' \
      '*-m+[modify default flow identifiers]:field:(srcid saddr daddr)' \
      '-q[suppress per-node argus record output]' \
      '-f+[ralabel.conf ASN labeling config]:file:_files -g "*.conf"' \
      '*::filter expression:' \
      && ret=0
    ;;

  rastream)
    _arguments -s -S \
      $_ra_common \
      '-a+[append suffix length (default 2)]:N:' \
      '-B+[buffer hold time before processing (sec)]:N:' \
      '-f+[post-processing program after closing output]:program:_command_names -e' \
      '*-M+[split/lock mode]:mode:(count size time flow lock lock=nonblock)' \
      '*::filter expression:' \
      && ret=0
    ;;

  rastrip)
    _arguments -s -S \
      $_ra_common \
      '*-M+[strip DSR (prefix + or - to add/remove) or "replace"]:dsr:($_strip_dsr replace)' \
      '*::filter expression:' \
      && ret=0
    ;;

  rasqlinsert)
    _arguments -s -S \
      $_ra_common \
      '*-M+[SQL operation mode]:mode:(cache drop rewrite time)' \
      '*-m+[flow key attributes for DB schema (or "none")]:fields:(none $_agg)' \
      '-S[read from argus data stream]' \
      '*::filter expression:' \
      && ret=0
    ;;

esac

return ret
