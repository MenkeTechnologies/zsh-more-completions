#compdef dsymutil
# _dsymutil — LLVM debug symbol linker for Darwin (LLVM project, C++); generate .dSYM bundles from object files
# upstream: https://github.com/llvm/llvm-project

_dsymutil() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-h[show help]' \
        '-arch=+[arch]:arch:' \
        '--arch=+[arch]:arch:' \
        '--accelerator=+[accelerator]:val:(Apple Dwarf Default Pub)' \
        '--build-variant-suffix=+[build variant suffix]:str:' \
        '--flat[flat output (no bundle)]' \
        '-f[flat output]' \
        '--minimize[minimize debug map]' \
        '-z[minimize debug map]' \
        '--no-odr[no ODR]' \
        '--no-output[no output]' \
        '--no-swiftmodule-timestamp[no swiftmodule timestamp]' \
        '--num-threads=+[threads]:n:' \
        '-j+[threads]:n:' \
        '--object-prefix-map=+[object prefix map]:str:' \
        '--oso-prepend-path=+[OSO prepend path]:str:' \
        '-o+[output file]:file:_files' \
        '--out=+[output file]:file:_files' \
        '--papertrail[paper trail]' \
        '--remarks-drop-without-debug[drop remarks without debug]' \
        '--remarks-output-format=+[remarks output format]:fmt:(yaml bitstream)' \
        '--remarks-prepend-path=+[remarks prepend path]:str:' \
        '--statistics[print statistics]' \
        '-s[print statistics]' \
        '--symbol-map=+[symbol map dir]:dir:_files -/' \
        '--symtab[print symbol table]' \
        '-S[print symbol table]' \
        '--toolchain=+[toolchain]:str:' \
        '--update[update existing dSYM]' \
        '-u[update existing dSYM]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--verify[verify after link]' \
        '--linker=+[linker]:val:(apple llvm)' \
        '*:file:_files'
}

_dsymutil "$@"
