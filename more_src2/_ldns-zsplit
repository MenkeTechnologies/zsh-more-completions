#compdef ldns-zsplit
# _ldns-zsplit — NLnet Labs ldns-zsplit (split a canonical-ordered zonefile into <zonefile>.000..999 parts so parts can be signed in parallel)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-zsplit.c usage on tip.

_ldns-zsplit() {
    _arguments \
        '-n+[split after this many RRs]:n:' \
        '-o+[initial $ORIGIN for zones starting with @]:origin:' \
        '-z[sort zone before splitting (slow on large zones)]' \
        '-v[show version and exit]' \
        '1:zonefile:_files' \
        '*:keyfile:_files'
}

_ldns-zsplit "$@"
