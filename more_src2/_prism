#compdef prism
# Documentation: https://github.com/stoplightio/prism/blob/master/docs/getting-started/03-cli.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'mock:start a mock server with the given document file'
  'proxy:start a proxy server with the given document file'
)

local -a log_levels=(silent fatal error warn info debug trace)

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'prism command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (mock)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port that Prism will run on]:port' \
          '(-h --host)'{-h+,--host=}'[host that Prism will listen to]:host' \
          '(-d --dynamic)'{-d,--dynamic}'[dynamically generate examples]' \
          '--cors[enable CORS headers]' \
          '--no-cors[disable CORS headers]' \
          '--errors[produce error responses for violations]' \
          '--no-errors[do not produce error responses for violations]' \
          '(-m --multiprocess)'{-m,--multiprocess}'[fork http server from the CLI]' \
          '(-v --verboseLevel)'{-v+,--verboseLevel=}'[verbose log level]:level:('"${log_levels[*]}"')' \
          '--json-schema-faker-fillProperties[generate additional properties in dynamic mode]' \
          '--ignoreExamples[treat spec as if it has no examples]' \
          '--seed=[seed for deterministic dynamic examples]:seed' \
          '1:document:_files -g "*.{json,yaml,yml}"' && ret=0
        ;;
      (proxy)
        _arguments \
          '(-p --port)'{-p+,--port=}'[port that Prism will run on]:port' \
          '(-h --host)'{-h+,--host=}'[host that Prism will listen to]:host' \
          '--cors[enable CORS headers]' \
          '--no-cors[disable CORS headers]' \
          '--errors[produce error responses for violations]' \
          '--no-errors[do not produce error responses for violations]' \
          '--validate-request[validate incoming HTTP requests]' \
          '--no-validate-request[do not validate incoming HTTP requests]' \
          '--upstream-proxy=[http proxy to reach upstream]:proxy url' \
          '(-m --multiprocess)'{-m,--multiprocess}'[fork http server from the CLI]' \
          '(-v --verboseLevel)'{-v+,--verboseLevel=}'[verbose log level]:level:('"${log_levels[*]}"')' \
          '1:document:_files -g "*.{json,yaml,yml}"' \
          '2:upstream URL' && ret=0
        ;;
    esac
    ;;
esac

return ret
