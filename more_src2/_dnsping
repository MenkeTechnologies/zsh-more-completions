#compdef dnsping
# =============================================================================
# dnsping — fortio/dnsping's "DNS Ping" — a Go
#   CLI that PROBES a DNS server with repeated
#   queries to measure PACKET LOSS + RESPONSE
#   LATENCY (like `ping(8)` does for ICMP, but
#   for the DNS protocol).  Emits a per-query
#   line + a final HISTOGRAM with percentiles
#   (p50 / p90 / p99) on stop.  Optional JSON
#   sidecar output for ingestion into
#   observability pipelines.  Built directly on
#   `miekg/dns v1.1.72` — the canonical Go DNS
#   protocol library that powers CoreDNS,
#   AdGuard Home, Caddy DNS-01, Traefik DNS
#   providers, blocky, dnscrypt-proxy, etc.
#   Go=106 leader bump continuing Axis 51
#   (DNS Server / Resolver Library) at the Go
#   pole, opened by R793 `_crab-hole`
#   (Rust=106, hickory-dns 0.26.1).
#
# AXIS 51 — DNS SERVER / RESOLVER LIBRARY — GO POLE
# ==================================================
# `miekg/dns` (8,692 stars on GitHub, BSD-3-
# Clause) is the canonical Go DNS protocol
# library.  Maintained by Miek Gieben (author of
# `RFC 4034bis` and many other DNS RFCs).
# Covers the full wire-protocol codec, message
# construction, zone-file parsing, DNSSEC,
# EDNS0, TSIG, GSS-TSIG, and an embeddable
# server.  Used by CoreDNS as its core
# protocol engine.  Distinguishes from sibling
# Go DNS libs:
#   - bogdanovich/dns_resolver               — minimal
#                                               resolver
#                                               wrapper
#                                               (76⭐),
#                                               built ON
#                                               TOP of
#                                               miekg/dns
#   - cloudflare/dns                         — Cloudflare
#                                               clone /
#                                               fork
#                                               (~68⭐)
#   - net.LookupIP (stdlib)                 — stdlib
#                                               resolver,
#                                               no
#                                               protocol-
#                                               level
#                                               access
#                                               (no
#                                               DNSSEC,
#                                               no TSIG,
#                                               no zone
#                                               parsing)
#
# Other Axis 51 implementations across the
# corpus:
#   * Rust       (R793): hickory-dns 0.26.1
#                — bundled in `crab-hole`
#                  (Pi-Hole clone DNS server
#                  with blocklist trie)
#   * Go         (R794, THIS ROUND):
#                miekg/dns v1.1.72 — bundled
#                in this round's `dnsping`
#                (probe-style DNS server
#                latency + loss measurement
#                tool)
#   * TS-Node    (R795 will close): dns2 /
#                native-dns / dns-packet —
#                JS-native DNS protocol
#                implementations
#
# Distinguishing dnsping from other corpus DNS
# tooling:
#   - DIG (`_dig`, BIND-9-shipped, C):
#     classic single-shot lookup tool.  No
#     loss / latency aggregation.  Heavier
#     output format
#   - DOG (`_dog`, Rust): modern `dig`
#     alternative.  Single-shot + colour
#     output.  No probe loop
#   - DOGGO (`_doggo`, Go): another modern
#     `dig` alternative.  Single-shot
#   - Q (`_q`, natesales/q, Go): tiny DNS
#     client with DoT / DoH / DoQ support.
#     Single-shot
#   - DNSX (`_dnsx`, projectdiscovery, Go):
#     bulk DNS toolkit for asset-discovery
#     pipelines (resolve thousands of
#     subdomains in parallel).  Different
#     scale point
#   - DNSPEEP (jvns/dnspeep, Rust, no
#     completion yet): packet-capture-based
#     observer of DNS queries leaving the
#     host.  Different angle entirely
#   - DNSMONSTER (`_dnsmonster`, Go):
#     passive DNS capture + monitoring with
#     ClickHouse / Postgres / InfluxDB /
#     NATS / parquet sinks.  Different
#     scale point (production-grade pcap
#     pipeline)
#   - DNSPING is the SMALL focused tool —
#     a UDP / TCP probe loop with per-query
#     latency stats and percentile
#     histogram.  Direct analogue of
#     `ping(8)` for ICMP
#
# CLI DESIGN — Go stdlib `flag` package:
# All flags use SINGLE-DASH form (`-c`,
# `-dnssec`, etc.); Go's flag parser also
# accepts double-dash for compatibility
# (`--dnssec` treated as the same flag).
# No subcommands.  Two positional arguments:
#   `dnsping [flags] <query-name> <server>`
# Plus three special bare positional words:
#   * `help`       — print full help text
#                    (same as `--help`)
#   * `version`    — print version
#   * `buildinfo`  — print build commit +
#                    timestamp + Go runtime
#                    version
#
# JSON OUTPUT FORMAT (`-json <path>`):
# When `-json -` is used, the binary writes
# the entire run summary to stdout after the
# probe loop exits.  When `-json <FILE>` is
# used, the same JSON object goes to the
# file.  The JSON includes per-run Config +
# Errors count + Success count + Stats
# {Count, Min, Max, Sum, Avg, StdDev,
# percentile bucket Data[]}.  Useful for
# parsing in monitoring pipelines
#
# QUERY-TYPE STRINGS (`-q <type>`):
# All standard DNS RR types: A (default),
# AAAA, CNAME, MX, NS, PTR, SOA, SRV, TXT,
# CAA, DS, DNSKEY, DLV, HINFO, NAPTR, NSEC,
# NSEC3, NSEC3PARAM, RRSIG, SSHFP, TLSA, +
# any miekg/dns-recognised StringToType key.
# Case-sensitive (per DNS spec)
#
# LOG LEVELS (`-loglevel <level>`):
# fortio's log levels: Debug, Verbose, Info
# (default), Warning, Error, Critical, Fatal.
# `-quiet` shortcuts to Error
#
# CRITICAL DIRECT DEPENDENCIES (from go.mod):
#   - github.com/miekg/dns v1.1.72
#                              — DNS protocol
#                                library
#                                [AXIS 51 LIBRARY]
#   - fortio.org/cli v1.12.3   — fortio's
#                                CLI helper
#                                (banner +
#                                version
#                                flag +
#                                arg help)
#   - fortio.org/fortio v1.74  — fortio
#                                core
#                                (histogram +
#                                periodic
#                                runner)
#   - fortio.org/log v1.18.3   — fortio
#                                structured
#                                logger
#                                (colorised
#                                with --logger
#                                -force-color)
#   - fortio.org/safecast 1.2  — safe int
#                                conversions
#   - golang.org/x/mod 0.32    — Go-module
#                                helpers
#
# Go 1.24.0+ MSRV per go.mod `go 1.24.0`.
#
# UPSTREAM:
#   * Source             : https://github.com/fortio/dnsping
#   * Site               : https://fortio.org
#   * pkg.go.dev         : https://pkg.go.dev/fortio.org/dnsping
#   * miekg/dns          : https://github.com/miekg/dns
#   * Docker hub         : https://hub.docker.com/r/fortio/dnsping
#   * License            : Apache-2.0
#   * Maintainer         : Laurent Demailly (ldemailly) at fortio.org
#
# INSTALL:
#   # From source (Go install)
#   go install fortio.org/dnsping@latest
#
#   # Homebrew tap
#   brew install fortio/tap/dnsping
#
#   # Docker
#   docker run fortio/dnsping www.google.com 8.8.8.8
#
#   # GitHub Releases
#   # https://github.com/fortio/dnsping/releases
#
# USAGE EXAMPLES:
#
#   # Probe Google DNS until ^C, query
#   # www.google.com A record every 1s
#   dnsping www.google.com 8.8.8.8
#
#   # 10 queries, 100ms interval, 200ms timeout
#   dnsping -c 10 -i 100ms -t 200ms \
#       www.google.com 1.1.1.1
#
#   # Query AAAA record over TCP
#   dnsping -q AAAA -tcp \
#       www.google.com 8.8.4.4
#
#   # Set DNSSEC OK + EDNS0 4096
#   dnsping -dnssec -edns \
#       example.com 9.9.9.9
#
#   # Custom port (DNS over a non-standard
#   # port, e.g. 5353 for mDNS)
#   dnsping -p 5353 mycomputer.local 224.0.0.251
#
#   # Disable recursion (query an
#   # authoritative server directly)
#   dnsping -no-recursion \
#       example.com a.iana-servers.net
#
#   # Reproducible run with fixed transaction
#   # ID + sequential IDs (matches
#   # tshark-replayable PCAP)
#   dnsping -fixed-id 42 -sequential-id \
#       -c 8 example.com 8.8.4.4
#
#   # Write JSON results to a file
#   dnsping -json sampleResult.json \
#       -c 8 example.com 8.8.4.4
#
#   # Write JSON to stdout
#   dnsping -json - -c 8 \
#       example.com 8.8.4.4 | jq .
#
#   # Quiet mode (only show errors + final
#   # histogram)
#   dnsping -quiet -c 100 \
#       example.com 8.8.8.8
#
#   # Verbose / Debug logging
#   dnsping -loglevel Debug \
#       example.com 8.8.8.8
#
#   # Force color even when piped
#   dnsping -logger-force-color \
#       example.com 8.8.8.8 | less -R
#
#   # Help / version / buildinfo (special
#   # bare positional args)
#   dnsping help
#   dnsping version
#   dnsping buildinfo
#
# OPTIONS (sourced directly from
# https://github.com/fortio/dnsping/blob/main/README.md help text):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dnsping_qtypes
_dnsping_qtypes=(
    'A:IPv4 host address (default)'
    'AAAA:IPv6 host address'
    'CNAME:Canonical name alias'
    'MX:Mail exchange'
    'NS:Authoritative name server'
    'PTR:Reverse DNS pointer'
    'SOA:Start of authority'
    'SRV:Service location'
    'TXT:Free-form text records'
    'CAA:Certificate Authority Authorization'
    'DS:Delegation signer (DNSSEC)'
    'DNSKEY:DNSSEC zone key'
    'DLV:DNSSEC Lookaside Validation'
    'HINFO:Host info (deprecated)'
    'NAPTR:Naming Authority Pointer'
    'NSEC:Next-secure (DNSSEC)'
    'NSEC3:Next-secure v3 (DNSSEC)'
    'NSEC3PARAM:NSEC3 parameters'
    'RRSIG:Resource record signature (DNSSEC)'
    'SSHFP:SSH fingerprint'
    'TLSA:DANE TLSA record'
    'OPT:EDNS0 pseudo-record'
)

local -a _dnsping_loglevels
_dnsping_loglevels=(
    'Debug:Most verbose'
    'Verbose:Verbose informational'
    'Info:Informational (default)'
    'Warning:Warnings only'
    'Error:Errors only'
    'Critical:Critical errors'
    'Fatal:Fatal errors'
)

_arguments -C \
    '-c+[number of requests to make (default: run until ^C)]:n: ' \
    '-dnssec[set the DNSSEC OK bit]' \
    '-edns[set EDNS0 4096]' \
    '-fixed-id=[non-zero id to use instead of random or sequential]:id: ' \
    '-i+[wait duration between requests (default 1s)]:duration: ' \
    '-json=[JSON output path (use - for stdout)]:path:_files' \
    '-logger-force-color[force color output even if stderr is not a terminal]' \
    '-logger-no-color[prevent colorized output even if stderr is a terminal]' \
    '-loglevel=[log level]:level:->level' \
    '-no-recursion[disable recursion (default is on)]' \
    '-p+[port to connect to (default 53)]:port: ' \
    '-q+[DNS query type]:type:->qtype' \
    '-quiet[quiet mode (sets loglevel to Error)]' \
    '-sequential-id[use sequential ids instead of random]' \
    '-t+[timeout duration per query (default 700ms)]:duration: ' \
    '-tcp[use TCP instead of UDP]' \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)--help[show help]' \
    '*:query name or server (or help|version|buildinfo special args):' \
    && ret=0

case $state in
    qtype)
        _describe -t qtypes 'DNS query type' _dnsping_qtypes && ret=0 ;;
    level)
        _describe -t levels 'log level' _dnsping_loglevels && ret=0 ;;
esac

return ret
