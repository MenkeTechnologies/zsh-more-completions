#compdef ixion
# ============================================================================
# _ixion — zsh completion for the Ixion programming language compiler —
#           "a modern, multi-paradigm compiled programming language for the
#           JVM platform" (171st programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/ixionlang/ixion
#   Maintainer : ixionlang / kingmang (Artyom)
#   License    : MIT
#   Stars      : 220
#   Language   : Kotlin + Java (Gradle build to a JVM jar +
#                shell launcher)
#   Module     : com.kingmang.ixion  (gradle group org.example)
#   Binary     : ixion  (entry class
#                com.kingmang.ixion.Ixion;  hand-rolled arg
#                parser, not picocli)
#   Source ext : .ix
#   Last push  : 2026-05-28
#
# WHAT IT IS
#   Ixion is "a multi-paradigm compiled programming language for
#   the JVM platform" — a modern scripting / systems hybrid with
#   first-class lambdas, pattern matching over algebraic data
#   types, union types (`type number = int | float`), structs,
#   generics, and an async runtime.  The reference implementation
#   parses `.ix` source via a Kotlin frontend, lowers to an
#   intermediate IR, and emits JVM bytecode through the ASM
#   library — or generates Java source (`--java`) for human
#   inspection and IDE integration.  An optimizer pass enables
#   constant folding (`--optimize`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main/kotlin/com/
#                       kingmang/ixion/Ixion.kt `parseArguments`
#                       + `printHelp` — Ixion uses a hand-rolled
#                       Kotlin `when`-based parser, not picocli
#                       despite picocli being on the dependency
#                       list)
#   ixion [OPTIONS] <ENTRY_FILE.ix>
#
#   Options:
#     -h, --help                     Display help and exit
#     --java                         Generate Java source code
#                                    instead of JVM bytecode
#     --compile-only                 Only compile, do not run
#                                    the resulting program
#     --optimize                     Enable optimizer passes
#                                    (constant folding)
#
#   Positional:
#     <entry-file>                   Path to the entry `.ix`
#                                    source file
#
# LANGUAGE-CORPUS POSITION
#   Ixion is the 171st programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R953 (_mostro-cli / MostroP2P Rust=146 OPENS Axis 91
#   Bitcoin / rust-bitcoin) and continued through R954
#   (_lndmon / Lightning Labs Go=146) and R955 (_btc-rpc-
#   explorer / janoside TS-Node=146 CLOSES Axis 91 at 1/1/1
#   three-language symmetry — triple-146 landmark and 84th axis
#   closed).  Ixion joins KernelScript (R952 170th — round-
#   number 170th-language milestone), Prog8 (R948 169th), Objeck
#   (R944 168th), Feral (R940 167th — R940 round-number commit
#   landmark), Biscuit/BL (R936 166th), Rux (R932 165th), Jule
#   (R928 164th), Nevalang (R924 163rd), Corvid (R920 162nd —
#   round-number R920 commit landmark), Soppo (R916 161st),
#   Cyrus (R912 160th — round-number language milestone),
#   Lumina (R908 159th), Penne (R904 158th), EndBASIC (R900
#   157th — R900 TRIPLE-9 commit landmark), goboscript (R896
#   156th), Alan (R892 155th), Mech (R888 154th — triple-8
#   landmark), Lisette (R884 153rd), Bril (R880 152nd), Vyxal
#   (R876 151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th),
#   Mochi (R860 147th), Oden (R856 146th), Hop (R852 145th),
#   Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th),
#   Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `ixion` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_ixion() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '--java[generate Java source code instead of JVM bytecode]' \
        '--compile-only[only compile, do not run]' \
        '--optimize[enable optimizer passes (constant folding)]' \
        ':Ixion entry source file:_files -g "*.ix"'
}

_ixion "$@"
