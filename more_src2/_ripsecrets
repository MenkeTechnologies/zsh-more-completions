#compdef ripsecrets
# Documentation: https://github.com/sirwart/ripsecrets/blob/main/src/args.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for ripsecrets - prevent committing secret keys into source control

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '--install-pre-commit[install ripsecrets as a pre-commit hook]' \
  '--strict-ignore[respect .secretsignore for paths passed as arguments]' \
  '--only-matching[print only the matched parts of lines]' \
  '*--additional-pattern=[additional regex pattern for secrets]:pattern' \
  '*:file:_files' && ret=0

return ret
