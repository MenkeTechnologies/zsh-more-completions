#compdef dvisvgm
# Documentation: dvisvgm --help (dvisvgm 3.6)
# Source: convert DVI / EPS / PDF to SVG (XML scalable vector graphics).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h-,--help=-}'[print help summary]::mode:' \
    '(- *)'{-V-,--version=-}'[print version]::extended:(yes no)' \
    '(-l --list-specials)'{-l,--list-specials}'[print supported special sets]' \
    '(-p --page)'{-p+,--page=}'[choose page(s) to convert]:ranges:' \
    '(-m --fontmap)*'{-m+,--fontmap=}'[evaluate additional font map files]:files:_files' \
    '(-E --eps -P --pdf)'{-E,--eps}'[convert EPS file to SVG]' \
    '(-E --eps -P --pdf)'{-P,--pdf}'[convert PDF file to SVG]' \
    '--stdin[read input file from stdin]' \
    '(-b --bbox)'{-b+,--bbox=}'[set size of bounding box]:size:' \
    '(-B --bitmap-format)'{-B+,--bitmap-format=}'[format for embedded PS/EPS bitmaps]:fmt:(jpeg png none)' \
    '(-j --clipjoin)'{-j,--clipjoin}'[compute intersection of clipping paths]' \
    '--colornames[prefer color names to RGB values if possible]' \
    '--comments[add comments with additional information]' \
    '--currentcolor=-[replace given color with currentColor]::color:' \
    '--embed-bitmaps[prevent references to external bitmap files]' \
    '(-f --font-format)'{-f+,--font-format=}'[file format of embedded fonts]:format:(svg woff woff2 ttf eot)' \
    '--grad-overlap[create overlapping color gradient segments]' \
    '--grad-segments=[number of color gradient segments per row]:n:' \
    '--grad-simplify=[reduce level of detail for small segments]:delta:' \
    '(-L --linkmark)'{-L+,--linkmark=}'[mark hyperlinked areas]:style:(none box line box+line)' \
    '(-O --optimize)'{-O-,--optimize=-}'[perform SVG optimizations]::modules:(all none)' \
    '(-o --output)'{-o+,--output=}'[name pattern of output files]:pattern:' \
    '(-d --precision)'{-d+,--precision=}'[number of decimal points 0-6]:n:' \
    '(-R --relative)'{-R,--relative}'[create relative path commands]' \
    '(-s --stdout)'{-s,--stdout}'[write SVG output to stdout]' \
    '--tmpdir=-[set/print directory for temporary files]::path:_files -/' \
    '(-n --no-fonts)'{-n-,--no-fonts=-}'[draw glyphs by using path elements]::variant:' \
    '--no-merge[do not merge adjacent text elements]' \
    '--no-styles[do not use CSS styles to reference fonts]' \
    '(-z --zip)'{-z-,--zip=-}'[create compressed .svgz file]::level:' \
    '(-r --rotate)'{-r+,--rotate=}'[rotate page content clockwise]:angle:' \
    '(-c --scale)'{-c+,--scale=}'[scale page content]:sx[,sy]:' \
    '(-t --translate)'{-t+,--translate=}'[shift page content]:tx[,ty]:' \
    '(-T --transform)'{-T+,--transform=}'[transform page content]:commands:' \
    '(-Z --zoom)'{-Z+,--zoom=}'[zoom page content]:factor:' \
    '(-C --cache)'{-C-,--cache=-}'[set/print cache directory]::dir:_files -/' \
    '(-e --exact-bbox)'{-e,--exact-bbox}'[compute exact glyph bounding boxes]' \
    '--keep[keep temporary files]' \
    '--libgs=[name of Ghostscript shared library]:file:_files' \
    '(-M --mag)'{-M+,--mag=}'[magnification of Metafont output]:factor:' \
    '--no-mktexmf[do not try to create missing fonts]' \
    '(-S --no-specials)'{-S-,--no-specials=-}'[do not process selected specials]::prefixes:' \
    '(-H --page-hashes)'{-H-,--page-hashes=-}'[activate page hashes]::params:' \
    '(-a --trace-all)'{-a-,--trace-all=-}'[trace all glyphs of bitmap fonts]::retrace:(yes no)' \
    '--color[colorize messages]' \
    '--message=[print message after writing an SVG file]:text:' \
    '--progress=-[enable progress indicator]::delay:' \
    '(-v --verbosity)'{-v+,--verbosity=}'[verbosity level 0-15]:level:' \
    '*:input file:_files -g "*.(dvi|eps|pdf)"' \
    && ret=0

return ret
