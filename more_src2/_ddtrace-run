#compdef ddtrace-run
# Documentation: https://ddtrace.readthedocs.io/en/stable/advanced_usage.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--info[print tracer health check and configuration info]' \
  '*::command:_command_names' && ret=0

return ret
