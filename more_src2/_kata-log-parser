#compdef kata-log-parser log-parser
# _kata-log-parser — Kata Containers log file parser (reads runtime+agent logs, emits text/csv/json/toml/xml/yaml)
# upstream: https://github.com/kata-containers/kata-containers
# Flags from src/tools/log-parser/main.go on tip (urfave/cli/v1).

_kata-log-parser() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print version and exit]' \
        '--check-only[check log files and only display output on error]' \
        '--debug[display debug information (requires --output-file)]' \
        '--error-if-file-empty[error if any input file is empty]' \
        '--error-if-no-records[error if every input file is empty]' \
        '--ignore-missing-fields[do not error on lines missing pid/source/name/level]' \
        '--list-output-formats[show available output formatters]' \
        '--no-agent-unpack[do not unpack agent log entries]' \
        '--quiet[suppress warning messages]' \
        '--strict[do not tolerate misformed agent messages]' \
        '--output-format=[output format]:fmt:(text csv json toml xml yaml)' \
        '--output-file=[write output to this file]:file:_files' \
        '*:logfile:_files'
}

_kata-log-parser "$@"
