#compdef pipsi
# _pipsi — pip script installer (per-script virtualenv) (mitsuhiko/pipsi)
# upstream: https://github.com/mitsuhiko/pipsi
# Subcommands & flags from pipsi/__init__.py (click).

_pipsi() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)--help[show help]' \
        '--home=[per-script virtualenv directory]:dir:_files -/' \
        '--bin-dir=[script bin directory]:dir:_files -/' \
        '--python=[Python interpreter to use]:python:_command_names -e' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'install:install a package and its scripts'
                'upgrade:upgrade installed packages'
                'uninstall:remove scripts of a package'
                'list:list installed packages'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                install)
                    _arguments \
                        '(-e --editable)'{-e,--editable}'[editable installation]' \
                        '--system-site-packages[expose system site-packages]' \
                        '*:package:'
                    ;;
                upgrade)
                    _arguments \
                        '(-e --editable)'{-e,--editable}'[editable upgrade]' \
                        '*:package:'
                    ;;
                uninstall)
                    _arguments \
                        '--yes[skip prompts]' \
                        '*:package:'
                    ;;
                list)
                    _arguments '--versions[show package versions]'
                    ;;
            esac
            ;;
    esac
}

_pipsi "$@"
