#compdef pamsumm
# Documentation: man pamsumm (Netpbm)
# Source: print sum, mean, min, or max of all samples in a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-sum -mean -min -max)-sum[total sum]' \
    '(-sum -mean -min -max)-mean[arithmetic mean]' \
    '(-sum -mean -min -max)-min[minimum]' \
    '(-sum -mean -min -max)-max[maximum]' \
    '-normalize[normalise to 0..1]' \
    '-brief[brief output (number only)]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
