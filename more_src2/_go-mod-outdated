#compdef go-mod-outdated
# Documentation: https://github.com/psampaz/go-mod-outdated
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-direct[show only direct modules]' \
  '-json[output as JSON]' \
  '-update[include available updates]' \
  '-style=[column style]:style:(markdown columns)' \
  '-ci[CI-friendly non-zero exit if updates exist]' \
  '*:extra go build arguments: _default'
