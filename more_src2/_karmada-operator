#compdef karmada-operator
# _karmada-operator — Karmada lifecycle operator (installs/upgrades Karmada components)
# upstream: https://github.com/karmada-io/karmada
# Flags from operator/cmd/operator/app/options/options.go on tip.

_karmada-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port (0=disable)]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--resync-period=[min frequency at which watched resources are reconciled]:dur:' \
        '--kube-api-qps=[QPS for K8s API]:f:' \
        '--kube-api-burst=[burst for K8s API]:n:' \
        '*--controllers=[explicit controller list (* = all)]:csv:' \
        '--concurrent-karmada-syncs=[concurrent Karmada CR syncs]:n:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--leader-elect-lease-duration=[leader lease duration]:dur:' \
        '--leader-elect-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-elect-retry-period=[leader retry period]:dur:' \
        '--leader-elect-resource-namespace=[leader-election lease namespace]:ns:' \
        '--profiling=[enable pprof endpoint]:bool:(true false)' \
        '--logging-format=[log format]:fmt:(text json)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_karmada-operator "$@"
