#compdef ras-mc-ctl
# Documentation: https://manpages.debian.org/bookworm/rasdaemon/ras-mc-ctl.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ras-mc-ctl: memory-controller / EDAC RAS event manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--quiet[quiet mode]' \
  '--mainboard[show mainboard info]' \
  '--status[print EDAC status]' \
  '--print-labels[print configured DIMM labels]' \
  '--guess-labels[guess DIMM labels from DMI]' \
  '--register-labels[load DIMM labels into kernel]' \
  '--labeldb=[label database file]:file:_files' \
  '--delay=[delay time]:time:' \
  '--layout[print board memory layout]' \
  '--summary[print summary]' \
  '--errors[show errors]' \
  '--error-count[show error counts]' \
  '--vendor-errors-summary=[vendor errors summary]:platform-id:' \
  '--vendor-errors=[vendor errors]:platform-id:' \
  '--vendor-platforms[list vendor platforms]' \
  '*::ras-mc-ctl args:_files' && ret=0
return ret
