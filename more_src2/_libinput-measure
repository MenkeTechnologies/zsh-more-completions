#compdef libinput-measure
# Documentation: https://man.archlinux.org/man/libinput-measure.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# libinput-measure: dispatcher for libinput measurement sub-tools.
# Real invocation: `libinput measure <feature> [args]`. This completion
# also matches when invoked as the underlying libinput-measure-* helper.
local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'fuzz:measure touch fuzz to avoid pointer jitter'
  'touch-size:measure touch size and orientation'
  'touchpad-size:measure the size of a touchpad'
  'touchpad-tap:measure tap-to-click time'
  'touchpad-pressure:measure touch pressure'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'libinput-measure feature' commands && ret=0 ;;
  (args)
    _arguments \
      '*:device:_files -g "/dev/input/event*"' && ret=0 ;;
esac

return ret
