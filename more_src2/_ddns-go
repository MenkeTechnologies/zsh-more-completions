#compdef ddns-go
# _ddns-go — jeessy2 ddns-go simple cross-platform dynamic DNS service web UI (jeessy2 team, Go); standard flag package
# upstream: https://github.com/jeessy2/ddns-go

_ddns-go() {
    _arguments \
        '-h[show help]' \
        '-help[show help]' \
        '-v[show version]' \
        '-version[show version]' \
        '-l+[listen address]:addr:' \
        '-f+[refresh interval seconds]:n:' \
        '-c+[config file path]:file:_files -g "*.yaml *.yml"' \
        '-cacheTimes=+[cache count]:n:' \
        '-noweb[disable web ui]' \
        '-skipVerify[skip TLS verify]' \
        '-dns=+[dns server]:str:' \
        '-resetPassword=+[new password]:str:' \
        '-s+[service action]:action:(install uninstall restart status)' \
        '-log+[log file]:file:_files' \
        '-conf.adapter=+[adapter]:str:'
}

_ddns-go "$@"
