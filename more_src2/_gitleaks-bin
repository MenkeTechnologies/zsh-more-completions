#compdef gitleaks
# _gitleaks-bin — gitleaks credential leak scanner (Zachary Rice, Go); detect secrets in git repos, files, and CI
# upstream: https://github.com/gitleaks/gitleaks

_gitleaks-bin() {
    local -a sub=(
        'detect:scan a git repo (default)'
        'protect:scan staged changes'
        'dir:scan a directory'
        'git:scan a git repo'
        'stdin:scan stdin'
        'completion:print shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-c+[config file]:file:_files' \
        '--config+[config file]:file:_files' \
        '--no-color[no color]' \
        '--no-banner[no banner]' \
        '-l+[log level]:level:(trace debug info warn error fatal)' \
        '--log-level+[log level]:level:' \
        '-v+[verbose]' \
        '--verbose[verbose]' \
        '--exit-code+[exit code]:n:' \
        '-r+[report path]:file:_files' \
        '--report-path+[report path]:file:_files' \
        '-f+[report format]:fmt:(json sarif csv junit template)' \
        '--report-format+[report format]:fmt:' \
        '--baseline-path+[baseline path]:file:_files' \
        '--report-template+[template path]:file:_files' \
        '--max-target-megabytes+[max megabytes]:n:' \
        '--max-decode-depth+[max decode depth]:n:' \
        '--ignore-gitleaks-allow[ignore gitleaks:allow comments]' \
        '--redact[redact secrets in output]' \
        '--enable-rule+[enable rule]:rule:' \
        '--disable-rule+[disable rule]:rule:' \
        '--enable-experimental[enable experimental]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitleaks subcommand' sub ;;
        args)
            case $words[1] in
                detect|git) _arguments \
                    '--source+[source]:dir:_files -/' \
                    '-s+[source]:dir:_files -/' \
                    '--log-opts+[git log options]:str:' \
                    '--no-git[do not use git, treat as filesystem]' \
                    '--pipe[read git log from stdin]' \
                    '--follow-symlinks[follow symlinks]' ;;
                dir) _arguments \
                    '--source+[source dir]:dir:_files -/' \
                    '--follow-symlinks[follow symlinks]' \
                    '*:path:_files -/' ;;
                protect) _arguments \
                    '--source+[source]:dir:_files -/' \
                    '--staged[scan staged only]' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gitleaks-bin "$@"
