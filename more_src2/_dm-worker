#compdef dm-worker
# _dm-worker — DM cluster worker node (pingcap/tiflow / Data Migration)
# upstream: https://github.com/pingcap/tiflow/tree/master/dm
# Flags from dm/worker/config.go.

_dm-worker() {
    local -a args
    args=(
        '(- *)-V[print version and exit]'
        '--print-sample-config[print sample dm-worker config file and exit]'
        '--config=[path to TOML config file]:file:_files -g "*.toml"'
        '--worker-addr=[listen address for client traffic]:addr:'
        '--advertise-addr=[advertise address for client traffic]:addr:'
        '-L+[log level]:level:(debug info warn error fatal)'
        '--log-file=[log file path]:file:_files'
        '--log-format=[log format]:fmt:(text json)'
        '--redact-info-log[enable log redaction]'
        '--join=[dm-master cluster master-addr list to join]:masters:'
        '--name=[human-readable dm-worker member name]:name:'
        '--ssl-ca=[trusted CA file]:file:_files -g "*.pem"'
        '--ssl-cert=[X509 certificate file]:file:_files -g "*.pem"'
        '--ssl-key=[X509 key file]:file:_files -g "*.pem"'
    )
    _arguments -s -S $args
}

_dm-worker "$@"
