#compdef nikto
# _nikto-bin — Nikto web server scanner (Chris Sullo, Perl); authorized HTTP/HTTPS vulnerability scanner
# upstream: https://github.com/sullo/nikto

_nikto-bin() {
    _arguments \
        '(-h --host)'{-h,--host}'+[target host or list]:host:_hosts' \
        '(-Help)-Help[show help]' \
        '(-port)-port+[target port(s)]:port:' \
        '-ssl[force SSL]' \
        '-nossl[no SSL]' \
        '-vhost+[virtual host]:vhost:_hosts' \
        '-id+[basic auth user:pass]:str:' \
        '-T+[tuning options]:str:' \
        '-Format+[output format]:fmt:(csv htm html json msf+ nbe sql txt xml)' \
        '-output+[output file]:file:_files' \
        '-Plugins+[plugins to run]:str:' \
        '-evasion+[evasion technique]:n:' \
        '-mutate+[mutate options]:str:' \
        '-Tuning+[tuning]:str:' \
        '-update[update plugins + dbs]' \
        '-Cgidirs+[CGI dirs]:str:' \
        '-config+[config file]:file:_files' \
        '-Display+[display options]:str:' \
        '-noheaders[no fingerprint header]' \
        '-pause+[pause sec between tests]:n:' \
        '-list-plugins[list plugins]' \
        '-Save+[save dir]:dir:_files -/' \
        '-Dbcheck[check syntax of all db files]' \
        '-no404[disable 404 checks]' \
        '-useragent+[user agent]:str:' \
        '-useproxy+[proxy URL]:url:_urls' \
        '-Version[show version]' \
        '*:target:'
}

_nikto-bin "$@"
