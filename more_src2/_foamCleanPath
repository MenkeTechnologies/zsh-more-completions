#compdef foamCleanPath
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamCleanPath — remove duplicate / non-existent / blacklisted entries from PATH-like vars.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[print usage]' \
    '*:path or wildcard list:' \
    && ret=0

return ret
