#compdef icingaweb2 icingacli
# Documentation: https://manpages.debian.org/bookworm/icingacli/icingacli.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm icingacli(1) manpage. icingaweb2 is the PHP
# web UI package; its CLI binary is `icingacli`, which uses module-style
# dispatch. Subcommands depend on which Icinga Web 2 modules are enabled.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# icingaweb2/icingacli: Icinga Web 2 PHP CLI dispatcher
local curcontext="$curcontext" ret=1
local -a modules
modules=(
  'module:manage Icinga Web 2 modules'
  'setup:run installer / generate config'
  'monitoring:monitoring module operations'
  'director:director module operations'
  'businessprocess:business process module operations'
  'reporting:reporting module operations'
  'doc:show documentation'
  'config:edit Icinga Web 2 configuration'
  'help:show help for a module/command'
)
_arguments -C \
  '--help[show help]' \
  '--verbose[verbose output]' \
  '1:module:->mod' \
  '*::arg:->args' && ret=0
case $state in
  mod) _describe -t modules 'icingacli module' modules && ret=0 ;;
esac
return ret
