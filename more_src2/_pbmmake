#compdef pbmmake
# Documentation: man pbmmake (Netpbm)
# Source: produce a uniform PBM image of given dimensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-white -black -gray)-white[fill with white]' \
    '(-white -black -gray)-black[fill with black]' \
    '(-white -black -gray)-gray[fill with gray (50% pattern)]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    && ret=0

return ret
