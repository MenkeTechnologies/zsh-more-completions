#compdef nethogs-cli
# _nethogs-cli — Arnout Engelen nethogs net top per-process bandwidth monitor CLI alias (raboof team, C++); custom argparse
# upstream: https://github.com/raboof/nethogs

_nethogs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[capture from all devices]' \
        '-b[bughunt mode]' \
        '-c+[update count]:n:' \
        '-C[capture TCP and UDP]' \
        '-d+[delay update]:n:' \
        '-f+[BPF filter]:str:' \
        '-l[loopback]' \
        '-p[promiscuous]' \
        '-P+[pid]:pid:_pids' \
        '-s[sort by sent]' \
        '-t[trace mode]' \
        '-v+[view mode]:n:(0 1 2 3)' \
        '-V[show version]' \
        '-x[show parent process]' \
        '*:devices:_net_interfaces'
}

_nethogs-cli "$@"
