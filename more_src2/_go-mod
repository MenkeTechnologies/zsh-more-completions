#compdef go-mod
# _go-mod — go mod subcommand wrapper; module maintenance commands
# upstream: https://pkg.go.dev/cmd/go

_go-mod() {
    local -a sub=(
        'download:download modules to module cache'
        'edit:edit go.mod from tools or scripts'
        'graph:print module requirement graph'
        'init:initialize new module in current dir'
        'tidy:add missing + remove unused modules'
        'vendor:make vendored copy of dependencies'
        'verify:verify dependencies have expected content'
        'why:explain why packages or modules are needed'
        'help:show help'
    )
    _arguments -C \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'go mod subcommand' sub ;;
        args)
            case $words[1] in
                download) _arguments '-x[print commands]' '-json[json output]' '-modcacherw[allow writes]' '-reuse+[reuse cache]:file:_files' '*:module:' ;;
                edit) _arguments \
                    '-fmt[reformat go.mod]' \
                    '-module+[set module path]:path:' \
                    '-require+[add require]:str:' \
                    '-droprequire+[drop require]:str:' \
                    '-exclude+[add exclude]:str:' \
                    '-dropexclude+[drop exclude]:str:' \
                    '-replace+[add replace]:str:' \
                    '-dropreplace+[drop replace]:str:' \
                    '-retract+[add retract]:str:' \
                    '-dropretract+[drop retract]:str:' \
                    '-tool+[add tool]:str:' \
                    '-droptool+[drop tool]:str:' \
                    '-go+[Go version]:ver:' \
                    '-toolchain+[toolchain]:tool:' \
                    '-print[print edited go.mod]' \
                    '-json[json output]' \
                    '*:file:_files -g "go.mod"' ;;
                init) _arguments '*:module-path:' ;;
                tidy) _arguments \
                    '-e[print all errors]' \
                    '-v[verbose]' \
                    '-go+[Go version]:ver:' \
                    '-compat+[compat version]:ver:' \
                    '-diff[print diff]' \
                    '-x[print commands]' ;;
                why) _arguments '-m[module-level]' '-vendor[only used vendor]' '*:pkg:' ;;
                graph) _arguments '-go+[Go version]:ver:' '-x[print commands]' ;;
                vendor) _arguments '-e[print all errors]' '-v[verbose]' '-o+[output dir]:dir:_files -/' ;;
                verify) ;;
            esac
            ;;
    esac
}

_go-mod "$@"
