#compdef dynatrace-cli monaco dt-cli
# _dynatrace-cli — Dynatrace Configuration as Code Monaco CLI (Dynatrace, Go); spf13/cobra
# upstream: https://github.com/Dynatrace/dynatrace-configuration-as-code

_dynatrace-cli() {
    local -a sub=(
        'deploy:deploy configurations'
        'delete:delete configurations'
        'download:download configurations'
        'convert:convert v1 to v2'
        'purge:purge environment'
        'match:match configurations'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--log-format=+[log format]:fmt:(text json)' \
        '--log-file=+[log file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'monaco subcommand' sub ;;
        args)
            case $words[1] in
                deploy) _arguments \
                    '1:manifest:_files -g "manifest.yaml"' \
                    '--environment=+[environment]:env:' \
                    '-e+[environment]:env:' \
                    '--group=+[group]:group:_groups' \
                    '-g+[group]:group:_groups' \
                    '--project=+[project]:str:' \
                    '-p+[project]:str:' \
                    '--dry-run[dry run]' \
                    '--continue-on-error[continue on error]' \
                    '-c[continue on error]' ;;
                delete) _arguments \
                    '1:manifest:_files -g "manifest.yaml"' \
                    '--file=+[delete file]:file:_files -g "delete.yaml"' \
                    '-f+[delete file]:file:_files -g "delete.yaml"' \
                    '--environment=+[environment]:env:' \
                    '-e+[environment]:env:' ;;
                download) _arguments \
                    '--environment-url=+[environment url]:url:_urls' \
                    '--manifest=+[manifest file]:file:_files -g "manifest.yaml"' \
                    '-m+[manifest file]:file:_files -g "manifest.yaml"' \
                    '--token=+[token env var]:str:' \
                    '--client-id=+[oauth client id env var]:str:' \
                    '--client-secret=+[oauth client secret env var]:str:' \
                    '--output-folder=+[output folder]:dir:_files -/' \
                    '-o+[output folder]:dir:_files -/' \
                    '--project=+[project name]:str:' \
                    '--specific-api=+[specific api]:list:' \
                    '--specific-settings=+[specific settings]:list:' \
                    '--specific-types=+[specific types]:list:' ;;
                convert) _arguments \
                    '1:environments.yaml:_files -g "environments.yaml"' \
                    '--output-folder=+[output folder]:dir:_files -/' \
                    '-o+[output folder]:dir:_files -/' ;;
                purge) _arguments \
                    '1:manifest:_files -g "manifest.yaml"' \
                    '--environment=+[environment]:env:' \
                    '-e+[environment]:env:' ;;
                match) _arguments \
                    '1:from-folder:_files -/' \
                    '2:to-folder:_files -/' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_dynatrace-cli "$@"
