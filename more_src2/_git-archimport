#compdef git-archimport
# Documentation: https://git-scm.com/docs/git-archimport
# Source: git/git git-archimport.perl — import an Arch repository into Git (Perl, Getopt::Std).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output]' \
    '-o[use old-style branch naming]' \
    '-a[auto-register Arch archive(s)]' \
    '-f[fetch all branches archived in the Arch repository]' \
    '-T[explicit tag table for import]' \
    '-D+[follow history depth]:depth:_default' \
    '-t+[temporary directory]:tempdir:_files -/' \
    '*:repository/arch-branch:_default' \
    && ret=0

return ret
