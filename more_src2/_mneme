#compdef mneme
# Documentation: https://github.com/zachallaun/mneme/tree/main/lib/mix/tasks
# Reference accessed: 2026-05-27
# Verified: upstream Mix.Tasks.Mneme.{Install,Test,Watch} switches and moduledoc.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'mneme.install:set up Mneme in the project (run with MIX_ENV=test)'
  'mneme.test:run tests with support for Mneme CLI options'
  'mneme.watch:run tests with a file watcher, integrated with Mneme prompts'
)

_arguments -s -S -C \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'mneme subcommand' subcmds && ret=0
    ;;
  rest)
    case $line[1] in
      mneme.test)
        _arguments -s -S \
          '--action=[default action on auto-assertions]:action:(prompt accept reject)' \
          '--default-pattern=[default suggested pattern]:pattern:(infer first last)' \
          '--diff=[diff strategy]:diff:(text semantic)' \
          '--diff-style=[diff layout]:style:(side_by_side stacked)' \
          '--force-update[update assertions without prompting]' \
          '--target=[assertion target]:target:(mneme ex_unit)' \
          '--dry-run[do not write changes to disk]' \
          '*--include=[include tests with the given tag]:tag:' \
          '*--exclude=[exclude tests with the given tag]:tag:' \
          '*--only=[run only tests matching the given tag]:tag:' \
          '*--formatter=[ExUnit formatter module]:module:' \
          '--stale[run only stale tests]' \
          '--trace[run with detailed test trace output]' \
          '--seed=[random seed for test order]:seed:' \
          '*:path:_files' && ret=0
        ;;
      mneme.watch)
        _arguments -s -S \
          '--exit-on-success[stop the watcher when the suite passes]' \
          '--action=[default action on auto-assertions]:action:(prompt accept reject)' \
          '--default-pattern=[default suggested pattern]:pattern:(infer first last)' \
          '--diff=[diff strategy]:diff:(text semantic)' \
          '--diff-style=[diff layout]:style:(side_by_side stacked)' \
          '--force-update[update assertions without prompting]' \
          '--target=[assertion target]:target:(mneme ex_unit)' \
          '--stale[run only stale tests]' \
          '*--include=[include tests with the given tag]:tag:' \
          '*--exclude=[exclude tests with the given tag]:tag:' \
          '*--only=[run only tests matching the given tag]:tag:' \
          '*:path:_files' && ret=0
        ;;
      mneme.install)
        _normal && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
