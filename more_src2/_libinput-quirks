#compdef libinput-quirks
# Documentation: https://man.archlinux.org/man/libinput-quirks.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list quirks applied to a device'
  'validate:check parsing of quirks files'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--data-dir=[directory for quirks files]:dir:_files -/' \
  '--verbose[verbose output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'libinput-quirks command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '--data-dir=[directory for quirks files]:dir:_files -/' \
          '--verbose[verbose output]' \
          '*:device:_files -g "/dev/input/event*"' && ret=0 ;;
      (validate)
        _arguments \
          '--data-dir=[directory for quirks files]:dir:_files -/' \
          '--verbose[verbose output]' && ret=0 ;;
    esac ;;
esac

return ret
