#compdef rdfcompare rdfdiff
# Documentation: https://jena.apache.org/documentation/tools/index.html
# Source: apache/jena jena-cmds/src/main/java/jena/rdfcompare.java — compare two RDF graphs regardless of serialization.
# Reference accessed: 2026-06-10
#
# Usage: rdfcompare source1 source2 [lang1 [lang2 [base1 [base2]]]]
# Exit: 0 = equal, 1 = unequal, -1 = error.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:source1 (URL or file):_files -g "*.(ttl|nt|nq|trig|rdf|xml|jsonld|json)(-.)"' \
    '2:source2 (URL or file):_files -g "*.(ttl|nt|nq|trig|rdf|xml|jsonld|json)(-.)"' \
    '3:lang1:(RDF/XML N-TRIPLE TURTLE JSON-LD)' \
    '4:lang2:(RDF/XML N-TRIPLE TURTLE JSON-LD)' \
    '5:base1 URI:_default' \
    '6:base2 URI:_default' \
    && ret=0

return ret
