#compdef eu-srcfiles
# _eu-srcfiles — elfutils source-file path lister (Mark Wielaard, Red Hat); print source paths referenced in a binary's DWARF
# upstream: https://sourceware.org/elfutils

_eu-srcfiles() {
    _arguments \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-d --debuginfo-path)'{-d,--debuginfo-path}'+[debuginfo path]:path:_files -/' \
        '(-z --zip)'{-z,--zip}'[zip output of source files]' \
        '(-c --core)'{-c,--core}'+[core file]:file:_files' \
        '(-p --pid)'{-p,--pid}'+[attach PID]:pid:_pids' \
        '*:file:_files'
}

_eu-srcfiles "$@"
