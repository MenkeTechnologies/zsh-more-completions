#compdef pbmtextps
# Documentation: man pbmtextps (Netpbm)
# Source: render text into a PBM image via Ghostscript-rendered PostScript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-font=[PostScript font name]:font:' \
    '-fontsize=[font size in points]:size:' \
    '-resolution=[output dpi]:n:' \
    '-leftmargin=[left margin]:n:' \
    '-rightmargin=[right margin]:n:' \
    '-topmargin=[top margin]:n:' \
    '-bottommargin=[bottom margin]:n:' \
    '-ascent=[font ascent]:n:' \
    '-descent=[font descent]:n:' \
    '-pad[pad image]' \
    '-crop[crop image]' \
    '-stroke=[stroke width]:n:' \
    '(-ascii85)-asciihex[ASCII Hex output]' \
    '(-asciihex)-ascii85[ASCII85 output]' \
    '-verbose[verbose output]' \
    '-dump-ps[dump PostScript instead of running Ghostscript]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:text:' \
    && ret=0

return ret
