#compdef prodigal Prodigal
# _prodigal — Doug Hyatt PRODIGAL PROkaryotic DYnamic programming Gene-finding ALgorithm bacterial archaeal gene prediction (hyattpd team, C); getopt
# upstream: https://github.com/hyattpd/Prodigal

_prodigal() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-i+[input fasta]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
        '--input=+[input fasta]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
        '-o+[output gff/gbk]:file:_files -g "*.gbk *.gff *.gff3 *.sco"' \
        '--output=+[output gff/gbk]:file:_files -g "*.gbk *.gff *.gff3 *.sco"' \
        '-a+[protein output]:file:_files -g "*.fa *.fasta *.faa"' \
        '--proteins=+[protein output]:file:_files' \
        '-d+[nucleotide output]:file:_files -g "*.fa *.fasta *.fna"' \
        '--mrna=+[nucleotide output]:file:_files' \
        '-s+[all_starts file]:file:_files' \
        '--start-positions=+[all_starts file]:file:_files' \
        '-w+[summary file]:file:_files' \
        '--summary=+[summary file]:file:_files' \
        '-f+[output format]:f:(gbk gff sco)' \
        '--output-format=+[output format]:f:(gbk gff sco)' \
        '-g+[translation table]:n:' \
        '--genetic-code=+[translation table]:n:' \
        '-p+[mode]:m:(single meta)' \
        '--mode=+[mode]:m:(single meta)' \
        '-m[mask sequences]' \
        '--mask[mask sequences]' \
        '-c[closed ends]' \
        '--closed[closed ends]' \
        '-n[no shine-dalgarno]' \
        '--no-shinedalgarno[no shine-dalgarno]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-t+[training file]:file:_files -g "*.trn"' \
        '--training=+[training file]:file:_files -g "*.trn"' \
        '-r+[shine-dalgarno file]:file:_files' \
        '*:fasta:_files -g "*.fa *.fasta *.fna *.fa.gz"'
}

_prodigal "$@"
