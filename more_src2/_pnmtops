#compdef pnmtops
# Documentation: man pnmtops (Netpbm)
# Source: convert a Netpbm image to PostScript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-scale=[scale factor]:s:' \
    '-dpi=[output resolution N or NxN]:dpi:' \
    '-imagewidth=[image width inches]:n:' \
    '-imageheight=[image height inches]:n:' \
    '-width=[page width inches]:N:' \
    '-height=[page height inches]:N:' \
    '-equalpixels[scale so that input pixels equal output pixels]' \
    '-bitspersample=[bits per sample]:N:(1 2 4 8 12)' \
    '(-turn -noturn)-turn[rotate output 90 if it fits better]' \
    '(-turn -noturn)-noturn[do not rotate output]' \
    '(-rle -runlength)'{-rle,-runlength}'[run-length encoded bytes]' \
    '-flate[Flate-compressed output]' \
    '-ascii85[ASCII85 encoding]' \
    '(-nocenter -center)-nocenter[do not centre on page]' \
    '(-nocenter -center)-center[centre image on page]' \
    '(-nosetpage -setpage)-nosetpage[no setpagedevice]' \
    '(-nosetpage -setpage)-setpage[emit setpagedevice]' \
    '-level=[PostScript LanguageLevel]:N:(1 2 3)' \
    '-dict[use dictionary for output]' \
    '-vmreclaim[insert vmreclaim operators]' \
    '-psfilter[emit PostScript /Filter chain]' \
    '-noshowpage[omit showpage operator]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
