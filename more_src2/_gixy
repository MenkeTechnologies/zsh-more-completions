#compdef gixy
# Documentation: https://github.com/dvershinin/gixy
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Maintained fork of yandex/gixy at github.com/dvershinin/gixy
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '(-c --config)'{-c,--config}'=-[config file]:file:_files' \
  '--write-config[path to write merged config]:file:_files' \
  '-l+[raise minimum severity (-l LOW, -ll MEDIUM, -lll HIGH)]' \
  '(-f --format)'{-f,--format}'=-[report format]:format:(console text ansi json)' \
  '(-o --output)'{-o,--output}'=-[write report]:file:_files' \
  '(-d --debug)'{-d,--debug}'[debug logging]' \
  '--tests=-[comma-separated tests to run]' \
  '--skips=-[comma-separated tests to skip]' \
  '--disable-includes[do not follow include directives]' \
  '--nginx-version=-[NGINX version for CVE checks]:version' \
  '--fix[apply detected fixes in place]' \
  '--fix-dry-run[preview fixes without applying]' \
  '--no-backup[skip backup files when fixing]' \
  '*:nginx config:_files'
