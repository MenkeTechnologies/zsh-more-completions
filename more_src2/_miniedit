#compdef miniedit
# _miniedit — Mininet miniedit (Tk-based topology editor that produces Mininet-compatible Python scripts; --help/--version; positional argument is an optional .mn topology file to open at start; mostly used in educational workshops or when prototyping software-defined networks)
# upstream: https://github.com/mininet/mininet
# Argument shape from mininet examples/miniedit.py on tip.

_miniedit() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '1::topology file:_files -g "*.mn"'
}

_miniedit "$@"
