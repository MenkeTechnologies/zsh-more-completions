#compdef ruby-install
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-s --src-dir)'{-s,--src-dir}'[source directory]:directory:_directories' \
  '(-i --install-dir)'{-i,--install-dir}'[install directory]:directory:_directories' \
  '(-p --patch)'{-p,--patch}'[apply patch file]:patch file:_files' \
  '--system[install into /usr/local]' \
  '(-M --mirror)'{-M,--mirror}'[mirror URL]:URL' \
  '--no-download[do not download source]' \
  '--no-verify[skip checksum verification]' \
  '--no-extract[skip extraction]' \
  '--no-install-deps[skip installing dependencies]' \
  '(-r --reinstall)'{-r,--reinstall}'[force reinstall]' \
  '(-j --jobs)'{-j,--jobs}'[number of parallel jobs]:jobs' \
  '(-c --cleanup)'{-c,--cleanup}'[cleanup source after install]' \
  '(-L --latest)'{-L,--latest}'[install latest version]' \
  '(-U --update)'{-U,--update}'[update ruby-install]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  ':ruby implementation:(ruby jruby rbx truffleruby mruby)' \
  ':version' && ret=0
return ret
