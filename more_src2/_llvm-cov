#compdef llvm-cov
# _llvm-cov — LLVM source code coverage tool (LLVM project, C++); show line/function coverage from instrumented binaries
# upstream: https://github.com/llvm/llvm-project

_llvm-cov() {
    local -a sub=(
        'gcov:GCC-compatible interface'
        'report:generate coverage report'
        'show:show coverage'
        'export:export coverage as JSON or LCOV'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llvm-cov subcommand' sub ;;
        args)
            case $words[1] in
                report|show|export) _arguments \
                    '-instr-profile=+[profile data]:file:_files -g "*.profdata"' \
                    '-arch=+[arch]:arch:' \
                    '-format=+[format]:fmt:(text html lcov)' \
                    '-output-dir=+[output dir]:dir:_files -/' \
                    '-show-branches=+[show branches]:val:(count percent)' \
                    '-show-expansions[show expansions]' \
                    '-show-functions[show functions]' \
                    '-show-instantiations[show instantiations]' \
                    '-show-instantiation-summary[show instantiation summary]' \
                    '-show-line-counts[show line counts]' \
                    '-show-line-counts-or-regions[show line counts or regions]' \
                    '-show-mcdc[show MC/DC]' \
                    '-show-mcdc-summary[show MC/DC summary]' \
                    '-show-region-summary[show region summary]' \
                    '-show-regions[show regions]' \
                    '-summary-only[summary only]' \
                    '-tab-size=+[tab size]:n:' \
                    '-name=+[filter name]:str:' \
                    '-name-regex=+[name regex]:regex:' \
                    '-name-allowlist=+[allowlist file]:file:_files' \
                    '-name-blocklist=+[blocklist file]:file:_files' \
                    '-num-threads=+[threads]:n:' \
                    '-j+[threads]:n:' \
                    '-object=+[additional object]:file:_files' \
                    '-path-equivalence=+[path equivalence]:str:' \
                    '-region-coverage-gt=+[region coverage >]:f:' \
                    '-region-coverage-lt=+[region coverage <]:f:' \
                    '-line-coverage-gt=+[line coverage >]:f:' \
                    '-line-coverage-lt=+[line coverage <]:f:' \
                    '-compilation-dir=+[compilation dir]:dir:_files -/' \
                    '-debug-info-correlate[debug info correlate]' \
                    '*:binary or source:_files' ;;
                gcov) _arguments \
                    '-a[all blocks]' \
                    '-b[branch probabilities]' \
                    '-c[branch counts]' \
                    '-f[function summaries]' \
                    '-l[long names]' \
                    '-n[no output]' \
                    '-o+[object dir]:dir:_files -/' \
                    '-p[preserve paths]' \
                    '-u[unconditional branches]' \
                    '*:source:_files' ;;
            esac
            ;;
    esac
}

_llvm-cov "$@"
