#compdef pass-audit
# Documentation: https://github.com/roddhjav/pass-audit
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pass-audit - audit passwords in pass

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-n --name)'{-n,--name}'=[check only passwords with this filename]:name:' \
  '(-q --quiet -v --verbose)'{-q,--quiet}'[quiet mode]' \
  '(-q --quiet -v --verbose)'{-v,--verbose}'[verbose mode]' \
  '*:path in password store:_files -W "${PASSWORD_STORE_DIR:-$HOME/.password-store}" -g "*.gpg(.:r)"'
