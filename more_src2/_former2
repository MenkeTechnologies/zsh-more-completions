#compdef former2
# Documentation: https://github.com/iann0036/former2/blob/master/cli/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'generate:query AWS and generate CloudFormation/Terraform/raw output'
      'filter:filter previously saved raw output to produce new outputs'
    )
    _describe -t commands 'former2 command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      generate|filter)
        _arguments -s -S \
          '--output-cloudformation=[CloudFormation output file]:file:_files' \
          '--output-terraform=[Terraform output file]:file:_files' \
          '--output-raw-data=[raw debug output JSON]:file:_files' \
          '--output-logical-id-mapping=[logical to physical id mapping file]:file:_files' \
          '--cfn-deletion-policy=[add DeletionPolicy to CloudFormation]:policy:(Delete Retain Snapshot)' \
          '--search-filter=[filter resources by name/tags]:filter' \
          '--regex-filter=[regex resource filter]:regex' \
          '--services=[include specific services]:services' \
          '--exclude-services=[exclude specific services]:services' \
          '--sort-output[sort resources by id]' \
          '--include-default-resources[include default VPCs and subnets]' \
          '--region=[AWS region]:region' \
          '--profile=[AWS named profile]:profile' \
          '--proxy=[proxy URL]:url' \
          '--debug[enable debug logging]' \
          '*: : _default' \
          && ret=0
        ;;
      *)
        _arguments -s -S '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
