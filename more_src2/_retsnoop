#compdef retsnoop
# Documentation: https://github.com/anakryiko/retsnoop (src/env.c argp_option table)
# Reference accessed: 2026-05-29
# retsnoop — BPF-based tool for capturing return-side stacks and arguments of kernel functions on errors.
# Authored by Andrii Nakryiko (Facebook/Meta). Uses argp not getopt — 6 option groups.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show full help]' \
  '(- *)--usage[show usage help]' \
  '*'{-v,--verbose}'[verbose output (-vv=debug, -vvv=extra)]' \
  '(- *)'{-V,--version}'[print retsnoop version]' \
  '*'{-c,--case=}'[predefined entry/allow/deny globs for use cases]:case:(bpf perf)' \
  '*'{-e,--entry=}'[glob for entry functions triggering error stack collection (repeatable)]:glob:' \
  '*'{-a,--allow=}'[glob for allowed functions in error stack collection (repeatable)]:glob:' \
  '*'{-d,--deny=}'[glob for denied functions ignored during collection (repeatable)]:glob:' \
  '(-E --call-stack -T --trace -A --capture-args -B --lbr --dry-run)'{-E,--call-stack}'[capture and emit call stacks (default mode)]' \
  '(-E --call-stack -T --trace -A --capture-args -B --lbr --dry-run)'{-T,--trace}'[capture and emit function call traces]' \
  '(-E --call-stack -T --trace -A --capture-args -B --lbr --dry-run)'{-A,--capture-args}'[capture and emit function arguments]' \
  '*'{-J,--inject-probe=}'[inject extra probe (kprobe/rawtp/tp; repeatable)]:probe:' \
  '(-E --call-stack -T --trace -A --capture-args -B --lbr --dry-run)'{-B,--lbr=}'[capture LBR entries with optional spec flags]:spec:' \
  '(-E --call-stack -T --trace -A --capture-args -B --lbr --dry-run)--dry-run[perform dry run without loading BPF programs]' \
  '(-M --kprobes-multi -K --kprobes -F --fentries)'{-M,--kprobes-multi}'[use multi-attach kprobes/kretprobes]' \
  '(-M --kprobes-multi -K --kprobes -F --fentries)'{-K,--kprobes}'[use single-attach kprobes/kretprobes]' \
  '(-M --kprobes-multi -K --kprobes -F --fentries)'{-F,--fentries}'[use fentries/fexits instead of kprobes]' \
  '*'{-p,--pid=}'[only trace this PID (repeatable)]:pid:_pids' \
  '*'{-P,--no-pid=}'[skip tracing this PID (repeatable)]:pid:_pids' \
  '*'{-n,--comm=}'[only trace processes with this name (repeatable)]:name:' \
  '*'{-N,--no-comm=}'[skip tracing processes with this name (repeatable)]:name:' \
  '(-L --longer)'{-L,--longer=}'[emit stacks exceeding min duration in ms]:ms:' \
  '(-S --success-stacks)'{-S,--success-stacks=}'[emit non-erroring (success) call stacks]:value:' \
  '(-I --interim-stacks)'{-I,--interim-stacks}'[emit incomplete interim call stacks]' \
  '*'{-x,--allow-errors=}'[record stacks with these errors only (repeatable, e.g. EINVAL, ENOENT)]:error:(EPERM ENOENT ESRCH EINTR EIO ENXIO E2BIG ENOEXEC EBADF ECHILD EAGAIN ENOMEM EACCES EFAULT EBUSY EEXIST EXDEV ENODEV ENOTDIR EISDIR EINVAL ENFILE EMFILE ENOTTY ETXTBSY EFBIG ENOSPC ESPIPE EROFS EMLINK EPIPE EDOM ERANGE)' \
  '*'{-X,--deny-errors=}'[ignore stacks with these errors (repeatable)]:error:(EPERM ENOENT ESRCH EINTR EIO ENXIO E2BIG ENOEXEC EBADF ECHILD EAGAIN ENOMEM EACCES EFAULT EBUSY EEXIST EXDEV ENODEV ENOTDIR EISDIR EINVAL ENFILE EMFILE ENOTTY ETXTBSY EFBIG ENOSPC ESPIPE EROFS EMLINK EPIPE EDOM ERANGE)' \
  '*--allow-retval=[record stacks with this return value (repeatable)]:value:' \
  '*--deny-retval=[ignore stacks with this return value (repeatable)]:value:' \
  '(-k --kernel)'{-k,--kernel=}'[path to vmlinux with DWARF info]:path:_files' \
  '(-s --symbolize)'{-s,--symbolize=}'[stack symbolization level]:level:(line inlines none)' \
  '*--debug=[enable debug feature (repeatable)]:feature:(multi-kprobe full-lbr bpf)' \
  '*'{-C,--config=}'[extra configuration parameters (repeatable)]:config:' \
  '--config-help[emit full extra configuration help]' \
  && ret=0

return ret
