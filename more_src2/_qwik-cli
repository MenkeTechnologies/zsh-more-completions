#compdef qwik-cli
# _qwik-cli — Qwik resumable web framework CLI alias (Builder.io / Misko Hevery, TypeScript); commander
# upstream: https://github.com/QwikDev/qwik

_qwik-cli() {
    local -a sub=(
        'new:scaffold component / route'
        'build:build for production'
        'add:add integration (adapter/integration)'
        'create:create project'
        'help:show help'
        'version:show version'
        'dev:start dev server'
        'lint:run linter'
        'preview:preview production build'
        'serve:serve production build'
        'test:run tests'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--strict[strict]' \
        '--debug[debug]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qwik subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '1:integration:(cloudflare-pages netlify-edge node express fastify deno aws-lambda azure-swa vercel-edge bun static)' \
                    '--installDeps[install deps]' \
                    '--skipInstall[skip install]' ;;
                new) _arguments \
                    '1:type:(component route layout)' \
                    '*:name:' ;;
                create) _arguments \
                    '1:starter-id:(empty playground library qwik-city-pure)' \
                    '*:dir:_files -/' \
                    '--no-install[no install]' \
                    '--no-git[no git]' ;;
                build|dev|preview|serve|lint|test) _arguments \
                    '--mode=+[mode]:m:(development production preview)' \
                    '--port=+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--open[open browser]' \
                    '--no-open[no open]' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_qwik-cli "$@"
