#compdef ncftp
# Documentation: man ncftp(1)
# Source: apple-oss-distributions/ncftp ncftp/Main.c (master) — interactive FTP client (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D[turn debug and trace on]' \
    '(-L -V)-L[line mode (no visual)]' \
    '(-L -V)-V[visual mode]' \
    '-H[show version info and exit]' \
    '-a[open anonymously]' \
    '-u[prompt for username and password]' \
    '-p+[FTP port number]:port:_default' \
    '-r[redial until connected]' \
    '-d+[redial delay seconds]:seconds:_default' \
    '-g+[give up after N redials]:N:_default' \
    '-C[force continuation (reget)]' \
    '-f[force overwrite]' \
    '-G[no wildcard matching]' \
    '-R[recursive fetch]' \
    '-n+[get files at most N days old]:days:_default' \
    '-c[fetch stdin or stdout]' \
    '-m[multi-page paginated listing]' \
    '-z[restart files from current position]' \
    '-i[interactive prompts on overwrite]' \
    '1::host[\:path]:_hosts' \
    && ret=0

return ret
