#compdef libtool libtoolize glibtool glibtoolize
# _libtool2 — GNU Project libtool CLI generic library support script for managing static and shared libraries across UNIX systems handling complex platform-specific link-rules archive-creation library-installation versioning -version-info-current-revision-age dlopen-loading-symbol-aliases compile-link-execute-finish-install-clean-mode operations within autotools build framework (GNU team, shell); getopt
# upstream: https://www.gnu.org/software/libtool/

_libtool2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--silent[silent]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--features[show features]' \
        '--mode=+[mode]:m:(clean compile execute finish install link uninstall)' \
        '--tag=+[t]:t:(CC CXX F77 FC GCJ RC GO)' \
        '--config[show config]' \
        '--dry-run[dry run]' \
        '-n[dry run]' \
        '--preserve-dup-deps[preserve duplicate deps]' \
        '--no-suppress[no suppress]' \
        '--no-warn=+[category]:str:' \
        '--no-finish[no finish]' \
        '-o+[output file]:file:_files' \
        '*::'
}

_libtool2 "$@"
