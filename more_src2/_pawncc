#compdef pawncc
# =============================================================================
# pawncc — the Pawn compiler.  Pawn (formerly "Small") is a simple,
#          typeless, 32-bit / 64-bit scripting language from ITB CompuPhase
#          designed for embedding inside larger host applications.  Pawn
#          compiles to a compact bytecode for a minimal "abstract machine"
#          (AMX) that is trivial to embed in C/C++ host programs — 30-50
#          KB of host-side code added per AMX runtime.  Best known as the
#          scripting language for SA-MP / OpenMP (San Andreas Multi-Player,
#          a massively-multiplayer mod for Grand Theft Auto: San Andreas
#          that has powered tens of thousands of fan-run game servers for
#          two decades), but also used in industrial control systems, IoT
#          firmware, and educational settings.  Originally developed in
#          the 1990s for embedded MS-DOS systems where every byte of AMX
#          runtime mattered; still maintained by Thiadmer Riemersma at
#          CompuPhase.
#
# Author:  Thiadmer Riemersma (ITB CompuPhase) — Dutch engineer, original
#          designer of the language since the early-1990s "Small" days
# Source:  https://github.com/compuphase/pawn
# CLI:     compiler/sc1.c — `parseoptions()` (hand-rolled C switch-based
#          option parsing — single-character options with attached args,
#          three value separators, DOS-and-POSIX-friendly prefix support)
# Library: Custom hand-rolled C in compiler/sc1.c `parseoptions()`
#          ("Single-character attached-value option grammar with three-
#           separator support (-d0 / -d=0 / -d:0 all equivalent) plus
#           [+/-] toggle-suffix and sym=val constant-definition shortcuts")
# License: Apache 2.0
# Status:  Stable — 575+ stars on compuphase/pawn; ~30+ years of active
#          development; SA-MP/OpenMP fan-server community of tens of
#          thousands of servers depends on pawncc; also used in industrial
#          control by AlliedModders (SourceMod's spcomp is a Pawn fork).
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 60TH DOCUMENTED LANGUAGE
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# its 60TH LANGUAGE (Pawn, via pawncc).  Pawn joins the taxonomy as the
# FIRST embeddable-bytecode language whose hand-rolled CLI grammar
# encodes design choices specific to its ~30-year MS-DOS-to-modern
# evolution: attached-value single-letter options with three value-
# separators, switch-toggle [+/-] suffix syntax, DOS slash-prefix
# support alongside POSIX dash-prefix, and `sym=val` raw-constant
# definitions interleaved with options.  This is the SIXTIETH-LANGUAGE
# MILESTONE — a round-number achievement after 59 prior languages
# documented.  New language tally: 60.  Top-language tally remains
# Rust=34 / Go=34 / TS-Node=34 (THREE-WAY TIE).  Taxonomy now spans
# 248 cross-language CLI library variants across 60 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS PAWNCC'S CLI GRAMMAR AND WHY IS IT THE 60TH DOCUMENTED LANGUAGE?
#
# pawncc's option parser is **hand-rolled C in `compiler/sc1.c`'s
# `parseoptions()` function** — no library dependency, just a single
# big switch statement over `argv[i][1]` with helper functions for
# value extraction.  Despite being hand-rolled, the GRAMMAR Thiadmer
# Riemersma chose for Pawn's CLI is highly distinctive and reflects
# the language's 30-year history embedded in CompuPhase's industrial
# control / DOS-era scripting environments.
#
# Pawn's CLI grammar is DISTINCT from every documented CLI library on
# SIX specific axes:
#
#   1. ATTACHED-VALUE SINGLE-LETTER OPTIONS (NO SPACE) AS THE NORM —
#      Pawn's options REQUIRE the value attached to the option letter,
#      with NO INTERVENING SPACE permitted by default:
#         pawncc -A4 file.p             # data alignment = 4 bytes
#         pawncc -C64 file.p            # 64-bit cell size
#         pawncc -d2 file.p             # debug level 2
#         pawncc -ifoo/include file.p   # include dir = foo/include
#         pawncc -oOUT_FILE file.p      # output base name = OUT_FILE
#         pawncc -O3 file.p             # optimization level 3
#         pawncc -S8192 file.p          # stack/heap size = 8192 cells
#         pawncc -Tconfig.cfg file.p    # config file = config.cfg
#      Compare:
#        getopt_long (POSIX):  short opts may take next argv slot,
#                               e.g. `-o output` (space allowed)
#        clap-derive (Rust):   `-o output` and `-o=output` both work
#        cobra (Go):           `-o output` (space allowed)
#        argparse (Python):    `-o output` (space allowed)
#        pawncc:               `-oOUTPUT` (NO SPACE) is the default;
#                               space-separation is NOT supported.
#      This is the **TIGHT-COUPLED-VALUE convention** inherited from
#      Borland Turbo C compilers of the late 1980s where the DOS
#      command-line was 128 bytes and saving bytes mattered.  Modern
#      compilers (gcc, clang) maintain this convention for backward
#      compatibility (`-O3`, `-Wno-foo`, `-Iinclude` all attached).
#
#   2. THREE EQUIVALENT VALUE SEPARATORS (-d0 / -d=0 / -d:0) — when an
#      explicit separator IS supplied between option and value, Pawn
#      accepts **THREE different separators interchangeably**:
#         pawncc -d0 file.p              # no separator
#         pawncc -d=0 file.p             # equals separator
#         pawncc -d:0 file.p             # colon separator
#      All three are equivalent per the README:
#         "Options with a value may optionally separate the value from
#          the option letter with a colon (":") or an equal sign ("=").
#          That is, the options "-d0", "-d=0" and "-d:0" are all
#          equivalent."
#      Compare:
#        getopt_long:    `--long=value` only
#        clap-derive:    `--long=value` and `--long value`
#        cobra:          `--long=value` and `--long value`
#        Virgil R501:    `-name=value` and `-name value` (consumeNext)
#        pawncc:         THREE SEPARATORS — `=`, `:`, and ATTACHED
#                         (no separator).
#      The `:` separator reflects the **VMS / Borland Turbo Pascal**
#      heritage of the language — Turbo Pascal compiler options used
#      `:` as the canonical separator (e.g. `tpc /A:8 program.pas`).
#
#   3. SWITCH-TOGGLE [+/-] SUFFIX SYNTAX FOR BOOLEAN OPTIONS — Pawn
#      uses `[+/-]` SUFFIX TO TOGGLE certain boolean-style options:
#         pawncc -;+ file.p              # require semicolons (+)
#         pawncc -;- file.p              # don't require semicolons (-)
#         pawncc -(+ file.p              # require fn-call parens (+)
#         pawncc -(- file.p              # don't require parens (-)
#      The default state is shown in `pawncc -h` output as `(default=+)`
#      or `(default=-)`.  This is the **TURBO-PASCAL TOGGLE CONVENTION**:
#      a switch character followed by `+` (on) or `-` (off).  Compare:
#        argparse (Py):   `--foo` / `--no-foo` (kwarg negation)
#        clap-derive:     `--foo` / `--no-foo` (action="negatable")
#        cobra:           `--foo=true` / `--foo=false` or `--foo`
#                          + `--no-foo` separately registered
#        pawncc:          `-;+` / `-;-` — UNIQUE TOGGLE-SUFFIX syntax.
#      The `;` and `(` are NOT typical option-name characters but Pawn
#      uses single non-alphanumeric characters as option NAMES because
#      its language-level features (semicolon-requirement, paren-
#      requirement) need terse one-character switches.
#
#   4. `sym=val` RAW-CONSTANT-DEFINITION SHORTCUT (NO DASH PREFIX) —
#      Pawn uniquely accepts `sym=val` on the command line WITHOUT a
#      leading dash to define COMPILE-TIME CONSTANTS that the Pawn
#      source code sees as immutable globals:
#         pawncc DEBUG=1 MAX_PLAYERS=100 file.p
#         # — equivalent to source `const DEBUG = 1; const MAX_PLAYERS = 100;`
#      Compare:
#        gcc/clang:    `-DSYMBOL=value` (preprocessor define, dashed)
#        rustc:        `--cfg feature="..."` (verbose, dashed)
#        scalac:       `-Dsym=val` (dashed)
#        pawncc:       `sym=val` (UNDASHED — constant assignment IS
#                       the bare-argument syntax)
#      This blurs the line between "compiler options" and "source-
#      level constants" — Pawn treats them uniformly.  Reflects the
#      embedded-scripting use case where the HOST application is
#      typically passing configuration in via the command line to
#      the bytecode compiler.
#
#   5. DOS-SLASH-PREFIX SUPPORT ALONGSIDE POSIX-DASH — Pawn accepts
#      both `-d0` and `/d0` interchangeably on DOS / Windows builds:
#         pawncc /d0 file.p              # debug level 0 (DOS-style)
#         pawncc -d0 file.p              # same (POSIX-style)
#      Compare:
#        go-flags R503:    POSIX + DOS support (forceposix build tag)
#        getopt_long:      POSIX only
#        clap-derive:      POSIX only
#        pawncc:           POSIX + DOS, decided at compile-time of
#                           pawncc itself (no runtime toggle — the
#                           build configures which prefix set is
#                           accepted).
#      Reflects Pawn's MS-DOS heritage where `/` was the canonical
#      switch prefix.  go-flags R503 is the closest analog among
#      documented CLI libraries — but go-flags makes the choice
#      runtime-toggleable; Pawn bakes it into the build.
#
#   6. POSITIONAL FILES BEFORE OR AFTER OPTIONS — Pawn permits the
#      file argument(s) to appear **AT ANY POSITION** in the command
#      line, mixed with options:
#         pawncc file.p -d2 -O3                  # files first
#         pawncc -d2 file.p -O3                  # files middle
#         pawncc -d2 -O3 file.p                  # files last
#         pawncc -d2 file1.p -O3 file2.p         # interleaved
#      The parser distinguishes options (any argv starting with `-`
#      or `/`) from files (anything else) AT EACH POSITION.  Compare:
#        clap-derive:      `--` terminator required for files-after-
#                           options on most options
#        cobra:            Flag position usually restricted
#        argparse (Py):    nargs='*' positional consumes everything
#        flaggy (Go):      flags-at-any-position is a documented
#                           feature (similar to pawncc)
#        pawncc:           Always allows interleaving — UNRESTRICTED
#                           position for files.
#      This makes scripted Pawn invocations easier — a Makefile can
#      build up the command line incrementally without worrying about
#      option/file ordering.
#
# THE pawncc CLI SURFACE (verbatim from compiler/sc1.c about() function)
#
#   Usage: pawncc <filename> [filename...] [options]
#
#   -A<num>     alignment in bytes of the data segment and the stack
#   -a          output assembler code
#   -C<num>     cell size in bits (default = -C32 or -C64)
#   -c<name>    codepage name or number (e.g. 1252 for Windows Latin-1)
#   -Dpath      active directory path (DOS builds only)
#   -d<num>     debugging level (default = -d1):
#                   0   no symbolic info, no run-time checks
#                   1   run-time checks, no symbolic information
#                   2   full debug information and dynamic checking
#                   3   same as -d2, but implies -O0
#   -e<name>    set name of error file (quiet compile)
#   -i<name>    path for include files
#   -k<hex>     key for encrypted scripts
#   -l          create list file (preprocess only)
#   -N<name>=<num>  specify index number for native function
#   -o<name>    set base name of (P-code) output file
#   -O<num>     optimization level (default = -O1):
#                   0   no optimization
#                   1   core instruction set (JIT-compatible)
#                   2   supplemental instruction set
#                   3   full instruction set (packed opcodes)
#   -p<name>    set the "prefix" file; omit name to block default prefix
#   -r[name]    write cross-reference report to console or to FILE
#                   (PAWN_LIGHT build excludes this option)
#   -S<num>     stack/heap size in cells (default = 4096)
#   -s<num>     skip lines from the input file
#   -t<num>     TAB indent size (default = 8)
#   -T<name>    set name of the configuration file to use
#   -V<num>     generate overlay code and instructions; set buffer size
#   -v<num>     verbosity level: 0=quiet, 1=normal, 2=verbose (default=1)
#   -w<num>     disable a specific warning by its number
#   -X<num>     abstract machine size limit in bytes
#   -XD<num>    abstract machine data/stack size limit in bytes
#   -\          use '\' for escape characters (Pawn syntax variation)
#   -^          use '^' for escape characters (Pawn syntax variation)
#   -;[+/-]     require a semicolon to end each statement
#                   (default = - / no semicolon required for one-liners)
#   -([+/-]     require parentheses for function invocation
#                   (default = - / Pawn-classic procedure-call syntax)
#   sym=val     define a compile-time constant "sym" with value "val"
#   sym=        define a compile-time constant "sym" with value 0
#
# Three-separator rule:
#   For all <num>/<name>-bearing options, the separator between option
#   and value is OPTIONAL.  These three are equivalent:
#     -d0       (no separator)
#     -d=0      (equals)
#     -d:0      (colon)
#
# Prefix:
#   On POSIX: only `-` works.
#   On DOS / Windows builds: both `-` and `/` work interchangeably.
#
# Typical usage:
#   $ pawncc gamemode.pwn -d2 -O3 -i/usr/share/pawn/include
#   $ pawncc gamemode.pwn DEBUG_MODE=1 MAX_PLAYERS=1000
#   $ pawncc -;+ -(- gamemode.pwn          # require ; + don't require ()
#   $ pawncc -e errors.log gamemode.pwn    # quiet compile, log errors
#
# Related Pawn binaries:
#   pawndisasm  AMX bytecode disassembler (also in compuphase/pawn,
#               compiler/pawndisasm.c) — disassembles .amx files to
#               human-readable mnemonic listing.
#   pawnrun     Minimal AMX host that runs .amx files standalone (for
#               testing scripts without a host application).
#   pawndbg     Source-level debugger that attaches to AMX runtime via
#               debugger remote-protocol (used by SA-MP server scripts).
#
# Related Pawn forks:
#   spcomp      AlliedModders' SourcePawn compiler (Half-Life 2 / Source
#               engine modding via SourceMod plugin framework).  Forked
#               from Pawn ~2006 with extensive divergence — different
#               binary, similar CLI grammar.
#   pawn-lang   community fork at pawn-lang/pawn that maintains
#               SA-MP-flavored Pawn separately from CompuPhase's
#               upstream.
#
# PAWN LANGUAGE TIES TO BORLAND TURBO C / TURBO PASCAL:
#
# Pawn's language design and CLI grammar BOTH reflect Thiadmer Riemersma's
# background at Borland in the 1980s and at CompuPhase building industrial
# control software in the 1990s.  The CLI's tight-coupled attached values,
# three-separator support, [+/-] toggle suffix, and `sym=val` constant
# definition are all idioms borrowed from Borland Turbo C / Turbo Pascal /
# Delphi.  Modern Pawn users coming from gcc/clang/rustc often need to
# unlearn the space-separation habit ("pawncc -o output" doesn't work —
# it must be "pawncc -ooutput").
#
# -----------------------------------------------------------------------------
# REAL-WORLD PAWNCC USERS (from upstream + community):
# -----------------------------------------------------------------------------
#
#   * SA-MP (San Andreas Multi-Player) — the original mass-adopter; tens
#     of thousands of GTA: San Andreas fan-servers built Pawn-coded
#     game-modes for two decades.
#   * OpenMP (open.mp) — the modern community successor to SA-MP after
#     SA-MP's main servers were taken down; still uses Pawn as the
#     server-side scripting language.
#   * AMX Mod X — Counter-Strike 1.6 / Half-Life 1 server-mod platform;
#     uses a Pawn fork (AMX Mod X scripting language) for plugins.
#   * SourceMod (alliedmodders/sourcemod) — Half-Life 2 / Source-engine
#     server mod; uses SourcePawn (spcomp), a Pawn fork.
#   * Industrial control: CompuPhase ships Pawn in commercial industrial-
#     control software for embedded systems where Lua is too heavyweight.
#   * Educational: Pawn is occasionally used in teaching embedded
#     scripting concepts because the AMX VM is ~600 lines of C that
#     students can read end-to-end.
#
# =============================================================================

_pawncc() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    # Pawn options use ATTACHED-VALUE syntax (-A4, -d2, -O3).  zsh _arguments
    # works best with the `-NAME[descr]:VAR:` form for prefix completion of
    # numeric / string suffixes.  We list the common ones explicitly.
    _arguments -C \
        '-A-[data segment / stack alignment in bytes]:bytes:' \
        '-a[output assembler code]' \
        '-C-[cell size in bits]:bits:(16 32 64)' \
        '-c-[codepage name or number]:codepage:' \
        '-D-[active directory path]:dir:_directories' \
        '-d-[debugging level]:level:(0 1 2 3)' \
        '-e-[error log file name]:file:_files' \
        '-i-[include path]:dir:_directories' \
        '-k-[encryption key (hex)]:hex:' \
        '-l[create list file (preprocess only)]' \
        '-N-[set native function index (NAME=NUM)]:spec:' \
        '-o-[output base name]:name:' \
        '-O-[optimization level]:level:(0 1 2 3)' \
        '-p-[prefix file name]:file:_files' \
        '-r-[cross-reference report file]:file:_files' \
        '-S-[stack/heap size in cells]:cells:' \
        '-s-[skip N input lines]:n:' \
        '-t-[TAB indent size]:n:' \
        '-T-[configuration file]:file:_files' \
        '-V-[overlay buffer size]:n:' \
        '-v-[verbosity level]:level:(0 1 2)' \
        '-w-[disable warning by number]:num:' \
        '-X-[abstract machine size limit (bytes)]:bytes:' \
        '-XD-[AMX data/stack size limit (bytes)]:bytes:' \
        '-\\[use backslash for escape character]' \
        '-^[use caret for escape character]' \
        '*:pawn file:_files -g "*.(p|pwn|inc)"' && ret=0

    return ret
}

_pawncc "$@"
