#compdef diskutil
# Documentation: https://www.unix.com/man-page/osx/8/diskutil/
# Source: Apple macOS — Disk Utility.app CLI backend (disk / volume / APFS / AppleRAID / CoreStorage).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'list:list disks and their partitions'
            'info:detailed info about a whole disk or partition'
            'eject:eject a disk (make offline)'
            'mount:mount a single volume'
            'mountDisk:mount all mountable volumes on a disk'
            'umount:unmount a single volume'
            'umountDisk:unmount all volumes on a disk'
            'rename:rename a volume'
            'partitionDisk:repartition disk (removes all volumes)'
            'eraseDisk:erase disk with new partitioning scheme'
            'eraseVolume:erase a volume (or create empty filesystem)'
            'secureErase:securely erase whole-disk or free space'
            'splitPartition:destructively split a volume into multiple partitions'
            'mergePartitions:merge two or more partitions on a disk'
            'resizeVolume:non-destructively resize a volume'
            'repairDisk:repair the partition-map layout'
            'verifyDisk:verify the partition-map layout'
            'repairVolume:repair file-system data structures'
            'verifyVolume:verify file-system data structures'
            'repairPermissions:repair permissions of a boot volume'
            'appleRAID:manage Software RAID volumes'
            'ap:APFS subcommands (alias)'
            'apfs:APFS subcommands'
            'coreStorage:manage CoreStorage volumes'
            'cs:CoreStorage subcommands (alias)'
        )
        _describe -t subcmds 'diskutil command' subcmds && ret=0
        ;;
    args)
        _default
        ;;
esac

return ret
