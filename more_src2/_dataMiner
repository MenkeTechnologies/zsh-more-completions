_dataMiner() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a subcmds
    subcmds=(
        'Sampledata:full database sampling module (alias: SD)'
        'SD:alias for Sampledata'
        'SampleSingleDatabase:specified database sampling module (alias: SSD)'
        'SSD:alias for SampleSingleDatabase'
        'Overview:database data volume statistics module (alias: OV)'
        'OV:alias for Overview'
        'SearchSensitiveData:database sensitive data capture via custom regex (alias: SS)'
        'SS:alias for SearchSensitiveData'
        'SingleTable:single table sampling module (alias: ST)'
        'ST:alias for SingleTable'
        'help:show help for a subcommand'
    )

    _arguments -C \
        '(-T --databaseType)'{-T,--databaseType=}'[database type]:type:(mysql mssql oracle mongo postgre)' \
        '(-da --databaseAddress)'{-da,--databaseAddress=}'[database address (host:port)]:host\:port:' \
        '(-du --databaseUser)'{-du,--databaseUser=}'[database username]:username:' \
        '(-dp --databasePassword)'{-dp,--databasePassword=}'[database password]:password:' \
        '(-dn --databaseName)'{-dn,--databaseName=}'[database name (for single-DB sampling)]:database name:' \
        '(-ds --databaseSchema)'{-ds,--databaseSchema=}'[database schema (optional, for postgre single-table)]:schema:' \
        '(-dt --databaseTable)'{-dt,--databaseTable=}'[database.table for single-table sampling]:database.table:' \
        '(-pa --proxyAddress)'{-pa,--proxyAddress=}'[SOCKS5 proxy address (host:port)]:host\:port:' \
        '(-pu --proxyUser)'{-pu,--proxyUser=}'[proxy username]:user:' \
        '(-pp --proxyPassword)'{-pp,--proxyPassword=}'[proxy password]:password:' \
        '(-n --num)'{-n,--num=}'[number of records to sample (default 3)]:n:' \
        '(-t --thread)'{-t,--thread=}'[thread count for SearchSensitiveData (default 5)]:n:' \
        '(-p --pattern)'{-p,--pattern=}'[custom Perl-flavor regex for SearchSensitiveData (e.g. ^[\\\\x{4e00}-\\\\x{9fa5}]{2,4}$)]:pattern:' \
        '(-tf --tnsFile)'{-tf,--tnsFile=}'[tnsnames.ora path (Oracle only)]:file:_files -g "*(.ora|tnsnames)"' \
        '(-WA --WindowsAuth)'{-WA,--WindowsAuth}'[use Windows authentication (MSSQL only)]' \
        '(-f --fileInput)'{-f,--fileInput=}'[batch DB connection file (one URL per line: schema://user:pass@host\:port)]:file:_files -g "*.(txt|csv)"' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)--version[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            _describe -t commands 'DataMiner command' subcmds && ret=0
            ;;
        args)
            case $line[1] in
                help)
                    _describe -t commands 'DataMiner command' subcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_dataMiner "$@"
