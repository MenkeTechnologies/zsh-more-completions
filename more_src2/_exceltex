#compdef exceltex
# Documentation: https://ctan.org/pkg/exceltex
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exceltex: Perl helper that imports spreadsheet data into LaTeX
# (haped/exceltex; man page: exceltex(1)).

local -a arguments

arguments=(
    '(-c --cleanup)'{-c,--cleanup}'[remove temporary files from previous runs]'
    '(-h --help)'{-h,--help}'[show help]'
    '(-v --version)'{-v,--version}'[show version]'
    '(-e --encoding)'{-e+,--encoding=}'[input encoding]:encoding:'
    '(-i --ignore-warnings)'{-i,--ignore-warnings}'[ignore warnings]'
    '(-o --euro-symbol)'{-o+,--euro-symbol=}'[euro currency symbol]:symbol:'
    '--reformat-sn[reformat scientific notation]'
    '--no-reformat-sn[do not reformat scientific notation]'
    '--comma[use comma as decimal separator]'
    '--no-comma[do not use comma as decimal separator]'
    '*:TeX file:_files -g "*.tex"'
)

_arguments -s -S $arguments
