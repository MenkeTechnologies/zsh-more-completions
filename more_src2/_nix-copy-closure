#compdef nix-copy-closure
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-copy-closure
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--to[copy closure to remote machine]' \
  '--from[copy closure from remote machine]' \
  '--gzip[enable SSH connection compression]' \
  '--include-outputs[also copy outputs of store derivations]' \
  '(-s --use-substitutes)'{-s,--use-substitutes}'[attempt to download missing store objects from substituters]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:store paths:_files' && ret=0

return ret
