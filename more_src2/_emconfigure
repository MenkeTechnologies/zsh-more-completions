#compdef emconfigure
# Documentation: https://emscripten.org/docs/compiling/Building-Projects.html
# Reference accessed: 2026-06-10

# Zsh completion for emconfigure - Emscripten configure wrapper
# emconfigure wraps ./configure (or cmake, etc.) setting CC=emcc, CXX=em++, etc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:configure command:_files -g "*configure*"' \
  '*::configure args:_normal' && ret=0

return ret
