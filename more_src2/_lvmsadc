#compdef lvmsadc
# Documentation: https://man7.org/linux/man-pages/man8/lvmsadc.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lvmsadc: read-only LVM statistics collector (deprecated)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '-d[debug level]:level:' \
  '*:VG name:' && ret=0
return ret
