#compdef mount_union
# Documentation: man mount_union(8)
# Source: netbsd/src sbin/mount_union — mount a union file system layer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[reverse layer order (directory becomes lower layer)]' \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '1:directory (upper layer by default):_files -/' \
    '2:union mount point:_files -/' \
    && ret=0

return ret
