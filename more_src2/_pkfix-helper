#compdef pkfix-helper
# Documentation: pkfix-helper --help
# Source: help pkfix(1) reconstruct font usage in an old PostScript document.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
    '(-q --quiet)'{-q,--quiet}'[decrease verbosity]' \
    '*'{-f+,--force=}'[force font association name=fontspec]:assignment:' \
    '--ps=[input PostScript file]:file:_files -g "*.ps"' \
    '--tex=[input TeX file]:file:_files -g "*.tex"' \
    '--cache=[cache filename]:file:_files' \
    '*--include=[restrict to matching fontspec]:fontspec:' \
    '*--exclude=[skip fonts matching regex]:regex:' \
    '*--keep=[keep specified fontspec as-is]:fontspec:' \
    '--no-repeats[do not repeat font associations]' \
    '--spp=[samples per point]:number:' \
    '1:input ps:_files -g "*.ps"' \
    '2:output ps:_files -g "*.ps"' \
    && ret=0

return ret
