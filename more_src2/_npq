#compdef npq
# Documentation: https://github.com/lirantal/npq/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--dry-run[run checks only without installing]' \
  '--plain[force non-rich text output]' \
  '--disable-auto-continue[require explicit confirmation; skip 15s countdown]' \
  '*: :' && ret=0

return ret
