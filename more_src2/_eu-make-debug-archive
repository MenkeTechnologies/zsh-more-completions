#compdef eu-make-debug-archive
# _eu-make-debug-archive — elfutils make-debug-archive helper; bundle separate .debug files into archive for distribution
# upstream: https://sourceware.org/elfutils

_eu-make-debug-archive() {
    _arguments \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-make-debug-archive "$@"
