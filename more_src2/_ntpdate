#compdef ntpdate
# _ntpdate — ntp-project ntpdate (legacy one-shot clock-set utility; queries one or more NTP servers and sets the system time via settimeofday or adjtime)
# upstream: https://github.com/ntp-project/ntp
# Flags from ntpdate/ntpdate.c getopt on tip.

_ntpdate() {
    _arguments \
        '(-4 -6)-4[force IPv4]' \
        '(-4 -6)-6[force IPv6]' \
        '-a+[enable authentication with key number]:keynum:' \
        '(-B)-b[always step the clock]' \
        '(-b)-B[never step the clock — always slew]' \
        '*-d[debug mode (repeatable, do not set clock)]' \
        '-e+[authentication-delay processing time (sec)]:dur:' \
        '-k+[key file for -a]:file:_files' \
        '-o+[NTP protocol version to send]:n:' \
        '-p+[number of samples per server (1-8)]:n:' \
        '-q[query-only mode (do not set clock)]' \
        '-s[log results via syslog]' \
        '-t+[per-server timeout (sec)]:sec:' \
        '-u[use an unprivileged source port]' \
        '-v[verbose output]' \
        '*:server:_hosts'
}

_ntpdate "$@"
