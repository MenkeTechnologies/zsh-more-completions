#compdef fftw-wisdom
# Documentation: https://www.fftw.org/fftw3_doc/Wisdom.html
# Source: FFTW/fftw3 tools/fftw-wisdom.c — generate FFTW wisdom for transform sizes (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    {-V,--version}'[show version]' \
    {-v,--verbose}'[verbose output]' \
    {-c,--canonical}'[generate canonical wisdom set]' \
    {-t+,--time-limit=}'[time limit in seconds]:seconds:_default' \
    {-o+,--output-file=}'[output wisdom file]:file:_files' \
    '(--measure --estimate --exhaustive -m -e -x)'{-i,--impatient}'[use impatient planning]' \
    '(--impatient --estimate --exhaustive -i -e -x)'{-m,--measure}'[use measure planning]' \
    '(--impatient --measure --exhaustive -i -m -x)'{-e,--estimate}'[use estimate planning]' \
    '(--impatient --measure --estimate -i -m -e)'{-x,--exhaustive}'[use exhaustive planning]' \
    {-n,--no-system-wisdom}'[do not import system wisdom]' \
    {-w+,--wisdom-file=}'[load wisdom file]:file:_files' \
    {-T+,--threads=}'[number of threads]:n:_default' \
    '*:transform size spec (e.g. cof1024 rof512):_default' \
    && ret=0

return ret
