#compdef deark
# Documentation: https://github.com/jsummers/deark/blob/master/readme.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for Deark file decoder / converter

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-d+[output directory]:dir:_directories' \
  '-id[identify files only]' \
  '-q[quiet]' \
  '-v[verbose diagnostics]' \
  '*:input:_files' && ret=0

return ret
