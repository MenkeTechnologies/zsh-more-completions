#compdef pacman-key
# Documentation: https://man.archlinux.org/man/pacman-key.8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pacman-key - pacman keyring management

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--init[initialize the keyring]' \
  '(-l --list-keys)'{-l,--list-keys}'[list keys]' \
  '--list-sigs[list keys and signatures]' \
  '(-a --add)'{-a,--add}'[add keys from file]:key file:_files' \
  '(-r --recv-keys)'{-r,--recv-keys}'[receive keys from keyserver]:key IDs' \
  '(-d --delete)'{-d,--delete}'[delete keys]:key IDs' \
  '(-e --export)'{-e,--export}'[export keys]:key IDs' \
  '(-f --finger)'{-f,--finger}'[list fingerprints]:key IDs' \
  '(-u --updatedb)'{-u,--updatedb}'[update trust database]' \
  '--refresh-keys[refresh keys from keyserver]' \
  '--populate[populate keyring from installed keyrings]:keyrings' \
  '--lsign-key[locally sign a key]:key ID' \
  '(-v --verify)'{-v,--verify}'[verify a signature]:signature file:_files' \
  '--edit-key[edit a key]:key ID' \
  '--import[import keys from pubring.gpg]:dir:_directories' \
  '--import-trustdb[import a trustdb]:dir:_directories' \
  '--nocolor[disable colored output]' \
  '--gpgdir=[GPG home directory]:directory:_directories' \
  '--keyserver=[keyserver URL]:keyserver' \
  '--config=[pacman config file]:config file:_files'
