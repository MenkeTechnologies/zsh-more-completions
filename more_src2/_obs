#compdef obs
# Documentation: https://obsproject.com/kb/launch-parameters
# Reference accessed: 2026-05-19
# Verified: obs --help on local install (Homebrew obs 31.x).
# Real flags: --help/-h, --version/-V, --multi/-m, --startstreaming,
# --startrecording, --startreplaybuffer, --startvirtualcam,
# --collection, --profile, --scene, --studio-mode,
# --minimize-to-tray, --safe-mode, --only-bundled-plugins,
# --verbose, --always-on-top, --unfiltered_log, --disable-updater,
# --disable-missing-files-check. (No --portable, no
# --disable-shutdown-check in obs --help — those are
# Windows-only / removed.)

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[show help]'
    '(- *)'{-V,--version}'[show version]'
    '--startstreaming[start streaming on launch]'
    '--startrecording[start recording on launch]'
    '--startvirtualcam[start virtual camera on launch]'
    '--startreplaybuffer[start replay buffer on launch]'
    '--collection[set scene collection]:collection:'
    '--profile[set profile]:profile:'
    '--scene[set starting scene]:scene:'
    '--studio-mode[enable studio mode]'
    '--minimize-to-tray[minimize to system tray]'
    '(-m --multi)'{-m,--multi}'[allow multiple instances]'
    '--always-on-top[start always on top]'
    '--verbose[verbose logging]'
    '--unfiltered_log[unfiltered log output]'
    '--disable-updater[disable built-in updater]'
    '--safe-mode[start in safe mode]'
    '--only-bundled-plugins[only load bundled plugins]'
    '--disable-missing-files-check[disable missing files check]'
)

_arguments -s -S $arguments
