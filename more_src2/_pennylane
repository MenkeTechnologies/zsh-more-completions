#compdef pennylane pennylane-cli pl
# _pennylane — Xanadu PennyLane Python framework for differentiable programming of quantum computers (PennyLaneAI team, Python); argparse
# upstream: https://github.com/PennyLaneAI/pennylane

_pennylane() {
    local -a sub=(
        'plugins:list installed plugins'
        'devices:list available devices'
        'run:run a quantum circuit'
        'train:train a quantum model'
        'optimize:optimize a circuit'
        'transform:apply circuit transform'
        'simulate:run on local simulator'
        'jit:JIT compile a quantum function'
        'catalyst:run with Catalyst compiler'
        'visualize:render circuit drawing'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--device=+[device]:d:(default.qubit default.mixed default.qutrit lightning.qubit lightning.gpu lightning.kokkos braket.local.qubit qiskit.aer qiskit.basicaer cirq.simulator cirq.mixedsimulator)' \
        '-d+[device]:str:' \
        '--wires=+[N]:n:' \
        '-w+[N]:n:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--diff-method=+[method]:m:(adjoint backprop parameter-shift finite-diff hadamard reversible)' \
        '--interface=+[interface]:i:(autograd jax torch tf numpy)' \
        '--optimizer=+[optimizer]:o:(GradientDescent Adam Adagrad RMSProp Momentum Nesterov AdaBelief QNG SPSA Rotosolve Rotoselect ShotAdaptive QHM Nesterov)' \
        '--steps=+[N]:n:' \
        '--learning-rate=+[F]:f:' \
        '--seed=+[seed]:n:' \
        '--no-grad[no gradient]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pennylane subcommand' sub ;;
        args)
            case $words[1] in
                catalyst) _arguments \
                    '--target=+[target]:t:(jax mlir hlo qjit asm binary)' \
                    '--optimization-level=+[level]:l:(0 1 2 3)' \
                    '*:script:_files -g "*.py"' ;;
                jit) _arguments \
                    '--autograph=+[bool]:b:(true false)' \
                    '*:function:_files -g "*.py"' ;;
                run|simulate) _arguments '*:circuit:_files -g "*.py *.qasm *.json"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_pennylane "$@"
