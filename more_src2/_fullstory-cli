#compdef fullstory-cli fullstory
# _fullstory-cli — FullStory fullstory-cli CLI command-line frontend wrapping the FullStory Digital Experience Intelligence DXI session-replay product-analytics platform REST API managing sessions users events segments custom-events properties signals notebooks dashboards funnels conversions journeys video-bookmarks pages bots (FullStory team, Go); cobra
# upstream: https://www.fullstory.com/

_fullstory-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'user:user operations'
        'session:session operations'
        'event:custom event operations'
        'segment:segment operations'
        'signal:signal operations'
        'note:note operations'
        'dashboard:dashboard operations'
        'funnel:funnel operations'
        'conversion:conversion operations'
        'journey:journey operations'
        'pages:page list'
        'properties:user property operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--org-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fullstory-cli subcommand' sub ;;
        args)
            case $words[1] in
                user|session|event|segment|signal|note|dashboard|funnel|conversion|journey|properties) _arguments '1:op:(list get create update delete export search identify suspend resume)' '*:id:' ;;
            esac
            ;;
    esac
}

_fullstory-cli "$@"
