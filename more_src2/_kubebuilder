#compdef kubebuilder
# Documentation: https://github.com/kubernetes-sigs/kubebuilder/tree/master/pkg/plugins/golang/v4
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (go/v4 plugin and pkg/cli).

_kubebuilder_commands() {
  local -a commands=(
    'init:Initialize a new project'
    'create:Scaffold a Kubernetes API or webhook'
    'edit:Update the project configuration'
    'alpha:Alpha-stage subcommands'
    'version:Print the kubebuilder version'
    'completion:Generate shell completion scripts'
    'help:Help about any command'
  )
  _describe 'command' commands
}

_kubebuilder_create_commands() {
  local -a commands=(
    'api:Scaffold a Kubernetes API'
    'webhook:Scaffold a webhook for an API resource'
  )
  _describe 'command' commands
}

_kubebuilder() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '--plugins=[plugin keys to be used for this subcommand execution]:plugins' \
    '--project-version=[project version]:version' \
    '(-h --help)'{-h,--help}'[help for kubebuilder]' \
    '1:command:_kubebuilder_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        init)
          _arguments \
            '--domain=[domain for your APIs]:domain' \
            '--repo=[Go module name]:repo' \
            '--skip-go-version-check[skip Go version check]' \
            '--fetch-deps[fetch dependencies after scaffolding]' \
            '--license=[license to use for headers]:license' \
            '--license-file=[path to a license header file]:file:_files' \
            '--owner=[owner name for copyright license headers]:owner' \
            '--plugins=[plugin keys]:plugins' \
            '--project-version=[project version]:version' \
            '(-h --help)'{-h,--help}'[help for init]'
          ;;
        create)
          _arguments -C \
            '1:command:_kubebuilder_create_commands' \
            '*::arg:->create_args'
          case $state in
            create_args)
              case $line[1] in
                api)
                  _arguments \
                    '--group=[resource group]:group' \
                    '--version=[resource version]:version' \
                    '--kind=[resource kind]:kind' \
                    '--plural=[resource plural form]:plural' \
                    '--resource[if set, generate the resource]' \
                    '--controller[if set, generate the controller]' \
                    '--controller-name=[custom controller name]:name' \
                    '--namespaced[resource is namespaced]' \
                    '--make[run make after generating]' \
                    '--force[attempt to create resource even if it already exists]' \
                    '--external-api-path=[Go package import path of an external API type]:path' \
                    '--external-api-domain=[domain of the external API type]:domain' \
                    '--external-api-module=[Go module of the external API type]:module' \
                    '(-h --help)'{-h,--help}'[help for api]'
                  ;;
                webhook)
                  _arguments \
                    '--group=[resource group]:group' \
                    '--version=[resource version]:version' \
                    '--kind=[resource kind]:kind' \
                    '--plural=[resource plural form]:plural' \
                    '--defaulting[scaffold a defaulting webhook]' \
                    '--programmatic-validation[scaffold a validating webhook]' \
                    '--conversion[scaffold a conversion webhook]' \
                    '--defaulting-path=[path of the defaulting webhook]:path' \
                    '--validation-path=[path of the validating webhook]:path' \
                    '--legacy[scaffold webhooks under the legacy path]' \
                    '--make[run make after generating]' \
                    '--force[attempt to create webhook even if it already exists]' \
                    '--external-api-path=[Go package import path of an external API type]:path' \
                    '--external-api-domain=[domain of the external API type]:domain' \
                    '--external-api-module=[Go module of the external API type]:module' \
                    '(-h --help)'{-h,--help}'[help for webhook]'
                  ;;
              esac
              ;;
          esac
          ;;
        edit)
          _arguments \
            '--multigroup[enable multi-group layout]' \
            '--namespaced[enable namespaced layout]' \
            '--force[overwrite scaffolded files to apply changes]' \
            '--license=[license to use for headers]:license' \
            '--license-file=[path to a license header file]:file:_files' \
            '--owner=[owner name for copyright license headers]:owner' \
            '(-h --help)'{-h,--help}'[help for edit]'
          ;;
        completion)
          _arguments \
            '1:shell:(bash zsh fish powershell)' \
            '(-h --help)'{-h,--help}'[help for completion]'
          ;;
      esac
      ;;
  esac
}

_kubebuilder "$@"
