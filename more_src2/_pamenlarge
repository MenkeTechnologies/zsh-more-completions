#compdef pamenlarge pnmenlarge
# Documentation: man pamenlarge (Netpbm)
# Source: enlarge a Netpbm image by an integer factor (pixel replication).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-scale=[scale factor]:integer:' \
    '-xscale=[horizontal scale factor]:integer:' \
    '-yscale=[vertical scale factor]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:scale factor or pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
