#compdef epstopdf repstopdf
# Documentation: epstopdf --help (epstopdf 2.36)
# Source: TeX epstopdf — convert EPS to PDF (default via Ghostscript).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '(-o --outfile)'{-o,--outfile=}'[output file]:file:_files -g "*.pdf"' \
    '--restricted[restricted mode]' \
    '(--debug --nodebug)--debug[debug output]' \
    '(--debug --nodebug)--nodebug[no debug output]' \
    '(--exact --noexact)--exact[scan ExactBoundingBox]' \
    '(--exact --noexact)--noexact[do not scan ExactBoundingBox]' \
    '(--filter --nofilter)--filter[read stdin]' \
    '(--filter --nofilter)--nofilter[do not read stdin]' \
    '(--gs --nogs)--gs[use ghostscript]' \
    '(--gs --nogs)--nogs[do not use ghostscript]' \
    '(--hires --nohires)--hires[scan HiResBoundingBox]' \
    '(--hires --nohires)--nohires[do not scan HiResBoundingBox]' \
    '--gscmd=[ghostscript command]:cmd:_command_names -e' \
    '*--gsopt=[single gs option]:opt:' \
    '*--gsopts=[gs options list]:opts:' \
    '--autorotate=[gs -dAutoRotatePages]:val:(None All PageByPage)' \
    '(--compress --nocompress)--compress[use compression]' \
    '(--compress --nocompress)--nocompress[no compression]' \
    '--device=[gs -sDEVICE=DEV]:device:(pdfwrite ps2write epswrite png16m pnggray jpeg)' \
    '(--embed --noembed)--embed[embed fonts]' \
    '(--embed --noembed)--noembed[do not embed fonts]' \
    '(--gray --nogray)--gray[grayscale output]' \
    '(--gray --nogray)--nogray[color output]' \
    '--pdfsettings=[gs -dPDFSETTINGS]:val:(screen ebook printer prepress default)' \
    '(--quiet --noquiet)--quiet[gs -q -dQUIET]' \
    '(--quiet --noquiet)--noquiet[gs verbose]' \
    '--res=[image resolution (DPI or DPIxDPI)]:dpi:' \
    '(--safer --nosafer)--safer[gs -dSAFER]' \
    '(--safer --nosafer)--nosafer[gs -dNOSAFER]' \
    '*:input EPS file:_files -g "*.eps"' \
    && ret=0

return ret
