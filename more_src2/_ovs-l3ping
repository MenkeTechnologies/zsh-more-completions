#compdef ovs-l3ping
# _ovs-l3ping — Open vSwitch ovs-l3ping ping L3 tunnel connectivity testing utility for Open vSwitch (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-l3ping() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-s[run server]' \
        '--server[run server]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-p+[port]:port:_ports' \
        '--port=+[port]:port:_ports' \
        '*:client target IP:_hosts'
}

_ovs-l3ping "$@"
