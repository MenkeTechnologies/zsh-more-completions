#compdef ppmtomitsu
# Documentation: man ppmtomitsu (Netpbm)
# Source: convert a PPM image to a Mitsubishi S340-10 dye-sublimation printer command stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-sharpness+[sharpness value]:val:' \
    '-enlarge+[enlargement value]:val:' \
    '-media+[media type string]:media:' \
    '-copy+[number of copies]:val:' \
    '-dpi300[300 dpi mode]' \
    '-tiny[tiny output mode]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
