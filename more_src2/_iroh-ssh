#
# WHAT IT IS
#   iroh-ssh is "ssh without ip" — instead of dialing a host by
#   IP, you dial it by its iroh `EndpointId` (a public ed25519
#   key) and the iroh DHT + relay mesh handles the rest
#   (UDP-hole-punch first, fall back to QUIC-over-relay).
#   Either side can install itself as a system service so the
#   endpoint is always reachable; the wire format is plain SSH
#   so existing `ssh` clients, scp, sftp, rsync, mosh, and
#   tmux-mirror tools work unchanged — iroh-ssh just opens the
#   QUIC tunnel and shuffles bytes through it.
#
#   The CLI mirrors `ssh(1)`'s short-flag surface (`-i`, `-L`,
#   `-R`, `-p`, `-l`, `-o`, `-A`, `-X`, `-N`, `-t`, `-v`, `-q`)
#   so it can be dropped in as a substitute under any wrapper
#   tool that shells out to ssh — including rsync, git+ssh,
#   ansible, and saltstack.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/cli.rs clap-derive
#                       `Cli` / `Cmd` / `ConnectArgs` / `SshOpts`
#                       / `ServerArgs` / `InfoArgs` / `ServiceCmd`
#                       declarations; extracted via `gh api
#                       repos/rustonbsd/iroh-ssh/contents/src/
#                       cli.rs`)
#
#   iroh-ssh [GLOBAL OPTIONS] [<SUBCOMMAND>] [args...]
#
#   Default (no subcommand) — client mode:
#     iroh-ssh [SSH_OPTS] [<USER>@<ENDPOINT_ID>] [-- <REMOTE_CMD>...]
#
#   Subcommands:
#     connect <USER@ENDPOINT_ID> [SSH_OPTS] [-- <CMD>...]
#                                    Connect to a remote
#                                    iroh-ssh endpoint
#       --relay-url <URL>              Use only these relay
#                                      servers, replacing the
#                                      defaults  (repeatable)
#       --extra-relay-url <URL>        Add relay servers alongside
#                                      the defaults  (repeatable)
#
#     server [--ssh-port <PORT>] [-p|--persist] [--key-dir <DIR>]
#            [--relay-url ...] [--extra-relay-url ...]
#                                    Start iroh-ssh server
#       --ssh-port <PORT>              Local sshd port to forward
#                                      to  [default: 22]
#       -p, --persist                  Persist the iroh identity
#                                      between runs
#       --key-dir <DIR>                Directory for iroh-ssh
#                                      identity keys
#                                      [default: ~/.ssh]
#
#     service <install|uninstall>    Install or uninstall as a
#                                    system service
#       install                        Install:  --ssh-port,
#                                                 --key-dir,
#                                                 --relay-url,
#                                                 --extra-relay-url
#       uninstall                      Remove the installed
#                                      system service
#
#     info [--key-dir <DIR>]         Show the local endpoint ID
#                                    and other node info
#
#     version                        Print version
#
#   Hidden subcommands  (exposed for tooling; not in the default
#                        --help screen):
#     exec <USER@ENDPOINT_ID> -- <CMD>...
#                                    One-shot remote-cmd mode
#                                    (like `ssh host cmd`)
#     proxy <ENDPOINT_ID>            Run as a proxy endpoint
#                                    (only one positional;
#                                    --relay-url / --extra-relay-url
#                                    apply)
#     run-service                    Windows-only — invoked by
#                                    the service control manager
#
#   ssh(1)-compatible SshOpts  (flattened into the default-mode
#                                Cli, ConnectArgs, and ExecArgs):
#     -i, --identity-file <PATH>     Identity file for publickey
#                                    auth
#     -L <[BIND:]LPORT:HOST:RPORT>   Local forward (repeatable;
#                                    host can't be an
#                                    endpoint_id yet)
#     -R <[BIND:]RPORT:HOST:LPORT>   Remote forward (repeatable)
#     -p, --port <PORT>              Remote sshd port (default
#                                    22)
#     -l <USER>                      Login user
#     -o <KEY=VALUE>                 Pass an ssh option
#                                    (repeatable)
#     -A                             Enable agent forwarding
#     -a                             Disable agent forwarding
#     -X                             Enable X11 forwarding
#     -Y                             Enable trusted X11
#                                    forwarding
#     -N                             Do not execute remote
#                                    command
#     -t                             Force pseudo-terminal
#     -T                             Disable pseudo-terminal
#     -v                             Increase verbosity  (count)
#     -q                             Quiet mode
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `iroh = "0.94"` declared in Cargo.toml —
#   `iroh` is THE canonical Rust P2P + QUIC + DHT + relay stack
#   maintained by n0-computer (n0-computer/iroh, 3,700+ stars;
#   the modern pure-Rust replacement for libp2p that powers
#   sendme, dumbpipe, iroh-blobs, iroh-docs, iroh-gossip,
#   iroh-willow, p2panda, kulfi, pigg, the upcoming Sefiria,
#   and a growing set of P2P-first applications).  iroh exposes
#   the typed `iroh::Endpoint::builder()` factory with
#   `.discovery_n0()` / `.discovery_dht()` /
#   `.discovery_local_network()` / `.alpns(vec![...])` /
#   `.bind(socket_addr)` / `.bind_async().await`, the typed
#   `endpoint.connect(node_addr, alpn).await? -> Connection`
#   QUIC connect primitive that returns a typed
#   `iroh::endpoint::Connection`, the typed `connection.
#   open_bi().await? -> (SendStream, RecvStream)` bi-directional
#   QUIC stream pair, the typed `connection.accept_bi().await?`
#   acceptor counterpart, the typed
#   `endpoint.node_addr().await?` /
#   `endpoint.add_node_addr(node_addr)?` /
#   `endpoint.home_relay().get()?` /
#   `endpoint.direct_addresses()`, the typed `iroh::NodeId`
#   (newtype around ed25519 public key — bech32 encoded with
#   prefix `iroh`), the typed `iroh::NodeAddr` (NodeId + relay
#   URL + direct sockets), the typed `iroh::RelayUrl` and
#   `iroh::RelayMode` (default n0 mesh / staging / custom /
#   disabled), the typed `iroh::SecretKey` /
#   `iroh::PublicKey` with native ed25519 signing + key
#   derivation, and the typed `iroh::Watchable<T>` async-aware
#   state primitive used pervasively for relay-URL changes,
#   home-relay shifts, network-change events, and connection-
#   state transitions.  Built on QUIC (via `quinn`),
#   `iroh-relay` (the DERP-like fallback mesh), `iroh-base`
#   (NodeId + key wire types), and `iroh-quinn-udp` (kernel
#   UDP socket I/O).  iroh-ssh's `src/api.rs` constructs an
#   `iroh::Endpoint` per `client_mode` / `server_mode`
#   invocation, advertises the `iroh-ssh/0` ALPN, and binds
#   the locally-running sshd port 22 to the iroh QUIC stream
#   pair after `endpoint.connect(node_addr, b"iroh-ssh/0")`.
#   Verified via:
#     gh api repos/rustonbsd/iroh-ssh/contents/Cargo.toml
#       → iroh = "0.94"
#       → clap = { version = "4.6.1", features = ["derive"] }
#       → [package] name = "iroh-ssh", version = "0.2.11",
#                    edition = "2024"
#     gh api repos/rustonbsd/iroh-ssh/contents/src/cli.rs
#       → #[derive(Parser)] struct Cli { cmd, target,
#                                          relay_url,
#                                          extra_relay_url,
#                                          ssh (flatten),
#                                          remote_cmd }
#       → #[derive(Subcommand)] enum Cmd { Connect, Exec(hide),
#                                           Server, Service,
#                                           Info, Proxy(hide),
#                                           RunService(hide),
#                                           Version }
#       → #[derive(Subcommand)] enum ServiceCmd { Install,
#                                                  Uninstall }
#       → SshOpts: -i, -L, -R, -p, -l, -o, -A, -a, -X, -Y, -N,
#                   -t, -T, -v, -q
#   This entry is the Rust=155 leader bump that OPENS Axis 100
#   (iroh P2P-stack / QUIC + DHT + relay mesh) at 1/0/0 — the
#   100th axis to be opened in the corpus.  Pairing Go and
#   TS-Node bumps will follow at R990 and R991 (Go=155
#   candidates: go-libp2p-based CLIs that line up with iroh's
#   conceptual scope — chrislusf/seaweedfs node ops, the
#   ipfs-cluster CLI, lotus-bench, lassie, the SEEK SP1
#   nodes; TS-Node=155 candidates: helia / @libp2p/* /
#   js-libp2p / quic-go-replacement-style TS users).
#
#   No completion for `iroh-ssh` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_iroh-ssh() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a ssh_opts
    ssh_opts=(
        '(-i --identity-file)'{-i,--identity-file}'=[identity file for publickey auth]:path:_files'
        '*-L+[local forward (lport:host:rport, repeatable)]:forward:'
        '*-R+[remote forward (rport:host:lport, repeatable)]:forward:'
        '(-p --port)'{-p,--port}'=[remote sshd port (default 22)]:port:'
        '-l+[login user]:user:_users'
        '*-o+[ssh option (KEY=VALUE, repeatable)]:option:'
        '-A[enable agent forwarding]'
        '-a[disable agent forwarding]'
        '-X[enable X11 forwarding]'
        '-Y[enable trusted X11 forwarding]'
        '-N[do not execute remote command]'
        '-t[force pseudo-terminal]'
        '-T[disable pseudo-terminal]'
        '*-v[increase verbosity (count)]'
        '-q[quiet mode]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '*--relay-url=[use only these relay servers (repeatable)]:url:' \
        '*--extra-relay-url=[add relay servers alongside defaults (repeatable)]:url:' \
        $ssh_opts \
        '1: :_iroh_ssh_commands_or_target' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                connect)
                    _arguments \
                        $ssh_opts \
                        '*--relay-url=[use only these relay servers]:url:' \
                        '*--extra-relay-url=[add relay servers alongside defaults]:url:' \
                        '1:target (user@ENDPOINT_ID):' \
                        '*::remote command:_command_names -e' && ret=0 ;;
                exec)
                    _arguments \
                        $ssh_opts \
                        '*--relay-url=[use only these relay servers]:url:' \
                        '*--extra-relay-url=[add relay servers alongside defaults]:url:' \
                        '1:target (user@ENDPOINT_ID):' \
                        '*::remote command:_command_names -e' && ret=0 ;;
                server)
                    _arguments \
                        '--ssh-port=[local sshd port to forward to (default 22)]:port:' \
                        '(-p --persist)'{-p,--persist}'[persist iroh identity between runs]' \
                        '--key-dir=[directory for iroh-ssh identity keys]:dir:_files -/' \
                        '*--relay-url=[use only these relay servers]:url:' \
                        '*--extra-relay-url=[add relay servers alongside defaults]:url:' && ret=0 ;;
                service)
                    _arguments \
                        '1:service operation:(install uninstall)' \
                        '*::arg:->svc_args'
                    case $state in
                        svc_args)
                            case $words[1] in
                                install)
                                    _arguments \
                                        '--ssh-port=[local sshd port to forward to (default 22)]:port:' \
                                        '--key-dir=[directory for iroh-ssh identity keys]:dir:_files -/' \
                                        '*--relay-url=[use only these relay servers]:url:' \
                                        '*--extra-relay-url=[add relay servers alongside defaults]:url:' && ret=0 ;;
                                uninstall)
                                    _arguments '*: :' && ret=0 ;;
                            esac ;;
                    esac
                    ;;
                info)
                    _arguments \
                        '--key-dir=[directory for iroh-ssh identity keys]:dir:_files -/' && ret=0 ;;
                proxy)
                    _arguments \
                        '1:endpoint id:' \
                        '*--relay-url=[use only these relay servers]:url:' \
                        '*--extra-relay-url=[add relay servers alongside defaults]:url:' && ret=0 ;;
                run-service|version)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_iroh_ssh_commands_or_target] )) ||
_iroh_ssh_commands_or_target() {
    local -a commands
    commands=(
        'connect:connect to a remote iroh-ssh endpoint'
        'server:start iroh-ssh server'
        'service:install or uninstall as a system service'
        'info:show local endpoint ID and node info'
        'version:print version'
    )
    _describe -t commands 'iroh-ssh command' commands
    _message -e target 'or target (user@ENDPOINT_ID)'
}

_iroh-ssh "$@"
