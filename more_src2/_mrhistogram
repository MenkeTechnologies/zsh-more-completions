#compdef mrhistogram
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrhistogram.html
# Source: MRtrix3/mrtrix3 cmd/mrhistogram.cpp — generate intensity histogram of an image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-allvolumes[single histogram across all volumes]' \
    '-bins+[number of bins]:n:_default' \
    '-template+[derive bins from this template image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-mask+[restrict to mask voxels]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-ignorezero[ignore zero-valued voxels]' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '2:hist (output histogram):_files' \
    && ret=0

return ret
