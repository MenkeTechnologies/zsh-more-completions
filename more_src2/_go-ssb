#compdef go-sbot sbot
# _go-ssb — Go Secure Scuttlebutt server / peer; sbot serves the local feed + replicates with peers
# upstream: https://github.com/ssbc/go-ssb

_go-ssb() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose log]' \
        '--repo+[repo dir]:dir:_files -/' \
        '--lis+[muxrpc listen addr]:addr:' \
        '--lis-ws+[websocket listen addr]:addr:' \
        '--debuglis+[debug HTTP listen]:addr:' \
        '--shscap+[secret-handshake capability]:cap:' \
        '--hmac+[hmac key]:key:' \
        '--hops+[replication hops]:n:' \
        '--enable-ebt[enable EBT replication]' \
        '--promisc[promisc replication]' \
        '*:cmd:'
}

_go-ssb "$@"
