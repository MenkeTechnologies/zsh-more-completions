#compdef protonup-ng
# Documentation: https://github.com/protonup-ng/protonup-ng
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for ProtonUp-ng (Proton-GE installer/updater)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-d --dir)'{-d,--dir}'[set installation directory]:directory:_files -/' \
  '(-t --tag)'{-t,--tag}'[install a specific version tag]:tag:' \
  '(-l --list)'{-l,--list}'[list installed versions]' \
  '(-r --remove)'{-r,--remove}'[remove existing installation]:version:' \
  '(-o --output)'{-o,--output}'[set download directory]:directory:_files -/' \
  '--releases[list available versions]' \
  '--download[download only, do not install]' \
  '-y[disable prompts and logs]' && ret=0

return ret
