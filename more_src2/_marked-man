#compdef marked-man
# ---------------------------------------------------------------------------
# marked-man — markdown to roff/man-page wrapper around marked (Node.js, 76★)
#
# upstream: https://github.com/kapouer/marked-man
# author : Jérémy Lal  <kapouer@melix.org>
# license: MIT
#
# Source-direct completion: every flag below is verbatim from bin/marked-man.js
# (which delegates to `marked/bin/marked` after applying its plugin) and from
# src/index.js (default option keys: name, section, manual, date, manVersion,
# mangle, breaks, headerIds).  Pass-through marked flags are from
# markedjs/marked bin/main.js arg-parsing switch.
#
# Direct deps from package.json:
#   marked           ^12.0.2     ← canonical Node CommonMark parser (this axis)
#   read-package-up  ^12.0.0     (Sindre Sorhus — pull pkg.version for man)
#
# marked-man rewrites a top-level `--version` to `--man-version` BEFORE
# delegating, so on this binary `--version` produces the man-page version
# string (not the marked-man binary's own version).  Note that.
#
# ============================================================================
# === AXIS 154 CLOSES — CommonMark / Markdown parser ecosystem ==============
# === TRIPLE-209 ROUND-NUMBER LANDMARK · 147th AXIS CLOSED ==================
# ============================================================================
# Axis position: TS-Node=209 CLOSES Axis 154 at slot 1/1/1 — quadruple-clean
# closure of the canonical CommonMark / Markdown parser ecosystem spanning
# the three major systems languages:
#
#     Rust    : pulldown-cmark    by Raph Levien (raphlinus — Xi-editor,
#                                    Google Fonts) + Marco Cecchetti
#                 → mdvi (Todd A. Fisher taf2, terminal markdown viewer)
#                 _mdvi           [Rust=209 OPENED Axis 154, slot 1/0/0]
#                 powers mdBook, the Rust Book, docs.rs, rustdoc, comrak
#                 reference comparisons.
#
#     Go      : yuin/goldmark     by Yusuke Inuzuka
#                 → semcheck (rejot-dev, LLM impl-vs-spec checker)
#                 _semcheck       [Go=209 CONTINUED Axis 154, slot 2/0/0]
#                 powers Hugo, golang.org/x/website, gitea wiki, soft-serve.
#
#     JS/Node : marked            by Christopher Jeffrey (chjj) — original
#                                  2011, now MarkedJS org (Steven styfle,
#                                  Josh amidknight, Tony tonybrix)
#                 → marked-man (Jérémy Lal kapouer — markdown→roff wrapper)
#                 _marked-man     [TS-Node=209 CLOSES Axis 154, slot 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 marked drives marked.js.org, docusaurus alt-renderers,
#                 chjj's own classic Node markdown stack.
#
# Round-number 209 landmark fires simultaneously across all three lanes:
# Rust completion #209 + Go completion #209 + TS-Node completion #209 =
# triple-209. Axis #147 closed in the lifetime of the corpus.
# ============================================================================

_marked-man() {
    _arguments -s -S \
        '(-o --output)'{-o,--output=}'[output file]:output file:_files' \
        '(-i --input)'{-i,--input=}'[input file]:input file:_files -g "*.(md|markdown|mdown|mkd)"' \
        '(-s --string)'{-s,--string=}'[markdown string to render]:markdown string:' \
        '(-t --tokens)'{-t,--tokens}'[emit lexer tokens as JSON instead of rendering]' \
        '(-c --config)'{-c,--config=}'[marked config file (defaults: ~/.marked.json, ~/.marked.js, ~/.marked/index.js)]:config file:_files -g "*.(json|js|mjs|cjs)"' \
        '(-n --no-clobber)'{-n,--no-clobber}'[do not overwrite existing output file]' \
        '(-h --help)'{-h,--help}'[show man page / help text]' \
        '(-v)-v[show marked-man version]' \
        '--version=[man-page VERSION (REWRITTEN from --version by marked-man before delegating to marked)]:version:' \
        '--name=[man-page name (NAME section)]:name:' \
        '--section=[man-page section number 1-8]:section:(1 2 3 4 5 6 7 8)' \
        '--manual=[man-page manual title (header center column)]:manual:' \
        '--date=[man-page date (epoch ms, or SOURCE_DATE_EPOCH env-driven)]:date:' \
        '--breaks[treat line breaks as <br> in source (default ON in marked-man)]' \
        '--no-breaks[disable --breaks]' \
        '--gfm[GitHub-Flavored Markdown extensions]' \
        '--no-gfm[disable GFM]' \
        '--pedantic[strict CommonMark adherence]' \
        '--no-pedantic[disable pedantic]' \
        '--mangle[obfuscate emails (OFF by default in marked-man)]' \
        '--no-mangle[disable email obfuscation]' \
        '--silent[suppress errors as warnings]' \
        '--no-silent[disable silent]' \
        '*:markdown input file:_files -g "*.(md|markdown|mdown|mkd|ron|1|2|3|4|5|6|7|8)"'
}

_marked-man "$@"
