#compdef deb-janitor
# Documentation: https://manpages.debian.org/deb-janitor
# Source: debian/devscripts scripts/deb-janitor — Debian janitor API client (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '--api-url=-[API endpoint URL]:url:_urls' \
    '1:subcommand:(schedule diff)' \
    '*::subcommand args:_default' \
    && ret=0

return ret
