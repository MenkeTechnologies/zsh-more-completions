#compdef osctrl-cli
# Documentation: https://osctrl.net/usage/osctrl-cli/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Removed from prior file: bogus man.archlinux.org search URL.

# osctrl-cli: osctrl osquery management CLI
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'audit-logs:audit log access'
  'carve:file carve operations'
  'check-api:verify API connectivity'
  'check-db:verify database connectivity'
  'environment:manage TLS environments'
  'env:manage TLS environments'
  'login:login and obtain API token'
  'node:manage enrolled nodes'
  'query:run queries'
  'settings:manage osctrl settings'
  'tag:manage tags'
  'user:manage users'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'osctrl-cli command' commands && ret=0 ;;
esac

return ret
