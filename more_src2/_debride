#compdef debride
# Documentation: https://github.com/seattlerb/debride
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for debride (Ruby dead method finder)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-e --exclude)'{-e,--exclude}'=[ignore specific directories or files]:file:_files' \
  '(-f --focus)'{-f,--focus}'=[only report methods matching regex]:regex' \
  '(-w --whitelist)'{-w,--whitelist}'=[file with whitelisted method names]:file:_files' \
  '--rails[Rails mode, whitelist common Rails methods]' \
  '--minimum=[filter results by method length]:n' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:files:_files -g "*.rb"' && ret=0

return ret
