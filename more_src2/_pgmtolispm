#compdef pgmtolispm
# Documentation: man pgmtolispm (Netpbm)
# Source: convert a PGM image to Lisp Machine bitmap format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
