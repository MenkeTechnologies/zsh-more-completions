#compdef openapi-to-dhall
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-openapi
# Source: dhall-lang/dhall-haskell dhall-openapi/openapi-to-dhall/Main.hs — Swagger/OpenAPI to Dhall generator.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--skipDuplicates[skip types with the same name when aggregating types]' \
    '--preferNaturalInt[render Swagger Integer as Dhall Natural unless negative]' \
    '--natIntExceptions=[fields treated opposite to preferNaturalInt]:exceptions:_default' \
    '--prefixMap=[prefix mappings as prefix1=base1,prefix2=base2,...]:mapping:_default' \
    '--splitPaths=[paths/model splits for definition extraction]:splits:_default' \
    '--crd[the input file is a custom resource definition]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-)1:file:_files' \
    && ret=0

return ret
