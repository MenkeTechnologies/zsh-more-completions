#compdef epspdf
# Documentation: epspdf --help (v0.6.5.1)
# Source: convert between [E]PS and PDF (Siep Kroonenberg).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '(-p --page --pagenumber)'{-p+,--page=,--pagenumber=}'[page number (positive integer)]:pnum:' \
    '(-g --grey --gray -G --GREY --GRAY)'{-g,--grey,--gray,-G,--GREY,--GRAY}'[convert to grayscale]' \
    '(-b --bbox --BoundingBox)'{-b,--bbox,--BoundingBox}'[compute tight bounding box]' \
    '(-T --target)'{-T+,--target=}'[render target]:target:(screen ebook printer prepress default)' \
    '(-N --pdfversion)'{-N+,--pdfversion=}'[PDF version]:version:(1.2 1.3 1.4 1.5 1.6 1.7 default)' \
    '(-U -I)-U[use pdftops if available]' \
    '(-U -I)-I[reverse -U]' \
    '(-s --save)'{-s,--save}'[save some settings to configuration file]' \
    '(-i --info)'{-i,--info}'[display detected filetype and exit]' \
    '-d[debug: do not remove temp files]' \
    '1:input file:_files -g "*.(eps|ps|pdf)"' \
    '2:output file:_files -g "*.(eps|ps|pdf)"' \
    && ret=0

return ret
