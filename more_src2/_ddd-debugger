#compdef ddd
# Documentation: https://www.gnu.org/software/ddd/manual/html_mono/ddd.html
# Reference accessed: 2026-05-16
# Verified: GNU DDD official manual. Binary is `ddd`, not `ddd-debugger`.
# All unrecognized args/options are passed to the inferior debugger.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --no-exec-window/--exec-window/--separate-windows/
# --attached-windows/--mode-text/--mode-graphic/--font/--bash/--make/
# --driver/-r/-c/-x/-tty/--config/--rcdir/--rcfile/--statesfile (not
# in upstream DDD manual).

# ddd: GNU Data Display Debugger (Motif GUI frontend to gdb/dbx/etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--configuration[show configuration]' \
  '--trace[trace internal commands]' \
  '--debugger=[debugger to use]:dbg:_command_names' \
  '--gdb[use gdb]' \
  '--dbx[use dbx]' \
  '--ladebug[use ladebug]' \
  '--wdb[use wdb]' \
  '--xdb[use xdb]' \
  '--jdb[use jdb]' \
  '--pydb[use pydb]' \
  '--perl[use perl debugger]' \
  '--host=[connect via SSH to host]:host:_hosts' \
  '--rhost=[connect to remote host]:host:_hosts' \
  '--display=[X display]:disp:' \
  '*:program/core file/options for debugger:_files' && ret=0
return ret
