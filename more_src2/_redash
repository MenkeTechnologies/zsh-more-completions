#compdef redash
# _redash — Arik Fraimovich Redash open-source self-hosted SQL dashboard and visualization platform manage CLI (getredash team, Python); flask-cli + click
# upstream: https://github.com/getredash/redash

_redash() {
    local -a sub=(
        'check_settings:check Redash settings'
        'create_db:create database schema'
        'run:run dev server'
        'shell:python shell'
        'database:database subcommands'
        'users:user subcommands'
        'groups:group subcommands'
        'ds:data source subcommands'
        'org:organization subcommands'
        'queries:query subcommands'
        'dashboards:dashboard subcommands'
        'rq:run RQ worker'
        'scheduler:run scheduler'
        'tasks:task subcommands'
        'extension:extension subcommands'
        'celery:celery subcommands'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redash subcommand' sub ;;
        args)
            case $words[1] in
                users) _arguments '1:users cmd:(create create_root delete list grant_admin invite invite_user password change_password)' ;;
                groups) _arguments '1:groups cmd:(create list add_user remove_user change_permissions)' ;;
                ds) _arguments '1:ds cmd:(new list test delete edit options)' ;;
                org) _arguments '1:org cmd:(set_google_apps_domains show_google_apps_domains list)' ;;
                queries) _arguments '1:queries cmd:(list reindex update)' ;;
                dashboards) _arguments '1:dashboards cmd:(list reindex)' ;;
                database) _arguments '1:db cmd:(create create_tables drop_tables reindex)' ;;
                rq) _arguments '1:rq cmd:(scheduler worker info dashboard)' ;;
                celery) _arguments '1:celery cmd:(beat worker status purge)' ;;
                tasks) _arguments '1:tasks cmd:(refresh_queries cleanup_query_results refresh_schemas count_db_objects schedule_periodic_jobs)' ;;
            esac
            ;;
    esac
}

_redash "$@"
