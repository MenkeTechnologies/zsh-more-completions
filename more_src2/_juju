#compdef juju
# Documentation: https://documentation.ubuntu.com/juju/3.6/reference/juju-cli/list-of-juju-cli-commands/
# Reference accessed: 2026-05-19
# Verified: upstream Juju 3.6 CLI command index at the URL above.

# juju: cloud operator / Canonical's model-driven operator framework
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'actions:list actions for an application'
  'add-cloud:add a cloud definition'
  'add-credential:add credentials for a cloud'
  'add-k8s:add a Kubernetes cluster as a cloud'
  'add-machine:add a machine to a model'
  'add-model:add a new model'
  'add-secret:add a new secret'
  'add-space:add a network space'
  'add-ssh-key:add a public SSH key'
  'add-storage:add storage to a unit'
  'add-unit:add a unit to an application'
  'add-user:add a new user'
  'bind:change bindings for an application'
  'bootstrap:bootstrap a controller'
  'change-user-password:change user password'
  'clouds:list clouds'
  'config:get/set application config'
  'consume:add a remote offer to the model'
  'controllers:list controllers'
  'create-backup:create a backup'
  'credentials:list credentials'
  'dashboard:print Juju Dashboard URL'
  'debug-log:display log messages for a model'
  'deploy:deploy a charm or bundle'
  'destroy-controller:destroy controller'
  'destroy-model:destroy a model'
  'download:download a charm'
  'enable-ha:enable HA for a controller'
  'exec:run a command on remote targets'
  'expose:expose application to internet'
  'find-offers:find consume-able offers'
  'grant:grant access to a model/controller'
  'info:show charm/bundle info'
  'integrate:integrate two applications'
  'login:log in to a controller'
  'logout:log out'
  'machines:list machines'
  'migrate:migrate a model to another controller'
  'models:list models'
  'offer:offer an application for consumption'
  'offers:list offers'
  'refresh:upgrade an application charm'
  'register:register a remote controller'
  'remove-application:remove application'
  'remove-machine:remove machine'
  'remove-relation:remove relation'
  'remove-unit:remove unit'
  'remove-user:remove a user'
  'resolved:mark resolved errors'
  'resume-relation:resume a suspended relation'
  'revoke:revoke access to a model/controller'
  'run:queue an action on units'
  'scale-application:set the desired unit count'
  'scp:scp files to/from unit/machine'
  'secrets:list secrets'
  'show-application:show app info'
  'show-cloud:show cloud info'
  'show-controller:show controller info'
  'show-model:show model info'
  'show-machine:show machine info'
  'show-status-log:show history of status changes'
  'show-unit:show unit info'
  'ssh:ssh into a unit/machine'
  'ssh-keys:list SSH keys'
  'status:show model status'
  'storage:list storage details'
  'suspend-relation:suspend a relation'
  'switch:switch active controller/model'
  'sync-agent-binary:upload agent binaries to a controller'
  'trust:set trust for an application'
  'unexpose:unexpose application'
  'unregister:unregister controller'
  'upgrade-controller:upgrade controller'
  'upgrade-machine:upgrade machine series'
  'upgrade-model:upgrade model'
  'users:list users'
  'version:show juju version'
  'wait-for:wait for a model/application/unit/machine state'
  'whoami:show current user/controller/model'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--debug[enable debug logging]' \
  '--verbose[verbose]' \
  '--quiet[quiet]' \
  '--logging-config=[logging config string]:cfg:' \
  '--show-log[show log on console]' \
  '-c[controller]:controller:' \
  '--controller=[controller]:controller:' \
  '-m[model]:model:' \
  '--model=[model]:model:' \
  '-B[no browser]' \
  '--no-browser-login[no browser login]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'juju command' commands && ret=0 ;;
esac
return ret
