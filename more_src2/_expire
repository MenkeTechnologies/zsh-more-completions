#compdef expire
# Documentation: man expire(8)
# Source: InterNetNews/inn expire/expire.c — expire articles per expire.ctl (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[new history directory]:dir:_files -/' \
    '-f+[new history file basename]:file:_files' \
    '-g+[graph stats file]:file:_files' \
    '-h+[existing history file]:file:_files' \
    '-i[ignore old database]' \
    '-N[ignore self-expiring entries]' \
    '-n[do not pause innd while running]' \
    '-p[use Posting time, not Arrival time]' \
    '-r+[reason for pause sent to innd]:reason:_default' \
    '-s+[expected history database size]:N:_default' \
    '-t[tracing — do not replace history]' \
    '-v+[verbosity level]:level:_default' \
    '-w+[time warp in days]:days:_default' \
    '-x[do not write new history, just statistics]' \
    '-z+[file to log unlink paths]:file:_files' \
    '1::expire.ctl:_files' \
    && ret=0

return ret
