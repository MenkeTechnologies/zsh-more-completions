#compdef embossversion
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/embossversion.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS embossversion: print the version of EMBOSS in use
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-full[also print build host and configure flags]' \
  '-outfile=[output file]:file:_files' \
  '*:output:_files' && ret=0
return ret
