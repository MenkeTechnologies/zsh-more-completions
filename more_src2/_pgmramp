#compdef pgmramp
# Documentation: man pgmramp (Netpbm)
# Source: generate a PGM gradient ramp image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-lr -tb -rectangle -ellipse -diagonal)-lr[left-right ramp]' \
    '(-lr -tb -rectangle -ellipse -diagonal)-tb[top-bottom ramp]' \
    '(-lr -tb -rectangle -ellipse -diagonal)-rectangle[rectangular gradient]' \
    '(-lr -tb -rectangle -ellipse -diagonal)-ellipse[elliptical gradient]' \
    '(-lr -tb -rectangle -ellipse -diagonal)-diagonal[diagonal gradient]' \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    && ret=0

return ret
