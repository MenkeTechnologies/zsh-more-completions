#compdef impacket-machine_role
# Documentation: https://github.com/fortra/impacket/blob/master/examples/machine_role.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-machine_role: query the domain role of a Windows machine.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target machine IP]:ip:' \
  '-port[destination port]:port:(139 445)' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '*::positional:_files' && ret=0
return ret
