#compdef mas
# Documentation: https://github.com/mas-cli/mas
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_mas_commands() {
  local -a commands=(
    'config:Output config'
    'get:Get free apps, install any apps'
    'home:Open app web page in browser'
    'install:Install gotten or purchased apps'
    'list:Output installed apps'
    'lookup:Output App Store app details'
    'lucky:Install first matching app'
    'open:Open app App Store page'
    'outdated:Output outdated apps'
    'reset:Reset App Store processes'
    'search:Search for App Store apps'
    'seller:Open seller app web pages'
    'signout:Sign out from App Store'
    'uninstall:Uninstall apps'
    'update:Update outdated apps'
    'version:Output version'
    'help:Show help'
  )
  _describe -t commands 'mas command' commands
}

_mas() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '--version[Print version]' \
    '1:command:_mas_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        install|home|open|seller|uninstall|get|lookup)
          _arguments \
            '*:app ID:'
          ;;
        search)
          _arguments \
            '(-p --price)'{-p,--price}'[Show price]' \
            '*:search term:'
          ;;
        lucky)
          _arguments \
            '*:search term:'
          ;;
        update)
          _arguments \
            '*:app ID (leave empty to update all):'
          ;;
        list|outdated|reset|signout|config|version)
          _arguments
          ;;
      esac
      ;;
  esac
}

_mas "$@"
