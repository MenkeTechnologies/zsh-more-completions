#compdef oden
# ============================================================================
# _oden — zsh completion for the Oden programming language compiler
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/oden-lang/oden
#   Author     : Oskar Wickström (sjsyrek + community)
#   License    : MIT
#   Stars      : 723
#   Language   : Haskell (compiler) / Oden (.oden source files)
#   Status     : Archived in 2017 ("NO LONGER IN ACTIVE DEVELOPMENT")
#                — included for historical / linguistic completeness
#   Last push  : 2017-04-11
#
# WHAT IT IS
#   Oden was "a statically-typed functional language that targets the Go
#   programming language" — Oskar Wickström's experiment in giving Go an
#   ML-flavoured front-end.  Oden source files compile to plain Go
#   source under a configurable GOPATH output (default `target/go`),
#   adding to the host Go toolchain:  Hindley-Milner type inference,
#   parameteric polymorphism, currying / partial application, tuples,
#   variadic constructors, and tagged sum types.  The compiler was
#   archived in April 2017;  no longer in active development, but it
#   remains a representative example of the ML-on-Go school (alongside
#   the more recent Gleam ML-on-BEAM lineage).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cli/Oden/CLI.hs `options` table
#                       + cli/Main.hs subcommand dispatch)
#   oden [GLOBAL_OPTIONS] <command> [args]
#
#   Global options:
#     -h, --help                Print this help message
#     -V, --version             Print the CLI version
#     -W, --warn[=all|none]     Enable or disable compiler warnings
#     -p, --oden-path[=DIR]     Search path for Oden sources
#                               (also honours the ODEN_PATH env var)
#     -o, --out-path[=DIR]      GOPATH output directory  [default: target/go]
#     -M, --monochrome          Print without colors
#
#   Commands  (Main.hs case dispatch):
#     build                     Compile all source files in the Oden path
#     run <PATH>                Run a specific Oden file as main
#     lint <PATH>               Check an Oden file for errors and warnings
#                               (--warn is force-enabled for this command)
#     print-inferred <PATH>     Infer types and print the package in the file
#     print-resolved <PATH>     Print the package after name resolution
#     print-env <PATH>          Print the package's import environment
#     print-types <PATH>        Print the package's type table
#     print-compiled <PATH>     Compile and print the package
#     print-codegen <PATH>      Compile and print the generated Go code
#
# LANGUAGE-CORPUS POSITION
#   Oden is the 146th programming language entry in this completion corpus,
#   closing the 3+1 micro-cycle that began at R853 (_tanour/capnp+capnp-rpc
#   Rust=121 opens Axis 66) and continued through R854 (_webfs/go-capnp
#   Go=121) and R855 (_capnp-es/capnp-es TS-Node=121 CLOSES Axis 66 Cap'n
#   Proto RPC Library at 1/1/1 + triple-121 landmark + 59 axes at 1/1/1).
#   Oden joins the roster of exotic languages already in the corpus
#   including Hop (R852 145th), Lustre (R848 144th), Ravi (R844 143rd),
#   ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832 140th —
#   round-number language milestone), Imba (R828 139th), Tao (R824
#   138th), Dada (R820 137th), Acton (R816 136th), Stanza (R812 135th),
#   Rune, Egel, Mlatu, Gwion, Silq (quantum), Mirth, Lawvere/bill,
#   Cognac/Cognate, and Scrapscript.
#
#   No completion for `oden` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_oden() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help and exit]' \
        '(- *)'{-V,--version}'[print the CLI version]' \
        '(-W --warn)'{-W-,--warn=-}'[enable/disable compiler warnings]::level:(all none)' \
        '(-p --oden-path)'{-p-,--oden-path=-}'[search path for Oden sources (env ODEN_PATH)]::oden path dir:_files -/' \
        '(-o --out-path)'{-o-,--out-path=-}'[GOPATH output directory (default target/go)]::out dir:_files -/' \
        '(-M --monochrome)'{-M,--monochrome}'[print without colors]' \
        '1: :_oden_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build)              _arguments '(- *)'{-h,--help}'[help for build]' && ret=0 ;;
                run|lint|print-inferred|print-resolved|print-env|print-types|print-compiled|print-codegen)
                    _arguments \
                        '(- *)'{-h,--help}'[help]' \
                        ':Oden source file:_files -g "*.oden"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_oden_commands] )) ||
_oden_commands() {
    local -a commands
    commands=(
        'build:compile all source files in the Oden path'
        'run:run a specific Oden file as main'
        'lint:check an Oden file for errors and warnings'
        'print-inferred:infer types and print the package in the given file'
        'print-resolved:print the package after name resolution'
        'print-env:print the package import environment'
        'print-types:print the package type table'
        'print-compiled:compile and print the package'
        'print-codegen:compile and print the generated Go code'
    )
    _describe -t commands 'oden command' commands
}

_oden "$@"
