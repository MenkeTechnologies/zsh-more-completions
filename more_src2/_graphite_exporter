#compdef graphite_exporter
# Documentation: https://github.com/prometheus/graphite_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' \
  '--graphite.listen-address=[address on which to accept graphite data]:address:' \
  '--graphite.mapping-config=[metric mapping configuration file]:file:_files' \
  '--graphite.mapping-strict-match[only store metrics that match a mapping rule]' \
  '--graphite.sample-expiry=[how long a sample is valid for]:duration:' \
  '--graphite.cache-size=[maximum number of cached metrics]:size:' \
  '--graphite.cache-type=[type of metric cache]:type:(lru random)' && ret=0

return ret
