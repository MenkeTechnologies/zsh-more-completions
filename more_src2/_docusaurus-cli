#compdef docusaurus-cli
# _docusaurus-cli — Meta Docusaurus static documentation site generator CLI alias (Meta, TypeScript); commander
# upstream: https://github.com/facebook/docusaurus

_docusaurus-cli() {
    local -a sub=(
        'build:build the site'
        'build-tag:tag and build'
        'clear:remove generated files'
        'deploy:deploy to gh-pages'
        'docs:docs subcommand (only with versioned docs)'
        'serve:serve built site'
        'start:start dev server'
        'swizzle:swizzle theme components'
        'version:show version'
        'write-heading-ids:write heading ids'
        'write-translations:write translation files'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "docusaurus.config.(js|ts)"' \
        '--cwd=+[change working dir]:dir:_files -/' \
        '--verbose[verbose]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'docusaurus subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--bundle-analyzer[bundle analyzer]' \
                    '--out-dir=+[output dir]:dir:_files -/' \
                    '--locale=+[locale]:str:' \
                    '--no-minify[no minify]' \
                    '--dev[dev build]' ;;
                deploy) _arguments \
                    '--locale=+[locale]:str:' \
                    '--out-dir=+[output dir]:dir:_files -/' \
                    '--skip-build[skip build]' \
                    '--target-dir=+[target dir]:str:' ;;
                start) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--locale=+[locale]:str:' \
                    '--hot-only[hot reload only]' \
                    '--no-open[no open browser]' \
                    '--poll=+[poll]:n:' ;;
                serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '-H+[host]:host:_hosts' \
                    '--dir=+[dir]:dir:_files -/' \
                    '--build[also build]' \
                    '--no-open[no open browser]' ;;
                swizzle) _arguments \
                    '1:theme:' \
                    '2:component:' \
                    '--wrap[wrap]' \
                    '--eject[eject]' \
                    '--danger[allow unsafe]' \
                    '--typescript[typescript]' \
                    '--list[list]' \
                    '--locale=+[locale]:str:' ;;
                write-translations|write-heading-ids) _arguments \
                    '--locale=+[locale]:str:' \
                    '--override[override]' \
                    '--maintain-case[maintain case]' \
                    '--messagePrefix=+[message prefix]:str:' ;;
                docs) _arguments \
                    '1:cmd:(version create)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_docusaurus-cli "$@"
