#compdef nmake
# Documentation: https://learn.microsoft.com/en-us/cpp/build/reference/running-nmake
# Reference accessed: 2026-05-16
# Verified: Microsoft Learn NMAKE Reference. Uses Windows-style /flags.
# (NetBSD nmake is a separate tool with a different interface; this
# completion targets the more common Microsoft variant.)
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# nmake: Microsoft NMAKE (MSVC build tool)
local curcontext="$curcontext" ret=1
_arguments -C \
  '/A[force build of all targets]' \
  '/B[force build even if timestamps equal]' \
  '/C[suppress default output]' \
  '/D[display timestamps of targets and dependents]' \
  '/E[environment overrides macro definitions]' \
  '/ERRORREPORT[error reporting (deprecated; WER controls)]:mode:(NONE PROMPT QUEUE SEND)' \
  '/F[makefile]:file:_files' \
  '/G[display !INCLUDE makefiles]' \
  '(/HELP /\\?)/HELP[show NMAKE syntax help]' \
  '(/HELP /\\?)/\\?[show NMAKE syntax help]' \
  '/I[ignore exit codes from commands]' \
  '/K[continue on errors]' \
  '/N[display but do not execute commands]' \
  '/NOLOGO[suppress NMAKE copyright]' \
  '/P[display macro/inference rule/target info]' \
  '/Q[check timestamps without building]' \
  '/R[clear .SUFFIXES list and ignore inference rules]' \
  '/S[suppress display of executed commands]' \
  '/T[update target timestamps without building]' \
  '/U[dump inline NMAKE files (use with /N)]' \
  '/X[error output file]:file:_files' \
  '/Y[disable batch-mode inference rules]' \
  '*:target or macro:' && ret=0
return ret
