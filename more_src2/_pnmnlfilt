#compdef pnmnlfilt
# Documentation: man pnmnlfilt (Netpbm)
# Source: apply Mitchell's nonlinear (alpha-trimmed mean) filter to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:alpha (-0.1..0.5):' \
    '2:radius (0.33..0.83):' \
    '3:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
