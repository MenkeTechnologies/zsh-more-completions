#compdef dualsensectl
# Documentation: https://github.com/nowrep/dualsensectl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

(( $+functions[_dualsensectl_commands] )) ||
_dualsensectl_commands(){
    local -a _dualsensectl_cmds

    _dualsensectl_cmds=(
        'power-off:turn off the controller (BT only)'
        'battery:get controller battery level'
        'info:get controller firmware info'
        'lightbar:enable/disable lightbar or set RGB color'
        'player-leds:set player LEDs (0=disabled, 1-7)'
        'led-brightness:set player/microphone LED dimming (0-2)'
        'microphone:enable or disable microphone'
        'microphone-led:control the microphone LED'
        'microphone-mode:toggle microphone to chat/asr/both'
        'microphone-volume:set microphone volume (0-255)'
        'speaker:toggle to internal/headphone/both'
        'volume:set audio volume (0-255)'
        'attenuation:set motor attenuation (RUMBLE TRIGGER 0-7)'
        'trigger:control trigger force feedback'
        'monitor:run shell commands on device events'
    )

    if ((CURRENT == 1)); then
        _describe -t commands 'dualsensectl commands' _dualsensectl_cmds
    fi
}

_arguments \
    '(- *)'{-h,--help}'[print help text]' \
    '(- *)'{-v,--version}'[print version number]' \
    '-l[list available devices]' \
    '-d+[specify device to use]:device:' \
    '-w[wait for shell command to complete (monitor only)]' \
    '*::dualsensectl commands:_dualsensectl_commands'
