#compdef dnsipq
# _dnsipq — djbdns dnsipq (look up A records but qualify each name through the qualification rules in /etc/resolv.conf "search"/"domain" directives before each query)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from dnsipq.c on tip.

_dnsipq() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '*:domain:_hosts'
}

_dnsipq "$@"
