#compdef gguf-set-metadata
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/gguf-py/gguf/scripts/gguf_set_metadata.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse in gguf-py/gguf/scripts/gguf_set_metadata.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--dry-run[do not actually change anything]' \
  '--force[change the field without confirmation]' \
  '--verbose[increase output verbosity]' \
  '1:GGUF model:_files -g "*.gguf"' \
  '2:metadata key' \
  '3:metadata value' && ret=0

return ret
