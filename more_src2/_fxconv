#compdef fxconv
# Documentation: https://github.com/lephe/Fx-SDK
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fxSDK fxconv: asset converter for Casio fx-9860G / fx-CG 50 / fx-CP 400 add-ins
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '--toolchain=[cross-compile triplet]:triplet:' \
  '--arch=[architecture target]:arch:' \
  '--section=[section name]:section:' \
  '--fx[target fx-9860G family (monochrome)]' \
  '--cg[target fx-CG 50 family (color)]' \
  '--cp[target fx-CP 400 family]' \
  '-b[binary mode]' \
  '--binary[binary mode]' \
  '-i[image mode]' \
  '--bopti-image[bopti image mode]' \
  '--libimg-image[libimg image mode]' \
  '-f[font mode]' \
  '--font[font mode]' \
  '--custom[custom converter mode]' \
  '--converters=[custom converter paths (semicolon-separated)]:paths:' \
  '--py[emit PythonExtra output]' \
  '--py-compact[use compact bytes notation]' \
  '*:asset file:_files' && ret=0

return ret
