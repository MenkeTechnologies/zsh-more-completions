#compdef delwcs
# _delwcs — delete World Coordinate System keywords from a FITS header (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from delwcs.c (single-letter getopt-style).

_delwcs() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-b[leave blank lines after removing keywords]' \
        '-n[write to new file]' \
        '-v[verbose output]' \
        '*:FITS file:_files -g "*.(fits|fit|fts)"'
}

_delwcs "$@"
