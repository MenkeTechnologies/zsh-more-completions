#compdef fluent-manager fluent-operator-manager
# _fluent-manager — Fluent Operator controller manager (FluentBit/Fluentd CRDs)
# upstream: https://github.com/fluent/fluent-operator
# Flags from cmd/fluent-manager/options.go on tip.

_fluent-manager() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--watch-namespaces=[csv of namespaces to watch (empty=all)]:csv:' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '--metrics-secure=[serve metrics over HTTPS]:bool:(true false)' \
        '--webhook-cert-path=[webhook TLS cert directory]:dir:_files -/' \
        '--webhook-cert-name=[webhook TLS cert filename]:name:' \
        '--webhook-cert-key=[webhook TLS key filename]:name:' \
        '--metrics-cert-path=[metrics TLS cert directory]:dir:_files -/' \
        '--metrics-cert-name=[metrics TLS cert filename]:name:' \
        '--metrics-cert-key=[metrics TLS key filename]:name:' \
        '--enable-http2=[enable HTTP/2 for metrics + webhook servers]:bool:(true false)' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--disable-component-controllers=[csv of disabled component controllers]:csv:' \
        '--zap-devel=[development logging]:bool:(true false)' \
        '--zap-encoder=[log encoder]:fmt:(json console)' \
        '--zap-log-level=[log level]:level:(debug info error)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_fluent-manager "$@"
