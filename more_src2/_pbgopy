#compdef pbgopy
# Documentation: https://github.com/nakabonne/pbgopy
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'copy:copy data to the server'
  'paste:paste data from the server'
  'serve:start the pbgopy server'
  'history:list/delete/clear clipboard history'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'pbgopy command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      copy)
        _arguments -s -S \
          '(-a --basic-auth)'{-a,--basic-auth}'[basic auth credentials user:pass]:user\:pass' \
          '(-c --from-clipboard)'{-c,--from-clipboard}'[use local OS clipboard as source]' \
          '(-p --password)'{-p,--password}'[password for symmetric encryption]:password' \
          '(-k --symmetric-key-file)'{-k,--symmetric-key-file}'[path to symmetric key file]:file:_files' \
          '(-K --public-key-file)'{-K,--public-key-file}'[RSA public key for encryption]:file:_files' \
          '(-u --gpg-user-id)'{-u,--gpg-user-id}'[GPG user ID for encryption]:user-id' \
          '--max-size=[maximum data size]:size' \
          '--timeout=[request time limit]:duration' && ret=0
        ;;
      paste)
        _arguments -s -S \
          '(-a --basic-auth)'{-a,--basic-auth}'[basic auth credentials user:pass]:user\:pass' \
          '--id=[specific history entry to retrieve]:id' \
          '(-p --password)'{-p,--password}'[password for decryption]:password' \
          '(-k --symmetric-key-file)'{-k,--symmetric-key-file}'[symmetric key file path]:file:_files' \
          '(-K --private-key-file)'{-K,--private-key-file}'[RSA private key for decryption]:file:_files' \
          '--private-key-password-file=[password file for encrypted private key]:file:_files' \
          '(-u --gpg-user-id)'{-u,--gpg-user-id}'[GPG user ID for decryption]:user-id' \
          '--max-size=[maximum data size]:size' \
          '--timeout=[request time limit]:duration' && ret=0
        ;;
      serve)
        _arguments -s -S \
          '(-a --basic-auth)'{-a,--basic-auth}'[basic auth credentials user:pass]:user\:pass' \
          '(-p --port)'{-p,--port}'[listen port]:port' \
          '--history-limit=[retained entries (0 unlimited)]:n' \
          '--ttl=[data expiration duration]:duration' && ret=0
        ;;
      history)
        _arguments -s -S \
          '(-a --basic-auth)'{-a,--basic-auth}'[basic auth credentials user:pass]:user\:pass' \
          '--json[JSON output format]' \
          '--timeout=[request time limit]:duration' \
          '1:subcommand:(delete clear)' && ret=0
        ;;
    esac
    ;;
esac

return ret
