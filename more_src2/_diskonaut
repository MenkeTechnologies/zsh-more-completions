# imsnif/diskonaut — terminal disk space navigator.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --path)'{-p,--path}'[directory to scan]:directory:_files -/' \
  ':directory to scan:_files -/'
