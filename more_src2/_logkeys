#compdef logkeys
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-s --start)'{-s,--start}'[start logging]' \
  '(-k --kill)'{-k,--kill}'[stop logging]' \
  '(-u --us-keymap)'{-u,--us-keymap}'[US keymap file]:keymap file:_files' \
  '(-m --keymap)'{-m,--keymap}'[custom keymap file]:keymap file:_files' \
  '(-o --output)'{-o,--output}'[output file]:output file:_files' \
  '(-d --device)'{-d,--device}'[input device]:device file:_files -W /dev/input' \
  '(-n --no-func-keys)'{-n,--no-func-keys}'[do not log function keys]' \
  '(-e --export)'{-e,--export}'[export keymap]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' && ret=0
return ret
