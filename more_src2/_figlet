#compdef figlet
# Documentation: man figlet(6)
# Source: cmatsuoka/figlet figlet.c (master) — ASCII-art big text generator (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A[read input from command line args]' \
    '-D[use Deutsch (ISO-646 German) char set]' \
    '-E[use English (ASCII) char set]' \
    '(-X -L -R)-X[determine direction from font]' \
    '(-X -L -R)-L[force left-to-right]' \
    '(-X -L -R)-R[force right-to-left]' \
    '(-x -l -c -r)-x[justify from font]' \
    '(-x -l -c -r)-l[left justify]' \
    '(-x -l -c -r)-c[center]' \
    '(-x -l -c -r)-r[right justify]' \
    '(-p -n)-p[paragraph mode]' \
    '(-p -n)-n[normal (default newline) mode]' \
    '(-s -k -S -o -W)-s[smush layout per font default]' \
    '(-s -k -S -o -W)-k[kerning (touch only)]' \
    '(-s -k -S -o -W)-S[force max smushing]' \
    '(-s -k -S -o -W)-o[smush by overlap]' \
    '(-s -k -S -o -W)-W[full width (no smushing)]' \
    '-t[use terminal width]' \
    '-N[no smushing override]' \
    '-v[show version]' \
    '-I+[print info code]:code:_default' \
    '-m+[smushmode bitmask]:mode:_default' \
    '-w+[output width]:cols:_default' \
    '-d+[font directory]:dir:_files -/' \
    '-f+[font file (without .flf)]:font:_default' \
    '-C+[control file]:file:_files' \
    '*:message:_default' \
    && ret=0

return ret
