#compdef linty
# Documentation: https://github.com/rwblickhan/linty
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall linty@0.4.0
# Probed via: completions zsh
# Repository: https://github.com/rwblickhan/linty.git

autoload -U is-at-least

_linty() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" \
'-c+[Optional path to .lintyconfig.json file]:CONFIG_PATH: ' \
'--config-path=[Optional path to .lintyconfig.json file]:CONFIG_PATH: ' \
'--error-on-warning[Treat warnings as errors]' \
'--no-confirm[Print warnings and continue without confirmation]' \
'--ignored[Include files listed in .gitignore and .ignore files]' \
'--hidden[Include hidden files]' \
'--pre-commit[Limit to files staged for commit]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'::files -- Relative paths to files to lint (default\: all files in current directory recursively):' \
":: :_linty_commands" \
"*::: :->linty" \
&& ret=0
    case $state in
    (linty)
        words=($line[2] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:linty-command-$line[2]:"
        case $line[2] in
            (init)
_arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
":: :_linty__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:linty-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_linty_commands] )) ||
_linty_commands() {
    local commands; commands=(
'init:Initialize an empty .lintyconfig' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'linty commands' commands "$@"
}
(( $+functions[_linty__completions_commands] )) ||
_linty__completions_commands() {
    local commands; commands=()
    _describe -t commands 'linty completions commands' commands "$@"
}
(( $+functions[_linty__help__completions_commands] )) ||
_linty__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'linty help completions commands' commands "$@"
}
(( $+functions[_linty__help_commands] )) ||
_linty__help_commands() {
    local commands; commands=(
'init:Initialize an empty .lintyconfig' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'linty help commands' commands "$@"
}
(( $+functions[_linty__help__help_commands] )) ||
_linty__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'linty help help commands' commands "$@"
}
(( $+functions[_linty__help__init_commands] )) ||
_linty__help__init_commands() {
    local commands; commands=()
    _describe -t commands 'linty help init commands' commands "$@"
}
(( $+functions[_linty__init_commands] )) ||
_linty__init_commands() {
    local commands; commands=()
    _describe -t commands 'linty init commands' commands "$@"
}

if [ "$funcstack[1]" = "_linty" ]; then
    _linty "$@"
else
    compdef _linty linty
fi
