#compdef qtile-cli
# _qtile-cli — Qtile Python tiling window manager CLI alias (Qtile team, Python); argparse
# upstream: https://github.com/qtile/qtile

_qtile-cli() {
    local -a sub=(
        'check:type-check config'
        'cmd-obj:run cmd on object'
        'migrate:run config migration'
        'run-cmd:run cmd from script'
        'shell:open qsh shell'
        'start:start qtile session'
        'top:run qtile top'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qtile subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--config=+[config file]:file:_files -g "config.py *.py"' \
                    '-c+[config file]:file:_files -g "config.py *.py"' \
                    '--socket=+[ipc socket]:file:_files' \
                    '-s+[ipc socket]:file:_files' \
                    '--no-spawn[no spawn]' \
                    '-n[no spawn]' \
                    '--log-level=+[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
                    '-l+[log level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
                    '--state=+[state file]:file:_files' \
                    '--with-state=+[state file]:file:_files' \
                    '--backend=+[backend]:b:(x11 wayland)' \
                    '-b+[backend]:b:(x11 wayland)' ;;
                check) _arguments \
                    '--config=+[config file]:file:_files -g "config.py *.py"' \
                    '-c+[config file]:file:_files -g "config.py *.py"' \
                    '--reload[reload]' \
                    '-r[reload]' ;;
                cmd-obj) _arguments \
                    '--socket=+[ipc socket]:file:_files' \
                    '-s+[ipc socket]:file:_files' \
                    '--object=+[object path]:str:' \
                    '-o+[object path]:str:' \
                    '--function=+[function name]:str:' \
                    '-f+[function name]:str:' \
                    '--args=+[args]:list:' \
                    '-a+[args]:list:' \
                    '--info[show info]' \
                    '-i[show info]' ;;
                run-cmd) _arguments \
                    '*:cmd:' ;;
                shell) _arguments \
                    '--socket=+[ipc socket]:file:_files' \
                    '-s+[ipc socket]:file:_files' \
                    '--command=+[run shell command]:str:' \
                    '-c+[run shell command]:str:' \
                    '--json[json mode]' \
                    '-j[json mode]' ;;
                top) _arguments \
                    '--socket=+[ipc socket]:file:_files' \
                    '-s+[ipc socket]:file:_files' \
                    '--lines=+[lines]:n:' \
                    '-l+[lines]:n:' \
                    '--limit=+[limit]:n:' \
                    '-i+[interval]:n:' \
                    '--interval=+[interval]:n:' ;;
                migrate) _arguments \
                    '--config=+[config file]:file:_files -g "config.py *.py"' \
                    '-c+[config file]:file:_files -g "config.py *.py"' \
                    '--yes[yes to all]' \
                    '-y[yes to all]' \
                    '--info[info]' \
                    '--list-migrations[list migrations]' \
                    '--run-migrations=+[run migrations]:list:' ;;
            esac
            ;;
    esac
}

_qtile-cli "$@"
