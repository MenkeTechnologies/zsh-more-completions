# -----------------------------------------------------------------------------
#
# THE git-subtrac CLI
#
# git-subtrac is a multi-subcommand CLI built on
# pborman/getopt.  Invocation:
#   git-subtrac [global-flags] <subcommand> [args]
#   git subtrac [global-flags] <subcommand> [args]
#
# Both forms work because git auto-discovers `git-*`
# binaries on PATH.
#
# Global flags:
#   -d, --git-dir <GIT_DIR>           path to git repo
#                                     (default ".")
#   -x, --exclude <commitids,...>     commit IDs to
#                                     exclude (repeatable)
#       --auto-exclude                auto-exclude missing
#                                     submodule commits
#   -v, --verbose                     verbose progress
#                                     logging
#
# Subcommands:
#   cid <ref>                         print the id of the
#                                     tracking commit for
#                                     the given ref
#   dump <refs...>                    print the cache after
#                                     loading the named
#                                     branch refs
#   update                            update all local
#                                     branches with
#                                     matching *.trac
#                                     branches
#
# Common invocations:
#   # Generate .trac tracking branches for every local branch
#   git subtrac update
#
#   # Update + auto-exclude missing submodule refs
#   git subtrac --auto-exclude update
#
#   # Run with verbose progress
#   git subtrac -v update
#
#   # Exclude specific commit IDs explicitly
#   git subtrac -x abc1234,def5678 update
#
#   # Operate on a repo other than cwd
#   git subtrac -d /path/to/repo update
#
#   # Print the tracking commit id for a specific ref
#   git subtrac cid main
#   git subtrac cid refs/heads/feature-x
#
#   # Dump the cache after loading multiple branches
#   git subtrac dump main develop feature-x
#
#   # Inspect a single ref's tracking content
#   git subtrac dump refs/heads/main
#
# Workflow after successful `update`:
#   1. Push the .trac branches alongside their main branches:
#        git push origin main main.trac
#        git push origin develop develop.trac
#
#   2. Edit .gitmodules to point to "." for all submodules:
#        [submodule "vendor/lib"]
#            path = vendor/lib
#            url = .                  # was: https://github.com/example/lib
#
#   3. Commit + push the .gitmodules change:
#        git add .gitmodules
#        git commit -m "vendor submodules via subtrac"
#        git push
#
#   End users cloning the repo can then `git submodule
#   update --init --recursive` without needing
#   git-subtrac installed; the submodule contents are
#   served from the parent repo's .trac branches.
#
# OPTIONS (sourced directly from
# https://github.com/apenwarr/git-subtrac/blob/master/git-subtrac.go):
#
# Global:
#   -d, --git-dir GIT_DIR             path to git repo (default .)
#   -x, --exclude commitids           commitids to exclude
#       --auto-exclude                auto exclude missing commits
#   -v, --verbose                     verbose mode
#
# Subcommands:
#   cid <ref>                         print tracking-commit id
#   dump <refs...>                    print cache after loading refs
#   update                            update all local branches
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gsub_subcommands
_gsub_subcommands=(
    'cid:print the id of the tracking commit for the given ref'
    'dump:print the cache after loading the named branch refs'
    'update:update all local branches with matching *.trac tracking branches'
)

local -a _gsub_global_flags
_gsub_global_flags=(
    '(-d --git-dir)'{-d,--git-dir}'=[path to git repo (default ".")]:git dir:_directories'
    '(-x --exclude)'{-x,--exclude}'=[commit IDs to exclude (comma-separated)]:commitids: '
    '--auto-exclude[auto-exclude missing submodule commits]'
    '(-v --verbose)'{-v,--verbose}'[verbose progress logging]'
)

_arguments -C \
    "${_gsub_global_flags[@]}" \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:->subcmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    subcmd)
        _describe -t subcmds 'git-subtrac subcommand' _gsub_subcommands && ret=0
        ;;
    args)
        case $words[1] in
            update)
                _arguments "${_gsub_global_flags[@]}" && ret=0
                ;;
            cid)
                _arguments \
                    "${_gsub_global_flags[@]}" \
                    '1:git ref: ' \
                    && ret=0
                ;;
            dump)
                _arguments \
                    "${_gsub_global_flags[@]}" \
                    '*:git ref: ' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
