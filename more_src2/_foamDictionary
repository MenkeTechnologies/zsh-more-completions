#compdef foamDictionary
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/miscellaneous/foamDictionary — read/edit OpenFOAM dictionary files (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-keywords[list keywords of selected entry]' \
    '-entry+[report/select named entry]:name:_default' \
    '-value[print entry value only]' \
    '-rename+[rename entry]:from/to:_default' \
    '-set+[set entry to value]:value:_default' \
    '-add+[add new entry with value]:value:_default' \
    '-merge+[merge value into entry]:value:_default' \
    '-dict[treat entry as a sub-dictionary]' \
    '-remove[remove entry]' \
    '-diff+[diff against another dictionary]:dict:_files' \
    '-includes[expand #include directives]' \
    '-expand[expand and write back to file]' \
    '-region+[region name]:region:_default' \
    '1:dictionary file:_files' \
    && ret=0

return ret
