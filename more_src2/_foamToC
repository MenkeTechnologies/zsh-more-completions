#compdef foamToC
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/miscellaneous/foamToC — list run-time-selectable models/solvers/BCs/libraries (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-noLibs[skip OpenFOAM libraries]' \
    '-libs+[search additional libraries]:libs:_default' \
    '-solvers[list available solvers]' \
    '-solver+[list options for named solver]:name:_default' \
    '-listLibs[list available libraries]' \
    '-switches[list debug/info/optimisation switches]' \
    '-all[show all entries]' \
    '-tables[list available tables]' \
    '-table+[list named table]:name:_default' \
    '-search+[search by name]:name:_default' \
    '-scalarBCs[list scalar boundary conditions]' \
    '-vectorBCs[list vector boundary conditions]' \
    && ret=0

return ret
