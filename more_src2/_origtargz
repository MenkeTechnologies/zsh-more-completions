#compdef origtargz
# Documentation: https://manpages.debian.org/origtargz
# Source: debian/devscripts scripts/origtargz.pl — fetch or unpack original Debian source tarball (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '*'{-p+,--path=}'[directory to search]:dir:_files -/' \
    '(-d --download-only)'{-d,--download-only}'[download only, do not unpack]' \
    '(-t --tar-only)'{-t,--tar-only}'[do not extract orig tarball signature]' \
    '(-u --unpack)'{-u-,--unpack=-}'[unpack mode]::mode:(no once yes)' \
    '--clean[remove non-VCS files before unpacking]' \
    && ret=0

return ret
