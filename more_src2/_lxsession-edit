#compdef lxsession-edit
# Documentation: https://github.com/lxde/lxsession/blob/master/lxsession-edit/lxsession-edit.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: lxsession-edit parses no flags itself; the only argument is a positional
# session name (falls back to $XDG_CURRENT_DESKTOP / $DESKTOP_SESSION or "LXDE").

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help and exit (GTK)]' \
  '*:session name:' && ret=0

return ret
