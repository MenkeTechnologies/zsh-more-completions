#compdef psternary
# Documentation: https://docs.generic-mapping-tools.org/latest/ternary.html
# Source: GenericMappingTools/gmt classic-mode psternary — ternary (a,b,c) diagram plot.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT for symbol coloring]:cpt:_files -g "*.cpt(-.)"' \
    '-G+[symbol fill]:color:_default' \
    '-J+[ternary diagram width (linear -Jx)]:proj:_default' \
    '-L+[vertex labels (a/b/c at 100%)]:labels:_default' \
    '-M[convert (a,b,c) → (x,y) without plotting]' \
    '-N[do not clip outside borders]' \
    '-R+[axis limits min1/max1/min2/max2/min3/max3]:region:_default' \
    '-S+[symbol type + size]:opts:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    '*:input table:_files' \
    && ret=0

return ret
