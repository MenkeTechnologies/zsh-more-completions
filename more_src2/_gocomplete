#compdef gocomplete
# ============================================================================
#  _gocomplete — gocomplete: bash completion for the Go command,
#                shipped as the canonical demo binary for the
#                posener/complete library — provides intelligent
#                completion for `go build`/`go test`/`go run`/
#                `go fmt`/`go vet`/`go doc`/`go tool ...` with
#                flag-by-flag predictors
#                (Eyal Posener — Israeli Rust/Go open-source dev)
#
#  Source-direct extraction from
#    https://github.com/posener/complete/blob/master/gocomplete/complete.go
#    https://github.com/posener/complete/blob/master/cmd/cmd.go (CLI install/uninstall flags)
#    https://github.com/posener/complete/blob/master/complete.go (Complete struct + Run method)
#
#  Maintained by Eyal Posener (Israeli Go OSS developer, prolific
#  contributor to Go ecosystem tooling).  posener/complete: 955 GH
#  stars.  gocomplete is the CANONICAL DEMO BINARY shipped within
#  the posener/complete repository that provides bash completion
#  for the `go` command — predicts Go subcommands (build, run,
#  test, fmt, vet, doc, get, generate, list, tool, mod, install,
#  clean, env, help, version), then within each subcommand
#  predicts the correct flag values (e.g. `go test -covermode`
#  completes to {set, count, atomic}; `go tool asm -I <dir>`
#  completes with directory paths; `go build -gccgoflags` accepts
#  anything; etc.).  When installed via `gocomplete -install`,
#  bash auto-completion is wired up for the `go` command so users
#  get intelligent suggestions for ALL `go` subcommands and their
#  flags out of the box.  Sister tools: go (in corpus + STOCK in
#  Go toolchain via _go), bash-completion (in corpus + STOCK via
#  bash-completion package), zsh built-in completion (the
#  /usr/share/zsh/functions/Completion/Unix/_go file), carapace
#  (in corpus via _carapace — universal cross-shell completion
#  generator by rsteube), shellpipes/bash-completion (in corpus).
#
#  CLI library taxonomy update: 18th Go CLI library — Eyal
#  Posener's **complete** (posener/complete).  Go ecosystem now
#  has 18 documented CLI libraries — TYING WITH RUST AND
#  TYPESCRIPT-NODE at the top of the cross-language taxonomy in
#  a THREE-WAY TIE at 18 each.  🎉 Go RE-TIES with Rust and
#  TypeScript-Node at 18.
#
#  posener/complete (955 stars) is a SHELL-COMPLETION-FOCUSED Go
#  CLI library that ALSO provides argv parsing for the install/
#  uninstall meta-commands needed to wire up shell completion.
#  Distinguishing philosophy: COMPLETION-FIRST DESIGN — instead
#  of being a CLI parser that happens to also support completion
#  (cobra/clap_complete model), posener/complete is a
#  COMPLETION ENGINE that happens to also support installation
#  + uninstallation argv parsing.  The library generates bash
#  completion at runtime by reading `COMP_LINE` / `COMP_POINT`
#  environment variables that bash sets when the user presses
#  TAB.  Used by HashiCorp Vault (32k stars — IN CORPUS via
#  _vault + STOCK on Kali; vault uses posener/complete for
#  every vault subcommand's completion), HashiCorp Nomad (15k
#  stars — IN CORPUS via _nomad), HashiCorp Terraform (45k stars
#  — IN CORPUS via _terraform + STOCK on most distros), HashiCorp
#  Consul (IN CORPUS via _consul), OpenBao (open-source Vault
#  fork — uses posener/complete), and many other HashiCorp +
#  HashiCorp-fork Go tools.  posener/complete is the de-facto
#  completion library FOR THE ENTIRE HASHICORP STACK.
#
#  posener/complete API:
#    import "github.com/posener/complete"
#
#    func main() {
#      // PREDICTORS describe what should be completed where
#      goFiles := complete.PredictFiles("*.go")
#      anyDir := complete.PredictDirs("*")
#
#      // COMMAND struct defines the completion tree for a CLI
#      cmd := complete.Command{
#        Flags: complete.Flags{
#          // Each flag maps to a PREDICTOR that suggests values
#          "-o":         anyFile,                     // -o expects a file
#          "-tags":      complete.PredictAnything,    // -tags expects free-form text
#          "-buildmode": complete.PredictAnything,
#          "-race":      complete.PredictNothing,     // -race is boolean
#          "-covermode": complete.PredictSet("set", "count", "atomic"),
#        },
#        // SUBCOMMAND tree
#        Sub: complete.Commands{
#          "build": {
#            Flags: ...,
#            Args:  goFiles,
#          },
#          "test": {
#            Flags: ...,
#            Args:  goFiles,
#          },
#          "tool": {
#            Sub: complete.Commands{
#              "asm": {
#                Flags: complete.Flags{
#                  "-I": anyDir,
#                  "-D": complete.PredictAnything,
#                  "-S": complete.PredictNothing,
#                },
#                Args: anyFile,
#              },
#              "addr2line": {
#                Args: anyFile,
#              },
#              // ...
#            },
#          },
#        },
#        // Args defines top-level positional completion
#        Args: complete.PredictNothing,
#      }
#
#      // Create the Complete instance + run
#      // Name MUST match the binary it's completing for
#      c := complete.New("go", cmd)
#
#      // Run() adds install/uninstall/yes flags then dispatches:
#      // - if COMP_LINE env var is set, produce completions
#      // - if -install flag is given, install bash completion
#      // - if -uninstall flag is given, remove bash completion
#      // - otherwise, exit and let the wrapper handle normal exec
#      c.Run()
#    }
#
#  posener/complete distinctive features:
#    - PREDICTOR TYPES — `Predict<X>` functions return values
#      for the current completion cursor:
#      * `PredictFiles("*.go")` — files matching glob
#      * `PredictDirs("*")` — directories matching glob
#      * `PredictSet("a", "b", "c")` — fixed set of choices
#      * `PredictAnything` — accepts any value (no specific
#        suggestions; user types freely)
#      * `PredictNothing` — boolean flag (no value expected)
#      * `PredictOr(p1, p2, ...)` — union of predictors
#      * `PredictFunc(fn)` — custom predictor function
#      * `PredictMulti(...)` — multiple values accepted
#    - HIERARCHICAL COMMAND TREE — `complete.Command{Flags, Sub,
#      Args}` recursively nests via `Sub: complete.Commands{...}`
#      for arbitrarily-deep subcommand structures (matches the
#      go tool's own deep `go tool asm ...` style)
#    - PER-FLAG PREDICTOR — `Flags: complete.Flags{"-flag":
#      Predictor}` maps each flag NAME to its value predictor;
#      this is what enables intelligent completion (e.g.
#      `go test -covermode` suggests {set, count, atomic} not
#      arbitrary strings)
#    - INSTALL / UNINSTALL META-COMMANDS — `c.Run()` adds
#      `-install` / `-uninstall` / `-y` flags to the binary
#      itself; running `gocomplete -install` writes
#      `complete -C gocomplete go` to ~/.bashrc to wire up bash
#      completion for the `go` command via this binary
#    - BASH COMPLETION INTEGRATION via COMP_LINE / COMP_POINT
#      env vars — bash sets these when the user presses TAB;
#      gocomplete reads them, parses the partial command line,
#      and emits completion suggestions on stdout (which bash
#      reads back to render the menu)
#    - SHELL SUPPORT — bash (primary), zsh (via bashcompinit),
#      fish (via wrap shim); not as universal as carapace but
#      proven battle-tested in HashiCorp's stack
#    - NO STANDARD CLI PARSING — posener/complete is NOT a
#      general-purpose CLI parser like cobra/urfave-cli; it
#      ASSUMES YOU ALREADY HAVE a CLI framework and want to ADD
#      completion on top.  Callers must integrate posener/
#      complete CALL with their existing flag/cobra/urfave-cli
#      tree by writing a PARALLEL `complete.Command` tree that
#      mirrors the real CLI's flags/subcommands.
#    - DESIGNED FOR INTEGRATION not replacement — HashiCorp's
#      tools use cobra for the REAL CLI parsing and posener/
#      complete for the COMPLETION layer, with the Vault/Nomad/
#      Terraform/Consul codebases maintaining BOTH structures
#      in parallel
#  Distinct from R237 Go spf13/cobra (subcommand-TREE with
#  Command structs + Run/RunE func fields — cobra has its OWN
#  built-in completion via spf13/cobra/doc/cobra-completer or
#  the newer cobra `GenZshCompletion()`/`GenBashCompletion()`
#  methods; cobra is the FRAMEWORK while posener/complete is
#  the COMPLETION-ENGINE alternative for tools that DON'T use
#  cobra), R237 Go spf13/pflag (POSIX-flag-compat), R237 Go
#  urfave/cli (urfave/cli has built-in `BashComplete` field
#  for completion — alternative to posener/complete), R237 Go
#  alecthomas/kingpin (kingpin has `Completion()` method —
#  alternative), R237 Go jessevdk/go-flags, R237 Go mitchellh/
#  cli (HashiCorp Terraform's earlier CLI; uses posener/complete
#  via integration), R262 Go stdlib `flag` (no completion), R363
#  Go peterbourgon/ff (no built-in completion), R367 Go akamensky/
#  argparse, R408 Go pborman/getopt, R411 Go integrii/flaggy
#  (no built-in completion), R414 Go alecthomas/kong (has
#  `--help-long`/`--shell-completion=bash` built-in), R417 Go
#  google/subcommands, R421 Go namsral/flag, R426 Go octago/
#  sflags, R431 Go peterbourgon/ff/v3/ffcli (no built-in
#  completion).  Go documented libraries so far: stdlib flag,
#  pflag, cobra, urfave-cli, kingpin, jessevdk/go-flags,
#  mitchellh/cli, ff, akamensky/argparse, pborman/getopt,
#  flaggy, kong, google/subcommands, namsral/flag, sflags,
#  ffcli, complete (this round)... 18 total.  posener/complete's
#  distinguishing feature vs all other Go libs: posener/complete
#  is the ONLY Go CLI library in the corpus that is
#  COMPLETION-FIRST (every other lib treats completion as an
#  add-on; complete treats CLI parsing as an add-on TO
#  completion).  posener/complete's approach: COMPLETION-FIRST
#  DESIGN with `complete.Command{Flags, Sub, Args}` recursive
#  tree + `complete.Flags{"-flag": Predictor}` per-flag value
#  predictor + PREDICTOR TYPES (PredictFiles/PredictDirs/
#  PredictSet/PredictAnything/PredictNothing/PredictOr/
#  PredictFunc/PredictMulti) + `complete.New(name, command).
#  Run()` entry point that adds `-install`/`-uninstall`/`-y`
#  meta-flags and dispatches based on COMP_LINE env var +
#  BASH COMPLETION INTEGRATION via COMP_LINE/COMP_POINT env
#  vars + DESIGNED FOR INTEGRATION with existing CLI frameworks
#  (cobra/urfave/etc.) + USED BY ENTIRE HASHICORP STACK (Vault/
#  Nomad/Terraform/Consul/OpenBao) — corpus's **first documented
#  completion-first Go CLI library**.  Brings cross-language CLI
#  library taxonomy variant count to 174; Go ecosystem now has
#  18 documented CLI libraries — TYING WITH RUST AND TYPESCRIPT-
#  NODE at the top of the cross-language taxonomy in a THREE-WAY
#  TIE at 18.
#
#  Surface (verbatim from `cmd/cmd.go` CLI.AddFlags method +
#  `complete.go` New/Run flow):
#
#  Usage:
#    gocomplete [-install | -uninstall] [-y]
#    gocomplete                              # when COMP_LINE env
#                                            # var is set (bash
#                                            # completion mode);
#                                            # reads partial cmd
#                                            # line from
#                                            # COMP_LINE/COMP_POINT
#                                            # and emits
#                                            # completions on
#                                            # stdout
#
#  Options (from posener/complete/cmd CLI struct AddFlags):
#    -install                       Install bash completion for
#                                   the "go" command — appends
#                                   `complete -C gocomplete go`
#                                   line to ~/.bashrc (or
#                                   appropriate shell rc file)
#                                   so that pressing TAB after
#                                   `go ...` invokes gocomplete
#                                   for suggestions
#    -uninstall                     Uninstall bash completion
#                                   for the "go" command —
#                                   removes the previously-
#                                   installed `complete -C
#                                   gocomplete go` line from
#                                   shell rc files
#    -y                             Assume "yes" answer to
#                                   prompts (non-interactive
#                                   mode for scripts / CI)
#
#  Bash-completion-protocol environment variables (read at
#  runtime when no install/uninstall flag given):
#    COMP_LINE                      Full command line being
#                                   completed (set by bash on
#                                   TAB)
#    COMP_POINT                     Cursor position within
#                                   COMP_LINE
#    COMP_DEBUG                     Enable debug output to
#                                   /tmp/complete.log (optional)
#
#  Subcommand tree completed FOR (read by gocomplete to suggest
#  completion for the `go` command being completed):
#    go build / go run / go test / go fmt / go vet / go doc /
#    go get / go generate / go list / go tool {addr2line / asm /
#    cgo / compile / cover / dist / link / nm / objdump / pack /
#    pprof / yacc / api / fix} / go env / go install / go clean /
#    go mod {download / edit / graph / init / tidy / vendor /
#    verify / why} / go version / go help
#
#  Examples:
#    gocomplete -install                            # Install bash completion for go cmd
#    gocomplete -install -y                         # Same, non-interactive
#    gocomplete -uninstall                          # Remove bash completion
#    gocomplete -uninstall -y                       # Same, non-interactive
#    # After install, in bash:
#    #   go test -<TAB>                             # Suggests -v, -race, -cover, etc.
#    #   go test -covermode=<TAB>                   # Suggests set, count, atomic
#    #   go tool asm -<TAB>                         # Suggests -I, -D, -S, -shared, etc.
#    #   go build ./<TAB>                           # Suggests Go packages in current dir
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also posener/complete users):
#    - vault (IN CORPUS via _vault + STOCK Kali — HashiCorp Vault
#      32k stars FLAGSHIP posener/complete user; previously
#      documented but posener/complete library not formally
#      entered into taxonomy)
#    - nomad (IN CORPUS via _nomad — HashiCorp Nomad 15k stars;
#      uses posener/complete; previously documented)
#    - terraform (IN CORPUS via _terraform + STOCK — HashiCorp
#      Terraform 45k stars; uses posener/complete; previously
#      documented)
#    - consul (IN CORPUS via _consul — HashiCorp Consul;
#      previously documented)
#    - openbao (kaisenlinux/openbao — open-source Vault fork;
#      FUTURE candidate)
#    - go (IN CORPUS + STOCK via _go — gocomplete completes FOR
#      the `go` command but doesn't replace its CLI)
# ============================================================================

_gocomplete() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '-install[install bash completion for the go command]' \
    '-uninstall[uninstall bash completion for the go command]' \
    '-y[assume yes for prompts (non-interactive)]'
}

_gocomplete "$@"
