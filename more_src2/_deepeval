#compdef deepeval
# Documentation: https://github.com/confident-ai/deepeval
# Reference accessed: 2026-05-22
# Verified: deepeval --help Typer CLI.

# Zsh completion for deepeval - LLM evaluation and Confident AI CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' && ret=0

case $state in
  cmds)
    _values 'deepeval command' \
      'test[run deepeval tests]' \
      'generate[generate synthetic goldens]' \
      'inspect[inspect saved test run traces]' \
      'view[view evaluation results]' \
      'login[login to Confident AI]' \
      'logout[logout from Confident AI]' \
      'settings[manage DeepEval settings]' \
      'set-confident-region[set Confident AI region]' \
      'set-debug[configure debug and logging]' \
      'unset-debug[restore default debug settings]' \
      'set-openai[configure OpenAI provider]' \
      'unset-openai[unset OpenAI provider]' \
      'set-anthropic[configure Anthropic provider]' \
      'unset-anthropic[unset Anthropic provider]' \
      'set-gemini[configure Gemini provider]' \
      'unset-gemini[unset Gemini provider]' \
      'set-ollama[configure Ollama provider]' \
      'unset-ollama[unset Ollama provider]' \
      'set-azure-openai[configure Azure OpenAI]' \
      'unset-azure-openai[unset Azure OpenAI]' \
      'set-litellm[configure LiteLLM provider]' \
      'unset-litellm[unset LiteLLM provider]' && ret=0
    ;;
esac

return ret
