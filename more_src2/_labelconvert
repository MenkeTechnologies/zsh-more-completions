#compdef labelconvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/labelconvert.html
# Source: MRtrix3/mrtrix3 cmd/labelconvert.cpp — remap label image via LUT (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-spine+[manual spine segmentation image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '1:path_in (input label image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:lut_in (input LUT):_files -g "*.txt"' \
    '3:lut_out (output LUT):_files -g "*.txt"' \
    '4:image_out (output label image):_files' \
    && ret=0

return ret
