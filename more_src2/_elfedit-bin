#compdef elfedit
# _elfedit-bin — GNU binutils elfedit; update ELF header / dynamic table without rebuilding
# upstream: https://sourceware.org/binutils

_elfedit-bin() {
    _arguments \
        '--input-mach+[machine]:mach:' \
        '--output-mach+[output machine]:mach:' \
        '--input-type+[type]:type:(none rel exec dyn core)' \
        '--output-type+[output type]:type:(none rel exec dyn core)' \
        '--input-osabi+[osabi]:abi:(none HPUX NetBSD GNU Solaris AIX FreeBSD TRU64 Modesto Openbsd OpenVMS NSK AROS FenixOS CloudABI OpenVOS)' \
        '--output-osabi+[output osabi]:abi:' \
        '--enable-x86-feature+[enable x86 feature]:feat:' \
        '--disable-x86-feature+[disable x86 feature]:feat:' \
        '--merge-notes[merge notes]' \
        '--no-merge-notes[no merge notes]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:file:_files'
}

_elfedit-bin "$@"
