#compdef lando
# Documentation: https://docs.lando.dev/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for Lando - local development environment

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'config:display the Lando configuration'
  'destroy:destroy a Lando app'
  'exec:execute a command in a service'
  'info:print info about the app'
  'init:initialize a Lando app'
  'list:list running Lando apps'
  'logs:display logs for an app'
  'poweroff:spin down all Lando apps'
  'rebuild:rebuild an app'
  'restart:restart an app'
  'share:share your local app publicly'
  'ssh:SSH into a service container'
  'start:start an app'
  'stop:stop an app'
  'update:update Lando'
  'version:display Lando version'
)

_arguments -s -S \
  '--channel=[set update channel]:channel:(edge stable none)' \
  '--clear[clear all Lando task caches]' \
  '--debug[show debug output]' \
  '--help[show help]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'lando command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      init)
        _arguments \
          '--source=[source location]:source:(cwd github remote)' \
          '--src=[source location]:source:(cwd github remote)' \
          '(-r --recipe)'{-r+,--recipe=}'[recipe to use]:recipe:' \
          '--webroot=[webroot relative to app root]:path:' \
          '--name=[app name]:name:' \
          '(-o --option)'{-o+,--option=}'[KEY=VALUE pair merged into recipe config]:kv:' \
          '--full[dump a lower-level lando file]' \
          '--github-auth=[GitHub personal access token]:token:' \
          '--github-repo=[GitHub git URL]:url:' \
          '--remote-url=[URL of git repo or archive]:url:' \
          '--remote-options=[options passed to clone/extract]:opts:' \
          '(-y --yes)'{-y,--yes}'[auto-answer yes]'
        ;;
      ssh|exec)
        _arguments \
          '(-s --service)'{-s+,--service=}'[target service]:service:' \
          '(-u --user)'{-u+,--user=}'[run as user]:user:' \
          '(-c --command)'{-c+,--command=}'[command to run]:command:'
        ;;
      logs)
        _arguments \
          '(-s --service)'{-s+,--service=}'[target service]:service:' \
          '(-f --follow)'{-f,--follow}'[follow log output]' \
          '(-t --timestamps)'{-t,--timestamps}'[show timestamps]'
        ;;
      rebuild)
        _arguments \
          '(-s --service)'{-s+,--service=}'[target service]:service:' \
          '(-y --yes)'{-y,--yes}'[auto-answer yes]'
        ;;
      destroy)
        _arguments '(-y --yes)'{-y,--yes}'[auto-answer yes]'
        ;;
    esac
    ;;
esac

return ret
