#compdef inxi
# _inxi — Smxi inxi system information script CLI (Harald Hope, Perl); custom argparse
# upstream: https://github.com/smxi/inxi

_inxi() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-A[audio info]' \
        '-B[battery info]' \
        '-b[basic output]' \
        '-C[cpu info]' \
        '-D[drive info]' \
        '-d[optical drive info]' \
        '-E[bluetooth info]' \
        '-F[full output]' \
        '-G[graphics info]' \
        '-i[network IP info]' \
        '-I[info: processes/clocks/uptime]' \
        '-J[USB info]' \
        '-l[partition labels]' \
        '-L[logical/lvm/raid info]' \
        '-m[memory/ram info]' \
        '-M[machine info]' \
        '-n[network advanced]' \
        '-N[network info]' \
        '-o[unmounted partition info]' \
        '-p[partitions full]' \
        '-P[partitions partial]' \
        '-r[repos]' \
        '-R[raid info]' \
        '-s[sensors]' \
        '-S[system info]' \
        '-t+[processes]:str:(c m cm cmN m N c N mNN cmNN)' \
        '-u[partition UUIDs]' \
        '-w[weather]' \
        '-W+[weather location]:str:' \
        '-y+[output line width]:n:' \
        '-z[filter privacy data]' \
        '-Z[filter override]' \
        '--admin[admin extra]' \
        '--extra=+[extra data level]:n:(1 2 3)' \
        '-x[extra short]' \
        '-xx[extra medium]' \
        '-xxx[extra long]' \
        '-c+[color scheme]:n:(0 94 95 32 33 34 35 36 37 38)' \
        '--color=+[color scheme]:n:(0 94 95 32 33 34 35 36 37 38)' \
        '--no-color[disable color]' \
        '-Y[disable color]' \
        '--output=+[output type]:o:(json xml screen)' \
        '--output-file=+[output file]:file:_files' \
        '--recommends[check recommended programs]' \
        '--debug=+[debug level]:n:' \
        '--filter[apply filter]' \
        '--filter-override[override filters]' \
        '--limit=+[limit dimm/cpu lines]:n:' \
        '--sleep=+[cpu sleep secs]:f:' \
        '--vs[version + perl info]' \
        '*:arg:'
}

_inxi "$@"
