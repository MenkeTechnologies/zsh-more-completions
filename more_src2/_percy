#compdef percy
# Documentation: https://www.npmjs.com/package/@percy/cli
# Reference accessed: 2026-05-23
# Verified: npx @percy/cli --help.

# Zsh completion for percy - Percy visual testing CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'doctor:diagnose network and configuration'
  'exec:start and stop Percy around a command'
  'exec:start:start a local Percy process'
  'exec:stop:stop a local Percy process'
  'exec:ping:ping a local Percy process'
  'exec:replay:upload archived snapshots'
  'replay:upload archived snapshots'
  'snapshot:snapshot a directory, file, or sitemap'
  'upload:upload a directory of images'
  'build:finalize:finalize parallel builds'
  'build:wait:wait for build completion'
  'build:id:print build ID from local process'
  'build:approve:approve builds'
  'build:unapprove:unapprove builds'
  'build:reject:reject builds'
  'build:delete:delete builds'
  'config:create:create Percy config file'
  'config:validate:validate Percy config file'
  'config:migrate:migrate Percy config file'
  'help:display command help'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-V --version)'{-V,--version}'[show version]'   '(-v --verbose)'{-v,--verbose}'[verbose logging]'   '(-q --quiet)'{-q,--quiet}'[errors only]'   '(-s --silent)'{-s,--silent}'[silent mode]'   '(-l --labels)'{-l,--labels=}'[associate build labels]:labels:'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'percy command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
