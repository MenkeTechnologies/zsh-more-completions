#compdef llvm-debuginfod-find
# _llvm-debuginfod-find — LLVM debuginfod client (LLVM project, C++); fetch debug info/source from debuginfod servers by build-id
# upstream: https://github.com/llvm/llvm-project

_llvm-debuginfod-find() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--dump[dump fetched data]' \
        '--build-id=+[build id hex]:hex:' \
        '--executable[fetch executable]' \
        '--source=+[fetch source]:path:_files' \
        '--debuginfo[fetch debug info]' \
        '*:arg:'
}

_llvm-debuginfod-find "$@"
