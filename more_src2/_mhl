#compdef mhl
# Documentation: man mhl(1)
# Source: nmh uip/mhlsbr.c (master) — produce formatted listings of nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-bell -nobell)-bell[ring bell at pause]' \
    '(-bell -nobell)-nobell[no bell]' \
    '(-clear -noclear)-clear[clear screen between messages]' \
    '(-clear -noclear)-noclear[no clear]' \
    '-folder+[folder context]:folder:_default' \
    '-form+[format file]:file:_files' \
    '-moreproc+[pager program]:cmd:_command_names -e' \
    '-nomoreproc[no pager]' \
    '-length+[output length lines]:N:_default' \
    '-width+[output width columns]:N:_default' \
    '-sleep+[pause seconds]:seconds:_default' \
    '(-dashstuffing -nodashstuffing)-dashstuffing[dash-stuff]' \
    '(-dashstuffing -nodashstuffing)-nodashstuffing[no dash-stuff]' \
    '-version[show version]' \
    '-help[show help]' \
    '-forward[forward-mode invocation]' \
    '-forwall[forwall-mode invocation]' \
    '-digest+[digest list]:digest:_default' \
    '-volume+[digest volume]:N:_default' \
    '-issue+[digest issue]:N:_default' \
    '-nobody[skip message body]' \
    '-fmtproc+[format program]:cmd:_command_names -e' \
    '-nofmtproc[no format program]' \
    '*:file:_files' \
    && ret=0

return ret
