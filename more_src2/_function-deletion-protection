#compdef function-deletion-protection
# _function-deletion-protection — Crossplane composition function that fails the pipeline if any composed resource is about to be deleted (gRPC server consumed by crossplane)
# upstream: https://github.com/crossplane-contrib/function-deletion-protection
# Flags from main.go on tip (alecthomas/kong).

_function-deletion-protection() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[emit debug logs in addition to info logs]' \
        '--network=[network on which to listen for gRPC connections]:net:(tcp unix)' \
        '--address=[address on which to listen for gRPC connections]:addr:' \
        '--tls-server-certs-dir=[directory containing server tls.key + tls.crt + ca.crt]:dir:_files -/' \
        '--insecure[run without mTLS credentials (--tls-server-certs-dir is ignored)]' \
        '--max-recv-message-size=[max received message size (MB)]:n:'
}

_function-deletion-protection "$@"
