#compdef doitlive
# Documentation: https://github.com/sloria/doitlive
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# doitlive uses Click's auto-generated zsh completion via _DOITLIVE_COMPLETE.
_doitlive() {
  eval $(env COMMANDLINE="${words[1,$CURRENT]}" _DOITLIVE_COMPLETE=complete-zsh  doitlive)
}
if [[ "$(basename -- ${(%):-%x})" != "_doitlive" ]]; then
  compdef _doitlive doitlive
fi
