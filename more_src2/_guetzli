#compdef guetzli
# Documentation: https://github.com/google/guetzli
# Reference accessed: 2026-05-16
# Verified: upstream google/guetzli README + guetzli.cc PrintUsage().
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --help/--memlimit/--nomemlimit flags (upstream guetzli
# has no --help; --memlimit was added by some packagers but is not
# in upstream).

# guetzli: Google perceptual JPEG encoder
local curcontext="$curcontext" ret=1
_arguments -C \
  '--quality=[visual quality (libjpeg-equivalent; min 84)]:Q:' \
  '--verbose[print encoding trace]' \
  '1:input file:_files -g "*.(png|jpg|jpeg)(-.)"' \
  '2:output file:_files -g "*.(jpg|jpeg)(-.)"' && ret=0
return ret
