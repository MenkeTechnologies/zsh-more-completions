#compdef falcon-web falcon-inspect-app
# _falcon-web — Falcon Python WSGI/ASGI micro-framework inspector CLI alias (Falcon project, Python); argparse
# upstream: https://github.com/falconry/falcon

_falcon-web() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--routes-only[print only routes]' \
        '-r[print only routes]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '*:app-spec:'
}

_falcon-web "$@"
