#compdef namecheap-cli
# _namecheap-cli — Namecheap domain registrar/DNS CLI alias (community implementations); custom argparse
# upstream: https://www.namecheap.com/support/api/intro/

_namecheap-cli() {
    local -a sub=(
        'domain:list:list domains'
        'domain:check:check availability'
        'domain:register:register domain'
        'domain:renew:renew domain'
        'domain:reactivate:reactivate domain'
        'domain:transfer:transfer domain'
        'domain:transfer:status:transfer status'
        'domain:info:get domain info'
        'domain:contacts:show contacts'
        'domain:contacts:set:set contacts'
        'domain:lock:lock domain'
        'domain:unlock:unlock domain'
        'domain:nameservers:get:get nameservers'
        'domain:nameservers:set:set nameservers'
        'domain:nameservers:reset:reset nameservers'
        'dns:get-hosts:get host records'
        'dns:set-hosts:set host records'
        'dns:set-default:set default DNS'
        'dns:set-email:set email forwarding'
        'dns:get-email:get email forwarding'
        'ssl:list:list ssl certificates'
        'ssl:activate:activate ssl'
        'ssl:renew:renew ssl'
        'ssl:reissue:reissue ssl'
        'whois-guard:enable:enable whois guard'
        'whois-guard:disable:disable whois guard'
        'whois-guard:renew:renew whois guard'
        'whois-guard:allow:allow address'
        'whois-guard:change:change email address'
        'users:get-balances:get balances'
        'users:create-add-funds-request:add funds'
        'users:get-pricing:get pricing'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-user=+[api user]:str:' \
        '--api-key=+[api key]:str:' \
        '--username=+[username]:user:_users' \
        '--client-ip=+[client ip]:str:' \
        '--config=+[config file]:file:_files' \
        '--sandbox[sandbox mode]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'namecheap subcommand' sub ;;
        args)
            case $words[1] in
                domain:check|domain:register|domain:renew|domain:reactivate|domain:transfer|domain:info|domain:contacts|domain:lock|domain:unlock) _arguments '1:domain:' ;;
                domain:nameservers:set) _arguments '1:domain:' '*:nameserver:_hosts' ;;
                dns:set-hosts) _arguments \
                    '1:domain:' \
                    '--type=+[record type]:t:(A AAAA CNAME MX MXE TXT URL URL301 FRAME NS)' \
                    '--name=+[host]:str:' \
                    '--address=+[address]:str:' \
                    '--ttl=+[ttl]:n:' \
                    '--prio=+[priority]:n:' ;;
            esac
            ;;
    esac
}

_namecheap-cli "$@"
