#compdef gpioget
# _gpioget — Bartosz Golaszewski libgpiod gpioget CLI for reading the current value of one or more GPIO lines on a specified chip with optional active-low bias as-is pull-up pull-down (linux team, C); getopt
# upstream: https://git.kernel.org/pub/scm/libs/libgpiod/libgpiod.git

_gpioget() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-l[active low]' \
        '--active-low[active low]' \
        '-B+[bias]:b:(as-is disable pull-down pull-up)' \
        '--bias=+[bias]:b:(as-is disable pull-down pull-up)' \
        '*:chip line:'
}

_gpioget "$@"
