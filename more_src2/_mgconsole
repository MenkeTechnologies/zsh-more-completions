#compdef mgconsole
# Documentation: https://memgraph.com/docs/getting-started/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mgconsole: Memgraph CLI (uses gflags; -flag and --flag both work)
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help on all flags]' \
  '(- *)--helpfull[show help on all flags]' \
  '(- *)--helpshort[show help on main module only]' \
  '(- *)--version[show version and build info]' \
  '--host=[server address]:host:_hosts' \
  '--port=[server port]:port:' \
  '--username=[database username]:user:_users' \
  '--password=[database password]:pw:' \
  '--use_ssl=[use SSL]:bool:(true false)' \
  '--csv_doublequote=[quote inner quotechars]:bool:(true false)' \
  '--csv_escapechar=[CSV escape character]:char:' \
  '--csv_delimiter=[CSV field delimiter]:char:' \
  '--output_format=[query output format]:fmt:(csv tabular cypherl)' \
  '--fit_to_screen=[fit output width to screen]:bool:(true false)' \
  '--no_history=[disable history]:bool:(true false)' \
  '--history=[history directory]:dir:_files -/' \
  '--term_colors=[terminal color syntax highlighting]:bool:(true false)' \
  '--verbose_execution_info=[print query execution metrics]:bool:(true false)' \
  '--flagfile=[load flags from file]:file:_files' \
  '--fromenv=[set flags from environment]:vars:' \
  '--tryfromenv=[set flags from env if present]:vars:' \
  '--undefok=[allow specified undefined flags]:vars:' \
  '*: :_files' && ret=0

return ret
