#compdef deeplake activeloop
# Documentation: https://docs.activeloop.ai/setup/authentication
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:log in to Deep Lake / Activeloop platform'
  'logout:log out of Activeloop'
  'register:create an Activeloop account'
  'reset:reset password'
  'reporting:opt in/out of usage reporting'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'activeloop command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (login)
        _arguments \
          '(-u --username)'{-u,--username}'=[username]:user:' \
          '(-p --password)'{-p,--password}'=[password]:password:' \
          '(-t --token)'{-t,--token}'=[API token]:token:' && ret=0 ;;
    esac ;;
esac

return ret
