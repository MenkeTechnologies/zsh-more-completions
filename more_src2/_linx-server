#
# THE linx-server CLI — Go stdlib flag + iniflags + pongo2 + Goji
#
# linx-server's CLI is in server.go.  Uses Go stdlib `flag`
# package wrapped with vharitonsky/iniflags (.ini config file
# support sharing flag namespace).
#
# Flags (30+ via flag.StringVar / BoolVar / Int64Var):
#   -bind ADDR                IP:port to bind (default 127.0.0.1:8080)
#   -filespath PATH           files storage directory
#   -metapath PATH            metadata storage directory
#   -sitename NAME            site name for UI / Open Graph
#   -siteurl URL              public-facing site URL
#   -selifpath PATH           direct-file path prefix
#                             (default "selif")
#   -certfile FILE            TLS certificate file
#   -keyfile FILE             TLS private key file
#   -realip                   trust X-Real-IP header
#   -nologs                   disable request logging
#   -allowhotlink             allow hotlinking from other sites
#   -basicauth                require HTTP Basic Auth
#   -authfile FILE            HTTP Basic Auth credentials file
#   -remoteauthfile FILE      remote-upload API keys file
#   -fastcgi                  run as FastCGI backend
#   -remoteuploads            allow remote URL uploads
#   -nodirectagents           block certain User-Agents from
#                             direct file access
#   -contentsecuritypolicy CSP override CSP header for UI
#   -filecontentsecuritypolicy CSP
#                             override CSP for file responses
#   -referrerpolicy POLICY    Referrer-Policy for UI
#   -filereferrerpolicy POLICY
#                             Referrer-Policy for file responses
#   -xframeoptions VALUE      X-Frame-Options header
#                             (default SAMEORIGIN)
#   -addheaders HEADER        additional HTTP header (repeatable)
#   -maxsize BYTES            maximum upload size
#   -maxexpiry SECONDS        maximum allowed expiry
#   -s3-endpoint URL          S3-compatible endpoint URL
#   -s3-region REGION         S3 region
#   -s3-bucket BUCKET         S3 bucket name
#   -s3-force-path-style      force S3 path-style addressing
#   -force-random-filename    always generate random filenames
#   -access-key-cookie-expiry SECONDS
#                             access-key cookie lifetime
#   -custompagespath PATH     custom pages directory
#   -cleanup-every-minutes N  cleanup interval for expired files
#   -config FILE              .ini config file path (iniflags)
#
# pongo2 is used throughout the templates/ directory for
# rendering UI pages (upload page, info page, file display
# page, etc.).
#
# Five-axis distinctness from tera (R673):
#
#   1. JINJA2 SYNTAX in Go — same syntax family as tera but
#      Go-native runtime.
#
#   2. REFLECTION-BASED CONTEXT LOOKUP — Go reflect package.
#
#   3. AUTO-ESCAPE BY DEFAULT — HTML safety built-in.
#
#   4. DJANGO-SPECIFIC FILTERS — timesince/timeuntil/
#      pluralize/slugify/etc.
#
#   5. FLORIAN-SCHLACHTER / flosch ECOSYSTEM PROVENANCE —
#      German maintainer; distinct from Keats (French).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/andreimarcu/linx-server/blob/master/server.go
# Go stdlib flag.StringVar / BoolVar / Int64Var / Uint64Var
# definitions.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '-bind=[IP:port to bind (default 127.0.0.1:8080)]:addr:_default' \
    '-filespath=[files storage directory]:directory:_files -/' \
    '-metapath=[metadata storage directory]:directory:_files -/' \
    '-sitename=[site name for UI]:name:_default' \
    '-siteurl=[public-facing site URL]:url:_default' \
    '-selifpath=[direct-file path prefix]:path:_default' \
    '-certfile=[TLS certificate file]:file:_files' \
    '-keyfile=[TLS private key file]:file:_files' \
    '-realip[trust X-Real-IP header]' \
    '-nologs[disable request logging]' \
    '-allowhotlink[allow hotlinking from other sites]' \
    '-basicauth[require HTTP Basic Auth]' \
    '-authfile=[HTTP Basic Auth credentials file]:file:_files' \
    '-remoteauthfile=[remote-upload API keys file]:file:_files' \
    '-fastcgi[run as FastCGI backend]' \
    '-remoteuploads[allow remote URL uploads]' \
    '-nodirectagents[block User-Agents from direct file access]' \
    '-contentsecuritypolicy=[CSP for UI]:csp:_default' \
    '-filecontentsecuritypolicy=[CSP for file responses]:csp:_default' \
    '-referrerpolicy=[Referrer-Policy for UI]:policy:_default' \
    '-filereferrerpolicy=[Referrer-Policy for file responses]:policy:_default' \
    '-xframeoptions=[X-Frame-Options header]:value:(DENY SAMEORIGIN ALLOW-FROM)' \
    '*-addheaders=[additional HTTP header]:header:_default' \
    '-maxsize=[maximum upload size in bytes]:bytes:_default' \
    '-maxexpiry=[maximum allowed expiry in seconds]:seconds:_default' \
    '-s3-endpoint=[S3-compatible endpoint URL]:url:_default' \
    '-s3-region=[S3 region]:region:_default' \
    '-s3-bucket=[S3 bucket name]:bucket:_default' \
    '-s3-force-path-style[force S3 path-style addressing]' \
    '-force-random-filename[always generate random filenames]' \
    '-access-key-cookie-expiry=[access-key cookie lifetime in seconds]:seconds:_default' \
    '-custompagespath=[custom pages directory]:directory:_files -/' \
    '-cleanup-every-minutes=[cleanup interval for expired files]:minutes:_default' \
    '-config=[.ini config file path]:file:_files -g "*.ini"' \
    && ret=0

return ret
