#compdef ngrep-tool
# _ngrep-tool — ngrep wrapper helper (custom shell wrapper around ngrep(8) seen in some distros that pre-tunes output for legibility (color, line-buffered, simple BPF expression); -d interface, -i ignore case, -W (none|byline|single|dump) output mode, -t timestamp, -T relative timestamp, -O write pcap, -I read pcap, -c match max, -n stop after N matches; positional argument is the match pattern then BPF filter)
# upstream: https://github.com/jpr5/ngrep
# Flags from ngrep ngrep.c on tip.

_ngrep-tool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d+[interface]:interface:_net_interfaces' \
        '-i[ignore case]' \
        '-W+[output mode]:mode:(none byline single dump)' \
        '-t[timestamp]' \
        '-T[relative timestamp]' \
        '-O+[write pcap]:file:_files -g "*.(pcap|pcapng)"' \
        '-I+[read pcap]:file:_files -g "*.(pcap|pcapng)"' \
        '-c+[match width]:width:' \
        '-n+[stop after N matches]:n:' \
        '-A+[trailing context]:n:' \
        '-s+[snaplen]:bytes:' \
        '-q[quiet]' \
        '-x[show hex dump]' \
        '-X[treat pattern as hex]' \
        '-w[match whole expression]' \
        '-v[invert match]' \
        '-D[delay]' \
        '-e[empty match]' \
        '1:pattern:' \
        '*:BPF filter:'
}

_ngrep-tool "$@"
