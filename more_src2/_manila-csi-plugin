#compdef manila-csi-plugin
# _manila-csi-plugin — OpenStack Manila shared-file-system CSI driver
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from cmd/manila-csi-plugin/main.go on tip.

_manila-csi-plugin() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--endpoint=[CSI endpoint (unix sock or tcp host\:port)]:endpoint:' \
        '--drivername=[CSI driver name]:name:' \
        '--nodeid=[DEPRECATED: node ID]:id:' \
        '--nodeaz=[DEPRECATED: node availability zone]:az:' \
        '--runtime-config-file=[runtime configuration file]:file:_files' \
        '--with-topology=[cluster is topology-aware]:bool:(true false)' \
        '--share-protocol-selector=[Manila share protocol]:proto:(NFS CEPHFS)' \
        '--fwdendpoint=[CSI Node Plugin endpoint to forward Node RPCs]:endpoint:' \
        '--compatibility-settings=[compatibility-layer settings]:csv:' \
        '*--user-agent=[extra gophercloud user-agent component]:component:' \
        '--cluster-id=[cluster identifier]:id:' \
        '--provide-controller-service=[run the controller service]:bool:(true false)' \
        '--provide-node-service=[run the node service]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_manila-csi-plugin "$@"
