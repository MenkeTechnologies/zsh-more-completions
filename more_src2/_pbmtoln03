#compdef pbmtoln03
# Documentation: man pbmtoln03 (Netpbm)
# Source: convert a PBM image to a DEC LN03+ printer command stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r[reverse bit order]' \
    '-l[landscape orientation]' \
    '-t[top-of-form before each image]' \
    '-b[break each line]' \
    '-f[form feed at end]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
