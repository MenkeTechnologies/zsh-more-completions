#compdef fedpkg centpkg rhpkg
# Documentation: man fedpkg(1)
# Source: network-box/fedpkg src/fedpkg.bash (master) — Fedora packaging system CLI (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'build:request a build'
    'chain-build:build current pkg, requesting chain'
    'ci:commit changes (alias of commit)'
    'clean:clean source tree'
    'clog:make %changelog block from git log'
    'clone:clone a module from dist-git'
    'co:alias of clone'
    'commit:commit changes to dist-git'
    'compile:local rpmbuild --short-circuit -bc'
    'diff:show diff'
    'gimmespec:show specfile name'
    'giturl:return URL for a build'
    'help:show help'
    'gitbuildurl:return git+URL with hash for a build'
    'import:import an SRPM into dist-git'
    'install:local rpmbuild --short-circuit -bi'
    'lint:run rpmlint'
    'local:local rpmbuild -ba'
    'mockbuild:build SRPM in mock'
    'mock-config:dump mock config'
    'new:show diff vs last tag'
    'new-sources:upload new sources (replace)'
    'patch:apply patch with quilt-style metadata'
    'prep:local rpmbuild -bp'
    'pull:pull from remote'
    'push:push to remote'
    'retire:retire a package'
    'scratch-build:request a scratch build'
    'sources:download package sources'
    'srpm:create an SRPM'
    'switch-branch:switch active branch'
    'tag:create/list/delete tags'
    'tag-request:request rel-eng tag'
    'unused-patches:show patches unused by spec'
    'update:submit bodhi update'
    'upload:upload new sources (append)'
    'verify-files:verify file list'
    'verrel:show name-version-release'
)

_arguments -s -C \
    '(- *)--help[show help]' \
    '(-v -q)-v[verbose]' \
    '(-v -q)-q[quiet]' \
    '--dist=[distribution target]:dist:_default' \
    '--user=[user name]:user:_default' \
    '--path=[path to package]:path:_files -/' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'fedpkg command' cmds && ret=0 ;;
esac

return ret
