#compdef ptybandage ptyrun
# Documentation: source-direct extraction from upstream jdebp/nosh
# source/{ptybandage,ptyrun} - both are 5-line execline scripts
# (decoded from the `#!/command/execlineb -S0` shebang plus the
# body `pty-allocate / pty-run [-t] / setsid /
# open-controlling-tty --exclusive -- / $@`). They take no flags
# of their own; the wrapped program follows as $@.
# Reference accessed: 2026-05-30 via gh api.
# jdebp/nosh pty helpers R132e — 2-stem multi-binary harvest of
# the two nosh pty-wrapping execline shell wrappers. ptybandage
# adds a -t (tty allocation marker) flag to its inner pty-run
# whereas ptyrun does not. Both compose pty-allocate + setsid +
# open-controlling-tty around the target program so that the
# program runs as if it were attached to a real tty even when its
# stdin/stdout are pipes or sockets.

case $service in

  ptybandage)
    # Wrap a program in a fresh pty pair where the program thinks
    # it has a controlling tty. Used by nosh service definitions
    # for programs that misbehave when not attached to a tty.
    _arguments -s -S \
      '*:program and arguments:_command_names -e'
    ;;

  ptyrun)
    # Like ptybandage but without the -t flag passed through to
    # the inner pty-run (slightly different tty allocation
    # semantics on BSDs).
    _arguments -s -S \
      '*:program and arguments:_command_names -e'
    ;;

esac
