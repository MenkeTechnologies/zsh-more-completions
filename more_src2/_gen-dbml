#compdef gen-dbml
# _gen-dbml — generate DBML (Database Markup Language) from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/dbmlgen.py (click).

_gen-dbml() {
    local -a args
    args=(
        '(-s --schema)'{-s+,--schema=}'[LinkML schema YAML file]:file:_files -g "*.(yaml|yml)"'
        '(-o --output)'{-o+,--output=}'[output DBML file (default stdout)]:file:_files -g "*.dbml"'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
    )
    _arguments -s -S $args
}

_gen-dbml "$@"
