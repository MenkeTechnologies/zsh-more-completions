#compdef gethostlatency gethostlatency-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/gethostlatency.py argparse)
# Reference accessed: 2026-05-29
# gethostlatency — trace getaddrinfo/gethostbyname[2]() libc calls and their latency (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only (default -1=all)]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  && ret=0

return ret
