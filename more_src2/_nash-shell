#compdef nash
# _nash-shell — Nash modular and secure shell (Tiago Katcipis et al, Go); secure shell with required arg patterns
# upstream: https://github.com/madlambda/nash

_nash-shell() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-c+[command]:code:' \
        '-norc[do not load rc]' \
        '-debug[debug]' \
        '-noinit[skip init script]' \
        '-stdin[read from stdin]' \
        '-interactive[interactive]' \
        '-trace[trace execution]' \
        '*:script:_files -g "*.sh"'
}

_nash-shell "$@"
