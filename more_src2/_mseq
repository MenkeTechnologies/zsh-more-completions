#compdef mseq
# Documentation: https://manpages.debian.org/testing/mblaze/mseq.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. mblaze mseq sequence manager.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-S[set sequence from stdin filenames]' \
  '-A[append to sequence from stdin]' \
  '-C[set current message and exit]:msg:' \
  '-c[behave as if msg was the current message]:msg:' \
  '-f[fix non-existing filenames by maildir id search]' \
  '-r[remove leading indentation from filenames]' \
  '*:message range:' && ret=0

return ret
