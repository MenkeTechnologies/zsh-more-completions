#compdef gh-cleanup-notifications gh-issue-estimate gh-is-ai-native
# Documentation: upstream READMEs at github.com/{awendt/gh-cleanup-notifications,sgoedecke/gh-issue-estimate,webmaxru/gh-is-ai-native}
# Reference accessed: 2026-05-30
# gh-extension family round 12. JavaScript slice harvest.
# Hunt-skip log this round:
#   gh-dep (MeroFuruya/gh-dep) — ARCHIVED 2025-12-13, config-file driven
#     (dep.json) with no CLI flag surface. Skip per archived-no-surface.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-cleanup-notifications)
    # awendt/gh-cleanup-notifications — auto-clean GitHub notifications.
    # Polls every minute and respects API rate-limit headers.
    _arguments -s -S \
      '--dry-run[preview changes without applying]' \
      '--verbose[verbose logging of API requests]' \
      '--cleanup-closed-prs[mark closed-PR notifications as done]' \
      '--cleanup-reassigned-prs[remove + unsubscribe from reassigned-PR notifications]' \
      '--cleanup-review-requests[clean up review-request notifications when reviews are complete]' \
      '--config=[JSON rules file]:file:_files -g "*.json"' \
      && ret=0
    ;;

  gh-issue-estimate)
    # sgoedecke/gh-issue-estimate — post-completion analysis of issues via
    # linked PR diffs. Categorizes work as Small/Medium/Large.
    _arguments -s -S \
      '--json[programmatic output]' \
      '*:issue URL, PR URL, or issue number:' \
      && ret=0
    ;;

  gh-is-ai-native)
    # webmaxru/gh-is-ai-native — detect AI-native primitives in a repo.
    # Has 1 documented subcommand (scan) which takes the target positional.
    local -a _subcmds
    _subcmds=(
      'scan:scan local filesystem or remote GitHub repo for AI primitives'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-is-ai-native subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          scan)
            _arguments \
              '--output=[output format]:format:(human json csv summary)' \
              '--fail-below=[exit code 2 if score below this threshold]:N:' \
              '*:target (local path or OWNER/REPO):_files' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
