#compdef latexmk
# _latexmk — John Collins latexmk Perl wrapper for running pdflatex xelatex lualatex bibtex biber makeindex repeatedly until references resolved with continuous-build modes (jcollins team, Perl); getopt
# upstream: https://ctan.org/pkg/latexmk

_latexmk() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-quiet[quiet]' \
        '-silent[silent]' \
        '-pdf[run pdflatex]' \
        '-pdfdvi[via dvi to pdf]' \
        '-pdfps[via ps to pdf]' \
        '-pdfxe[run xelatex]' \
        '-xelatex[run xelatex]' \
        '-pdflua[run lualatex]' \
        '-lualatex[run lualatex]' \
        '-dvi[output dvi]' \
        '-ps[output ps]' \
        '-pv[preview pdf]' \
        '-pvc[preview continuous]' \
        '-c[clean intermediate files]' \
        '-C[clean all output]' \
        '-CA[clean all output]' \
        '-bibtex[run bibtex]' \
        '-nobibtex[no bibtex]' \
        '-bibtex-cond[bibtex conditional]' \
        '-bibfudge[bib fudge]' \
        '-recorder[use recorder]' \
        '-norecorder[no recorder]' \
        '-shell-escape[allow shell escape]' \
        '-no-shell-escape[no shell escape]' \
        '-synctex=+[N]:n:(-1 0 1)' \
        '-interaction=+[mode]:m:(batchmode nonstopmode scrollmode errorstopmode)' \
        '-jobname=+[name]:str:' \
        '-output-directory=+[dir]:dir:_files -/' \
        '-outdir=+[dir]:dir:_files -/' \
        '-auxdir=+[dir]:dir:_files -/' \
        '-aux-directory=+[dir]:dir:_files -/' \
        '-deps[print deps]' \
        '-deps-out=+[file]:file:_files' \
        '-print=+[t]:t:(dvi ps pdf)' \
        '-r+[rc file]:file:_files -g "*.latexmkrc *.rc"' \
        '-rc-report[report rc files]' \
        '-norc[no rc files]' \
        '-Werror[warnings as errors]' \
        '-time[time runs]' \
        '-use-make[use make]' \
        '-pretex=+[code]:str:' \
        '-usepretex=+[code]:str:' \
        '*:LaTeX file:_files -g "*.tex *.ltx *.dtx *.ins *.fdb_latexmk *.bib"'
}

_latexmk "$@"
