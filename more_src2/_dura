#compdef dura
# Documentation: https://github.com/tkellogg/dura
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dura - background git commit saver (Rust, clap)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  subcmd)
    local -a subcmds=(
      'capture:run a single backup of an entire repository'
      'serve:start the watcher that listens for file changes'
      'watch:add the current directory to the watch list'
      'unwatch:remove the current directory from the watch list'
      'kill:stop the running serve worker'
      'status:show daemon status and list watched repositories'
      'metrics:convert logs into snapshot metrics'
      'help:show help for a subcommand'
    )
    _describe -t commands 'dura subcommand' subcmds && ret=0
    ;;
  args)
    case $words[1] in
      capture|watch|unwatch)
        _arguments \
          '(-i --include)'{-i+,--include=}'[re-include directories]:dir:_directories' \
          '(-e --exclude)'{-e+,--exclude=}'[exclude directories]:dir:_directories' \
          '(-d --maxdepth)'{-d+,--maxdepth=}'[recursion depth (default 255)]:n:' \
          '*:directory:_directories' && ret=0
        ;;
      serve)
        _arguments '--logfile=[custom logfile path]:file:_files' && ret=0
        ;;
      status)
        _arguments '--json[output JSON]' && ret=0
        ;;
      metrics)
        _arguments \
          '(-i --input)'{-i+,--input=}'[log file to read]:file:_files' \
          '(-o --output)'{-o+,--output=}'[JSON output file]:file:_files' && ret=0
        ;;
      help)
        local -a subcmds=(capture serve watch unwatch kill status metrics help)
        _describe -t commands 'subcommand' subcmds && ret=0
        ;;
    esac
    ;;
esac

return ret
