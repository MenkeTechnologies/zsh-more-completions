#compdef manga-tui
# ============================================================================
# manga-tui - Terminal manga reader + downloader (Rust, MIT)
#
# Author : Josue Barreto (josueBarretogit)
# Upstream: https://github.com/josueBarretogit/manga-tui
#
# manga-tui is a ratatui-based Terminal UI manga reader + downloader
# that pulls chapters from MangaDex, Weebcentral, and Mangapill,
# renders panels inline with `ratatui-image` (sixel / iTerm / Kitty
# graphics protocols), and exports completed chapters to EPUB +
# CBZ + raw image archives for offline viewing. It optionally
# integrates with AniList for reading-progress sync via OAuth2 +
# the AniList GraphQL API.
#
# The EPUB emission lane is built on `epub-builder = "0.8.0"`
# (declared verbatim at upstream Cargo.toml HEAD), the canonical
# Rust EPUB writer by Elisabeth Henry (crowdagger /
# crowdagger/epub-builder, 167 stars). The library implements the
# EPUB 3.x package format end-to-end: Open Container Format zip
# wrapper, OPF (Open Packaging Format) manifest + spine + metadata
# (Dublin Core), NCX (Navigation Control file for XML; EPUB 2.x
# back-compat), the EPUB 3 nav.xhtml table of contents document,
# the XHTML 1.1 + SVG 1.1 content profile, and (X)HTML escaping.
# It uses `zip` for the OCF wrapper, `mime_guess` for content-type
# resolution, and `epub-builder::style::*` modules for default
# stylesheets.
#
# ----------------------------------------------------------------------------
# AXIS 203 :: EPUB GENERATION (EPUB 2 / EPUB 3 / OPF / NCX)
# Round 1307 :: Rust slot 1 of 4 :: OPENS Axis 203
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : crowdagger/epub-builder        - EPUB 3 builder + EPUB 2 back-compat
#   Go      : bmaupin/go-epub                - EPUB 3 builder
#   TS/Node : cyrilis/epub-gen               - EPUB 3 builder
#
# All three target the EPUB 3.x package format (W3C Recommendation
# since 2017) with EPUB 2.x back-compat for older readers. The
# format is a zip archive (OCF) containing an OPF package document
# (metadata + manifest + spine), one or more (X)HTML 1.1 content
# documents, optional CSS / images / fonts, and a nav.xhtml table
# of contents. The three libraries differ on builder ergonomics:
# epub-builder in Rust uses a typed `EpubBuilder` accumulator;
# bmaupin/go-epub uses struct-method chaining; cyrilis/epub-gen
# uses a declarative options object passed to a single function
# call. All three produce valid EPUBs that pass `epubcheck`.
#
# manga-tui is the Rust opener - a real downstream consumer
# emitting one EPUB per manga chapter (or per manga title in
# bulk mode) with inline-image-heavy XHTML content. Manga is
# a stress test for EPUB generation: many embedded images, RTL
# reading direction (Japanese / Arabic), per-page Spine entries,
# and large file counts per chapter. This exercises the full
# epub-builder pipeline rather than a "hello, world" e-book
# generator demo.
# ============================================================================

_manga-tui() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-d --data-dir)'{-d,--data-dir}'[print the data directory and exit]' \
        '(-c --config-dir)'{-c,--config-dir}'[print the config directory and exit]' \
        '(-p --provider)'{-p,--provider}'[manga provider]:provider:(mangadex weebcentral mangapill)' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_manga_tui_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                lang)     _manga_tui_lang ;;
                anilist)  _manga_tui_anilist ;;
            esac
            ;;
    esac

    return ret
}

_manga_tui_cmds() {
    local -a cmds
    cmds=(
        'lang:Manage preferred reading language'
        'anilist:Configure AniList reading-progress sync'
    )
    _describe -t commands 'manga-tui command' cmds
}

_manga_tui_lang() {
    _arguments \
        '(-p --print)'{-p,--print}'[print the active reading language]' \
        '(-s --set)'{-s,--set}'[set the preferred reading language code]:language:' \
        '(- *)'{-h,--help}'[help]'
}

_manga_tui_anilist() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(init check)'
}

_manga-tui "$@"
