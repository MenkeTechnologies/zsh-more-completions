#compdef dulwich
# Documentation: upstream cli.py source at github.com/jelmer/dulwich/blob/master/dulwich/cli.py
# Reference accessed: 2026-05-30
# dulwich — pure-Python git implementation. CLI mimics git's verb set
# with 100+ subcommands. State-machine dispatch with grouped sub-actions
# for `notes`/`replace`/`stash`/`submodule`/`worktree`.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'add:add file contents to the index'
  'annotate:annotate each line in a file with commit information'
  'archive:create an archive of files from a named tree'
  'bisect:binary search for a commit'
  'blame:show what revision/author last modified each line'
  'branch:list, create, or delete branches'
  'bundle:move objects between repositories via archive files'
  'check-ignore:debug gitignore / exclude files'
  'check-mailmap:check committer/author names via mailmap'
  'checkout:switch branches or restore working tree files'
  'cherry:find commits not in upstream'
  'cherry-pick:apply changes introduced by existing commits'
  'clone:clone a repository into a new directory'
  'column:display data in columns'
  'commit:record changes to the repository'
  'commit-tree:create a new commit object from a tree'
  'config:get and set repository or global options'
  'count-objects:count unpacked objects + their disk usage'
  'daemon:run a really simple git protocol server'
  'describe:describe a commit using the most recent tag'
  'diagnose:collect diagnostic info for bug reports'
  'diff:show changes between commits, commit and working tree'
  'diff-tree:compare the content and mode of trees'
  'dump-index:show information about a pack index file'
  'dump-pack:dump the contents of a pack file for debugging'
  'fetch:download objects and refs from another repository'
  'fetch-pack:receive missing objects from another repository'
  'filter-branch:rewrite branches'
  'for-each-ref:output information on each ref'
  'format-patch:prepare patches for email submission'
  'fsck:verify the connectivity and validity of objects'
  'gc:cleanup unnecessary files and optimize the local repository'
  'grep:print lines matching a pattern in the index'
  'help:show help for a command'
  'init:create an empty repository or reinitialize an existing one'
  'interpret-trailers:add/parse structured info in commit messages'
  'lfs:large file storage commands'
  'log:show commit logs'
  'ls-files:show information about files in the index and working tree'
  'ls-remote:list references in a remote repository'
  'ls-tree:list the contents of a tree object'
  'mailinfo:extract patch and authorship from email message'
  'mailsplit:simple Unix mbox splitter program'
  'maintenance:run tasks to optimize repository data'
  'merge:join two or more development histories'
  'merge-base:find common ancestors between commits'
  'merge-tree:perform 3-way merge without touching the working tree'
  'mv:move or rename a file/directory/symlink'
  'notes:add or inspect commit notes (add/list/remove/show)'
  'pack-objects:create a packed archive of objects'
  'pack-refs:pack heads and tags for efficient repository access'
  'prune:prune all unreachable objects from the object database'
  'pull:fetch from and integrate with another repository or branch'
  'push:update remote refs along with associated objects'
  'rebase:reapply commits on top of another base tip'
  'receive-pack:receive what is pushed into the repository'
  'reflog:manage reflog information'
  'remote:manage tracked repositories (add)'
  'repack:pack unpacked objects in a repository'
  'replace:create/list/delete replace refs'
  'rerere:reuse recorded resolution of conflicted merges'
  'reset:reset current HEAD to the specified state'
  'restore:restore working tree files'
  'rev-list:list commit objects in reverse chronological order'
  'revert:revert some existing commits'
  'rm:remove files from the working tree and index'
  'shortlog:summarize git log output'
  'show:show various types of objects'
  'show-branch:show branches and their commits'
  'show-ref:list references in a local repository'
  'stash:stash changes in dirty working directory (list/pop/push)'
  'status:show the working tree status'
  'stripspace:remove unnecessary whitespace from text'
  'submodule:initialize, update, inspect submodules (add/init/list/update)'
  'switch:switch branches'
  'symbolic-ref:read, modify, delete symbolic refs'
  'tag:create, list, delete, or verify a tag object'
  'unpack-objects:unpack objects from a packed archive'
  'update-server-info:update auxiliary info file for dumb servers'
  'upload-pack:send objects packed back to the requester'
  'var:show logical variables'
  'verify-commit:check the GPG signature of commits'
  'verify-tag:check the GPG signature of tags'
  'web-daemon:run a minimal HTTP server for repositories'
  'worktree:manage multiple working trees (add/list/lock/move/prune/remove/repair/unlock)'
  'write-tree:create a tree object from the current index'
)

_arguments -C -s -S \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'dulwich subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      notes)
        _arguments \
          '1:notes action:(add list remove show)' && ret=0
        ;;
      replace)
        _arguments \
          '1:replace action:(delete list)' && ret=0
        ;;
      stash)
        _arguments \
          '1:stash action:(list pop push)' && ret=0
        ;;
      submodule)
        _arguments \
          '1:submodule action:(add init list update)' && ret=0
        ;;
      worktree)
        _arguments \
          '1:worktree action:(add list lock move prune remove repair unlock)' && ret=0
        ;;
      remote)
        _arguments \
          '1:remote action:(add)' && ret=0
        ;;
    esac
    ;;
esac

return ret
