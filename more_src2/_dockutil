#compdef dockutil
# Documentation: https://github.com/kcrawford/dockutil
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# macOS Dock helper (kcrawford/dockutil).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-h[help]' \
  '--version[show version]' \
  '--add=[add dock item]:path or URL:_files' \
  '--remove=[remove by label, path, url, all, or spacer-tiles]:item label (or all|spacer-tiles)' \
  '--move=[move item]:dock item label' \
  '--find=[find item]:needle' \
  '--list[list dock items]' \
  '--label=[set label]:label' \
  '--type=[item type]:type:(spacer folder)' \
  '--replacing=[replace existing item]:dock label' \
  '--position=[insert position]:position:(beginning end middle)' \
  '--after=[insert after label]:dock label' \
  '--before=[insert before label]:dock label' \
  '--section=[dock section]:section:(apps others)' \
  '--view=[folder stack view]:view:(grid fan list auto)' \
  '--display=[folder display]:display:(folder stack)' \
  '--sort=[folder sort]:sort:(name dateadded datemodified datecreated kind)' \
  '--no-restart[do not restart Dock]' \
  '--allhomes[act on all user home dirs]' \
  '--homeloc=[/Users parent path]:directory:_files -/' \
  '*::extra plist or paths:_files' && ret=0

return ret
