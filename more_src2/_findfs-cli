#compdef findfs-cli
# _findfs-cli — util-linux findfs find filesystem by label or UUID CLI alias (util-linux team, C); custom argparse
# upstream: https://github.com/util-linux/util-linux

_findfs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '*:LABEL=val or UUID=val or PARTUUID=val or PARTLABEL=val:'
}

_findfs-cli "$@"
