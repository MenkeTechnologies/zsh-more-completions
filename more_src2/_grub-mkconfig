#compdef grub-mkconfig grub2-mkconfig
# _grub-mkconfig — GRUB grub-mkconfig (generate grub.cfg by sourcing /etc/grub.d/* scripts seeded by /etc/default/grub; -o writes to a file (typically /boot/grub/grub.cfg or /boot/efi/EFI/<distro>/grub.cfg), --help/--version)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mkconfig.in on tip.

_grub-mkconfig() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output+[output file]:file:_files'
}

_grub-mkconfig "$@"
