#compdef msmtp-cli
# _msmtp-cli — Martin Lambers msmtp SMTP client with sendmail interface CLI alias (marlam team, C); custom argparse
# upstream: https://github.com/marlam/msmtp

_msmtp-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--pretend[print info, don'\''t send]' \
        '-P[print info, don'\''t send]' \
        '--debug[verbose debug output]' \
        '-d[verbose debug output]' \
        '--serverinfo[print server info]' \
        '--rmqs=+[host]:host:_hosts' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--source-ip=+[ip]:str:' \
        '--timeout=+[seconds]:n:' \
        '--protocol=+[protocol]:p:(smtp lmtp)' \
        '--domain=+[domain]:str:' \
        '--auth=+[auth method]:m:(on off plain login cram-md5 digest-md5 scram-sha-1 scram-sha-256 gssapi external xoauth2 oauthbearer)' \
        '-a+[auth method]:m:(on off plain login cram-md5 digest-md5 scram-sha-1 scram-sha-256 gssapi external xoauth2 oauthbearer)' \
        '--user=+[user]:_users' \
        '-u+[user]:_users' \
        '--passwordeval=+[command]:str:' \
        '--tls=+[bool]:b:(on off)' \
        '--tls-starttls=+[bool]:b:(on off)' \
        '--tls-trust-file=+[file]:file:_files' \
        '--tls-crl-file=+[file]:file:_files' \
        '--tls-fingerprint=+[fp]:str:' \
        '--tls-key-file=+[file]:file:_files' \
        '--tls-cert-file=+[file]:file:_files' \
        '--tls-certcheck=+[bool]:b:(on off)' \
        '--tls-priorities=+[priorities]:str:' \
        '--tls-host-override=+[host]:host:_hosts' \
        '--tls-min-dh-prime-bits=+[bits]:n:' \
        '--auto-from=+[bool]:b:(on off)' \
        '--maildomain=+[domain]:str:' \
        '--from=+[address]:str:' \
        '-f+[address]:str:' \
        '--allow-from-override=+[bool]:b:(on off)' \
        '--add-missing-from-header=+[bool]:b:(on off)' \
        '--add-missing-date-header=+[bool]:b:(on off)' \
        '--remove-bcc-headers=+[bool]:b:(on off)' \
        '--undisclosed-recipients=+[bool]:b:(on off)' \
        '--dsn-notify=+[args]:str:' \
        '-N+[args]:str:' \
        '--dsn-return=+[mode]:m:(hdrs full)' \
        '-R+[mode]:m:(hdrs full)' \
        '--logfile=+[file]:file:_files' \
        '-X+[file]:file:_files' \
        '--syslog=+[facility]:s:(LOG_MAIL LOG_USER LOG_LOCAL0 LOG_LOCAL1 LOG_LOCAL2 LOG_LOCAL3 LOG_LOCAL4 LOG_LOCAL5 LOG_LOCAL6 LOG_LOCAL7 off)' \
        '-Y+[facility]:s:(LOG_MAIL LOG_USER LOG_LOCAL0 LOG_LOCAL1 LOG_LOCAL2 LOG_LOCAL3 LOG_LOCAL4 LOG_LOCAL5 LOG_LOCAL6 LOG_LOCAL7 off)' \
        '--aliases=+[file]:file:_files' \
        '--proxy-host=+[host]:host:_hosts' \
        '--proxy-port=+[port]:port:' \
        '--socket=+[socket]:file:_files' \
        '--read-recipients[read recipients from to/cc/bcc]' \
        '-t[read recipients from to/cc/bcc]' \
        '--read-envelope-from[read envelope from header]' \
        '--keepbcc=+[bool]:b:(on off)' \
        '--logfile-time-format=+[format]:str:' \
        '--read-aliases[read aliases]' \
        '--configure=+[address]:str:' \
        '--account=+[account]:str:' \
        '-A+[account]:str:' \
        '--list-accounts[list accounts]' \
        '--Q[quiet mode]' \
        '-C+[file]:file:_files' \
        '--file=+[file]:file:_files' \
        '*:recipient:'
}

_msmtp-cli "$@"
