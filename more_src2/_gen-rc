#compdef gen-rc
# Documentation: https://github.com/FFmpeg/FFmpeg/blob/master/tools/gen-rc
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gen-rc generates the Windows .rc resources file for an FFmpeg library
# usage: gen-rc <library-name> <comment>

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:library name (e.g. libavcodec):(libavcodec libavdevice libavfilter libavformat libavutil libpostproc libswresample libswscale)' \
  '2:comment:' && ret=0

return ret
