#compdef deeptools
# Documentation: https://github.com/deeptools/deepTools
# Reference accessed: 2026-05-27
# Verified: upstream deeptools/deepTools deeptools/deeptools_list_tools.py (tool registry) and deeptools/__init__.py.

# Zsh completion for the deeptools NGS visualization suite launcher.
# The real CLIs are separate binaries; this completes the tool name list.

local -a _deeptools_tools
_deeptools_tools=(
  'multiBamSummary:compute read coverage genome-wide across BAM files'
  'multiBigwigSummary:compute scores from multiple bigWig files'
  'correctGCBias:correct GC bias in BAM coverage'
  'bamCoverage:generate a coverage track (bigWig/bedGraph) from BAM'
  'bamCompare:compare two BAM files and write a coverage ratio track'
  'bigwigCompare:compare two bigWig files'
  'bigwigAverage:average multiple bigWig files'
  'computeMatrix:prepare matrix file for plotHeatmap and plotProfile'
  'alignmentSieve:filter BAM alignments by various criteria'
  'plotCorrelation:plot heatmap or scatter from a correlation matrix'
  'plotPCA:plot PCA from a count matrix'
  'plotFingerprint:plot cumulative read enrichment'
  'bamPEFragmentSize:report paired-end fragment size distribution'
  'computeGCBias:compute GC bias of a BAM file'
  'plotCoverage:plot read coverage distribution'
  'estimateReadFiltering:estimate effect of read filtering'
  'plotHeatmap:plot a heatmap from a computeMatrix output'
  'plotProfile:plot a profile from a computeMatrix output'
  'plotEnrichment:plot read/feature enrichment'
  'computeMatrixOperations:manipulate computeMatrix output files'
)

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[print version]' \
  '1:deeptools tool:->tool' && return 0

case $state in
  tool)
    _describe -t tools 'deeptools tool' _deeptools_tools
    ;;
esac
