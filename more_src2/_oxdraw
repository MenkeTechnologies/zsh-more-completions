#compdef oxdraw
# ============================================================================
# oxdraw - Mermaid-style declarative-diagram CLI +
#          library + web view; SVG/PNG output via
#          resvg + tiny-skia (Rust, MIT)
#
# Author : Rohan Adwankar
# Upstream: https://github.com/RohanAdwankar/oxdraw
# crates : oxdraw (binary: oxdraw)
#
# `oxdraw` is a diagram-as-code tool that parses
# Mermaid-style flowchart syntax + renders the
# diagram directly to SVG or PNG without relying
# on the official mermaid.js library or a headless-
# browser pipeline. The Rust implementation gives
# it dramatically faster startup + lower memory
# footprint than browser-based Mermaid renderers.
#
# Additional features beyond static rendering:
#   - Interactive editor (`--edit`): launches a
#     local web view for draggable node-position
#     editing
#   - Code-map generation (`--code-map <path>`):
#     scans a codebase + uses an LLM to generate
#     a diagram of file/module relationships
#   - Codedown markdown generation
#     (`--codedown <path>`): produces a markdown
#     file with embedded code mappings
#   - Multi-LLM backend support (OpenAI-compatible
#     `--api-key` + Google Gemini `--gemini`)
#
# Use cases:
#   - Architecture diagrams generated from code
#     repositories
#   - Tutorial markdown with auto-rendered
#     flowcharts
#   - Mermaid-syntax-to-SVG conversion in CI
#     pipelines (faster than Puppeteer-based
#     mermaid-cli)
#   - Self-hosted Mermaid alternative without
#     Node.js + Chromium dependencies
#
# Usage:
#   oxdraw -i <input> -o <output> [options]
#   oxdraw --new                 # interactive
#                                 # diagram editor
#   oxdraw --edit -i <file>      # edit existing
#                                 # diagram
#   oxdraw --code-map <path>     # generate code
#                                 # map from repo
#
# Rendering Flags (clap derive):
#   -i, --input <path|->          - input diagram
#                                    file (`-` for
#                                    stdin)
#   -o, --output <path|->         - output file
#                                    (`-` for
#                                    stdout)
#   -e, --output-format <fmt>     - output format
#                                    (svg/png);
#                                    defaults to
#                                    output
#                                    extension or
#                                    svg
#       --png                     - convenience
#                                    flag to force
#                                    PNG output
#                                    (conflicts
#                                    with
#                                    --output-
#                                    format)
#       --scale <factor>          - scale factor
#                                    when
#                                    rasterizing
#                                    PNG (default
#                                    10.0)
#   -b, --background-color <name> - background
#                                    color for
#                                    SVG (default
#                                    `white`)
#   -q, --quiet                   - suppress
#                                    informational
#                                    output
#
# Interactive editor flags:
#       --edit                    - launch
#                                    interactive
#                                    editor
#                                    (requires
#                                    --input)
#   -n, --new                     - scaffold a new
#                                    Mermaid
#                                    diagram +
#                                    launch editor
#       --serve-host <host>       - override editor
#                                    host binding
#       --serve-port <port>       - override editor
#                                    port binding
#
# Code-map / codedown flags:
#       --code-map <path>         - generate code
#                                    map from
#                                    codebase path
#                                    (LLM-driven)
#       --codedown <path>         - generate
#                                    codedown
#                                    (markdown
#                                    with code
#                                    mappings)
#       --codedown-style <style>  - codedown style
#                                    (architecture
#                                    /tutorial/api)
#       --augment-markdown <path> - augment
#                                    existing
#                                    markdown
#                                    with code
#                                    mappings
#       --repo-path <path>        - repository
#                                    path for
#                                    augment-
#                                    markdown
#       --api-key <key>           - LLM API key
#                                    (optional;
#                                    falls back
#                                    to env)
#       --model <name>            - LLM model for
#                                    code map
#                                    generation
#       --api-url <url>           - LLM API URL
#       --regen                   - force code map
#                                    regen (skip
#                                    cache)
#       --prompt <text>           - custom prompt
#                                    appended to
#                                    LLM
#                                    instructions
#       --no-ai                   - deterministic
#                                    generation
#                                    instead of
#                                    LLM (code-map
#                                    only)
#       --max-nodes <n>           - max nodes in
#                                    deterministic
#                                    mode (default
#                                    20)
#       --gemini <key>            - use Google
#                                    Gemini API
#                                    with provided
#                                    key
#                                    (conflicts
#                                    with
#                                    --api-key)
#
# Examples:
#   oxdraw -i diagram.mmd -o out.svg
#   oxdraw -i diagram.mmd --png --scale 2.0 -o out.png
#   cat diagram.mmd | oxdraw -i - -o -
#   oxdraw --new
#   oxdraw --edit -i existing.mmd
#   oxdraw --code-map ./my-project --model gpt-4o-mini
#   oxdraw --codedown ./my-project --codedown-style architecture
#
# The resvg lane is built on `resvg = "0.43"`
# with `features = ["text"]` (declared verbatim at
# upstream Cargo.toml HEAD as a direct dep) +
# `tiny-skia = "0.11"` with `features = ["png"]`
# (the rasterizer companion library), the canonical
# Rust SVG-rendering library by Yevhenii Reizner
# (RazrFalcon) - github.com/linebender/resvg.
#
# `resvg` (Reasonable SVG) is the canonical Rust
# SVG-rendering library:
#   - Implements a substantial subset of the SVG
#     1.1 + SVG 2 specification
#   - Uses `usvg` (Universal SVG) for SVG parsing +
#     resolution into a normalized tree
#   - Uses `tiny-skia` (Yevhenii's pure-Rust port
#     of Google's Skia 2D-rasterization engine)
#     for the actual pixel rendering
#   - Supports text rendering via fontdb +
#     fontkit + rustybuzz (HarfBuzz port to Rust)
#   - Supports CSS-style styling, gradients,
#     filters, masks, clip paths, markers, patterns
#   - Pure-Rust with no C dependencies (unlike
#     librsvg which requires cairo + pango + glib)
#
# Yevhenii Reizner's broader Rust ecosystem
# footprint (the linebender / svgkit / Rust
# graphics stack):
#   - resvg + usvg + svgtypes + svgfilters (the
#     SVG-rendering pipeline)
#   - tiny-skia (canonical Rust 2D-rasterization
#     library; Skia-port; used by resvg + many
#     other Rust graphics tools)
#   - rustybuzz (Rust port of HarfBuzz text-
#     shaping engine)
#   - fontdb (canonical Rust font-database
#     manager)
#   - Various other Linebender Foundation graphics
#     libraries
#
# Reizner's foundational role in Rust graphics
# rendering mirrors Klaus Post's role in Go SIMD
# systems + Niemeyer's in Go YAML + Schlueter's
# in Node infrastructure - SVG rendering + 2D
# rasterization is a vertically integrated tool
# chain where Reizner authored every layer.
#
# Other resvg/usvg consumers in the Rust ecosystem
# (illustrating canonical position):
#   - Tauri (Cross-platform desktop apps; uses
#     resvg for icon rendering)
#   - emilk/egui (Immediate-mode GUI; uses
#     resvg for SVG widget rendering)
#   - linebender/druid + linebender/xilem (GUI
#     toolkits)
#   - lapce/floem (Floem GUI framework)
#   - libnyanpasu/clash-nyanpasu (Clash GUI)
#   - oxdraw (THIS BINARY)
#   - macro_railroad (Rust macro syntax-diagram
#     generator)
#
# The Linebender Foundation (Raph Levien's Rust
# graphics + interactive systems research project)
# hosts the resvg + tiny-skia + druid + xilem +
# vello stack. resvg specifically is one of the
# few Rust libraries that has displaced an
# entrenched C/GTK incumbent (librsvg) for many
# use cases due to its pure-Rust portability +
# memory safety.
#
# ----------------------------------------------------------------------------
# AXIS 264 :: SVG rendering libraries (parse +
#              rasterize/render SVG documents
#              following the W3C SVG 1.1/2.0
#              specification)
# Round 1490 :: Rust slot 1 of 4 :: OPENS Axis 264
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : linebender/resvg              - Yevhenii
#                                              Reizner's
#                                              canonical
#                                              Rust SVG
#                                              renderer;
#                                              pure-Rust;
#                                              displaces
#                                              librsvg in
#                                              many use
#                                              cases
#   Go      : ajstarks/svgo                 - Anthony
#                                              Starks'
#                                              canonical
#                                              Go SVG
#                                              generation
#                                              library
#                                              (write-only,
#                                              no
#                                              rendering)
#             OR
#             srwiley/oksvg + rasterx       - Steven
#                                              R. Wiley's
#                                              Go SVG
#                                              renderer
#                                              pipeline
#                                              (parse +
#                                              rasterize)
#   TS/Node : svgdotjs/svg.js                - canonical
#                                              Node SVG
#                                              DOM-manipulation
#                                              library
#             OR
#             yWorks/svg-to-png              - Node SVG
#                                              rendering
#                                              CLI
#
# SVG is a *spec-bound* axis - the W3C SVG 1.1 +
# SVG 2 specifications define the XML grammar +
# rendering semantics. Compliant implementations
# parse the same SVG document into equivalent
# rendering trees, modulo:
#   - SVG 2 vs SVG 1.1 feature differences
#     (resvg supports a subset of SVG 2)
#   - Font rendering differences (text shaping is
#     not byte-exact across HarfBuzz versions +
#     ICU versions)
#   - Filter/effect rendering precision (floating-
#     point rounding differences across rasterizers)
#   - Color profile handling (ICC profile support
#     varies)
#
# Structural commentary on the canonical libraries:
#   - resvg (Rust): pure-Rust; parser
#     (usvg/svgtypes) + rasterizer (tiny-skia);
#     no C dependencies
#   - ajstarks/svgo (Go): write-only generator;
#     popular for Go-based diagram generation in
#     scientific computing + visualization
#   - srwiley/oksvg + rasterx (Go): parser +
#     rasterizer pair; the Go canonical for
#     parsing + rendering existing SVG
#   - svgdotjs/svg.js (Node): DOM-manipulation
#     library; doesn't rasterize; rasterization in
#     Node typically delegates to Puppeteer/
#     Chromium or sharp/librsvg
#
# Cross-language interop happens at the SVG
# document level - the same SVG XML produces
# visually equivalent output across all three
# lanes (modulo the font/effect/profile caveats
# above).
#
# Axis 264 opens with the Rust slot at Reizner's
# resvg, anchoring his multi-axis canonical
# position in Rust graphics. Subsequent rounds
# will visit the Go (ajstarks/svgo or srwiley/
# oksvg) + TS/Node (svgdotjs/svg.js or related)
# canonicals.
#
# Notable distinction from prior canonical-author
# patterns: while Gallant has the largest
# *application* footprint (ripgrep + globset +
# regex + xsv + fst + ...) and Tolnay has the
# largest *foundational-library* footprint (syn +
# quote + serde + thiserror + ...), Reizner has
# a *vertically-integrated stack* footprint -
# every layer of the resvg pipeline (svgtypes +
# usvg + svgfilters + tiny-skia + rustybuzz +
# fontdb) is his code, creating an entire
# rendering toolchain with no external Rust
# dependencies on graphics primitives.
# ============================================================================

_oxdraw() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-i --input)'{-i,--input}'[input diagram file (- for stdin)]:file:_files' \
        '(-o --output)'{-o,--output}'[output file (- for stdout)]:file:_files' \
        '(-e --output-format)'{-e,--output-format}'[output format]:fmt:(svg png)' \
        '--png[force PNG output]' \
        '--scale=[PNG rasterization scale factor]:factor:' \
        '(-b --background-color)'{-b,--background-color}'[SVG background color]:color:' \
        '(-q --quiet)'{-q,--quiet}'[suppress informational output]' \
        '--edit[launch interactive editor]' \
        '(-n --new)'{-n,--new}'[scaffold new Mermaid diagram + launch editor]' \
        '--serve-host=[editor host binding override]:host:_hosts' \
        '--serve-port=[editor port binding override]:port:' \
        '--code-map=[generate code map from codebase path]:path:_files -/' \
        '--codedown=[generate codedown from codebase path]:path:_files -/' \
        '--codedown-style=[codedown style]:style:(architecture tutorial api)' \
        '--augment-markdown=[augment existing markdown with code mappings]:file:_files' \
        '--repo-path=[repository path for augment-markdown]:path:_files -/' \
        '--api-key=[LLM API key (or use env var)]:key:' \
        '--model=[LLM model name]:model:' \
        '--api-url=[LLM API URL]:url:' \
        '--regen[force code map regeneration (skip cache)]' \
        '--prompt=[custom prompt appended to LLM instructions]:text:' \
        '--no-ai[deterministic generation instead of LLM (code-map only)]' \
        '--max-nodes=[max nodes in deterministic mode]:n:' \
        '--gemini=[use Google Gemini API with provided key]:key:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_oxdraw "$@"
