#compdef mdp
# Documentation: https://github.com/visit1985/mdp/blob/master/mdp.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mdp - command-line markdown presentation tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show usage and exit]' \
  '(- *)'{-v,--version}'[show version and license]' \
  '(-c --nocodebg)'{-c,--nocodebg}'[do not change background color of code blocks]' \
  '(-d --debug)'{-d,--debug}'[enable debug messages on stderr]' \
  '(-e --expand)'{-e,--expand}'[enable character entity expansion]' \
  '(-f --nofade)'{-f,--nofade}'[disable color fading in 256 color mode]' \
  '(-i --invert)'{-i,--invert}'[swap black and white color]' \
  '(-j --jump)'{-j,--jump}'[jump to slide number]:slide number:' \
  '(-s --noslidenum)'{-s,--noslidenum}'[do not show slide number at bottom]' \
  '(-t --notrans)'{-t,--notrans}'[disable transparency in transparent terminal]' \
  '(-x --noslidemax)'{-x,--noslidemax}'[show slide number but not total]' \
  '1:markdown file:_files -g "*.{md,markdown}"'
