#compdef duff
# Documentation: https://github.com/elmindreda/duff
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elmindreda/duff — duplicate file finder

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[display help and exit]' \
  '(- *)-v[display version and exit]' \
  '-0[null-terminate input/output instead of newlines]' \
  '-a[include hidden files in recursive searches]' \
  '-e[excess mode - list all but one of each duplicate cluster]' \
  '-q[quiet mode - suppress warnings and errors]' \
  '-r[recursively search into directories]' \
  '-H[follow symlinks listed on command line (directories only)]' \
  '-L[follow all symlinks (directories only)]' \
  '-P[do not follow any symlinks (default; directories only)]' \
  '-d+[message digest function]:digest:(sha1 sha256 sha384 sha512)' \
  '-f+[cluster header format with %n %d %s %i escapes]:format:' \
  '-l+[minimum file size for sampling optimization]:size:' \
  '-p[physical mode - treat hard links as separate files]' \
  '-t[thorough mode - byte-by-byte comparison]' \
  '-z[exclude empty files from duplicate reporting]' \
  '*:file or directory:_files' && ret=0

return ret
