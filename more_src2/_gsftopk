#compdef gsftopk
# Documentation: gsftopk --help (TeX Live 2026)
# Source: convert a PostScript Type 1 font to PK bitmap format via Ghostscript.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[print help and exit]' \
    '(- *)'{-v,--version}'[print version and exit]' \
    '(-t --test)'{-t,--test}'[check for presence of font in .map file]' \
    '--mapline=[use LINE as the .map file line]:line:' \
    '--mapfile=[use FILE as a .map file (default psfonts.map)]:file:_files -g "*.map"' \
    '(-i --interpreter)'{-i+,--interpreter=}'[GhostScript interpreter to use]:gs:_command_names -e' \
    '--dosnames[short pk filename (cmr10.pk instead of cmr10.600pk)]' \
    '(-q --quiet)'{-q,--quiet}'[do not print progress to stdout]' \
    '--debug=[set debugging flags]:num:' \
    '1:font:' \
    '2:dpi:' \
    && ret=0

return ret
