#compdef phony
# _phony — send a fake GitHub webhook payload to a hook endpoint (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/phony/main.go (flag).

_phony() {
    _arguments \
        '-address=[hook endpoint to send to]:url:_urls' \
        '-hmac=[HMAC token used to sign payload]:token:' \
        '-event=[event type to send (e.g. pull_request, ping)]:event:(push pull_request issue_comment ping check_run check_suite)' \
        '-payload=[file to send as payload]:file:_files -g "*.json"'
}

_phony "$@"
