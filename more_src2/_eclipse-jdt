#compdef ecj
# _eclipse-jdt — Eclipse Java Development Tools batch compiler (Eclipse Foundation, Java); standalone javac-like compiler
# upstream: https://github.com/eclipse-jdt/eclipse.jdt.core

_eclipse-jdt() {
    _arguments \
        '-help[show help]' \
        '-?[show help]' \
        '-version[show version]' \
        '-v[show version]' \
        '-cp+[classpath]:cp:' \
        '-classpath+[classpath]:cp:' \
        '--system+[system module path]:dir:_files -/' \
        '-d+[output dir]:dir:_files -/' \
        '-encoding+[encoding]:enc:' \
        '-source+[source compat]:ver:' \
        '-target+[target version]:ver:' \
        '-bootclasspath+[boot classpath]:cp:' \
        '-extdirs+[extdirs]:dirs:' \
        '-endorseddirs+[endorseddirs]:dirs:' \
        '-sourcepath+[source path]:cp:' \
        '-deprecation[deprecation warnings]' \
        '-Xlint+[lint]:str:' \
        '-X[show extended options]' \
        '-g[debug info]' \
        '-g:none[no debug info]' \
        '-1.3[compile for Java 1.3]' \
        '-1.4[compile for Java 1.4]' \
        '-1.5[compile for Java 5]' \
        '-1.6[compile for Java 6]' \
        '-1.7[compile for Java 7]' \
        '-1.8[compile for Java 8]' \
        '-9[compile for Java 9]' \
        '-10[compile for Java 10]' \
        '-11[compile for Java 11]' \
        '-17[compile for Java 17]' \
        '-21[compile for Java 21]' \
        '-warn+[warnings]:warnings:' \
        '-err+[errors]:warnings:' \
        '-info+[info]:warnings:' \
        '-nowarn[no warnings]' \
        '-properties+[properties file]:file:_files' \
        '-time[time compile]' \
        '-noExit[no exit]' \
        '-repeat+[repeat]:n:' \
        '-proc:+[annotation processing]:mode:(none only)' \
        '-processor+[processors]:str:' \
        '-processorpath+[processor path]:cp:' \
        '-s+[generated source dir]:dir:_files -/' \
        '-A+[processor option]:KEY=VAL:' \
        '-progress[show progress]' \
        '-log+[log file]:file:_files' \
        '-maxProblems+[max problems]:n:' \
        '-genericsignature[include generics signature]' \
        '-preview[enable preview features]' \
        '*:file:_files'
}

_eclipse-jdt "$@"
