#compdef difi
# Documentation: https://github.com/xguot/difi
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# xguot/difi — interactive Git diff reviewer (Go).
# Usage: `difi [target]` where target is a ref (e.g. main, HEAD~1); also reads stdin.
# README documents no flags; config lives at ~/.config/difi/config.yaml.

_arguments -s -S \
  '1::git target:__difi_refs' \
  '*::file:_files'

__difi_refs() {
  local -a refs
  refs=( ${(f)"$(git for-each-ref --format='%(refname:short)' refs/heads refs/remotes refs/tags 2>/dev/null)"} )
  _describe -t refs 'git ref' refs
}
