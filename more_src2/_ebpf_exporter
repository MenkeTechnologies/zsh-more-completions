#compdef ebpf_exporter
# Documentation: https://github.com/cloudflare/ebpf_exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--config.dir=[directory with config files]:directory:_directories' \
  '--config.file=[path to config file]:file:_files' \
  '--config.check[check configuration and exit]' \
  '--debug[enable debug logging]' \
  '--web.listen-address=[address to listen on]:address:' \
  '--web.telemetry-path=[path for metrics]:path:' \
  '--web.config.file=[TLS/auth config file]:file:_files' \
  '--log.level=[log level]:level:(debug info warn error)' \
  '--log.format=[log format]:format:(logfmt json)' && ret=0

return ret
