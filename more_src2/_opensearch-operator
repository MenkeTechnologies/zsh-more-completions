#compdef opensearch-operator
# _opensearch-operator — OpenSearch Kubernetes operator (reconciles OpenSearchCluster + OpenSearchUser/Role/ActionGroup/Tenant/IndexTemplate/ISMPolicy/Snapshot/SnapshotPolicy CRs)
# upstream: https://github.com/opensearch-project/opensearch-k8s-operator
# Flags from opensearch-operator/main.go on tip + controller-runtime zap.Options.

_opensearch-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metric endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--leader-elect[enable leader election]' \
        '--enable-webhooks=[enable validating webhooks for OpenSearch CRs]:bool:(true false)' \
        '--webhook-port=[validating webhook server port]:port:' \
        '--watch-namespace=[restrict to a single namespace (empty = all)]:ns:' \
        '--loglevel=[operator log level]:level:(debug info warn error)' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_opensearch-operator "$@"
