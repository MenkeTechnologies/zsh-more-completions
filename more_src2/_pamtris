#compdef pamtris
# Documentation: man pamtris (Netpbm)
# Source: rasterise triangles read from stdin into a PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[output width]:width:' \
    '-height=[output height]:height:' \
    '(-rgb -grayscale -num_attribs)-num_attribs=[attributes per vertex]:attributes:' \
    '(-rgb -grayscale)-tupletype=[output tuple type]:type:(BLACKANDWHITE GRAYSCALE GRAYSCALE_ALPHA RGB RGB_ALPHA CMYK)' \
    '(-num_attribs -rgb -grayscale)-rgb[RGB output]' \
    '(-num_attribs -rgb -grayscale)-grayscale[grayscale output]' \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
