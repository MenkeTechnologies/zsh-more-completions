#compdef pt-index-usage
# Documentation: https://docs.percona.com/percona-toolkit/pt-index-usage.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--charset=[default character set]:charset:' \
  '--config=[comma-separated config files]:files:_files' \
  '--create-save-results-database[auto-create results db]' \
  '(--create-views --no-create-views)'{--create-views,--no-create-views}'[generate example query views]' \
  '--database=[default database]:db:' \
  '--databases=[databases to analyze]:dbs:' \
  '--databases-regex=[regex for databases]:regex:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--drop=[index types to recommend dropping]:flag:(primary unique non-unique all)' \
  '--empty-save-results-tables[empty save tables first]' \
  '--host=[MySQL host]:host:_hosts' \
  '--ignore-databases=[databases to ignore]:list:' \
  '--ignore-databases-regex=[regex for databases to ignore]:regex:' \
  '--ignore-tables=[tables to ignore]:list:' \
  '--ignore-tables-regex=[regex for tables to ignore]:regex:' \
  '--mysql_ssl=[create SSL MySQL connection]:n:' \
  '--password=[MySQL password]:pw:' \
  '--port=[MySQL port]:port:' \
  '--progress=[progress reporting spec]:spec:' \
  '--quiet[suppress warnings and progress]' \
  '(--report --no-report)'{--report,--no-report}'[display analysis reports]' \
  '--report-format=[report format]:fmt:(drop_unused_indexes)' \
  '--save-results-database=[save results DSN]:dsn:' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:file:_files' \
  '--tables=[tables to analyze]:tables:' \
  '--tables-regex=[regex for tables]:regex:' \
  '--user=[MySQL user]:user:' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '*:slow_log:_files' && ret=0

return ret
