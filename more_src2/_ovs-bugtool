#compdef ovs-bugtool
# _ovs-bugtool — Open vSwitch bug report tool CLI (OVS team, Python); custom argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-bugtool() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-y[yes]' \
        '--yestoall[yes to all prompts]' \
        '-s+[size limit MB]:n:' \
        '--silent[silent]' \
        '--entries=+[entries]:list:' \
        '--output=+[output format]:fmt:(tar tar.bz2 tar.gz zip)' \
        '--outfd=+[output fd]:n:' \
        '--outfile=+[output file]:file:_files' \
        '*:arg:'
}

_ovs-bugtool "$@"
