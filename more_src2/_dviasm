#compdef dviasm
# Documentation: dviasm --help (TeX Live)
# Source: dviasm — Python DVI disassembler / assembler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-u --unit)'{-u,--unit=}'[unit (default pt)]:unit:(sp pt bp mm cm in)' \
    '(-o --output)'{-o,--output=}'[output file (default stdout)]:file:_files' \
    '(-e --encoding)'{-e,--encoding=}'[input/output encoding]:enc:(utf8 ascii latin1)' \
    '(-x --xxx-encoding)'{-x,--xxx-encoding=}'[encoding for xxx strings]:enc:(none utf8 ascii sjis)' \
    '(-t --tabsize)'{-t,--tabsize=}'[push/pop tab size]:n:' \
    '(-p --ptex)'{-p,--ptex}'[ISO-2022-JP DVI for pTeX]' \
    '(-s --subfont)'{-s,--subfont=}'[UCS2 subfont list (comma-separated, empty disables internal list)]:fonts:' \
    '1:DVI file or DVI dump:_files -g "*.{dvi,tex,dump,txt}"' \
    && ret=0

return ret
