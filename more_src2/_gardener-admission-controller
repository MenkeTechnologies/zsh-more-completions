#compdef gardener-admission-controller
# _gardener-admission-controller — Gardener admission webhook server
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-admission-controller/app/options.go on tip.

_gardener-admission-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[admission-controller config file]:file:_files -g "*.(yaml|yml)"' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardener-admission-controller "$@"
