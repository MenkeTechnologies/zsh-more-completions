local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:Dimension:(2 3 4)' \
    '2:infile.nii:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outfile.nii:_files' \
    '4:basis (PHYSICAL / LOCAL / reference.nii.gz):_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
