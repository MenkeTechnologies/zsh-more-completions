#compdef misspell
# _misspell-bin — misspell common spelling fixer for source code (Nick Galbreath, Go); flags + fixes typos in comments/strings
# upstream: https://github.com/client9/misspell

_misspell-bin() {
    _arguments \
        '-debug[debug log]' \
        '-error[exit on misspelling]' \
        '-f+[output template]:fmt:' \
        '-i+[words to ignore]:words:' \
        '-j+[parallel jobs]:n:' \
        '-locale+[locale]:locale:(US UK)' \
        '-o+[output file]:file:_files' \
        '-q[quiet]' \
        '-source+[source type]:type:(text go)' \
        '-w[overwrite files]' \
        '-legal[print legal]' \
        '*:file or dir:_files'
}

_misspell-bin "$@"
