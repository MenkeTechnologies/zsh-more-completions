# ============================================================================
# _pingme — zsh completion for PingMe, the multi-platform notifier CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/kha7iq/pingme
#   Author     : Liaqat Ali (kha7iq)
#   License    : MIT
#   Stars      : 853
#   Language   : Go
#   Module     : github.com/kha7iq/pingme  (Go 1.25.4)
#   Binary     : pingme  (built from root main.go)
#   Last push  : 2026-05-14
#
# WHAT IT IS
#   PingMe is "a unified CLI and web service for sending notifications
#   across multiple messaging platforms" — Liaqat Ali's urfave/cli/v2
#   notification dispatcher.  A single binary speaks 16 platforms via the
#   `nikoksr/notify` abstraction layer (which transitively pulls in the
#   canonical native client libraries for each — `bwmarrin/discordgo` for
#   Discord, the Slack Web API client for Slack, `gotify/go-api-client`
#   for Gotify, `gomatrix` for Matrix, `gotwilio` for Twilio, etc.), plus
#   an optional `serve` mode that exposes a webhook-receiving HTTP
#   server which dispatches incoming POSTs to the same platform
#   pipeline.  Authentication for the webhook server supports API-key,
#   HMAC-signed, basic-auth, or none.
#
# CLI ARGUMENT GRAMMAR  (verbatim from main.go urfave/cli/v2 app +
#                       service/*/Send() Flags blocks)
#   pingme <command> [flags]
#
#   Commands  (one per messaging platform, plus webhook server):
#     serve | server | webhook    Start the webhook server
#       -p, --port <PORT>           [default 8080;  env PINGME_PORT]
#       -H, --host <HOST>           [default 0.0.0.0; env PINGME_HOST]
#       (Auth via env vars only:  PINGME_AUTH_METHOD =
#        apikey|hmac|basic|none, then PINGME_API_KEYS,
#        PINGME_HMAC_SECRET, PINGME_BASIC_USER/PINGME_BASIC_PASS)
#
#     discord                     Send a message to Discord channels
#       --token <TOKEN>             bot token (REQUIRED; env DISCORD_TOKEN)
#       --channel <IDS>             channel IDs, comma-separated
#                                   (REQUIRED; env DISCORD_CHANNELS)
#       --msg <TEXT>                message body (env DISCORD_MESSAGE)
#       --title <TITLE>             message title
#                                   [default time; env DISCORD_MSG_TITLE]
#
#     telegram                    Telegram (token + chatid + msg)
#     slack                       Slack (token + channel + msg)
#     rocketchat                  Rocket.Chat
#     msteams                     Microsoft Teams
#     mattermost                  Mattermost
#     matrix                      Matrix (gomatrix)
#     mastodon                    Mastodon
#     pushover                    Pushover
#     pushbullet                  Pushbullet
#     gotify                      Gotify
#     line                        LINE Notify
#     twillio                     Twilio SMS (NOTE: upstream spelling)
#     wechat                      WeChat Work
#     zulip                       Zulip
#     email                       SMTP email
#
#   Each platform command has its own `--token` / `--channel` /
#   `--msg` (etc.) flag set;  every flag also has an environment
#   variable counterpart documented in `pingme <cmd> --help`.
#
#   Standard urfave/cli auto-flags:
#     -h, --help                  Show help
#     -v, --version               Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/nikoksr/notify v1.3.0` in go.mod
#   (notify's `service/discord` package in turn transitively pulls
#   `github.com/bwmarrin/discordgo v0.29.0`, as verified in go.sum).
#   bwmarrin/discordgo is the canonical Go Discord library — the de-facto
#   Go binding for the Discord API, used by the bulk of production Go
#   Discord bots.  PingMe's `service/discord/discord.go` imports
#   `notify/service/discord` which delegates to discordgo for the actual
#   bot-token authentication, channel resolution, and message send.
#   Verified via:
#     gh api repos/kha7iq/pingme/contents/go.mod
#       → github.com/nikoksr/notify v1.3.0
#     gh api repos/kha7iq/pingme/contents/go.sum
#       → github.com/bwmarrin/discordgo v0.29.0
#     gh api repos/kha7iq/pingme/contents/service/discord/discord.go
#       → discordSvc := discord.New(); discordSvc.AuthenticateWithBotToken(...)
#   This entry is the Go=122 leader bump that continues Axis 67
#   (Discord Bot Library) opened at R857 with Rust=serenity 0.12.1 +
#   poise 0.6.1 (mchestr/displex).
#
#   No completion for `pingme` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_pingme() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_pingme_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                serve|server|webhook)  _pingme_serve   && ret=0 ;;
                discord)               _pingme_discord && ret=0 ;;
                telegram|slack|rocketchat|msteams|mattermost|matrix|mastodon|pushover|pushbullet|gotify|line|twillio|wechat|zulip|email)
                    _arguments \
                        '--token=[platform auth token]:token:' \
                        '--channel=[channel/recipient identifier]:channel:' \
                        '--msg=[message body]:message:' \
                        '--title=[message title]:title:' \
                        '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pingme_commands] )) ||
_pingme_commands() {
    local -a commands
    commands=(
        'serve:start webhook server (aliases: server, webhook)'
        'server:start webhook server'
        'webhook:start webhook server'
        'discord:send message to Discord channels (via bwmarrin/discordgo)'
        'telegram:send message to Telegram chat'
        'slack:send message to Slack channel'
        'rocketchat:send message to Rocket.Chat'
        'msteams:send message to Microsoft Teams'
        'mattermost:send message to Mattermost'
        'matrix:send message to Matrix (gomatrix)'
        'mastodon:send message/toot to Mastodon'
        'pushover:send Pushover notification'
        'pushbullet:send Pushbullet notification'
        'gotify:send Gotify notification'
        'line:send LINE Notify message'
        'twillio:send Twilio SMS (upstream spelling)'
        'wechat:send WeChat Work message'
        'zulip:send Zulip message'
        'email:send SMTP email'
    )
    _describe -t commands 'pingme command' commands
}

(( $+functions[_pingme_serve] )) ||
_pingme_serve() {
    _arguments \
        '(-p --port)'{-p+,--port=}'[server port (default 8080; env PINGME_PORT)]:port:' \
        '(-H --host)'{-H+,--host=}'[server host (default 0.0.0.0; env PINGME_HOST)]:host:_hosts' \
        '(- *)'{-h,--help}'[help for serve]'
}

(( $+functions[_pingme_discord] )) ||
_pingme_discord() {
    _arguments \
        '--token=[Discord bot token (REQUIRED; env DISCORD_TOKEN)]:bot token:' \
        '--channel=[Discord channel IDs comma-separated (REQUIRED; env DISCORD_CHANNELS)]:channel ids:' \
        '--msg=[message content (env DISCORD_MESSAGE)]:message:' \
        '--title=[message title (default time; env DISCORD_MSG_TITLE)]:title:' \
        '(- *)'{-h,--help}'[help for discord]'
}

_pingme "$@"
