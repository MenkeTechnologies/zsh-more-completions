#compdef roughtime
# Documentation: https://github.com/cloudflare/roughtime
# Reference accessed: 2026-05-21
# Verified: there is no canonical `roughtime` CLI binary. Roughtime
# is a secure clock-synchronization protocol with multiple
# implementations (cloudflare/roughtime, int08h/roughenough,
# dansarie/pyroughtime, Google's Go impl). Each ships its own binary
# names (e.g. `getroughtime`, `roughenough-client`, `pyroughtime.py`,
# `roughtimed`). No canonical subcommand set exists upstream.
# STUB: no canonical `roughtime` CLI exists; rely on _files for args.

local curcontext="$curcontext" ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
