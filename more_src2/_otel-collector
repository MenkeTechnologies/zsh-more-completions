#compdef otel-collector
# _otel-collector — OpenTelemetry otel-collector CLI command-line frontend wrapping the OpenTelemetry Collector vendor-agnostic CNCF observability data collector pipeline receivers processors exporters connectors extensions OTLP-gRPC-HTTP Jaeger Zipkin Prometheus Fluentd Kafka Elastic Splunk-HEC AWS-XRay Datadog Honeycomb New-Relic Logz-IO Lightstep traces-metrics-logs profiles (OpenTelemetry CNCF team, Go); cobra
# upstream: https://opentelemetry.io/

_otel-collector() {
    local -a sub=(
        'validate:validate config files'
        'components:list available components'
        'completion:generate shell completion'
        'featuregates:list feature gates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config=+[file/uri]:file:_files -g "*.yml *.yaml"' \
        '*--config=+[file/uri]:file:_files -g "*.yml *.yaml"' \
        '--set=+[k=v]:str:' \
        '*--set=+[k=v]:str:' \
        '--feature-gates=+[gate]:str:' \
        '*--feature-gates=+[gate]:str:' \
        '--log-level=+[level]:l:(debug info warn error fatal panic)' \
        '--log-format=+[fmt]:f:(console json)' \
        '--metrics-addr=+[host:port]:_hosts' \
        '--metrics-level=+[l]:l:(none basic normal detailed)' \
        '--ballast-size-mib=+[N]:n:' \
        '--mem-ballast-size-mib=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'otel-collector subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_otel-collector "$@"
