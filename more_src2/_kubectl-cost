#compdef kubectl-cost
# Documentation: https://github.com/kubecost/kubectl-cost/blob/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-N --kubecost-namespace)'{-N+,--kubecost-namespace=}'[namespace Kubecost is deployed in]:namespace:' \
  '(-r --release-name)'{-r+,--release-name=}'[Helm release name]:release:' \
  '--service-name=[Kubecost cost analyzer service name]:service:' \
  '--service-port=[port the Kubecost APIs run on]:port:' \
  '--use-proxy[proxy requests through the Kubernetes API server]' \
  '--allocation-path=[URL path for allocation queries]:path:' \
  '--predict-speccost-path=[URL path for prediction queries]:path:' \
  '--opencost[target OpenCost defaults]' \
  '--log-level=[logging verbosity]:level:(debug info warn error)' \
  '--context=[kubeconfig context name]:context:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      namespace:'aggregated cost by namespace'
      deployment:'aggregated cost by deployment'
      controller:'aggregated cost by controller'
      label:'aggregated cost by label values'
      pod:'aggregated cost by pod'
      node:'cost breakdown by node assets'
      predict:'estimate cost impact of undeployed YAML specifications'
      tui:'terminal user interface for cost visualization'
      version:'print version'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    _default && ret=0
    ;;
esac

return ret
