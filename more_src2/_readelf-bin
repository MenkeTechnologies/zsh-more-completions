#compdef readelf
# _readelf-bin — GNU binutils readelf; display info from ELF format object files
# upstream: https://sourceware.org/binutils

_readelf-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[equivalent to -h -l -S -s -r -d -V -A -I]' \
        '(-h --file-header)'{-h,--file-header}'[ELF file header]' \
        '(-l --program-headers --segments)'{-l,--program-headers,--segments}'[program headers]' \
        '(-S --section-headers --sections)'{-S,--section-headers,--sections}'[section headers]' \
        '(-g --section-groups)'{-g,--section-groups}'[section groups]' \
        '(-t --section-details)'{-t,--section-details}'[section details]' \
        '(-e --headers)'{-e,--headers}'[all headers]' \
        '(-s --syms --symbols)'{-s,--syms,--symbols}'[symbol table]' \
        '(--dyn-syms)--dyn-syms[dynamic symbol table]' \
        '(--lto-syms)--lto-syms[LTO symbol table]' \
        '(-n --notes)'{-n,--notes}'[notes]' \
        '(-r --relocs)'{-r,--relocs}'[relocations]' \
        '(-u --unwind)'{-u,--unwind}'[unwind info]' \
        '(-d --dynamic)'{-d,--dynamic}'[dynamic section]' \
        '(-V --version-info)'{-V,--version-info}'[version sections]' \
        '(-A --arch-specific)'{-A,--arch-specific}'[arch-specific]' \
        '(-c --archive-index)'{-c,--archive-index}'[archive index]' \
        '(-D --use-dynamic)'{-D,--use-dynamic}'[use dynamic sym]' \
        '(-L --lint)'{-L,--lint}'[run sanity checks]' \
        '(-x --hex-dump)'{-x,--hex-dump}'+[hex dump section]:section:' \
        '(-p --string-dump)'{-p,--string-dump}'+[string dump section]:section:' \
        '(-R --relocated-dump)'{-R,--relocated-dump}'+[relocated dump]:section:' \
        '(-z --decompress)'{-z,--decompress}'[decompress before dump]' \
        '(-w --debug-dump)'{-w,--debug-dump}'+[dwarf section]:section:(rawline decodedline info abbrev pubnames aranges macro frames frames-interp str loc Ranges pubtypes gdb_index trace_info trace_abbrev trace_aranges)' \
        '(-T --silent-truncation)'{-T,--silent-truncation}'[no truncation marker]' \
        '(-H --help)'{-H,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-W --wide)'{-W,--wide}'[wide output]' \
        '(-N --full-section-name)'{-N,--full-section-name}'[full section name]' \
        '(-U --unicode)'{-U,--unicode}'+[unicode]:mode:(default invalid locale escape hex highlight)' \
        '(-X --extra-sym-info)'{-X,--extra-sym-info}'[extra symbol info]' \
        '--decompress[decompress sections]' \
        '*:file:_files'
}

_readelf-bin "$@"
