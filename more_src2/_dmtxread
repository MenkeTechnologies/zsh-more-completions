#compdef dmtxread
# Documentation: https://manpages.debian.org/testing/dmtx-utils/dmtxread.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --codewords)'{-c,--codewords}'[output extracted codewords]' \
  '(-e --minimum-edge)'{-e,--minimum-edge}'+[minimum expected edge pixel length]:n' \
  '(-E --maximum-edge)'{-E,--maximum-edge}'+[maximum expected edge pixel length]:n' \
  '(-g --gap)'{-g,--gap}'+[scan grid pixel gap]:px' \
  '(-l --list-formats)'{-l,--list-formats}'[list supported image formats]' \
  '(-m --milliseconds)'{-m,--milliseconds}'+[halt scan after N ms per image]:ms' \
  '(-n --newline)'{-n,--newline}'[add newline after decoded data]' \
  '(-p --page)'{-p,--page}'+[scan only Nth page]:n' \
  '(-q --square-deviation)'{-q,--square-deviation}'+[squareness tolerance (degrees)]:deg' \
  '(-r --resolution)'{-r,--resolution}'+[decoding resolution dpi]:dpi' \
  '(-s --symbol-size)'{-s,--symbol-size}'+[symbol size asr|RxC]:size' \
  '(-t --threshold)'{-t,--threshold}'+[minimum edge threshold percent]:percent' \
  '(-x --x-range-min)'{-x,--x-range-min}'+[skip left pixels]:n' \
  '(-X --x-range-max)'{-X,--x-range-max}'+[skip right pixels]:n' \
  '(-y --y-range-min)'{-y,--y-range-min}'+[skip lower pixels]:n' \
  '(-Y --y-range-max)'{-Y,--y-range-max}'+[skip upper pixels]:n' \
  '(-C --corrections-max)'{-C,--corrections-max}'+[limit error corrections per image]:n' \
  '(-D --diagnose)'{-D,--diagnose}'[create diagnostic image copy]' \
  '(-M --mosaic)'{-M,--mosaic}'[interpret as Data Mosaic barcodes]' \
  '(-N --stop-after)'{-N,--stop-after}'+[stop after Nth barcode]:n' \
  '(-P --page-numbers)'{-P,--page-numbers}'[include page numbers in output]' \
  '(-R --corners)'{-R,--corners}'[prefix output with corner locations]' \
  '(-S --shrink)'{-S,--shrink}'+[internally reduce image by factor]:n' \
  '(-U --unicode)'{-U,--unicode}'[output extended ASCII as UTF-8]' \
  '(-v --verbose)'{-v,--verbose}'[verbose messaging]' \
  '*:image:_files -g "*.{png,jpg,jpeg,tiff,tif,gif,bmp,ico,xpm,pnm,pbm,pgm,ppm,xbm,xv}"' && ret=0

return ret
