#compdef fsck_msdos fsck.fat fsck.vfat fsck.msdos dosfsck
# _fsck_msdos — Tim Reece fsck_msdos dosfsck CLI for the FAT12 FAT16 FAT32 MS-DOS filesystem consistency checker validating boot sector FAT entries directory clusters lost chains automatic repair preen mode read-only test (mtools team, C); getopt
# upstream: https://github.com/dosfstools/dosfstools

_fsck_msdos() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a[automatic repair]' \
        '-A[autorepair, allowing user input]' \
        '-b[read boot sector but do not check]' \
        '-c+[cluster check]:n:' \
        '-d+[disconnect]:str:' \
        '-f[force check]' \
        '-l[list path names being checked]' \
        '-m[memory only check]' \
        '-n[no confirm]' \
        '-p[preen mode]' \
        '-q[quiet]' \
        '-r[interactively repair]' \
        '-S[strict UTF-8]' \
        '-t[mark unreadable clusters bad]' \
        '-u+[name]:str:' \
        '-v[verbose]' \
        '-w[write changes]' \
        '-y[yes confirm]' \
        '*:device:_files'
}

_fsck_msdos "$@"
