#compdef pantheon-terminal
# Documentation: https://manpages.debian.org/experimental/pantheon-terminal/pantheon-terminal.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pantheon-terminal: elementary OS terminal emulator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)'{-v,--version}'[print version info and exit]' \
  '(-e --execute)'{-e+,--execute=}'[execute the specified binary in terminal]:path:_files' \
  '(-w --working-directory)'{-w+,--working-directory=}'[set working directory on startup]:dir:_files -/' \
  '*::pantheon-terminal args:_files' && ret=0
return ret
