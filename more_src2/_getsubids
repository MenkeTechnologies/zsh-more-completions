#compdef getsubids
# Documentation: man getsubids(1)
# Source: shadow-maint/shadow src/getsubids.c (master) — list sub-UID/GID ranges (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-g[list subgid ranges (default: subuid)]' \
    '-h[show help]' \
    '1:owner:_users' \
    && ret=0

return ret
