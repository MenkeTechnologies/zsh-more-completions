#compdef deptrac
# Documentation: https://github.com/deptrac/deptrac
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'analyse:analyze dependencies'
  'analyze:analyze dependencies'
  'debug\:layer:debug layers'
  'debug\:token:debug tokens'
  'debug\:unassigned:list unassigned tokens'
  'debug\:unused:list unused dependencies'
  'init:create a depfile'
  'changed-files:run analyse only on changed files'
  'list:list commands'
  'help:show help for a command'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-c+[configuration file]:config:_files -g "*.(yaml|yml)"' \
  '--config-file=[configuration file]:config:_files -g "*.(yaml|yml)"' \
  '--cache-file=[cache file]:file:_files' \
  '--no-cache[disable cache]' \
  '--clear-cache[clear the result cache]' \
  '-v[verbose mode]' \
  '-vv[more verbose]' \
  '-vvv[debug mode]' \
  '--no-ansi[disable ANSI output]' \
  '--ansi[force ANSI output]' \
  '-q[quiet mode]' \
  '--quiet[quiet mode]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'deptrac command' commands && ret=0
    ;;
  args)
    case "${words[1]}" in
      analyse|analyze)
        _arguments -s -S \
          '--formatter=[output formatter]:formatter:(console graphviz-dot graphviz-html graphviz-image table json junit xml baseline github-actions codeclimate mermaid-js)' \
          '-o+[output file]:file:_files' \
          '--output=[output file]:file:_files' \
          '--fail-on-uncovered[fail on uncovered dependencies]' \
          '--report-uncovered[report uncovered dependencies]' \
          '--report-skipped[report skipped violations]' \
          '--no-progress[disable progress bar]' \
          '*:depfile:_files -g "*.(yaml|yml)"' && ret=0
        ;;
    esac
    ;;
esac

return ret
