#compdef passgen
# Documentation: https://github.com/bradtraversy/passgen
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Multiple unrelated tools ship as "passgen"; this completion targets
# bradtraversy/passgen (Node.js password generator). Other passgens
# (Rust morshedulmunna, C FurqanHun, etc.) use different flags.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-l --length)'{-l,--length}'[password length (default 8)]:length:' \
  '(-s --save)'{-s,--save}'[save password to passwords.txt]' \
  '(-nn --no-numbers)'{-nn,--no-numbers}'[exclude numbers]' \
  '(-ns --no-symbols)'{-ns,--no-symbols}'[exclude symbols]'
