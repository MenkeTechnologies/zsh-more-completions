#compdef gdcmscu
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmscu.cxx — DICOM Q/R Service Class User (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-H --hostname)'{-H+,--hostname=}'[server hostname]:host:_default' \
    '(-p --port)'{-p+,--port=}'[server port (default 104)]:port:_default' \
    '--aetitle=[calling AE Title]:ae:_default' \
    '--call=[called AE Title]:ae:_default' \
    '--echo[C-ECHO (default)]' \
    '--store[C-STORE]' \
    '--find[C-FIND]' \
    '--move[C-MOVE]' \
    '--get[C-GET]' \
    '(-i --input)'{-i+,--input=}'[input DICOM file (C-STORE)]:file:_files' \
    '(-r --recursive)'{-r,--recursive}'[recursive]' \
    '--store-query=[store constructed query in file]:file:_files' \
    '--worklist[C-FIND Worklist Model]' \
    '--patientroot[C-FIND Patient Root Model]' \
    '--studyroot[C-FIND Study Root Model]' \
    '--patient[C-FIND query on Patient info]' \
    '--study[C-FIND query on Study info]' \
    '--series[C-FIND query on Series info]' \
    '--image[C-FIND query on Image info]' \
    '*--key=[0123,4567=VALUE search criteria (wildcard ok)]:key:_default' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '*:hostname or port:_default' \
    && ret=0

return ret
