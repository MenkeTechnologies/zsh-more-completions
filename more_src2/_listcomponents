#compdef listcomponents
# _listcomponents — Alloy helper that prints every registered component name + stability tier
# upstream: https://github.com/grafana/alloy
# Source: internal/cmd/listcomponents/main.go on tip — takes no flags; tab-separated output to stdout.

_listcomponents() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_listcomponents "$@"
