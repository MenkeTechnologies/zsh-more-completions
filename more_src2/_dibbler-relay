# dibbler-relay: Dibbler DHCPv6 relay
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:action:((run\:"start in console" start\:"start as daemon" stop\:"stop running relay" status\:"show status"))' && ret=0
return ret
