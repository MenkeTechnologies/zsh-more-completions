#compdef pamrestack
# Documentation: man pamrestack (Netpbm)
# Source: rewrap a PAM image to a new row width.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[target output width]:width:' \
    '-trim=[trim mode]:mode:(fill crop abort)' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
