_deepcool-digital-linux() {
    local -a modes
    modes=(auto cpu_temp cpu_usage cpu_power cpu_freq cpu_fan gpu_temp gpu_usage gpu_power cpu gpu psu)

    _arguments -s \
        '(-h --help)'{-h,--help}'[print help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '(-l --list)'{-l,--list}'[print Product IDs of connected DeepCool devices]' \
        '(-g --gpulist)'{-g,--gpulist}'[print all available GPUs with vendor+ID+PCI address]' \
        '(-m --mode)'{-m+,--mode=}'[primary display mode]:mode:($modes)' \
        '(-s --secondary)'{-s+,--secondary=}'[secondary display mode (LS720/LT720 dual-screen)]:mode:($modes)' \
        '--pid=[USB Product ID for multi-device hosts]:product id:' \
        '--gpuid=[GPU vendor:id (nvidia:1, amd:0, intel:0)]:vendor\:id:(nvidia:0 nvidia:1 nvidia:2 amd:0 amd:1 intel:0)' \
        '(-u --update)'{-u+,--update=}'[update interval in ms (default 1000, range 100-2000)]:ms:' \
        '(-f --fahrenheit)'{-f,--fahrenheit}'[use °F instead of °C]' \
        '(-a --alarm)'{-a,--alarm}'[enable alarm]' \
        '(-r --rotate)'{-r+,--rotate=}'[display rotation (LP-series only)]:degree:(90 180 270)' \
        '(-z --zeros)'{-z,--zeros}'[display leading zeros (LD-series only)]'
}

_deepcool-digital-linux "$@"
