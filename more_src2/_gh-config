#compdef gh-config
# _gh-config — GitHub gh config subcommand alias (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-config() {
    local -a sub=(
        'get:print value of given key'
        'list:print list of keys and values'
        'set:set key/value config'
        'clear-cache:clear gh cache'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh-config subcommand' sub ;;
        args)
            case $words[1] in
                get|set) _arguments \
                    '--host=+[GitHub host]:host:_hosts' \
                    '-h+[GitHub host]:host:_hosts' \
                    '*:key-value:(git_protocol editor prompt pager prefer_editor_prompt http_unix_socket browser version)' ;;
                list) _arguments \
                    '--host=+[GitHub host]:host:_hosts' \
                    '-h+[GitHub host]:host:_hosts' ;;
                clear-cache) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_gh-config "$@"
