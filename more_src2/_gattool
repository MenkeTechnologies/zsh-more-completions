#compdef gatttool gattool
# Documentation: https://github.com/bluez/bluez/blob/master/attrib/gatttool.c
# Reference accessed: 2026-05-27
# Verified: upstream bluez attrib/gatttool.c GOptionEntry arrays
#   (options, gatt_options, primary_char_options, char_rw_options)
# Note: canonical binary name is gatttool (three t's); gattool (two t's)
# is an occasional packaging typo - both #compdef names are wired up.
# gatttool is deprecated in BlueZ 5.x in favor of btgatt-client but is
# still shipped by many distros.

_arguments -s \
  '(-i --adapter)'{-i+,--adapter=}'[specify local adapter interface]:hci device:' \
  '(-b --device)'{-b+,--device=}'[specify remote Bluetooth address]:bdaddr:' \
  '(-t --addr-type)'{-t+,--addr-type=}'[set LE address type]:type:(public random)' \
  '(-m --mtu)'{-m+,--mtu=}'[specify the MTU size]:mtu:' \
  '(-p --psm)'{-p+,--psm=}'[specify the PSM for GATT/ATT over BR/EDR]:psm:' \
  '(-l --sec-level)'{-l+,--sec-level=}'[set security level]:level:(low medium high)' \
  '--primary[primary service discovery]' \
  '--characteristics[characteristics discovery]' \
  '--char-read[characteristics value/descriptor read]' \
  '--char-write[write without response (write command)]' \
  '--char-write-req[characteristics value write (write request)]' \
  '--char-desc[characteristics descriptor discovery]' \
  '--listen[listen for notifications and indications]' \
  '(-I --interactive)'{-I,--interactive}'[use interactive mode]' \
  '(-a --handle)'{-a+,--handle=}'[read/write characteristic by handle]:handle:' \
  '(-n --value)'{-n+,--value=}'[write characteristic value]:hex value:' \
  '(-s --start)'{-s+,--start=}'[starting handle]:handle:' \
  '(-e --end)'{-e+,--end=}'[ending handle]:handle:' \
  '(-u --uuid)'{-u+,--uuid=}'[UUID16 or UUID128]:uuid:' \
  '--offset=[offset for read/write]:offset:'
