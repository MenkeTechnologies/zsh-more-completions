#compdef rustywind
# Documentation: https://github.com/avencera/rustywind
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--stdin[read input from stdin]' \
  '--write[modify files in place with reorganized classes]' \
  '--dry-run[display sorted output without changing files]' \
  '--check-formatted[verify if files are already formatted (exit 1 if not)]' \
  '--config-file=[load custom sort order from JSON configuration]:file:_files' \
  '--output-css-file=[derive sort order from a CSS file]:file:_files' \
  '--vite-css=[use CSS from Vite dev server for sort order (experimental)]:url:' \
  '--custom-regex=[apply custom regex pattern instead of default]:regex:' \
  '--allow-duplicates[preserve duplicate class definitions]' \
  '--ignored-files=[skip specified files during processing]:files:_files' \
  '--skip-ssl-verification[disable SSL checks when fetching remote CSS]' \
  '--quiet[suppress log messages]' \
  '*:file or directory:_files' && ret=0

return ret
