#compdef openmsx
# _openmsx — openMSX: cycle-accurate MSX emulator (openMSX/openMSX)
# upstream: https://github.com/openMSX/openMSX
# Flags from doc/openmsx.sgml.

_openmsx() {
    local -a args
    args=(
        '(-h --help)'{-h,--help}'[show help and exit]'
        '(-v --version)'{-v,--version}'[show version and exit]'
        '-cart=[insert ROM cartridge into the first cartridge slot]:file:_files -g "*.(rom|zip|gz)"'
        '-carta=[insert ROM cartridge into cartridge slot A]:file:_files -g "*.(rom|zip|gz)"'
        '-cartb=[insert ROM cartridge into cartridge slot B]:file:_files -g "*.(rom|zip|gz)"'
        '-diska=[insert disk image into drive A]:file:_files -g "*.(dsk|di1|di2|xsa|zip|gz)"'
        '-diskb=[insert disk image into drive B]:file:_files -g "*.(dsk|di1|di2|xsa|zip|gz)"'
        '-cassetteplayer=[load tape image into the cassette player]:file:_files -g "*.(cas|wav|zip|gz)"'
        '-laserdisc=[load laserdisc video into the laserdisc player]:file:_files -g "*.(ogv|zip|gz)"'
        '-control=[control type (stdio or socket)]:type:(stdio socket)'
        '-machine=[MSX machine to emulate]:machine:'
        '*-ext=[insert an extension cartridge (repeatable)]:extension:'
        '*-setting=[load a Tcl/console setting]:setting:'
    )
    _arguments -s -S $args
}

_openmsx "$@"
