#compdef phc2sys
# _phc2sys — linuxptp phc2sys CLI synchronizing the Linux system clock to a PTP Hardware Clock PHC slave or vice versa step adjust offset frequency PI servo selecting realtime CLOCK_REALTIME source from ptp4l socket with given alarm threshold (linuxptp team, C); getopt
# upstream: https://linuxptp.sourceforge.net/

_phc2sys() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c+[clock]:str:' \
        '-d+[pps dev]:file:_files -g "/dev/pps*"' \
        '-s+[source]:str:' \
        '-O+[offset ns]:str:' \
        '-w[wait for ptp4l]' \
        '-f+[config file]:file:_files -g "*.conf *.cfg"' \
        '-r[realtime]' \
        '-R+[rate Hz]:n:' \
        '-N+[steps]:n:' \
        '-P+[Kp]:n:' \
        '-I+[Ki]:n:' \
        '-S+[step threshold]:n:' \
        '-F+[first step]:n:' \
        '-E+[servo]:s:(pi linreg)' \
        '-u+[summary updates]:n:' \
        '-n+[domain]:n:' \
        '-x[no max freq]' \
        '-z+[uds]:file:_files' \
        '-l+[print level]:l:(0 1 2 3 4 5 6 7)' \
        '-m[print to stdout]' \
        '-q[no syslog]' \
        '*:other:'
}

_phc2sys "$@"
