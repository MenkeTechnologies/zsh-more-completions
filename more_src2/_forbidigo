#compdef forbidigo
# Documentation: https://github.com/ashanbrown/forbidigo
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Usage: forbidigo [flags...] patterns... -- packages...
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '-set_exit_status[exit 1 if any issues found]' \
  '-exclude_godoc_examples[exclude godoc examples (default true)]' \
  '-tests[include test files (default true)]' \
  '-analyze_types[type-aware matching]' \
  '*:patterns or packages:_files -g "*.go"'
