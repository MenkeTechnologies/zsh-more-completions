#compdef deliver
# _deliver — fastlane deliver iOS App Store metadata/screenshots/binary uploader (fastlane, Ruby); commander
# upstream: https://github.com/fastlane/fastlane

_deliver() {
    local -a sub=(
        'submit_build:submit build for review'
        'init:scaffold deliver config'
        'generate_summary:generate summary'
        'download_screenshots:download screenshots'
        'download_metadata:download metadata'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--username=+[apple ID username]:str:_users' \
        '-u+[apple ID username]:str:_users' \
        '--app-identifier=+[app identifier]:str:' \
        '-a+[app identifier]:str:' \
        '--app=+[app id]:str:' \
        '-p+[app id]:str:' \
        '--ipa=+[ipa path]:file:_files -g "*.ipa"' \
        '-i+[ipa path]:file:_files -g "*.ipa"' \
        '--pkg=+[pkg path]:file:_files -g "*.pkg"' \
        '-c+[pkg path]:file:_files -g "*.pkg"' \
        '--build-number=+[build number]:str:' \
        '-n+[build number]:str:' \
        '--platform=+[platform]:p:(ios appletvos osx xros)' \
        '-j+[platform]:p:(ios appletvos osx xros)' \
        '--metadata-path=+[metadata path]:dir:_files -/' \
        '-m+[metadata path]:dir:_files -/' \
        '--screenshots-path=+[screenshots path]:dir:_files -/' \
        '-w+[screenshots path]:dir:_files -/' \
        '--skip-binary-upload=+[skip binary upload]:b:(true false)' \
        '-k+[skip binary upload]:b:(true false)' \
        '--skip-screenshots=+[skip screenshots]:b:(true false)' \
        '-x+[skip screenshots]:b:(true false)' \
        '--skip-metadata=+[skip metadata]:b:(true false)' \
        '-z+[skip metadata]:b:(true false)' \
        '--skip-app-version-update=+[skip app version update]:b:(true false)' \
        '--force=+[force]:b:(true false)' \
        '-f+[force]:b:(true false)' \
        '--overwrite-screenshots=+[overwrite screenshots]:b:(true false)' \
        '--submit-for-review=+[submit for review]:b:(true false)' \
        '-s+[submit for review]:b:(true false)' \
        '--reject-if-possible=+[reject if possible]:b:(true false)' \
        '--automatic-release=+[automatic release]:b:(true false)' \
        '--auto-release-date=+[auto release date]:str:' \
        '--phased-release=+[phased release]:b:(true false)' \
        '--reset-ratings=+[reset ratings]:b:(true false)' \
        '--price-tier=+[price tier]:n:' \
        '--app-rating-config-path=+[app rating config path]:file:_files' \
        '--submission-information=+[submission info]:str:' \
        '--team-id=+[team id]:str:' \
        '-l+[team id]:str:' \
        '--team-name=+[team name]:str:' \
        '-r+[team name]:str:' \
        '--dev-portal-team-id=+[dev portal team id]:str:' \
        '--itc-provider=+[itc provider]:str:' \
        '--run-precheck-before-submit=+[run precheck before submit]:b:(true false)' \
        '--precheck-default-rule-level=+[precheck rule level]:lvl:(warn error skip)' \
        '--app-version=+[app version]:str:' \
        '-w+[app version]:str:' \
        '--description=+[description]:str:' \
        '--release-notes=+[release notes]:str:' \
        '--copyright=+[copyright]:str:' \
        '--api-key-path=+[api key path]:file:_files' \
        '--api-key=+[api key hash]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'deliver subcommand' sub ;;
    esac
}

_deliver "$@"
