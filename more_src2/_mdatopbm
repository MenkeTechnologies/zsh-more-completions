#compdef mdatopbm
# Documentation: man mdatopbm (Netpbm)
# Source: convert a Microdesign MDA bitmap to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d[double-density mode]' \
    '-i[invert black/white]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:mda file:_files' \
    && ret=0

return ret
