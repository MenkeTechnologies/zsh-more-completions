# Reference accessed: 2026-05-16
# Verified: upstream fishshell.com fish_key_reader docs.
# Removed from prior file: bogus man.archlinux.org search URL.

# fish-key-reader: explain terminal escape sequences for fish bindings
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-c --continuous)'{-c,--continuous}'[session for inspecting multiple key sequences]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[explain received sequence in addition to decoded key]' \
  '(-V --version)'{-V,--version}'[show fish version and exit]' && ret=0
return ret
