#compdef grdview
# Documentation: https://docs.generic-mapping-tools.org/latest/grdview.html
# Source: GenericMappingTools/gmt src/grdview.c — 3D surface plot of a grid (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[map projection]:projection:_default' \
    '-B+[axes options]:opts:_default' \
    '-G+[drape grid or image]:file:_files' \
    '-I+[intensity grid/value]:opts:_default' \
    '-K[allow more PS later]' \
    '-N+[base level + fill]:opts:_default' \
    '-O[append PostScript]' \
    '-P[portrait]' \
    '-Q+[plotting mode]:mode:(c g i m s)' \
    '-R+[region]:region:_default' \
    '-S+[smoothing factor]:smooth:_default' \
    '-T+[tile drawing options]:opts:_default' \
    '-U+[plot timestamp]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[x shift]:shift:_default' \
    '-c+[subplot panel]:panel:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-n+[grid interpolation]:opts:_default' \
    '-p+[3D perspective view]:view:_default' \
    '-t+[transparency]:value:_default' \
    '1:input grid:_files -g "*.{grd,nc}"' \
    && ret=0

return ret
