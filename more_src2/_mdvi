#compdef mdvi
# ---------------------------------------------------------------------------
# mdvi — professional markdown viewer for the terminal with Vim navigation (Rust, 278★)
#
# upstream: https://github.com/taf2/mdvi
# author : Todd A. Fisher  <todd.fisher@gmail.com>  (taf2)
# license: MIT
#
# Source-direct completion: every flag below is verbatim from src/main.rs on
# the mdvi tip — `Cli` clap-derive struct with `path`, `--line`/`-l`, and
# `--image-protocol` (ValueEnum: Auto, Halfblocks, Sixel, Kitty, Iterm2).
#
# Direct deps from Cargo.toml:
#   pulldown-cmark = "0.12"     ← canonical Rust CommonMark parser (this axis)
#   ratatui        = "0.29"     (TUI render layer)
#   crossterm      = "0.28"
#   ratatui-image  = "8.1"      (image-defaults, crossterm backend)
#   syntect        = "5.3"      (default-fancy, code highlighting)
#   image          = "0.25"
#   reqwest        = "0.12"     (blocking + rustls-tls; fetches remote img/url)
#   arboard        = "3.6"      (clipboard for yank)
#   clap           = "4.5"      (derive)
#
# === AXIS 154 OPENER — CommonMark / Markdown parser ecosystem ===
# Axis position: Rust=209 OPENS Axis 154 at slot 1/0/0.  Canonical Rust
# CommonMark parser is `pulldown-cmark` by Raph Levien (raphlinus, formerly
# Google Fonts / Xi-editor) with Marco Cecchetti continuing development —
# a pull-based zero-allocation CommonMark parser that powers mdBook, the
# Rust Book, docs.rs option rendering, comrak's reference impl comparisons,
# rustdoc, and gitbook-ish static-site generators.  mdvi consumes
# pulldown-cmark events directly to walk the AST and render to ratatui spans
# (heading, emphasis, code-block-with-syntect, link, image) inside a TUI.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=209   ← THIS FILE              (axis 154 OPENS, slot 1/0/0)
#   Go=209     ← next round              (axis 154 continues, slot 2/0/0)
#   TS-Node=209 ← round after            (axis 154 CLOSES at triple-209, slot 1/1/1)
# ---------------------------------------------------------------------------

_mdvi() {
    _arguments -s -S \
        '(-l --line)'{-l,--line=}'[start at a specific line (1-based, default 1)]:line number:' \
        '--image-protocol=[image rendering protocol]:protocol:((
            auto\:auto-detect\ best\ supported\ protocol
            halfblocks\:Unicode\ half-block\ characters\ \(works\ everywhere\)
            sixel\:DEC\ Sixel\ \(xterm\,\ mlterm\,\ wezterm\)
            kitty\:Kitty\ graphics\ protocol\ \(kitty\,\ ghostty\,\ wezterm\)
            iterm2\:iTerm2\ inline\ images\ \(iTerm2\,\ WezTerm\)
        ))' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1:markdown file:_files -g "*.(md|markdown|mdown|mkd|mkdn)"'
}

_mdvi "$@"
