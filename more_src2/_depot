#compdef depot
# Documentation: https://depot.dev/docs/cli/reference
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Depot — fast Docker image builds
local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'bake:build from a Docker Bake file'
      'build:build an image from a Dockerfile'
      'cache:manage build cache'
      'configure-docker:configure Docker to use Depot'
      'init:initialize a new Depot project'
      'list:list recent builds'
      'login:log in to Depot'
      'logout:log out of Depot'
      'org:manage organizations'
      'projects:list available projects'
      'pull:pull built image from registry'
      'push:push built image to registry'
    )
    _describe -t commands 'depot command' commands && ret=0
    ;;
  args)
    case $line[1] in
      build)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--project=[Depot project ID]:project' \
          '*'{-t+,--tag=}'[name and optionally a tag]:name\:tag' \
          '(-f --file)'{-f+,--file=}'[name of the Dockerfile]:dockerfile:_files' \
          '*--platform=[target platform]:platform' \
          '*--build-arg=[build-time variable]:arg' \
          '--target=[target build stage]:target' \
          '*--output=[output destination]:output' \
          '--push[push image to registry]' \
          '--load[load image into Docker]' \
          '--no-cache[do not use cache]' \
          '--progress=[set type of progress output]:type:(auto plain tty rawjson)' \
          '*--cache-from=[external cache source]:cache' \
          '*--cache-to=[cache export destination]:cache' \
          '*--secret=[secret to expose to build]:secret' \
          '*--ssh=[SSH agent socket or keys]:ssh' \
          '*--label=[metadata for an image]:label' \
          '--shm-size=[size of /dev/shm]:size' \
          '--lint[enable Dockerfile linting]' \
          '--save[save build to project]' \
          '1:path:_directories' && ret=0
        ;;
      bake)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--project=[Depot project ID]:project' \
          '*'{-f+,--file=}'[build definition file]:file:_files' \
          '--push[push images]' \
          '--load[load images]' \
          '--no-cache[do not use cache]' \
          '*--set=[override target value]:override' \
          '--print[print options without building]' \
          '*:target' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:directory:_directories' && ret=0
        ;;
      login)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--org-id=[organization ID]:org' \
          '--clear[remove existing token first]' \
          '--token=[API token]:token' && ret=0
        ;;
      logout)
        _arguments -s -S '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      org)
        _arguments -s -S \
          '1:subcommand:(list switch show)' && ret=0
        ;;
      cache)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(reset)' && ret=0
        ;;
    esac
    ;;
esac

return ret
