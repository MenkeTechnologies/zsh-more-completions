#compdef git-subtree
# Documentation: https://git-scm.com/docs/git-subtree
# Source: git/git contrib/subtree/git-subtree.sh — split/join git repositories in subdirectories (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    {-h,--help}'[show help]' \
    {-q,--quiet}'[quiet mode]' \
    {-d,--debug}'[show debug messages]' \
    {-P+,--prefix=}'[subdir name to split out]:prefix:_files -/' \
    '--annotate=-[prefix for new commit messages]:prefix:_default' \
    {-b+,--branch=}'[create branch from split subtree]:branch:_default' \
    '--ignore-joins[ignore prior --rejoin commits]' \
    '--onto=-[connect new tree to existing one]:onto:_default' \
    '--rejoin[merge new branch back into HEAD]' \
    '--squash[merge subtree changes as a single commit]' \
    {-m+,--message=}'[commit message for merge]:msg:_default' \
    '(-S --gpg-sign)'{-S-,--gpg-sign=-}'[GPG-sign commits (optional keyid)]::key-id:_default' \
    '1:subcommand:(add merge split pull push)' \
    '*::args:->cmdargs' \
    && ret=0

return ret
