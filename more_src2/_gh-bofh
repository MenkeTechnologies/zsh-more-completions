#compdef gh-bofh gh-drop gh-feed gh-ghq-cd gh-ranking gh-sparkle
# Documentation: upstream READMEs at github.com/{AliSajid/gh-bofh,drakulavich/gh-drop,jo-es/gh-feed,cappyzawa/gh-ghq-cd,yukukotani/gh-ranking,dyxushuai/gh-sparkle}
# Reference accessed: 2026-05-30
# gh-extension family round 10. Continued TypeScript + Rust slice harvest.
# Hunt-skip log this round:
#   gh-start (jasonappah/gh-start) — WIP repo with no documented surface;
#     skip until upstream ships.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-bofh)
    # AliSajid/gh-bofh — generate random BOFH excuses.
    #   -c / -m are short-form mutex; --type is the long form.
    _arguments -s -S \
      '(-c --classic -m --modern -t --type)-c[classic (90s era) excuse]' \
      '(-c --classic -m --modern -t --type)--classic[classic (90s era) excuse]' \
      '(-c --classic -m --modern -t --type)-m[modern excuse]' \
      '(-c --classic -m --modern -t --type)--modern[modern excuse]' \
      '(-c --classic -m --modern -t --type)-t+[excuse type]:type:(classic modern)' \
      '(-c --classic -m --modern -t --type)--type=[excuse type]:type:(classic modern)' \
      && ret=0
    ;;

  gh-drop)
    # drakulavich/gh-drop — upload images to GitHub issues/PRs.
    local -a _subcmds
    _subcmds=(
      'auth:authentication subcommand group'
    )
    _arguments -C -s -S \
      '*--image=[image to upload (repeatable)]:file:_files -g "*.(png|jpg|jpeg|gif|webp)"' \
      '--issue=[issue or PR number to attach to]:number:' \
      '--body=[message body (use <!-- gh-drop:IMAGE:N --> placeholders)]:body:' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-drop subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          auth)
            _arguments \
              '1:auth action:(login logout)' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-feed)
    # jo-es/gh-feed — TUI for reading + replying to PR discussions.
    _arguments -s -S \
      '--pr=[preselect a PR number]:number:' \
      '--repo=[target repository (owner/repo)]:repo:' \
      && ret=0
    ;;

  gh-ghq-cd)
    # cappyzawa/gh-ghq-cd — interactive ghq-managed repo browser.
    # Has tmux/zellij integration via -w/-p/-H/-V/-c flags.
    _arguments -s -S \
      '-w[open in new window/tab]' \
      '-p[create pane split]' \
      '(-H -V)-H[horizontal split direction]' \
      '(-H -V)-V[vertical split direction]' \
      '-c+[command to execute in new pane/window]:command:' \
      && ret=0
    ;;

  gh-ranking)
    # yukukotani/gh-ranking — display org-wide GitHub activity rankings.
    #   gh ranking <org> <action> [--team TEAM] [--query QUERY]
    _arguments -s -S \
      '--team=[filter by team ID]:team:' \
      '--query=[additional GitHub search filters]:query:' \
      '1:organization:' \
      '2:action:(open-pr review-pr)' \
      && ret=0
    ;;

  gh-sparkle)
    # dyxushuai/gh-sparkle — AI-generated commit messages via GitHub Models.
    _arguments -s -S \
      '--language=[output language for description text]:language:' \
      '--examples=[recent commits as context (1-20, default 3)]:N:' \
      '--model=[GitHub Models model name]:model:' \
      '--dry-run[preview without committing]' \
      '--summary-only[use only summary, exclude diff details]' \
      && ret=0
    ;;

esac

return ret
