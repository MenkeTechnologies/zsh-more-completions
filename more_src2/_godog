#compdef godog
# Documentation: https://github.com/cucumber/godog
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --definitions)'{-d,--definitions}'[print step definitions and exit]' \
  '(-f --format)'{-f,--format}'[output formatter]:format:(pretty progress cucumber events junit)' \
  '--concurrency[number of concurrent scenarios]:number' \
  '--no-colors[disable ANSI color output]' \
  '(-t --tags)'{-t,--tags}'[filter scenarios by tags]:tags' \
  '--strict[fail on pending or undefined steps]' \
  '--random[randomize scenario execution order]' \
  '--stop-on-failure[stop after first failure]' \
  '(-o --output)'{-o,--output}'[output file]:file:_files' \
  '*:feature file:_files -g "*.feature"' && ret=0

return ret
