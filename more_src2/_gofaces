_gofaces() {
    _arguments -s -S \
        '-model[path to the ONNX model file]:onnx model:_files -g "*.onnx"' \
        '-img[path of an input JPEG image]:jpeg image:_files -g "*.(jpg|jpeg|JPG|JPEG)"' \
        '-output[path of an output PNG mask (empty = no file)]:png path:_files -g "*.png"' \
        '-s[silent mode]' \
        '-h[show help]' \
        '-help[show help]'
}

_gofaces "$@"
