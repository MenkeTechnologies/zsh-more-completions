#compdef fuser-cli
# _fuser-cli — Werner Almesberger fuser identify processes using files or sockets CLI alias (psmisc team, C); custom argparse
# upstream: https://gitlab.com/psmisc/psmisc

_fuser-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[show all files]' \
        '--all[show all files]' \
        '-c[show all processes using same fs]' \
        '--mount[show all processes using same fs]' \
        '-M[require mount point]' \
        '--ismountpoint[require mount point]' \
        '-w[only writers]' \
        '--writeonly[only writers]' \
        '-i[ask before killing]' \
        '--interactive[ask before killing]' \
        '-k[kill processes]' \
        '--kill[kill processes]' \
        '-l[list signal names]' \
        '--list-signals[list signal names]' \
        '-m[list with same mount point]' \
        '-n+[namespace]:n:(file udp tcp)' \
        '--namespace=+[namespace]:n:(file udp tcp)' \
        '-s[silent]' \
        '--silent[silent]' \
        '-SIGNAL[send signal]' \
        '-u[append user name]' \
        '--user[append user name]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-4[only ipv4]' \
        '--ipv4[only ipv4]' \
        '-6[only ipv6]' \
        '--ipv6[only ipv6]' \
        '*:file or socket:_files'
}

_fuser-cli "$@"
