#compdef grdrotater
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/spotter/grdrotater.html
# Source: GenericMappingTools/gmt supplements/spotter — rotate a grid via plate-tectonic total reconstruction.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E+[rotation (file / plate IDs / lon/lat/angle)]:opts:_default' \
    '-G+[output grid file]:file:_files' \
    '-A+[crop or extend rotated region]:opts:_default' \
    '-D+[output rotated polygon outline file]:file:_files' \
    '-F+[multisegment polygon clip file]:file:_files' \
    '-N[suppress polygon-outline output]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S[skip grid rotation; only rotate polygon]' \
    '-T+[reconstruction time(s)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '-o+[output column selection]:cols:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
