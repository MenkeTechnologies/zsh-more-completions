#compdef ohmybash ohmybash-installer
# _ohmybash — ohmybash CLI helper for managing the Oh My Bash community framework switching themes enabling plugins aliases completions self-update from upstream Git repo backup restore (ohmybash team, Bash); getopt
# upstream: https://github.com/ohmybash/oh-my-bash

_ohmybash() {
    local -a sub=(
        'theme:switch theme'
        'plugin:manage plugin'
        'alias:manage alias group'
        'completion:manage completion'
        'update:update Oh My Bash'
        'reset:reset configuration'
        'reload:reload Oh My Bash'
        'uninstall:uninstall Oh My Bash'
        'doctor:run diagnostics'
        'show:show current settings'
        'preview:preview theme'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ohmybash subcommand' sub ;;
        args)
            case $words[1] in
                theme) _arguments \
                    '1:action:(set list current preview)' \
                    '*:theme name:' ;;
                plugin|alias|completion) _arguments \
                    '1:action:(enable disable list)' \
                    '*:item name:' ;;
                update) _arguments \
                    '1:channel:(stable dev master main)' ;;
            esac
            ;;
    esac
}

_ohmybash "$@"
