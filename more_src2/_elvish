#compdef elvish
# Documentation: https://elv.sh/ref/command.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elvish: expressive programming language and versatile interactive shell

_arguments -s -S \
  '(- *)-help[show help and exit]' \
  '(- *)-version[show version and exit]' \
  '-buildinfo[show build info and exit]' \
  '-json[output -buildinfo/-compileonly/-version as JSON]' \
  '-c+[execute first argument as code]:command:' \
  '-compileonly[parse and compile, do not execute]' \
  '-deprecation-level+[show warnings for features deprecated as of version 0.N]:level:' \
  '-i[POSIX compat no-op]' \
  '-log+[write debug logs to file]:file:_files' \
  '-lsp[run the built-in language server]' \
  '-norc[skip rc file in interactive mode]' \
  '-rc+[custom rc file path]:file:_files' \
  '-daemon[run as storage daemon]' \
  '-db+[database file path]:file:_files' \
  '-sock+[daemon UNIX socket path]:file:_files' \
  '*:script file:_files'
