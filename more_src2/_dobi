# -----------------------------------------------------------------------------
#
# THE dobi CLI
#
# dobi is a multi-subcommand cobra-based CLI.
# Invocation:
#   dobi [flags] RESOURCE[:ACTION] [RESOURCE[:ACTION]...]
#   dobi <subcommand> [args]
#
# Top-level flags:
#   -f, --filename <PATH>             config file path
#                                     (default
#                                     "dobi.yaml")
#   -v, --verbose                     verbose (Debug
#                                     level logging)
#   -q, --quiet                       quiet (Warn
#                                     level logging)
#       --no-bind-mount               use image-layer
#                                     mount instead
#                                     of bind-mount
#                                     (env
#                                     DOBI_NO_BIND_MOUNT)
#       --version                     print version
#                                     and exit
#   -h, --help                        show help
#
# Positional (run mode):
#   RESOURCE[:ACTION] ...             one or more
#                                     resource:action
#                                     pairs.  If no
#                                     :action is
#                                     given, the
#                                     resource's
#                                     default action
#                                     runs
#
# Subcommands:
#   list                              list declared
#                                     resources
#   autoclean                         run the remove
#                                     action for all
#                                     resources
#
# list flags:
#   -a, --all                         include
#                                     resources
#                                     without
#                                     descriptions
#   -g, --grouped                     group by tag
#   -t, --tags <list>                 only list tasks
#                                     matching these
#                                     tags
#
# Environment variables:
#   DOCKER_API_VERSION                Docker API
#                                     version to use
#                                     (default 1.25)
#   DOBI_NO_BIND_MOUNT                default for
#                                     --no-bind-mount
#
# Common invocations:
#   # Run the default action of a resource
#   dobi build
#
#   # Run a specific action of a resource
#   dobi build:push
#
#   # Run multiple resources in sequence
#   dobi build test integration:run
#
#   # Use a non-default config file
#   dobi -f ci-dobi.yaml build
#   dobi --filename ci-dobi.yaml build
#
#   # Verbose / Quiet
#   dobi -v build
#   dobi -q build
#
#   # CI mode: layer-baked mounts (no bind-mount)
#   DOBI_NO_BIND_MOUNT=true dobi build
#   dobi --no-bind-mount build
#
#   # List all declared resources
#   dobi list
#   dobi list -a                    # include those without descriptions
#   dobi list -g                    # group by tag
#   dobi list -t ci,test            # only matching tags
#
#   # Run autoclean to invoke `remove` actions
#   dobi autoclean
#
#   # Print version
#   dobi --version
#
# Sample dobi.yaml structure:
#   ```yaml
#   image=build-image:
#       image: myapp-builder
#       dockerfile: Dockerfile
#       context: .
#       tags: [dev, build]
#
#   mount=src:
#       bind: ./src
#       path: /app/src
#       read-only: false
#
#   job=test:
#       use: build-image
#       mounts: [src]
#       command: pytest tests/
#       tags: [test]
#
#   alias=ci:
#       tasks: [build-image, test]
#       tags: [ci]
#   ```
#
# OPTIONS (sourced directly from
# https://github.com/dnephin/dobi/blob/master/cmd/dobi.go +
# https://github.com/dnephin/dobi/blob/master/cmd/list.go +
# https://github.com/dnephin/dobi/blob/master/cmd/autoclean.go):
#
# (See subcommand documentation above for the complete
# flag set.)
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dobi_subcommands
_dobi_subcommands=(
    'list:list declared resources'
    'autoclean:run the remove action for all resources'
)

local -a _dobi_global_flags
_dobi_global_flags=(
    '(-f --filename)'{-f,--filename}'=[config file path (default dobi.yaml)]:config:_files -g "*.(yaml|yml)"'
    '(-v --verbose)'{-v,--verbose}'[verbose Debug-level logging]'
    '(-q --quiet)'{-q,--quiet}'[quiet Warn-level logging]'
    '--no-bind-mount[use image-layer mount instead of bind-mount]'
)

_arguments -C \
    "${_dobi_global_flags[@]}" \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[print version and exit]' \
    '1:subcommand or RESOURCE[:ACTION]:->subcmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    subcmd)
        _describe -t subcmds 'dobi subcommand (or RESOURCE[:ACTION])' _dobi_subcommands && ret=0
        ;;
    args)
        case $words[1] in
            list)
                _arguments \
                    "${_dobi_global_flags[@]}" \
                    '(-a --all)'{-a,--all}'[include resources without descriptions]' \
                    '(-g --grouped)'{-g,--grouped}'[group resources by tag]' \
                    '(-t --tags)'{-t,--tags}'=[only list tasks matching these tags]:tags: ' \
                    && ret=0
                ;;
            autoclean)
                _arguments "${_dobi_global_flags[@]}" && ret=0
                ;;
            *)
                # Positional resource[:action] continuation
                _arguments "${_dobi_global_flags[@]}" && ret=0
                ;;
        esac
        ;;
esac

return ret
