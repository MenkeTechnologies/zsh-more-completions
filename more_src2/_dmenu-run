#compdef dmenu-run dmenu_run
# Documentation: https://tools.suckless.org/dmenu/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: dmenu_run is a script wrapping dmenu; accepts the same flags as dmenu(1).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-b[appear at the bottom of the screen]' \
  '-f[grab keyboard before reading stdin]' \
  '-i[case-insensitive matching]' \
  '-l+[list items vertically with N lines]:lines' \
  '-m+[monitor number to display on]:monitor' \
  '-p+[prompt to be displayed]:prompt' \
  '-fn+[font or font set]:font' \
  '-nb+[normal background color]:color' \
  '-nf+[normal foreground color]:color' \
  '-sb+[selected background color]:color' \
  '-sf+[selected foreground color]:color' \
  '-w+[window id to embed into]:window id' \
  '-v[print version]' && ret=0

return ret
