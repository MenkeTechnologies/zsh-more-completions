#compdef envsubst
# Documentation: envsubst --help (GNU gettext)
# Source: GNU gettext — substitute environment variables in shell format strings.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --variables)'{-v,--variables}'[output variables occurring in SHELL-FORMAT]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '(- *)'{-V,--version}'[output version information and exit]' \
    '*:SHELL-FORMAT:' \
    && ret=0

return ret
