#compdef pullnews
# Documentation: man pullnews(1)
# Source: InterNetNews/inn frontends/pullnews.in — pull articles from upstream NNTP (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[print help]' \
    '-a+[hashfeed value/mod[:offset]]:hashfeed:_default' \
    '-b+[backtrack fraction 0.0-1.0]:frac:_default' \
    '-B[header-only feed]' \
    '-c+[config file]:file:_files' \
    '-C+[progress width chars]:N:_default' \
    '-d+[debug level]:level:_default' \
    '-f+[get fraction 0.0-1.0 per group]:frac:_default' \
    '-F+[fake hop hostname]:host:_hosts' \
    '-g+[only get groups (comma separated)]:groups:_default' \
    '-G+[add groups to config]:groups:_default' \
    '-H+[strip header fields (colon-separated)]:headers:_default' \
    '-k+[checkpoint config every N articles]:N:_default' \
    '-l+[log file]:file:_files' \
    '-L+[largest article size]:bytes:_default' \
    '-m+[header match patterns]:pat:_default' \
    '-M+[max articles per group]:N:_default' \
    '-n[no-op, fake it]' \
    '-N+[NNTP connection timeout]:secs:_default' \
    '-O[optimized: STAT before download]' \
    '-p+[downstream port]:port:_default' \
    '-P+[hop limit +N or -N]:hops:_default' \
    '-q[quiet]' \
    '-Q+[quietness level]:level:_default' \
    '-r+[write rnews file instead of feed]:file:_files' \
    '-R[be a reader (MODE READER + POST)]' \
    '-s+[downstream host[:port][_tlsmode]]:host:_hosts' \
    '-S+[max run time seconds]:secs:_default' \
    '-t+[connection retries]:N:_default' \
    '-T+[retry pause seconds]:secs:_default' \
    '-w+[highwater mark]:N:_default' \
    '-x[insert Xref if missing]' \
    '-z+[sleep seconds between articles]:secs:_default' \
    '-Z+[sleep seconds between groups]:secs:_default' \
    '*:upstream host:_hosts' \
    && ret=0

return ret
