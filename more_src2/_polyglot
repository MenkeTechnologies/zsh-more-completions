#compdef polyglot poly
# Documentation: https://github.com/vmchale/polyglot
# Reference accessed: 2026-05-20
# Verified: upstream README + project page. Detailed flag table is
# not published outside `man poly`; conservative stub limited to
# documented invocation pattern (positional directory). Removed from
# prior file: fabricated --exclude/--parallel/--table/--sort flags
# that are not documented upstream.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:directory:_directories'
