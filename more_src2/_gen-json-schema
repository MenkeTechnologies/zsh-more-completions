#compdef gen-json-schema
# _gen-json-schema — generate JSON Schema from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/jsonschemagen.py (click).

_gen-json-schema() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.json"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(json)'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '--useuris[use URI references for terms]'
        '--metauris[use meta URI references]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into generated output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '--inline[inline enum / type definitions instead of $ref]'
        '(-t --top-class)'{-t+,--top-class=}'[top-level class to emit]:class:'
        '--not-closed[allow additional properties (default)]'
        '--closed[disallow additional properties]'
        '--include-range-class-descendants[include all subclasses of range targets]'
        '--no-range-class-descendants[only emit the named range class]'
        '--indent=[indent level for JSON output]:n:'
        '--title-from=[title source]:source:(name title)'
        '*--include=[only include classes matching this pattern]:pattern:'
        '--materialize-patterns[materialize regex patterns]'
        '--no-materialize-patterns[do not materialize regex patterns]'
        '--preserve-names[keep schema names as-is]'
        '--normalize-names[normalize names to JSON-Schema conventions]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-json-schema "$@"
