#compdef debsigs
# debsigs — sign Debian packages with GPG

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--sign=[sign with specified role]:role:(origin maint archive)' \
  '--default-key=[specify default GPG key ID]:key-id:' \
  '--gpgoptions=[pass additional options to GPG]:options:' \
  '--secret-keyring=[specify GPG secret keyring]:file:_files' \
  '--verify[verify signatures on package]' \
  '--list[list signatures on package]' \
  '--delete=[delete signature of specified role]:role:(origin maint archive)' \
  '-v[verbose output]' \
  '-q[quiet output]' \
  '*:deb file:_files -g "*.deb"' \
  && ret=0

return ret
