#compdef policy-controller-webhook policy-webhook
# _policy-controller-webhook — Sigstore admission webhook for ClusterImagePolicy (sigstore/policy-controller)
# upstream: https://github.com/sigstore/policy-controller
# Flags from cmd/webhook/main.go (flag).

_policy-controller-webhook() {
    _arguments \
        '-webhook-name=[name of the (validating+mutating) webhook configurations]:name:' \
        '-tuf-mirror=[alternate TUF mirror]:url:_urls' \
        '-tuf-root=[alternate TUF root.json]:file:_files' \
        '-disable-tuf[disable TUF support]' \
        '-mutating-webhook-name=[mutating webhook configuration name]:name:' \
        '-validating-webhook-name=[validating webhook configuration name]:name:' \
        '-policy-resync-period=[ClusterImagePolicy resync period]:duration:' \
        '-trustroot-resync-period=[TrustRoot resync period]:duration:' \
        '-secure-port=[HTTPS listen port]:port:'
}

_policy-controller-webhook "$@"
