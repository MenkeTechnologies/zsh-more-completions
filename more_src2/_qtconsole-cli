#compdef qtconsole-cli qtconsole2 jupyter-qtconsole
# _qtconsole-cli — Jupyter Project qtconsole-cli jupyter-qtconsole CLI command-line frontend wrapping the QtConsole rich Qt GUI Jupyter console for IPython providing kernel-launch existing connection profile pylab matplotlib confirm-exit transparent style stylesheet ipywidgets-rendering inline-figure-formats inline-figure-resolution kernel-name (Jupyter Project team, Python); traitlets
# upstream: https://qtconsole.readthedocs.io/

_qtconsole-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--existing=+[file]:file:_files -g "*.json"' \
        '--profile=+[name]:str:' \
        '--kernel=+[name]:str:' \
        '--style=+[name]:str:' \
        '--stylesheet=+[file]:file:_files -g "*.qss *.css"' \
        '--syntax-style=+[name]:str:' \
        '--editor=+[name]:str:' \
        '--confirm-exit[confirm before exit]' \
        '--no-confirm-exit[no confirm exit]' \
        '--transparent[transparent background]' \
        '--no-transparent[no transparent]' \
        '--paging=+[m]:m:(inside hsplit vsplit custom none)' \
        '--banner[show banner]' \
        '--no-banner[no banner]' \
        '--gui-completion=+[m]:m:(plain droplist ncurses)' \
        '--object-info-string-level=+[N]:n:' \
        '--inline-format=+[f]:f:(png svg pdf jpg)' \
        '--debug[debug]' \
        '--log-level=+[l]:l:(DEBUG INFO WARN ERROR CRITICAL)' \
        '--ConsoleWidget.font_family=+[name]:str:' \
        '--ConsoleWidget.font_size=+[N]:n:' \
        '--JupyterWidget.in_prompt=+[text]:str:' \
        '--JupyterWidget.out_prompt=+[text]:str:' \
        '--MainWindow.frame=+[bool]:s:(true false)' \
        '--MultipleInstanceApp.unique=+[bool]:s:(true false)' \
        '--connection-file=+[file]:file:_files -g "*.json"' \
        '-f+[connection file]:file:_files' \
        '--no-prompt[no prompt]' \
        '*::'
}

_qtconsole-cli "$@"
