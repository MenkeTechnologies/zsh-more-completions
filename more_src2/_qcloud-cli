#compdef qcloud-cli
# _qcloud-cli — Tencent QCloud CLI legacy (Tencent Cloud, Python); thin Python CLI wrapper around Tencent Cloud APIs
# upstream: https://github.com/QcloudApi/qcloudcli

_qcloud-cli() {
    local -a sub=(
        'configure:configure profile'
        'cvm:Cloud Virtual Machine'
        'cdb:Cloud Database'
        'redis:Redis'
        'mongodb:MongoDB'
        'cls:logs'
        'cdn:CDN'
        'cmq:Message Queue'
        'cmqlive:Live'
        'cwp:CWP host security'
        'tke:Tencent K8s Engine'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--secretId+[secret id]:str:' \
        '--secretKey+[secret key]:str:' \
        '--region+[region]:region:' \
        '--profile+[profile]:profile:' \
        '--output+[output format]:fmt:(json table text)' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qcloud-cli subcommand' sub ;;
    esac
}

_qcloud-cli "$@"
