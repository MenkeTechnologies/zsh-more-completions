#compdef grib_to_netcdf
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_to_netcdf
# Source: ecmwf/eccodes tools/grib_to_netcdf.cc — convert GRIB to NetCDF (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-I+[keys to ignore (default method,type,stream,refdate,hdate)]:keys:_default' \
    '-S+[split keys (default param,expver)]:keys:_default' \
    '-R+[reference date YYYYMMDD (default 19000101)]:date:_default' \
    '-D+[data type]:type:(NC_BYTE NC_SHORT NC_INT NC_FLOAT NC_DOUBLE)' \
    '-T[do not use time of validity]' \
    '-f[force, do not fail on error]' \
    '-o+[output NetCDF file]:file:_files' \
    '*:grib file:_files' \
    && ret=0

return ret
