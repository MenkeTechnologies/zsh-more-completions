#compdef postscreen
# Documentation: https://www.postfix.org/postscreen.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: postscreen is a Postfix daemon launched via master(8) with
# generic Postfix daemon options; not normally invoked from the shell.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-D[run the daemon under debugger control]' \
  '-o[override main.cf parameter]:name=value:' \
  '-v[increase verbose logging level]' && ret=0

return ret
