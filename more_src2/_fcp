#compdef fcp
# Documentation: https://github.com/Svetlitski/fcp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fcp (Svetlitski/fcp) - fast cp(1) alternative in Rust.
# Upstream fcp deliberately exposes only --help/--version; copy semantics
# mirror cp(1) and arguments are simply source(s) and destination.
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
