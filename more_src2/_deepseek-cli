#compdef deepseek-cli ds
# Documentation: https://github.com/CharlesArea/deepseek-cli
# Reference accessed: 2026-05-23
# Verified: npx deepseek-cli --help.

# Zsh completion for deepseek-cli - DeepSeek API CLI (npm package)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'deepseek-cli command' \
      'ask[ask DeepSeek AI a question]' \
      'a[alias for ask]' \
      'config[configure DeepSeek API settings]' && ret=0
    ;;
  args)
    case $line[1] in
      ask|a)
        _arguments '*:question:' && ret=0
        ;;
      config)
        _arguments '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
