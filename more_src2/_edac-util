#compdef edac-util
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/edac-util.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-s --status)'{-s,--status}'[print drivers loaded]' \
  '(-r --report)'{-r,--report}'+[type of report]:report:(default simple full ue ce)' && ret=0

return ret
