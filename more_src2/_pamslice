#compdef pamslice
# Documentation: man pamslice (Netpbm)
# Source: extract one line of pixel values out of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-row -column)-row=[row number to slice]:rownumber:' \
    '(-row -column)-column=[column number to slice]:columnnumber:' \
    '-plane=[plane number]:planenumber:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
