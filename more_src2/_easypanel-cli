#compdef easypanel-cli
# _easypanel-cli — Easypanel modern server control panel CLI alias (easypanel team, TypeScript); custom argparse
# upstream: https://easypanel.io

_easypanel-cli() {
    local -a sub=(
        'install:install easypanel'
        'update:update easypanel'
        'uninstall:uninstall easypanel'
        'login:login to instance'
        'logout:logout'
        'reset-password:reset admin password'
        'config:show:show config'
        'config:set:set config option'
        'projects:list:list projects'
        'projects:create:create project'
        'projects:delete:delete project'
        'projects:rename:rename project'
        'services:list:list services'
        'services:create:create service'
        'services:get:get service'
        'services:delete:delete service'
        'services:deploy:deploy service'
        'services:restart:restart service'
        'services:stop:stop service'
        'services:start:start service'
        'services:logs:show logs'
        'services:env:get:get env vars'
        'services:env:set:set env vars'
        'services:domains:list:list domains'
        'services:domains:add:add domain'
        'services:domains:remove:remove domain'
        'services:mounts:list:list mounts'
        'services:mounts:add:add mount'
        'services:mounts:remove:remove mount'
        'templates:list:list templates'
        'templates:install:install template'
        'monitor:status:show monitor status'
        'monitor:logs:show logs'
        'backups:list:list backups'
        'backups:create:create backup'
        'backups:restore:restore backup'
        'backups:delete:delete backup'
        'users:list:list users'
        'users:create:create user'
        'users:delete:delete user'
        'docker:cleanup:cleanup docker'
        'docker:prune:prune docker'
        'docker:stats:show docker stats'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[easypanel url]:url:_urls' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'easypanel subcommand' sub ;;
        args)
            case $words[1] in
                services:create) _arguments \
                    '--project-name=+[project]:str:' \
                    '--service-name=+[service name]:str:' \
                    '--type=+[type]:t:(app postgres mysql mariadb mongo redis)' \
                    '--source-type=+[source]:s:(image git github gitlab)' \
                    '--image=+[image]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_easypanel-cli "$@"
