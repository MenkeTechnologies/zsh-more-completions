#compdef debc
# Documentation: https://manpages.debian.org/debc
# Source: debian/devscripts scripts/debc.1 — display contents of generated .deb packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '-a+[Debian architecture]:arch:_default' \
    '-t+[GNU system type]:type:_default' \
    '--debs-dir=-[directory with .deb files]:dir:_files -/' \
    '--check-dirname-level=-[directory check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory regex]:regex:_default' \
    '--list-changes[list .changes file and exit]' \
    '--list-debs[list .deb files and exit]' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    '1::changes file:_files -g "*.changes"' \
    '*:package:_default' \
    && ret=0

return ret
