#compdef kbcli
# _kbcli — ApeCloud KubeBlocks kbcli CLI command-line frontend wrapping the KubeBlocks Kubernetes-native database operator providing cluster create connect describe restart backup restore failover switchover horizontal-scale vertical-scale volume-expansion stop start restart for PostgreSQL MySQL Redis MongoDB MariaDB Kafka Cassandra (ApeCloud team, Go); cobra
# upstream: https://kubeblocks.io/

_kbcli() {
    local -a sub=(
        'install:install KubeBlocks'
        'uninstall:uninstall KubeBlocks'
        'upgrade:upgrade KubeBlocks'
        'cluster:cluster management'
        'backup:backup operations'
        'backup-policy:backup policy operations'
        'restore:restore operations'
        'ops:operations request'
        'class:class operations'
        'addon:addon management'
        'kubeblocks:KubeBlocks management'
        'context:context management'
        'org:organization management'
        'preflight:preflight checks'
        'fault:fault injection'
        'migration:migration operations'
        'cluster-version:ClusterVersion operations'
        'cluster-definition:ClusterDefinition operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-A[all namespaces]' \
        '-o+[format]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kbcli subcommand' sub ;;
        args)
            case $words[1] in
                cluster|backup|restore|ops|class|addon|migration) _arguments '1:op:(list get create update delete describe connect restart start stop scale-out scale-in vertical-scale horizontal-scale switchover failover)' '*:name:' ;;
            esac
            ;;
    esac
}

_kbcli "$@"
