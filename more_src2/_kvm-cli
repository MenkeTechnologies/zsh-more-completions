#compdef kvm-cli kvm-ok kvm-spice
# _kvm-cli — Linux KVM CLI helpers (kvm-ok / kvm-spice) (Red Hat / KVM team, Bash/C); custom argparse
# upstream: https://www.linux-kvm.org/

_kvm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--check[check KVM support]' \
        '-c[check KVM support]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '*:arg:'
}

_kvm-cli "$@"
