#compdef jetzig
# ============================================================================
#  _jetzig — Jetzig: Rails-style web framework written in Zig (David Bond)
#
#  Source-direct extraction from
#    https://github.com/jetzig-framework/jetzig/blob/main/src/jetzig/Environment.zig
#    https://github.com/MasterQ32/zig-args (the zig-args library by
#    Felix "MasterQ32" Queißner)
#
#  Maintained by David Bond and the Jetzig contributors (jetzig-
#  framework/jetzig).  1468 GH stars.  Jetzig is a RAILS-STYLE web
#  framework for Zig — provides routing, controllers, views, ORM,
#  database migrations, mailer, background jobs, and CLI scaffolding
#  in a Zig-native package.  Sister tools: Zap (alternative Zig web
#  framework), httpz (low-level Zig HTTP server, IN CORPUS), Rocket
#  (Rust web framework), Phoenix (Elixir, in corpus), Rails (Ruby).
#  The `jetzig` binary serves dev mode + production deployment via
#  Jetzig-built apps; the `jetzig` standalone CLI also scaffolds new
#  apps via `jetzig init`.
#
#  CLI library taxonomy update: 3rd Zig CLI library — Felix Queißner's
#  **zig-args** (MasterQ32/zig-args; also mirrored as ikskuh/zig-args).
#  Zig ecosystem now has 3 documented CLI libraries (R288 stdlib +
#  R355 Hejsil/zig-clap + R390 MasterQ32/zig-args).
#
#  zig-args (MasterQ32/zig-args) is Felix Queißner's STRUCT-BASED
#  declarative CLI argument parser for Zig — uses Zig's compile-time
#  type introspection to derive the parser shape from an Options
#  struct.  Distinct from R288 Zig stdlib (manual `process.args()`
#  iteration) and R355 Hejsil/zig-clap (comptime multi-line string
#  DSL) by being struct-field-driven with `shorthands` + `meta`
#  comptime constants for metadata.  Used by Jetzig web framework
#  (1468 stars), zigself (Self language implementation in Zig, 218
#  stars), TinyVG SDK tools (text/render conversion utilities, 301
#  stars), Rheia blockchain (Lithdew, 291 stars), Zig-Showdown
#  game competition tools, Ashet OS wiki tool, marijnfs/zig-possle,
#  ikskuh/proxy-head, ikskuh/turtlefont, deshader (Vulkan/OpenGL
#  shader debugger), zion package manager, last-arg/feedgaze RSS
#  reader, and many Zig CLI tools that want struct-driven parsing
#  without the comptime-string complexity of zig-clap.
#
#  zig-args API:
#    const std = @import("std");
#    const args = @import("args");
#
#    const Options = struct {
#      help: bool = false,
#      verbose: bool = false,
#      output: []const u8 = "out.txt",
#      port: u16 = 8080,
#      level: ?LogLevel = null,
#      format: OutputFormat = .text,
#      @"env-file": []const u8 = ".env",
#      @"log-level": ?u8 = null,
#
#      // Map short names to long names
#      pub const shorthands = .{
#        .h = "help",
#        .v = "verbose",
#        .o = "output",
#        .p = "port",
#      };
#
#      // Help wrap width
#      pub const wrap_len = 80;
#
#      // Per-option metadata
#      pub const meta = .{
#        .option_docs = .{
#          .help    = "Show help",
#          .verbose = "Enable verbose output",
#          .output  = "Output file path (default: out.txt)",
#          .port    = "Listen port (default: 8080)",
#          .level   = "Log level: TRACE | DEBUG | INFO | WARN | ERROR",
#          .format  = "Output format: text | json | xml",
#        },
#      };
#    };
#
#    const LogLevel = enum { TRACE, DEBUG, INFO, WARN, ERROR };
#    const OutputFormat = enum { text, json, xml };
#
#    pub fn main() !void {
#      var gpa = std.heap.GeneralPurposeAllocator(.{}){};
#      const allocator = gpa.allocator();
#
#      const opts = try args.parseForCurrentProcess(Options, allocator,
#                                                    .print);
#      defer opts.deinit();
#
#      if (opts.options.help) {
#        const writer = std.io.getStdErr().writer();
#        try args.printHelp(Options, opts.executable_name orelse
#                            "mytool", writer);
#        return;
#      }
#
#      // Use opts.options.output, opts.options.port, etc.
#      // Positional args: opts.positionals (Zig slice)
#    }
#
#  zig-args distinctive features:
#    - ZIG COMPILE-TIME TYPE INTROSPECTION — `parseForCurrentProcess`
#      uses Zig's `@typeInfo(OptionsStruct)` to derive the parser
#      shape from the struct's fields at COMPILE TIME (zero runtime
#      overhead, type-safe)
#    - OPTIONS STRUCT — each field is a flag; field name → flag name
#      (camelCase or hyphenated via `@"long-name"` Zig identifier
#      escape syntax)
#    - DEFAULT VALUES from Zig struct field defaults (e.g. `port:
#      u16 = 8080`)
#    - ZIG TYPE COERCION — `u16` field gets coerced from string to
#      integer; `?LogLevel` field gets coerced to enum value; `[]const
#      u8` gets the raw string; `bool` becomes presence/absence
#    - HYPHENATED LONG NAMES via Zig identifier escape: `@"log-level":
#      ?u8 = null` becomes `--log-level VALUE` (Zig allows arbitrary
#      identifiers via `@"…"` syntax)
#    - ENUM CHOICES via Zig enum types — `?LogLevel = null` allows
#      `--log-level=TRACE`/`DEBUG`/`INFO`/etc.; zig-args derives the
#      valid values from the enum at comptime
#    - OPTIONAL TYPES — `?T` field becomes "optional value not present
#      by default" semantics (null = not set, otherwise set to value)
#    - `pub const shorthands = .{ .h = "help", .b = "bind" }` —
#      COMPTIME CONSTANT mapping single-char short names to long
#      names; Zig's anonymous struct syntax with field-name as the
#      shorthand letter
#    - `pub const wrap_len = 80` — COMPTIME CONSTANT for help text
#      wrap width
#    - `pub const meta = .{ .option_docs = .{ .opt = "help text" } }`
#      — COMPTIME CONSTANT nested struct providing per-option help
#      text (`meta.option_docs.OPT_NAME` = help string for OPT_NAME)
#    - `args.parseForCurrentProcess(Options, allocator, .print)` —
#      MAIN PARSE FUNCTION returning a tagged-union result; `.print`
#      mode prints errors to stderr, `.silent` returns error tuple
#    - `args.parse(Options, raw_args_slice, allocator, .print)` —
#      ALTERNATIVE entry point taking explicit args slice (for testing)
#    - `opts.options.OPT_NAME` — TYPED ACCESS to parsed values via
#      the struct's field
#    - `opts.executable_name` — CAPTURED program name from argv[0]
#    - `opts.positionals` — Zig slice of POSITIONAL args
#    - `opts.deinit()` — explicit deallocation (Zig manual memory
#      management)
#    - `args.printHelp(Options, "name", writer)` — MANUAL HELP
#      generation from Options struct + program name + writer
#    - PROCESS EXIT model — caller controls via `std.process.exit(N)`
#      or returning from main
#    - NO automatic --help (caller checks `opts.options.help` and
#      calls `args.printHelp`)
#    - NO automatic --version (caller writes manually)
#    - NO subcommand support natively (caller hand-rolls)
#    - REQUIRES Zig allocator (manual memory management)
#  Distinct from R288 Zig stdlib (manual `process.args()` iteration
#  with hand-rolled parsing — no library at all), R355 Hejsil/zig-clap
#  (COMPTIME MULTI-LINE STRING DSL — `params: []const clap.Param(u8)`
#  with `clap.parseParam(...)` parsing the string at COMPTIME — string
#  vs zig-args's struct), R275 Rust clap-derive (Rust struct + macros
#  — CLOSEST concept analog but Rust language with proc-macros vs
#  Zig's comptime introspection), R338 Odin core:flags (Odin struct
#  tags + RTTI), R363 D andrey-zherikov/argparse (D UDAs + SumType
#  dispatch — also struct-driven but D language).  zig-args's
#  approach: ZIG COMPILE-TIME TYPE INTROSPECTION via `@typeInfo` +
#  OPTIONS STRUCT with field defaults driving parser + ZIG TYPE
#  COERCION via field types (u16/bool/enum/optional/slice) +
#  HYPHENATED NAMES via Zig identifier escape `@"name"` + `shorthands`
#  / `wrap_len` / `meta.option_docs` COMPTIME CONSTANTS for metadata
#  + `args.parseForCurrentProcess(Options, allocator, .print)` MAIN
#  PARSE + `opts.options.OPT` / `opts.executable_name` / `opts.
#  positionals` typed RESULT + MANUAL HELP via `args.printHelp` +
#  PROCESS EXIT controlled by caller + NO automatic --help/--version/
#  subcommands — corpus's **first documented Zig-comptime-struct-
#  introspection CLI library**.  Brings cross-language CLI library
#  taxonomy variant count to 129; Zig ecosystem now has 3 documented
#  CLI libraries.
#
#  Surface (verbatim from `src/jetzig/Environment.zig` Options struct):
#
#  Options:
#    -h, --help                     Show help and exit
#    -b, --bind ADDR                IP address/hostname to bind to
#                                   (default: 127.0.0.1)
#    -p, --port PORT                Port to listen on (default: 8080)
#        --log FILE                 Path to log file (`-` for stdout;
#                                   default: `-`)
#        --log-error FILE           Optional separate error log file
#                                   (`-` for stderr; default: same as
#                                   --log location)
#        --log-level LEVEL          Min log level: TRACE | DEBUG |
#                                   INFO | WARN | ERROR | FATAL
#                                   (default: DEBUG in dev, INFO in
#                                   production)
#        --log-format FORMAT        Log format: development | production
#                                   | json | null (default: development)
#        --env-file FILE            Path to .env file (default: .env)
#    -d, --detach                   Run server in background (requires
#                                   --log; default: false)
#
#  Auto-injected by zig-args (caller must wire up):
#    -h, --help                     (declared in Options struct;
#                                   caller checks `opts.options.help`)
#
#  Build & development:
#    jetzig init [PROJECT]          Scaffold a new Jetzig app
#    jetzig server                  Start development server (default)
#    jetzig database PROVIDER       Manage database (PostgreSQL/SQLite)
#    jetzig generate CONTROLLER     Generate scaffolding
#    jetzig routes                  Print routes table
#    jetzig auth GENERATE           Generate auth scaffolding
#    jetzig test                    Run tests
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also zig-args users):
#    - zigself (sin-ack/zigself 218 stars — Self language in Zig,
#      uses zig-args via `zig_args.parseForCurrentProcess`; FUTURE
#      candidate for distinct Self-language scope)
#    - tinyvg sdk text/render tools (TinyVG/sdk 301 stars — vector
#      graphics SDK tools, uses zig-args; specialized graphics use
#      case)
#    - dim (zig-osdev/disk-image-step 17 stars — disk image builder,
#      smaller community)
#    - rheia (lithdew/rheia 291 stars — Zig blockchain, uses zig-args
#      via `args.parseForCurrentProcess(Arguments, gpa, .print)`;
#      FUTURE candidate for blockchain scope)
#    - proxy-head (ikskuh/proxy-head 8 stars — pixel framebuffer
#      proxy by zig-args author himself, dogfood example)
#    - turtlefont / Zig-Showdown / Ashet-OS / bottom-zig / mzterwm /
#      naoki9911/zig-vmm / GhostKellz/zion / last-arg/feedgaze /
#      OSDVF/deshader / softprops/atlas-cli-zig-plugin (smaller
#      community Zig tools)
# ============================================================================

_jetzig() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '(-b --bind)'{-b,--bind}'=[IP/hostname to bind (default 127.0.0.1)]:address' \
    '(-p --port)'{-p,--port}'=[port to listen on (default 8080)]:port' \
    '--log=[path to log file (- for stdout)]:file:_files' \
    '--log-error=[path to error log file (- for stderr)]:file:_files' \
    '--log-level=[minimum log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
    '--log-format=[log format]:format:(development production json null)' \
    '--env-file=[path to .env file (default .env)]:file:_files' \
    '(-d --detach)'{-d,--detach}'[run server in background (requires --log)]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs=(
        'init:scaffold a new Jetzig app'
        'server:start development server'
        'database:manage database (PostgreSQL/SQLite)'
        'generate:generate scaffolding'
        'routes:print routes table'
        'auth:auth scaffolding'
        'test:run tests'
      )
      _describe -t commands 'jetzig subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        init|generate|database)
          _files
          ;;
      esac
      ;;
  esac
}

_jetzig "$@"
