#compdef qradar-cli qradar qradarctl
# _qradar-cli — IBM QRadar qradar-cli CLI command-line frontend wrapping the IBM QRadar SIEM Security Information and Event Management on-premises and SaaS XDR threat detection investigation response platform CLI providing login logout whoami offense rule reference-set log-source domain custom-rule custom-property building-block search ariel-query saved-search asset vulnerability network-hierarchy backup-recovery deployment configuration tenant license user role tuning (IBM QRadar team, Python); custom argparse
# upstream: https://www.ibm.com/qradar

_qradar-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'offense:offense operations'
        'rule:rule operations'
        'reference-set:reference set operations'
        'reference-map:reference map operations'
        'log-source:log source operations'
        'domain:domain operations'
        'custom-rule:custom rule operations'
        'custom-property:custom property operations'
        'building-block:building block operations'
        'search:Ariel search operations'
        'saved-search:saved search operations'
        'ariel-query:Ariel query'
        'asset:asset operations'
        'vulnerability:vulnerability operations'
        'network-hierarchy:network hierarchy operations'
        'backup:backup/recovery operations'
        'tenant:tenant operations'
        'license:license operations'
        'user:user operations'
        'role:role operations'
        'analytics:analytics operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--sec-token=+[token]:str:' \
        '--api-url=+[url]:str:' \
        '--version-api=+[v]:str:' \
        '-c+[config file]:file:_files -g "*.ini *.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.ini *.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table xml csv)' \
        '--output=+[format]:f:(json yaml table xml csv)' \
        '--insecure[skip TLS verify]' \
        '--cert-bundle=+[file]:file:_files -g "*.pem *.crt"' \
        '--filter=+[expr]:str:' \
        '--fields=+[fields]:str:' \
        '--range=+[r]:str:' \
        '--sort=+[col]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qradar subcommand' sub ;;
        args)
            case $words[1] in
                offense|rule|reference-set|reference-map|log-source|domain|custom-rule|custom-property|building-block|saved-search|asset|vulnerability|tenant|user|role) _arguments '1:op:(list get create update delete close hide protect assign add-note bulk-load purge)' '*:id:' ;;
                search|ariel-query) _arguments '*:aql:' ;;
            esac
            ;;
    esac
}

_qradar-cli "$@"
