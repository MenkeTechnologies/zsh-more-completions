#compdef grdmath
# Documentation: https://docs.generic-mapping-tools.org/latest/grdmath.html
# Source: GenericMappingTools/gmt classic-mode grdmath — RPN calculator with 200+ operators (ADD/SUB/SIN/MEAN/SDIST/...).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[coastline area/level filter (LDISTG only)]:filter:_default' \
    '-C+[retain/replace default CPT]:cpt:_default' \
    '-D+[LDISTG resolution]:res:(full high intermediate low crude)' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-M[derivative units = z_units/m (flat-earth)]' \
    '-N[no strict domain matching across grids]' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[reduce stack to single grid via reducer]:reducer:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata replacement]:value:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-r[pixel registration (default gridline)]' \
    '-x+[CPU cores limit]:n:_default' \
    '*:operator or operand:_default' \
    && ret=0

return ret
