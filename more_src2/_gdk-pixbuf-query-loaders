#compdef gdk-pixbuf-query-loaders
# _gdk-pixbuf-query-loaders — GTK gdk-pixbuf-query-loaders (rebuild the gdk-pixbuf loaders.cache listing every installed GdkPixbuf module + its MIME types/extensions; --update-cache writes the cache file in place, otherwise output goes to stdout)
# upstream: https://gitlab.gnome.org/GNOME/gdk-pixbuf (gdk-pixbuf/queryloaders.c)
# Flags from gdk-pixbuf gdk-pixbuf/queryloaders.c on tip.

_gdk-pixbuf-query-loaders() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--update-cache[update loaders cache in place]' \
        '*:loader module:_files'
}

_gdk-pixbuf-query-loaders "$@"
