# WHAT IS koanf AND WHY IS IT THE 66TH GO CLI LIBRARY?
#
# koanf (https://github.com/knadh/koanf, 4,051+ stars) is **Kailash
# Nadh's "Simple, extremely lightweight, extensible, configuration
# management library for Go"** — explicitly positioned in its README
# as the modern "Alternative to viper".  Where viper (R630) is a
# global-singleton monolith with comprehensive features built-in,
# koanf is a modular per-instance library where every Provider
# (source) and Parser (format) is a separate Go module that you
# explicitly compose.
#
# koanf's distinguishing characteristics:
#
#   1. NO GLOBAL SINGLETON — koanf instances are self-contained via
#      `koanf.New(delim)`:
#
#          import (
#              "github.com/knadh/koanf/v2"
#              "github.com/knadh/koanf/parsers/toml"
#              "github.com/knadh/koanf/parsers/yaml"
#              "github.com/knadh/koanf/providers/env"
#              "github.com/knadh/koanf/providers/file"
#              "github.com/knadh/koanf/providers/posflag"
#          )
#
#          var ko = koanf.New(".")
#
#          // Load TOML files:
#          ko.Load(file.Provider("config.toml"), toml.Parser())
#
#          // Override with env vars:
#          ko.Load(env.Provider("APP_", ".", func(s string) string {
#              return strings.ReplaceAll(strings.ToLower(
#                  strings.TrimPrefix(s, "APP_")), "_", ".")
#          }), nil)
#
#          // Override with pflag CLI args:
#          f := pflag.NewFlagSet("", pflag.ContinueOnError)
#          f.String("db.host", "localhost", "db host")
#          ko.Load(posflag.Provider(f, ".", ko), nil)
#
#          // Access values:
#          host := ko.String("db.host")
#          port := ko.Int("db.port")
#
#      Compare:
#         * Rust config-rs (R629): builder pattern (per-instance)
#         * Rust figment (R633): per-instance Figment via merge()
#         * Go viper (R630): GLOBAL singleton (or per-instance via
#                              viper.New)
#         * Node cosmiconfig (R631): per-instance explorer
#         * koanf: PER-INSTANCE via koanf.New, no global state
#      FIRST documented Go Axis 13 library with no-global-singleton
#      design as a primary feature.
#
#   2. MODULAR PROVIDER/PARSER SEPARATION — each Provider and Parser
#      is a separate Go module under knadh/koanf:
#
#      Providers (where config comes FROM):
#         * koanf/providers/file       — file system
#         * koanf/providers/env        — environment vars
#         * koanf/providers/posflag    — spf13/pflag bridge
#         * koanf/providers/basicflag  — stdlib flag bridge
#         * koanf/providers/structs    — Go struct as defaults
#         * koanf/providers/rawbytes   — bytes in memory
#         * koanf/providers/s3         — AWS S3 objects
#         * koanf/providers/consul     — HashiCorp Consul KV
#         * koanf/providers/vault      — HashiCorp Vault
#         * koanf/providers/fs         — Go fs.FS interface
#         * koanf/providers/http       — HTTP URL fetching
#         * koanf/providers/etcd       — etcd KV store
#         * koanf/providers/cliflag    — urfave/cli bridge
#
#      Parsers (how to parse the bytes):
#         * koanf/parsers/json
#         * koanf/parsers/toml
#         * koanf/parsers/yaml
#         * koanf/parsers/hcl
#         * koanf/parsers/hjson
#         * koanf/parsers/kubejson
#         * koanf/parsers/dotenv
#         * koanf/parsers/javaprops
#         * koanf/parsers/nestedtext
#
#      Each module is independently versioned + only the chosen
#      ones get pulled into your binary.  Compare:
#         * Rust config-rs (R629): 7 file formats via feature flags
#         * Rust figment (R633): 7+ providers as features
#         * Go viper (R630): MONOLITHIC — all formats compiled in
#         * koanf: MODULAR — only pulled-in modules add to binary
#      FIRST documented Go Axis 13 library with modular Provider+
#      Parser as independently-versioned Go modules.
#
#   3. EXPLICIT MERGE SEMANTICS — koanf's Load() explicitly chains;
#      each Load call merges the result into the koanf instance:
#
#          ko := koanf.New(".")
#          ko.Load(file.Provider("base.toml"), toml.Parser())
#          ko.Load(file.Provider("env.toml"), toml.Parser())
#          ko.Load(env.Provider("APP_", "."), nil)
#          ko.Load(posflag.Provider(f, ".", ko), nil)
#
#          // ko.Cut("database") returns a sub-koanf for nested keys:
#          db := ko.Cut("database")
#          dbURL := db.String("url")
#
#      Compare:
#         * Rust config-rs (R629): add_source(...) chain (similar)
#         * Rust figment (R633): merge(provider) chain (similar)
#         * Go viper (R630): viper.SetConfigName + AddConfigPath
#                              + ReadInConfig (different style)
#         * koanf: EXPLICIT Load(provider, parser) calls
#      FIRST documented Go Axis 13 library with explicit Load()-
#      chained provider+parser merge as primary API.
#
#   4. TYPED GETTERS — koanf provides explicitly-typed getters
#      across many Go primitive types:
#
#          ko.String("key")          // string
#          ko.Int("key")             // int
#          ko.Int64("key")           // int64
#          ko.Float64("key")         // float64
#          ko.Bool("key")            // bool
#          ko.Duration("key")        // time.Duration
#          ko.Bytes("key")           // []byte
#          ko.Time("key", layout)    // time.Time with layout
#          ko.Strings("key")         // []string
#          ko.Ints("key")            // []int
#          ko.Int64s("key")          // []int64
#          ko.Float64s("key")        // []float64
#          ko.Bools("key")           // []bool
#          ko.StringMap("key")       // map[string]string
#          ko.StringsMap("key")      // map[string][]string
#          ko.Slices("key")          // []*koanf.Koanf
#          ko.Unmarshal("key", &v)   // serde-style deserialize
#          ko.UnmarshalWithConf(...) // with custom config
#
#      Compare:
#         * Rust config-rs (R629): try_deserialize<T>() via serde
#         * Rust figment (R633): extract::<T>() via serde
#         * Go viper (R630): viper.GetString / GetInt / etc.
#                              (similar)
#         * koanf: typed-getter MAP+SLICE variants (StringsMap,
#                   Int64s, etc.)
#      FIRST documented Go Axis 13 library with this breadth of
#      typed getters including map+slice variants.
#
#   5. KAILASH NADH / LISTMONK ECOSYSTEM PROVENANCE — koanf is by
#      Kailash Nadh (knadh on GitHub), CTO of Zerodha (India's
#      largest stock broker) + prolific Go open-source author.
#      Kailash's ecosystem includes:
#         * listmonk — self-hosted newsletter manager (17k+ stars)
#         * dns.toys (THIS — same-author dogfooding)
#         * niltalk — anonymous chat server
#         * sql-jobber — SQL job queue
#         * stuffbin — embedded static assets
#         * goyesql — Go YAML SQL templates
#         * 30+ Go projects
#      koanf is the "production infrastructure" Kailash extracts +
#      uses across his projects.  Downstream users:
#         * listmonk (17k stars — Kailash's own)
#         * Hashicorp/copywrite (R607 — uses BOTH go-hclog AND
#                                  koanf in the same project,
#                                  cross-axis library composition)
#         * dns.toys (THIS — same-author 2.8k stars)
#         * mr-karan/logchef (ClickHouse analytics, 756 stars)
#         * qonto/prometheus-rds-exporter
#         * blessnetwork/b7s (BLESS Network daemon)
#         * ryanolee/go-pot (honeypot)
#         * stephenafamo/bob (SQL query builder, 1.7k stars)
#         * 1500+ Go applications
#      FIRST documented Go Axis 13 library with this specific
#      Kailash-Nadh / Zerodha / listmonk-ecosystem provenance.
#
# koanf's relationship to viper (R630) and other Axis 13 libraries:
#
#   * Unlike viper (R630, Go) — viper is global-singleton monolith
#                                 with built-in HCL + cobra; koanf
#                                 is per-instance with explicit
#                                 Provider+Parser composition
#   * Closest cross-language analogs:
#         * Rust figment (R633) — DIRECT PARALLEL: both libraries
#                                   take "Provider trait" approach
#                                   vs builder pattern; both ship
#                                   profile-aware extraction
#         * Rust config-rs (R629) — different (builder pattern)
#         * Node cosmiconfig (R631) — file-discovery only
#     koanf is the SECOND documented Go Axis 13 library providing
#     no-global-singleton + modular Provider+Parser architecture
#     + Kailash-Nadh / listmonk-ecosystem provenance.
#
