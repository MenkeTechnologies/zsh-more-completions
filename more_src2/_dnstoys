local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '*--config=[path to TOML config file (repeatable; default config.toml)]:config file:_files -g "*.{toml,conf}"' \
    '(- *)--version[show build version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
