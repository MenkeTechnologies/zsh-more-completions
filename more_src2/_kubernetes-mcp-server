#compdef kubernetes-mcp-server
# Documentation: https://github.com/manusa/kubernetes-mcp-server
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help for kubernetes-mcp-server]' \
  '--version[print version information]' \
  '--port=[start the MCP server in HTTP/SSE mode on the specified port]:port' \
  '--log-level=[log verbosity level 0-9]:level' \
  '--config=[path to the main TOML configuration file]:file:_files' \
  '--config-dir=[path to a drop-in configuration directory]:directory:_files -/' \
  '--kubeconfig=[path to the Kubernetes configuration file]:file:_files' \
  '--list-output=[output format for resource lists]:format:(yaml table)' \
  '--read-only[run in read-only mode]' \
  '--disable-destructive[disable destructive operations]' \
  '--stateless[run in stateless mode]' \
  '--toolsets=[comma-separated list of toolsets to enable]:toolsets' \
  '--disable-multi-cluster[restrict to current context only]' \
  '--cluster-provider=[cluster provider strategy]:provider:(kubeconfig in-cluster kcp disabled)' \
  '*::args:_default' && return 0
