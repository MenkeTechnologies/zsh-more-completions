#compdef pamfile pnmfile
# Documentation: man pamfile (Netpbm)
# Source: describe a Netpbm image file (format, dimensions, depth).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-allimages[describe every image in a multi-image file]' \
    '-comments[print comments]' \
    '-count[print only image count]' \
    '-machine[machine-readable output]' \
    '-size[print only size]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
