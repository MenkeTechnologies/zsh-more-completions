#compdef fieldalignment
# _fieldalignment — Go x/tools field-alignment analyzer (Cuong Manh Le, Go team); detect and rewrite suboptimal struct layouts
# upstream: https://pkg.go.dev/golang.org/x/tools/go/analysis/passes/fieldalignment

_fieldalignment() {
    _arguments \
        '-fix[apply rewrites]' \
        '-V[show version]' \
        '-c+[context lines]:n:' \
        '-cpuprofile+[CPU profile]:file:_files' \
        '-debug+[debug flags]:flags:' \
        '-fix[rewrite]' \
        '-flags[print analyzer flags]' \
        '-json[json output]' \
        '-memprofile+[memory profile]:file:_files' \
        '-source[show source]' \
        '-tags+[build tags]:tags:' \
        '-trace+[trace file]:file:_files' \
        '-v[verbose]' \
        '*:packages:'
}

_fieldalignment "$@"
