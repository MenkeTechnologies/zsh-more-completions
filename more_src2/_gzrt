#compdef gzrecover
# Documentation: https://github.com/arenn/gzrt/blob/master/gzrecover.1
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gzrt package ships the `gzrecover` binary (gzip recovery toolkit).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show usage]' \
  '(- *)-V[show version]' \
  '-v[verbose mode]' \
  '-s[split mode: write each segment to its own file]' \
  '(-p)-o+[output file]:file:_files' \
  '(-o)-p[write recovered data to stdout]' \
  '*:gzip file:_files -g "*.gz"' && ret=0

return ret
