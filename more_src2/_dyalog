#compdef dyalog
# =============================================================================
# dyalog — Dyalog Ltd's "Dyalog APL interpreter" — the
#          commercial Dyalog APL development environment and
#          runtime.  Dyalog APL is the leading modern
#          implementation of Ken Iverson's APL array language
#          (1962), used in finance (Morgan Stanley, JP Morgan,
#          Optiver), actuarial science (insurance pricing),
#          healthcare (medical records), and government
#          (statistics agencies) for high-throughput numerical
#          computation expressed via Iverson's notation of
#          single-character array primitives (rank, reduce,
#          outer product, etc.).
#          Distinguishing from GNU APL, J (Iverson's later
#          ASCII APL), K/Q (Arthur Whitney), and other array
#          languages by:
#            - SINGLE-CHARACTER PRIMITIVES — APL operators are
#              single Unicode glyphs (⍳ ⍴ ⍒ ⍴ ⌽ ⍉ ⊃ ⊂ ⍷ ⍕ ⎕
#              etc.); Dyalog uses the APL387 Unicode font.
#              Iverson designed APL as a notation BEFORE he
#              had a computer to run it on; Dyalog faithfully
#              reproduces the symbolic notation.
#            - RANK + REDUCE + OUTER PRODUCT — APL's central
#              power is array-rank polymorphism:
#                  sum ← +/⍳100        ⍝ sum of 1 to 100 = 5050
#                  table ← ⍳5 ∘.× ⍳5   ⍝ 5x5 multiplication table
#                  mean ← {(+/⍵) ÷ ≢⍵} ⍝ mean of vector
#                  primes ← {(2=+/[1]0=⍵∘.|⍵)/⍵} ⍳ 100
#            - DFNs (Direct Functions) — modern Dyalog syntax
#              for anonymous + named function expressions:
#                  Mean ← {(+/⍵) ÷ ≢⍵}
#                  Mean ⍳10  ⍝ 5.5
#            - TRADFNs (Traditional Functions) — classic APL
#              function definition syntax with header line:
#                  ∇ r ← x Plus y
#                    r ← x + y
#                  ∇
#            - NAMESPACES + CLASSES + INHERITANCE — modern
#              Dyalog supports OO; `:Class` and `:EndClass`
#              define classes with constructors, properties,
#              methods
#            - .NET INTEROP via SAOL (System APL Object Linkage)
#              — Dyalog programs can use .NET Framework /
#              .NET Core / .NET 5+ classes directly
#            - PYTHON INTEROP via pynapl — bidirectional
#              Python ↔ Dyalog data exchange
#            - JUPYTER KERNEL — Dyalog/dyalog-jupyter-kernel
#              for notebook-based exploration
#            - WORKSPACE PERSISTENCE — .dws files store
#              complete program state (variables, functions,
#              classes, namespaces) for resume across sessions
#            - 4 PARALLEL APL MODES — .NET TLS (Tasks), futures,
#              spawning, isolation containers
#            - SQAPL — SQL database access via ODBC
#            - HTTPCOMMAND — `]HttpCommand` user command for
#              HTTP requests
#            - JARVIS — REST + JSON web service framework
#            - MISERVER — full APL-based web application server
#            - LINK component — text-file storage for source
#              (modern alternative to .dws workspace storage)
#            - WIDE Unicode SUPPORT — APL387 font + UTF-8
#              source files
#            - RIDE — cross-platform Electron-based IDE
#              (separate Dyalog/ride repo)
#            - DOCKER IMAGE — official `dyalog/dyalog`
#              docker image for containerized deployments
#          Used by: quantitative finance (option-pricing,
#          portfolio analytics), actuarial (insurance pricing
#          models), healthcare (medical records, claims),
#          government (statistical agencies), and APL
#          competitions (Code Golf, APL Forge).
#
# Author:  Dyalog Ltd (Bramley, UK) — founded 1983 by John
#          Scholes + Pete Donnelly + others.  Dyalog APL is
#          the commercial successor to APL2 from IBM and
#          Sharp APL.  Current version v19.0 (2026).
#          License: Commercial (free non-commercial use for
#          evaluation + personal projects; paid for commercial
#          deployment).
# Source:  https://www.dyalog.com (commercial product;
#          interpreter source is proprietary)
#          https://github.com/Dyalog (companion projects:
#          ride IDE, dyalog-jupyter-kernel, MiServer, Jarvis,
#          MDAPL textbook, pynapl, etc.)
#          https://docs.dyalog.com (online documentation)
# Manpage: dyalog(1) (proprietary; documentation at
#          docs.dyalog.com)
# Language: APL (A Programming Language) — Ken Iverson's
#           1962 mathematical notation.  Dyalog APL is one
#           of several modern APL implementations (others:
#           GNU APL, NARS2000, APLX, IBM APL2, Sharp APL).
#           Distinct from:
#              * J (Iverson's later 1990 ASCII-only APL
#                successor; in our corpus as `jconsole`)
#              * K (Arthur Whitney's 1992 compact APL
#                derivative — predecessor of Q)
#              * Q (KX Systems' database-query language built
#                on K; in our corpus as `q`)
#              * BQN (Marshall Lochbaum's 2020 modern APL with
#                first-class functions and 2-train syntax;
#                in our corpus as `bqn`)
#              * Uiua (Kai Schmidt's 2022 stack-based array
#                language with Unicode glyphs; in our corpus
#                as `uiua`)
#              * APL\360 (the original IBM mainframe
#                implementation)
#              * NARS2000 (Bob Smith's free APL with
#                hypercomplex numbers)
#           Dyalog distinguishes itself by:
#              1. COMMERCIAL MAINTENANCE — paid licensing
#                 funds full-time development team since 1983
#              2. MASSIVE STANDARD LIBRARY — SQAPL, Conga
#                 (TCP/IP), File system, HTTP, JSON, XML,
#                 WebSockets all standard
#              3. .NET + PYTHON INTEROP — first-class FFI to
#                 both ecosystems
#              4. PARALLEL APL — futures, tasks, isolates
#              5. SOURCE LINK — modern .apl text-file storage
#                 replacing .dws binary workspace
#              6. JUPYTER + RIDE — modern dev experience
#              7. DOCKER + AWS — cloud deployment story
#              8. JOHN SCHOLES (1948-2019) DFN INVENTION —
#                 Direct Functions (Dfns) are John Scholes's
#                 contribution to modern APL; concise
#                 anonymous-function syntax
#              9. INDUSTRY ADOPTION — Morgan Stanley, JP
#                 Morgan, Optiver, Aviva, MetLife use Dyalog
#                 APL in production
#             10. APL FORGE — Dyalog sponsors annual APL
#                 programming competition with $5000 prize
# License: Commercial (free non-commercial)
# Status:  Dyalog APL ~v19.0 in 2026; established commercial
#          product since 1983; over 40 years of continuous
#          development.  Companion repos: 230 stars Dyalog/
#          ride, 76 stars Dyalog/dyalog-jupyter-kernel.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — 98TH LANGUAGE: DYALOG APL
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy expands its
# **98TH PROGRAMMING LANGUAGE**: Dyalog APL.  This expands the taxonomy
# from 97 to 98 documented programming languages.  Pattern: R661 Rust=73
# (dialoguer → Axis 8 OPENS) → R662 Go=73 (c-bata/go-prompt) → R663
# TS-Node=73 (prompts → Axis 8 1/1/1) → R664 98TH LANGUAGE (Dyalog APL
# via dyalog THIS).  This completes the 3-leader-bump + 1-new-language
# micro-cycle.
#
# WHY DYALOG APL IS A DISTINCTIVE 98TH LANGUAGE:
#
#   1. COMMERCIAL APL — Dyalog APL is the canonical COMMERCIAL
#      modern APL implementation.  Distinct from GNU APL (free
#      reimplementation in our taxonomy), J (Iverson's ASCII-
#      only successor), K (Whitney's compact dialect), Q (KX
#      Systems database query), BQN (Marshall Lochbaum's
#      modern reboot), and Uiua (stack-based variant).
#      Dyalog's commercial maintenance since 1983 ensures
#      enterprise-grade ecosystem (debuggers, profilers, IDE,
#      version control integration, .NET FFI, Python FFI).
#
#   2. SINGLE-CHARACTER UNICODE GLYPHS — APL's defining
#      characteristic is its mathematical notation using
#      single Unicode glyphs for array operations:
#         ⍳   index generator (iota)
#         ⍴   reshape / shape
#         ⌽   reverse / rotate
#         ⊃   first / pick / disclose
#         ⊂   enclose
#         /   reduce / replicate
#         ¨   each (map)
#         ⍣   power operator
#         ∘.  outer product (Cartesian-style table)
#         .   inner product (matrix multiplication generalization)
#      No keyword vocabulary; pure symbolic notation.  Distinct
#      from every conventional programming language.
#
#   3. RANK + REDUCE + OUTER PRODUCT POLYMORPHISM — APL's
#      central abstraction is the array-rank-polymorphic
#      operator.  A function that works on scalars
#      automatically works on vectors, matrices, and higher-
#      dimensional arrays:
#         3 × 5           ⍝ scalar: 15
#         3 × 1 2 3       ⍝ scalar-vector: 3 6 9
#         (1 2 3) × (4 5 6) ⍝ vector-vector: 4 10 18
#      `each` operator (¨) applies a function to every element;
#      `outer product` (∘.) generates a Cartesian table.
#
#   4. JOHN SCHOLES DFN INVENTION — Direct Functions (Dfns)
#      are modern Dyalog APL's most important post-Iverson
#      innovation, contributed by John Scholes (1948-2019)
#      of Dyalog Ltd.  Dfns provide concise anonymous-function
#      syntax with implicit arguments ⍺ (left) and ⍵ (right):
#         Mean ← {(+/⍵) ÷ ≢⍵}
#         ⍝ Mean is a Dfn taking right-arg ⍵, returning mean
#         5 ↑ ⍳100         ⍝ first 5: 1 2 3 4 5
#         Mean 5 ↑ ⍳100    ⍝ 3
#      Distinct from tradfns (traditional functions with ∇ +
#      header line).
#
#   5. PARALLEL APL — Dyalog supports parallel evaluation via:
#         Tasks    (.NET threadpool-style)
#         Futures  (lazy evaluation with parallel completion)
#         Spawn    (background workers)
#         Isolates (process-level isolation containers)
#      Distinct from APL's traditional single-threaded model.
#
#   6. .NET INTEROP via SAOL — Dyalog programs can construct
#      .NET objects, call .NET methods, subclass .NET classes,
#      and integrate with the .NET Framework / .NET Core /
#      .NET 5+ ecosystems.  Used in Windows-heavy enterprise
#      deployments.
#
#   7. PYTHON INTEROP via pynapl — bidirectional Python ↔
#      Dyalog data exchange.  Allows Dyalog code to call
#      pandas / numpy / sklearn / PyTorch from APL functions
#      and Python to call back into Dyalog workspaces.
#
#   8. JUPYTER KERNEL — Dyalog/dyalog-jupyter-kernel provides
#      a Jupyter kernel running Dyalog APL.  Enables
#      notebook-based APL exploration (combined with Markdown,
#      LaTeX, inline plots via SharpPlot).
#
#   9. .dws WORKSPACE PERSISTENCE — Dyalog programs save their
#      entire state (variables, functions, classes, namespaces)
#      to .dws files.  Resumable across sessions.  Modern
#      alternative: .apl text-file storage via the Link
#      component, enabling Git version control.
#
#  10. FINANCIAL INDUSTRY ADOPTION — Morgan Stanley + JP
#      Morgan + Optiver + Aviva + MetLife + many other
#      financial institutions use Dyalog APL in production
#      for options pricing, portfolio optimization,
#      insurance rate calculation, and high-frequency
#      analytics where Iverson's notation maps naturally
#      onto matrix-oriented financial mathematics.
#
# Cross-language CLI library taxonomy after R664:
#   * 98 languages documented (Dyalog APL is the 98th)
#   * 398 total CLI library variants
#   * Rust=73 / Go=73 / TS-Node=73 (three-way tie at leaderboard top)
#   * Axis 9 / Logging: 6/6/6 three-language symmetric
#   * Axes 10 + 13 + 14: 2/2/2 three-language symmetric
#   * Axes 7 + 8 + 11 + 12 + 15 + 16 + 17 + 18: 1/1/1 three-language symmetric
#   * Eleven axes at three-language symmetry
#
# APL family in taxonomy:
#   * gnu-apl (open-source GNU APL implementation)
#   * dyalog (commercial Dyalog APL THIS — R664)
#   * jconsole (J — Iverson's ASCII-only APL successor)
#   * q (KX Systems Q built on K)
#   * bqn (Marshall Lochbaum modern APL)
#   * uiua (Kai Schmidt stack-based array)
#
# Languages documented prior to R664 (selected):
#   * R605 ATS2 (patsopt) — 84th
#   * R612 Logtalk (logtalk_backend_select) — 85th
#   * R616 M/MUMPS (ydbinstall.sh) — 86th
#   * R620 REXX (regina) — 87th
#   * R624 Austral (austral) — 88th
#   * R628 Onyx (onyx) — 89th
#   * R632 TXR (txr) — 90th
#   * R636 Ioke (ioke) — 91st
#   * R640 Falcon (falcon) — 92nd
#   * R644 Slang (slangc) — 93rd
#   * R648 Clarity (clarity-cli) — 94th
#   * R652 Icon (icont) — 95th
#   * R656 Limbo (limbo) — 96th
#   * R660 SNOBOL4 (snobol4) — 97th
#   * R664 Dyalog APL (dyalog THIS) — 98th
#
# -----------------------------------------------------------------------------
#
# THE dyalog CLI — Dyalog manual-sourced flags
#
# dyalog accepts the following invocation flags (sourced from
# Dyalog's official manual at docs.dyalog.com + the docker
# entrypoint script in Dyalog/DyalogDocker):
#
# Toggle flags (use + to enable, - to disable):
#   +s | -s          Silent mode (suppress startup banner)
#   +q | -q          Quiet mode (suppress non-essential output)
#   +b | -b          Batch mode (no terminal interaction)
#   +script | -script
#                    Script mode (treat input file as APL script)
#   +runtime | -runtime
#                    Runtime mode (RIDE-only; no interactive
#                    session)
#   +CONSOLE | -CONSOLE
#                    Console mode (no GUI)
#
# Configuration parameters (prefix with -):
#   -RIDE_INIT=address:port
#                    RIDE listen address (e.g. "SERVE:::4502")
#                    or connect address ("CONNECT:host:port")
#   -APL_DEFAULT_WX=N
#                    Default workspace expansion (3 = enable
#                    .NET object autocomplete)
#   -APL_TEXTINAPLCORE=N
#                    Use APL text in core (1 default)
#   -WORKSPACE_PATH=path
#                    Workspace search path (colon-separated)
#   -SESSION_FILE=path
#                    Path to session file (.dse)
#
# Environment variables (alternative to flags):
#   DYALOG=path      Path to Dyalog installation
#                    (e.g. /opt/mdyalog/19.0/64/unicode)
#   WSPATH=paths     Colon-separated workspace search paths
#   LOAD=workspace   Workspace to load at startup
#   CONFIGFILE=path  Path to .dcfg configuration file
#   DYAPP=path       Path to .dyapp application bootstrap
#   APL_DEFAULT_WX=N
#                    Set default workspace expansion
#   APL_TEXTINAPLCORE=N
#                    Text in APL core
#   TRACE_ON_ERROR=N
#                    Trace on error (0 = disabled)
#   SESSION_FILE=path
#                    Session file location
#
# File extensions:
#   .dws             Dyalog workspace (binary state save)
#   .dyapp           Dyalog application bootstrap script
#   .dcfg            Dyalog configuration file
#   .apl             APL source file (Link component format)
#   .aplf            APL function file
#   .apln            APL namespace file
#   .aplc            APL class file
#   .aplo            APL operator file
#   .aplt            APL trait file
#   .dse             Dyalog session file
#
# Positional argument: workspace name or .dws file path
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced from Dyalog official manual at
# docs.dyalog.com/Manuals/Manuals.htm + Dyalog/DyalogDocker
# entrypoint script + Dyalog/DyalogDocker documentation.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '+s[silent mode (suppress startup banner)]' \
    '-s[disable silent mode]' \
    '+q[quiet mode (suppress non-essential output)]' \
    '-q[disable quiet mode]' \
    '+b[batch mode (no terminal interaction)]' \
    '-b[disable batch mode]' \
    '+script[script mode (treat input as APL script)]' \
    '-script[disable script mode]' \
    '+runtime[runtime mode (RIDE-only, no interactive)]' \
    '-runtime[disable runtime mode]' \
    '+CONSOLE[console mode (no GUI)]' \
    '-CONSOLE[disable console mode]' \
    '-RIDE_INIT=[RIDE listen/connect address]:address:_default' \
    '-APL_DEFAULT_WX=[default workspace expansion]:level:(0 1 2 3)' \
    '-APL_TEXTINAPLCORE=[use APL text in core]:value:(0 1)' \
    '-WORKSPACE_PATH=[workspace search path (colon-separated)]:paths:_default' \
    '-SESSION_FILE=[path to session file (.dse)]:file:_files -g "*.dse"' \
    '*:workspace or script:_files -g "*.(dws|dyapp|dcfg|apl|aplf|apln|aplc|aplo|aplt)"' \
    && ret=0

return ret
