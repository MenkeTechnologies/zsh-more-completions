#compdef mstvpd
# Documentation: https://www.mankier.com/1/mstvpd
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mstvpd: Mellanox VPD read tool. Dumps the on-card PCI Vital Product Data.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-v[show version]' \
  '-m[dump raw VPD data to stdout]' \
  '-n[do not validate checksum]' \
  '-r[do not check/display VPD_W tag]' \
  '-t+[timeout in seconds (default 30)]:seconds:' \
  '*:device:' && ret=0
return ret
