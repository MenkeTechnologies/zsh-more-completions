#compdef mark
# Documentation: man mark(1)
# Source: nmh uip/mark.c (master) — manipulate message sequences (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-add -delete -list)-add[add messages to sequence]' \
    '(-add -delete -list)-delete[remove messages from sequence]' \
    '(-add -delete -list)-list[list sequence contents]' \
    '*-sequence+[sequence name]:name:_default' \
    '(-public -nopublic)-public[use public sequence]' \
    '(-public -nopublic)-nopublic[use private sequence]' \
    '(-zero -nozero)-zero[clear sequence before adding]' \
    '(-zero -nozero)-nozero[do not clear]' \
    '-version[show version]' \
    '-help[show help]' \
    '-debug[debug output]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
