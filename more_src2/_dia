#compdef dia
# Documentation: https://manpages.debian.org/bookworm/dia-common/dia.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(-e --export)'{-e+,--export=}'[export to file]:file:_files' \
  '(-t --filter)'{-t+,--filter=}'[export format]:fmt:(cgm dia dxf eps eps-builtin eps-pango fig mp pdf plt hpgl png shape svg)' \
  '(-L --show-layers)'{-L+,--show-layers=}'[only include layers (csv or range)]:layers:' \
  '(-s --size)'{-s+,--size=}'[size WxH for PNG export]:size:' \
  '(-n --nosplash)'{-n,--nosplash}'[do not show splash]' \
  '(-l --log-to-stderr)'{-l,--log-to-stderr}'[log to stderr]' \
  '--integrated[integrated UI mode]' \
  '--credits[show credits]' \
  '--list-filters[list export filters]' \
  '--display=[X display]:display:' \
  '*:diagram file:_files -g "*.dia"' && ret=0

return ret
