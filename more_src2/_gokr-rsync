#compdef gokr-rsync
# ============================================================================
# gokr-rsync - pure-Go rsync (client + server, sender +
#                receiver, daemon mode) (Go, BSD-3-Clause)
#
# Author : gokrazy contributors (Michael Stapelberg et al)
# Upstream: https://github.com/gokrazy/rsync
#
# `gokr-rsync` is a native Go reimplementation of tridge
# rsync (Wayne Davison's C implementation from the samba
# project) + openrsync (Kristaps Dzonsons' OpenBSD
# implementation, also used on macOS 15+). It supports
# both client + server roles, both sender + receiver
# halves, and both rsync-over-SSH + rsync-protocol-over-
# TCP daemon mode. The binary is wire-compatible with
# stock rsync, which means you can use it as a drop-in
# replacement on either side of any rsync connection.
#
# Usage:
#   gokr-rsync [OPTIONS] [SRC]... [DEST]
#   gokr-rsync --daemon [OPTIONS]    # rsyncd-mode listener
#
# Key flags (subset; gokr-rsync mirrors tridge rsync's
# full popt-style option set):
#
#   Operating modes:
#     --daemon                    run in rsyncd listener mode
#     --server                    internal: peer is a client
#     --sender                    internal: peer is a sender
#                                 (only valid with --server)
#
#   File-attribute preservation:
#     -a, --archive               equivalent to -rlptgoD
#     -r, --recursive             recurse into directories
#     -d, --dirs                  transfer dirs without recurse
#     -l, --links                 copy symlinks as symlinks
#     -p, --perms                 preserve permissions
#     -t, --times                 preserve modification times
#     -g, --group                 preserve group
#     -o, --owner                 preserve owner
#     -D                          preserve device + special files
#     -H, --hard-links            preserve hard-links
#     -A, --acls                  preserve ACLs
#     -X, --xattrs                preserve extended attributes
#     -U, --atimes                preserve access times
#     -N, --crtimes               preserve creation times
#
#   Transfer behaviour:
#     -n, --dry-run               show what would be done
#     -v, --verbose               increase verbosity
#         --debug=FLAG[,FLAG...]  enable debug topics
#         --info=FLAG[,FLAG...]   enable info topics
#     -q, --quiet                 suppress non-error output
#         --progress              show per-file transfer progress
#         --stats                 print transfer stats at end
#     -z, --compress              compress data on the wire
#         --compress-level=N      compression level (1-9)
#         --compress-choice=STR   zlib/zstd/lz4 (--zc)
#         --skip-compress=LIST    skip-compress suffixes
#
#   Selection / filtering:
#     -e, --rsh=COMMAND           specify the remote shell
#     -C, --cvs-exclude           auto-exclude CVS-style files
#     -f, --filter=RULE           add a filter rule
#         --exclude=PATTERN       exclude pattern
#         --exclude-from=FILE     read excludes from FILE
#         --include=PATTERN       don't exclude this pattern
#         --include-from=FILE     read includes from FILE
#         --files-from=FILE       read file list from FILE
#         --from0                 read file list null-separated
#
#   Delta / deletion:
#         --delete                delete extraneous files on
#                                 receiver
#         --delete-before
#         --delete-during
#         --delete-after
#         --delete-delay
#         --delete-excluded       also delete excluded files
#         --delete-missing-args
#         --max-delete=NUM        cap deletions
#         --backup, -b            backup replaced files
#         --backup-dir=DIR        --backup destination dir
#         --suffix=SUFFIX         --backup suffix
#
#   Performance / tuning:
#         --bwlimit=RATE          bandwidth limit
#         --block-size=SIZE
#         --max-alloc=SIZE
#     -B, --block-size=SIZE
#     -T, --temp-dir=DIR          tmpdir for partial files
#         --partial               keep partially transferred
#         --partial-dir=DIR       store partials here
#         --inplace               update destination in place
#         --append                append to destination files
#         --append-verify
#         --whole-file, -W        copy whole files
#
#   Address binding (daemon mode):
#         --address=BIND          bind address
#         --port=PORT             listen port
#         --config=FILE           rsyncd.conf path
#         --log-file=FILE         log file
#
#   Gokrazy-specific (prefixed with `gokr.`):
#         --gokr.dont_restrict    skip pivot-root jailing
#         --gokr.config=FILE      TOML config path (parsed
#                                 via BurntSushi/toml)
#         --gokr.listen=ADDR      listener bind address
#         --gokr.monitoring_listen=ADDR
#         --gokr.anonssh_listen=ADDR
#         --gokr.modulemap=SPEC   module->path map
#
#   Help / version:
#     -h, --help                  print help
#     -V, --version               print version
#
# The full flag set mirrors tridge rsync's popt-style
# table (~250 long options + ~40 short options). The
# completion below covers the most-used subset.
#
# The BurntSushi/toml lane is built on `github.com/
# BurntSushi/toml v1.6.0` (declared verbatim at upstream
# go.mod HEAD as a direct dep, imported from internal/
# rsyncdconfig/config.go as `toml.Decode(input, &cfg)`),
# the canonical Go TOML library by Andrew Gallant
# (BurntSushi - rg / xsv / fst / ucd-generate author) -
# github.com/BurntSushi/toml, 4800+ stars. The package
# is the de-facto Go TOML parser and serializer; it
# delegates struct-tag mapping to the `toml:"key"` tag
# convention exactly mirroring encoding/json's tag style.
#
# The structural-canonical claim for the Go slot:
# BurntSushi also authored BurntSushi/toml-test (the
# TOML spec's official conformance corpus, used to
# grade every TOML library across every language).
# That makes the Go canonical author the same person as
# the canonical spec-conformance-suite author - an
# unusually clean root-of-trust pattern in the cross-
# language landscape.
#
# gokr-rsync uses BurntSushi/toml to decode the rsyncd
# daemon's listener / module / SSH-listener config at
# daemon startup: the operator hands `--gokr.config=
# rsyncd.toml`, the file contents are read, and
# `toml.Decode` populates a typed `Config` struct
# with `[[listener]]`, `[[module]]`, and `dont_namespace`
# fields (struct-tagged with `toml:"listener"` etc.).
#
# ----------------------------------------------------------------------------
# AXIS 243 :: TOML parsing (TOML v1.0.0 spec compliant
#              parsers + serializers)
# Round 1428 :: Go slot 2 of 4 :: continues Axis 243
#
# Cross-language canonical library family for this axis:
#   Rust    : toml-rs/toml                 [R1427 _typsite]
#   Go      : BurntSushi/toml              [R1428 THIS FILE]
#   TS/Node : iarna/iarna-toml             [R1429 closing]
#
# BurntSushi/toml is structurally interesting in this
# axis because of the *spec-author = library-author*
# root-of-trust pattern. Andrew Gallant authored both:
#   1. `BurntSushi/toml` - the canonical Go TOML library
#   2. `BurntSushi/toml-test` - the TOML spec's official
#      conformance corpus, used by ALL TOML libraries
#      across ALL languages to grade their compliance
#
# No other Go-ecosystem library in this axis cluster has
# the same root-of-trust shape. Compare:
#   - Rust toml-rs: written by Alex Crichton at Mozilla
#     (Cargo's first author); separate from the spec
#     conformance suite
#   - Node iarna-toml: written by Rebecca Turner at npm;
#     separate from the spec conformance suite
#
# Gallant's library is graded against his own conformance
# suite, which sounds circular but isn't - the suite is
# language-agnostic JSON-output specification, and every
# other Go TOML library (pelletier/go-toml v2 included)
# is graded against the same suite. The suite came first
# (2014); the libraries grade against it.
#
# Cross-language interop happens at the wire format
# level - TOML is byte-text-based, so the same TOML
# input parsed by toml-rs/toml + BurntSushi/toml +
# iarna/iarna-toml produces structurally identical
# parsed values (toml-test's JSON-canonical reference
# representation confirms this).
# ============================================================================

_gokr-rsync() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--daemon[run in rsyncd listener mode]' \
        '--server[internal: peer is the client]' \
        '--sender[internal: peer is the sender (only with --server)]' \
        '(-a --archive)'{-a,--archive}'[equivalent to -rlptgoD]' \
        '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
        '(-d --dirs)'{-d,--dirs}'[transfer dirs without recurse]' \
        '(-l --links)'{-l,--links}'[copy symlinks as symlinks]' \
        '(-p --perms)'{-p,--perms}'[preserve permissions]' \
        '(-t --times)'{-t,--times}'[preserve modification times]' \
        '(-g --group)'{-g,--group}'[preserve group]' \
        '(-o --owner)'{-o,--owner}'[preserve owner]' \
        '-D[preserve device + special files]' \
        '(-H --hard-links)'{-H,--hard-links}'[preserve hard-links]' \
        '(-A --acls)'{-A,--acls}'[preserve ACLs]' \
        '(-X --xattrs)'{-X,--xattrs}'[preserve extended attributes]' \
        '(-U --atimes)'{-U,--atimes}'[preserve access times]' \
        '(-N --crtimes)'{-N,--crtimes}'[preserve creation times]' \
        '(-n --dry-run)'{-n,--dry-run}'[show what would be done]' \
        '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
        '--debug=[enable debug topics]:topics:' \
        '--info=[enable info topics]:topics:' \
        '(-q --quiet)'{-q,--quiet}'[suppress non-error output]' \
        '--progress[show per-file transfer progress]' \
        '--stats[print transfer stats at end]' \
        '(-z --compress)'{-z,--compress}'[compress data on the wire]' \
        '--compress-level=[compression level (1-9)]:N:' \
        '--compress-choice=[zlib/zstd/lz4]:codec:(zlib zstd lz4)' \
        '--skip-compress=[skip-compress suffix list]:suffixes:' \
        '(-e --rsh)'{-e,--rsh}'=[specify the remote shell]:command:' \
        '(-C --cvs-exclude)'{-C,--cvs-exclude}'[auto-exclude CVS-style files]' \
        '*'{-f,--filter}'=[add a filter rule (repeatable)]:rule:' \
        '*--exclude=[exclude pattern (repeatable)]:pattern:' \
        '--exclude-from=[read excludes from FILE]:file:_files' \
        '*--include=[do not exclude this pattern (repeatable)]:pattern:' \
        '--include-from=[read includes from FILE]:file:_files' \
        '--files-from=[read file list from FILE]:file:_files' \
        '--from0[file list is null-separated]' \
        '--delete[delete extraneous files on receiver]' \
        '--delete-before' \
        '--delete-during' \
        '--delete-after' \
        '--delete-delay' \
        '--delete-excluded[also delete excluded files]' \
        '--delete-missing-args' \
        '--max-delete=[cap deletions]:N:' \
        '(-b --backup)'{-b,--backup}'[backup replaced files]' \
        '--backup-dir=[backup destination dir]:dir:_files -/' \
        '--suffix=[backup suffix]:suffix:' \
        '--bwlimit=[bandwidth limit]:rate:' \
        '(-B --block-size)'{-B,--block-size}'=[checksum block size]:size:' \
        '--max-alloc=[max allocation size]:size:' \
        '(-T --temp-dir)'{-T,--temp-dir}'=[tmpdir for partial files]:dir:_files -/' \
        '--partial[keep partially transferred files]' \
        '--partial-dir=[store partials here]:dir:_files -/' \
        '--inplace[update destination in place]' \
        '--append[append to destination files]' \
        '--append-verify' \
        '(-W --whole-file)'{-W,--whole-file}'[copy whole files (no delta)]' \
        '--address=[bind address (daemon)]:addr:' \
        '--port=[listen port (daemon)]:port:' \
        '--config=[rsyncd.conf path (daemon)]:file:_files' \
        '--log-file=[log file]:file:_files' \
        '--gokr.dont_restrict[skip pivot-root jailing]' \
        '--gokr.config=[TOML config path (parsed via BurntSushi/toml)]:file:_files -g "*.toml"' \
        '--gokr.listen=[listener bind address]:addr:' \
        '--gokr.monitoring_listen=[monitoring bind address]:addr:' \
        '--gokr.anonssh_listen=[anonymous-SSH bind address]:addr:' \
        '--gokr.modulemap=[module->path map]:spec:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '*:rsync src/dest:_files'
}

_gokr-rsync "$@"
