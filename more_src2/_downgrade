#compdef downgrade
# Documentation: https://archlinux-downgrade.github.io/downgrade/downgrade.8
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for downgrade - downgrade Arch Linux packages

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--ala-url=[set Arch Linux Archive URL]:url' \
  '--ala-only[only use Arch Linux Archive]' \
  '--cached-only[only use local cache]' \
  '--prefer-cache[prefer cache before querying ALA]' \
  '--latest[automatically pick latest version]' \
  '--oldest[automatically pick oldest version]' \
  '--ignore=[IgnorePkg behavior]:mode:(prompt always never)' \
  '--unignore=[remove package from IgnorePkg]:package' \
  '--maxdepth=[max depth for cached package search]:depth' \
  '--pacman=[pacman command]:command' \
  '--pacman-conf=[pacman config file]:file:_files' \
  '--pacman-cache=[pacman cache directory]:directory:_files -/' \
  '--pacman-log=[pacman log file]:file:_files' \
  '*:package:->packages' && return 0

case $state in
  packages)
    local -a packages
    packages=(${(f)"$(pacman -Qq 2>/dev/null)"})
    _describe -t packages 'installed packages' packages
    ;;
esac
