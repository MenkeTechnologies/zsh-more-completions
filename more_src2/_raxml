#compdef raxml raxmlHPC raxmlHPC-PTHREADS raxmlHPC-MPI raxmlHPC-PTHREADS-SSE3 raxmlHPC-PTHREADS-AVX raxmlHPC-PTHREADS-AVX2
# Documentation: upstream raxmlHPC(1) man page at
# manpages.debian.org/bookworm/raxml/raxmlHPC.1.en.html
# Reference accessed: 2026-05-30 via WebFetch.
# Classic RAxML R100 — 7-stem multi-binary harvest covering the
# classic (pre-NG) RAxML family. All seven binaries share the same
# CLI surface; the suffixes denote build variants (PTHREADS for
# OpenMP, MPI for cluster, SSE3/AVX/AVX2 for SIMD).
# The successor raxml-ng (modern Kozlov rewrite) is covered
# separately in `more_src/_raxml-ng`.

local -a _algorithms _models
_algorithms=(
  'a:rapid Bootstrap analysis + best-scoring ML tree'
  'A:compute pairwise distances'
  'b:compute bootstop convergence on a set of trees'
  'B:compute optimal branch lengths'
  'c:check consistency of taxon names'
  'C:ancestral state reconstruction'
  'd:new rapid hill-climbing (DEFAULT)'
  'D:RF distance between trees'
  'e:optimize model parameters'
  'E:execute experimental options'
  'F:tree topology search with FAST option'
  'g:per-site log likelihoods for CONSEL'
  'G:per-site log likelihoods (improved)'
  'h:print help'
  'H:thorough optimization of model parameters'
  'i:perform partial likelihood vector tests'
  'I:autoMR-derived likelihood-based test of placement'
  'j:generate bootstrapped alignment files'
  'J:compute majority rule consensus tree'
  'k:print bipartition information for the bootstrap trees'
  'm:compare bipartitions between sets of trees'
  'M:ML optimization with multiple-trees per-tree'
  'n:compute log-likelihoods on a user starting tree'
  'N:compute the consensus of bootstrap trees'
  'o:old & slow rapid hill-climbing'
  'p:perform pure stepwise MP addition of new sequences'
  'P:perform a phylogenetic placement analysis (EPA)'
  'q:fast quartet calculator'
  'r:compute RF distance between trees'
  'R:read in binary tree and write Newick format'
  's:split alignment files'
  'S:compute ancestral states'
  't:do final thorough optimization of ML tree under GAMMA'
  'T:do final thorough optimization of ML tree under GAMMA with -X'
  'u:execute morphological + molecular co-estimation'
  'U:execute Pthreads-based gene-tree estimation'
  'v:classify a bunch of environmental sequences (placement)'
  'V:visualize matrix decomposition'
  'w:compute ELW test'
  'W:compute SH-aLRT'
  'x:rapid bootstrapping'
  'y:compute parsimony starting tree only'
)
_models=(
  GTRCAT GTRCATI GTRGAMMA GTRGAMMAI BINCAT BINGAMMA
  PROTCATDAYHOFF PROTCATWAG PROTCATBLOSUM62 PROTCATJTT PROTCATLG
  PROTCATMTREV PROTCATMTART PROTCATMTZOA PROTCATGTR
  PROTGAMMADAYHOFF PROTGAMMAWAG PROTGAMMABLOSUM62 PROTGAMMAJTT
  PROTGAMMALG PROTGAMMAMTREV PROTGAMMAGTR PROTGAMMAAUTO
  MULTICAT MULTIGAMMA
)

_arguments -s -S \
  '-s+[alignment data file (PHYLIP format)]:file:_files -g "*.(phy|phylip|fasta|fa)"' \
  '-n+[output file name suffix]:name:' \
  '-m+[substitution model]:model:($_models)' \
  '-p+[parsimony random seed]:seed:' \
  '-x+[rapid bootstrap random seed]:seed:' \
  '-b+[bootstrap random seed]:seed:' \
  '-N+[number of alternative runs on distinct starting trees]:N or autoMR:' \
  '-#+[same as -N]:N:' \
  '-T+[number of threads (PTHREADS only)]:N:' \
  '-o+[outgroup name or comma-separated list]:outgroup(s):' \
  '-f+[algorithm to execute]:algorithm:((${_algorithms}))' \
  '-t+[user starting tree file (Newick)]:file:_files' \
  '-q+[partition file (model assignments)]:file:_files' \
  '-c+[number of rate categories for CAT model (default 25)]:N:' \
  '-w+[output directory (full path)]:dir:_directories' \
  '-M[estimate per-partition branch lengths]' \
  '-a+[per-column weights file]:file:_files' \
  '-A+[secondary structure substitution model]:model:' \
  '-B+[branch length cutoff]:value:' \
  '-C[verbose output]' \
  '-d[run with random starting trees]' \
  '-D[ML search convergence criterion]' \
  '-e+[log likelihood epsilon (default 0.1)]:value:' \
  '-E+[exclude/include file]:file:_files' \
  '-F[ML tree search with FAST option]' \
  '-g+[constraint tree (multifurcating)]:file:_files' \
  '-G+[ML estimate of GAMMA parameter]:value:' \
  '-h[show help]' \
  '-H[disable pattern compression]' \
  '-i+[initial rearrangement setting]:N:' \
  '-I+[autoMR threshold]:value:' \
  '-J+[majority rule threshold (MR / MRE / STRICT)]:type:(MR MRE STRICT)' \
  '-k[print bootstrap branch lengths]' \
  '-K+[K-mer-frequency-based gene assignment]:value:' \
  '-L+[likelihood-based test of bipartitions]:value:' \
  '-O[disable check for duplicate sequences]' \
  '-P+[external substitution-matrix file]:file:_files' \
  '-Q[fast quartet calculator]' \
  '-r+[constraint tree (bifurcating)]:file:_files' \
  '-R+[user starting tree binary file]:file:_files' \
  '-S+[secondary-structure file]:file:_files' \
  '-u[experimental option]' \
  '-U[use saved memory mode]' \
  '-V[disable rate heterogeneity]' \
  '-W+[sliding window size]:N:' \
  '-X[reduce memory consumption by half (RF distance only)]' \
  '-y[compute parsimony starting tree only]' \
  '-Y+[multiple-tree file for branch-length estimation]:file:_files' \
  '-z+[user tree file for evaluation]:file:_files' \
  '--no-bfgs[turn off BFGS optimization]' \
  '--no-seq-check[skip sequence consistency check]' \
  '--epa-keep-placements=[number of placements to keep per query]:N:' \
  '--epa-accumulated-threshold=[likelihood threshold for placements]:value:' \
  '--epa-prob-threshold=[probability threshold for placements]:value:' \
  '--JC69[use Jukes-Cantor model]' \
  '--K80[use Kimura 2-parameter model]' \
  '--HKY85[use HKY85 model]' \
  '--mesquite[output in Mesquite format]' \
  '--silent[silent mode]' \
  '--asc-corr=[ascertainment-bias correction]:method:(lewis stamatakis felsenstein)'
