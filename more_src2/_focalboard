#compdef focalboard focalboard-server
# _focalboard — Mattermost Focalboard open-source self-hosted Trello/Asana/Notion-style project management board (mattermost team, Go); standard flag package
# upstream: https://github.com/mattermost/focalboard

_focalboard() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-config+[config file]:file:_files -g "*.json"' \
        '-config-file+[config file]:file:_files -g "*.json"' \
        '-host+[bind host]:host:_hosts' \
        '-port+[http port]:port:_ports' \
        '-database-type+[db driver]:d:(sqlite3 postgres mysql)' \
        '-database+[db DSN]:str:' \
        '-secret+[session secret]:str:' \
        '-prometheus-address+[metrics addr]:str:' \
        '-web-path+[web dir]:dir:_files -/' \
        '-files-path+[files dir]:dir:_files -/' \
        '-monitor-pid-path+[pid file]:file:_files' \
        '-server-root+[server root url]:url:_urls' \
        '-tls-cert+[cert file]:file:_files' \
        '-tls-key+[key file]:file:_files' \
        '-tls-cert-path+[cert file]:file:_files' \
        '-tls-key-path+[key file]:file:_files' \
        '-use-ssl[enable ssl]' \
        '-port-ssl+[ssl port]:port:_ports' \
        '-single-user[single user mode]' \
        '-watch-poll-interval+[ms]:n:' \
        '-data-retention-enable[enable data retention]' \
        '-data-retention-days+[N]:n:'
}

_focalboard "$@"
