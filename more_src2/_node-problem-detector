#compdef node-problem-detector
# _node-problem-detector — Kubernetes per-node problem detector daemon
# upstream: https://github.com/kubernetes/node-problem-detector
# Flags from cmd/options/options.go on tip.

_node-problem-detector() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--system-log-monitors=[DEPRECATED: system log monitor config paths (csv)]:csv:' \
        '--custom-plugin-monitors=[DEPRECATED: custom plugin monitor config paths (csv)]:csv:' \
        '--config.system-log-monitor=[system log monitor config paths (csv)]:csv:' \
        '--config.custom-plugin-monitor=[custom plugin monitor config paths (csv)]:csv:' \
        '--config.system-stats-monitor=[system stats monitor config paths (csv)]:csv:' \
        '--enable-k8s-exporter=[report to Kubernetes API server]:bool:(true false)' \
        '--event-namespace=[namespace for recorded events]:ns:' \
        '--apiserver-override=[override kube-apiserver address]:url:_urls' \
        '--apiserver-wait-timeout=[apiserver readiness wait timeout]:dur:' \
        '--apiserver-wait-interval=[apiserver readiness check interval]:dur:' \
        '--k8s-exporter-heartbeat-period=[forced apiserver sync period]:dur:' \
        '--k8s-exporter-write-events=[write Kubernetes Event objects]:bool:(true false)' \
        '--k8s-exporter-update-node-conditions=[update Node conditions]:bool:(true false)' \
        '--version=[print version and quit]:bool:(true false)' \
        '--hostname-override=[hostname override (else os.Hostname)]:name:' \
        '--port=[HTTP server bind port]:port:' \
        '--address=[HTTP server bind address]:host:' \
        '--prometheus-port=[Prometheus metrics port]:port:' \
        '--prometheus-address=[Prometheus metrics bind address]:host:' \
        '--kube-api-qps=[K8s API QPS]:f:' \
        '--kube-api-burst=[K8s API burst]:n:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_node-problem-detector "$@"
