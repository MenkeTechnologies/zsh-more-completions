#compdef mdtoc
# Documentation: https://github.com/kubernetes-sigs/mdtoc
# Reference accessed: 2026-05-17
# Verified: kubernetes-sigs/mdtoc upstream README/flags
# (-d/--dryrun, -i/--inplace, -s/--skip-prefix, -m/--max-depth,
# -o/--output).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --min-depth, --toc, --header (none of these exist on
# kubernetes-sigs/mdtoc; mdtoc uses HTML comment markers
# <!-- toc --> ... <!-- /toc --> in the source file instead).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --dryrun)'{-d,--dryrun}'[check without writing; exit 1 on diff]' \
  '(-i --inplace)'{-i,--inplace}'[edit file in place (requires toc tags)]' \
  '(-s --skip-prefix)'{-s,--skip-prefix}'[ignore headers before opening toc tag]' \
  '(-m --max-depth)'{-m+,--max-depth=}'[max TOC header depth]:n:(1 2 3 4 5 6)' \
  '(-o --output)'{-o+,--output=}'[write TOC to file]:file:_files' \
  '*:markdown:_files -g "*.(md|markdown)(-.)"' && ret=0
return ret
