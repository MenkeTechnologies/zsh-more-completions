#
# THE js-compute-runtime CLI
#
# js-compute-runtime is invoked as:
#   js-compute-runtime [FLAGS] [OPTIONS] [<input>] [<output>]
#
# Common invocations:
#   # Compile bin/index.js to bin/main.wasm (defaults)
#   js-compute-runtime
#
#   # Specify input + output explicitly
#   js-compute-runtime src/index.js dist/main.wasm
#
#   # Enable AOT compilation (faster, larger)
#   js-compute-runtime --enable-aot src/index.js dist/main.wasm
#
#   # Enable HTTP cache hook API
#   js-compute-runtime --enable-http-cache src/index.js dist/main.wasm
#
#   # Pass environment variables (multiple, comma-separated)
#   js-compute-runtime --env API_KEY=secret,DEBUG=true src/index.js dist/main.wasm
#
#   # Enable experimental features
#   js-compute-runtime \
#       --enable-experimental-high-resolution-time-methods \
#       --enable-experimental-top-level-await \
#       --enable-stack-traces \
#       src/index.js dist/main.wasm
#
#   # Use custom engine WASM
#   js-compute-runtime --engine-wasm fastly.debug.wasm src/index.js dist/main.wasm
#
#   # Debug intermediate files
#   js-compute-runtime --debug-intermediate-files /tmp/jsrt src/index.js dist/main.wasm
#
#   # Show version / help
#   js-compute-runtime --version
#   js-compute-runtime --help
#
# OPTIONS (sourced directly from
# https://github.com/fastly/js-compute-runtime/blob/main/src/printHelp.ts):
#
# FLAGS:
#   -h, --help                                      Show help
#   -V, --version                                   Show version
#
# OPTIONS:
#   --env KEY=VALUE                                 Set environment variables
#                                                   (multi, comma-separated)
#   --module-mode                                   [experimental] Run all
#                                                   sources as native modules
#   --engine-wasm FILE                              JS engine WASM file path
#   --enable-http-cache                             Enable HTTP cache hook API
#   --enable-aot                                    Enable AOT compilation
#                                                   (faster, larger output)
#   --enable-experimental-high-resolution-time-methods
#                                                   Enable experimental
#                                                   fastly.now() method
#   --enable-experimental-top-level-await           Enable experimental TLA
#   --enable-stack-traces                           Enable stack traces
#   --exclude-sources                               Don't include sources in
#                                                   stack traces
#   --debug-intermediate-files DIR                  Output intermediate files
#   --weval-bin BIN                                 Path to weval binary for
#                                                   AOT compilation
#
# ARGS:
#   <input>                                         Input JS script
#                                                   (default: bin/index.js)
#   <output>                                        Output WASM module
#                                                   (default: bin/main.wasm)
#
# Config files (via cosmiconfig):
#   .fastly.toml, .fastly.json, .fastly.yml,
#   .fastlyrc, .fastlyrc.json                       Project config
#   fastly key in package.json                      Alternative config location
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*--env=[set environment variables (multi)]:KEY=VALUE:_default' \
    '--module-mode[(experimental) run all sources as native modules]' \
    '--engine-wasm=[JS engine WASM file path]:file:_files -g "*.wasm"' \
    '--enable-http-cache[enable HTTP cache hook API]' \
    '--enable-aot[enable AOT compilation]' \
    '--enable-experimental-high-resolution-time-methods[enable experimental fastly.now()]' \
    '--enable-experimental-top-level-await[enable experimental top-level await]' \
    '--enable-stack-traces[enable stack traces]' \
    '--exclude-sources[do not include sources in stack traces]' \
    '--debug-intermediate-files=[output intermediate files directory]:dir:_files -/' \
    '--weval-bin=[path to weval binary]:file:_files' \
    '1:input JS script:_files -g "*.(js|mjs|cjs|ts)"' \
    '2:output WASM module:_files -g "*.wasm"' \
    && ret=0

return ret
