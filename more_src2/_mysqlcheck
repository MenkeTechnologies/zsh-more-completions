#compdef mysqlcheck mysqlrepair mysqlanalyze mysqloptimize
# Documentation: mysqlcheck --help (MySQL 9.6)
# Source: MySQL mysqlcheck — check / repair / analyze / optimize tables.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--print-defaults[print argument list and exit]' \
    '--no-defaults[do not read default option files]' \
    '--defaults-file=[only read defaults from given file]:file:_files' \
    '--defaults-extra-file=[read this file after global files]:file:_files' \
    '--defaults-group-suffix=[also read groups with concat(group,suffix)]:suffix:' \
    '--login-path=[read this path from login file]:path:' \
    '--no-login-paths[do not read login paths]' \
    '(-A --all-databases)'{-A,--all-databases}'[check all databases]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)'{-a,--analyze}'[analyze tables]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)'{-c,--check}'[check tables (default)]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)-r[repair tables]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)--repair[repair tables]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)'{-o,--optimize}'[optimize tables]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)'{-m,--medium-check}'[faster than extended-check]' \
    '(-c --check -r --repair -a --analyze -o --optimize -m --medium-check -C --check-only-changed)'{-C,--check-only-changed}'[check changed/unclean tables only]' \
    '(-1 --all-in-1)'{-1,--all-in-1}'[one query per database (comma list of tables)]' \
    '--auto-repair[auto-fix corrupted tables]' \
    '--bind-address=[IP to bind to]:ip:' \
    '--character-sets-dir=[character set files directory]:dir:_files -/' \
    '(-g --check-upgrade)'{-g,--check-upgrade}'[check tables for version-dependent changes]' \
    '--compress[use compression in protocol]' \
    '(-B --databases)'{-B,--databases}'[treat name args as database names]' \
    '*-#+[debug spec (no-op on non-debug builds)]:spec:' \
    '--debug-check[no-op]' \
    '--debug-info[no-op]' \
    '--default-character-set=[default character set]:name:' \
    '--default-auth=[default auth client plugin]:name:' \
    '--enable-cleartext-plugin[enable cleartext auth plugin]' \
    '(-F --fast)'{-F,--fast}'[check only unclean tables]' \
    '(-f --force)'{-f,--force}'[continue on SQL error]' \
    '(-e --extended)'{-e,--extended}'[100% consistency check or slow repair]' \
    '(- *)'{-?,--help}'[show help and exit]' \
    '(-h --host)'{-h,--host=}'[connect to host]:host:_hosts' \
    '(-u --user)'{-u,--user=}'[user]:user:_users' \
    '(-p --password)'{-p,--password=-}'[password]::password:' \
    '(-P --port)'{-P,--port=}'[server port]:port:_ports' \
    '(-S --socket)'{-S,--socket=}'[connection socket]:socket:_files' \
    '*--ssl-mode=[SSL mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
    '--ssl-ca=[CA cert file]:file:_files' \
    '--ssl-capath=[CA cert directory]:dir:_files -/' \
    '--ssl-cert=[client cert]:file:_files' \
    '--ssl-key=[client key]:file:_files' \
    '--ssl-cipher=[SSL ciphers]:ciphers:' \
    '(-q --quick)'{-q,--quick}'[quick check (no full scan)]' \
    '--silent[be silent]' \
    '--skip-database=[ignore named database]:db:' \
    '--tables[treat args after db as tables]' \
    '--use-frm[for repair, use only .frm file]' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(- *)'{-V,--version}'[show version]' \
    '--write-binlog[do binlog this operation]' \
    '--skip-write-binlog[do not binlog this operation]' \
    '1:database:' \
    '*:table:' \
    && ret=0

return ret
