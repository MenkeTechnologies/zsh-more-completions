#compdef openqa-cli
# _openqa-cli — CLI for the openQA REST API (os-autoinst/openQA)
# upstream: https://github.com/os-autoinst/openQA
# Flags from openqa-cli(1) man page.

_openqa-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--apibase=[API base path (default /api/v1)]:path:' \
        '--apikey=[API key]:key:' \
        '--apisecret=[API secret]:secret:' \
        '--host=[target host (default http://localhost)]:host:' \
        '--osd[set host to http://openqa.suse.de]' \
        '--o3[set host to https://openqa.opensuse.org]' \
        '--odn[set host to https://openqa.debian.net]' \
        '--pretty[prettify JSON output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'api:perform a REST API call'
                'archive:archive job into a directory'
                'schedule:schedule a job (test run)'
                'clone-job:clone a job to another instance'
                'monitor:wait for and display job results'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_openqa-cli "$@"
