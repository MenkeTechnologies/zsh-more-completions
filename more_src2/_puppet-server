#compdef puppetserver puppet-server
# _puppet-server — Puppet Inc puppetserver Clojure-based Puppet master server with JRuby compile workers (puppetlabs team, Clojure); custom argparse
# upstream: https://github.com/puppetlabs/puppetserver

_puppet-server() {
    local -a sub=(
        'foreground:start in foreground'
        'start:start as service'
        'stop:stop service'
        'restart:restart service'
        'reload:reload service'
        'status:show service status'
        'ca:certificate authority subcommands'
        'gem:gem subcommands'
        'irb:open jruby IRB'
        'ruby:run ruby script'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[config file]:file:_files -g "puppetserver.conf *.conf"' \
        '--config=+[config file]:file:_files -g "puppetserver.conf *.conf"' \
        '--debug[debug logging]' \
        '-d[debug logging]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--logdir=+[log dir]:dir:_files -/' \
        '--vardir=+[var dir]:dir:_files -/' \
        '--confdir=+[conf dir]:dir:_files -/' \
        '--codedir=+[code dir]:dir:_files -/' \
        '--rundir=+[run dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'puppet-server subcommand' sub ;;
        args)
            case $words[1] in
                ca) _arguments '1:ca cmd:(generate list sign revoke clean import enable migrate setup verify prune migrate-csrs migrate-certs)' ;;
                gem) _arguments '1:gem cmd:(install uninstall list search update env help)' ;;
            esac
            ;;
    esac
}

_puppet-server "$@"
