#compdef ltrace-cli
# _ltrace-cli — ltrace library and system call tracer CLI alias (ltrace team, C); custom argparse
# upstream: https://gitlab.com/cespedes/ltrace

_ltrace-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[align column]:n:' \
        '--align=+[align column]:n:' \
        '-A+[array length max]:n:' \
        '-b[no signals output]' \
        '-c[count time and calls]' \
        '-C[demangle symbols]' \
        '--demangle[demangle symbols]' \
        '-D+[debug mask]:n:' \
        '--debug=+[debug mask]:n:' \
        '-e+[expr]:str:' \
        '-E+[options]:str:' \
        '-f[follow forks]' \
        '-F+[config file]:file:_files' \
        '--config=+[config file]:file:_files' \
        '-i[print instruction pointer]' \
        '-l+[library]:str:' \
        '--library=+[library]:str:' \
        '-L[do not display library calls]' \
        '-n+[indent]:n:' \
        '--indent=+[indent]:n:' \
        '-o+[file]:file:_files' \
        '--output=+[file]:file:_files' \
        '-O+[option]:str:' \
        '-p+[pid]:pid:_pids' \
        '--pid=+[pid]:pid:_pids' \
        '-r[print relative timestamps]' \
        '-s+[max string size]:n:' \
        '--string-size=+[max string size]:n:' \
        '-S[trace syscalls also]' \
        '--syscalls[trace syscalls also]' \
        '-t[print absolute timestamp]' \
        '-tt[print microseconds]' \
        '-ttt[print timestamp as float]' \
        '-T[show time spent in calls]' \
        '-u+[user]:_users' \
        '--user=+[user]:_users' \
        '-w+[stack depth]:n:' \
        '--where=+[stack depth]:n:' \
        '-x+[expr]:str:' \
        '-X[trace x86 syscalls]' \
        '*:command:_command_names'
}

_ltrace-cli "$@"
