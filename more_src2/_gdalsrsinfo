#compdef gdalsrsinfo
# Documentation: https://gdal.org/programs/gdalsrsinfo.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '--single-line[print WKT on single line]' \
  '-V[validate SRS]' \
  '-e[search for EPSG number(s) corresponding to SRS]' \
  '-o+[output type]:type:(default all wkt_all PROJJSON proj4 wkt1 wkt_simple wkt_noct wkt_esri wkt wkt2 wkt2_2015 wkt2_2019 epsg mapinfo xml)' \
  '-p[pretty-print]' \
  '*:SRS def or filename:_files' && ret=0

return ret
