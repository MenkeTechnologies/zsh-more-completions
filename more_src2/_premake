#compdef premake5 premake4
# _premake — Premake build configuration tool (Jess Perkins, Lua); generate Make/Ninja/Visual Studio/Xcode projects
# upstream: https://github.com/premake/premake-core

_premake() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--cc+[compiler]:cc:(clang gcc msc)' \
        '--debugger+[debugger]:debugger:' \
        '--dotnet+[dotnet]:dotnet:(msnet mono pnet)' \
        '--file+[premake script]:file:_files -g "premake5.lua"' \
        '-f+[premake script]:file:_files -g "premake5.lua"' \
        '--fatal[fatal warnings]' \
        '--insecure[disable TLS verification]' \
        '--interactive[start REPL]' \
        '--os+[target OS]:os:(aix bsd haiku ios linux macosx solaris windows)' \
        '--scripts+[scripts dir]:dir:_files -/' \
        '--systemscript+[system script]:file:_files' \
        '--to+[output dir]:dir:_files -/' \
        '--verbose[verbose]' \
        '--version[show version]' \
        '*:action:'
}

_premake "$@"
