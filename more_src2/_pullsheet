_pullsheet() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--org=[GitHub org name]:org:' \
        '--repos=[comma-delimited list of repositories (owner/repo,owner/repo)]:repos:' \
        '--branches=[comma-delimited list of branches]:branches:' \
        '--users=[comma-delimited list of GitHub usernames]:users:' \
        '--since=[when to query from (date or duration, default now-90d)]:since:' \
        '--until=[when to query till (date or duration, default now)]:until:' \
        '--include-bots[include bot accounts in the output]' \
        '--title=[title to use for output pages]:title:' \
        '--token-path=[GitHub token file path]:path:_files' \
        '--out=[output format (default CSV)]:format:(CSV HTML JSON)' \
        '1: :_pullsheet_commands' \
        '*: :' && ret=0

    return ret
}

(( $+functions[_pullsheet_commands] )) ||
_pullsheet_commands() {
    local -a commands
    commands=(
        'prs:generate data around pull requests'
        'issues:generate data around issues'
        'issue-comments:generate data around comments on issues'
        'reviews:generate data around reviews'
        'leaderboard:generate leaderboard data (per-user totals)'
        'server:serve leaderboard data with web UI'
    )
    _describe -t commands 'pullsheet command' commands
}

_pullsheet "$@"
