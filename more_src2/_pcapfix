#compdef pcapfix
# Documentation: https://manpages.debian.org/testing/pcapfix/pcapfix.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pcapfix (repair broken pcap/pcapng files)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-d --deep-scan)'{-d,--deep-scan}'[force deep scan for corrupted data]' \
  '(-s --soft-mode)'{-s,--soft-mode}'[soft mode packet detection]' \
  '(-n --pcapng)'{-n,--pcapng}'[force PCAPNG file format]' \
  '(-o --outfile)'{-o,--outfile}'[set output file name]:output file:_files' \
  '(-t --data-link-type)'{-t,--data-link-type}'[force specific data link type]:DLT number' \
  '(-v --verbose)'{-v,--verbose}'[verbose output (stackable)]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:pcap file:_files -g "*.(pcap|pcapng|cap)(N)"' && ret=0

return ret
