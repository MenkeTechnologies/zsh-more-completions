#compdef gdal-config
# Documentation: https://gdal.org/programs/gdal-config.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '--prefix=[install dir]:dir:_files -/' \
  '--libs[linker flags]' \
  '--cflags[compile flags]' \
  '--version[show version]' \
  '--ogr-enabled[whether OGR is built into GDAL]' \
  '--formats[list configured formats]'
