#compdef kcreg
# _kcreg — Keycloak Project kcreg CLI command-line registration management tool for Keycloak realms managing client registrations register update delete config truststore credential reset-secret service-account-info create-initial-access-token authentication-flow client-policy import-export validating-Keycloak-admin-API (Keycloak team, Java); getopt
# upstream: https://www.keycloak.org/

_kcreg() {
    local -a sub=(
        'config:configuration'
        'create:create a new client'
        'get:fetch a registered client'
        'update:update a registered client'
        'delete:delete a registered client'
        'attrs:list available attributes'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[url]:str:' \
        '-s+[server]:str:' \
        '--realm=+[name]:str:' \
        '-r+[realm]:str:' \
        '--user=+[user]:str:' \
        '-u+[user]:str:' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--client=+[client]:str:' \
        '--secret=+[secret]:str:' \
        '--token=+[token]:str:' \
        '--initial-token=+[token]:str:' \
        '--registration-access-token=+[token]:str:' \
        '--config-file=+[file]:file:_files' \
        '-c+[config file]:file:_files' \
        '--truststore=+[file]:file:_files -g "*.jks *.pkcs12 *.p12"' \
        '--trustpass=+[password]:str:' \
        '-o+[output]:f:(json table)' \
        '--output=+[format]:f:(json table)' \
        '-f+[file]:file:_files -g "*.json"' \
        '--file=+[file]:file:_files -g "*.json"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kcreg subcommand' sub ;;
    esac
}

_kcreg "$@"
