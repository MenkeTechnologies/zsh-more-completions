#compdef freedm
# Documentation: https://manpages.debian.org/bookworm/freedm/freedm.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm freedm(6) manpage. Wrapper script; engine
# selected via -p / $DOOMPORT / ~/.doomport symlink. All args after
# -- are forwarded to the underlying Doom engine.
# Removed from prior file: bogus man.archlinux.org search URL.

# freedm: FreeDM deathmatch wad launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[Doom engine to use (precedence over env/symlink)]:engine:(prboom prboom-plus zandronum chocolate-doom crispy-doom)' \
  '--[forward following args to engine]' \
  '*:engine arg:_files' && ret=0
return ret
