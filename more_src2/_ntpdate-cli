#compdef ntpdate-cli
# _ntpdate-cli — NTP Project ntpdate set date/time via NTP CLI alias (ntp team, C); custom argparse
# upstream: https://github.com/ntp-project/ntp

_ntpdate-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '-a+[auth key]:n:' \
        '-B[force slew]' \
        '-b[force step]' \
        '-d[debug]' \
        '-e+[auth delay]:n:' \
        '-k+[keys file]:file:_files' \
        '-o+[version]:n:' \
        '-p+[samples]:n:' \
        '-q[query only]' \
        '-s[log via syslog]' \
        '-t+[timeout seconds]:n:' \
        '-u[use unprivileged port]' \
        '-v[verbose]' \
        '*:servers:_hosts'
}

_ntpdate-cli "$@"
