#compdef jbigtopnm
# Documentation: man jbigtopnm (Netpbm)
# Source: convert a JBIG (Joint Bi-level Image) file to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-xmax+[max output width pixels]:n:' \
    '-ymax+[max output height pixels]:n:' \
    '-binary[force binary output]' \
    '-diagnose[diagnostic mode]' \
    '-plane+[output single plane]:plane:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:jbig input file:_files -g "*.(jbg|jbig)"' \
    '2:output file:_files' \
    && ret=0

return ret
