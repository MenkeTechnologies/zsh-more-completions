#compdef ethkey rlpdump
# Documentation: upstream cmd/{ethkey,rlpdump}/main.go at github.com/ethereum/go-ethereum
# Reference accessed: 2026-05-30
# Continuation of go-ethereum sister-binary R40. Both ship alongside
# the previously-covered _geth/_abigen/_clef/_devp2p binaries.

local curcontext="$curcontext" state line ret=1

case $service in

  ethkey)
    # ethereum/go-ethereum ethkey — key management utility.
    local -a _subcmds
    _subcmds=(
      'generate:generate a new keyfile'
      'inspect:inspect a keyfile'
      'changepassphrase:change the passphrase on a keyfile'
      'signmessage:sign a message with a keyfile'
      'verifymessage:verify a signed message'
    )
    _arguments -C -s -S \
      '--passwordfile=[file containing the password for the keyfile]:file:_files' \
      '--json[output JSON instead of human-readable format]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'ethkey subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

  rlpdump)
    # ethereum/go-ethereum rlpdump — RLP encoding/decoding tool.
    _arguments -s -S \
      '-hex=[dump given hex data]:hex:' \
      '-reverse[convert ASCII to RLP]' \
      '-noascii[do not print ASCII strings readably]' \
      '-single[print only the first element, discard the rest]' \
      '-pos[display element byte positions]' \
      '*:input file:_files' \
      && ret=0
    ;;

esac

return ret
