#compdef droid
# Documentation: https://factory.mintlify.app/reference/cli-reference
# Reference accessed: 2026-05-22
# Verified: upstream Factory Droid CLI reference at the URL above.

# Zsh completion for droid - Factory AI coding agent CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --file)'{-f,--file}'[read prompt from file]:file:_files' \
  '(-m --model)'{-m,--model}'[select model ID]:model:' \
  '(-s --session-id)'{-s,--session-id}'[continue existing session]:session:' \
  '(-r --resume)'{-r,--resume}'[resume previous session]' \
  '(-w --worktree)'{-w,--worktree}'[run in git worktree]:name:' \
  '(-o --output-format)'{-o,--output-format}'[output format]:format:(text json stream-json stream-jsonrpc)' \
  '--auto[autonomy level]:level:(low medium high)' \
  '--enabled-tools[force-enable tools]:tools:' \
  '--disabled-tools[disable tools]:tools:' \
  '--list-tools[list available tools and exit]' \
  '--input-format[input format]:format:(stream-jsonrpc)' \
  '--reasoning-effort[reasoning effort]:level:(off none low medium high)' \
  '--spec-model[model for spec mode]:model:' \
  '--spec-reasoning-effort[reasoning effort for spec]:level:(off none low medium high)' \
  '--use-spec[start in specification mode]' \
  '--skip-permissions-unsafe[skip all permission prompts]' \
  '--cwd[working directory]:directory:_directories' \
  '--tag[session tag (repeatable)]:tag:' \
  '--log-group-id[log group ID]:id:' \
  '--fork[fork and resume session]:session:' \
  '--mission[run in mission mode]' \
  '--worker-model[mission worker model]:model:' \
  '--worker-reasoning-effort[worker reasoning effort]:level:(off none low medium high)' \
  '--validator-model[mission validator model]:model:' \
  '--validator-reasoning-effort[validator reasoning effort]:level:(off none low medium high)' \
  '--append-system-prompt[append to system prompt]:text:' \
  '--append-system-prompt-file[append file to system prompt]:file:_files' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'droid command' \
      'exec[non-interactive task execution]' \
      'search[search local sessions]' \
      'find[alias for search]' \
      'mcp[manage MCP servers]' \
      'plugin[manage plugins]' \
      'computer[bring-your-own-machine registration]' \
      'daemon[run Factory daemon server]' \
      'update[update CLI to latest version]' && ret=0
    ;;
  args)
    case $line[1] in
      search|find)
        _arguments \
          '--kind[filter entry kind]:kind:(message_text document tool_use tool_result all)' \
          '--limit-sessions[max sessions to return]:n:' \
          '--limit-hits[max matches per kind]:n:' \
          '--context-chars[context chars around match]:n:' \
          '--json[emit JSON results]' \
          '--reindex[rebuild local search index]' && ret=0
        ;;
      mcp)
        if (( CURRENT == 3 )); then
          _values 'mcp action' add remove && ret=0
        elif [[ $line[2] == add ]]; then
          _arguments \
            '1:server name:' \
            '2:URL or command:' \
            '--type[transport type]:type:(http stdio)' \
            '*--env[stdio env KEY=value]:env:' \
            '*--header[HTTP header]:header:' && ret=0
        fi
        ;;
      plugin)
        if (( CURRENT == 3 )); then
          _values 'plugin action' install uninstall update list marketplace && ret=0
        elif [[ $line[2] == (install|i|uninstall|remove|update) ]]; then
          _arguments \
            '1:plugin:' \
            '(-s --scope)'{-s,--scope}'[installation scope]:scope:(user project)' && ret=0
        fi
        ;;
      computer)
        if (( CURRENT == 3 )); then
          _values 'computer action' register remove list ssh && ret=0
        elif [[ $line[2] == register ]]; then
          _arguments \
            '1:machine name:' \
            '(-y --yes)'{-y,--yes}'[skip interactive prompts]' && ret=0
        elif [[ $line[2] == ssh ]]; then
          _arguments '1:computer name:' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
