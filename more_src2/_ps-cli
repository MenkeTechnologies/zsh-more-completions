#compdef ps-cli
# _ps-cli — procps ps report process status snapshot CLI alias (procps team, C); custom argparse
# upstream: https://gitlab.com/procps-ng/procps

_ps-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[all with tty except session leaders]' \
        '-A[all processes]' \
        '-d[all except session leaders]' \
        '-e[all processes]' \
        '-N[negate selection]' \
        '--deselect[negate selection]' \
        '-C+[command names]:str:' \
        '-G+[real group]:str:' \
        '--Group=+[real group]:str:' \
        '-g+[session/groups]:str:' \
        '--group=+[effective group]:str:' \
        '-p+[pids]:str:' \
        '--pid=+[pids]:str:' \
        '--ppid=+[ppid]:str:' \
        '-q+[pids quick]:str:' \
        '--quick-pid=+[pids quick]:str:' \
        '-s+[session ids]:str:' \
        '--sid=+[session ids]:str:' \
        '-t+[ttys]:str:' \
        '--tty=+[ttys]:str:' \
        '-u+[effective users]:str:' \
        '--user=+[effective users]:str:' \
        '-U+[real users]:str:' \
        '--User=+[real users]:str:' \
        '-F[extra full format]' \
        '-f[full format]' \
        '-j[jobs format]' \
        '-l[long format]' \
        '-M[security data]' \
        '-O+[format]:str:' \
        '-o+[user defined format]:str:' \
        '--format=+[user defined format]:str:' \
        '-y[no flags]' \
        '-Z[security data]' \
        '--context[security data]' \
        '-H[show tree]' \
        '--forest[show tree]' \
        '-n+[namelist]:file:_files' \
        '--no-headers[no headers]' \
        '-w[wide]' \
        '--cols=+[width]:n:' \
        '--columns=+[width]:n:' \
        '--width=+[width]:n:' \
        '--rows=+[height]:n:' \
        '--sort=+[spec]:str:' \
        '--cumulative[include child times]' \
        '--headers[repeat headers]' \
        '--lines=+[height]:n:' \
        '-c[different scheduling info]' \
        '-T[show all threads]' \
        '-L[show threads]' \
        '-m[show threads after]' \
        '-r[restrict to running]' \
        '*:arg:'
}

_ps-cli "$@"
