# =============================================================================
# matano — Open-source security data lake for threat hunting, detection &
#          response, and cybersecurity analytics.  Deploys to AWS via CDK
#          and orchestrates a serverless pipeline: ingests logs from S3/
#          Kinesis/SQS, normalizes via VRL transformations, lands them in
#          Iceberg tables on S3, and exposes them for Athena/Spark queries.
#          Used by security teams as a self-hosted alternative to Splunk/
#          Datadog Cloud SIEM at fractional cost.
#
# Author:  Matano Labs (security data platform startup)
# Source:  https://github.com/matanolabs/matano
# CLI:     cli/src/commands/ (uses @oclif/core)
# Library: oclif/core
#          ("Node.js Open CLI Framework. Built by Salesforce.")
# License: Apache-2.0
# Status:  Active — 1,675+ stars; used in production by multiple security
#          teams as a self-hosted SIEM lake; backed by Y Combinator and
#          security-tooling investors.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 30
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 30TH TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 29 to 30 documented libraries (oclif via matano).  New leaderboard:
# Rust=30, Go=30, TypeScript-Node=30 — THREE-WAY TIE RESTORED at the
# ROUND-NUMBER MILESTONE of 30 documented CLI library variants for EACH
# of the three top languages.  Taxonomy now spans 231 cross-language CLI
# library variants across 55 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS oclif/core AND WHY IS IT A DISTINCT 30TH TS-NODE CLI LIBRARY?
#
# oclif (https://github.com/oclif/core, 301+ stars on core; @oclif/oclif
# scaffolder is separate) is the **Open CLI Framework, originally created
# by Heroku and currently maintained by SALESFORCE**.  oclif is THE
# canonical Salesforce/Heroku CLI infrastructure: every `heroku` and
# `sfdx` (Salesforce Developer Experience) CLI subcommand runs through
# oclif.  oclif is also the foundation for Twilio CLI, Hyperledger Fabric
# CLI, Adobe IO CLI, AWS Amplify CLI, NetApp ONTAP CLI, and many other
# enterprise CLI tools.
#
# oclif is FUNDAMENTALLY a CLI FRAMEWORK, not just a parser.  It bundles:
#
#   * Argument parsing (flags + args)
#   * Plugin architecture (install/uninstall plugins from npm)
#   * Hook system (prerun, postrun, init, command_not_found, etc.)
#   * Help text generation with topic-based grouping
#   * Auto-update mechanism (CLI can self-update from npm)
#   * Telemetry hooks for usage analytics
#   * Manifest caching for fast startup
#   * Topic separator customization (defaults to `:`)
#   * Colon-namespaced subcommands as a FIRST-CLASS concept
#   * Argument validation with custom flag types
#   * Custom error handling with helpful suggestions
#   * Multi-CLI scaffolding (`oclif generate`)
#
# oclif is DISTINCT from every other documented TS-Node CLI library on
# SEVEN specific axes:
#
#   1. ENTERPRISE-CLI-FRAMEWORK POSITIONING — oclif is the FIRST documented
#      TS-Node "CLI framework" rather than "CLI library."  Where libraries
#      like cleye R472, citty R476, stricli R466 give you a parser and let
#      you wire it up to your CLI, oclif gives you a SCAFFOLDED PROJECT
#      with directory conventions, plugin architecture, and lifecycle
#      hooks.  Created Heroku CLI as the dogfood project; Salesforce
#      acquired Heroku and continued investing in oclif as their CLI
#      foundation.
#
#   2. CLASS-BASED COMMAND DEFINITION (similar to clipanion R480) — oclif
#      commands extend `Command`:
#         export default class Deploy extends Command {
#             static description = "Deploys matano.";
#             static examples = ["matano deploy", "matano deploy --profile prod"];
#             static flags = {
#                 profile: Flags.string({ char: "p", description: "AWS Profile" }),
#                 "user-directory": Flags.string({ required: false }),
#             };
#             async run() { /* handler */ }
#         }
#      Similar to clipanion R480 but with KEY differences (see #3, #4).
#
#   3. FILE-SYSTEM-BASED COMMAND DISCOVERY — oclif commands live in
#      `src/commands/<name>.ts` with the file path becoming the command
#      path.  `src/commands/deploy.ts` registers a `deploy` command;
#      `src/commands/generate/aws.ts` registers a `generate:aws` colon-
#      namespaced command.  This is FILESYSTEM-AS-ROUTING — analogous
#      to Next.js's pages/ directory but for CLI subcommands.  NO OTHER
#      documented TS-Node CLI library uses filesystem routing.
#
#   4. PLUGIN ARCHITECTURE — oclif CLIs can install plugins as npm
#      packages: `matano plugins:install @oclif/plugin-warn-if-update-
#      available`.  Each plugin contributes its own commands to the
#      CLI's command tree.  Plugins are loaded LAZILY (only when their
#      commands are invoked), keeping startup fast even with many
#      installed plugins.  Heroku CLI uses this extensively to ship
#      `heroku-deploy`, `heroku-pipelines`, `heroku-buildpack-registry`,
#      etc. as separate plugins.  NO OTHER documented TS-Node CLI
#      library has a plugin architecture at this scale.
#
#   5. COLON-NAMESPACED COMMANDS AS FIRST-CLASS — oclif uses `:` (or
#      configurable separator) to namespace commands: `heroku apps:create`,
#      `sfdx force:apex:test:run`, `matano generate:aws-detection-config`.
#      The colon-namespacing is encoded in package.json's `oclif.
#      topicSeparator` and `oclif.topics`.  Commando (R487 Go) has a
#      similar convention but as a NAMING choice; oclif makes it a
#      FRAMEWORK-LEVEL feature with auto-generated help grouping.
#
#   6. HOOK SYSTEM — oclif has lifecycle hooks: `init` (before any
#      command), `prerun` (before each command), `postrun` (after each
#      command), `command_not_found` (when user types nonexistent
#      command), `update` (on auto-update events).  Hooks are
#      registered in package.json's `oclif.hooks` and live as separate
#      TypeScript files.  matano uses `prerun` for telemetry:
#         "hooks": {
#             "prerun": "./dist/hooks/metadata-reporting",
#             "init": "./dist/hooks/metadata-reporting-info"
#         }
#      Useful for cross-cutting concerns (telemetry, auth refresh,
#      version warnings) that would otherwise require wrapping every
#      command handler.
#
#   7. `Flags.string`/`Flags.boolean`/`Flags.integer`/etc. AS FACTORY
#      FUNCTIONS — flag declarations use factory function calls:
#         Flags.string({ char: "p", description: "..." })
#         Flags.boolean({ char: "v" })
#         Flags.integer({ default: 3, min: 1, max: 10 })
#      Each Flag factory returns a typed Flag<T> object that oclif
#      assembles into the command's static `flags` object.  Compare
#      cleye R472 which uses Type constructors (`type: Number`); citty
#      R476 which uses string literals (`type: "number"`); clipanion
#      R480 which uses Option factories on class fields (`= Option.
#      Boolean(...)`).  oclif's Flags factory style is closer to
#      clipanion but produces inert data objects rather than Option
#      instances; the data objects are assembled into the command's
#      schema at parse time.
#
# THE oclif API SURFACE (verbatim from matano usage)
#
#   import { Command, Flags } from "@oclif/core";
#   import BaseCommand from "../base";
#
#   export default class Deploy extends BaseCommand {
#       static description = "Deploys matano.";
#       static examples = [
#           "matano deploy",
#           "matano deploy --profile prod",
#       ];
#       static flags = {
#           ...BaseCommand.flags,
#           profile: Flags.string({
#               char: "p",
#               description: "AWS Profile to use for credentials.",
#           }),
#           "user-directory": Flags.string({
#               required: false,
#               description: "Matano user directory to use.",
#           }),
#       };
#
#       async run() {
#           const { flags } = await this.parse(Deploy);
#           // flags.profile, flags["user-directory"]
#       }
#   }
#
# Command class lifecycle:
#   constructor(argv, config) — receives argv + oclif config
#   async init() — pre-run setup
#   async run() — main handler
#   async catch(error) — error handler
#   async finally() — cleanup
#
# Flags factory variants:
#   Flags.string({...})       — string flag
#   Flags.boolean({...})      — boolean flag (no value)
#   Flags.integer({...})      — integer flag
#   Flags.option({...})       — enum (with options array)
#   Flags.file({...})         — file path with existence validation
#   Flags.directory({...})    — directory path with existence validation
#   Flags.url({...})          — URL with validation
#   Flags.help({...})         — auto-generates --help
#   Flags.version({...})      — auto-generates --version
#   Flags.custom({...})       — custom parser via parse function
#
# Args (positional, separate from flags):
#   Args.string({...})         — positional string arg
#   Args.integer({...})        — positional integer arg
#   Args.file({...})           — positional file arg
#   Args.directory({...})      — positional directory arg
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander.js (fluent), yargs (chainable), minimist (pure parser),
#     arg (small), meow (yargs wrap), mri (minimist successor), caporal,
#     nopt, cmd-ts, clipanion R480 (class-based, Yarn Berry),
#     citty R476 (defineCommand UnJS), cac, sade, type-flag, vorpal R442,
#     gluegun (full framework), stricli R466 (Bloomberg zero-dep),
#     cleye R472 (TS-first), command-line-args R484 (UNIX-decomposed),
#     cliffy R488 (Deno-first), oclif (THIS, enterprise CLI framework
#                                  with plugins/hooks/scaffolding)
#
# oclif is the FIRST documented TS-Node CLI FRAMEWORK (vs library).
# clipanion R480 is class-based like oclif but more LIBRARY (no plugins,
# no hooks, no scaffolding).  oclif is closer to **Java's Spring Boot
# CLI** or **Python's Click framework** than to other TS CLI libraries —
# its design assumes you're building a LARGE, MULTI-COMMAND CLI with
# enterprise concerns like plugin distribution and telemetry.
#
# REAL-WORLD oclif USERS:
#
#   * heroku/cli — Heroku CLI (the original dogfood project, in corpus)
#   * salesforcecli/sfdx — Salesforce Developer Experience (sfdx)
#   * matanolabs/matano — security data lake (THIS, 1675*)
#   * fonoster/routr — programmable SIP server (1683*)
#   * segmentio/typewriter — Segment Analytics typewriter (242*)
#   * twilio/twilio-cli — Twilio CLI (in corpus)
#   * adobe/aio-cli — Adobe IO CLI
#   * aws-amplify/amplify-cli — AWS Amplify CLI (in corpus)
#   * netapp/ontap — NetApp ONTAP CLI
#   * synmetrix/synmetrix — analytics platform
#   * prismatic-io/prism — Prismatic.io CLI
#   * inkdevhub/swanky-cli — Substrate smart contracts dev (71*)
#   * hightouchio/cli — Hightouch reverse ETL CLI
#   * knocklabs/knock-cli — Knock notifications CLI
#   * apimatic/apimatic-cli — APIMatic CLI
#   * Hundreds of other enterprise CLIs across npm
#
# -----------------------------------------------------------------------------
# MATANO'S CLI SURFACE (verbatim from cli/src/commands/)
# -----------------------------------------------------------------------------
#
# USAGE:
#   matano [TOPIC:]<COMMAND> [OPTIONS]
#
# Top-level commands:
#   deploy                       Deploys matano (provisions AWS infra
#                                via CDK)
#   destroy                      Tears down matano AWS infrastructure
#   diff                         Shows pending changes in matano config
#                                vs deployed state
#   info                         Shows info about the deployed matano
#                                installation (account, region, ARNs)
#   init                         Initializes a new matano user directory
#                                with example configs
#   refresh-context              Refreshes locally cached matano context
#                                (used after deploy when other tools
#                                need to know the deployed resource IDs)
#   disable-metadata-reporting   Opt out of telemetry data sent to
#                                Matano Labs
#
# Topic: generate (utilities to generate boilerplate):
#   generate:aws-config             Generate AWS config skeleton
#   generate:aws-detection-config   Generate AWS detection rule scaffolds
#   generate:matano-detection       Generate matano detection rule
#   generate:matano-log-source      Generate matano log source config
#
# Common flags (inherited from BaseCommand):
#   -p, --profile <NAME>         AWS Profile to use for credentials
#   --user-directory <DIR>       Matano user directory to use
#                                (path to a matano config directory)
#   -h, --help                   Show help and exit
#   -v, --version                Show version and exit
#
# Plugin commands (added by @oclif/plugin-help and @oclif/plugin-autocomplete):
#   help [COMMAND]                       Show help for a command
#   autocomplete                          Display autocomplete installation
#                                         instructions
#   plugins:install <PLUGIN>             Install an oclif plugin from npm
#   plugins:uninstall <PLUGIN>           Uninstall an oclif plugin
#   plugins:list                          List installed plugins
#   plugins:update                        Update installed plugins
#
# Environment variables (read by hooks):
#   MATANO_DISABLE_METADATA_REPORTING    Disable telemetry (alternative to
#                                         disable-metadata-reporting command)
#   DEBUG                                 Enable debug logging
#
# =============================================================================

_matano() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a topics commands generate_subs plugins_subs

    commands=(
        'deploy:deploys matano (provisions AWS infra via CDK)'
        'destroy:tears down matano AWS infrastructure'
        'diff:shows pending changes in matano config vs deployed state'
        'info:shows info about deployed matano installation'
        'init:initializes a new matano user directory'
        'refresh-context:refreshes locally cached matano context'
        'disable-metadata-reporting:opt out of telemetry'
        'generate:utilities to generate boilerplate'
        'help:show help for a command'
        'autocomplete:autocomplete installation instructions'
        'plugins:manage installed plugins'
    )

    generate_subs=(
        'aws-config:generate AWS config skeleton'
        'aws-detection-config:generate AWS detection rule scaffolds'
        'matano-detection:generate matano detection rule'
        'matano-log-source:generate matano log source config'
    )

    plugins_subs=(
        'install:install an oclif plugin from npm'
        'uninstall:uninstall an oclif plugin'
        'list:list installed plugins'
        'update:update installed plugins'
    )

    _arguments -C \
        '(-p --profile)'{-p,--profile}'[AWS Profile to use for credentials]:profile:' \
        '--user-directory[matano user directory]:dir:_directories' \
        '(-h --help)'{-h,--help}'[show help and exit]' \
        '(-v --version)'{-v,--version}'[show version and exit]' \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'matano command' commands && ret=0
            ;;
        (args)
            case $line[1] in
                (generate)
                    _describe -t generate_subs 'generate subcommand' generate_subs && ret=0
                    ;;
                (plugins)
                    _describe -t plugins_subs 'plugins subcommand' plugins_subs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_matano "$@"
