#compdef gardener-extension-admission-aws
# _gardener-extension-admission-aws — Gardener AWS admission webhook
# upstream: https://github.com/gardener/gardener-extension-provider-aws
# Flag families from gardener extensions/pkg/controller/cmd Options on tip.

_gardener-extension-admission-aws() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-id=[leader-election lease name]:id:' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--webhook-config-server-host=[webhook server bind host]:host:' \
        '--webhook-config-server-port=[webhook server bind port]:port:' \
        '--webhook-config-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-bind-address=[health probe bind host\:port]:host\:port:' \
        '--log-level=[log level]:level:(debug info error)' \
        '--log-format=[log format]:fmt:(json text)' \
        '--gardener-version=[gardenlet/gardener-operator version]:ver:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--master=[Kubernetes API server URL]:url:_urls' \
        '*--webhooks=[csv of webhooks to enable]:csv:' \
        '*--disable-webhooks=[csv of webhooks to disable]:csv:' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '--version[print version and exit]' \
        '-v[klog verbosity level]:n:'
}

_gardener-extension-admission-aws "$@"
