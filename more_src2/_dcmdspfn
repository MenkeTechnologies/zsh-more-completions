#compdef dcmdspfn
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmdspfn.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmimgle/apps/dcmdspfn.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmimgle/apps/dcmdspfn.cc OFCommandLine setup + docs/man/dcmdspfn.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+Im --monitor-file)'{+Im+,--monitor-file=}'[text file describing the monitor characteristics]:filename:_files' \
  '(+Ic --camera-file)'{+Ic+,--camera-file=}'[text file describing the camera characteristics]:filename:_files' \
  '(+Ip --printer-file)'{+Ip+,--printer-file=}'[text file describing the printer characteristics]:filename:_files' \
  '(+Is --scanner-file)'{+Is+,--scanner-file=}'[text file describing the scanner characteristics]:filename:_files' \
  '(+Il --lum-range)'{+Il+,--lum-range=}'[minimum and maximum luminance (cd/m^2)]:min max:' \
  '(+Io --od-range)'{+Io+,--od-range=}'[minimum and maximum optical density (OD)]:min max:' \
  '(+Ca --ambient-light)'{+Ca+,--ambient-light=}'[ambient light value (cd/m^2, default: file f)]:a:' \
  '(+Ci --illumination)'{+Ci+,--illumination=}'[illumination value (cd/m^2, default: file f)]:i:' \
  '(+Dn --min-density)'{+Dn+,--min-density=}'[Dmin value (default: off, only with +Ip and +Io)]:m:' \
  '(+Dx --max-density)'{+Dx+,--max-density=}'[Dmax value (default: off, only with +Ip and +Io)]:m:' \
  '(+Cd --ddl-count)'{+Cd+,--ddl-count=}'[number of Digital Driving Levels (default: 256)]:n:' \
  '(+Cf --curve-fitting)'{+Cf+,--curve-fitting=}'[use polynomial curve fitting algorithm with order n (0..99)]:n:' \
  '(+Og --gsdf)'{+Og+,--gsdf=}'[write GSDF curve data to file f]:filename:_files' \
  '(+Oc --cielab)'{+Oc+,--cielab=}'[write CIELAB curve data to file f]:filename:_files'
