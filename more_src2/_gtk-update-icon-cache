#compdef gtk-update-icon-cache gtk4-update-icon-cache
# Documentation: gtk-update-icon-cache --help (GTK)
# Source: GTK gtk-update-icon-cache — build per-theme icon-cache for an icon-theme directory.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --force)'{-f,--force}'[overwrite existing cache even if up to date]' \
    '(-t --ignore-theme-index)'{-t,--ignore-theme-index}'[skip index.theme existence check]' \
    '(-i --index-only --include-image-data)'{-i,--index-only}'[do not include image data]' \
    '(-i --index-only --include-image-data)--include-image-data[include image data in the cache]' \
    '(-c --source)'{-c,--source=}'[output a C header file with this variable name]:name:' \
    '(-q --quiet)'{-q,--quiet}'[turn off verbose output]' \
    '(-v --validate)'{-v,--validate}'[validate existing icon cache]' \
    '(- *)'{-h,--help}'[show help options]' \
    '*:icon-theme directory:_files -/' \
    && ret=0

return ret
