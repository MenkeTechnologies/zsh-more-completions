#compdef ewfmount
# Documentation: https://github.com/libyal/libewf
# Source: libyal/libewf manuals/ewfmount.1 — FUSE-mount an EWF E01/Ex01 image as a raw block device.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[input format]:format:(raw files)' \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-X[extended options to pass to FUSE]:fuse opts:' \
    '*:EWF image then mountpoint:_files' \
    && ret=0

return ret
