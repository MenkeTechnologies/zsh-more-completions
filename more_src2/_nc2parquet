autoload -U is-at-least

_nc2parquet() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--output-format=[Output format for structured data]:OUTPUT_FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'-c+[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--config=[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'-v[Enable verbose logging]' \
'--verbose[Enable verbose logging]' \
'(-v --verbose)-q[Quiet mode - suppress all output except errors]' \
'(-v --verbose)--quiet[Quiet mode - suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_nc2parquet_commands" \
"*::: :->nc2parquet" \
&& ret=0
    case $state in
    (nc2parquet)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:nc2parquet-command-$line[1]:"
        case $line[1] in
            (convert)
_arguments "${_arguments_options[@]}" : \
'-n+[NetCDF variable name to extract]:VARIABLE:_default' \
'--variable=[NetCDF variable name to extract]:VARIABLE:_default' \
'--input-override=[Override input path from config]:INPUT_OVERRIDE:_default' \
'--output-override=[Override output path from config]:OUTPUT_OVERRIDE:_default' \
'*--range=[Apply range filter\: dimension\:min\:max]:RANGE_FILTERS:_default' \
'*--list=[Apply list filter\: dimension\:val1,val2,val3]:LIST_FILTERS:_default' \
'*--point2d=[Apply 2D point filter\: lat_dim,lon_dim\:lat,lon\:tolerance]:POINT2D_FILTERS:_default' \
'*--point3d=[Apply 3D point filter\: time_dim,lat_dim,lon_dim\:time,lat,lon\:tolerance]:POINT3D_FILTERS:_default' \
'*--rename=[Rename column\: old_name\:new_name (can be used multiple times)]:RENAME_COLUMNS:_default' \
'*--unit-convert=[Convert column units\: column\:from_unit\:to_unit]:UNIT_CONVERSIONS:_default' \
'*--kelvin-to-celsius=[Convert temperature from Kelvin to Celsius for given column]:KELVIN_TO_CELSIUS:_default' \
'*--formula=[Apply mathematical formula\: target_column\:formula\:source1,source2,...]:FORMULAS:_default' \
'*-N+[Extract multiple variables in one pass (comma-delimited, e.g. "temperature,pressure"). When set, all listed variables are written as separate columns into one Parquet file. All variables must have the same dimensions as each other]:VARIABLES:_default' \
'*--variables=[Extract multiple variables in one pass (comma-delimited, e.g. "temperature,pressure"). When set, all listed variables are written as separate columns into one Parquet file. All variables must have the same dimensions as each other]:VARIABLES:_default' \
'--glob=[Process all files matching this glob pattern (e.g. "data/**/*.nc"). When set, the OUTPUT argument is treated as an output directory]:PATTERN:_default' \
'--compression=[Parquet compression codec\: snappy, zstd, gzip, lz4, uncompressed]:CODEC:_default' \
'--compression-level=[Compression level (Zstd\: 1-22, Gzip\: 0-9; not valid for snappy/lz4/uncompressed)]:LEVEL:_default' \
'--row-group-size=[Row group size in number of rows]:ROWS:_default' \
'--output-format=[Output format for structured data]:OUTPUT_FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'-c+[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--config=[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--force[Force overwrite existing output files]' \
'--dry-run[Dry run - validate configuration without processing]' \
'--no-statistics[Disable writing column statistics (min, max, null count)]' \
'-v[Enable verbose logging]' \
'--verbose[Enable verbose logging]' \
'(-v --verbose)-q[Quiet mode - suppress all output except errors]' \
'(-v --verbose)--quiet[Quiet mode - suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::input -- Input NetCDF file path (local or S3):_default' \
'::output -- Output Parquet file path (local or S3):_default' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'--output-format=[Output format for structured data]:OUTPUT_FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'-c+[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--config=[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--detailed[Show detailed validation report]' \
'-v[Enable verbose logging]' \
'--verbose[Enable verbose logging]' \
'(-v --verbose)-q[Quiet mode - suppress all output except errors]' \
'(-v --verbose)--quiet[Quiet mode - suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'::config_file -- Configuration file to validate:_files' \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
'-n+[Show only specific variable info]:VARIABLE:_default' \
'--variable=[Show only specific variable info]:VARIABLE:_default' \
'--format=[Output format for file information]:FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'--output-format=[Output format for structured data]:OUTPUT_FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'-c+[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--config=[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--detailed[Show detailed variable information]' \
'-v[Enable verbose logging]' \
'--verbose[Enable verbose logging]' \
'(-v --verbose)-q[Quiet mode - suppress all output except errors]' \
'(-v --verbose)--quiet[Quiet mode - suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':file -- NetCDF file path (local or S3):_default' \
&& ret=0
;;
(template)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file path (default\: stdout)]:OUTPUT:_files' \
'--output=[Output file path (default\: stdout)]:OUTPUT:_files' \
'--format=[Configuration format]:FORMAT:((json\:"JSON configuration format"
yaml\:"YAML configuration format"))' \
'--output-format=[Output format for structured data]:OUTPUT_FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'-c+[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--config=[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'-v[Enable verbose logging]' \
'--verbose[Enable verbose logging]' \
'(-v --verbose)-q[Quiet mode - suppress all output except errors]' \
'(-v --verbose)--quiet[Quiet mode - suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':template_type -- Template type to generate:((basic\:"Basic conversion template"
s3\:"S3 storage template"
multi-filter\:"Multi-filter template"
weather\:"Weather data template"
ocean\:"Ocean data template"))' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file path (default\: stdout)]:OUTPUT:_files' \
'--output=[Output file path (default\: stdout)]:OUTPUT:_files' \
'--output-format=[Output format for structured data]:OUTPUT_FORMAT:((human\:"Human-readable output"
json\:"JSON structured output"
yaml\:"YAML structured output"
csv\:"CSV output (where applicable)"))' \
'-c+[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'--config=[Configuration file path (JSON or YAML)]:CONFIG:_files' \
'-v[Enable verbose logging]' \
'--verbose[Enable verbose logging]' \
'(-v --verbose)-q[Quiet mode - suppress all output except errors]' \
'(-v --verbose)--quiet[Quiet mode - suppress all output except errors]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_nc2parquet__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:nc2parquet-help-command-$line[1]:"
        case $line[1] in
            (convert)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(info)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(template)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_nc2parquet_commands] )) ||
_nc2parquet_commands() {
    local commands; commands=(
'convert:Convert NetCDF files to Parquet format' \
'validate:Validate configuration file or arguments' \
'info:Show information about NetCDF file' \
'template:Generate configuration templates' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'nc2parquet commands' commands "$@"
}
(( $+functions[_nc2parquet__completions_commands] )) ||
_nc2parquet__completions_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet completions commands' commands "$@"
}
(( $+functions[_nc2parquet__convert_commands] )) ||
_nc2parquet__convert_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet convert commands' commands "$@"
}
