(( $+functions[_nc2parquet__help__help_commands] )) ||
_nc2parquet__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet help help commands' commands "$@"
}
(( $+functions[_nc2parquet__help__info_commands] )) ||
_nc2parquet__help__info_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet help info commands' commands "$@"
}
(( $+functions[_nc2parquet__help__template_commands] )) ||
_nc2parquet__help__template_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet help template commands' commands "$@"
}
(( $+functions[_nc2parquet__help__validate_commands] )) ||
_nc2parquet__help__validate_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet help validate commands' commands "$@"
}
(( $+functions[_nc2parquet__info_commands] )) ||
_nc2parquet__info_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet info commands' commands "$@"
}
(( $+functions[_nc2parquet__template_commands] )) ||
_nc2parquet__template_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet template commands' commands "$@"
}
(( $+functions[_nc2parquet__validate_commands] )) ||
_nc2parquet__validate_commands() {
    local commands; commands=()
    _describe -t commands 'nc2parquet validate commands' commands "$@"
}

if [ "$funcstack[1]" = "_nc2parquet" ]; then
    _nc2parquet "$@"
else
    compdef _nc2parquet nc2parquet
fi
