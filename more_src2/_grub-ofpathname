#compdef grub-ofpathname
# Documentation: https://man.archlinux.org/man/grub-ofpathname.8.en
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# grub-ofpathname: print OpenFirmware path for a device
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-?[show help]' \
  '(- *)-V[show version]' \
  '(- *)--usage[show usage]' \
  '1:device:_files -g "/dev/*"' && ret=0
return ret
