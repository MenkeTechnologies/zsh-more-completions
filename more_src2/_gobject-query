#compdef gobject-query
# Documentation: gobject-query --help (GLib)
# Source: GLib gobject-query — display GObject type-tree information.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a qualifiers
qualifiers=(
    'froots:iterate over fundamental roots'
    'tree:print type tree'
)

_arguments -s -C \
    '-r+[specify root type]:type:' \
    '-n[do not descend type tree]' \
    '(- *)-h[show help]' \
    '-b+[indent string]:string:' \
    '-i+[incremental indent string]:string:' \
    '-s+[line spacing]:lines:' \
    '-x[ignored / reserved]' \
    '-y[ignored / reserved]' \
    '1:qualifier:->qual' \
    && ret=0

case $state in
    qual)
        _describe -t qualifiers 'gobject-query qualifier' qualifiers && ret=0
        ;;
esac

return ret
