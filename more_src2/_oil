#compdef oil osh ysh
# Documentation: https://oils.pub/release/latest/doc/ref/chap-front-end.html
# Reference accessed: 2026-05-19
# Verified: upstream Oils frontend flag_def.py via the URL above and
# https://github.com/oilshell/oil/blob/master/frontend/flag_def.py
# Note: project renamed Oil -> Oils for Unix; binaries are osh and ysh.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[display help]' \
  '(- *)--version[display version]' \
  '-c+[execute command string]:command:' \
  '-i[interactive mode]' \
  '(-l --login)'{-l,--login}'[login shell]' \
  '-n[parse only, do not execute]' \
  '-o+[enable shell option]:option:' \
  '+o+[disable shell option]:option:' \
  '*-O+[enable Oils option]:option:' \
  '*+O+[disable Oils option]:option:' \
  '-x[print commands before execution]' \
  '-v[print input as read]' \
  '-e[exit on error]' \
  '-u[error on unset variables]' \
  '-s[read from stdin]' \
  '--rcfile=[startup file]:file:_files' \
  '--rcdir=[rc directory]:dir:_files -/' \
  '--norc[do not read rc files]' \
  '--headless[accept ECMD input]' \
  '--eval=[evaluate file before script]:file:_files' \
  '--eval-pure=[evaluate file without I/O]:file:_files' \
  '--debug-file=[debug log file]:file:_files' \
  '--xtrace-to-debug-file[send xtrace to debug file]' \
  '--ast-format=[AST output format]:format:(text abbrev-text none __perf __dumpdoc)' \
  '--tool=[run a tool instead of the shell]:tool:(tokens syntax-tree cat-em fmt lint ysh-ify deps test find-lhs-array lossless-cat)' \
  '--do-lossless[enable lossless parsing]' \
  '--completion-display=[completion style]:style:(minimal nice)' \
  '--location-str=[location string for errors]:s:' \
  '--location-start-line=[line number offset]:n:' \
  '*:script:_files' && ret=0

return ret
