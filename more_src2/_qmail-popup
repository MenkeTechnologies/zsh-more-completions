#compdef qmail-popup
# _qmail-popup — qmail's POP3 password-prompter (reads USER/PASS or APOP from descriptor 0, then execs `subprogram` with FD 3 holding "user\0pass\0apop-timestamp\0"; pairs with checkpassword + qmail-pop3d under inetd)
# upstream: https://github.com/notqmail/notqmail
# Source: qmail-popup.8 on tip; positional only — no flags.

_qmail-popup() {
    _arguments \
        '1:hostname:_hosts' \
        '*::subprogram:_command_names -e'
}

_qmail-popup "$@"
