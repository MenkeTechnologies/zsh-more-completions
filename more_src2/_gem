#compdef gem
# Documentation: https://guides.rubygems.org/command-reference/
# Source: rubygems/rubygems lib/rubygems/command_manager.rb — RubyGems CLI (Ruby).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-v --version)'{-v,--version}'[show version]' \
    '--verbose[verbose output]' \
    '--silent[no output]' \
    '--no-verbose[no verbose output]' \
    '--debug[turn on Ruby debugging]' \
    '--norc[skip loading ~/.gemrc]' \
    '1:command:(build cert check cleanup contents dependency environment exec fetch generate_index help info install list lock mirror open outdated owner pristine push rdoc rebuild search server setup signin signout sources specification stale uninstall unpack update which yank)' \
    '*::command args:->cmdargs' \
    && ret=0

return ret
