#compdef nicstat
# Documentation: https://www.mankier.com/1/nicstat
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-a[equivalent to -x -t -u]' \
  '-i+[interfaces csv]:list:_net_interfaces' \
  '-l[just list interfaces]' \
  '-M[display throughput in Mbps]' \
  '-n[non-local interfaces only]' \
  '-p[parseable output format]' \
  '-s[summary output]' \
  '-S+[Linux only: speed and duplex for interfaces]:speeds:' \
  '-t[show TCP statistics]' \
  '-u[show UDP statistics]' \
  '-U[separate read and write utilization]' \
  '-x[extended output]' \
  '-z[skip zero-traffic interfaces]' \
  '-k[Solaris only: search via kstat link_state]' \
  '*: :' && ret=0

return ret
