#compdef lockfile
# _lockfile — procmail's lockfile (create one or more NFS-safe semaphore lock files; clock-skew-immune force-removal after a timeout; commonly used to serialize shell-script access)
# upstream: https://github.com/BuGlessRB/procmail
# Flags from man/lockfile.man on tip.

_lockfile() {
    _arguments \
        '-+[sleep N seconds between retries]:sec:' \
        '-r+[number of retries (-1 = forever)]:n:' \
        '-l+[force-unlock after N seconds of staleness]:sec:' \
        '-s+[suspend after a forced unlock]:sec:' \
        '-![invert exit status]' \
        '(-ml -mu)-ml[lock the system mailbox]' \
        '(-ml -mu)-mu[unlock the system mailbox]' \
        '*:lockfile:_files'
}

_lockfile "$@"
