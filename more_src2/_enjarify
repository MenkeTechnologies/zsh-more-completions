#compdef enjarify
# Documentation: https://github.com/google/enjarify/blob/master/README.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: -q/--quiet is not documented upstream; main.py recognises only
# -o/--output, -f/--force and --fast. Keeping permissive flag set.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output JAR file]:file:_files -g "*.jar"' \
  '(-f --force)'{-f,--force}'[overwrite existing output file]' \
  '--fast[skip bytecode optimisations for speed]' \
  '*:dex/apk input:_files -g "*.(apk|dex)"' && ret=0

return ret
