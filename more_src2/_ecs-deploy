#compdef ecs-deploy
# _ecs-deploy — silinternational/ecs-deploy (bash CLI that updates an ECS service's image and waits for new task to stabilize; -c cluster, -n service, -i image, -t timeout, -m min health %, -M max %, -k aws CLI key, --use-latest-task-def, --skip-deployments-check)
# upstream: https://github.com/silinternational/ecs-deploy
# Flags from ecs-deploy bash script on tip.

_ecs-deploy() {
    _arguments \
        '-h[show help]' \
        '-c+[cluster]:cluster:' \
        '-n+[service]:service:' \
        '-i+[new image]:image:' \
        '-t+[timeout seconds]:seconds:' \
        '-m+[min healthy %]:percent:' \
        '-M+[max %]:percent:' \
        '-D+[desired-count]:n:' \
        '-r+[region]:region:' \
        '-p+[profile]:profile:' \
        '-k+[aws access key id]:key:' \
        '-s+[aws secret access key]:secret:' \
        '-e+[tag-env-var KEY=VAL]:envvar:' \
        '-v[verbose]' \
        '--task-definition+[task def ARN/family]:taskdef:' \
        '--max-definitions+[deregister older defs]:n:' \
        '--use-latest-task-def[reuse latest task def]' \
        '--force-new-deployment[force new deployment]' \
        '--skip-deployments-check[skip deployment check]' \
        '--copy-task-definition-tags[carry tags over]' \
        '--enable-rollback[rollback on failure]'
}

_ecs-deploy "$@"
