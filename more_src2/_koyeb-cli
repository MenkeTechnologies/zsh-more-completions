#compdef koyeb-cli koyeb
# _koyeb-cli — Koyeb serverless PaaS CLI alias (koyeb team, Go); cobra
# upstream: https://github.com/koyeb/koyeb-cli

_koyeb-cli() {
    local -a sub=(
        'app:apps commands'
        'apps:apps commands'
        'apps create:create app'
        'apps describe:describe app'
        'apps update:update app'
        'apps delete:delete app'
        'apps list:list apps'
        'apps get:get app'
        'apps init:init app'
        'apps pause:pause app'
        'apps resume:resume app'
        'archive:create archive'
        'archive create:create archive'
        'archive list:list archives'
        'service:services commands'
        'services:services commands'
        'services create:create service'
        'services describe:describe service'
        'services update:update service'
        'services delete:delete service'
        'services list:list services'
        'services get:get service'
        'services redeploy:redeploy service'
        'services pause:pause service'
        'services resume:resume service'
        'services exec:exec into service'
        'services logs:show logs'
        'services metrics:show metrics'
        'deployments:deployments commands'
        'deployments cancel:cancel deployment'
        'deployments describe:describe deployment'
        'deployments list:list deployments'
        'deployments get:get deployment'
        'deployments logs:show deployment logs'
        'deployments exec:exec into deployment'
        'domains:domains commands'
        'domains create:add domain'
        'domains delete:remove domain'
        'domains describe:describe domain'
        'domains list:list domains'
        'domains refresh:refresh DNS'
        'instance:instances commands'
        'instances:instances commands'
        'instances describe:describe instance'
        'instances exec:exec into instance'
        'instances list:list instances'
        'instances get:get instance'
        'organization:org commands'
        'organizations:org commands'
        'organizations describe:describe org'
        'organizations get:get org'
        'organizations members:list members'
        'organizations switch:switch org'
        'organizations rename:rename org'
        'organization invitations:list invitations'
        'organization plans:list plans'
        'login:login'
        'logout:logout'
        'whoami:show current user'
        'tokens:tokens commands'
        'tokens create:create token'
        'tokens delete:delete token'
        'tokens list:list tokens'
        'secrets:secrets commands'
        'secrets create:create secret'
        'secrets update:update secret'
        'secrets delete:delete secret'
        'secrets list:list secrets'
        'secrets reveal:reveal secret'
        'databases:databases commands'
        'databases create:create database'
        'databases delete:delete database'
        'databases describe:describe database'
        'databases get:get database'
        'databases list:list databases'
        'volumes:volumes commands'
        'volumes create:create volume'
        'volumes delete:delete volume'
        'volumes describe:describe volume'
        'volumes list:list volumes'
        'volumes get:get volume'
        'snapshots:snapshots commands'
        'snapshots create:create snapshot'
        'snapshots delete:delete snapshot'
        'snapshots list:list snapshots'
        'snapshots restore:restore snapshot'
        'metrics:show metrics'
        'regions:list regions'
        'instance-types:list instance types'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files' \
        '--debug[debug]' \
        '--debug-full[debug full]' \
        '--organization=+[org id]:str:' \
        '-o+[output format]:f:(table json yaml)' \
        '--output=+[output format]:f:(table json yaml)' \
        '--url=+[api url]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'koyeb subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_koyeb-cli "$@"
