#compdef esl-reformat
# Documentation: https://www.mankier.com/1/esl-reformat
# Reference accessed: 2026-05-17
# Verified: HMMER Easel esl-reformat(1) reference on mankier.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -d as "describe sequences only" (real -d is "DNA: U->T");
# fabricated --rna/--dna/--ignore/--acceptx/--rename (real flags are
# -r/-d/--informat/--gapsym/--mingap/--keeprf/--nogap/--wussify/
# --dewuss/--fullwuss/--replace/--small).

# esl-reformat: HMMER Easel sequence file reformatter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[DNA; convert U to T]' \
  '-l[lowercase residues]' \
  '-n[convert non-standard nucleotides to N]' \
  '-o[output file]:file:_files' \
  '-r[RNA; convert T to U]' \
  '-u[uppercase residues]' \
  '-x[convert non-IUPAC DNA chars to N]' \
  '--gapsym[gap character]:c:' \
  '--informat[input format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa clustal phylip phylips selex)' \
  '--mingap[remove all-gap columns]' \
  '--keeprf[preserve RF annotation with --mingap]' \
  '--nogap[remove any column containing gaps]' \
  '--wussify[convert to WUSS RNA structure]' \
  '--dewuss[convert from WUSS to plain]' \
  '--fullwuss[convert to full WUSS]' \
  '--replace[character substitution c1\:c2]:c1\:c2:' \
  '--small[memory-efficient mode]' \
  '*:output format and input file:_files' && ret=0
return ret
