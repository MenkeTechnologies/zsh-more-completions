#compdef greenmask
# Documentation: https://docs.greenmask.io/latest/commands/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '--config=[Greenmask config file]:file:_files -g "*.(yml|yaml)(-.)"' \
  '--log-format=[Console log format]:format:(text json)' \
  '--log-level=[Minimum log level]:level:(debug info warn error)' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'dump:Create transformed logical dumps'
      'list-dumps:List dump storage entries'
      'restore:Restore from a logical dump'
      'delete:Delete remote or local dump artifacts'
      'show-dump:Print metadata for a dump'
      'list-transformers:List built-in transformers'
      'validate:Validate a Greenmask config'
      'show-transformer:Print documentation for a transformer'
      'completion:Generate shell completions'
      'help:Help about any command'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
