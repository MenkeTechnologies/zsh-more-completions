#compdef nri-prometheus
# Documentation: https://github.com/newrelic/nri-prometheus
# Reference accessed: 2026-05-19
# Verified: upstream cmd/nri-prometheus/config.go ArgumentList struct
# (config_path takes precedence over configfile when both set).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-config_path=[path to config file]:file:_files' \
  '-configfile=[deprecated alias of -config_path]:file:_files' \
  '-nri_host_id=[host ID override when target is localhost]:host:_hosts' \
  '-verbose[print more information to logs]' \
  '-pretty[print pretty formatted JSON]' \
  '-metrics[publish metrics data]' \
  '-inventory[publish inventory data]' \
  '-events[publish events data]' \
  '-metadata[add customer-defined key-value attributes]' \
  '-nri_add_hostname[add hostname attribute to the samples]' \
  '-nri_cluster=[cluster name]:cluster:' \
  '-nri_service=[service name]:service:' \
  '*::nri-prometheus args:_files' && ret=0
return ret
