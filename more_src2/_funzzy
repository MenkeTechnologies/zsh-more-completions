#compdef funzzy
# Documentation: https://github.com/cristianoliveira/funzzy
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[verbose / version (context-dependent)]' \
  '-c+[specify config file]:config file:_files' \
  '--config=[specify config file]:config file:_files' \
  '-t+[filter tasks by target tag]:target:' \
  '--target=[filter tasks by target tag]:target:' \
  '(-b --fail-fast)'{-b,--fail-fast}'[bail execution if any task fails]' \
  '(-n --non-block)'{-n,--non-block}'[cancel running task when new file changes occur]' \
  '1:command:->cmds' \
  '*:args:' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'init:initialize a new project with boilerplate configuration'
    )
    _describe -t commands 'funzzy command' cmds && ret=0
    ;;
esac

return ret
