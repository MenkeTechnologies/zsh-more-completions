#compdef parquet-read parquet-rewrite parquet-concat parquet-schema parquet-fromcsv parquet-rowcount parquet-layout parquet-index parquet-show-bloom-filter
# Documentation: upstream parquet/src/bin/*.rs at github.com/apache/arrow-rs
# Reference accessed: 2026-05-30 via gh api inspection of each
# clap-derive #[derive(Parser)] Args struct + #[clap(...)] macros
# and the local CompressionArgs/EncodingArgs/WriterVersionArgs/
# RecordTerminator ValueEnum definitions in parquet-rewrite.rs and
# parquet-fromcsv.rs.
# Apache Arrow parquet-rs R108 — 9-stem multi-binary harvest of the
# Apache parquet-rs `cli` feature binaries (cargo install parquet
# --features=cli).

case $service in

  parquet-read)
    # Binary file to read data from a Parquet file.
    _arguments -s -S \
      '(-j --json)'{-j,--json}'[print in JSON lines format]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:parquet file (or - for stdin):_files -g "*.parquet"' \
      '2::num records:'
    ;;

  parquet-rewrite)
    # Read and write parquet file with potentially different settings.
    local -a _comp _enc _writer_ver _bloom_pos _stats
    _comp=( none snappy gzip lzo brotli lz4 zstd lz4-raw )
    _enc=( plain plain-dictionary rle bit-packed delta-binary-packed delta-length-byte-array delta-byte-array rle-dictionary byte-stream-split )
    _writer_ver=( 1.0 2.0 )
    _bloom_pos=( after-row-group end )
    _stats=( none chunk page )
    _arguments -s -S \
      '(-i --input)'{-i,--input}'=[input parquet file]:file:_files -g "*.parquet"' \
      '(-o --output)'{-o,--output}'=[output parquet file]:file:_files' \
      '--compression=[compression codec for all columns]:codec:($_comp)' \
      '--compression-level=[level for gzip/brotli/zstd]:N:' \
      '--encoding=[encoding for all columns (if dictionary disabled)]:encoding:($_enc)' \
      '--dictionary-enabled=[enable dictionary encoding]:bool:(true false)' \
      '--dictionary-page-size-limit=[max dictionary page size in bytes]:bytes:' \
      '--max-row-group-size=[max rows per row group]:N:' \
      '--data-page-row-count-limit=[max rows per data page]:N:' \
      '--data-page-size-limit=[max data page size in bytes]:bytes:' \
      '--statistics-truncate-length=[max length of min/max stats]:N:' \
      '--column-index-truncate-length=[max length of min/max stats in column index]:N:' \
      '--write-page-header-statistics=[write stats to page headers]:bool:(true false)' \
      '--write-path-in-schema=[write path_in_schema to column metadata]:bool:(true false)' \
      '--bloom-filter-enabled=[enable bloom filters for all columns]:bool:(true false)' \
      '--bloom-filter-fpp=[bloom filter false positive probability]:f:' \
      '--bloom-filter-ndv=[number of distinct values for bloom filter]:N:' \
      '--bloom-filter-position=[bloom filter position]:pos:($_bloom_pos)' \
      '--statistics-enabled=[statistics level]:level:($_stats)' \
      '--writer-version=[parquet writer version]:version:($_writer_ver)' \
      '--key-value-metadata=[KEY=VALUE metadata pairs]:kv:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]'
    ;;

  parquet-concat)
    # Concatenate one or more parquet files into one.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:output parquet file:_files' \
      '*:input parquet files:_files -g "*.parquet"'
    ;;

  parquet-schema)
    # Print the schema and metadata of a parquet file.
    _arguments -s -S \
      '(-v --verbose)'{-v,--verbose}'[enable printing full file metadata]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:parquet file:_files -g "*.parquet"'
    ;;

  parquet-fromcsv)
    # Convert CSV → Parquet.
    local -a _input_fmt _term _comp
    _input_fmt=( csv tsv )
    _term=( lf crlf )
    _comp=( uncompressed snappy gzip lzo brotli lz4 zstd lz4-raw )
    _arguments -s -S \
      '(-s --schema)'{-s,--schema}'=[parquet schema definition file]:file:_files' \
      '(-i --input-file)'{-i,--input-file}'=[input CSV file]:file:_files -g "*.(csv|tsv|txt)"' \
      '(-o --output-file)'{-o,--output-file}'=[output Parquet file]:file:_files' \
      '(-f --input-format)'{-f,--input-format}'=[input format]:format:($_input_fmt)' \
      '(-b --batch-size)'{-b,--batch-size}'=[batch size]:N:' \
      '(-h --has-header)'{-h,--has-header}'[input has header row]' \
      '(-d --delimiter)'{-d,--delimiter}'=[field delimiter]:char:' \
      '(-r --record-terminator)'{-r,--record-terminator}'=[record terminator]:term:($_term)' \
      '(-e --escape-char)'{-e,--escape-char}'=[escape character]:char:' \
      '(-q --quote-char)'{-q,--quote-char}'=[quote character]:char:' \
      '(-D --double-quote)'{-D,--double-quote}'=[double quote]:bool:(true false)' \
      '(-C --csv-compression)'{-C,--csv-compression}'=[CSV input compression]:codec:($_comp)' \
      '(-c --parquet-compression)'{-c,--parquet-compression}'=[parquet output compression (default snappy)]:codec:($_comp)' \
      '(-w --writer-version)'{-w,--writer-version}'=[parquet writer version]:version:(1.0 2.0)' \
      '(-m --max-row-group-size)'{-m,--max-row-group-size}'=[max rows per row group]:N:' \
      '--help[show help]' \
      '(- *)'{-V,--version}'[show version]'
    ;;

  parquet-rowcount)
    # Return the number of rows in one or more parquet files.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '*:parquet file(s):_files -g "*.parquet"'
    ;;

  parquet-layout)
    # Print the physical layout of a parquet file (row groups,
    # column chunks, pages).
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:parquet file:_files -g "*.parquet"'
    ;;

  parquet-index)
    # Print the page index of a parquet file for a specific column.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:parquet file:_files -g "*.parquet"' \
      '2:column name:'
    ;;

  parquet-show-bloom-filter)
    # Read bloom filter data from a Parquet file.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '1:parquet file:_files -g "*.parquet"' \
      '2:column name:' \
      '*:value to look up:'
    ;;

esac
