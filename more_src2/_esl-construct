#compdef esl-construct
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-construct.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-construct: build/modify consensus secondary structure from MSA
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-a[list conflicting basepair positions, then exit]' \
  '-v[verbose, list per-sequence basepair conflicts]' \
  '-x[new SS_cons as max set of basepairs with 0 conflicts]' \
  '-r[remove consensus basepairs that conflict with any individual]' \
  '-c[new SS_cons from individual with most overlap]' \
  '--rfc[with -c, use RF-annotated sequence as consensus]' \
  '--indi=[new SS_cons from named individual sequence]:name' \
  '--rfindi[with --indi, set that sequence as RF]' \
  '--ffreq=[new SS_cons as basepairs in >x fraction of sequences]:x' \
  '--fmin[highest threshold yielding consistent consensus]' \
  '-o[output alignment file]:file:_files' \
  '--pfam[output in Pfam (non-interleaved) format]' \
  '-l[file listing sequences with conflicts]:file:_files' \
  '--lmax=[with -l, only list seqs with >n conflicts]:n' \
  '*:alignment file:_files' && ret=0
return ret
