#compdef operator-controller
# _operator-controller — OLMv1 cluster-extension controller (operator-framework/operator-controller)
# upstream: https://github.com/operator-framework/operator-controller
# Flags from cmd/operator-controller/main.go on tip.

_operator-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics bind host\:port (requires --tls-cert/--tls-key)]:host\:port:' \
        '--pprof-bind-address=[pprof bind host\:port (0/empty disables)]:host\:port:' \
        '--health-probe-bind-address=[health probe bind host\:port]:host\:port:' \
        '--catalogd-cas-dir=[CA bundle dir for verifying catalogd HTTPS]:dir:_files -/' \
        '--pull-cas-dir=[CA bundle dir for verifying image-registry HTTPS]:dir:_files -/' \
        '--tls-cert=[metrics server TLS cert (requires --tls-key)]:file:_files' \
        '--tls-key=[metrics server TLS key (requires --tls-cert)]:file:_files' \
        '--leader-elect[enable leader election]' \
        '--cache-path=[local filesystem cache directory]:dir:_files -/' \
        '--system-namespace=[namespace used to deploy system resources]:ns:' \
        '--global-pull-secret=[global pull secret in <namespace>/<name>]:secret:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_operator-controller "$@"
