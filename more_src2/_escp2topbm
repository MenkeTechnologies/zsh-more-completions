#compdef escp2topbm
# Documentation: man escp2topbm (Netpbm)
# Source: convert an Epson ESC/P2 printer file back into a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:print file:_files' \
    && ret=0

return ret
