#compdef footclient
# Documentation: https://codeberg.org/dnkl/foot
# Documentation: https://codeberg.org/dnkl/foot/src/branch/master/client.c
# Documentation: https://codeberg.org/dnkl/foot/src/branch/master/doc/footclient.1
# Reference accessed: 2026-05-27
# Verified: upstream client.c long_options[] table (dnkl/foot)
#
# Note: the foot Wayland terminal does not ship a `foot-msg` binary; the IPC
# client used to talk to a running `foot --server` is `footclient`. This file
# is therefore registered for `footclient`. Plain `foot` is completed via its
# own bundled completion in dnkl/foot/completions/.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help and exit]' \
  '(-v --version)'{-v,--version}'[print version and exit]' \
  '(-t --term)'{-t+,--term=}'[value to set TERM to]:term:' \
  '(-T --title)'{-T+,--title=}'[initial window title]:title:' \
  '(-a --app-id)'{-a+,--app-id=}'[window app-id (Wayland)]:app-id:' \
  '--toplevel-tag=[set the Wayland xdg-toplevel tag]:tag:' \
  '(-w --window-size-pixels)'{-w+,--window-size-pixels=}'[initial window size in pixels (WIDTHxHEIGHT)]:size:' \
  '(-W --window-size-chars)'{-W+,--window-size-chars=}'[initial window size in characters (COLSxROWS)]:size:' \
  '(-m --maximized)'{-m,--maximized}'[start maximized]' \
  '(-F --fullscreen)'{-F,--fullscreen}'[start fullscreen]' \
  '(-L --login-shell)'{-L,--login-shell}'[start the shell as a login shell]' \
  '(-D --working-directory)'{-D+,--working-directory=}'[initial working directory]:directory:_files -/' \
  '(-s --server-socket)'{-s+,--server-socket=}'[path to foot-server socket]:socket:_files' \
  '(-H --hold)'{-H,--hold}'[keep window open after the child terminates]' \
  '(-N --no-wait)'{-N,--no-wait}'[return immediately after spawning the window]' \
  '*'{-o+,--override=}'[override a config option (section.key=value)]:override:' \
  '(-E --client-environment)'{-E,--client-environment}'[use the client environment instead of the server one]' \
  '(-d --log-level)'{-d+,--log-level=}'[log threshold]:level:(info warning error none)' \
  '(-l --log-colorize)'{-l-,--log-colorize=-}'[colorize log output]::when:(auto never always)' \
  '*::command:_command_names -e' && ret=0

return ret
