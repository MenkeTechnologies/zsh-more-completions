#compdef fred
# Documentation: https://github.com/DannyBen/fredric
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fred — FRED (St Louis Fed) API command-line client from fredric gem.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds=(
      'get:output data to terminal'
      'pretty:display formatted JSON'
      'see:show colored output'
      'url:display constructed URL'
      'save:write output to file'
    )
    _describe -t commands 'fred command' cmds && ret=0
    ;;
  args)
    case $words[1] in
      get|save)
        _arguments \
          '--csv[output CSV format]' \
          '*:path or params' && ret=0
        ;;
      *)
        _message 'path and params' && ret=0
        ;;
    esac
    ;;
esac

return ret
