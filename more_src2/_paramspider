#compdef paramspider
# Documentation: https://github.com/devanshbatham/ParamSpider/blob/master/paramspider/main.py
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '(-d --domain)'{-d+,--domain=}'[target domain]:domain:'
  '(-l --list)'{-l+,--list=}'[file containing list of domains]:file:_files'
  '(-s --stream)'{-s,--stream}'[stream URLs on the terminal]'
  '--proxy=[proxy address for web requests]:proxy:'
  '(-p --placeholder)'{-p+,--placeholder=}'[placeholder for parameter values (default FUZZ)]:placeholder:'
  '(- *)-h[show help message]'
  '(- *)--help[show help message]'
)

_arguments -s -S $arguments
