#compdef fbv
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-a --alpha)'{-a,--alpha}'[use alpha channel]' \
  '(-c --dontclear)'{-c,--dontclear}'[do not clear screen before displaying]' \
  '(-e --enlarge)'{-e,--enlarge}'[enlarge image to fit screen]' \
  '(-f --stretch)'{-f,--stretch}'[stretch image to fit screen]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --ignore-aspect)'{-i,--ignore-aspect}'[ignore aspect ratio]' \
  '(-r --delay)'{-r,--delay}'[slideshow delay in seconds]:seconds:' \
  '(-s --size)'{-s,--size}'[set display size (WxH)]:size:' \
  '--version[show version]' \
  '*:image file:_files' && ret=0
return ret
