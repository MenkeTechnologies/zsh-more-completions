#compdef dremio-cli
# _dremio-cli — Dremio lakehouse query engine CLI (Dremio Corp, Java); custom argparse
# upstream: https://github.com/dremio/dremio-oss

_dremio-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--host=+[dremio host]:host:_hosts' \
        '-h+[dremio host]:host:_hosts' \
        '--port=+[dremio port]:port:' \
        '-p+[dremio port]:port:' \
        '--user=+[dremio user]:str:_users' \
        '-u+[dremio user]:str:_users' \
        '--password=+[dremio password]:str:' \
        '-w+[dremio password]:str:' \
        '--ssl[use SSL]' \
        '--ssl-truststore=+[ssl truststore]:file:_files' \
        '--ssl-truststore-password=+[ssl truststore password]:str:' \
        '--query=+[query to run]:sql:' \
        '-q+[query to run]:sql:' \
        '--file=+[query file]:file:_files -g "*.sql"' \
        '-f+[query file]:file:_files -g "*.sql"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--format=+[output format]:fmt:(json csv tsv table)' \
        '-t+[output format]:fmt:(json csv tsv table)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--source=+[source name]:src:' \
        '-s+[source name]:src:' \
        '*:arg:'
}

_dremio-cli "$@"
