#compdef gitnr
# Documentation: https://github.com/reemus-dev/gitnr
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall gitnr@0.3.0
# Probed via: completions zsh
# Repository: https://github.com/reemus-dev/gitnr

autoload -U is-at-least

_gitnr() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-r[Refresh the cache (templates are cached for 1h)]' \
'--refresh[Refresh the cache (templates are cached for 1h)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_gitnr_commands" \
"*::: :->gitnr" \
&& ret=0
    case $state in
    (gitnr)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gitnr-command-$line[1]:"
        case $line[1] in
            (create)
_arguments "${_arguments_options[@]}" : \
'-f+[Write template to the specified file path]:OUT_FILE:_default' \
'--file=[Write template to the specified file path]:OUT_FILE:_default' \
'-s[Write template to .gitignore file in current directory]' \
'--save[Write template to .gitignore file in current directory]' \
'-r[Refresh the cache (templates are cached for 1h)]' \
'--refresh[Refresh the cache (templates are cached for 1h)]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'*::templates -- Space or comma separated list of templates to use. Templates can be prefixed with
the provider name to avoid any ambiguity.:_default' \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
'-r[Refresh the cache (templates are cached for 1h)]' \
'--refresh[Refresh the cache (templates are cached for 1h)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-r[Refresh the cache (templates are cached for 1h)]' \
'--refresh[Refresh the cache (templates are cached for 1h)]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Specify desired shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_gitnr__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:gitnr-help-command-$line[1]:"
        case $line[1] in
            (create)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(search)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_gitnr_commands] )) ||
_gitnr_commands() {
    local commands; commands=(
'create:Create a .gitignore file from one or more templates' \
'search:Choose templates interactively from the GitHub & TopTal collections' \
'completions:Generate completions to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gitnr commands' commands "$@"
}
(( $+functions[_gitnr__completions_commands] )) ||
_gitnr__completions_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr completions commands' commands "$@"
}
(( $+functions[_gitnr__create_commands] )) ||
_gitnr__create_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr create commands' commands "$@"
}
(( $+functions[_gitnr__help_commands] )) ||
_gitnr__help_commands() {
    local commands; commands=(
'create:Create a .gitignore file from one or more templates' \
'search:Choose templates interactively from the GitHub & TopTal collections' \
'completions:Generate completions to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'gitnr help commands' commands "$@"
}
(( $+functions[_gitnr__help__completions_commands] )) ||
_gitnr__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr help completions commands' commands "$@"
}
(( $+functions[_gitnr__help__create_commands] )) ||
_gitnr__help__create_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr help create commands' commands "$@"
}
(( $+functions[_gitnr__help__help_commands] )) ||
_gitnr__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr help help commands' commands "$@"
}
(( $+functions[_gitnr__help__search_commands] )) ||
_gitnr__help__search_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr help search commands' commands "$@"
}
(( $+functions[_gitnr__search_commands] )) ||
_gitnr__search_commands() {
    local commands; commands=()
    _describe -t commands 'gitnr search commands' commands "$@"
}

if [ "$funcstack[1]" = "_gitnr" ]; then
    _gitnr "$@"
else
    compdef _gitnr gitnr
fi
