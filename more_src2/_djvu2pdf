#compdef djvu2pdf
# Documentation: https://0x2a.at/site/projects/djvu2pdf/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: djvu2pdf is a minimal shell wrapper around ddjvu+gs; takes
# input.djvu and optional output.pdf positional arguments only.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:input djvu file:_files -g "*.djvu(-.)"' \
  '2:output pdf file:_files -g "*.pdf(-.)"' && return 0
