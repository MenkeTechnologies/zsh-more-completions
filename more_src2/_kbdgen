#compdef kbdgen
# Documentation: https://github.com/divvun/kbdgen
# Source: divvun/kbdgen — Rust keyboard layout generator.
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _kg_cmds
_kg_cmds=(
    'fetch:retrieve dependencies for a keyboard bundle'
    'target:generate keyboard layouts for a target platform'
    'help:show help'
)

local -a _kg_targets
_kg_targets=(
    'android:Android keyboard'
    'macos:macOS keyboard'
    'linux:Linux (X11/Wayland) keyboard'
    'windows:Windows keyboard'
    'chromeos:ChromeOS keyboard'
    'ios:iOS keyboard'
)

local -a _kg_target_actions
_kg_target_actions=(
    'clone:clone target template'
    'generate:generate target files'
    'build:build target package'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'kbdgen command' _kg_cmds && ret=0
        ;;
    args)
        case $line[1] in
            target)
                _arguments -s -S \
                    '--bundle-path=[keyboard bundle path]:bundle:_files -/' \
                    '--output-path=[output path]:dir:_files -/' \
                    '1:target:->target' \
                    '2:action:->action' \
                    && ret=0
                case $state in
                    target) _describe -t targets 'target platform' _kg_targets && ret=0 ;;
                    action) _describe -t actions 'target action' _kg_target_actions && ret=0 ;;
                esac
                ;;
            fetch)
                _arguments -s -S \
                    '--bundle-path=[bundle path]:bundle:_files -/' \
                    && ret=0
                ;;
        esac
        ;;
esac

return ret
