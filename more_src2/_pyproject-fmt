#compdef pyproject-fmt
# Documentation: https://pyproject-fmt.readthedocs.io/en/latest/
# Reference accessed: 2026-06-04

# Zsh completion for pyproject-fmt (Python pyproject.toml formatter)
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  '(-s --stdout)'{-s,--stdout}'[print the formatted output to stdout]'
  '--check[check if the file would be reformatted without writing]'
  '--indent[number of spaces for indentation]:indent number:'
  '--keep-full-version[do not normalize version specifiers]'
  '--max-supported-python[maximum Python version to support]:version:'
  '--min-supported-python[minimum Python version to support]:version:'
  '--column-width[maximum column width]:width:'
  '--no-sort[do not sort fields and items]'
  '*:pyproject.toml file:_files -g "*.toml"'
)

_arguments -s -S $arguments
