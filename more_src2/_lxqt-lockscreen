#compdef lxqt-lockscreen
# Documentation: https://github.com/lxqt/lxqt-session/tree/master/lxqt-leave
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: lxqt-lockscreen is a thin wrapper that triggers the screen lock via the
# LXQt session DBus interface; upstream exposes only built-in help and version.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
