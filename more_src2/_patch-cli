#compdef patch-cli
# _patch-cli — GNU patch apply diff files to originals CLI alias (GNU team, C); custom argparse
# upstream: https://savannah.gnu.org/projects/patch/

_patch-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-p+[strip level]:n:' \
        '--strip=+[strip level]:n:' \
        '-d+[change directory]:dir:_files -/' \
        '--directory=+[change directory]:dir:_files -/' \
        '-D+[define]:str:' \
        '--ifdef=+[define]:str:' \
        '-E[remove empty files]' \
        '--remove-empty-files[remove empty files]' \
        '-F+[fuzz]:n:' \
        '--fuzz=+[fuzz]:n:' \
        '-l[ignore whitespace]' \
        '--ignore-whitespace[ignore whitespace]' \
        '-N[skip already applied patches]' \
        '--forward[skip already applied patches]' \
        '-R[reverse patch]' \
        '--reverse[reverse patch]' \
        '-r+[reject file]:file:_files' \
        '--reject-file=+[reject file]:file:_files' \
        '-s[silent]' \
        '--silent[silent]' \
        '--quiet[silent]' \
        '-t[ask no questions]' \
        '--batch[ask no questions]' \
        '-u[interpret as unified diff]' \
        '--unified[interpret as unified diff]' \
        '-c[interpret as context diff]' \
        '--context[interpret as context diff]' \
        '-e[interpret as ed script]' \
        '--ed[interpret as ed script]' \
        '-n[interpret as normal diff]' \
        '--normal[interpret as normal diff]' \
        '-G+[merge style]:str:' \
        '--merge=+[merge style]:str:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '-b[backup]' \
        '--backup[backup]' \
        '-V+[backup style]:s:(simple numbered existing nil never none t)' \
        '--version-control=+[backup style]:s:(simple numbered existing nil never none t)' \
        '-B+[backup prefix]:str:' \
        '--prefix=+[backup prefix]:str:' \
        '-Y+[basename prefix]:str:' \
        '--basename-prefix=+[basename prefix]:str:' \
        '-z+[suffix]:str:' \
        '--suffix=+[suffix]:str:' \
        '-Z[set times]' \
        '--set-utc[set times]' \
        '-T[set times to context]' \
        '--set-time[set times to context]' \
        '--remove-empty-files[remove empty files]' \
        '--posix[posix mode]' \
        '--dry-run[dry run]' \
        '--no-backup-if-mismatch[no backup if mismatch]' \
        '--backup-if-mismatch[backup if mismatch]' \
        '--read-only=+[mode]:m:(ignore warn fail)' \
        '--binary[binary mode]' \
        '--follow-symlinks[follow symlinks]' \
        '--reject-format=+[fmt]:f:(unified context)' \
        '--global-reject-file=+[file]:file:_files' \
        '--no-keep-empty-files[no keep empty files]' \
        '*:patch file:_files -g "*.{patch,diff}"'
}

_patch-cli "$@"
