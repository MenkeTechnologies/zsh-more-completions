#compdef karmada-metrics-adapter
# Documentation: https://karmada.io/docs/reference/components/karmada-metrics-adapter/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Removed invented
# --karmada-kubeconfig/--leader-elect*/--master/--cert-dir/--logtostderr;
# real flags are apiserver-style as below.

# karmada-metrics-adapter: Karmada metrics adapter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--kubeconfig=[path to karmada control plane kubeconfig file]:file:_files' \
  '--authentication-kubeconfig=[kubeconfig pointing at the core kubernetes server]:file:_files' \
  '--secure-port=[port to serve HTTPS with authn/authz]:port:' \
  '--bind-address=[IP address to listen for the --secure-port]:addr:' \
  '--tls-cert-file=[file containing the default x509 Certificate for HTTPS]:file:_files' \
  '--tls-private-key-file=[file containing the default x509 private key]:file:_files' \
  '--metrics-bind-address=[metrics bind address]:addr:' \
  '--feature-gates=[feature gates]:gates:' \
  '--v=[log level]:n:' \
  '*::karmada-metrics-adapter args:_files' && ret=0
return ret
