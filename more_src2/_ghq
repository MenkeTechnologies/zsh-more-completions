#compdef ghq
# Documentation: https://github.com/x-motemen/ghq
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_ghq_vcs_types=(git subversion git-svn hg darcs fossil bazaar)

_ghq() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local -a _ghq_cmds
  _ghq_cmds=(
    'get:clone/sync a remote repository'
    'list:list local repositories'
    'root:show repositories root'
    'create:create a new repository'
    'look:look into a local repository'
    'rm:delete local repository'
    'migrate:relocate existing repository under ghq root'
  )

  _arguments -C \
    '--help[show help]' \
    '--version[show version]' \
    '1:command:->cmds' \
    '*::arg:->args'

  case "$state" in
    cmds)
      _describe -t commands 'ghq command' _ghq_cmds
      ;;
    args)
      case $line[1] in
        get)
          _arguments \
            {-u,--update}'[update if already cloned]' \
            {-p,--no-recursive}'[do not clone recursively]' \
            '--shallow[perform shallow clone]' \
            '--look[look into after clone]' \
            '--vcs[specify VCS backend]:vcs:('"${_ghq_vcs_types[*]}"')' \
            '--silent[suppress output]' \
            '--branch[specify branch]:branch:' \
            '--bare[create bare repository]' \
            '*:repository:'
          ;;
        list)
          _arguments \
            {-p,--full-path}'[print full paths]' \
            {-e,--exact}'[exact match]' \
            '--vcs[filter by VCS backend]:vcs:('"${_ghq_vcs_types[*]}"')' \
            '--unique[print unique subpaths]' \
            '*:query:'
          ;;
        root)
          _arguments \
            '--all[show all roots]'
          ;;
        create)
          _arguments \
            '--vcs[specify VCS backend]:vcs:('"${_ghq_vcs_types[*]}"')' \
            '*:repository:'
          ;;
        look)
          _arguments \
            '*:repository:'
          ;;
        rm)
          _arguments \
            '--dry-run[do not actually delete]' \
            '*:repository:'
          ;;
        migrate)
          _arguments \
            '-y[answer yes to prompts]' \
            '--dry-run[do not actually move]' \
            '*:repository:'
          ;;
      esac
      ;;
  esac
}

_ghq "$@"
