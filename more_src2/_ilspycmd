#compdef ilspycmd
# Documentation: https://github.com/icsharpcode/ILSpy/blob/master/ICSharpCode.ILSpyCmd/IlspyCmdProgram.cs
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --outputdir)'{-o,--outputdir=}'[output directory]:dir:_files -/' \
  '(-p --project)'{-p,--project}'[decompile as compilable project]' \
  '(-t --type)'{-t,--type=}'[decompile specific type]:type:' \
  '(-l --list)'{-l,--list=}'[list entities]:kind:(class interface struct delegate enum)' \
  '--list-resources[list embedded resources]' \
  '--resource=[extract a single resource by name]:name:' \
  '--decompile-baml[with -p, decompile BAML to XAML]' \
  '(-il --ilcode)'{-il,--ilcode}'[display IL code]' \
  '--il-sequence-points[IL with sequence points]' \
  '(-lv --languageversion)'{-lv,--languageversion=}'[C# language version]:ver:' \
  '(-genpdb --generate-pdb)'{-genpdb,--generate-pdb}'[create PDB file]' \
  '(-usepdb --use-varnames-from-pdb)'{-usepdb,--use-varnames-from-pdb}'[use PDB var names]' \
  '*'{-r,--referencepath=}'[reference assemblies dir]:dir:_files -/' \
  '*'{-ds,--decompiler-setting=}'[set a decompiler setting]:setting:' \
  '--ilspy-settingsfile=[path to ILSpy settings file]:file:_files' \
  '--no-dead-code[remove unreachable code]' \
  '--no-dead-stores[remove unused assignments]' \
  '(-d --dump-package)'{-d,--dump-package}'[extract package assemblies]' \
  '--nested-directories[output by namespace hierarchy]' \
  '--generate-diagrammer[generate HTML diagrams]' \
  '--generate-diagrammer-include=[whitelist regex]:regex:' \
  '--generate-diagrammer-exclude=[blacklist regex]:regex:' \
  '--generate-diagrammer-report-excluded[report excluded types]' \
  '--generate-diagrammer-docs=[XML docs path]:file:_files' \
  '--generate-diagrammer-strip-namespaces=[namespaces to strip]:ns:' \
  '--generate-diagrammer-json-only[only JSON output]' \
  '--disable-updatecheck[skip version check]' \
  '*:assembly:_files -g "*.(dll|exe)"'
