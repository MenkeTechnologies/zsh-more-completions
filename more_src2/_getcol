#compdef getcol
# _getcol — extract / summarize columns from a tab-table or text file (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from getcol.c (single-letter getopt-style).

_getcol() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a[sum values in each numeric column]' \
        '-b[bar-separated input]' \
        '-c[count entries in each column]' \
        '-d+[decimal places in floating-point output]:n:' \
        '-e[compute median of each numeric column]' \
        '-f[print range of values in column]' \
        '-g[compute absolute median of each numeric column]' \
        '-h[print Starbase tab-table header]' \
        '-i[tab-separated input]' \
        '-j[compute absolute mean of each numeric column]' \
        '-k[count columns on first line]' \
        '-l+[lines to append at end]:n:' \
        '-m[compute mean of each numeric column]' \
        '-n+[number of lines to read]:n:' \
        '-o[OR conditions instead of ANDing]' \
        '-p[print sum or mean only]' \
        '-q[compute mean in quadrature]' \
        '-r+[range of lines to read]:range:' \
        '-s+[lines to skip]:n:' \
        '-t[tab-separated output]' \
        '-u[line-separated output]' \
        '-v[verbose output]' \
        '-w[print file pathnames]' \
        '-x+[value to ignore]:val:' \
        '-y[stddev of means of selected columns]' \
        '-z[stddev of absolute means of selected columns]' \
        '1:input file:_files' \
        '*:columns:'
}

_getcol "$@"
