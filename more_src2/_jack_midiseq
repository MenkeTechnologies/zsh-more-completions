#compdef jack_midiseq
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/example-clients/midiseq.c
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above. No CLI flags — positional
# only: "jack_midiseq name nsamp [startindex note nsamp] ...".

# jack_midiseq: JACK MIDI sequencer (positional only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:client name:' \
  '2:total samples (nsamp):' \
  '*:startindex note nsamp triple:' && ret=0
return ret
