#compdef rgb2ycbcr
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/rgb2ycbcr.c — convert RGB TIFF to YCbCr (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[compression algorithm]:comp:(jpeg lzw zip packbits none)' \
    '-r+[rows per strip]:rows:_default' \
    '-h+[horizontal sampling factor]:factor:(1 2 4)' \
    '-v+[vertical sampling factor]:factor:(1 2 4)' \
    '*:tiff files (last is output):_files -g "*.{tif,tiff,TIF,TIFF}"' \
    && ret=0

return ret
