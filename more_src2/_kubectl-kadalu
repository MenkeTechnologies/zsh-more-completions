#compdef kubectl-kadalu
# Documentation: https://github.com/kadalu/kadalu/blob/devel/cli/kubectl_kadalu/__main__.py
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'install:deploy the kadalu operator'
      'storage-add:add storage to kadalu'
      'storage-list:list configured storage'
      'storage-remove:remove a storage pool'
      'remove-archived-pv:remove archived persistent volumes'
      'logs:show kadalu component logs'
      'healinfo:show heal information'
      'option-set:set a kadalu option'
      'option-reset:reset a kadalu option'
      'version:show version'
    )
    _describe -t commands 'kubectl-kadalu command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
