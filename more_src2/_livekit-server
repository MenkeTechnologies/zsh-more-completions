#compdef livekit-server
# Documentation: https://github.com/livekit/livekit
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for livekit-server (urfave/cli). Many tuning flags are generated
# from config; see `livekit-server help-verbose` for the full generated list.

local curcontext="$curcontext" state line ret=1

_arguments -C -s -S \
  '*--bind=[IP to listen on (repeatable)]:ip:' \
  '--config=[path to LiveKit YAML]:config:_files' \
  '--config-body=[YAML inline / \$LIVEKIT_CONFIG]:yaml:' \
  '--key-file=[path to API keys file]:file:_files' \
  '--keys=[API keys key\:secret lines / \$LIVEKIT_KEYS]:keys:' \
  '--region=[node region / \$LIVEKIT_REGION]:region:' \
  '--node-ip=[advertised node IP / \$NODE_IP]:ip:' \
  '--udp-port=[WebRTC UDP ports / \$UDP_PORT]:port:' \
  '--redis-host=[Redis host\:port / \$REDIS_HOST]:host:' \
  '--redis-password=[Redis password / \$REDIS_PASSWORD]:password:' \
  '--turn-cert=[TURN TLS cert / \$LIVEKIT_TURN_CERT]:file:_files' \
  '--turn-key=[TURN TLS key / \$LIVEKIT_TURN_KEY]:file:_files' \
  '--cpuprofile=[write CPU profile]:file:_files' \
  '--memprofile=[write heap profile]:file:_files' \
  '--disable-strict-config[allow lenient config parsing]' \
  '--dev[development mode: debug logs + pprof]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'help-verbose:print help including generated config flags'
      'generate-keys:generate an API key and secret'
      'ports:print configured listener ports'
      'create-join-token:generate a room join token (deprecated)'
      'list-nodes:list nodes in a multi-node deployment'
    )
    _describe -t commands 'livekit-server command' commands && ret=0
    ;;
  args)
    case $words[1] in
      generate-keys|ports|list-nodes|help-verbose|create-join-token) ;;
    esac
    ;;
esac

return ret
