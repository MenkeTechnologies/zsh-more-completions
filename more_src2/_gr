#compdef gr
# Documentation: https://github.com/jordilin/gitar
# Reference accessed: 2026-05-23
# Verified: upstream README (gr init, gr mr create, gr --verbose).

# Zsh completion for gr - GitAR multi-remote GitHub/GitLab CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'init:generate config for domain'
  'mr:merge/pull request operations'
  'pp:pipeline operations'
  'my:authenticated user info'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'gr command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (init)
        _arguments '--domain[remote domain]:domain:(github.com gitlab.com)' && ret=0
        ;;
      (mr)
        _values 'mr subcommand' 'create[open merge request]' 'list[list merge requests]' && ret=0
        ;;
      (pp|my)
        _arguments \
          '--page[page number]:n:' \
          '--refresh[refresh cache]' \
          '--format[output format]:format:' \
          '1:sub:(list)' && ret=0
        ;;
    esac
    ;;
esac

return ret
