#compdef gotree

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'annotate:annotate internal nodes'
  'brlen:modify branch lengths'
  'collapse:collapse branches'
  'compare:compare trees'
  'compute:compute tree properties'
  'divide:divide tree into subtrees'
  'draw:draw tree'
  'generate:generate random trees'
  'matrix:print distance matrix'
  'merge:merge trees'
  'nni:perform nearest neighbor interchange'
  'prune:prune taxa from tree'
  'randsupport:assign random support values'
  'reformat:reformat tree'
  'rename:rename tips/nodes'
  'repopulate:repopulate tree with removed tips'
  'resolve:resolve polytomies'
  'reroot:reroot tree'
  'rotate:rotate children of nodes'
  'shuffletips:shuffle tip names'
  'stats:print tree statistics'
  'subtree:extract subtree'
  'support:compute branch support'
  'upload:upload tree to web service'
)

local -a global_flags=(
  '(-i --input)'{-i,--input}'[input tree file]:input file:_files'
  '(-o --output)'{-o,--output}'[output tree file]:output file:_files'
  '--format[tree format]:format:(newick nexus phyloxml)'
  '(-t --threads)'{-t,--threads}'[number of threads]:threads:'
  '--seed[random seed]:seed:'
)

_arguments -s -S \
  $global_flags \
  '1:subcommand:->subcmd' \
  '*::arg:->args' && ret=0

case $state in
  (subcmd)
    _describe -t subcommands 'gotree subcommand' subcommands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (brlen)
        local -a brlen_cmds=(
          'clear:set all branch lengths to 0'
          'cut:cut long branches'
          'round:round branch lengths'
          'scale:scale branch lengths'
          'setmin:set minimum branch length'
          'setrand:set random branch lengths'
        )
        _describe -t subcommands 'brlen subcommand' brlen_cmds && ret=0
        ;;
      (collapse)
        local -a collapse_cmds=(
          'clade:collapse clades'
          'depth:collapse by depth'
          'length:collapse short branches'
          'support:collapse low-support branches'
        )
        _describe -t subcommands 'collapse subcommand' collapse_cmds && ret=0
        ;;
      (compare)
        local -a compare_cmds=(
          'edges:compare edges between trees'
          'tips:compare tips between trees'
          'trees:compare tree topologies'
        )
        _describe -t subcommands 'compare subcommand' compare_cmds && ret=0
        ;;
      (compute)
        local -a compute_cmds=(
          'bipartitiontree:compute bipartition tree'
          'consensus:compute consensus tree'
          'edgetrees:compute edge trees'
          'support:compute support values'
        )
        _describe -t subcommands 'compute subcommand' compute_cmds && ret=0
        ;;
      (draw)
        local -a draw_cmds=(
          'png:draw tree as PNG'
          'svg:draw tree as SVG'
          'text:draw tree as text'
        )
        _describe -t subcommands 'draw subcommand' draw_cmds && ret=0
        ;;
      (generate)
        local -a generate_cmds=(
          'balancedtree:generate balanced tree'
          'caterpillar:generate caterpillar tree'
          'startree:generate star tree'
          'uniformtree:generate uniform random tree'
          'yuletree:generate Yule random tree'
        )
        _describe -t subcommands 'generate subcommand' generate_cmds && ret=0
        ;;
      (reformat)
        local -a reformat_cmds=(
          'newick:reformat as Newick'
          'nexus:reformat as Nexus'
        )
        _describe -t subcommands 'reformat subcommand' reformat_cmds && ret=0
        ;;
      (reroot)
        local -a reroot_cmds=(
          'midpoint:reroot at midpoint'
          'outgroup:reroot on outgroup'
        )
        _describe -t subcommands 'reroot subcommand' reroot_cmds && ret=0
        ;;
      (rotate)
        local -a rotate_cmds=(
          'rand:randomly rotate children'
          'sort:sort children'
        )
        _describe -t subcommands 'rotate subcommand' rotate_cmds && ret=0
        ;;
      (stats)
        local -a stats_cmds=(
          'edges:print edge statistics'
          'nodes:print node statistics'
          'rooted:check if tree is rooted'
          'tips:print tip statistics'
        )
        _describe -t subcommands 'stats subcommand' stats_cmds && ret=0
        ;;
      (support)
        local -a support_cmds=(
          'classical:compute classical bootstrap support'
        )
        _describe -t subcommands 'support subcommand' support_cmds && ret=0
        ;;
      (upload)
        local -a upload_cmds=(
          'itol:upload to iTOL'
          'ncbi:upload to NCBI'
        )
        _describe -t subcommands 'upload subcommand' upload_cmds && ret=0
        ;;
      (*)
        _arguments -s -S $global_flags '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
