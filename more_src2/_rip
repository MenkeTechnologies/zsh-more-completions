#compdef rip
# Documentation: https://github.com/nivekuil/rip
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-d --decompose)'{-d,--decompose}'[permanently delete (unlink) the entire graveyard]' \
  '(-i --inspect)'{-i,--inspect}'[print info about target before prompting for action]' \
  '(-s --seance)'{-s,--seance}'[print files sent under the current directory]' \
  '(-u --unbury)'{-u,--unbury}'[undo last removal or restore files from the graveyard]:target:_files' \
  '--graveyard=[directory where deleted files go to rest]:path:_directories' \
  '(-h --help)'{-h,--help}'[print help information]' \
  '(-V --version)'{-V,--version}'[print version information]' \
  '*:file:_files' && ret=0
return ret
