#compdef fold-cli
# _fold-cli — GNU coreutils fold wrap each input line to fit in specified width CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_fold-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b[count bytes rather than columns]' \
        '--bytes[count bytes rather than columns]' \
        '-s[break at spaces]' \
        '--spaces[break at spaces]' \
        '-w+[width]:n:' \
        '--width=+[width]:n:' \
        '*:files:_files'
}

_fold-cli "$@"
