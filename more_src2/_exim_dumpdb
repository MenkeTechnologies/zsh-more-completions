#compdef exim_dumpdb
# Documentation: https://manpages.debian.org/bookworm/exim4-base/exim_dumpdb.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm exim_dumpdb(8) manpage explicitly states the
# command has no options other than spool directory and database name.
# Removed from prior file: fabricated -h/-V flags and bogus man.archlinux.org
# search URL.

# exim_dumpdb: print contents of an Exim hints database
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:spool directory:_files -/' \
  '2:database name:(retry wait-remote_smtp wait-lmtp callout ratelimit misc tls seen)' && ret=0
return ret
