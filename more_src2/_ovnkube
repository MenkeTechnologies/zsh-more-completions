#compdef ovnkube
# _ovnkube — OVN-Kubernetes main control-plane/data-plane daemon (ovn-kubernetes/ovn-kubernetes)
# upstream: https://github.com/ovn-kubernetes/ovn-kubernetes
# Flags from go-controller/cmd/ovnkube/ovnkube.go + pkg/config/config.go on tip.

_ovnkube() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '--init-cluster-manager=[run as the cluster manager (Pod CIDR / NetworkID issuer)]:node:' \
        '--init-ovnkube-controller=[run the ovnkube-controller (per-zone OVN reconciler)]:node:' \
        '--init-node=[run as the node agent on the named node]:node:' \
        '--cleanup-node=[clean up OVN-K state for the named node and exit]:node:' \
        '--pidfile=[write PID to file]:file:_files' \
        '--loglevel=[klog verbosity (0-5)]:n:(0 1 2 3 4 5)' \
        '--logfile=[log file path]:file:_files' \
        '--logfile-maxsize=[per-file max size (MB)]:n:' \
        '--logfile-maxbackups=[max log backups]:n:' \
        '--logfile-maxage=[max log file age (days)]:n:' \
        '--k8s-apiserver=[apiserver URL]:url:_urls' \
        '--k8s-kubeconfig=[kubeconfig file]:file:_files' \
        '--k8s-token=[bearer token for apiserver auth]:token:' \
        '--k8s-cacert=[CA cert file for apiserver TLS]:file:_files' \
        '--nb-address=[northbound DB host\:port (or comma-sep)]:list:' \
        '--sb-address=[southbound DB host\:port (or comma-sep)]:list:' \
        '--nb-cert=[OVN NB client cert]:file:_files' \
        '--nb-privkey=[OVN NB client key]:file:_files' \
        '--nb-cacert=[OVN NB CA cert]:file:_files' \
        '--sb-cert=[OVN SB client cert]:file:_files' \
        '--sb-privkey=[OVN SB client key]:file:_files' \
        '--sb-cacert=[OVN SB CA cert]:file:_files' \
        '--gateway-mode=[gateway mode]:mode:(local shared disabled)' \
        '--gateway-interface=[gateway interface or "auto"]:iface:' \
        '--gateway-nexthop=[gateway next-hop IP]:ip:' \
        '--gateway-vlanid=[gateway VLAN ID]:n:' \
        '--cluster-subnets=[cluster pod CIDR list (comma-sep)]:list:' \
        '--service-cluster-ip-range=[Service ClusterIP CIDR]:cidr:' \
        '--enable-ssl[enable SSL for OVN DBs]' \
        '--metrics-bind-address=[Prometheus metrics bind host\:port]:host\:port:' \
        '--enable-acl-logging[emit ACL drop/allow logs]' \
        '--enable-multicast[enable multicast support]' \
        '--enable-egress-firewall[enable EgressFirewall feature]' \
        '--enable-egress-ip[enable EgressIP feature]' \
        '--enable-egress-qos[enable EgressQoS feature]' \
        '--enable-network-policy[enable Kubernetes NetworkPolicy support]' \
        '--enable-multi-network[enable Multus/multi-network attachments]'
}

_ovnkube "$@"
