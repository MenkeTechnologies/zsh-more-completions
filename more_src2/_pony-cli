_pony-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[release]:level:(0 1 2 3)' \
        '--release=+[level]:l:(0 1 2 3)' \
        '-d[debug build]' \
        '--debug[debug build]' \
        '-D+[define]:str:' \
        '*-D+[define]:str:' \
        '--define=+[name]:str:' \
        '*--define=+[name]:str:' \
        '-b+[bin name]:str:' \
        '--bin-name=+[name]:str:' \
        '-o+[output]:dir:_files -/' \
        '--output=+[dir]:dir:_files -/' \
        '-c+[cpu]:str:' \
        '--cpu=+[name]:str:' \
        '--features=+[list]:str:' \
        '--triple=+[triple]:str:' \
        '--stats[print stats]' \
        '--ast[print AST]' \
        '--astpackage[print AST package]' \
        '--trace[trace]' \
        '--width=+[N]:n:' \
        '--immerr[immediate errors]' \
        '-p+[path]:dir:_files -/' \
        '*-p+[path]:dir:_files -/' \
        '--path=+[dir]:dir:_files -/' \
        '*--path=+[dir]:dir:_files -/' \
        '--abi=+[name]:str:' \
        '--ssa[print SSA]' \
        '--asm[print ASM]' \
        '--llvm[print LLVM]' \
        '--c[print C]' \
        '--obj[print obj]' \
        '--bc[print BC]' \
        '--bin[print bin]' \
        '--cross-compile[cross compile]' \
        '--checktree[check tree]' \
        '--paths-only[paths only]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--pic[position-independent code]' \
        '--no-pic[no PIC]' \
        '--ponypath=+[paths]:str:' \
        '--ponyplanforspark[plan for spark]' \
        '--docs[generate docs]' \
        '--lint[lint]' \
        '--safe=+[modules]:str:' \
        '--runtimebc[runtime BC]' \
        '--simplebuiltin[simple builtin]' \
        '--strip[strip]' \
        '-s[strip]' \
        '--asn1=+[file]:file:_files' \
        '--linker=+[name]:str:' \
        '--link-arch=+[arch]:str:' \
        '--link-ldcmd=+[cmd]:str:' \
        '--define-builtin[define builtin]' \
        '--no-progress[no progress]' \
        '--allow-unsafe-c[allow unsafe C]' \
        '--lib=+[name]:str:' \
        '*--lib=+[name]:str:' \
        '*:pony package:_files -g "*.pony"'
}

