#compdef maven mvnd
# _maven — Apache Maven build tool long alias / Maven Daemon (Apache Software Foundation, Java); commons-cli + Plexus
# upstream: https://github.com/apache/maven

_maven() {
    local -a phases=(
        'clean:remove all output files' 'validate:validate the project' 'compile:compile sources'
        'test:run unit tests' 'package:package compiled code' 'verify:run integration tests'
        'install:install package in local repo' 'deploy:deploy artifact to remote repo'
        'site:generate project site'
    )
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-V[show version and continue]' \
        '-am[also make dependencies]' \
        '-amd[also make dependents]' \
        '-B[run in batch mode]' \
        '--batch-mode[run in batch mode]' \
        '-C[fail if checksum mismatch]' \
        '--strict-checksums[fail if checksum mismatch]' \
        '-c[warn if checksum mismatch]' \
        '--lax-checksums[warn if checksum mismatch]' \
        '-cpu[check plugin updates]' \
        '--check-plugin-updates[check plugin updates]' \
        '-D+[define system property]:str:' \
        '--define=+[define system property]:str:' \
        '-e[produce execution error messages]' \
        '--errors[produce execution error messages]' \
        '-emp+[encrypted master password]:str:' \
        '--encrypt-master-password=+[encrypted master password]:str:' \
        '-ep+[encrypt password]:str:' \
        '--encrypt-password=+[encrypt password]:str:' \
        '-f+[force POM file]:file:_files -g "pom.xml *.xml"' \
        '--file=+[force POM file]:file:_files -g "pom.xml *.xml"' \
        '-fae[fail at end]' \
        '--fail-at-end[fail at end]' \
        '-ff[fail fast]' \
        '--fail-fast[fail fast]' \
        '-fn[never fail build]' \
        '--fail-never[never fail build]' \
        '-gs+[global settings file]:file:_files -g "*.xml"' \
        '--global-settings=+[global settings file]:file:_files -g "*.xml"' \
        '-l+[log file]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '-N[do not recurse into subprojects]' \
        '--non-recursive[do not recurse into subprojects]' \
        '-o[work offline]' \
        '--offline[work offline]' \
        '-P+[profile list]:str:' \
        '--activate-profiles=+[profile list]:str:' \
        '-pl+[project list]:str:' \
        '--projects=+[project list]:str:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-rf+[resume from project]:str:' \
        '--resume-from=+[resume from project]:str:' \
        '-s+[user settings file]:file:_files -g "*.xml"' \
        '--settings=+[user settings file]:file:_files -g "*.xml"' \
        '-t+[toolchains file]:file:_files -g "*.xml"' \
        '--toolchains=+[toolchains file]:file:_files -g "*.xml"' \
        '-T+[thread count]:n:' \
        '--threads=+[thread count]:n:' \
        '-U[force update]' \
        '--update-snapshots[force update]' \
        '-up[no update plugins]' \
        '--update-plugins[no update plugins]' \
        '-X[debug output]' \
        '--debug[debug output]' \
        '*:phase-or-goal:_values phase $phases'
}

_maven "$@"
