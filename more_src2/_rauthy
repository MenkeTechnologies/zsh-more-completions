#compdef rauthy
# _rauthy — OIDC / OAuth2 / PAM Single Sign-On IdP (sebadob/rauthy)
# upstream: https://github.com/sebadob/rauthy
# Subcommands + flags from src/bin/src/cli_args.rs (clap).

_rauthy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_rauthy_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                serve)
                    _arguments \
                        '(-c --config-file)'{-c+,--config-file=}'[config file path (default: ./config.toml)]:file:_files -g "*.toml"' \
                        '(-t --test)'{-t,--test}'[integration test mode (debug builds only)]'
                    ;;
                generate-config)
                    _arguments \
                        '(-o --output-file)'{-o+,--output-file=}'[write the new config to this file]:file:_files' \
                        '--overwrite[overwrite the output file if it exists]'
                    ;;
                validate-config)
                    _arguments \
                        '(-p --path)'{-p+,--path=}'[config file to validate]:file:_files -g "*.toml"'
                    ;;
                generate-enc-key)
                    _arguments \
                        '(-k --with-key-id)'{-k+,--with-key-id=}'[explicit key id (regex [a-zA-Z0-9:_-]{2,20})]:keyid:'
                    ;;
                hash-password)
                    _arguments \
                        '(-m --m-cost)'{-m+,--m-cost=}'[Argon2 memory cost in bytes (>=32768)]:n:' \
                        '(-t --t-cost)'{-t+,--t-cost=}'[Argon2 iterations]:n:' \
                        '(-p --p-cost)'{-p+,--p-cost=}'[Argon2 parallel threads]:n:'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_rauthy_commands] )) ||
_rauthy_commands() {
    local -a commands
    commands=(
        'serve:start the Rauthy server'
        'generate-config:generate a starter config.toml'
        'validate-config:validate an existing Rauthy config file'
        'generate-enc-key:generate a secure encryption key'
        'generate-secrets:generate Raft cluster secrets'
        'hash-password:hash a password with Rauthy Argon2 parameters'
    )
    _describe -t commands 'rauthy command' commands
}

_rauthy "$@"
