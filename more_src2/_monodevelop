#compdef monodevelop
# _monodevelop — MonoDevelop / Xamarin Studio IDE (C#); cross-platform .NET / Mono IDE
# upstream: https://github.com/mono/monodevelop

_monodevelop() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--verbose[verbose log]' \
        '--debug[debug log]' \
        '--ipc-tcp[force TCP IPC]' \
        '--new-window[force new window]' \
        '--no-redirect[do not redirect stdout]' \
        '--no-recent[do not save recent items]' \
        '--profile[profile mode]' \
        '--clog[continuous log]' \
        '--clog-level+[log level]:level:(Debug Info Warn Error Fatal)' \
        '--user-config+[user config dir]:dir:_files -/' \
        '--user-data+[user data dir]:dir:_files -/' \
        '--user-cache+[user cache dir]:dir:_files -/' \
        '--user-log+[user log dir]:dir:_files -/' \
        '*:project or file:_files'
}

_monodevelop "$@"
