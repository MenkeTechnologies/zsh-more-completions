#compdef refurb
# Documentation: https://github.com/dosisod/refurb
# Reference accessed: 2026-05-20
# Verified: upstream README at the URL above.
# Fixed --sort enum from invented "category" to documented values
# filename/error. Added --timing-stats, --no-color, --verbose / -v.
# Restored sub-command stub for `refurb gen`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help message]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--debug[show AST debug information]' \
  '--quiet[suppress all output except errors]' \
  '*--enable=[enable specific check]:check id:' \
  '*--disable=[disable specific check]:check id:' \
  '--enable-all[enable all checks]' \
  '--disable-all[disable all checks]' \
  '*--ignore=[ignore error code]:error code:' \
  '*--load=[load custom check module]:module:' \
  '--config-file=[path to config file]:config:_files' \
  '--python-version=[target Python version]:version:(3.7 3.8 3.9 3.10 3.11 3.12 3.13)' \
  '--format=[output format]:format:(text github)' \
  '--sort=[sort order]:sort:(filename error)' \
  '--no-color[disable colored output]' \
  '--timing-stats=[write timing stats to file]:file:_files' \
  '--explain=[explain an error code]:error code:' \
  '*:file or directory:_files' && ret=0

return ret
