#compdef glance-manage
# Documentation: https://docs.openstack.org/glance/latest/cli/glancemanage.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# glance-manage: DB / admin commands (db_* subcommands only)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'db_version:display current migration level'
  'db_upgrade:upgrade DB to a specified version'
  'db_version_control:place database under migration control'
  'db_sync:initialize and upgrade the database'
  'db_expand:rolling upgrade expand step'
  'db_migrate:rolling upgrade migrate step'
  'db_contract:rolling upgrade contract step'
  'db_export_metadefs:export metadata definitions to JSON'
  'db_load_metadefs:import metadata definitions from JSON'
  'db_unload_metadefs:clear metadata definitions from DB'
  'db_purge:purge old soft-deleted rows'
  'db_purge_images_table:purge old soft-deleted image rows'
)
_arguments -C \
\
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "--debug[set log level to debug]" \
  "-d[set log level to debug]" \
  "(-v --verbose)"{-v,--verbose}"[verbose output]" \
  "--log-config-append=[log config file]:file:_files" \
  "--log-date-format=[log date format]:fmt:" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--log-format=[log format]:fmt:" \
  "--nodebug[do not set log level to debug]" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  "--watch-log-file[watch log file]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'glance-manage command' commands && ret=0 ;;
esac
return ret
