#compdef irecovery
# _irecovery — talk to iBoot / iBSS over USB (libimobiledevice/libirecovery)
# upstream: https://github.com/libimobiledevice/libirecovery
# Flags from tools/irecovery.c.

_irecovery() {
    local -a args
    args=(
        '(-i --ecid)'{-i+,--ecid=}'[connect to a specific device by ECID]:ecid:'
        '(-c --command)'{-c+,--command=}'[run CMD on the device]:cmd:'
        '(-m --mode)'{-m,--mode}'[print the current device mode (Normal / Recovery / DFU / WTF)]'
        '(-f --file)'{-f+,--file=}'[send FILE to the device]:file:_files'
        '(-k --payload)'{-k+,--payload=}'[send limera1n USB exploit payload from FILE]:file:_files'
        '(-r --reset)'{-r,--reset}'[reset the iBoot client]'
        '(-n --normal)'{-n,--normal}'[reboot the device into normal mode (exit recovery loop)]'
        '(-e --script)'{-e+,--script=}'[execute the recovery script FILE]:file:_files'
        '(-s --shell)'{-s,--shell}'[start an interactive shell]'
        '(-q --query)'{-q,--query}'[query device info]'
        '(-a --devices)'{-a,--devices}'[list info for all known devices]'
        '*'{-v,--verbose}'[enable verbose output (repeat for higher verbosity)]'
        '(- *)'{-h,--help}'[show help]'
    )
    _arguments -s -S $args
}

_irecovery "$@"
