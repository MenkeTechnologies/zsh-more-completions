#compdef filebrowser
# _filebrowser-srv — File Browser Go web-based file manager (Filebrowser team); HTTP UI for browsing/uploading files
# upstream: https://github.com/filebrowser/filebrowser

_filebrowser-srv() {
    local -a sub=(
        'config:configure database settings'
        'hash:hash a password'
        'rules:manage allow/deny rules'
        'users:user management'
        'upgrade:upgrade db schema'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '-a+[bind address]:addr:' \
        '-p+[port]:port:' \
        '-r+[root dir]:dir:_files -/' \
        '-b+[baseurl]:str:' \
        '-d+[database file]:file:_files' \
        '-c+[config file]:file:_files' \
        '-t+[TLS cert]:file:_files' \
        '-k+[TLS key]:file:_files' \
        '--socket+[unix socket]:file:_files' \
        '--cache-dir+[cache dir]:dir:_files -/' \
        '--img-processors+[image processors]:n:' \
        '--locale+[locale]:locale:' \
        '--log+[log file]:file:_files' \
        '--no-auth[disable auth]' \
        '--auth.method+[auth method]:method:(json noauth proxy hook)' \
        '--branding.name+[branding name]:name:' \
        '--branding.disableExternal[disable external links]' \
        '--branding.files+[branding files dir]:dir:_files -/' \
        '--password+[bcrypt password]:pw:' \
        '--commands+[allowed commands]:cmds:' \
        '--username+[default user]:user:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'filebrowser subcommand' sub ;;
        args)
            case $words[1] in
                users) _arguments \
                    '1:users cmd:(add update find ls rm import export)' \
                    '*:args:' ;;
                rules) _arguments \
                    '1:rules cmd:(add ls rm)' \
                    '*:args:' ;;
                config) _arguments \
                    '1:config cmd:(init set get cat import export)' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_filebrowser-srv "$@"
