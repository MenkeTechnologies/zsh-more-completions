#compdef eprover
# _eprover — Stephan Schulz eprover CLI E equational theorem prover for first-order logic with equality reading TPTP-syntax LOP-syntax problem files producing CNF-resolution paramodulation rewriting term-ordering-driven proof search emitting JSON Prover9 SAT-DIMACS proof-object-output ATP-pipeline format (Stephan Schulz team, C); getopt
# upstream: https://www.eprover.org/

_eprover() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[silent]' \
        '--silent[silent]' \
        '-l+[verbosity level]:l:(0 1 2 3 4 5 6)' \
        '-x+[exit on result]:s:(yes no)' \
        '--cpu-limit=+[sec]:n:' \
        '--soft-cpu-limit=+[sec]:n:' \
        '--memory-limit=+[MB]:n:' \
        '--auto[automatic mode]' \
        '--auto-schedule[automatic schedule mode]' \
        '--auto-schedule2[automatic schedule v2]' \
        '--satauto-schedule[SAT auto schedule]' \
        '-G+[goals from]:str:' \
        '--free-numbers[free numbers as constants]' \
        '--tptp-in[TPTP input format]' \
        '--tptp2-in[TPTP-2 input format]' \
        '--tptp3-in[TPTP-3 input format]' \
        '--tptp-out[TPTP output format]' \
        '--tstp-in[TSTP input format]' \
        '--tstp-out[TSTP output format]' \
        '--tstp-format[TSTP format]' \
        '--print-statistics[print statistics]' \
        '--output-file=+[file]:file:_files' \
        '-o+[file]:file:_files' \
        '--proof-object[output proof object]' \
        '--proof-object-output=+[fmt]:f:(graph dot json)' \
        '--full-deriv[full derivation]' \
        '--print-saturated[print saturated set]' \
        '--print-pid[print pid]' \
        '--print-version[print version]' \
        '--print-strategy[print strategy]' \
        '*:problem file:_files -g "*.p *.tptp *.fof *.cnf *.tff *.thf"'
}

_eprover "$@"
