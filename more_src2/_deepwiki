#compdef deepwiki
# Documentation: https://github.com/qwadratic/deepwiki-cli
# Reference accessed: 2026-05-22
# Verified: src/index.ts Commander command definitions.

# Zsh completion for deepwiki - DeepWiki API CLI for public GitHub repo docs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'deepwiki command' \
      'query[query DeepWiki about repositories]' \
      'get[get query result by ID]' \
      'status[check query status]' \
      'list[list queries]' \
      'warm[warm repository index]' && ret=0
    ;;
  args)
    case $line[1] in
      query)
        _arguments \
          '(-m --mode)'{-m,--mode}'[query mode]:mode:(fast deep codemap)' \
          '(-s --stream)'{-s,--stream}'[stream NDJSON response]' \
          '(-c --context)'{-c,--context}'[additional context]:text:' \
          '--id[reuse query ID for follow-ups]:id:' \
          '--no-summary[disable summary generation]' \
          '--mermaid[output Mermaid diagram for codemap]' \
          '1:query:' \
          '*:repo:' && ret=0
        ;;
      get|status)
        _arguments '1:query id:' && ret=0
        ;;
      warm|list)
        _arguments '*:repo:' && ret=0
        ;;
    esac
    ;;
esac

return ret
