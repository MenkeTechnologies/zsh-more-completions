#compdef gnmanalyse
# Documentation: https://gdal.org/en/stable/programs/gnmanalyse.html
# Source: OSGeo/gdal apps/gnmanalyse.cpp — Geographic Network analyzer (Dijkstra, K-paths, connected components).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)--help[show help]' \
    '(-q -quiet)'{-q,-quiet}'[suppress progress output]' \
    '-ds+[destination dataset path]:ds:_files' \
    '-f+[output dataset format]:format:_default' \
    '-l+[result layer name]:layer:_default' \
    '*-dsco+[dataset creation option NAME=VALUE]:option:_default' \
    '*-lco+[layer creation option NAME=VALUE]:option:_default' \
    '*-alo+[algorithm-specific option NAME=VALUE]:option:_default' \
    '1:subcommand:(dijkstra kpaths resource)' \
    '*::args:_files' \
    && ret=0

return ret
