#compdef rdiff
# Documentation: https://librsync.github.io/page_rdiff.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity]' \
  '(-s --statistics)'{-s,--statistics}'[show statistics]' \
  '(-f --force)'{-f,--force}'[force overwrite output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'signature:Generate a signature file'
      'delta:Generate a delta file'
      'patch:Apply a delta file'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (signature)
        _arguments \
          '(-b --block-size)'{-b,--block-size}'=[block size]:size:' \
          '(-S --sum-size)'{-S,--sum-size}'=[checksum size]:size:' \
          '--hash=[hash algorithm]:hash:(md4 blake2)' \
          '1:basis file:_files' \
          '2::signature file:_files' && ret=0
        ;;
      (delta)
        _arguments \
          '1:signature file:_files' \
          '2:new file:_files' \
          '3::delta file:_files' && ret=0
        ;;
      (patch)
        _arguments \
          '1:basis file:_files' \
          '2:delta file:_files' \
          '3::output file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
