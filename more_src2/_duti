#compdef duti
# Documentation: https://github.com/moretension/duti
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for duti - macOS default app handler tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[print usage and exit]' \
  '(- *)-V[print version and exit]' \
  '-v[verbose output]' \
  '-d[display the default handler for a UTI and exit]:uti:' \
  '-l[display all handlers for a UTI and exit]:uti:' \
  '-s[set the handler from arguments]' \
  '-x[print default application for extension]:extension:' \
  '*:settings file or path:_files' && ret=0

return ret
