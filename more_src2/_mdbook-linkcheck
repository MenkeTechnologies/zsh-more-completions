#compdef mdbook-linkcheck
# Documentation: https://github.com/Michael-F-Bryan/mdbook-linkcheck
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-s --standalone)'{-s,--standalone}'[run standalone, not as an mdbook plugin]' \
  '(-c --colour)'{-c+,--colour=}'[output colouring]:choice:(always auto never)' \
  '(-f --files)'{-f+,--files=}'[only check the given files]:files:_files' \
  '--no-cache[ignore existing cache, neither using nor updating it]' \
  '1:book directory:_directories' && return 0
