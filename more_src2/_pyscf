#compdef pyscf
# Documentation: https://pyscf.org/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. STUB — PySCF is a Python
# library invoked as `python script.py`; it has no canonical CLI of its
# own. Completion just offers a Python script as the argument.

# PySCF: Python-based simulations of chemistry framework (script runner)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:Python script:_files -g "*.py"' && ret=0
return ret
