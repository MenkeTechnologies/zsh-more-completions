#compdef pnmmercator
# Documentation: man pnmmercator (Netpbm)
# Source: convert a Netpbm equirectangular map to a Mercator-projection map (or inverse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-inverse[inverse projection (Mercator -> equirectangular)]' \
    '-nomix[no anti-aliasing]' \
    '(-verbose -vverbose)-verbose[verbose output]' \
    '(-verbose -vverbose)-vverbose[very verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
