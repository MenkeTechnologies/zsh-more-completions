#compdef orb orbctl
# Documentation: https://docs.orbstack.dev/quick-start
# Reference accessed: 2026-05-17
# Verified: OrbStack `orb`/`orbctl` upstream command surface
# (create, delete, list, start, stop, restart, rename, default, info,
# status, logs, shell, run, ssh, debug, push, pull, config, login,
# logout, update, migrate, docker, k8s, report, reset, completion,
# version, help) plus global -m/--machine, -u/--user flags.
# Removed from prior file: bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'create:create a new Linux machine'
  'delete:delete a machine'
  'list:list machines'
  'start:start OrbStack or a machine'
  'stop:stop OrbStack or a machine'
  'restart:restart a machine'
  'rename:rename a machine'
  'default:view or set default machine'
  'info:show machine details'
  'status:show OrbStack status'
  'logs:show machine logs'
  'shell:open an interactive shell'
  'run:run a command in a machine'
  'ssh:show SSH connection info'
  'debug:debug Docker containers'
  'push:copy files into Linux'
  'pull:copy files from Linux'
  'config:show or set OrbStack settings'
  'login:authenticate and activate license'
  'logout:logout of account'
  'update:update OrbStack'
  'migrate:migrate from Docker Desktop'
  'docker:Docker-related commands'
  'k8s:Kubernetes management'
  'report:collect diagnostic info'
  'reset:erase all Linux and Docker data'
  'completion:generate shell completion'
  'version:show version'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-m --machine)'{-m+,--machine=}'[target machine]:machine:' \
  '(-u --user)'{-u+,--user=}'[user inside the machine]:user:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'orb command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--arch=[machine architecture]:arch:(arm64 amd64)' \
          '(-u --user)'{-u+,--user=}'[default user]:user:' \
          '(-c --config)'{-c+,--config=}'[cloud-init config file]:file:_files' \
          '*::distro_or_name:' && ret=0 ;;
      (delete|start|stop|restart|info|logs|rename|default|ssh)
        _arguments '*::machine:' && ret=0 ;;
      (push|pull)
        _arguments \
          '(-m --machine)'{-m+,--machine=}'[machine]:machine:' \
          '(-u --user)'{-u+,--user=}'[user]:user:' \
          '*::path:_files' && ret=0 ;;
      (run)
        _arguments \
          '(-m --machine)'{-m+,--machine=}'[machine]:machine:' \
          '(-u --user)'{-u+,--user=}'[user]:user:' \
          '*::command:_command_names' && ret=0 ;;
      (config)
        _arguments \
          '*::subcmd:(get set show)' && ret=0 ;;
      (k8s)
        local -a k8s_subs=(
          'enable:enable Kubernetes'
          'disable:disable Kubernetes'
          'status:show Kubernetes status'
          'kubeconfig:show kubeconfig path'
        )
        _describe -t kcmds 'k8s subcommand' k8s_subs && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
