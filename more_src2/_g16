#compdef g16
# _g16 — Gaussian Inc Gaussian 16 quantum chemistry program direct executable form (gaussian team, Fortran); custom argparse
# upstream: https://gaussian.com

_g16() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-c[checkpoint file]:file:_files -g "*.chk"' \
        '--chk=+[checkpoint file]:file:_files -g "*.chk"' \
        '-r+[rwf file]:file:_files -g "*.rwf"' \
        '--rwf=+[rwf file]:file:_files -g "*.rwf"' \
        '-y+[restart file]:file:_files -g "*.rwf"' \
        '-i+[input file]:file:_files -g "*.gjf *.com *.gau *.inp"' \
        '-o+[output file]:file:_files -g "*.out *.log"' \
        '-p+[number of CPUs]:n:' \
        '-l+[link]:str:' \
        '-m+[memory MB]:n:' \
        '-t+[scratch dir]:dir:_files -/' \
        '-d+[debug level]:n:' \
        '-x+[external scratch]:dir:_files -/' \
        '-s+[short trace]:b:(0 1)' \
        '--nproc=+[CPUs]:n:' \
        '--mem=+[memory]:n:' \
        '*:input file:_files -g "*.gjf *.com *.gau *.inp"'
}

_g16 "$@"
