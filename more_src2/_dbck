#compdef dbck
# Documentation: NSS internal database checker
# Source: nss-dev/nss cmd/dbck/dbck.c (master) — NSS cert8.db consistency/repair tool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-H[show long help]' \
    '(-D -R)-D[dump analysis (read-only)]' \
    '(-D -R)-R[repair database]' \
    '-d+[NSS cert database directory]:dir:_files -/' \
    '-m[put database graph in ./mailfile (default stdout)]' \
    '-v[verbose, dump cert8.db contents]' \
    '-f+[dumpfile for verbose output]:file:_files' \
    '-o+[output database name]:dbname:_default' \
    '-a[recover all certs/keys]' \
    '-p[recover personal certs]' \
    '-r[recover root certs]' \
    '-s[recover certs by subject]' \
    '-x[recover expired certs]' \
    && ret=0

return ret
