#compdef rocker rocker-cli
# _rocker — Rocker R Docker images project CLI alias (Rocker Project / rocker-org, Dockerfile + shell); custom argparse
# upstream: https://github.com/rocker-org/rocker

_rocker() {
    local -a sub=(
        'pull:pull rocker image'
        'run:run rocker container'
        'build:build rocker image'
        'list:list rocker images'
        'inspect:inspect rocker image'
        'start:start rocker container'
        'stop:stop rocker container'
        'restart:restart rocker container'
        'logs:show container logs'
        'exec:exec command in rocker container'
        'clean:remove unused rocker images'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--image=+[rocker image]:i:(r-ver rstudio tidyverse verse geospatial ml ml-verse cuda binder shiny shiny-verse plumber)' \
        '-i+[rocker image]:i:(r-ver rstudio tidyverse verse geospatial ml ml-verse cuda binder shiny shiny-verse plumber)' \
        '--tag=+[image tag]:t:(latest 4.4.0 4.3.2 4.2.3 4.1.3 4.0.5 3.6.3)' \
        '-t+[image tag]:t:(latest 4.4.0 4.3.2 4.2.3 4.1.3 4.0.5 3.6.3)' \
        '--port=+[host port]:port:' \
        '-p+[host port]:port:' \
        '--user=+[user]:str:_users' \
        '-u+[user]:str:_users' \
        '--password=+[password]:str:' \
        '--volume=+[volume mount]:list:' \
        '-v+[volume mount]:list:' \
        '--name=+[container name]:str:' \
        '-n+[container name]:str:' \
        '--detach[detach]' \
        '-d[detach]' \
        '--gpu[GPU]' \
        '-g[GPU]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rocker subcommand' sub ;;
    esac
}

_rocker "$@"
