#compdef remotes
# _remotes — Posit Software remotes R package for installing R packages from GitHub GitLab Bitbucket SVN URL Bioconductor (r-lib team, R); R function
# upstream: https://github.com/r-lib/remotes

_remotes() {
    local -a sub=(
        'install_github:install from GitHub'
        'install_gitlab:install from GitLab'
        'install_bitbucket:install from Bitbucket'
        'install_svn:install from SVN'
        'install_url:install from URL'
        'install_bioc:install from Bioconductor'
        'install_cran:install from CRAN'
        'install_dev:install dev version from CRAN'
        'install_git:install from Git'
        'install_local:install from local archive'
        'install_version:install specific version'
        'install_deps:install dependencies'
        'update_packages:update installed packages'
        'package_deps:get package dependencies'
        'system_requirements:system requirements'
        'dev_package_deps:get dev dependencies'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--lib=+[library path]:dir:_files -/' \
        '--upgrade=+[mode]:m:(default ask always never)' \
        '--dependencies=+[deps]:str:' \
        '--repos=+[repos csv]:str:' \
        '--build=+[bool]:b:(true false)' \
        '--quick[quick install]' \
        '--quiet[quiet]' \
        '--force[force install]' \
        '--keep-source[keep source]' \
        '--type=+[type]:t:(source binary)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'remotes subcommand' sub ;;
    esac
}

_remotes "$@"
