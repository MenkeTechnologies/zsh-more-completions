#compdef rollbar-agent
# Documentation: https://github.com/rollbar/rollbar-agent
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rollbar-agent: log shipper for Rollbar error tracking.
# Upstream README documents no CLI flags; configuration is via
# rollbar-agent.conf. Minimal stub. STUB.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::rollbar-agent args:_files' && ret=0
return ret
