#compdef pod2text
# Documentation: pod2text --help
# Source: Perl POD pod2text — convert POD to plain text.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(-a --alt)'{-a,--alt}'[alternate output format]' \
    '--code[include non-POD text from input]' \
    '(-c --color)'{-c,--color}'[ANSI color output (needs Term\:\:ANSIColor)]' \
    '(-e --encoding)'{-e,--encoding=}'[output encoding]:enc:(UTF-8 ASCII iso-8859-1)' \
    '--errors=[error handling style]:style:(die warn pod none)' \
    '--guesswork=[heuristic rules]:rules:' \
    '(-i --indent)'{-i,--indent=}'[indent width]:n:' \
    '(-l --loose)'{-l,--loose}'[add blank line after =headN]' \
    '(-o --overstrike)'{-o,--overstrike}'[overstrike formatting]' \
    '(-q --quotes)'{-q,--quotes=}'[quote style for C<>]:quotes:' \
    '--nourls[no URL formatting]' \
    '(-s --sentence)'{-s,--sentence}'[double-space after sentences]' \
    '--stderr[error output to stderr]' \
    '(-t --termcap)'{-t,--termcap}'[use termcap for formatting]' \
    '(-u --utf8)'{-u,--utf8}'[shortcut for --encoding=UTF-8]' \
    '(-w --width)'{-w,--width=}'[output width]:n:' \
    '1:input POD:_files -g "*.{pod,pm,pl}"' \
    '*:output file:_files' \
    && ret=0

return ret
