#compdef grd2kml
# Documentation: https://docs.generic-mapping-tools.org/latest/grd2kml.html
# Source: GenericMappingTools/gmt classic-mode grd2kml — convert a grid to Google Earth KML quadtree tiles.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-N+[output prefix (top-level KML name)]:prefix:_default' \
    '-A+[altitude mode]:mode:(a g s)' \
    '-C+[colour palette (master/cpt/colors)]:cpt:_default' \
    '-E+[remote-host URL prefix]:url:_urls' \
    '-F+[downsampling filter]:filter:(b c g m)' \
    '-H+[rasterization quality (sub-pixel smoothing)]:scale:_default' \
    '-I+[illumination (file or constant)]:opts:_default' \
    '-L+[fixed tile size (default 256)]:n:_default' \
    '-S+[extra zoom levels past full res]:n:_default' \
    '-T+[KML document title]:title:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[contour overlay (cfile/pen)]:opts:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
