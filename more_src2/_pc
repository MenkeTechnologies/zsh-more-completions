#compdef pc pinecone
# Documentation: https://github.com/pinecone-io/cli
# Reference accessed: 2026-05-20
# Verified: upstream README. Binary is `pc`; also accept `pinecone` as
# an alias since some installs ship that name.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:authentication operations (login, configure, whoami, status)'
  'config:CLI configuration (set-api-key)'
  'target:set target organization and project context'
  'organization:manage organizations'
  'project:manage projects'
  'api-key:manage API keys'
  'index:index management and vector data operations'
  'completion:generate shell completion script'
  'help:show help'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--json[JSON output]' \
  '--profile=[profile to use]:profile:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'pc command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (auth)
        _arguments \
          '1:subcommand:(login configure whoami status)' \
          '*::arg:_files' && ret=0 ;;
      (config)
        _arguments \
          '1:subcommand:(set-api-key)' \
          '*::arg:_files' && ret=0 ;;
      (target)
        _arguments \
          '--org=[organization]:org:' \
          '--project=[project]:project:' && ret=0 ;;
      (organization)
        _arguments \
          '1:subcommand:(list describe update delete)' \
          '*::arg:_files' && ret=0 ;;
      (project)
        _arguments \
          '1:subcommand:(create list describe update delete)' \
          '*::arg:_files' && ret=0 ;;
      (api-key)
        _arguments \
          '1:subcommand:(create list describe update delete)' \
          '*::arg:_files' && ret=0 ;;
      (index)
        _arguments \
          '1:subcommand:(create list describe configure delete stats vector)' \
          '*::arg:_files' && ret=0 ;;
      (completion)
        _arguments '1:shell:(bash zsh fish powershell)' && ret=0 ;;
      (*) _files && ret=0 ;;
    esac ;;
esac

return ret
