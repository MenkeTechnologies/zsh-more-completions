#compdef ovhctl
# _ovhctl — Community ovhctl OVH cloud commandline interface for the OVH public cloud and bare-metal APIs (ovh team, Go); cobra
# upstream: https://github.com/ovh/cli

_ovhctl() {
    local -a sub=(
        'auth:authentication subcommands'
        'completion:generate completion'
        'me:show current user'
        'cloud:public cloud subcommands'
        'dedicated:dedicated server subcommands'
        'domain:domain subcommands'
        'hosting:web hosting subcommands'
        'ip:ip subcommands'
        'sms:SMS subcommands'
        'telephony:telephony subcommands'
        'vps:VPS subcommands'
        'config:configuration subcommands'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--region=+[region]:r:(ovh-eu ovh-ca ovh-us kimsufi-eu kimsufi-ca soyoustart-eu soyoustart-ca runabove-ca)' \
        '--application-key=+[key]:str:' \
        '--application-secret=+[secret]:str:' \
        '--consumer-key=+[key]:str:' \
        '-o+[format]:f:(text json yaml table)' \
        '--output=+[format]:f:(text json yaml table)' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ovhctl subcommand' sub ;;
        args)
            case $words[1] in
                cloud) _arguments '1:cloud cmd:(project instance flavor image volume network ssh-key snapshot storage region quota price billing user role)' ;;
                dedicated) _arguments '1:dedicated cmd:(server install boot ipmi monitoring intervention reboot reverse)' ;;
                domain) _arguments '1:domain cmd:(list info zone records dnssec contacts owo register transfer)' ;;
                vps) _arguments '1:vps cmd:(list info reboot start stop reset reinstall snapshot ipv4 ipv6)' ;;
                ip) _arguments '1:ip cmd:(list info move reverse rip mitigation game antiddos)' ;;
                auth) _arguments '1:auth cmd:(login logout request-consumer-key validate)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_ovhctl "$@"
