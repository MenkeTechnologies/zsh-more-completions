#compdef dumpfs
# Documentation: man dumpfs(8)
# Source: netbsd/src usr.sbin/dumpfs — dump UFS/FFS file system information (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[show each alternate superblock]' \
    '-c[show each cylinder group]' \
    '-F[dump filesystem image from a file]' \
    '-i[show each allocated inode]' \
    '-j[show WAPBL journal details]' \
    '-m[show cylinder group summary]' \
    '-s[show superblock details]' \
    '-v[increase verbosity]' \
    '*:filesystem or device:_files' \
    && ret=0

return ret
