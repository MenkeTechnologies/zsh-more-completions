#compdef git-credential-cache
# Documentation: man git-credential-cache(1)
# Source: git/git Documentation/git-credential-cache.adoc (master) — credential cache helper (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--timeout=[cache seconds (default 900)]:seconds:_default' \
    '--socket=[unix socket path]:file:_files' \
    '1::action:(get store erase exit)' \
    && ret=0

return ret
