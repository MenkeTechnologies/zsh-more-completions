#compdef pomo
# Documentation: https://github.com/kevinschoon/pomo/blob/master/pkg/cmd/cmd.go
# Reference accessed: 2026-05-21
# Verified against pomo source pkg/cmd/cmd.go (kevinschoon/pomo)

# Zsh completion for pomo (CLI pomodoro timer)

local curcontext="$curcontext" state line ret=1

local -a _pomo_subcommands
_pomo_subcommands=(
  'start:start a new task'
  's:start a new task'
  'init:initialize the sqlite database'
  'config:display the current configuration'
  'cf:display the current configuration'
  'create:create a new task without starting'
  'c:create a new task without starting'
  'begin:begin requested pomodoro'
  'b:begin requested pomodoro'
  'list:list historical tasks'
  'l:list historical tasks'
  'delete:delete a stored task'
  'd:delete a stored task'
  'status:output the current status'
  'st:output the current status'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'pomo subcommand' _pomo_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      start|s|create|c)
        _arguments \
          '-d[duration of each stent]:duration:' \
          '-p[number of pomodoros]:pomodoros:' \
          '*-t[tag associated with this task]:tag:' \
          '*:message:' && ret=0
        ;;
      begin|b)
        _arguments '1:task id:' && ret=0
        ;;
      list|l)
        _arguments \
          '-json[output task history as JSON]' \
          '-assend[sort tasks ascending in age]' \
          '-a[output all tasks]' \
          '-n[limit the number of results]:n:' \
          '-d[show tasks within this duration]:duration:' && ret=0
        ;;
      delete|d)
        _arguments '*:task id:' && ret=0
        ;;
      status|st)
        _arguments '-json[output status as JSON]' && ret=0
        ;;
    esac
    ;;
esac

return ret
