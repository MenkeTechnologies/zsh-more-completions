#compdef mayastor-agent-ha-cluster agent-ha-cluster
# _mayastor-agent-ha-cluster — Mayastor HA cluster agent (handles NVMe-oF path failover across the fleet by orchestrating per-node HA agents)
# upstream: https://github.com/openebs/mayastor-control-plane
# Flags from control-plane/agents/src/bin/ha/cluster/main.rs Cli on tip (clap).

_mayastor-agent-ha-cluster() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-g --grpc-endpoint)'{-g,--grpc-endpoint}'=[gRPC server bind address]:addr:' \
        '(-s --store)'{-s,--store}'=[persistent-store URL (etcd)]:url:_urls' \
        '--store-timeout=[persistent-store operation timeout]:duration:' \
        '(-c --core-grpc)'{-c,--core-grpc}'=[core gRPC URL]:url:_urls' \
        '(-j --jaeger)'{-j,--jaeger}'=[Jaeger collector endpoint]:url:_urls' \
        '*'{-t,--tracing-tags}'=[csv key=value tags for tracing (TRACING_TAGS)]:csv:' \
        '--fast-requeue=[fast-requeue period]:duration:' \
        '(-e --events-url)'{-e,--events-url}'=[NATS JetStream events URL]:url:_urls' \
        '--events-replicas=[JetStream replication factor for events]:n:' \
        '(-f --fmt-style)'{-f,--fmt-style}'=[log format style]:style:(default compact pretty json)' \
        '--ansi-colors=[enable ANSI colours]:bool:(true false)'
}

_mayastor-agent-ha-cluster "$@"
