#compdef foamNewApp
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamNewApp — create a new OpenFOAM application skeleton with wmake files/options.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-plain -p)'{-plain,-p}'[create a plain application for non-CFD use]' \
    '*:application name:' \
    && ret=0

return ret
