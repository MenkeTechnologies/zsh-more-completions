#compdef lspcmcia pccardctl
# Documentation: man lspcmcia(8) / pccardctl(8)
# Source: pcmciautils src/pccardctl.c — PCMCIA/PC-Card control utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '*'{-v,--verbose}'[verbose output (stackable)]' \
    '1:command:(ls insert eject suspend resume reset info status config ident)' \
    '*::socket:_default' \
    && ret=0

return ret
