#compdef delv-cli
# _delv-cli — ISC delv Domain Entity Lookup & Validation utility CLI alias (ISC team, C); custom argparse
# upstream: https://github.com/isc-projects/bind9

_delv-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-4[ipv4]' \
        '-6[ipv6]' \
        '-a+[anchor file]:file:_files' \
        '-b+[address]:str:' \
        '-c+[class]:c:(IN CH HS)' \
        '-d+[debug level]:n:' \
        '-i[ignore IP source]' \
        '-m[memory debug]' \
        '-p+[port]:port:' \
        '-q+[name]:str:' \
        '-t+[type]:str:' \
        '-x+[reverse address]:str:' \
        '-tcp[force TCP]' \
        '-tls[force TLS]' \
        '+anchor=+[file]:file:_files' \
        '+all[show all]' \
        '+cd[checking disabled]' \
        '+class[show class]' \
        '+comments[show comments]' \
        '+crypto[show crypto]' \
        '+dlv=+[anchor]:str:' \
        '+dnssec[request DNSSEC]' \
        '+mtrace[show messages]' \
        '+multiline[multiline output]' \
        '+ns[show NS]' \
        '+root=+[anchor name]:str:' \
        '+rrcomments[show RR comments]' \
        '+rtrace[show messages]' \
        '+short[short form]' \
        '+split=+[width]:n:' \
        '+sudpsize=+[size]:n:' \
        '+trust[show trust chain]' \
        '+ttl[show ttl]' \
        '+ttlunits[show ttl units]' \
        '+unknownformat[unknown format]' \
        '+vtrace[validation trace]' \
        '+yaml[yaml output]' \
        '*:name type class:'
}

_delv-cli "$@"
