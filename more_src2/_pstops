#compdef pstops psselect epsffit extractres includeres
# Documentation: https://manpages.debian.org/bookworm/psutils/{pstops,psselect,epsffit,extractres,includeres}.1.en.html
# Reference accessed: 2026-05-30
# psutils Round 2 — companion to the earlier _psnup multi-stem (psnup +
# psresize + psbook + ps2pdf, round 132). This file covers the 5 remaining
# Angus Duggan PostScript-transformation tools:
#   pstops     general page-by-page transform (the engine behind psnup)
#   psselect   page selector
#   epsffit    EPS bounding-box fitter
#   extractres extract resources from a PostScript document
#   includeres splice extracted resources back in

local curcontext="$curcontext" state line ret=1

local -a _papers
_papers=(a0 a1 a2 a3 a4 a5 b5 letter legal tabloid statement executive folio quarto 10x14)

case $service in

  pstops)
    _arguments -s -S \
      '-q[suppress page-number output]' \
      '-b[prevent `bind` ops in PS prolog from binding]' \
      '-w+[output paper width]:width:' \
      '-h+[output paper height]:height:' \
      '-p+[output paper size]:paper:'"($_papers)" \
      '-d+[draw border line (default 1pt)]:lwidth:' \
      '1:page-spec (e.g. "2:0(0,0)+1(0,0)"):' \
      '2:infile:_files -g "*.(ps|eps)"' \
      '3:outfile:_files -g "*.(ps|eps)"' \
      && ret=0
    ;;

  psselect)
    _arguments -s -S \
      '-q[suppress page-number output]' \
      '(-e -o)-e[select even pages]' \
      '(-e -o)-o[select odd pages]' \
      '-r[reverse page order]' \
      '-p+[page ranges (e.g. 1,3-5,7)]:pages:' \
      '1:infile:_files -g "*.(ps|eps)"' \
      '2:outfile:_files -g "*.(ps|eps)"' \
      && ret=0
    ;;

  epsffit)
    _arguments -s -S \
      '-c[centre image in bounding box]' \
      '-r[rotate 90° CCW]' \
      '(-a -m)-a[adjust aspect ratio to fit (default: preserve)]' \
      '(-a -m)-m[rotate to maximise size if better fit]' \
      '-s[append `showpage` so the image prints]' \
      '1:llx (lower-left X):' \
      '2:lly (lower-left Y):' \
      '3:urx (upper-right X):' \
      '4:ury (upper-right Y):' \
      '5:infile:_files -g "*.eps"' \
      '6:outfile:_files -g "*.eps"' \
      && ret=0
    ;;

  extractres)
    _arguments -s -S \
      '-m[combine same-named resources into one file (needed for some font downloaders)]' \
      && ret=0
    ;;

  includeres)
    # Pure stdin → stdout filter; no documented flags.
    return 0
    ;;

esac

return ret
