#compdef psmeca
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/seis/psmeca.html
# Source: GenericMappingTools/gmt supplements/seis — plot earthquake focal-mechanism beach balls.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[projection]:proj:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[focal-mechanism format + scale]:format:_default' \
    '-A+[offset focal mechanisms to alt coords]:opts:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT for depth coloring]:cpt:_files -g "*.cpt(-.)"' \
    '-D+[event depth range filter]:opts:_default' \
    '-E+[extensive-quadrant fill]:color:_default' \
    '-F+[axes / symbol / label attributes]:opts:_default' \
    '-G+[compressive-quadrant fill]:color:_default' \
    '-H+[per-record symbol scaling]:opts:_default' \
    '-I+[intensity modulation]:value:_default' \
    '-L+[beach-ball outline pen]:pen:_default' \
    '-N[plot outside frame]' \
    '-T+[nodal-plane visualization]:opts:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[line/symbol outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-di+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-t+[transparency percent]:pct:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
