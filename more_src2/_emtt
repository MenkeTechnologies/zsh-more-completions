_emtt() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-l --log-level)'{-l,--log-level}'=[log level (env LOG_LEVEL; default debug)]:level:(error warn info debug trace)' \
        '1: :_emtt_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                syslog)
                    _arguments \
                        '--bot-token=[Telegram bot token (env TELEGRAM_BOT_TOKEN)]:token:' \
                        '--chat-id=[Telegram chat ID (env TELEGRAM_CHAT_ID)]:chat-id:' \
                        '--api-server=[self-hosted Bot API server URL (env TELEGRAM_API_SERVER)]:url:' \
                        '--template=[minijinja message template (env TELEGRAM_TEMPLATE)]:template:' \
                        '--parse-mode=[Telegram parse mode (default html)]:mode:(html markdown markdown-v2)' \
                        '--syslog-host=[UDP listen host (env SYSLOG_HOST; default 0.0.0.0)]:host:' \
                        '--syslog-port=[UDP listen port (env SYSLOG_PORT; default 50514)]:port:' \
                        '--dm=[forward direct messages (env MESH_DM; default true)]:bool:(true false)' \
                        '--channel=[restrict to a specific Meshtastic channel (env MESH_CHANNEL)]:channel:' \
                        '--proxy-url=[SOCKS-/HTTPS-proxied Telegram egress (env PROXY_URL)]:url:' \
                        '--webhook-url=[additional generic webhook POST target (env WEBHOOK_URL)]:url:' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_emtt_commands] )) ||
_emtt_commands() {
    local -a commands
    commands=(
        'syslog:run in syslog-bridge mode (Meshtastic → Telegram daemon)'
    )
    _describe -t commands 'emtt command' commands
}

_emtt "$@"
