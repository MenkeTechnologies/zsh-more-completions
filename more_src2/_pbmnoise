#compdef pbmnoise
# Documentation: man pbmnoise (Netpbm)
# Source: generate a random-noise PBM image of given dimensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-ratio=[black:white ratio M/N]:ratio:' \
    '-pack[pack output into raw bytes]' \
    '-randomseed=[random seed]:integer:' \
    '-endian=[byte endianness]:endian:(big little native swap)' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    && ret=0

return ret
