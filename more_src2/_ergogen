_ergogen() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-o --output)'{-o,--output}'[output folder]:dir:_files -/' \
        '(-d --debug)'{-d,--debug}'[debug mode]' \
        '--clean[clean output directory before parsing]' \
        '(--svg --generate-svg)'{--svg,--generate-svg}'[generate SVG outputs]' \
        '(- *)--version[print version]' \
        '(- *)--help[print help]' \
        '1:config file:_files -g "*.(yaml|yml)"'
}

_ergogen "$@"
