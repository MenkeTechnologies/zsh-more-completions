# ergogen - ergonomic mechanical-keyboard
#            layout/PCB/case generator (Node.js,
#            MIT)
#
# Author : Bán Dénes (mr@zealot.hu / mrZealot)
# Upstream: https://github.com/ergogen/ergogen
# Homepage: https://ergogen.xyz
# npm    : ergogen (binary: ergogen)
#
# `ergogen` is the de-facto canonical tool in the
# ergonomic mechanical-keyboard hobbyist community
# for generating complete keyboard build artifacts
# from a single YAML config file. From a ~100-line
# YAML spec describing key positions, key roles,
# and design constraints, it emits:
#   - Points: anchor-based key positions in 2D
#     space
#   - Outlines: case + plate outline polygons
#     (DXF, JSCAD, or SVG)
#   - Cases: 3D-printable case STL files (via
#     JSCAD compilation)
#   - PCBs: full KiCad PCB files (.kicad_pcb)
#     with switches + diodes + microcontroller
#     + USB footprints + routed traces
#   - Footprints: programmatically defined
#     switch + MCU footprints
#
# Output is bundled into a downloadable `.zip`
# file (via jszip) containing all generated
# artifacts ready for fab houses (JLCPCB, PCBWay,
# Aisler, OSH Park) + 3D-printing services.
#
# Use cases:
#   - Designing a custom ergonomic mechanical
#     keyboard from scratch (Corne, Lily58,
#     Kyria, Sofle, etc. all have ergogen YAMLs
#     in the community)
#   - Iterating on keyboard ergonomics by
#     tweaking YAML + regenerating PCB +
#     case in one step
#   - Teaching keyboard PCB design without
#     requiring KiCad expertise upfront
#   - Generating manufacturable PCB files for
#     JLCPCB/PCBWay assembly orders
#
# Usage:
#   ergogen <config_file> [options]
#
# Positional:
#   <config_file>                - YAML config
#                                   file describing
#                                   keyboard layout
#                                   (required)
#
# Flags (yargs v17 declarative):
#   -o, --output <dir>           - output folder
#                                   (default
#                                   `./output`)
#   -d, --debug                  - debug mode
#                                   (emits
#                                   intermediate
#                                   artifacts +
#                                   verbose
#                                   logging)
#       --clean                  - clean output
#                                   directory
#                                   before parsing
#       --svg                    - generate SVG
#                                   outputs in
#                                   addition to
#                                   DXF/JSCAD/STL
#                                   (alias
#                                   --generate-svg)
#       --version                - print yargs
#                                   version
#       --help                   - print yargs
#                                   help
#
# Example invocation:
#   ergogen corne.yaml -o ./out --clean --svg
#   ergogen --debug kyria.yaml
#
# Example YAML config (corne-style 42-key split):
#   meta:
#     engine: 4.1.0
#     name: my-corne
#     author: anonymous
#     version: 1.0.0
#     license: MIT
#   units:
#     kx: cx
#     ky: cy
#   points:
#     zones:
#       matrix:
#         columns:
#           pinky: { rotate: 5 }
#           ring: { spread: 19 }
#           middle: { spread: 19, stagger: 5 }
#           index: { spread: 19, stagger: -3 }
#         rows:
#           bottom:
#           home:
#           top:
#   outlines:
#     plate:
#       - what: rectangle
#         where: true
#         size: [kx-0.5, ky-0.5]
#         operation: stack
#   pcbs:
#     my_corne_pcb:
#       outlines:
#         main:
#           outline: plate
#       footprints:
#         switches:
#           what: ergogen/key
#           where: true
#           params:
#             from: matrix
#             to: row{row}
#
