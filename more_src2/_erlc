#compdef erlc
# Documentation: erlc -help
# Source: Erlang/OTP erlc — Erlang compiler driver.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b+[type of output file (e.g. beam)]:type:(beam jam asm core src)' \
    '-d[turn on debugging of erlc itself]' \
    '*-D-[define preprocessor symbol]:NAME[=VALUE]:' \
    '(- *)-help[show help]' \
    '*-I+[include search path]:dir:_files -/' \
    '(-M -MD -MMD)-M[generate make dependency rule]' \
    '-MF+[dependency output file]:file:_files' \
    '-MT+[target of dependency rule]:target:' \
    '-MQ+[quote-escaped target of rule]:target:' \
    '-MG[treat missing headers as generated deps]' \
    '-MP[add phony target for each dep]' \
    '(-M -MD -MMD)-MD[same as -M with default file]' \
    '(-M -MD -MMD)-MMD[generate deps as a side-effect]' \
    '-o+[output directory or file]:name:_files -/' \
    '*-pa+[prepend path to code path]:dir:_files -/' \
    '*-pz+[append path to code path]:dir:_files -/' \
    '-v[verbose compiler output]' \
    '-Werror[warnings into errors]' \
    '-W0[disable warnings]' \
    '-Wall[enable all warnings]' \
    '-W[enable warnings (default; same as -W1)]' \
    '-W1[warning level 1]' \
    '-W2[warning level 2]' \
    '-W3[warning level 3]' \
    '(-E -S -P)-E[generate listing of expanded code]' \
    '(-E -S -P)-S[generate assembly listing]' \
    '(-E -S -P)-P[generate listing of preprocessed code]' \
    '-enable-feature+[enable feature]:feature:' \
    '-disable-feature+[disable feature]:feature:' \
    '(- *)-list-features[list available features]' \
    '-describe-feature+[long description of feature]:feature:' \
    '*+-[pass Erlang term to compiler]:term:' \
    '*:Erlang source:_files -g "*.{erl,beam,yrl,xrl,S,core}"' \
    && ret=0

return ret
