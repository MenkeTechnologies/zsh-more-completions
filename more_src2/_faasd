#compdef faasd
# Documentation: https://github.com/openfaas/faasd/tree/master/cmd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'up:start faasd providers (reads docker-compose file)'
  'provider:run as the OpenFaaS faasd-provider'
  'install:install faasd with systemd units'
  'collect:collect function logs'
  'service:manage a faasd service'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'faasd command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (up)
        _arguments \
          {-f+,--file=}'[docker-compose YAML]:file:_files -g "*.{yaml,yml}"' && ret=0 ;;
      (provider)
        _arguments \
          '--pull-policy=[image pull policy]:policy:(IfNotPresent Always Never)' && ret=0 ;;
    esac ;;
esac

return ret
