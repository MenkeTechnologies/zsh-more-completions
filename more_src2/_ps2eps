#compdef ps2eps
# Documentation: ps2eps --help (v1.70)
# Source: Roland Bless — convert PostScript to Encapsulated PostScript (EPS).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-f --force)'{-f,--force}'[force overwriting existing files]' \
    '(-q --quiet)'{-q,--quiet}'[quiet operation]' \
    '(-N --noinsert)'{-N,--noinsert}'[do not insert any postscript code]' \
    '(-O --preserveorientation)'{-O,--preserveorientation}'[do not filter Orientation: header]' \
    '(-X --BBonly)'{-X,--BBonly}'[print resulting bounding box(es) only]' \
    '(-n --nofix -F --fixps)'{-n,--nofix}'[do not try to fix postscript code]' \
    '(-n --nofix -F --fixps)'{-F,--fixps}'[fix postscript code unconditionally]' \
    '(-P --removepreview)'{-P,--removepreview}'[remove preview image]' \
    '(-c --comments)'{-c,--comments}'[preserve document structure comments]' \
    '(-b --binary)'{-b,--binary}'[treat postscript as binary]' \
    '(-C --clip)'{-C,--clip}'[insert postscript code for clipping]' \
    '(-m --mono)'{-m,--mono}'[use black/white bitmap for calculation]' \
    '(-s --size)'{-s+,--size=}'[page size]:pagedim:' \
    '(-R --rotate)'{-R+,--rotate=}'[rotate resulting EPS]:direction:(+ - ^)' \
    '(-t --translate)'{-t+,--translate=}'[x,y offset in postscript points]:offset:' \
    '(-r --resolution)'{-r+,--resolution=}'[dpi resolution to render with ghostscript]:dpi:' \
    '(-l --loose)'{-l,--loose}'[expand bounding box by one point each direction]' \
    '(-B --ignoreBB)'{-B,--ignoreBB}'[do not use existing bounding box as page size]' \
    '(-E --ignoreEOF)'{-E,--ignoreEOF}'[do not use %%EOF as end-of-file hint]' \
    '*:ps file:_files -g "*.(ps|prn|eps)"' \
    && ret=0

return ret
