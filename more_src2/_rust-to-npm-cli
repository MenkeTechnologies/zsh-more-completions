#compdef rust-to-npm-cli
# Documentation: https://github.com/a11ywatch/rust-to-npm
# Reference accessed: 2026-05-23
# Verified: upstream README build/deploy subcommands.

# Zsh completion for rust-to-npm-cli - deploy Rust projects to crates.io and npm

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'build:build npm package locally without deploying'
  'deploy:build and deploy to crates.io and npm'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'rust-to-npm-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (build|deploy)
        _arguments \
          '(-b)'{-b}'[deploy to cargo and npm]' \
          '(-n)'{-n=}'[custom npm package name]:name:' \
          '--npm_package_name=[custom npm package name]:name:' \
          '--source[ship and compile project from source]' && ret=0 ;;
    esac ;;
esac

return ret
