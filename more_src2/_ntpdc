#compdef ntpdc
# _ntpdc — ntp-project ntpdc (legacy "mode 7" private-protocol control utility for ntpd; superseded by ntpq for most use cases but still useful for some queries)
# upstream: https://github.com/ntp-project/ntp
# Flags from ntpdc/ntpdc-opts.def on tip (AutoOpts).

_ntpdc() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[force IPv4 name resolution]' \
        '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[force IPv6 name resolution]' \
        '*'{-c+,--command=}'[run a single ntpdc command and exit (repeatable)]:cmd:' \
        '(-d --debug-level)'{-d+,--debug-level=}'[increment debug level]:n:' \
        '(-i --interactive)'{-i,--interactive}'[force interactive mode]' \
        '(-l --listpeers)'{-l,--listpeers}'[print peer list]' \
        '(-n --numeric)'{-n,--numeric}'[show numeric host addresses]' \
        '(-p --peers)'{-p,--peers}'[print peer summary]' \
        '(-s --showpeers)'{-s,--showpeers}'[show detailed peer list]' \
        '(-u --unconnected)'{-u,--unconnected}'[use unconnected UDP to talk to ntpd]' \
        '*:host:_hosts'
}

_ntpdc "$@"
