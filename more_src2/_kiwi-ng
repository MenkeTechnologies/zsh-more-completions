#compdef kiwi-ng
# _kiwi-ng — KIWI appliance / image builder (OSInside/kiwi)
# upstream: https://github.com/OSInside/kiwi
# Subcommands + flags from kiwi/cli.py (docopt).

_kiwi-ng() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '*--profile=[profile name (repeatable)]:profile:' \
        '*--setenv=[export environment variable into the caller (key=value)]:var=value:' \
        '--shared-cache-dir=[alternative shared cache directory]:dir:_files -/' \
        '--temp-dir=[temp directory used during the build]:dir:_files -/' \
        '--target-arch=[override the target architecture]:arch:(x86_64 aarch64 armv7l armv6l ppc64le s390x riscv64)' \
        '--type=[image build type]:type:(iso oem vmx pxe docker appx kis tbz simpledisk)' \
        '--logfile=[write logs to FILE (stdout for terminal)]:file:_files' \
        '--logsocket=[unix-domain socket to send logs to]:file:_files' \
        '--loglevel=[python logging level (10=debug, 20=info, 30=warn, 40=error)]:level:' \
        '--debug[print debug information]' \
        '--debug-run-scripts-in-screen[run kiwi scripts inside a screen session]' \
        '--color-output[colorize warning / error messages]' \
        '--config=[runtime configuration file]:file:_files -g "*.(yaml|yml)"' \
        '--kiwi-file=[explicit kiwi image description]:file:_files -g "*.kiwi"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_kiwi-ng_services' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                image)
                    _arguments \
                        '1: :_kiwi-ng_image_commands' \
                        '*:image arg:_files' && ret=0 ;;
                system)
                    _arguments \
                        '1: :_kiwi-ng_system_commands' \
                        '*:system arg:_files' && ret=0 ;;
                result)
                    _arguments \
                        '1: :_kiwi-ng_result_commands' \
                        '*:result arg:_files' && ret=0 ;;
                help) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kiwi-ng_services] )) ||
_kiwi-ng_services() {
    local -a services
    services=(
        'image:image-description operations (info, resize)'
        'system:end-to-end build / prepare / create / update an image'
        'result:operate on previously built image-result bundles'
        'help:show the manual page'
    )
    _describe -t services 'kiwi-ng service' services
}

(( $+functions[_kiwi-ng_image_commands] )) ||
_kiwi-ng_image_commands() {
    local -a commands
    commands=(
        'info:print details about the image description'
        'resize:resize the disk of a previously built oem image'
    )
    _describe -t commands 'kiwi-ng image command' commands
}

(( $+functions[_kiwi-ng_system_commands] )) ||
_kiwi-ng_system_commands() {
    local -a commands
    commands=(
        'build:prepare + create in one step (full build)'
        'prepare:prepare the unpacked root tree'
        'create:create the image from a prepared root tree'
        'update:update an existing prepared root tree'
    )
    _describe -t commands 'kiwi-ng system command' commands
}

(( $+functions[_kiwi-ng_result_commands] )) ||
_kiwi-ng_result_commands() {
    local -a commands
    commands=(
        'bundle:bundle previously built image results'
        'list:list the contents of a result bundle'
    )
    _describe -t commands 'kiwi-ng result command' commands
}

_kiwi-ng "$@"
