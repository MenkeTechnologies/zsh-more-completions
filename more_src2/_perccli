#compdef perccli
# Documentation: https://www.dell.com/support/manuals/en-us/poweredge-rc-h730/perc_cli_rg/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# perccli: Dell-branded storcli (PERC RAID controllers)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)help[show help]' \
  '(- *)-v[show version]' \
  '(- *)v[show version]' \
  'show[show ctrl/PD/LD/encl/all]' \
  'add[create VD / dimmer setting]' \
  'delete[delete VD]' \
  'flush[flush ctrl cache]' \
  'flash[flash firmware]' \
  'expand[expand virtual drive]' \
  'init[initialize VD]' \
  'consistency[VD consistency check]' \
  'patrolread[patrol read]' \
  'spinup[spinup drives]' \
  'spindown[spindown drives]' \
  'start[start operation]' \
  'stop[stop operation]' \
  'pause[pause operation]' \
  'resume[resume operation]' \
  'set[set parameter]' \
  'get[get parameter]' \
  'import[import foreign config]' \
  'transform[transform RAID level]' \
  'replace[replace member]' \
  'rebuild[rebuild operation]' \
  '*:perccli args:' && ret=0
return ret
