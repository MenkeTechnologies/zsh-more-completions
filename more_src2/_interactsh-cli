#compdef interactsh-cli interactsh interactsh-client
# _interactsh-cli — ProjectDiscovery Interactsh interactsh-cli CLI command-line frontend wrapping the Interactsh open-source out-of-band OOB DNS HTTP HTTPS SMTP SMTPS LDAP FTP TLS server interaction monitoring tool used for SSRF blind XSS blind SQLi blind RCE detection self-hosted public-server DNS-rebinding interactsh-client interactsh-server polling correlation server-token JSON-output CSV-output filter HTTP-callback Slack-Discord-Telegram-pagerduty webhook-notifications (ProjectDiscovery team Sandeep Singh Sajan Karuthedath, Go); goflags
# upstream: https://github.com/projectdiscovery/interactsh

_interactsh-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s+[interactsh server]:str:' \
        '-server=+[host]:_hosts' \
        '-n+[number of payloads]:n:' \
        '-token+[token]:str:' \
        '-pi+[poll interval sec]:n:' \
        '-dns-only[DNS only]' \
        '-http-only[HTTP only]' \
        '-smb-only[SMB only]' \
        '-no-display[no display]' \
        '-json[JSON output]' \
        '-o+[output file]:file:_files' \
        '-output=+[file]:file:_files' \
        '-payload-store+[file]:file:_files' \
        '-rt+[response token]:str:' \
        '-correlation-id+[id]:str:' \
        '-color[color]' \
        '-no-color[no color]' \
        '-nc[no color]' \
        '-asn[ASN]' \
        '-filter+[regex]:str:' \
        '-match+[regex]:str:' \
        '-proxy+[url]:str:' \
        '-config+[file]:file:_files -g "*.yaml *.yml"' \
        '-disable-update-check[no update]' \
        '-up[update]' \
        '*:args:'
}

_interactsh-cli "$@"
