#compdef datalevin
# _datalevin — Huahai Yang Datalevin durable datalog database CLI alias (juji-io team, Clojure); custom argparse
# upstream: https://github.com/juji-io/datalevin

_datalevin() {
    local -a sub=(
        'shell:interactive shell'
        'serv:start datalevin server'
        'help:show help'
        'exec:execute script file'
        'repl:start CLI REPL'
        'stat:show database stats'
        'compact:compact database'
        'copy:copy database'
        'drop:drop database'
        'list:list databases'
        'load:bulk load entities'
        'dump:dump database'
        'transact:run transaction'
        'query:run datalog query'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--root=+[storage root]:dir:_files -/' \
        '-r+[storage root]:dir:_files -/' \
        '--idle-timeout=+[idle ms]:n:' \
        '-i+[idle ms]:n:' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--server=+[server url]:url:_urls' \
        '--username=+[username]:user:_users' \
        '-u+[username]:user:_users' \
        '--password=+[password]:str:' \
        '-P+[password]:str:' \
        '--db-name=+[db name]:str:' \
        '-d+[db name]:str:' \
        '--engine=+[engine]:e:(lmdb kv-store)' \
        '--all[all]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datalevin subcommand' sub ;;
        args)
            case $words[1] in
                load|dump|copy|drop) _arguments \
                    '--db=+[db dir]:dir:_files -/' \
                    '--input=+[input file]:file:_files' \
                    '--output=+[output file]:file:_files' \
                    '--format=+[format]:f:(edn json)' ;;
                exec) _arguments '1:script file:_files -g "*.clj"' ;;
                query|transact) _arguments \
                    '--db=+[db dir]:dir:_files -/' \
                    '1:input:' ;;
            esac
            ;;
    esac
}

_datalevin "$@"
