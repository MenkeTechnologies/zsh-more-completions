#compdef qsv-cli
# _qsv-cli — Joel Natividad qsv blazing-fast CSV swiss-army-knife (xsv fork) CLI alias (jqnatividad team, Rust); docopt-rs
# upstream: https://github.com/jqnatividad/qsv

_qsv-cli() {
    local -a sub=(
        'apply:apply series of string/datetime/currency/geocode transforms'
        'applydp:apply data-processing transforms'
        'behead:drop header row'
        'cat:concatenate CSV files row/col-wise'
        'count:count rows'
        'dedup:remove duplicate rows'
        'describegpt:generate AI-assisted column descriptions'
        'diff:diff two CSV files'
        'enum:add row number/UUID column'
        'excel:export Excel sheets to CSV'
        'exclude:set-difference between two CSV files'
        'explode:explode rows into multiple based on delim'
        'extdedup:streaming dedup'
        'extsort:streaming sort'
        'fetch:fetch URLs in column to new column'
        'fetchpost:HTTP POST fetch'
        'fill:fill empty values'
        'fixlengths:make all rows same length'
        'flatten:flatten rows for display'
        'fmt:reformat CSV'
        'foreach:run command for each row'
        'frequency:compute frequency tables'
        'geocode:reverse-geocode lat/lng'
        'headers:show headers'
        'help:show help'
        'index:create index file'
        'input:read funky CSV with custom dialect'
        'join:join two CSVs'
        'joinp:fast Polars join'
        'jsonl:convert JSONL to CSV'
        'jsonp:convert nested JSON via JSON Path'
        'json:convert JSON to CSV'
        'lens:lens-based row viewer'
        'luau:execute Luau script on each row'
        'partition:partition by column'
        'pivot:pivot table'
        'prompt:GUI file picker'
        'pseudo:pseudonymize columns'
        'py:run Python expression per row'
        'rename:rename headers'
        'replace:regex replace in column'
        'reverse:reverse rows'
        'safenames:make headers safe'
        'sample:random sample N rows'
        'schema:JSON schema generation'
        'search:regex search'
        'searchset:regex search using set of regexes'
        'select:select columns'
        'slice:slice rows'
        'snappy:snappy compress/decompress'
        'sniff:auto-detect CSV dialect'
        'sort:sort rows'
        'sortcheck:check if sorted'
        'split:split into multiple files'
        'sqlp:Polars SQL query'
        'stats:column statistics'
        'tojsonl:CSV to JSONL'
        'table:aligned tabular output'
        'template:render template per row'
        'tojson:CSV to JSON'
        'transpose:transpose rows/cols'
        'validate:validate against schema'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--list[list commands]' \
        '--envlist[list env vars]' \
        '--updatenow[update qsv now]' \
        '--update[update qsv]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qsv subcommand' sub ;;
        args)
            case $words[1] in
                join|joinp) _arguments \
                    '1:columns1:' \
                    '2:input1:_files -g "*.csv"' \
                    '3:columns2:' \
                    '4:input2:_files -g "*.csv"' \
                    '--left[left outer join]' \
                    '--right[right outer join]' \
                    '--full[full outer join]' \
                    '--cross[cross join]' \
                    '--no-case[case insensitive]' \
                    '--nulls[allow nulls]' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' ;;
                sqlp) _arguments \
                    '1:query:' \
                    '*:files:_files -g "*.csv"' \
                    '--format=+[output format]:f:(csv json jsonl parquet arrow avro)' \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--streaming[streaming]' \
                    '--cache-schema=+[seconds]:n:' \
                    '--low-memory[low memory mode]' \
                    '--no-optimizations[no optimizations]' ;;
                stats|frequency|count|fmt|select|search|sort|slice) _arguments \
                    '--output=+[output file]:file:_files' \
                    '-o+[output file]:file:_files' \
                    '--no-headers[no headers]' \
                    '-n[no headers]' \
                    '--delimiter=+[delimiter]:str:' \
                    '-d+[delimiter]:str:' \
                    '--quiet[quiet]' \
                    '*:files:_files -g "*.csv"' ;;
            esac
            ;;
    esac
}

_qsv-cli "$@"
