#compdef flux-operator
# _flux-operator — ControlPlane Flux Operator (lifecycle for fluxcd controllers)
# upstream: https://github.com/controlplaneio-fluxcd/flux-operator
# Flags from cmd/operator/main.go on tip.

_flux-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--concurrent=[concurrent reconciles per controller]:n:' \
        '--reporting-interval=[FluxReport reporting interval]:dur:' \
        '--requeue-dependency=[requeue interval for dependent resources]:dur:' \
        '--metrics-addr=[metrics bind host\:port]:host\:port:' \
        '--health-addr=[health probe bind host\:port]:host\:port:' \
        '--storage-path=[on-disk artifact storage path]:dir:_files -/' \
        '--default-service-account=[default impersonated ServiceAccount]:sa:' \
        '--default-workload-identity-service-account=[default WI ServiceAccount]:sa:' \
        '*--override-manager=[override fieldManager (repeatable)]:name:' \
        '--web-server-port=[FluxReport web UI port]:port:' \
        '--web-server-only=[only run the web UI server]:bool:(true false)' \
        '--web-config=[web config file]:file:_files' \
        '--web-config-secret-name=[Secret name with web config]:name:' \
        '--leader-elect=[enable leader election]:bool:(true false)' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_flux-operator "$@"
