#compdef photoflare
# Documentation: https://github.com/PhotoFlare/photoflare/blob/master/photoflare.1
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. STUB: no CLI flags documented beyond
# image file argument.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*:image:_files -g "*.jpg *.jpeg *.png *.gif *.bmp *.tif *.tiff *.svg *.webp *.heic *.psd *.xcf"' && ret=0

return ret
