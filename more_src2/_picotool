#compdef picotool
# Documentation: https://github.com/raspberrypi/picotool
# Reference accessed: 2026-05-20
# Verified: upstream raspberrypi/picotool README. Subcommand set and
# device-selection flags taken from the README's command reference.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help message]' \
  '--version[show version information]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'info:display information from device or UF2/ELF/BIN file'
      'config:display or change program configuration settings'
      'load:load program/memory range from a file onto the device'
      'save:save program/memory from device flash to a file'
      'verify:verify device contents match file data'
      'erase:erase program/memory stored in flash'
      'reboot:reboot the device'
      'encrypt:encrypt and optionally sign a binary (RP2350)'
      'seal:add final metadata (hash/signature) to a binary'
      'link:link multiple binaries into one block loop'
      'otp:RP2350 one-time-programmable memory management'
      'partition:RP2350 partition table operations'
      'uf2:UF2 file creation and diagnostics'
      'coprodis:post-process disassembly with coprocessor instructions'
      'version:display picotool version'
      'help:show help for a command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (info)
        _arguments \
          '-a[show all information]' \
          '-b[show basic information]' \
          '-p[show build attributes (pins)]' \
          '-d[show device information]' \
          '-l[show program metadata]' \
          '(-f --force)'{-f,--force}'[force non-BOOTSEL device to reset for command]' \
          '(-F --force-no-reboot)'{-F,--force-no-reboot}'[force reset without remounting USB drive]' \
          '--bus=[filter by USB bus number]:bus:' \
          '--address=[filter by USB device address]:address:' \
          '--vid=[filter by USB vendor id]:vid:' \
          '--pid=[filter by USB product id]:pid:' \
          '--ser=[filter by USB serial number]:serial:' \
          '-t+[file type]:type:(uf2 elf bin)' \
          '*:file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (load)
        _arguments \
          '(-v --verify)'{-v,--verify}'[verify after loading]' \
          '(-x --execute)'{-x,--execute}'[execute after loading]' \
          '(-n --no-overwrite)'{-n,--no-overwrite}'[do not overwrite existing flash contents]' \
          '(-N --no-overwrite-unsafe)'{-N,--no-overwrite-unsafe}'[do not overwrite bootrom]' \
          '(-u --update)'{-u,--update}'[skip write if contents match]' \
          '(-o --offset)'{-o+,--offset=}'[load at offset]:offset:' \
          '(-f --force)'{-f,--force}'[force non-BOOTSEL device to reset for command]' \
          '(-F --force-no-reboot)'{-F,--force-no-reboot}'[force reset without remounting USB drive]' \
          '--bus=[filter by USB bus number]:bus:' \
          '--address=[filter by USB device address]:address:' \
          '--vid=[filter by USB vendor id]:vid:' \
          '--pid=[filter by USB product id]:pid:' \
          '--ser=[filter by USB serial number]:serial:' \
          '-t+[file type]:type:(uf2 elf bin)' \
          '--family=[family id for UF2]:family:' \
          '1:firmware file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (save)
        _arguments \
          '-p[save program only]' \
          '-a[save all flash contents]' \
          '-r[save address range]:start end:' \
          '(-f --force)'{-f,--force}'[force device reset]' \
          '(-F --force-no-reboot)'{-F,--force-no-reboot}'[force reset without remount]' \
          '--bus=[filter by USB bus number]:bus:' \
          '--address=[filter by USB device address]:address:' \
          '--vid=[filter by USB vendor id]:vid:' \
          '--pid=[filter by USB product id]:pid:' \
          '--ser=[filter by USB serial number]:serial:' \
          '-t+[file type]:type:(uf2 elf bin)' \
          '1:output file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (verify)
        _arguments \
          '(-o --offset)'{-o+,--offset=}'[verify at offset]:offset:' \
          '-r[verify address range]:start end:' \
          '(-f --force)'{-f,--force}'[force device reset]' \
          '(-F --force-no-reboot)'{-F,--force-no-reboot}'[force reset without remount]' \
          '--bus=[filter by USB bus number]:bus:' \
          '--address=[filter by USB device address]:address:' \
          '--vid=[filter by USB vendor id]:vid:' \
          '--pid=[filter by USB product id]:pid:' \
          '--ser=[filter by USB serial number]:serial:' \
          '-t+[file type]:type:(uf2 elf bin)' \
          '1:firmware file:_files -g "*.(uf2|elf|bin)"' && ret=0
        ;;
      (erase)
        _arguments \
          '-a[erase all]' \
          '-p+[erase partition]:partition:' \
          '-r+[erase address range]:start end:' \
          '(-f --force)'{-f,--force}'[force device reset]' \
          '--bus=[filter by USB bus number]:bus:' \
          '--address=[filter by USB device address]:address:' && ret=0
        ;;
      (reboot)
        _arguments \
          '(-a --application)'{-a,--application}'[reboot into application]' \
          '(-u --usb)'{-u,--usb}'[reboot into BOOTSEL mode]' \
          '(-f --force)'{-f,--force}'[force device reset]' \
          '--bus=[filter by USB bus number]:bus:' \
          '--address=[filter by USB device address]:address:' && ret=0
        ;;
      (version)
        _arguments '-s[short version]' && ret=0
        ;;
    esac
    ;;
esac

return ret
