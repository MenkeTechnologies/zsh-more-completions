#compdef rukpak-unpack
# _rukpak-unpack — Rukpak unpack helper (initContainer that extracts a bundle directory into the provisioner storage)
# upstream: https://github.com/operator-framework/rukpak
# Flags from cmd/unpack/main.go on tip (cobra).

_rukpak-unpack() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[displays rukpak version information]' \
        '--bundle-dir=[directory in which the bundle can be found]:dir:_files -/'
}

_rukpak-unpack "$@"
