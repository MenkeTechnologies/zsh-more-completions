#compdef genqlient
# Documentation: https://github.com/Khan/genqlient
# Source: https://github.com/Khan/genqlient/blob/main/generate/main.go
# Reference accessed: 2026-06-01
# Khan Academy's type-safe Go GraphQL client generator.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--init[write out and use a default config file]' \
    '--version[print version information]' \
    '(- *)'{-h,--help}'[show help]' \
    '1:config file:_files -g "genqlient*.yaml"' \
    && ret=0

return ret
