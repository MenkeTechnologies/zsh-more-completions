#compdef kauthproxy
# Documentation: https://github.com/int128/kauthproxy/blob/master/README.md
# Reference accessed: 2026-05-19
# Verified: upstream int128/kauthproxy README flags section.
# Removed invented --target-port; added real --address /
# --skip-open-browser plus standard kubectl global flags.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*--address=[address on which to run the proxy]:address:' \
  '--skip-open-browser[do not open the browser automatically]' \
  '(-n --namespace)'{-n,--namespace}'=[namespace scope for this CLI request]:namespace:' \
  '(-v --v)'{-v,--v}'=[log level verbosity]:level:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '--cluster=[kubeconfig cluster to use]:cluster:' \
  '--user=[kubeconfig user to use]:user:' \
  '--server=[Kubernetes API server address and port]:server:' \
  '--token=[bearer token for authentication to the API server]:token:' \
  '--insecure-skip-tls-verify[skip server certificate validation]' \
  '--request-timeout=[length of time to wait before giving up on a request]:timeout:' \
  '*:pod or service URL:_default'
