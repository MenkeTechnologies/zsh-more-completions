#compdef foamCleanCase
# Documentation: https://github.com/OpenFOAM/OpenFOAM-12/blob/master/bin/foamCleanCase
# Reference accessed: 2026-05-27
# Verified: upstream bin/foamCleanCase shell script usage() function

# foamCleanCase: OpenFOAM case-cleanup script. Only -case/-c and -help/-h.
local curcontext="$curcontext" ret=1
_arguments -s \
  '(-case -c)'{-case,-c}'[specify case directory (default: local dir)]:dir:_files -/' \
  '(-help -h)'{-help,-h}'[print usage]' && ret=0
return ret
