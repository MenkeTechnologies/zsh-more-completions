#compdef pgmtoppm
# Documentation: man pgmtoppm (Netpbm)
# Source: colorize a PGM image into a PPM via a color or color ramp.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-black=[color for black pixels]:color:' \
    '-white=[color for white pixels]:color:' \
    '-map=[colormap file]:file:_files -g "*.(ppm|pnm|pam)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:colorspec or colorspec1-colorspec2 or pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
