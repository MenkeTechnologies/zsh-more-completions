#compdef grin-wallet
# _grin-wallet — Grin Council grin-wallet MimbleWimble Grin cryptocurrency wallet CLI (mimblewimble team, Rust); clap-derive
# upstream: https://github.com/mimblewimble/grin-wallet

_grin-wallet() {
    local -a sub=(
        'init:create a new wallet'
        'recover:recover from seed'
        'cli:enter interactive wallet'
        'listen:run wallet listener'
        'owner_api:run owner http api'
        'web:run web wallet'
        'send:send grins'
        'invoice:invoice another wallet'
        'pay:pay an invoice'
        'receive:receive grins'
        'finalize:finalize a transaction'
        'issue_invoice:issue invoice'
        'process_invoice:process invoice'
        'info:show wallet summary'
        'outputs:list outputs'
        'txs:list transactions'
        'post:post tx to chain'
        'repost:repost tx'
        'cancel:cancel a transaction'
        'restore:restore from chain'
        'check:check repair'
        'address:show address'
        'open:open wallet'
        'close:close wallet'
        'export_proof:export payment proof'
        'verify_proof:verify proof'
        'account:account subcommands'
        'scan:scan UTXOs'
        'completion:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-u+[usernet]:str:' \
        '--floonet[floonet]' \
        '-f[floonet]' \
        '--usernet[usernet]' \
        '--pass=+[password]:str:' \
        '-p+[password]:str:' \
        '--account=+[account]:str:' \
        '-a+[account]:str:' \
        '--node_api_address=+[url]:url:_urls' \
        '-r+[url]:url:_urls' \
        '--external[external listener]' \
        '-e[external listener]' \
        '--show_spent[show spent]' \
        '--top_level_dir=+[wallet dir]:dir:_files -/' \
        '--api_secret=+[secret file]:file:_files' \
        '--node_api_secret=+[secret file]:file:_files' \
        '--testing[testing mode]' \
        '-t[testing mode]' \
        '--init_mode=+[mode]:m:(short long)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grin-wallet subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--method=+[method]:m:(http file self keybase slatepack)' \
                    '-m+[method]:m:(http file self keybase slatepack)' \
                    '--dest=+[destination]:str:' \
                    '-d+[destination]:str:' \
                    '--amount=+[amount grin]:f:' \
                    '--minimum_confirmations=+[N]:n:' \
                    '-c+[N]:n:' \
                    '--selection_strategy=+[strategy]:s:(all smallest)' \
                    '-s+[strategy]:s:(all smallest)' \
                    '--fluff[fluff/relay]' \
                    '-y[skip confirmation]' \
                    '--ttl_blocks=+[N]:n:' ;;
                receive) _arguments \
                    '--input=+[slate file]:file:_files' \
                    '-i+[slate file]:file:_files' \
                    '--message=+[message]:str:' \
                    '-g+[message]:str:' ;;
                account) _arguments '1:account cmd:(create switch list)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_grin-wallet "$@"
