#compdef kilocode
# Documentation: https://github.com/Kilo-Org/kilocode
# Reference accessed: 2026-05-22
# Verified: @kilocode/cli --help (kilocode npm bin).

# Zsh completion for kilocode - Kilo AI agent TUI and tooling CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'kilocode command' \
      'completion[generate shell completion script]' \
      'acp[start Agent Client Protocol server]' \
      'mcp[manage MCP servers]' \
      'attach[attach to running kilo server]' \
      'run[run kilo with a message]' \
      'debug[debugging and troubleshooting tools]' \
      'auth[manage AI providers and credentials]' \
      'providers[alias for auth]' \
      'agent[manage agents]' \
      'upgrade[upgrade kilo version]' \
      'uninstall[uninstall kilo and related files]' \
      'serve[start headless kilo server]' \
      'models[list available models]' \
      'roll-call[batch-test models for connectivity]' \
      'stats[show token usage and cost statistics]' \
      'export[export session data as JSON]' \
      'import[import session data from JSON or URL]' \
      'pr[fetch and checkout GitHub PR branch]' \
      'session[manage sessions]' \
      'remote[enable remote session relay]' \
      'config[configuration tools]' \
      'plugin[install plugin and update config]' \
      'plug[alias for plugin]' \
      'db[database tools]' \
      'help[show full CLI reference]' && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments '*:message words:' && ret=0
        ;;
      attach)
        _arguments '1:server URL:' && ret=0
        ;;
      export)
        _arguments '1:session ID:' && ret=0
        ;;
      import)
        _arguments '1:JSON file or URL:_files' && ret=0
        ;;
      pr)
        _arguments '1:PR number:' && ret=0
        ;;
      roll-call)
        _arguments '1:model filter:' && ret=0
        ;;
      plugin|plug)
        _arguments '1:plugin module:' && ret=0
        ;;
      models)
        _arguments '1:provider:' && ret=0
        ;;
      upgrade)
        _arguments '1:version target:' && ret=0
        ;;
    esac
    ;;
esac

return ret
