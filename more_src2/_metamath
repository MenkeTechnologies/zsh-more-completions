#compdef metamath
# _metamath — Metamath: formal proof verifier and proof assistant
# upstream: https://github.com/metamath/metamath-exe
# Invocation: `metamath [ commands | file ]` (REPL); commands also passable on argv.

_metamath() {
    local -a args
    args=(
        '*:Metamath database or command:_files -g "*.mm"'
    )
    _arguments -s -S $args
    if (( CURRENT == 2 )); then
        local -a cmds
        cmds=(
            'read:load a Metamath database from a file'
            'verify:verify proofs in the loaded database'
            'verify-proof:verify a single proof'
            'verify-markup:verify markup in comments'
            'prove:enter interactive proof mode for a theorem'
            'show:display theorems, statements, or the proof tree'
            'search:search the database for matching statements'
            'minimize-with:minimize a proof using the named lemmas'
            'improve:try to improve the active proof'
            'save:save the current proof'
            'write:write a modified database to a file'
            'open:open a log or HTML file'
            'close:close an open log or HTML file'
            'set:set an option (scroll, width, height, echo, ...)'
            'tools:enter the file-utility submode'
            'help:show online help'
            'submit:read commands from a script file'
            'exit:exit Metamath'
            'quit:exit Metamath'
            'erase:erase the current database'
        )
        _describe -t commands 'metamath command' cmds
    fi
}

_metamath "$@"
