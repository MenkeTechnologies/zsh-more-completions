#compdef phpunit
# Documentation: phpunit --help (PHPUnit 13.2.0)
# Source: PHP unit-testing framework CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--bootstrap=[bootstrap PHP script]:file:_files -g "*.php"' \
    '(-c --configuration)'{-c+,--configuration=}'[XML config file]:file:_files -g "*.xml"' \
    '--no-configuration[ignore phpunit.xml]' \
    '*--extension=[register test-runner extension class]:class:' \
    '--no-extensions[do not register extensions]' \
    '--include-path=[prepend PHP include_path]:path:_files -/' \
    '*-d+[set php.ini value (key[=value])]:setting:' \
    '--cache-directory=[cache directory]:dir:_files -/' \
    '--generate-configuration[generate suggested config and exit]' \
    '--migrate-configuration[migrate config to current format]' \
    '--validate-configuration[validate XML config and exit]' \
    '--generate-baseline=[generate baseline file]:file:_files' \
    '--use-baseline=[use baseline to ignore issues]:file:_files' \
    '--ignore-baseline[do not use baseline]' \
    '--all[ignore test selection from config]' \
    '--list-suites[list available test suites]' \
    '*--testsuite=[run only specified suite(s)]:name:' \
    '*--exclude-testsuite=[exclude specified suite(s)]:name:' \
    '--list-groups[list available test groups]' \
    '*--group=[run only specified group(s)]:name:' \
    '*--exclude-group=[exclude specified group(s)]:name:' \
    '*--covers=[run tests covering name]:name:' \
    '*--uses=[run tests using name]:name:' \
    '--list-test-files[list available test files]' \
    '--list-test-ids[list tests as IDs]' \
    '--list-tests[list available tests]' \
    '--list-tests-xml=[list tests as XML to file]:file:_files' \
    '--filter=[filter pattern]:pattern:' \
    '--exclude-filter=[exclusion pattern]:pattern:' \
    '--test-suffix=[file suffix(es) to search]:suffixes:' \
    '--test-files-file=[file listing test files]:file:_files' \
    '--run-test-id=[run a single test by id]:test id:' \
    '--process-isolation[run each test in a separate process]' \
    '--globals-backup[backup/restore $GLOBALS]' \
    '--static-backup[backup/restore static properties]' \
    '--strict-coverage[strict coverage metadata]' \
    '--strict-global-state[strict global-state checks]' \
    '--disallow-test-output[disallow output during tests]' \
    '--enforce-time-limit[enforce time limit based on size]' \
    '--default-time-limit=[default time limit (seconds)]:sec:' \
    '--do-not-report-useless-tests[hide useless-test reports]' \
    '--stop-on-defect=-[stop after first or n-th defect]::n:' \
    '--stop-on-error=-[stop after first or n-th error]::n:' \
    '--stop-on-failure=-[stop after first or n-th failure]::n:' \
    '--stop-on-warning=-[stop after first or n-th warning]::n:' \
    '--stop-on-risky=-[stop after first or n-th risky]::n:' \
    '--stop-on-deprecation=-[stop on deprecation]::n:' \
    '--stop-on-notice=-[stop on notice]::n:' \
    '--stop-on-skipped=-[stop on skipped]::n:' \
    '--stop-on-incomplete=-[stop on incomplete]::n:' \
    '--fail-on-empty-test-suite[fail on empty suite]' \
    '--fail-on-warning[fail on warning]' \
    '--fail-on-risky[fail on risky test]' \
    '--fail-on-deprecation[fail on deprecation]' \
    '--fail-on-notice[fail on notice]' \
    '--fail-on-skipped[fail on skipped]' \
    '--fail-on-incomplete[fail on incomplete]' \
    '--fail-on-all-issues[fail on any issue]' \
    '--cache-result[write results cache]' \
    '--do-not-cache-result[do not cache results]' \
    '--order-by=[order tests]:order:(default defects depends duration-ascending duration-descending no-depends random reverse size-ascending size-descending)' \
    '--resolve-dependencies[alias for --order-by depends]' \
    '--ignore-dependencies[alias for --order-by no-depends]' \
    '--random-order[alias for --order-by random]' \
    '--random-order-seed=[random seed]:N:' \
    '--reverse-order[alias for --order-by reverse]' \
    '--colors=[color output flag]:mode:(never auto always)' \
    '--columns=[output columns or max]:n:' \
    '--diff-context=[diff context lines]:n:' \
    '--stderr[write output to stderr]' \
    '--no-progress[no progress output]' \
    '--no-results[no results output]' \
    '--no-output[no output at all]' \
    '--display-incomplete[show incomplete details]' \
    '--display-skipped[show skipped details]' \
    '--display-deprecations[show deprecation details]' \
    '--display-errors[show error details]' \
    '*:test file or directory:_files -g "*.php"' \
    && ret=0

return ret
