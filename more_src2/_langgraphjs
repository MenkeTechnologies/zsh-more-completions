#compdef langgraphjs langgraph-cli
# Documentation: https://github.com/langchain-ai/langgraphjs
# Reference accessed: 2026-05-23
# Verified: npx @langchain/langgraph-cli --help.

# Zsh completion for langgraphjs - LangGraph.js CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'langgraphjs command' \
      'dev[run LangGraph API server in development mode]' \
      'dockerfile[generate Dockerfile for LangGraph API server]' \
      'build[build LangGraph API server Docker image]' \
      'up[launch LangGraph API server]' \
      'new[create new LangGraph project]' \
      'sysinfo[print system information]' && ret=0
    ;;
  args)
    case $line[1] in
      dev)
        _arguments \
          '(-p --port)'{-p+,--port=}'[server port]:port:' \
          '(-h --host)'{-h+,--host=}'[bind host]:host:' \
          '--no-browser[disable auto-open browser]' \
          '(-n --n-jobs-per-worker)'{-n+,--n-jobs-per-worker=}'[workers per worker]:count:' \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '--tunnel[expose server via Cloudflare Tunnel]' && ret=0
        ;;
      dockerfile)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '1:save-path:output path:_files' && ret=0
        ;;
      new)
        _arguments \
          '(-t --template)'{-t+,--template=}'[project template]:template:' \
          ':path:project path:_directories' && ret=0
        ;;
      build|up)
        _arguments '(-c --config)'{-c+,--config=}'[config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
