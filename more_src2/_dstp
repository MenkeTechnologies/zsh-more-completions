#compdef dstp
# Documentation: https://github.com/ycd/dstp
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dstp: run common networking tests against any site (DNS, ping, TLS).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-a --addr)'{-a+,--addr=}'[URL or IP address to test]:url:' \
  '(-o --out)'{-o+,--out=}'[output format]:format:(plaintext json)' \
  '-p+[number of ping packets]:count:' \
  '-t+[ping timeout in seconds]:seconds:' \
  '--port=[port for TLS/HTTPS testing]:port:' \
  '--dns=[custom DNS server for resolution]:dns:' \
  '*::args: _default' && ret=0

return ret
