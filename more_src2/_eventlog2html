#compdef eventlog2html
# _eventlog2html — render GHC eventlogs as interactive HTML (mpickering/eventlog2html)
# upstream: https://github.com/mpickering/eventlog2html
# Flags from src/Eventlog/Args.hs (optparse-applicative).

_eventlog2html() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--sort=[band sort field]:field:(size stddev name number gradient)' \
        '--reverse[reverse the order of bands]' \
        '--bands=[max bands to draw (0=unlimited)]:n:' \
        '--limit-detailed=[max bands in detailed view]:n:' \
        '(-p --heap-profile)'{-p,--heap-profile}'[input is .hp heap profile]' \
        '--no-include-js[fetch JS from CDN instead of bundling]' \
        '(-j --json)'{-j,--json}'[output JSON]' \
        '--no-traces[do not display traces on chart]' \
        '--include-trace-events[include traceEvent in addition to traceMarker]' \
        '--colour-scheme=[Vega color scheme]:scheme:' \
        '--y-axis=[fixed y-axis max in bytes]:bytes:' \
        '*'{-i+,--include=}'[include trace SUBSTRING]:substr:' \
        '*'{-x+,--exclude=}'[exclude trace SUBSTRING]:substr:' \
        '-o+[output file]:file:_files -g "*.html"' \
        '*:eventlog:_files -g "*.(eventlog|hp)"'
}

_eventlog2html "$@"
