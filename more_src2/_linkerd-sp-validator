#compdef linkerd-sp-validator
# _linkerd-sp-validator — Linkerd2 ServiceProfile validating admission webhook
# upstream: https://github.com/linkerd/linkerd2
# Flags from controller/cmd/sp-validator/main.go on tip.

_linkerd-sp-validator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-metrics-addr=[Prometheus metrics bind host\:port]:host\:port:' \
        '-addr=[webhook server bind host\:port]:host\:port:' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-enable-pprof[expose pprof on the admin server]' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]' \
        '-stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)'
}

_linkerd-sp-validator "$@"
