#compdef nvc
# Documentation: https://www.nickg.me.uk/nvc/manual.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-a[analyze VHDL source files]' \
  '-e[elaborate a design]' \
  '-r[run a simulation]' \
  '-i[interactive TCL shell]' \
  '--init[initialise the working library directory]' \
  '--install[install verification frameworks]' \
  '--list[list analysed and elaborated units]' \
  '--print-deps[print Makefile dependencies of unit]' \
  '--do=[execute batch TCL script]:file:_files' \
  '--cover-export[export coverage data]' \
  '--cover-merge[merge coverage databases]' \
  '--cover-report[generate coverage report]' \
  '--std=[VHDL standard]:standard:(1993 2002 2008 2019)' \
  '--work=[set work library]:library name' \
  '-L+[add library search path]:directory:_directories' \
  '--map=[library mapping]:mapping' \
  '-H+[set heap size]:size' \
  '-M+[set memory limit]:count' \
  '--messages=[message format]:format' \
  '--ieee-warnings=[control IEEE warnings]:state:(on off)' \
  '--ignore-time[ignore TIME values in standard package]' \
  '--seed=[random seed]:n' \
  '--vhpi-debug[VHPI debug output]' \
  '--vhpi-trace[VHPI call trace]' \
  '--relaxed[disable pedantic LRM checks]' \
  '--psl[enable PSL parsing in comments]' \
  '--no-save[do not save analysed/elaborated units]' \
  '--check-synthesis[warn on synthesis issues]' \
  '--single-unit[treat all input files as a single unit]' \
  '--preserve-case[preserve case of identifiers]' \
  '--error-limit=[stop after N errors]:n' \
  '-Werror[treat warnings as errors]' \
  '-D+[define preprocessor symbol]:name' \
  '--define=[define preprocessor symbol]:name' \
  '-f[read filenames from file]:file:_files' \
  '--files=[read filenames from file]:file:_files' \
  '-g+[set generic value]:name=value' \
  '-O0[optimisation level 0]' \
  '-O1[optimisation level 1]' \
  '-O2[optimisation level 2]' \
  '-O3[optimisation level 3]' \
  '--cover[enable code coverage]' \
  '--cover-spec=[coverage specification]:specification' \
  '--cover-file=[coverage output file]:file:_files' \
  '--no-collapse[do not collapse signals]' \
  '--stderr=[stderr severity threshold]:level:(note warning error failure)' \
  '--stop-delta=[stop after delta cycles]:cycles' \
  '--stop-time=[stop simulation after time]:time' \
  '--exit-severity=[exit on severity]:level:(note warning error failure)' \
  '--trace[trace simulation]' \
  '--stats[display statistics]' \
  '--shuffle[randomize process execution order]' \
  '--dump-arrays[dump arrays in waveform]' \
  '-w[dump waveform]' \
  '--wave=[dump waveform to file]:file:_files -g "*.(fst|vcd|ghw)"' \
  '--gtkw[write GTKWave save file]' \
  '--format=[waveform format]:format:(fst vcd)' \
  '--include=[include signal in waveform]:pattern' \
  '--exclude=[exclude signal from waveform]:pattern' \
  '--load=[load VHPI plugin]:plugin file:_files -g "*.so"' \
  '*:VHDL file:_files -g "*.(vhd|vhdl)"' && ret=0

return ret
