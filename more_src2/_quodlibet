#compdef quodlibet
# Documentation: https://quodlibet.readthedocs.io/en/latest/guide/interacting.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--debug[debug mode]' \
  '--no-plugins[disable plugins]' \
  '--run[start playing]' \
  '--quit[quit running instance]' \
  '--play[start playback]' \
  '--pause[pause playback]' \
  '--play-pause[toggle playback]' \
  '--next[next track]' \
  '--previous[previous track]' \
  '--stop[stop playback]' \
  '--status[print player status]' \
  '--volume=[set volume 0-100]:level' \
  '--volume-up[raise volume]' \
  '--volume-down[lower volume]' \
  '--seek=[seek within current song]:time' \
  '--query=[search library]:query' \
  '--play-file=[play file or directory]:file:_files' \
  '--enqueue=[enqueue file or query]:item' \
  '--unqueue=[remove from queue]:item' \
  '--print-playing=[print current song using format]:format' \
  '--print-query=[print results of query]:query' \
  '--print-queue[print queue]' \
  '--refresh[refresh library]' \
  '--hide-window[hide window]' \
  '--show-window[show window]' \
  '--toggle-window[toggle window]' \
  '--focus[focus running instance]' \
  '--set-rating=[set rating of current song]:rating' \
  '--rating-up[increase rating]' \
  '--rating-down[decrease rating]' \
  '*:file:_files' && ret=0

return ret
