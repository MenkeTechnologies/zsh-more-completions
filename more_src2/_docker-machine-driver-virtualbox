#compdef docker-machine-driver-virtualbox
# _docker-machine-driver-virtualbox — Docker Machine VirtualBox driver (bundled docker-machine driver that runs boot2docker VMs in VirtualBox; plugin binary only exposes --version, --debug, --plugin; create-time flags (--virtualbox-cpu-count, --virtualbox-memory, --virtualbox-disk-size, --virtualbox-boot2docker-url) live on docker-machine create)
# upstream: https://github.com/docker/machine (drivers/virtualbox)
# Flags from docker/machine drivers/virtualbox on tip.

_docker-machine-driver-virtualbox() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug to stderr]' \
        '--plugin[run as plugin]'
}

_docker-machine-driver-virtualbox "$@"
