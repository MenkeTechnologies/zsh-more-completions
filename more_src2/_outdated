#compdef outdated kubectl-outdated
# Documentation: https://github.com/replicatedhq/outdated
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# kubectl outdated plugin - report out-of-date images in a Kubernetes cluster.
# USAGE.md documents --context only; standard kubectl flags pass through.
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--kubeconfig=[kubeconfig]:file:_files' \
  '--context=[kube context]:context' \
  '*:args:_default'
