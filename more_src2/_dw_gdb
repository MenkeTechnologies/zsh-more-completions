# 6 options decoded source-direct from opts
# array at dw_gdb.lpr:77-113 + GetLongOpts call
# at dw_gdb.lpr:120.
_arguments -s -S \
  '(- *)'{-H,-h,-?,--help}'[display help and exit]' \
  '(-S -s --serialport)'{-S+,-s+,--serialport=}'[connect to serial port (e.g. /dev/ttyUSB0 or COM3)]:serial port:_files' \
  '(-B -b --baud)'{-B+,-b+,--baud=}'[connect using baud rate (auto-scan if omitted)]:baud rate:' \
  '(-T -t --tcpport)'{-T+,-t+,--tcpport=}'[TCP port for GDB remote connection (default: 1234)]:port:' \
  '(-I -i --ispenable)'{-I,-i,--ispenable}'[temporarily disable DWEN fuse to enable ISP]' \
  '(-V -v --verbose)'{-V,-v,--verbose}'[enable verbose debug output]' && ret=0

