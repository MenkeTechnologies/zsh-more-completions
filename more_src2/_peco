#compdef peco
# Documentation: peco --help on peco 0.6.x
# Source: peco/peco — simplistic interactive filtering tool.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--query=[initial query value]:query:' \
    '--rcfile=[path to settings file]:file:_files' \
    '(- *)--version[print version and exit]' \
    '(-b --buffer-size)'{-b,--buffer-size=}'[lines kept in search buffer]:n:' \
    '--null[expect NUL as separator]' \
    '--initial-index=[0-based initial selection index]:n:' \
    '--initial-filter=[default filter name]:filter:' \
    '--prompt=[prompt string]:str:' \
    '--layout=[layout mode]:layout:(top-down bottom-up top-down-query-bottom)' \
    '--select-1[exit immediately if input has 1 line]' \
    '--exit-0[exit 1 if input empty]' \
    '--select-all[select all items and exit]' \
    '--on-cancel=[action on user cancel]:action:(success error)' \
    '--selection-prefix=[selection-indicator prefix string]:prefix:' \
    '--exec=[execute command on selected lines]:cmd:_command_names -e' \
    '--print-query[print current query as first output line]' \
    '--color=[color mode]:mode:(auto none)' \
    '--height=[display height in lines or percentage]:height:' \
    '*:file:_files' \
    && ret=0

return ret
