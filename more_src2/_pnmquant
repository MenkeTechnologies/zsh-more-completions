#compdef pnmquant
# Documentation: man pnmquant (Netpbm)
# Source: quantise a Netpbm image to N colors (wrapper for pnmcolormap + pnmremap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-center -meancolor -meanpixel)-center[centroid placement]' \
    '(-center -meancolor -meanpixel)-meancolor[mean of palette color values]' \
    '(-center -meancolor -meanpixel)-meanpixel[mean of pixel values mapped]' \
    '(-floyd -fs -nofloyd -nofs)'{-floyd,-fs}'[Floyd-Steinberg dither]' \
    '(-floyd -fs -nofloyd -nofs)'{-nofloyd,-nofs}'[no Floyd-Steinberg dither]' \
    '(-spreadbrightness -spreadluminosity)-spreadbrightness[spread in brightness]' \
    '(-spreadbrightness -spreadluminosity)-spreadluminosity[spread in luminosity]' \
    '(-norandom -randomseed)-norandom[no random dithering]' \
    '(-norandom -randomseed)-randomseed=[random seed]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ncolors:' \
    '2:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
