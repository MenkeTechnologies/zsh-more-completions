#compdef querytee
# _querytee — Loki query response comparator/proxy (grafana/loki)
# upstream: https://github.com/grafana/loki
# Flags from cmd/querytee/main.go + pkg/querytee/proxy.go (flag.FlagSet).

_querytee() {
    _arguments \
        '-server.metrics-port=[port where metrics are exposed]:port:' \
        '-server.service-port=[port where query-tee service listens]:port:' \
        '-backend.endpoints=[comma-separated backend endpoint URLs]:list:' \
        '-backend.read-timeout=[backend response read timeout]:duration:' \
        '-routing.mode=[routing mode]:mode:(race v1-preferred v2-preferred)' \
        '-routing.v1-preferred=[preferred v1 (chunks) backend hostname]:host:' \
        '-routing.v2-preferred=[preferred v2 (dataobjs) backend hostname]:host:' \
        '-routing.race-tolerance=[v2 race handicap (duration)]:duration:' \
        '-routing.split-lag=[minimum data age for v2 routing]:duration:' \
        '-routing.split-retention-days=[lifecycle of data objects in days]:days:' \
        '-routing.add-routing-decisions-to-warnings[add routing decisions as response warnings]' \
        '-proxy.compare-responses[compare responses between primary and secondary]' \
        '-proxy.disable-backend-read=[non-primary backends with read proxy disabled]:list:' \
        '-proxy.value-comparison-tolerance=[float tolerance]:f:' \
        '-proxy.compare-use-relative-error[use relative error tolerance]' \
        '-proxy.compare-skip-recent-samples=[skip comparing samples within window]:duration:' \
        '-proxy.passthrough-non-registered-routes[passthrough non-registered routes to preferred]' \
        '-proxy.compare-instrument[report metrics on response comparisons]' \
        '-proxy.skip-fanout-when-not-sampling[skip fan-out when goldfish sampling is off]' \
        '-log.level=[log level]:level:(debug info warn error)' \
        '-tracing.enabled[enable tracing]'
}

_querytee "$@"
