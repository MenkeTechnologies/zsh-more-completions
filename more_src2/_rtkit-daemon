#compdef rtkit-daemon
# _rtkit-daemon — D-Bus daemon to grant realtime scheduling priority (heftig/rtkit)
# upstream: https://github.com/heftig/rtkit
# Flags from rtkit-daemon.c (getopt_long).

_rtkit-daemon() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--scheduling-policy=[policy for granted realtime threads]:policy:(OTHER BATCH FIFO RR)' \
        '--our-realtime-priority=[realtime priority for the daemon itself]:prio:' \
        '--our-nice-level=[nice level for the daemon itself]:n:' \
        '--max-realtime-priority=[maximum realtime priority grantable]:prio:' \
        '--min-nice-level=[minimum nice level grantable]:n:' \
        '--user-name=[user to drop privileges to]:user:_users' \
        '--rttime-usec-max=[RLIMIT_RTTIME cap (usec)]:usec:' \
        '--users-max=[max users with realtime threads]:n:' \
        '--processes-per-user-max=[max processes per user]:n:' \
        '--threads-per-user-max=[max realtime threads per user]:n:' \
        '--actions-burst-sec=[burst window for action throttling (sec)]:sec:' \
        '--actions-per-burst-max=[max actions per burst window]:n:' \
        '--no-drop-privileges[do not drop privileges]' \
        '--no-chroot[do not chroot]' \
        '--no-limit-resources[do not apply rlimits]' \
        '--no-canary[disable canary watchdog]' \
        '--canary-cheep-msec=[interval between canary cheeps (msec)]:msec:' \
        '--canary-watchdog-msec=[watchdog timeout (msec)]:msec:' \
        '--canary-demote-root[demote root on canary failure]' \
        '--canary-demote-unknown[demote unknown processes on canary failure]' \
        '--canary-refuse-sec=[seconds to refuse requests after canary failure]:sec:' \
        '--stderr[log to stderr]' \
        '--introspect[print D-Bus introspection XML and exit]'
}

_rtkit-daemon "$@"
