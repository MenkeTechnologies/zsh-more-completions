#compdef go-blueprint
# Documentation: https://github.com/Melkeydev/go-blueprint
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# go-blueprint: Go project scaffolding (Melkeydev/go-blueprint).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'create:create a new Go project'
      'completion:generate shell completion'
    )
    _describe -t commands 'go-blueprint command' commands && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-n+[project name]:name' \
          '--name=[project name]:name' \
          '-f+[framework to use]:framework:(chi gin fiber echo gorilla httprouter standard-library)' \
          '--framework=[framework to use]:framework:(chi gin fiber echo gorilla httprouter standard-library)' \
          '-d+[database driver]:driver:(mysql postgres sqlite mongo redis scylla none)' \
          '--driver=[database driver]:driver:(mysql postgres sqlite mongo redis scylla none)' \
          '--advanced[enable advanced features prompt]' \
          '--feature=[add feature]:feature:(htmx githubaction websocket tailwind docker react)' \
          '-g[initialize git repository]' \
          '--git=[git init mode]:mode:(commit stage skip)' && ret=0
        ;;
      completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash zsh fish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
