#compdef netapp-cli ontap-cli
# _netapp-cli — NetApp ONTAP cluster CLI alias (NetApp team, varies); custom argparse via ssh CLI shell
# upstream: https://docs.netapp.com/

_netapp-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-cluster+[cluster name]:str:' \
        '-vserver+[vserver name]:str:' \
        '-user+[username]:_users' \
        '-password+[password]:str:' \
        '-output+[format]:f:(json text xml table)' \
        '-noconfirm[no confirm]' \
        '-debug[debug]' \
        '-script+[script file]:file:_files' \
        '-cmd+[command]:str:' \
        '*:command:'
}

_netapp-cli "$@"
