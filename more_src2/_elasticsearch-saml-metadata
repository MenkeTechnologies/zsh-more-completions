#compdef elasticsearch-saml-metadata
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/saml-metadata.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-s,--silent}'[silent]' \
  {-v,--verbose}'[verbose]' \
  '-E[configure setting]:kv:' \
  '--realm=[realm name]:name:' \
  '--out=[output file]:file:_files -g "*.xml"' \
  '--batch[skip prompts]' \
  '--locale=[locale]:locale:' \
  '--service-name=[service name]:name:' \
  '--attribute=[requested attribute name]:name:' \
  '--organisation-name=[organisation name]:name:' \
  '--organisation-display-name=[display name]:name:' \
  '--organisation-url=[organisation URL]:url:' \
  '--contacts[include contacts in metadata]' \
  '--signing-cert=[signing certificate (PEM)]:file:_files' \
  '--signing-key=[signing key (PEM)]:file:_files' \
  '--signing-bundle=[signing bundle PKCS#12]:file:_files' \
  '--signing-key-password=[signing key password]:password:' && ret=0

return ret
