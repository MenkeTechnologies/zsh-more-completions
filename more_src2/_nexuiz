#compdef nexuiz
# Documentation: https://manpages.debian.org/buster/nexuiz/nexuiz.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian buster nexuiz(6) manpage. DarkPlaces engine (Nexuiz is
# Xonotic's predecessor, same engine family).

# Nexuiz: predecessor to Xonotic (DarkPlaces engine)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-window[run in windowed mode]' \
  '-fullscreen[run in fullscreen]' \
  '-width[window width]:width:' \
  '-height[window height]:height:' \
  '+set[set cvar (e.g. v_hwgamma, vid_fullscreen, vid_width, vid_height)]:cvar:: :' \
  '+exec[execute config file]:file:_files -g "*.cfg"' \
  '+connect[connect to server]:host:_hosts' \
  '*::extra args:_files' && ret=0
return ret
