#compdef ftvalid
# _ftvalid — FreeType ftvalid CLI for validating OpenType/TrueType table conformance running per-table validators GSUB GPOS GDEF JSTF MATH BASE CFF gvar fvar mort morx kern kerx (freetype team, C); getopt
# upstream: https://github.com/freetype/freetype

_ftvalid() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l+[level]:l:(default warn error tight loose)' \
        '--level=+[level]:l:(default warn error tight loose)' \
        '-t+[table]:t:(BASE CFF CFF2 GDEF GPOS GSUB JSTF MATH STAT SVG VORG ankr avar bdat bhed bloc bsln cmap cvar cvt feat fmtx fpgm fvar gasp glyf gvar hdmx head hhea hmtx just kern kerx lcar loca ltag maxp meta mort morx name opbd post prep prop sbix sfnt sing trak tsi0 tsi1 tsi2 tsi3 tsi5 tsib tsid tsij tsip tsis tsiv ufwd vdmx vhea vmtx zapf)' \
        '--table=+[table]:t:(BASE CFF GDEF GPOS GSUB cmap glyf hmtx maxp name post)' \
        '-x+[exclude table]:str:' \
        '--exclude=+[exclude table]:str:' \
        '-a[all tables]' \
        '--all[all tables]' \
        '-r[recursive]' \
        '--recursive[recursive]' \
        '-i+[output indent]:n:' \
        '--indent=+[output indent]:n:' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '*:font file:_files -g "*.ttf *.otf *.ttc *.otc *.woff *.woff2"'
}

_ftvalid "$@"
