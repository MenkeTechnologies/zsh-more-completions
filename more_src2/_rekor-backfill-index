#compdef rekor-backfill-index
# _rekor-backfill-index — Rekor backfill Redis search-index from log entries
# upstream: https://github.com/sigstore/rekor
# Flags from cmd/backfill-index/main.go on tip.

_rekor-backfill-index() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-redis-hostname=[Redis hostname]:host:' \
        '-redis-port=[Redis port]:port:' \
        '-redis-password=[Redis password]:pw:' \
        '-redis-enable-tls=[enable TLS to Redis]:bool:(true false)' \
        '-redis-insecure-skip-verify=[skip Redis TLS verification]:bool:(true false)' \
        '-mysql-dsn=[MySQL DSN]:dsn:' \
        '-start=[first index to backfill]:n:' \
        '-end=[last index to backfill]:n:' \
        '-rekor-address=[Rekor base URL]:url:_urls' \
        '-rekor-disable-keepalives=[disable HTTP keep-alives]:bool:(true false)' \
        '-rekor-retry-count=[max Rekor request retries]:n:' \
        '-rekor-retry-wait-min=[min wait between retries]:dur:' \
        '-rekor-retry-wait-max=[max wait between retries]:dur:' \
        '-concurrency=[backfill worker count]:n:' \
        '-version=[print version and exit]:bool:(true false)'
}

_rekor-backfill-index "$@"
