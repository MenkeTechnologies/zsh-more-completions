#compdef pd pd-extended pd-vanilla pdsend pdreceive
# _pd — Miller Puckette Pure Data pd real-time graphical programming environment for audio video graphics (pure-data team, C); getopt
# upstream: https://github.com/pure-data/pure-data

_pd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-nogui[no GUI]' \
        '-gui[force GUI]' \
        '-stderr[log to stderr]' \
        '-nostderr[no stderr log]' \
        '-d+[verbosity]:n:' \
        '-noprefs[ignore preferences]' \
        '-nostdpath[no standard path]' \
        '-stdpath[standard path]' \
        '-helppath+[help search path]:dir:_files -/' \
        '-path+[search path]:dir:_files -/' \
        '-open+[file to open]:file:_files -g "*.pd"' \
        '-lib+[library to load]:str:' \
        '-font-size=+[points]:n:' \
        '-font-face=+[font]:font:' \
        '-font-weight=+[weight]:w:(normal bold)' \
        '-jack[use JACK]' \
        '-alsa[use ALSA]' \
        '-portaudio[use PortAudio]' \
        '-pulseaudio[use PulseAudio]' \
        '-oss[use OSS]' \
        '-mmio[use Windows MMIO]' \
        '-asio[use ASIO]' \
        '-audiobuf=+[ms]:n:' \
        '-blocksize=+[samples]:n:' \
        '-rt[realtime priority]' \
        '-nrt[no realtime priority]' \
        '-callback[callback scheduler]' \
        '-nocallback[no callback scheduler]' \
        '-batch[batch mode]' \
        '-realtime[realtime audio]' \
        '-r+[sample rate]:n:' \
        '-inchannels=+[N]:n:' \
        '-outchannels=+[N]:n:' \
        '-channels=+[N]:n:' \
        '-audioindev=+[N]:n:' \
        '-audiooutdev=+[N]:n:' \
        '-audiodev=+[N]:n:' \
        '-mididev=+[N]:n:' \
        '-midiindev=+[N]:n:' \
        '-midioutdev=+[N]:n:' \
        '-noaudio[no audio]' \
        '-nomidi[no midi]' \
        '-stripverbose[strip verbose]' \
        '-listdev[list devices]' \
        '-version[show version]' \
        '-loadbang[force loadbang]' \
        '-noloadbang[no loadbang]' \
        '-server[run as server]' \
        '-send+[message]:str:' \
        '*:patch:_files -g "*.pd"'
}

_pd "$@"
