#compdef packwiz
# Documentation: https://packwiz.infra.link/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for packwiz (Minecraft modpack manager)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'completion:generate shell completions'
  'curseforge:manage mods from CurseForge'
  'init:initialize a new modpack'
  'list:list mods in the modpack'
  'migrate:migrate modpack loader or Minecraft version'
  'modrinth:manage mods from Modrinth'
  'pin:pin a mod to its current version'
  'refresh:refresh the pack index'
  'remove:remove a mod from the modpack'
  'serve:start a local HTTP server for the modpack'
  'settings:manage modpack settings'
  'unpin:unpin a previously pinned mod'
  'update:update mods in the modpack'
  'url:add mod from a custom URL'
  'utils:miscellaneous utilities'
  'help:show help for a command'
)

_arguments -s -S \
  '1:command:->command' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--pack-file=[path to pack.toml]:file:_files -g "*.toml"' \
  '--meta-folder=[path to meta folder]:dir:_files -/' \
  '--meta-folder-base=[base directory for meta folder]:dir:_files -/' \
  '--yes[accept all prompts]' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'packwiz command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (remove)
        _arguments '*:mod name' && ret=0
        ;;
      (update)
        _arguments \
          '--all[update all mods]' \
          '*:mod name' && ret=0
        ;;
      (curseforge)
        local -a cf_cmds=(
          'install:install a mod from CurseForge'
          'detect:detect mods from CurseForge'
          'import:import a CurseForge modpack'
          'open:open a project on CurseForge'
          'export:export the modpack for CurseForge'
        )
        _describe -t commands 'curseforge command' cf_cmds && ret=0
        ;;
      (modrinth)
        local -a mr_cmds=(
          'install:install a mod from Modrinth'
          'export:export the modpack for Modrinth'
        )
        _describe -t commands 'modrinth command' mr_cmds && ret=0
        ;;
      (serve)
        _arguments '--port=[HTTP port]:port' && ret=0
        ;;
      (init)
        _arguments \
          '--name=[modpack name]:name' \
          '--author=[modpack author]:author' \
          '--version=[modpack version]:version' \
          '--modloader=[mod loader]:loader:(fabric forge quilt neoforge liteloader none)' \
          '--mc-version=[Minecraft version]:version' && ret=0
        ;;
      (help)
        _describe -t commands 'command' commands && ret=0
        ;;
    esac
    ;;
esac

return ret
