#compdef dnsvalidator

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-tL --target-resolvers)'{-tL,--target-resolvers}'[File containing resolvers to validate]:file:_files' \
  '(-o --output)'{-o,--output}'[Output file for valid resolvers]:file:_files' \
  '(-t --threads)'{-t,--threads}'[Number of threads]:number:' \
  '--timeout[Timeout for DNS queries in seconds]:seconds:' \
  '(-r --retries)'{-r,--retries}'[Number of retries for failed queries]:number:' \
  '--silent[Suppress output]' \
  '--trust-dns[Trust target resolvers for baseline check]' \
  '--query[Domain to test resolvers against]:domain:' \
  '--baseline[Comma-separated list of trusted resolvers for baseline]:resolvers:' \
  && ret=0

return ret
