#compdef masurca
# Documentation: https://github.com/alekseyzimin/masurca
# Source: alekseyzimin/masurca README.md — Maryland Super-Read Celera Assembler (shell/Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(-g)-h[show help]' \
    '(-h)-g[generate config template]' \
    '1::config file:_files' \
    && ret=0

return ret
