#compdef msgpre
# Documentation: GNU gettext msgpre(1) man page (installed locally)
# Reference accessed: 2026-05-19
# Verified: against local `msgpre --help` and man msgpre output.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-i+,--input=}'[input PO file]:file:_files -g "*.po"' \
  {-D+,--directory=}'[add directory to input file search list]:dir:_files -/' \
  {-o+,--output-file=}'[output PO file]:file:_files -g "*.po"' \
  '--keep-fuzzy[keep fuzzy messages unmodified]' \
  '--species=[type of LLM]:type:(ollama)' \
  '--url=[URL of LLM server]:url:' \
  {-m+,--model=}'[LLM model to use]:model:' \
  '--prompt=[prompt to use before standard input]:text:' \
  '--postprocess=[command to post-process output]:command:' \
  {-P,--properties-input}'[input is Java .properties syntax]' \
  '--stringtable-input[input is NeXTstep/GNUstep .strings syntax]' \
  '--color[use colors and text attributes always]' \
  '--color=[use colors when]:when:(always never auto html)' \
  '--style=[CSS style file for --color]:file:_files' \
  '--force-po[write PO file even if empty]' \
  '--indent[indented output style]' \
  '--no-location[suppress #: filename:line lines]' \
  {-n,--add-location}'[preserve #: filename:line lines (default)]' \
  '--strict[strict Uniforum output style]' \
  {-p,--properties-output}'[write Java .properties file]' \
  '--stringtable-output[write NeXTstep/GNUstep .strings file]' \
  {-w+,--width=}'[output page width]:n:' \
  '--no-wrap[do not break long lines]' \
  {-s,--sort-output}'[generate sorted output]' \
  {-F,--sort-by-file}'[sort output by file location]' \
  {-q,--quiet,--silent}'[suppress progress indicators]' \
  '*:input file:_files -g "*.po"' && ret=0

return ret
