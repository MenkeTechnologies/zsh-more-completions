#compdef jfq
# ============================================================================
# jfq - JSONata on the command line (Node.js, MIT)
#
# Author : George Blue (blgm)
# Upstream: https://github.com/blgm/jfq
# npm    : jfq (binary: jfq)
#
# `jfq` is a tiny command-line JSONata evaluator -
# `jq`-style streaming filter, but using the JSONata
# query language (https://jsonata.org/) instead of
# jq's bespoke syntax. JSONata is a JSON-native
# query + transformation language standardized at
# Stedi (formerly IBM-internal); jfq is the
# canonical Node-binding CLI wrapper.
#
# Use cases:
#   - JSONata as a drop-in replacement for `jq`
#     when you need SQL-style aggregation, joins,
#     or transformations
#   - YAML-in / YAML-out filter pipelines without
#     needing a separate YAML <-> JSON converter
#   - Newline-delimited JSON (NDJSON) emission for
#     downstream log-pipeline consumption
#   - Lightweight CI-pipeline data extraction
#     (transform Kubernetes manifests, OpenAPI
#     specs, GitHub API responses)
#
# Usage:
#   jfq [options] [<query>] [<file> ...]
#
# When the first positional argument is a path that
# exists on disk, jfq treats it as input + uses `$`
# (the identity query); otherwise the first arg is
# the JSONata query expression. Files default to
# stdin if none are given.
#
# Flags (commander.js v6 .option() declarations):
#   -n, --ndjson                  - emit newline-
#                                    delimited JSON
#                                    output (one
#                                    object per line)
#   -j, --json                    - force JSON
#                                    output (suppress
#                                    pretty-printing
#                                    + array-collapse
#                                    heuristics)
#   -y, --yaml                    - emit YAML output
#                                    (uses `js-yaml`
#                                    YAML.dump under
#                                    the hood)
#   -a, --accept-yaml             - accept YAML
#                                    input (uses
#                                    `js-yaml`
#                                    YAML.load under
#                                    the hood)
#   -p, --plain-text              - do not decorate
#                                    output (skip
#                                    ANSI colorizer)
#   -q, --query-file <path>       - read JSONata
#                                    query from a
#                                    file instead of
#                                    the first
#                                    positional
#                                    argument
#   -h, --help                    - print
#                                    commander.js
#                                    help
#   -V, --version                 - print
#                                    commander.js
#                                    version
#
# Examples:
#   echo '{"a": 1}' | jfq 'a'
#   jfq '$sum(items.price)' invoice.json
#   jfq -y 'metadata.name' deployment.yaml
#   jfq -a -y 'spec.template.spec.containers[0].image' k8s.yaml
#   jfq -n '$[].id' users.json   # NDJSON output
#   jfq -q query.jsonata data.json
#
# The js-yaml lane is built on `js-yaml ^4.1.0`
# (declared verbatim at upstream package.json HEAD
# as a direct dep, imported as
# `import YAML from 'js-yaml'` in src/jfq.js, then
# `YAML.load(string, { json: true })` for YAML
# input parsing + `YAML.dump(yaml)` for YAML output
# emission), the canonical Node YAML library by
# Vitaly Puzrin + the nodeca contributor team -
# github.com/nodeca/js-yaml.
#
# js-yaml is the de-facto canonical Node YAML
# library by overwhelming reverse-dependency count
# (50,000+ npm packages depend on it):
#   - ESLint (config-file loading + .eslintrc.yaml
#     parsing)
#   - webpack (loader + plugin config parsing for
#     YAML-based config files)
#   - Babel (.babelrc.yaml + babel.config.yaml
#     parsing)
#   - Vue.js + Nuxt.js + Next.js (i18n YAML +
#     config loading)
#   - Storybook (configuration loading)
#   - Hugo + Jekyll-like static-site generators
#     (front-matter parsing in JS toolchains)
#   - Helm-style chart YAML manipulation in JS
#     toolchains
#   - Kubernetes manifest tooling (kubeval +
#     kustomize JS bindings + cdk8s)
#   - GitHub Actions YAML parsers (act tooling)
#   - Docker Compose v3 + Buildkit (YAML config
#     parsing for JS-based Docker tooling)
#
# js-yaml v4 distinguishing features over v3:
#   - Default-safe loading (the `load` function
#     is now safe; the v3 `safeLoad` is gone)
#   - Better YAML 1.2 spec compliance
#   - Stricter error messages with line + column
#     info
#   - Schema-based parsing (`YAML.load(text, {
#     schema: YAML.JSON_SCHEMA })` for strict-JSON-
#     compatible-YAML)
#   - Smaller bundle size (~35% smaller)
#   - Tree-shakeable ES Modules
#
# Vitaly Puzrin + the nodeca org's broader Node
# ecosystem footprint:
#   - js-yaml (canonical Node YAML library; THIS
#     AXIS)
#   - markdown-it (canonical Node CommonMark/
#     GFM parser; the engine behind VS Code's
#     Markdown preview + every major Node Markdown
#     toolchain)
#   - pako (canonical pure-JS zlib port; used by
#     ~every Node compression library that needs
#     gzip/deflate)
#   - argparse (Node port of Python's argparse;
#     foundational CLI-parsing library)
#   - sax (pure-JS SAX-style XML parser; used by
#     many older Node XML toolchains)
#   - linkify-it (canonical URL detection library
#     used by markdown-it for autolinking)
#
# Puzrin's foundational role mirrors Tolnay's in
# Rust + Niemeyer's in Go + Schlueter's in Node
# infrastructure - the nodeca org publishes
# small, focused, foundational libraries that
# the ecosystem builds on. Distinct from
# Schlueter's role (which spans infrastructure
# tooling like npm + node-glob + rimraf + node-
# semver), Puzrin's nodeca position is in
# *document-format parsing libraries* (YAML +
# Markdown + zlib + XML + URL detection).
#
# jfq uses js-yaml in src/jfq.js:
#   ```js
#   import YAML from 'js-yaml'
#   const parseYaml = (string, fileName) => {
#     try {
#       return YAML.load(string, { json: true })
#     } catch (err) { ... }
#   }
#   const formatYaml = yaml =>
#     typeof yaml === 'undefined'
#       ? ''
#       : YAML.dump(yaml)
#   ```
# YAML input gets parsed via `YAML.load` with
# `{ json: true }` to enforce JSON-schema-
# compatible YAML (no anchors/aliases/custom
# tags), then transformed via the JSONata query,
# then re-serialized via `YAML.dump` if -y is set.
#
# ----------------------------------------------------------------------------
# AXIS 262 :: YAML parsing libraries (YAML 1.1/1.2
#              spec parsing + serialization)
# Round 1486 :: TS-Node slot 3 of 4 :: CLOSES Axis 262
#                                       (255th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : dtolnay/serde-yaml          [R1484 _lorikeet]
#             (archived 2024 but still
#              dominant via 10,000+
#              reverse-deps)
#   Go      : go-yaml/yaml v3             [R1485 _swcat]
#             (Canonical Ltd / Gustavo
#              Niemeyer)
#   TS/Node : nodeca/js-yaml              [R1486 THIS FILE]
#             (Puzrin's canonical;
#              50,000+ reverse-deps)
#
# nodeca/js-yaml closes Axis 262 with the
# *foundational-document-format-library* pattern.
# The three lanes form a clean spectrum:
#
#   - Rust (serde_yaml): foundational but archived;
#     ecosystem fragmented; community migrating
#     slowly to saphyr/serde_yml
#   - Go (yaml.v3): foundational + actively
#     maintained; single canonical import path
#     `gopkg.in/yaml.v3`; migration to
#     `go.yaml.in/yaml/v3` in progress but
#     unified
#   - Node (js-yaml): foundational + actively
#     maintained; co-canonical with eemeli/yaml
#     (the newer Node YAML library focused on
#     round-trip-with-comments) but js-yaml
#     dominates by reverse-dependency count
#
# Multi-axis canonical-Node author cohort (now
# spanning 10 distinct individuals):
#   - Sindre Sorhus (chalk + ~1000 microlibs)
#   - Matt Ranney + Redis Inc. (node-redis)
#   - Brian Carlson (node-postgres)
#   - Andrey Sitnik (PostCSS + browserslist +
#     nanoid)
#   - Lovell Fuller (sharp)
#   - Paul Miller (noble umbrella)
#   - Devon Govett (foliojs umbrella +
#     lightningcss)
#   - Matteo Collina (undici + pino + fastify)
#   - Isaac Z. Schlueter (npm CLI + node-glob +
#     rimraf + node-semver)
#   - Vitaly Puzrin + nodeca (js-yaml +
#     markdown-it + pako + argparse + sax +
#     linkify-it, THIS AXIS)
#
# Cross-language interop at the YAML document
# level - the same YAML file parses into
# equivalent data structures across all three
# lanes, enabling polyglot toolchains like
# Kubernetes manifests (k8s YAML consumed by
# kubectl in Go + Helm in Go + Pulumi in TS +
# cdk8s in TS + k8s Rust clients).
#
# Use-case spectrum across the three lanes:
#   - lorikeet (Rust, serde_yaml): parallel
#     DevOps test runner using serde_yaml for
#     test-plan loading
#   - swcat (Go, yaml.v3): file-based software
#     catalog using yaml.v3 for entity
#     definitions + plugin configs
#   - jfq (Node, js-yaml): JSONata CLI evaluator
#     using js-yaml for YAML-in / YAML-out
#     pipelines
#
# Three lanes, three use-case shapes (DevOps test
# orchestration / service-catalog tooling /
# JSON-data-query CLI), three YAML library
# governance patterns (single-author-archived /
# company-backed-unified / org-backed-multi-
# maintainer), all converging on the YAML 1.2
# spec with minor compatibility edge cases.
#
# Axis 262 closes the round 1486 cycle - 255th
# axis closed total.
#
# Notable architectural symmetry across the
# axis: serde_yaml (Rust) + yaml.v3 (Go) +
# js-yaml (Node) all implement the same YAML 1.2
# spec but each is the *foundational* library
# in its host ecosystem - meaning ~every other
# YAML-consuming library in that language
# transitively depends on them. This makes the
# axis a "pure-canonical" axis where canonical
# selection is unambiguous: there is no
# competing canonical library in any of the
# three lanes that has equivalent reverse-
# dependency reach.
# ============================================================================

_jfq() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-n --ndjson)'{-n,--ndjson}'[newline-delimited JSON output]' \
        '(-j --json)'{-j,--json}'[force JSON output]' \
        '(-y --yaml)'{-y,--yaml}'[YAML output (via js-yaml YAML.dump)]' \
        '(-a --accept-yaml)'{-a,--accept-yaml}'[accept YAML input (via js-yaml YAML.load)]' \
        '(-p --plain-text)'{-p,--plain-text}'[do not decorate output (skip ANSI colorizer)]' \
        '(-q --query-file)'{-q,--query-file}'[read JSONata query from file]:file:_files' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '*:query or file:_files'
}

_jfq "$@"
