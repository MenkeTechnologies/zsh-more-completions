#compdef deployctl
# Documentation: https://docs.deno.com/deploy/manual/deployctl/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'deploy:deploy code to Deno Deploy'
  'projects:manage projects'
  'deployments:manage deployments'
  'logs:stream and query deployment logs'
  'top:monitor real-time resource usage'
  'api:make a Subhosting API call'
  'upgrade:upgrade deployctl to a given version'
  'completion:generate shell completion'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--token=[Deno Deploy access token]:token:' \
  '--config=[deno.json or deployctl config file]:file:_files' \
  '--save-config[save provided arguments to config]' \
  '--color=[colored output]:mode:(auto always never)' \
  '--format=[output format]:format:(json text)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'deployctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deploy)
        _arguments \
          '--project=[project name]:name:' \
          '--entrypoint=[entry file path or URL]:path:_files' \
          '--org=[organization name]:org:' \
          '*--include=[path to include]:path:_files' \
          '*--exclude=[path to exclude]:path:_files' \
          '*--env=[env var KEY=VALUE]:env:' \
          '*--env-file=[env file]:file:_files' \
          '--import-map=[import map file]:file:_files' \
          '--db=[KV database name or uuid]:db:' \
          '--prod[create a production deployment]' \
          '--dry-run[do not actually deploy]' && ret=0 ;;
      (projects)
        local -a project_subs=(
          'list:list accessible projects'
          'show:show project details'
          'rename:rename a project'
          'create:create a new project'
          'delete:delete a project'
        )
        _describe -t pcmds 'projects subcommand' project_subs && ret=0
        _arguments \
          '--org=[organization filter]:org:' \
          '--project=[project name]:name:' && ret=0 ;;
      (deployments)
        local -a deploy_subs=(
          'list:list deployments'
          'show:show deployment details'
          'redeploy:redeploy from an existing build'
          'delete:delete a deployment'
        )
        _describe -t dcmds 'deployments subcommand' deploy_subs && ret=0
        _arguments \
          '--project=[project name]:name:' \
          '--id=[deployment id]:id:' \
          '--last[target last deployment]' \
          '--next=[navigate forward]:n:' \
          '--prev[navigate backward]' \
          '--prod[promote to production]' \
          '--db=[KV database]:db:' \
          '*--env=[env var KEY=VALUE]:env:' \
          '*--env-file=[env file]:file:_files' \
          '--page=[page number]:n:' \
          '--limit=[results per page]:n:' && ret=0 ;;
      (logs)
        _arguments \
          '--deployment=[deployment id]:id:' \
          '--project=[project name]:name:' \
          '--levels=[log level filter]:levels:' \
          '--regions=[region filter]:regions:' \
          '--grep=[search pattern]:pattern:' \
          '--since=[start timestamp]:ts:' \
          '--until=[end timestamp]:ts:' && ret=0 ;;
      (top)
        _arguments \
          '*--region=[region filter]:region:' \
          '--project=[project name]:name:' && ret=0 ;;
      (api)
        _arguments \
          '--method=[HTTP method]:method:(GET POST PUT PATCH DELETE)' \
          '--body=[request body JSON]:json:' \
          '*::path:' && ret=0 ;;
      (upgrade)
        _arguments '*::version:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
