#compdef grit
# _grit — Morgante Pell getgrit Grit query language CLI for code transformations and AST search (getgrit team, Rust); clap-derive
# upstream: https://github.com/getgrit/gritql

_grit() {
    local -a sub=(
        'apply:apply a pattern to files'
        'check:check files against patterns'
        'init:initialize a grit project'
        'list:list available patterns'
        'patterns:pattern subcommands'
        'auth:auth subcommands'
        'plumbing:plumbing subcommands'
        'install:install grit'
        'doctor:show diagnostics'
        'lsp:run language server'
        'parse:parse pattern'
        'completions:generate completion'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--app=+[app]:str:' \
        '--grit-dir=+[grit dir]:dir:_files -/' \
        '--json[json output]' \
        '--jsonl[jsonl output]' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'grit subcommand' sub ;;
        args)
            case $words[1] in
                apply) _arguments \
                    '--dry-run[dry run]' \
                    '-d[dry run]' \
                    '--force[force apply]' \
                    '-f[force apply]' \
                    '--interactive[interactive]' \
                    '-i[interactive]' \
                    '--language=+[language]:l:(js ts tsx jsx python rust go java css html json yaml markdown)' \
                    '-l+[language]:l:(js ts tsx jsx python rust go java css html json yaml markdown)' \
                    '--limit=+[max matches]:n:' \
                    '--ai[use ai]' \
                    '--watch[watch files]' \
                    '1:pattern:' \
                    '*:file:_files' ;;
                check) _arguments \
                    '--level=+[severity]:l:(info warn error)' \
                    '*:file:_files' ;;
                patterns) _arguments '1:patterns cmd:(list test edit describe ls)' ;;
                auth) _arguments '1:auth cmd:(login logout get-token refresh)' ;;
                plumbing) _arguments '1:plumbing cmd:(check apply list parse)' ;;
                init) _arguments \
                    '--global[global init]' \
                    '*:dir:_files -/' ;;
                completions) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_grit "$@"
