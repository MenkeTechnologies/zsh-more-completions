#compdef rider
# Documentation: https://www.jetbrains.com/help/rider/Working_with_the_IDE_Features_from_Command_Line.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Also referenced:
#   https://www.jetbrains.com/help/rider/Opening_Files_from_Command_Line.html
#   https://www.jetbrains.com/help/rider/Command_Line_Differences_Viewer.html
#   https://www.jetbrains.com/help/rider/Command_Line_Merge_Tool.html

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'diff:open the diff viewer comparing two files'
  'merge:open the three-way merge dialog'
  'attach-to-process:start Rider and attach the debugger to a running process'
)

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--wait[wait for the files to be closed before returning]' \
  '--line=[open file with caret at this line]:line number:' \
  '--column=[open file with caret at this column]:column number:' \
  '--nosplash[do not show splash screen]' \
  '--dontReopenProjects[skip reopening previous projects]' \
  '--disableNonBundledPlugins[launch without manually installed plugins]' \
  '1: :->cmd' \
  '*:files or directories:_files' && ret=0

case $state in
  (cmd)
    if (( CURRENT == 2 )); then
      _describe -t commands 'rider subcommand' commands
    fi
    _files
    ret=0
    ;;
esac

return ret
