#compdef glyphsLib glyphs2ufo glyphs2ttf glyphsLib-cli
# _glyphsLib — Hugely Type glyphsLib CLI for round-tripping Glyphs .glyphs source format to UFO designspace TTF/OTF and back for variable-font workflows shared between Glyphs.app and FontTools (googlefonts team, Python); argparse
# upstream: https://github.com/googlefonts/glyphsLib

_glyphsLib() {
    local -a sub=(
        'glyphs2ufo:convert Glyphs to UFO'
        'ufo2glyphs:convert UFO to Glyphs'
        'glyphs2ttf:convert Glyphs to TTF'
        'glyphs2otf:convert Glyphs to OTF'
        'glyphs2variable:build variable font'
        'glyphs2designspace:convert Glyphs to designspace'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glyphsLib subcommand' sub ;;
        args)
            case $words[1] in
                glyphs2ufo) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--output-dir=+[output dir]:dir:_files -/' \
                    '--write-public-skip-export-glyphs[write skip export]' \
                    '--no-preserve-glyphsapp-metadata[no preserve metadata]' \
                    '--minimal[minimal]' \
                    '--propagate-anchors=+[b]:b:(true false)' \
                    '--instance-dir=+[dir]:dir:_files -/' \
                    '--designspace-path=+[file]:file:_files -g "*.designspace"' \
                    '--generate-GDEF[generate GDEF]' \
                    '--no-generate-GDEF[no generate GDEF]' \
                    '*:glyphs file:_files -g "*.glyphs *.glyphspackage"' ;;
                ufo2glyphs) _arguments \
                    '-o+[output file]:file:_files -g "*.glyphs *.glyphspackage"' \
                    '--output-path=+[output file]:file:_files -g "*.glyphs *.glyphspackage"' \
                    '*:ufo files or designspace:_files -g "*.ufo *.ufoz *.designspace"' ;;
                glyphs2ttf|glyphs2otf|glyphs2variable) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--output-dir=+[output dir]:dir:_files -/' \
                    '--no-production-names[no production names]' \
                    '--keep-glyph-names[keep glyph names]' \
                    '*:glyphs file:_files -g "*.glyphs *.glyphspackage"' ;;
            esac
            ;;
    esac
}

_glyphsLib "$@"
