#compdef rancher-agent
# Documentation: https://github.com/rancher/system-agent/blob/main/install.sh
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# rancher-agent: Rancher System Agent registration script (install.sh entrypoint).
# Flags below mirror parse_args() in upstream install.sh; the actual binary
# (rancher-system-agent) is driven via subcommands sentinel|validate-config|
# validate-connection and CATTLE_* env vars.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-s --server)'{-s+,--server=}'[Rancher server URL]:url:' \
  '(-t --token)'{-t+,--token=}'[registration token]:token:' \
  '(-c --ca-checksum)'{-c+,--ca-checksum=}'[CA checksum]:sha:' \
  '(-n --node-name)'{-n+,--node-name=}'[node name]:name:' \
  '-i+[internal address]:addr:' \
  '--internal-address=[internal address]:addr:' \
  '--address=[external address]:addr:' \
  '-w[register as worker role]' \
  '--worker[register as worker role]' \
  '-p[register as controlplane role]' \
  '--controlplane[register as controlplane role]' \
  '-e[register as etcd role]' \
  '--etcd[register as etcd role]' \
  '--all-roles[register all roles (controlplane, etcd, worker)]' \
  '--no-roles[register with no roles]' \
  '(-l --label)'{-l+,--label=}'[label key=value]:label:' \
  '(--taint --taints)'{--taint=,--taints=}'[node taint]:taint:' \
  '*::rancher-agent args:_files' && ret=0
return ret
