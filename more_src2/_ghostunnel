#compdef ghostunnel
# Documentation: https://github.com/ghostunnel/ghostunnel
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_ghostunnel() {
    local matches=($(${words[1]} --completion-bash "${(@)words[2,$CURRENT]}"))
    compadd -a matches

    if [[ $compstate[nmatches] -eq 0 && $words[$CURRENT] != -* ]]; then
        _files
    fi
}

if [[ "$(basename -- ${(%):-%x})" != "_ghostunnel" ]]; then
    compdef _ghostunnel ghostunnel
fi
