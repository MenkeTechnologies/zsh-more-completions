#compdef fitscopy
# _fitscopy — copy FITS files with CFITSIO extended filename filtering (HEASARC/cfitsio)
# upstream: https://github.com/HEASARC/cfitsio
# Usage from utilities/fitscopy.c: fitscopy inputfile outputfile

_fitscopy() {
    _arguments \
        '1:input FITS file (with optional [filter]):_files -g "*.(fits|fit|imh|dat)"' \
        '2:output FITS file:_files -g "*.(fits|fit)"'
}

_fitscopy "$@"
