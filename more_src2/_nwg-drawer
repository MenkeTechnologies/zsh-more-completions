#compdef nwg-drawer
# Documentation: https://github.com/nwg-piotr/nwg-drawer
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nwg-drawer - application launcher for Wayland

_arguments \
  '(- *)-h[show help]' \
  '-v[show version]' \
  '-c+[columns (default 6)]:columns:' \
  '-closebtn+[close button position]:position:(left right none)' \
  '-d[debug mode]' \
  '-fm+[file manager (default thunar)]:command:' \
  '-fscol+[file search result columns]:columns:' \
  '-fslen+[file search name length limit]:length:' \
  '-ft[force theme for libadwaita apps]' \
  '-g+[GTK theme name]:theme:' \
  '-i+[icon theme name]:theme:' \
  '-is+[icon size]:size:' \
  '-k[keyboard interactivity on-demand]' \
  '-lang+[force language]:language:' \
  '-mb+[margin bottom]:pixels:' \
  '-ml+[margin left]:pixels:' \
  '-mr+[margin right]:pixels:' \
  '-mt+[margin top]:pixels:' \
  '-nocats[disable category filtering]' \
  '-nofs[disable file search]' \
  '-o+[output display name]:output:' \
  '-open[control resident instance: open]' \
  '-close[control resident instance: close]' \
  '-ovl[use overlay layer]' \
  '-pbexit+[power bar exit command]:command:' \
  '-pblock+[power bar lock command]:command:' \
  '-pbpoweroff+[power bar poweroff command]:command:' \
  '-pbreboot+[power bar reboot command]:command:' \
  '-pbsleep+[power bar sleep command]:command:' \
  '-pbsize+[power bar icon size]:size:' \
  '-pbuseicontheme[use icon theme for power bar]' \
  '-r[run resident]' \
  '-s+[CSS styling file]:file:_files -g "*.css"' \
  '-spacing+[icon spacing (default 20)]:pixels:' \
  '-term+[terminal emulator]:command:' \
  '-wm+[compositor type]:wm:(sway hyprland river niri uwsm)'
