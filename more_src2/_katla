#compdef katla
# ============================================================================
#  _katla — katla: Idris2 source-to-documentation generator —
#           takes Idris2 source files (.idr) along with the
#           compiler's intermediate Type Tree (TTM) files and
#           generates beautifully-typeset HTML / LaTeX /
#           Markdown / Pandoc documentation with HYPERLINKED
#           identifiers (clicking on a function name jumps to
#           its definition), TYPE-ANNOTATED bindings, and
#           SYNTAX HIGHLIGHTING that reflects Idris2's actual
#           typechecker output (not generic regex-based
#           highlighting)
#           (Idris Community / Andre Videla / Edwin Brady et al.
#           — idris-community/katla)
#
#  Source-direct extraction from
#    https://github.com/idris-community/katla/blob/main/src/Katla.idr
#    https://github.com/idris-community/katla/blob/main/src/Katla/CLI.idr
#      (Collie Command definitions for inline/macro/markdown/
#      literate/html subcommands)
#    https://github.com/ohad/collie (the ohad/collie library by
#    Ohad Kammar — Edinburgh University functional programming
#    researcher, co-author of CARP/Effect papers)
#
#  Maintained by Idris Community (Andre Videla as primary
#  katla maintainer; with contributions from Edwin Brady — the
#  IDRIS LANGUAGE CREATOR — and the broader Idris community).
#  idris-community/katla: 21 GH stars (small academic community
#  but ACTIVELY MAINTAINED).  katla is the canonical Idris2
#  documentation generator used to produce the official Idris2
#  language tour, the Idris2 standard library API docs, and
#  many academic papers that include typeset Idris2 code.
#  Distinct from generic syntax-highlighting tools (Pygments,
#  Rouge, highlight.js) by leveraging Idris2's TYPE-TREE
#  intermediate format (.ttm files emitted by the Idris2
#  compiler during typechecking) to ACCURATELY color and
#  HYPERLINK identifiers — function calls link to their
#  definitions, data constructors link to their type signatures,
#  types display their universe levels and constraints, etc.
#  This is impossible with regex-based highlighters because
#  IDRIS2 IS DEPENDENTLY TYPED — the "type" of a value depends
#  on its term-level context, and only a full typechecker can
#  resolve which symbol refers to which definition.  Sister
#  tools: idris2 (the Idris2 compiler/REPL — IN CORPUS via
#  _idris2), pack (Idris2 package manager by Stefan Hoeck —
#  IN CORPUS via different `pack`), idris2-lsp (Idris2 Language
#  Server Protocol implementation), idris2-pretty-printer, R443
#  Curry's PAKCS (logic+functional language; closest sibling
#  to Idris2 in the academic functional space), R429 Frege
#  (Haskell-on-JVM — functional cousin without dependent
#  types), agda (Agda dependently-typed proof assistant), coq
#  (Coq proof assistant — in corpus + STOCK), lean (Lean
#  theorem prover — in corpus + STOCK).
#
#  IDRIS2 is Edwin Brady's PURELY FUNCTIONAL DEPENDENTLY-TYPED
#  programming language — successor to Idris1 (which was
#  written in Haskell; Idris2 is SELF-HOSTING, written
#  entirely in Idris2 itself).  Distinctive features: FULL
#  DEPENDENT TYPES (types can depend on terms; e.g. `Vect n
#  Int` is a vector of length n known at type-check time),
#  QUANTITATIVE TYPE THEORY (QTT — runtime usage annotations
#  on bindings: 0 for erased compile-time-only, 1 for linear/
#  use-once, ω for unrestricted), TOTALITY CHECKING (compiler
#  proves your function terminates on all inputs), INTERACTIVE
#  EDITING (Holes — leave `?foo` in your code; the compiler
#  shows the goal type + available variables to fill it),
#  ELABORATOR REFLECTION (write metaprograms that manipulate
#  the elaborator at compile time), CHEZ SCHEME / RACKET / JS /
#  RefC backends.  Use cases: formally-verified software
#  engineering, dependent-type theory research, theorem
#  proving, type-driven development, and pedagogy of
#  dependently-typed programming.  Edwin Brady wrote the
#  textbook "TYPE-DRIVEN DEVELOPMENT WITH IDRIS" (Manning
#  2017) which uses Idris1; Idris2 introduces QTT on top of
#  Idris1's semantics.
#
#  CLI library taxonomy update: 1st Idris2 CLI library — Ohad
#  Kammar's **Collie** library (ohad/collie).  Idris2 joins
#  the cross-language taxonomy as the 41st documented language.
#  🎉 NEW LANGUAGE entry — Idris2 joins alongside Rust, Go,
#  TypeScript-Node, Python, Ruby, Perl, Haskell, OCaml,
#  Elixir, R, Bash, Deno, Lua, Scheme, Clojure, Common Lisp,
#  Racket, Crystal, Nim, Zig, Odin, V, Mojo, Roc, Hare,
#  Standard ML, Erlang, Pony, Prolog, Pike, F#, Janet, D,
#  Picat, BQN, Frege, Lobster, Curry, Mercury, Wren.  🎉 40+1
#  THRESHOLD CROSSED — Idris2 is the 41st documented language.
#
#  Collie (ohad/collie) is Ohad "ohad" Kammar's Idris2 CLI
#  library — provides a `Command nm` indexed type for typed
#  command-line parsing where the command's NAME is encoded in
#  the type and the legal subcommands / modifiers / arguments
#  are checked at COMPILE TIME via Idris2's dependent typing.
#  Distinguishing philosophy: TYPE-DRIVEN CLI DESIGN — the
#  CLI schema is a Collie record whose fields (`subcommands`,
#  `modifiers`, `arguments`) carry type-level evidence about
#  valid usage; the compiler proves at type-check time that
#  the user's `katlaExec` handler covers every possible
#  command path.  Distinct from R275 Rust clap-derive (clap is
#  Rust + proc-macro; Collie is Idris2 + dependent types —
#  fundamentally different abstraction levels), R415 cmd-ts
#  (TypeScript parser-combinator algebra — closest spiritual
#  cousin since both are inspired by Haskell's optparse-
#  applicative), R420 Rust ksk001100/seahorse (also a builder-
#  pattern CLI lib but Rust not Idris2).  Used by idris-
#  community/katla (Idris2 doc generator, 21 stars), idris-
#  community/idris2-lsp (Idris2 Language Server Protocol),
#  ohad/collie repo's own examples, and other Idris2-community
#  CLI tools.
#
#  Collie API (in Idris2):
#    module MyTool
#
#    import Collie
#
#    -- DEFINE COMMANDS with dependent types — `Command "name"`
#    -- is the type for a command named "name"
#    inlineCmd : Command "inline"
#    inlineCmd = MkCommand
#      { description = "Generate inline code snippet macro"
#      , subcommands = []                          -- no sub-cmds
#      , modifiers = []                            -- no flags
#      , arguments = lotsOf filePath               -- 0+ files
#      }
#
#    macroCmd : Command "macro"
#    macroCmd = MkCommand
#      { description = "Generate code snippet macro"
#      , subcommands = ["inline" ::= inlineCmd]    -- ONE sub-cmd
#      , modifiers = []
#      , arguments = lotsOf filePath
#      }
#
#    katlaCmd : Command "katla"
#    katlaCmd = MkCommand
#      { description = "Idris2 documentation generator"
#      , subcommands =
#        [ "macro"    ::= macroCmd
#        , "markdown" ::= markdownCmd
#        , "literate" ::= literateCmd
#        , "html"     ::= htmlCmd
#        ]
#      , modifiers =
#        [ "--config" ::= option "Config file path" filePath
#        , "--verbose" ::= flag "Verbose output"
#        ]
#      , arguments = lotsOf filePath
#      }
#
#    -- HANDLER FUNCTION (signature inferred from CLI schema)
#    katlaExec : ExecutionFrom katlaCmd -> IO ()
#    katlaExec = ...  -- compiler enforces total coverage
#
#    main : IO ()
#    main = katlaCmd.handleWith katlaExec
#
#  Collie distinctive features:
#    - DEPENDENT-TYPED Command schema — `Command "name"` is
#      indexed by the command's name (compile-time string
#      literal); the compiler tracks which command we're
#      defining and prevents typos in subcommand names
#    - RECORD-OF-RECORDS schema — Command = { description,
#      subcommands, modifiers, arguments }; each field carries
#      its own type-level invariants
#    - `::= ` operator — Idris2 infix constructor used to
#      assign sub-elements: `"name" ::= subCommand` /
#      `"--flag" ::= option ...` / `"--switch" ::= flag ...`
#    - SUBCOMMANDS as LIST of `(name, Command)` pairs —
#      each subcommand can recursively have its own subcommands
#    - MODIFIERS — flags + options.  `option "desc" type` for
#      value-bearing flags; `flag "desc"` for boolean switches
#    - ARGUMENTS — variadic argument list typed via `lotsOf
#      argType` (zero-or-more); also `oneOf` (single required)
#      and `argType` combinators
#    - filePath / dirPath / textArg — built-in argument types
#      with sensible parsing
#    - `Command.handleWith handler` — the magic glue: takes a
#      handler function whose TYPE matches the command tree's
#      execution path, and dispatches to the appropriate
#      sub-handler based on argv
#    - `ExecutionFrom cmd` — the type-level encoding of all
#      possible execution paths through `cmd`; handlers
#      pattern-match on this and the compiler proves coverage
#    - TOTALITY-CHECKED — `%default covering` ensures the
#      handler covers all possible command/subcommand
#      combinations (compile-time coverage check)
#    - AUTO --help / -h generation from descriptions; usage
#      strings derived from the type structure
#    - INSPIRED BY Haskell's optparse-applicative (the same
#      applicative-functor compositional pattern) but lifted
#      into Idris2's dependent type system
#    - INFIX OPERATORS — Collie heavily uses Idris2's
#      operator-precedence syntax for readable schema
#      definitions; the `::=` operator looks like Pascal's
#      "is defined as" notation
#  Idris2 is the FIRST DOCUMENTED Idris2 CLI library in the
#  corpus's cross-language taxonomy.  Idris2 joins the 40 other
#  documented languages as the 41st represented language.
#  Brings cross-language CLI library taxonomy variant count to
#  191 (190 + ohad/collie = 191).
#
#  Surface (verbatim from `src/Katla/CLI.idr` Collie Command
#  definitions):
#
#  Usage:
#    katla <backend> [<sub-backend>] [--config <FILE>] [<idr-files>...]
#
#  Backends (top-level subcommands):
#    macro <FILES...>               Generate LaTeX MACRO that
#                                   typesets the code snippet
#                                   (returns \katlamacro{...}
#                                   commands to be included in
#                                   LaTeX docs); nested
#                                   subcommand `macro inline`
#                                   produces inline code-span
#                                   macros instead of block
#                                   macros
#    macro inline <FILES...>        Generate macro for INLINE
#                                   code snippets (typically
#                                   used for `verb`-like inline
#                                   code; nested under `macro`)
#    markdown <FILES...> [--config <FILE>]
#                                   Markdown backend — emits
#                                   GitHub-flavored Markdown
#                                   with fenced code blocks
#                                   carrying class names for
#                                   each token type (for
#                                   styling via CSS in the
#                                   target Markdown renderer)
#    markdown init                  Generate the default
#                                   Markdown preamble config
#                                   file (Dhall format)
#    literate <FILES...> [--config <FILE>]
#                                   Literate LaTeX backend —
#                                   emits a complete .tex file
#                                   with the Idris2 source code
#                                   typeset as LaTeX listings
#                                   (with hyperlinks, type
#                                   annotations); intended for
#                                   academic papers with
#                                   embedded code
#    literate init                  Generate the default
#                                   literate-LaTeX preamble
#                                   config (Dhall format)
#    html <FILES...> [--config <FILE>]
#                                   HTML backend — emits
#                                   HTML with `<span class
#                                   ="...">` markup per token;
#                                   typical usage shown in
#                                   help text:
#                                   `html Katla.idr build/ttc/
#                                   */Katla.ttm > out.html`
#    html init                      Generate the default HTML
#                                   preamble config (Dhall
#                                   format)
#    pandoc <FILES...>              Pandoc backend (auxiliary
#                                   format)
#
#  Modifiers (flag options):
#    --config <FILE>                Preamble configuration file
#                                   in DHALL FORMAT (a typed
#                                   functional configuration
#                                   language by Gabriel Gonzales)
#                                   — used by markdown /
#                                   literate / html / pandoc
#                                   backends to customize the
#                                   preamble (CSS for HTML,
#                                   LaTeX packages for LaTeX,
#                                   etc.).  Use `<backend> init`
#                                   to generate a default
#                                   config to edit.
#
#  Positional:
#    <FILES...>                     Idris2 source files (.idr)
#                                   plus their corresponding
#                                   TYPE-TREE files (.ttm) from
#                                   the Idris2 compiler's
#                                   `build/ttc/*` directory.
#                                   katla needs BOTH to
#                                   accurately render type
#                                   annotations and hyperlinks.
#
#  Examples:
#    katla html Katla.idr build/ttc/*/Katla.ttm > out.html  # HTML doc
#    katla literate paper.idr build/ttc/*/paper.ttm > paper.tex  # LaTeX
#    katla markdown README.idr build/ttc/*/README.ttm > README.md
#    katla html init                                       # Generate default HTML config
#    katla html --config my-config.dhall src/MyMod.idr build/ttc/*/MyMod.ttm
#    katla macro snippet.idr                              # Inline LaTeX macro
#    katla macro inline tiny.idr                          # Inline code macro
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  similar dependently-typed language tools):
#    - idris2 (IN CORPUS via _idris2 — the Idris2 compiler/
#      REPL; previously documented but Idris2 language not
#      formally entered into taxonomy until R452)
#    - pack (IN CORPUS via _pack — DIFFERENT `pack` tool;
#      stefan-hoeck/idris2-pack 151 stars is the Idris2 package
#      manager but binary name `pack` conflicts with existing
#      corpus entry)
#    - idris2-lsp (idris-community/idris2-lsp — Idris2
#      Language Server Protocol; FUTURE candidate)
#    - agda (Agda dependently-typed proof assistant — IN
#      CORPUS via _agda)
#    - coq (Coq proof assistant — IN CORPUS + STOCK)
#    - lean (Lean theorem prover — IN CORPUS + STOCK; uses
#      different CLI library)
#    - idris-community/katla repo itself (21 stars library /
#      tool)
# ============================================================================

_katla() {
  local context state state_descr line
  typeset -A opt_args
  local curcontext="$curcontext"

  _arguments -C \
    '--config[preamble configuration file in Dhall format]:file:_files -g "*.dhall"' \
    '1: :->subcommand' \
    '*:: :->args' && return

  case "$state" in
    subcommand)
      local -a subcmds
      subcmds=(
        'macro:generate LaTeX macro for typesetting code snippets'
        'markdown:Markdown backend (fenced code blocks with class markup)'
        'literate:literate LaTeX backend (complete .tex file for papers)'
        'html:HTML backend (span-class markup for CSS styling)'
        'pandoc:Pandoc backend'
      )
      _describe -t subcommands 'katla backend' subcmds
      ;;
    args)
      case "${words[1]}" in
        macro)
          if [[ "${words[2]}" == "inline" ]]; then
            _files -g "*.idr"
          else
            local -a macrosub
            macrosub=('inline:generate macro for inline code snippets')
            _describe -t subcommands 'macro subcommand' macrosub
            _files -g "*.idr"
          fi
          ;;
        markdown|literate|html|pandoc)
          if [[ "${words[2]}" == "init" ]]; then
            return
          fi
          local -a initsub
          initsub=('init:generate default preamble config (Dhall)')
          _describe -t subcommands 'subcommand' initsub
          _arguments -s -S \
            '--config[preamble configuration file in Dhall format]:file:_files -g "*.dhall"' \
            '*:file:_files -g "*.(idr|ttm)"'
          ;;
      esac
      ;;
  esac
}

_katla "$@"
