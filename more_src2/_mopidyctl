#compdef mopidyctl
# Documentation: https://github.com/mopidy/mopidy/blob/main/extra/mopidyctl/mopidyctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mopidyctl is a thin sh wrapper around `mopidy --config ... $@` for service use.
# Accepts the same options as mopidy itself; delegate to that completion.
local curcontext="$curcontext" state line ret=1

_arguments -C \
  '*--config=[config file path; repeat or colon-separate]:path:_files' \
  '*'{-o+,--option=}'[override config SECTION/KEY=VALUE]:override' \
  '(-q --quiet)'{-q,--quiet}'[decrease amount of output to minimum]' \
  '*'{-v,--verbose}'[increase verbosity; repeat up to four times]' \
  ':subcommand:(config deps)' \
  '*::arg:->args' && ret=0

return ret
