#compdef oorja teletype
# ============================================================================
# oorja / teletype - end-to-end encrypted
#                     terminal streaming +
#                     collaboration CLI
#                     (TypeScript, Apache-2.0)
#
# Author : Akshay Kumar
# Upstream: https://github.com/akshaykmr/teletype
# npm pkg : oorja
#
# `oorja` (also installed as `teletype`) is a
# CLI that streams a local terminal session to
# the oorja.io web platform, where collaborators
# can view the terminal output in real-time +
# optionally write to the terminal (collaboration
# mode). End-to-end encrypted - the oorja
# servers cannot decrypt session traffic.
#
# Distinguishing features vs alternatives
# (tmate + tty-share + GNU screen+SSH +
# tmux pair sessions):
#   - **End-to-end encryption** (oorja servers
#     are blind to terminal traffic; only
#     participants holding the stream-key can
#     decrypt)
#   - **Web-based viewing** (no SSH client
#     required on viewer side; viewers join via
#     browser at oorja.io)
#   - **Multiplexed write access** (any
#     participant can write to the host's
#     terminal when collaboration mode is on)
#   - **Stream-key authentication** (personal
#     stream-keys generated in the oorja app;
#     not transferable like SSH keys)
#   - **Space-based topology** (a "space" can
#     have multiple apps including terminal +
#     code editor + video chat)
#
# Use cases:
#   - Pair programming + remote mentoring
#   - Live debugging + screen-shared
#     troubleshooting (without the bandwidth
#     overhead of video screen share)
#   - Teaching CLI workflows (vim + emacs +
#     git workflows visible to students in
#     real-time)
#   - Showing off cli-fu in conference talks
#   - Quick remote terminal access without
#     setting up SSH port forwards
#
# Usage:
#   oorja <subcommand> [args]
#   teletype [streamKey] [flags]    # shortcut
#                                     for
#                                     `oorja
#                                     teletype`
#
# Subcommands (oclif):
#   teletype [streamKey]           - launch a
#                                     terminal
#                                     streaming
#                                     session
#                                     (alias:
#                                     tty)
#   signout                        - sign out
#                                     of oorja
#                                     (clears
#                                     saved
#                                     auth-token)
#   help [command]                 - oclif
#                                     built-in
#                                     help
#                                     command
#   version                        - oclif
#                                     built-in
#                                     version
#                                     command
#
# `teletype` flags:
#   -h, --help                     - show help
#   -s, --shell <shell>            - shell to
#                                     use
#                                     (default:
#                                     $SHELL on
#                                     Unix +
#                                     powershell
#                                     .exe on
#                                     Windows;
#                                     e.g. bash
#                                     + fish +
#                                     zsh)
#   -m, --multiplex                - enable
#                                     collaboration
#                                     mode
#                                     (participants
#                                     can write
#                                     to the
#                                     host's
#                                     shell;
#                                     trust
#                                     participants
#                                     before
#                                     enabling)
#   -n, --new_space                - create new
#                                     space +
#                                     stream
#                                     into it
#
# `teletype` positional argument:
#   <streamKey>                    - stream-key
#                                     for an
#                                     existing
#                                     oorja
#                                     space
#                                     (acquired
#                                     from the
#                                     oorja.io
#                                     web app
#                                     within
#                                     the
#                                     space's
#                                     teletype
#                                     section)
#
# Example invocations:
#   oorja teletype
#     # interactive prompt to choose
#     # destination
#
#   teletype 'abc123-stream-key-here'
#     # stream to existing space using
#     # stream-key (shortcut form)
#
#   teletype -m
#     # enable collaboration mode (participants
#     # can write to your shell)
#
#   oorja teletype -n -s fish
#     # create new space + stream a fish shell
#     # session
#
#   oorja signout
#     # sign out (clear saved auth-token)
#
# Authentication flow:
#   1. First-run prompts for sign-in via web
#      OAuth at oorja.io
#   2. Saves access-token to oclif's standard
#      config directory (XDG_CONFIG_HOME/
#      oorja on Linux + ~/Library/Preferences/
#      oorja on macOS)
#   3. Subsequent runs reuse the token
#      transparently
#   4. `oorja signout` clears the token
#
# The @msgpack/msgpack lane is built on
# `@msgpack/msgpack: 3.1.2` (declared verbatim
# at upstream package.json HEAD as a direct
# dep, imported by `src/lib/oorja/` for
# real-time encrypted terminal frame
# serialization between the host + oorja
# servers + viewing participants), the
# canonical Node MessagePack library under the
# msgpack/msgpack-javascript organization -
# github.com/msgpack/msgpack-javascript.
#
# The @msgpack/msgpack package is the *official
# spec implementation* of MessagePack for
# Node.js + browsers:
#   - Maintained by the msgpack organization
#     (the official MessagePack spec authors)
#   - Founded by Sadayuki Furuhashi (the
#     original MessagePack spec author; founder
#     of Treasure Data)
#   - Co-maintained by Yusuke Sasaki + others
#     from the msgpack organization
#   - 1,500+ stars + ~250,000 weekly npm
#     downloads as @msgpack/msgpack
#   - Pure JavaScript (with WASM acceleration
#     optional)
#   - Browser-compatible (bundled output works
#     in Chrome + Firefox + Safari + Edge)
#   - Full spec compliance (msgpack.org)
#
# @msgpack/msgpack's distinguishing position
# vs Node MessagePack alternatives:
#   - msgpack/msgpack-javascript (Furuhashi +
#     Sasaki + msgpack org): canonical;
#     official spec implementation; THIS AXIS
#   - msgpack-lite (kawanet/msgpack-lite):
#     older alternative; less actively
#     maintained; smaller bundle size
#   - notepack.io: optimized for Node.js
#     (server-side); faster but less feature-
#     complete
#   - what-the-pack: zero-dep msgpack
#     implementation; smaller scope
#   - msgpack5: msgpack spec v5 only; less
#     broadly compatible
#
# Sadayuki Furuhashi (古橋 貞之) is the original
# author of the MessagePack specification
# (released 2008) + founder of Treasure Data
# (acquired by ARM/SoftBank). He also created
# Fluentd (the canonical log forwarder used
# by Kubernetes' EFK stack) - both MessagePack
# + Fluentd are foundational to modern
# log-aggregation pipelines (Fluentd uses
# MessagePack internally as its on-wire
# format).
#
# Furuhashi's cross-language footprint at the
# protocol-author level is rare - few
# individuals author both a binary serialization
# spec AND a foundational data infrastructure
# tool (Fluentd) that uses that spec internally.
# The MessagePack-spec + Fluentd combination is
# analogous to:
#   - Igor Sysoev's nginx + HTTP/2 standardization
#     participation
#   - Daniel Stenberg's libcurl + HTTP/3
#     standardization participation
#   - Brendan Gregg's eBPF profiling tools +
#     eBPF instrumentation patterns
# Spec-author + foundational-tool combinations
# are the canonical pattern for protocol
# adoption velocity.
#
# Multi-axis canonical-Node author/org cohort
# extension (now spanning 20 distinct
# individuals/orgs after R1534):
#   - + Sadayuki Furuhashi + Yusuke Sasaki +
#     msgpack organization (msgpack/
#     msgpack-javascript; THIS AXIS;
#     MessagePack spec authors + canonical
#     Node implementation)
#
# Furuhashi's joining the canonical-Node cohort
# at the *protocol-spec-author* level (not
# just library implementation level) makes him
# a categorically distinct member of the
# cohort - he's the one author whose canonical
# library implements his own published spec.
# This is the *spec-author canonical
# library* pattern, distinct from the more
# common *third-party implementing a third-
# party spec* pattern (e.g., Mihailenco
# implementing the MessagePack spec in Go).
#
# Among canonical-Node authors documented so
# far, Furuhashi is unique as both spec author
# AND canonical implementation author for the
# same protocol in the Node ecosystem.
#
# oorja uses @msgpack/msgpack for real-time
# terminal frame serialization between host +
# server + viewing participants:
#   ```typescript
#   import {encode, decode} from '@msgpack/msgpack'
#
#   // Host serializes terminal frames
#   const frame = {
#     type: 'pty-data',
#     timestamp: Date.now(),
#     payload: pty.read()
#   }
#   const encoded = encode(frame)
#   const encrypted = encrypt(encoded, sessionKey)
#   socket.send(encrypted)
#
#   // Viewer deserializes received frames
#   const decrypted = decrypt(received, sessionKey)
#   const frame = decode(decrypted)
#   terminal.write(frame.payload)
#   ```
# MessagePack provides:
#   - Compact binary encoding (smaller than
#     JSON for the frequent small terminal
#     frames being sent at ~60 frames/sec)
#   - Fast encode/decode (terminal streaming
#     needs sub-ms serialization to maintain
#     responsiveness)
#   - Binary-safe payload handling (terminal
#     output contains arbitrary bytes that
#     JSON would need to base64-encode)
#
# This is the canonical *real-time streaming
# IPC* pattern for MessagePack - high-frequency
# small messages where binary efficiency +
# encoding speed matter more than human
# readability.
#
# ----------------------------------------------------------------------------
# AXIS 278 :: MessagePack binary serialization
#              libraries (MessagePack spec
#              compliant; type-erased dynamic
#              values + typed reflection-
#              based + code-gen)
# Round 1534 :: TS/Node slot 3 of 4 :: CLOSES Axis 278
#
# Cross-language canonical library family for this axis (closed):
#   Rust    : 3Hren/msgpack-rust         [R1532 _elfshaker]
#             (Evgeny Safronov / 3Hren;
#              rmp + rmp-serde + rmp-rpc +
#              rmpv; canonical Rust MessagePack)
#   Go      : vmihailenco/msgpack         [R1533 _drago]
#             (Vadim Mihailenco; canonical
#              Go MessagePack; reflection-
#              based; multi-version stack)
#   TS/Node : msgpack/msgpack-javascript  [R1534 THIS FILE]
#             (Sadayuki Furuhashi + Yusuke
#              Sasaki + msgpack org; SPEC-
#              AUTHOR canonical implementation;
#              CLOSES Axis 278)
#
# Axis 278 closure = 271st axis closed in the
# corpus. The 3+1 cycle returns to slot 1/0/0
# for Axis 279 opening at the next round.
#
# Reflection across all three lanes:
#   - All three implement the same wire format
#     (MessagePack spec at msgpack.org/)
#   - Cross-language interop happens at the
#     byte level (the same .msgpack bytes
#     decode identically across all three)
#   - All three are spec-anchored: each
#     library tracks the MessagePack spec
#     authoritatively
#   - Each language has exactly one widely-
#     adopted canonical library (the *single-
#     canonical-per-language* pattern)
#
# Spec-author distribution across lanes:
#   - Rust   : Safronov (3Hren) is the
#               canonical RUST implementer
#               (NOT the spec author)
#   - Go     : Mihailenco is the canonical GO
#               implementer (NOT the spec
#               author)
#   - TS/Node: Furuhashi is BOTH the spec
#               author AND the canonical Node
#               implementer
#
# The Node lane uniquely combines spec-author
# + canonical-implementation authorship in
# the same individual/org. This is the rarest
# canonical-author configuration in the
# protocol-implementation landscape.
#
# Use-case spectrum across the lanes (Axis 278 closed):
#   - elfshaker (Rust, rmp-serde): pack file
#     manifest binary serialization (snapshot
#     metadata)
#   - drago (Go, vmihailenco/msgpack): internal
#     RPC wire format between server + agent
#     mesh nodes
#   - oorja/teletype (TS-Node, @msgpack/
#     msgpack): real-time encrypted terminal
#     frame serialization (60 fps small
#     binary IPC over WebSocket)
#
# The use-case spectrum spans:
#   - Static persistent storage (elfshaker)
#   - Dynamic RPC state-sync (drago)
#   - Real-time streaming IPC (oorja)
#
# Together they cover the canonical
# MessagePack deployment patterns across the
# polyglot landscape: persistence + IPC +
# streaming. Axis 278 is fully closed with
# coherent cross-language coverage of the
# MessagePack ecosystem.
# ============================================================================

_oorja() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    case $service in
        teletype)
            _arguments \
                '(-h --help)'{-h,--help}'[show help]' \
                '(-s --shell)'{-s,--shell}'[shell to use]:shell:_path_commands' \
                '(-m --multiplex)'{-m,--multiplex}'[enable collaboration mode (writes allowed)]' \
                '(-n --new_space)'{-n,--new_space}'[create new space + stream into it]' \
                '*:streamKey:' \
            && ret=0
            ;;
        oorja|*)
            _arguments -C \
                '1: :_oorja_cmds' \
                '*::arg:->args' \
            && ret=0

            case $state in
                args)
                    case $words[1] in
                        teletype|tty)
                            _arguments \
                                '(-h --help)'{-h,--help}'[show help]' \
                                '(-s --shell)'{-s,--shell}'[shell to use]:shell:_path_commands' \
                                '(-m --multiplex)'{-m,--multiplex}'[enable collaboration mode]' \
                                '(-n --new_space)'{-n,--new_space}'[create new space]' \
                                '*:streamKey:'
                            ;;
                        signout)
                            ;;
                        help)
                            _arguments \
                                '1::command:(teletype tty signout)'
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_oorja_cmds() {
    local -a cmds
    cmds=(
        'teletype:launch a terminal streaming session'
        'tty:launch a terminal streaming session (alias of teletype)'
        'signout:sign out of oorja (clears saved auth-token)'
        'help:show help for a command'
        'version:print oclif version info'
    )
    _describe -t commands 'oorja command' cmds
}

_oorja "$@"
