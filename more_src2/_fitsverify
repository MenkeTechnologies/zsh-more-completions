#compdef fitsverify ftverify
# _fitsverify — verify FITS file conformance to the standard (HEASARC/cfitsio)
# upstream: https://github.com/HEASARC/cfitsio
# Flags from utilities/fitsverify.c (usage in main).

_fitsverify() {
    _arguments \
        '(- *)-h[show help]' \
        '-H[test ESO HIERARCH keywords]' \
        '-l[list all header keywords]' \
        '-q[quiet (one-line pass/fail per file)]' \
        '-e[only report errors, ignore warnings]' \
        '*:FITS file or @filelist:_files -g "*.(fits|fit|fts)"'
}

_fitsverify "$@"
