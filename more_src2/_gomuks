# Zsh completion for gomuks - terminal Matrix client

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '--desktop[backend is running as a subprocess in the desktop app]'
