#compdef fooocus fooocus-cli
# _fooocus — lllyasviel Fooocus simplified SDXL image generator CLI alias (lllyasviel, Python); custom argparse
# upstream: https://github.com/lllyasviel/Fooocus

_fooocus() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--listen=+[listen address]:host:_hosts' \
        '--port=+[port]:port:' \
        '--share[share via gradio]' \
        '--external-working-path=+[external working path]:dir:_files -/' \
        '--temp-path=+[temp path]:dir:_files -/' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '--persistent[persistent storage]' \
        '--always-no-vram[always no VRAM]' \
        '--always-low-vram[always low VRAM]' \
        '--always-normal-vram[always normal VRAM]' \
        '--always-high-vram[always high VRAM]' \
        '--always-gpu[always GPU]' \
        '--always-cpu[always CPU]' \
        '--always-offload-from-vram[always offload from VRAM]' \
        '--cuda-device=+[CUDA device]:n:' \
        '--cuda-malloc[CUDA malloc]' \
        '--disable-cuda-malloc[disable CUDA malloc]' \
        '--directml=+[DirectML]:n:' \
        '--pytorch-deterministic[deterministic]' \
        '--all-in-fp32[all in fp32]' \
        '--all-in-fp16[all in fp16]' \
        '--unet-in-bf16[unet in bf16]' \
        '--unet-in-fp16[unet in fp16]' \
        '--unet-in-fp8-e4m3fn[unet in fp8 e4m3fn]' \
        '--unet-in-fp8-e5m2[unet in fp8 e5m2]' \
        '--vae-in-fp16[vae in fp16]' \
        '--vae-in-fp32[vae in fp32]' \
        '--vae-in-cpu[vae in CPU]' \
        '--clip-in-fp16[clip in fp16]' \
        '--clip-in-fp32[clip in fp32]' \
        '--clip-in-fp8-e4m3fn[clip in fp8 e4m3fn]' \
        '--attention-split[split attention]' \
        '--attention-quad[quad attention]' \
        '--attention-pytorch[pytorch attention]' \
        '--disable-xformers[disable xformers]' \
        '--auto-launch[auto launch browser]' \
        '--disable-auto-launch[disable auto launch]' \
        '--disable-preset-download[disable preset download]' \
        '--disable-image-log[disable image log]' \
        '--disable-analytics[disable analytics]' \
        '--disable-server-info[disable server info]' \
        '--enable-describe-uov-image[enable describe uov image]' \
        '--language=+[language]:l:(default cn jp kr ru de fr es ar)' \
        '--preset=+[preset]:p:(default initial anime realistic lcm playground_v2.5 sai turbo lightning)' \
        '--theme=+[theme]:t:(dark light)' \
        '--in-browser[in browser]' \
        '--debug-mode[debug mode]' \
        '*:arg:'
}

_fooocus "$@"
