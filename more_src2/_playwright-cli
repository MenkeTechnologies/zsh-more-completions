#compdef playwright-cli
# Documentation: https://playwright.dev/docs/next/getting-started-cli
# Reference accessed: 2026-05-23
# Verified: @playwright/cli command list from Playwright docs.

# Zsh completion for playwright-cli - Playwright CLI for coding agents

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'open:open browser or URL'
  'goto:navigate to URL'
  'close:close page'
  'click:click element'
  'dblclick:double click'
  'fill:fill field'
  'type:type text'
  'select:select option'
  'check:check checkbox'
  'uncheck:uncheck checkbox'
  'hover:hover element'
  'drag:drag and drop'
  'upload:upload files'
  'snapshot:capture snapshot'
  'screenshot:screenshot'
  'pdf:save PDF'
  'eval:evaluate JS'
  'go-back:history back'
  'go-forward:history forward'
  'reload:reload page'
  'press:press key'
  'tab-list:list tabs'
  'tab-new:new tab'
  'tab-select:select tab'
  'tab-close:close tab'
  'install:init workspace'
  'install-browser:install browser'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'playwright-cli command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (open|goto) _arguments ':url:_urls' && ret=0 ;;
      (click|dblclick|fill|hover|check|uncheck|select)
        _arguments ':ref:' && ret=0 ;;
      (snapshot)
        _arguments '--filename[snapshot file]:file:_files' '--depth[max depth]:n:' && ret=0
        ;;
      (screenshot)
        _arguments '--filename[image file]:file:_files' && ret=0
        ;;
      (tab-select|tab-close)
        _arguments ':index:' && ret=0
        ;;
      (*)
        _arguments '*::args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
