#compdef kli
# _kli — ksctl multi-cloud Kubernetes CLI (ksctl/cli)
# upstream: https://github.com/ksctl/cli
# Subcommands from cmd/handler.go (cobra).

_kli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-t --toggle)'{-t,--toggle}'[toggle test flag]' \
        '--debug[run in debug mode]' \
        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_kli_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                cluster)
                    _arguments '1:cluster subcommand:(create delete list get connect scale-up scale-down summary addons)'
                    ;;
                configure)
                    _arguments '1:configure subcommand:(storage cloud telemetry)'
                    ;;
                addons)
                    _arguments '1:addons subcommand:(enable disable)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kli_commands] )) ||
_kli_commands() {
    local -a commands
    commands=(
        'cluster:cluster operations (create / delete / list / scale / connect)'
        'configure:configure storage / cloud / telemetry'
        'version:print kli version'
        'self-update:upgrade kli to the latest release'
        'completion:generate shell completion script'
    )
    _describe -t commands 'kli command' commands
}

_kli "$@"
