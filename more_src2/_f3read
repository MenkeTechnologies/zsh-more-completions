#compdef f3read
# Documentation: https://github.com/AltraMayor/f3/blob/master/src/f3read.c
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-s+,--start-at=}'[first file number]:num:' \
  {-e+,--end-at=}'[last file number]:num:' \
  {-r+,--max-read-rate=}'[max read rate KB/s]:rate:' \
  {-p+,--show-progress=}'[show progress (1/0)]:num:(0 1)' \
  '*:directory:_files -/' && ret=0

return ret
