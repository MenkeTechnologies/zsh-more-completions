#compdef edje_decc
# Documentation: https://github.com/Enlightenment/efl/blob/master/src/bin/edje/edje_decc.c
# Reference accessed: 2026-05-17
# Verified: upstream source at the URL above.

# edje_decc: decompile .edj into source .edc
local curcontext="$curcontext" ret=1
_arguments -C \
  '-main-out[output file name for decompiled EDC source]:file:_files' \
  '-no-build-sh[do not generate build script]' \
  '-current-dir[output files to the current directory]' \
  '-output[output directory]:dir:_files -/' \
  '*:file:_files -g "*.edj"' && ret=0
return ret
