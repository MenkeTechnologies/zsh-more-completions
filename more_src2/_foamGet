#compdef foamGet
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamGet — copy a dictionary file from $FOAM_ETC/caseDicts/ into a case.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-case -c)'{-case,-c}'[case directory (default cwd)]:dir:_directories' \
    '(-ext -e)'{-ext,-e}'[file extension (e.g. cfg for ".cfg")]:ext:' \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-no-ext -n)'{-no-ext,-n}'[file without extension]' \
    '(-target -t)'{-target,-t}'[target directory (default system)]:dir:_directories' \
    '(-region -r)'{-region,-r}'[alternative mesh region]:name:' \
    '*:dict name:' \
    && ret=0

return ret
