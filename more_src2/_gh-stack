#compdef gh-stack gh-s gh-token gh-f
# Documentation: upstream READMEs at github.com/{github/gh-stack,gennaro-tedesco/gh-s,Link-/gh-token,gennaro-tedesco/gh-f}
# Reference accessed: 2026-05-30
# gh-extension family round 3. Companions to the previous rounds 158/159
# multi-stems and the pre-existing _gh-poi/_gh-notify/_gh-dash/etc files.
# Sourced from the github.com/topics/gh-extension star-sorted listing.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-stack)
    # github/gh-stack — stacked-PR management (private-preview at this date).
    # Per upstream README four command categories with many subcommands and
    # only a handful of well-documented flags.
    local -a _subcmds
    _subcmds=(
      'init:initialize a new stack'
      'add:add a branch to the stack'
      'modify:modify a stack entry'
      'submit:submit the stack as linked PRs'
      'up:navigate up the stack'
      'down:navigate down the stack'
      'top:jump to top of stack'
      'bottom:jump to bottom of stack'
      'trunk:jump to trunk'
      'switch:switch between stacks'
      'rebase:rebase the stack'
      'sync:sync with upstream'
      'push:push the stack'
      'view:show stack structure'
      'checkout:checkout a stack entry'
      'link:link existing branches into a stack'
      'unstack:remove a branch from the stack'
      'feedback:open feedback form'
      'alias:set up shell aliases'
    )
    _arguments -C -s -S \
      '--auto[skip PR title prompts during submit]' \
      '--force-with-lease[safe force-push for rebased branches]' \
      '--numbered[auto-increment branch names (feat/01, feat/02 ...)]' \
      '(--downstack --upstack)--downstack[rebase only down-stack portion]' \
      '(--downstack --upstack)--upstack[rebase only up-stack portion]' \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-stack subcommand' _subcmds && ret=0
        ;;
    esac
    ;;

  gh-s)
    # gennaro-tedesco/gh-s — interactive repository search via fzf.
    _arguments -s -S \
      '(-l --lang)-l+[filter by programming language]:language:' \
      '(-l --lang)--lang=[filter by programming language]:language:' \
      '(-d --desc)-d+[search within repository descriptions]:description:' \
      '(-d --desc)--desc=[search within repository descriptions]:description:' \
      '(-u --user)-u+[restrict to a specific user/org]:user:' \
      '(-u --user)--user=[restrict to a specific user/org]:user:' \
      '(-t --topic)-t+[filter by topic]:topic:' \
      '(-t --topic)--topic=[filter by topic]:topic:' \
      '(-c --colour)-c+[prompt colour]:colour:' \
      '(-c --colour)--colour=[prompt colour]:colour:' \
      '(-L --limit)-L+[result count limit (default 20)]:N:' \
      '(-L --limit)--limit=[result count limit (default 20)]:N:' \
      '(-E --empty)-E[search by flags only (no name prompt)]' \
      '(-E --empty)--empty[search by flags only (no name prompt)]' \
      '1:search term:' \
      && ret=0
    ;;

  gh-token)
    # Link-/gh-token — generate short-lived GitHub App installation tokens.
    local -a _subcmds
    _subcmds=(
      'generate:create a new installation token'
      'revoke:invalidate an existing token'
      'installations:list GitHub App installations'
      'help:show command documentation'
    )
    _arguments -C -s -S \
      '(-): :->subcmd' \
      '(-)*:: :->subcmd_args' \
      && ret=0
    case $state in
      subcmd)
        _describe -t commands 'gh-token subcommand' _subcmds && ret=0
        ;;
      subcmd_args)
        case $words[1] in
          generate)
            _arguments \
              '(--key --base64-key)--key=[private key file path]:file:_files -g "*.pem"' \
              '(--key --base64-key)--base64-key=[base64-encoded private key]:base64:' \
              '--app-id=[GitHub App ID]:id:' \
              '--installation-id=[target installation ID]:id:' \
              '--hostname=[GitHub Enterprise Server hostname]:host:' && ret=0
            ;;
          revoke)
            _arguments \
              '1:installation token:' && ret=0
            ;;
        esac
        ;;
    esac
    ;;

  gh-f)
    # gennaro-tedesco/gh-f — fzf-driven multi-subcommand GitHub workflow tool.
    # Each subcommand has both a short alias (-a, -p, -b ...) and a long name
    # (adds, prs, branches ...). Per upstream, running `gh f` alone prints the
    # help page.
    local -a _subcmds
    _subcmds=(
      'adds:stage files with diff preview'
      'prs:view, diff, and checkout pull requests'
      'branches:checkout and diff branches'
      'logs:navigate commit history'
      'tags:checkout and diff version tags'
      'releases:manage release tags'
      'runs:filter and search workflow run logs'
      'greps:search revision history with regex'
      'search:query issues across repositories'
      'myissue:find your own opened issues'
      'pick:cherry-pick files between branches'
    )
    _arguments -s -S \
      '(-a -p -b -l -t -R -r -g -s -m -k)-a[stage files (alias for adds)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-p[pull requests (alias for prs)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-b[branches (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-l[logs (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-t[tags (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-R[releases (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-r[runs (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-g[greps (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-s[search (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-m[myissue (alias)]' \
      '(-a -p -b -l -t -R -r -g -s -m -k)-k[pick (alias)]' \
      '1: :->cmd' \
      && ret=0
    case $state in
      cmd)
        _describe -t commands 'gh-f command' _subcmds && ret=0
        ;;
    esac
    ;;

esac

return ret
