#compdef flare
# Documentation: https://github.com/clintbellanger/flare-engine/blob/master/src/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/main.cpp argv loop (lines 343-410) + built-in --help printout
# Removed from prior file: --mod-paths (not in source), --debug (real is
# --debug-event), --render-device (real is --renderer; no enum values).

# Flare: free single-player 2D action RPG
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[print help and quit]' \
  '(- *)--version[print release version and quit]' \
  '--data-path=[exact mod-data path]:dir:_files -/' \
  '--debug-event[print verbose hardware input info]' \
  '--renderer=[rendering backend (default sdl)]:renderer:' \
  '--no-audio[disable sound effects and music]' \
  '--mods=[comma-separated mod list]:list:' \
  '--load-slot=[load save slot index]:slot:' \
  '--load-script=[execute mod-relative script on load]:script:' \
  '*::extra args:_files' && ret=0
return ret
