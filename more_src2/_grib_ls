#compdef grib_ls
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_ls
# Source: ecmwf/eccodes tools/grib_ls.dox — list keys/values from GRIB files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p+[keys to print (key[:s/d/i],...)]:keys:_default' \
    '-F+[C-style float format]:format:_default' \
    '-P+[append keys to default print list]:keys:_default' \
    '-w+[where clause filter (key=value or key!=value)]:filter:_default' \
    '-j[json output]' \
    '-B+[order-by directive]:order:_default' \
    '-l+[value close to a latitude,longitude[,mode,file]]:latlon:_default' \
    '-s+[key=value pairs to set]:kvs:_default' \
    '-i+[data value at given index]:index:_default' \
    '-n+[print all keys in given namespace]:namespace:_default' \
    '-m[print MARS keys]' \
    '(- *)-V[show version]' \
    '-W+[minimum column width (default 10)]:n:_default' \
    '-M[turn off multi-field support]' \
    '-g[copy GTS header]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '-X+[input file offset in bytes]:offset:_default' \
    '-x[fast parsing (headers only)]' \
    '*:grib file:_files' \
    && ret=0

return ret
