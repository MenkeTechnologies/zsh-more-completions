#compdef epsffit
# Documentation: epsffit usage (psutils 1.23)
# Source: fit an EPS file into the specified bounding box.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[center figure within bounding box]' \
    '-r[rotate figure 90 degrees]' \
    '-a[adjust bounding box; preserve aspect ratio]' \
    '-m[maximise size, ignore aspect ratio]' \
    '-s[show bounding box]' \
    '1:LLX (lower-left x):' \
    '2:LLY (lower-left y):' \
    '3:URX (upper-right x):' \
    '4:URY (upper-right y):' \
    '5:input eps:_files -g "*.eps"' \
    '6:output eps:_files -g "*.eps"' \
    && ret=0

return ret
