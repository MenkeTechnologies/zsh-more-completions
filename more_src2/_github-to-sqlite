#compdef github-to-sqlite

_github-to-sqlite() {
    local curcontext="$curcontext" state line ret=1

    _arguments -C \
        '(- *)--help[show help message and exit]' \
        '(- *)--version[show version and exit]' \
        '1:subcommand:->subcmd' \
        '*::args:->args' && ret=0

    case $state in
        subcmd)
            local -a subcmds=(
                'repos:save repository metadata'
                'starred:save starred repositories'
                'issues:save issues for a repository'
                'pull-requests:save pull requests for a repository'
                'comments:save comments for a repository'
                'commits:save commits for a repository'
                'releases:save releases for a repository'
                'contributors:save contributors for a repository'
                'stargazers:save stargazers for a repository'
                'tags:save tags for a repository'
                'workflows:save GitHub Actions workflows'
                'runs:save GitHub Actions workflow runs'
            )
            _describe -t commands 'github-to-sqlite subcommand' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                repos|starred|issues|pull-requests|comments|commits|releases|contributors|stargazers|tags|workflows|runs)
                    _arguments \
                        '--auth=[GitHub auth token]:token:' \
                        '(-d --db)'{-d,--db}'[SQLite database file]:database:_files' \
                        '--repo=[GitHub repository (owner/repo)]:repository:' \
                        '--user=[GitHub username]:username:' \
                        '--org=[GitHub organization]:organization:' \
                        '--since=[fetch data since date]:date:' \
                        '--until=[fetch data until date]:date:' \
                        '*:database file:_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_github-to-sqlite "$@"
