#compdef nginx-ingress-controller
# _nginx-ingress-controller — Kubernetes Ingress NGINX controller daemon
# upstream: https://github.com/kubernetes/ingress-nginx
# Flags from pkg/flags/flags.go on tip.

_nginx-ingress-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--apiserver-host=[Kubernetes API server URL]:url:_urls' \
        '--certificate-authority=[CA cert file]:file:_files' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--default-backend-service=[default backend Service (ns/name)]:svc:' \
        '--ingress-class=[IngressClass annotation value to watch]:class:' \
        '--controller-class=[IngressClass.spec.controller string]:name:' \
        '--watch-ingress-without-class=[also watch Ingresses with no IngressClass]:bool:(true false)' \
        '--ingress-class-by-name=[match IngressClass by name instead of controller]:bool:(true false)' \
        '--configmap=[ConfigMap with controller settings (ns/name)]:cm:' \
        '--publish-service=[Service to populate Ingress status from (ns/name)]:svc:' \
        '--tcp-services-configmap=[ConfigMap with TCP services (ns/name)]:cm:' \
        '--udp-services-configmap=[ConfigMap with UDP services (ns/name)]:cm:' \
        '--sync-period=[full resync period]:dur:' \
        '--watch-namespace=[restrict watch to a single namespace]:ns:' \
        '--watch-namespace-selector=[namespace label selector to watch]:selector:' \
        '--profiling=[enable pprof endpoint]:bool:(true false)' \
        '--default-ssl-certificate=[default SSL cert Secret (ns/name)]:secret:' \
        '--health-check-path=[health-check URL path]:path:' \
        '--health-check-timeout=[health-check probe timeout (s)]:s:' \
        '--update-status=[update Ingress status]:bool:(true false)' \
        '--election-id=[leader-election lease name]:id:' \
        '--election-ttl=[leader-election lease TTL]:dur:' \
        '--update-status-on-shutdown=[update Ingress status on shutdown]:bool:(true false)' \
        '--report-node-internal-ip-address=[use node internal IP for status reporting]:bool:(true false)' \
        '--version[show version and exit]' \
        '--enable-ssl-passthrough=[enable SSL passthrough handling]:bool:(true false)' \
        '--disable-leader-election=[disable leader election]:bool:(true false)' \
        '--disable-svc-external-name=[disable ExternalName Services]:bool:(true false)' \
        '--annotations-prefix=[Ingress annotation prefix]:prefix:' \
        '--enable-annotation-validation=[enable annotation validation]:bool:(true false)' \
        '--http-port=[HTTP listen port]:port:' \
        '--https-port=[HTTPS listen port]:port:' \
        '--healthz-port=[healthz listen port]:port:' \
        '--metrics-per-host=[expose metrics per host]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_nginx-ingress-controller "$@"
