#compdef mosml mosmlc mosmllex mosmlyac mosmltop
# Documentation: https://github.com/kfl/mosml/tree/master/man
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Moscow ML toolchain. Flags come from kfl/mosml manpages and mosmlyac main.c.
local curcontext="$curcontext" state line ret=1

case $service in
  (mosml|mosmltop)
    _arguments -C \
      '-conservative[conservative mode (warn on Modules extensions, default)]' \
      '-liberal[liberal mode (accept Modules extensions without warnings)]' \
      '-orthodox[orthodox mode (reject Modules extensions)]' \
      '-I+[directory to search for interface, bytecode, source]:dir:_files -/' \
      '-imptypes[distinguish imperative and applicative type variables]' \
      '-P+[library units open at compile-time]:set:(default sml90 nj93 full none)' \
      '-quietdec[suppress interactive prompts and responses]' \
      '-stdlib+[standard library directory]:dir:_files -/' \
      '-valuepoly[enable value polymorphism (default)]' \
      '*: :_files -g "*.(sml|sig|ui|uo)"' && ret=0 ;;
  (mosmlc)
    _arguments -C \
      '-c[compile only, do not link]' \
      '-conservative[conservative mode (default)]' \
      '-liberal[liberal mode]' \
      '-orthodox[reject Modules extensions]' \
      '-files+[response file with filenames to link]:file:_files' \
      '-g[include exception name info / print inferred interfaces]' \
      '-I+[directory for compiled interface and implementation files]:dir:_files -/' \
      '-imptypes[distinguish imperative and applicative types]' \
      '-msgstyle+[error message format]:style:(msdev)' \
      '-noautolink[require explicit object file specification]' \
      '-noheader[output bytecode only, no executable header]' \
      '-o+[output filename (default a.out)]:file:_files' \
      '-P+[library units open at compile-time]:set:(default sml90 nj93 full none)' \
      '-q[enable quotation/antiquotation mechanism]' \
      '-quotation[enable quotation/antiquotation mechanism]' \
      '-standalone[create stand-alone executable]' \
      '-stdlib+[standard library directory]:dir:_files -/' \
      '-structure[compile subsequent source files in structure mode]' \
      '-toplevel[compile subsequent source files in toplevel mode]' \
      '-v[print version numbers of compiler passes]' \
      '-valuepoly[enable value polymorphism]' \
      '*: :_files -g "*.(sml|sig|ui|uo|c|o)"' && ret=0 ;;
  (mosmllex)
    _arguments -C \
      '*: :_files -g "*.lex"' && ret=0 ;;
  (mosmlyac)
    _arguments -C \
      '-v[generate parsing table description and conflict report]' \
      '-b+[name output files using prefix]:prefix' \
      '-s[short option processing variant]' \
      '*: :_files -g "*.grm"' && ret=0 ;;
esac

return ret
