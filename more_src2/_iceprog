#compdef iceprog
# Documentation: https://manpages.debian.org/testing/fpga-icestorm/iceprog.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iceprog: Project IceStorm flash/SRAM programmer for Lattice iCE40 FPGAs (via FTDI).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-d+[USB device string (d:bus/dev, i:vid:pid, s:vid:pid:serial)]:device:' \
  '-I+[FTDI interface]:iface:(A B C D)' \
  '-o+[flash offset in bytes]:offset:' \
  '-s[skip file size verification]' \
  '-S[program SRAM directly (no flash write)]' \
  '-b[bulk erase entire flash before writing]' \
  '-n[do not erase flash before writing]' \
  '-c[verify only (no write)]' \
  '-r[read entire flash to file]:file:_files' \
  '-R[read first 256kB from flash to file]:file:_files' \
  '-t[read flash ID sequence]' \
  '-v[verbose]' \
  '*:file:_files -g "*.bin"' && ret=0

return ret
