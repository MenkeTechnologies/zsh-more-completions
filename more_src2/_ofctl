#compdef ofctl
# Documentation: man ofctl(8)
# Source: netbsd/src usr.sbin/ofctl — display OpenPROM/OpenFirmware device tree (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[device file (default /dev/openprom or /dev/openfirm)]:device:_files' \
    '-l[dump partial tree from specified node]' \
    '-p[display node properties]' \
    '-r+[read from proplib file instead of device]:propfile:_files' \
    '-v[display full path name for each node]' \
    '-w+[write device tree to proplib file]:propfile:_files' \
    '1::node:_default' \
    && ret=0

return ret
