#compdef ovh-cli
# _ovh-cli — OVHcloud API CLI wrapper (OVHcloud, Python); thin REST CLI for OVHcloud APIs
# upstream: https://github.com/yadutaf/ovh-cli

_ovh-cli() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '--config+[config file]:file:_files' \
        '--endpoint+[API endpoint]:endpoint:(ovh-eu ovh-ca ovh-us soyoustart-eu soyoustart-ca kimsufi-eu kimsufi-ca)' \
        '--application-key+[application key]:str:' \
        '--application-secret+[application secret]:str:' \
        '--consumer-key+[consumer key]:str:' \
        '--list[list endpoints]' \
        '--list-detail[detailed list]' \
        '--describe[show schema]' \
        '--debug[debug]' \
        '*::path:'
}

_ovh-cli "$@"
