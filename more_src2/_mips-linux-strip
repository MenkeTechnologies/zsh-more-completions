#compdef mips-linux-strip mips-linux-gnu-strip mipsel-linux-gnu-strip mips64-linux-gnuabi64-strip mips64el-linux-gnuabi64-strip
# _mips-linux-strip — GNU binutils mips-linux-strip CLI cross-arch ELF symbol-stripping tool removing debug info DWARF symbol tables relocations notes from MIPS32 MIPS64 mips mipsel mips64 mips64el Linux binaries shared libraries object files keeping specific symbols only-keep-debug discarding all unneeded keep-section-symbols (GNU team, C); getopt
# upstream: https://www.gnu.org/software/binutils/

_mips-linux-strip() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-s[strip all]' \
        '--strip-all[strip all]' \
        '-S[strip debug]' \
        '--strip-debug[strip debug]' \
        '-g[strip debug]' \
        '-d[strip debug]' \
        '--strip-unneeded[strip unneeded]' \
        '--strip-dwo[strip .dwo sections]' \
        '-K+[keep symbol]:str:' \
        '--keep-symbol=+[symbol]:str:' \
        '-N+[strip symbol]:str:' \
        '--strip-symbol=+[symbol]:str:' \
        '-w[wildcards]' \
        '--wildcard[wildcards]' \
        '-x[discard all]' \
        '--discard-all[discard all]' \
        '-X[discard locals]' \
        '--discard-locals[discard locals]' \
        '-R+[section]:str:' \
        '--remove-section=+[section]:str:' \
        '--keep-section=+[section]:str:' \
        '--only-keep-debug[only keep debug sections]' \
        '-o+[output]:file:_files' \
        '--output-file=+[file]:file:_files' \
        '-I+[input format]:str:' \
        '--input-target=+[fmt]:str:' \
        '-O+[output format]:str:' \
        '--output-target=+[fmt]:str:' \
        '-p[preserve dates]' \
        '--preserve-dates[preserve dates]' \
        '*:file:_files'
}

_mips-linux-strip "$@"
