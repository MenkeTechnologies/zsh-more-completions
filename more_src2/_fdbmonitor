#compdef fdbmonitor
# Documentation: https://apple.github.io/foundationdb/configuration.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,-?,--help}'[show help]' \
  '--conffile=[config file]:file:_files' \
  '--lockfile=[lockfile path]:file:_files' \
  '--loggroup=[log group name]:name:' \
  '--daemonize[run as daemon]'
