#compdef pdflatexpicscale
# Documentation: pdflatexpicscale (TeX Live 2026) — Perl GD wrapper
# Source: TeX pdflatexpicscale — auto-scale pictures for pdflatex builds.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose]' \
    '-h[show help]' \
    '--version[show version]' \
    '--dryrun[do not write scaled images]' \
    '--basepath=[picture-source base path]:dir:_files -/' \
    '--scaledpath=[output scaled-pictures path]:dir:_files -/' \
    '--basedpi=[base DPI]:dpi:' \
    '--scaleddpi=[scaled DPI]:dpi:' \
    '*:LaTeX file:_files -g "*.tex"' \
    && ret=0

return ret
