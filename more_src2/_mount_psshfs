#compdef mount_psshfs
# Documentation: man mount_psshfs(8)
# Source: netbsd/src usr.sbin/puffs/mount_psshfs — mount via ssh sftp (C, puffs).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[number of connections (2 separates data from directory ops)]:nconnect:(1 2)' \
    '-e[make filesystem NFS-exportable]' \
    '-F+[SSH configuration file]:configfile:_files' \
    '-g+[map remote gid to file server effective gid]:manglegid:_default' \
    '-o+[mount and puffs options]:options:_default' \
    '-O+[pass option directly to ssh]:sshopt=value:_default' \
    '-p[attempt reconnection on connection failure]' \
    '-r+[max outstanding read requests per node]:max_reads:_default' \
    '-s[stay in foreground]' \
    '-t+[cache timeout seconds (0=never, -1=forever)]:timeout:_default' \
    '-u+[map remote uid to file server effective uid]:mangleuid:_default' \
    '1:user@host[\:path]:_user_at_host' \
    '2:mount point:_files -/' \
    && ret=0

return ret
