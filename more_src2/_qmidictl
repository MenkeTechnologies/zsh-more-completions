#compdef qmidictl
# _qmidictl — MIDI remote-control via UDP / multicast (rncbc/qmidictl)
# upstream: https://github.com/rncbc/qmidictl
# Flags from src/qmidictlOptions.cpp (QCommandLineParser).

_qmidictl() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-i --interface)'{-i+,--interface=}'[network interface to use]:iface:' \
        '(-u --udp-addr)'{-u+,--udp-addr=}'[UDP/IP multicast address]:addr:' \
        '(-p --udp-port)'{-p+,--udp-port=}'[UDP/IP port]:port:' \
        '(-m --mmc-device)'{-m+,--mmc-device=}'[MIDI machine control device ID (0-127)]:id:'
}

_qmidictl "$@"
