#compdef fnirt
# fnirt — FMRIB non-linear image registration tool

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--ref=[reference volume]:reference image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '--in=[input volume]:input image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '--cout=[output coefficient field]:output warp coefficients:_files -g "*.{nii,nii.gz}"' \
  '--iout=[output warped image]:output image:_files -g "*.{nii,nii.gz}"' \
  '--fout=[output field (displacement)]:output field:_files -g "*.{nii,nii.gz}"' \
  '--jout=[output Jacobian map]:jacobian image:_files -g "*.{nii,nii.gz}"' \
  '--refout=[output ref for debugging]:reference output:_files -g "*.{nii,nii.gz}"' \
  '--intout=[output intensity mapping]:intensity output:_files -g "*.{nii,nii.gz}"' \
  '--aff=[affine matrix]:affine matrix:_files -g "*.mat"' \
  '--inwarp=[input warp field]:input warp:_files -g "*.{nii,nii.gz}"' \
  '--config=[configuration file]:config file:_files -g "*.cnf"' \
  '--refmask=[mask for reference image]:reference mask:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '--inmask=[mask for input image]:input mask:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '--lambda=[weight of regularisation]:lambda values:' \
  '--infwhm=[FWHM of Gaussian smoothing for input]:FWHM values (mm):' \
  '--reffwhm=[FWHM of Gaussian smoothing for reference]:FWHM values (mm):' \
  '--subsamp=[subsampling scheme]:subsampling levels:' \
  '--warpres=[warp field resolution (mm)]:resolution:' \
  '--verbose[print diagnostic information]'
