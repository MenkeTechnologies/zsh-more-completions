#compdef pandoc-crossref
# Documentation: https://lierdakil.github.io/pandoc-crossref/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. pandoc-crossref runs as a pandoc
# filter; configuration is done through YAML metadata, not CLI flags.
# STUB: only --help and --version style flags are wired up.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:input:_files' && ret=0
return ret
