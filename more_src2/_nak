# fiatjaf/nak — nostr CLI (urfave/cli/v3 `main.go` root Flags + Commands)

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '--config-path=[hidden config dir override]:dir:_files -/' \
  '*-q[count: quieter; -qq silences stdout helpers]' \
  '*-v[count: verbose]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'nak command' compadd -- event req filter fetch count decode encode key verify relay admin bunker \
    serve blossom dekey encrypt decrypt gift outbox wallet mcp curl fs publish nsite git group nip sync spell profile validate
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
