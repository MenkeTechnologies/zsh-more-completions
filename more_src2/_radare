#compdef radare
# _radare — radare radare2 disassembler/RE framework binary alias (radareorg, C); custom argparse
# upstream: https://github.com/radareorg/radare2

_radare() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-0[print zero between commands]' \
        '-2[disable double output buffering (deprecated)]' \
        '-=[bind ip to localhost]' \
        '-a+[architecture]:str:' \
        '-A[analyze all]' \
        '-AA[analyze all aa-style]' \
        '-AAA[analyze all aaa-style]' \
        '-AAAA[analyze all aaaa-style]' \
        '-b+[bits]:n:(16 32 64)' \
        '-B+[base address]:str:' \
        '-c+[command]:str:' \
        '-C[continue running]' \
        '-d[debug mode]' \
        '-D+[debug backend]:str:' \
        '-e+[set config]:str:' \
        '-f[block size]' \
        '-F+[force binplugin]:str:' \
        '-h[show help]' \
        '-hh[show extra help]' \
        '-H+[show env var]:str:' \
        '-i+[run script]:file:_files' \
        '-I+[run script after init]:file:_files' \
        '-j[json output]' \
        '-k+[kernel info]:str:' \
        '-K[bypass color]' \
        '-l+[load plugin]:str:' \
        '-L[list plugins]' \
        '-m+[map at]:str:' \
        '-M[disable demangling]' \
        '-n[do not load rbin info]' \
        '-N[no scripts]' \
        '-o+[open path]:file:_files' \
        '-p+[load project]:str:' \
        '-P+[load patch file]:file:_files' \
        '-q[quiet]' \
        '-Q[quiet quit]' \
        '-r+[load remote session]:str:' \
        '-R+[set runtime cfg]:str:' \
        '-s+[seek to address]:str:' \
        '-S[start in sandbox mode]' \
        '-t[load rbin info in thread]' \
        '-T[load tabs]' \
        '-u[no overflow allocation]' \
        '-v[show version]' \
        '-V[show version]' \
        '-w[open file in write mode]' \
        '-x[exec start command]' \
        '-X+[allow plugins outside extension]:str:' \
        '-z[do not load strings]' \
        '-zz[load all strings]' \
        '*:file:_files'
}

_radare "$@"
