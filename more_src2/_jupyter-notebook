#compdef jupyter-notebook
# Documentation: jupyter-notebook docs (jupyter-notebook.readthedocs.io)
# Source: jupyter-notebook — interactive Jupyter notebook server.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--ip=[bind IP address]:ip:' \
    '--port=[port to use]:port:_ports' \
    '--port-retries=[port retries on collision]:n:' \
    '--no-browser[do not open a browser at startup]' \
    '--browser=[browser to launch]:browser:' \
    '--autoreload[auto-reload on source change]' \
    '--allow-root[allow running as root]' \
    '--debug[enable debug mode]' \
    '--notebook-dir=[notebook root directory]:dir:_files -/' \
    '--ServerApp.notebook_dir=[notebook root directory]:dir:_files -/' \
    '--password=[server login password]:password:' \
    '--PasswordIdentityProvider.hashed_password=[pre-hashed password]:hash:' \
    '--token=[authentication token]:token:' \
    '--certfile=[SSL certificate]:file:_files -g "*.{pem,crt}"' \
    '--keyfile=[SSL key file]:file:_files -g "*.{pem,key}"' \
    '--client-ca=[client CA file]:file:_files -g "*.{pem,crt}"' \
    '--generate-config[generate default config file]' \
    '--config=[config file]:file:_files' \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '(- *)--help-all[show all help]' \
    '*:notebook file:_files -g "*.ipynb"' \
    && ret=0

return ret
