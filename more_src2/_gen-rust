#compdef gen-rust
# _gen-rust — generate Rust types from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/rustgen/cli.py (click).

_gen-rust() {
    local -a args
    args=(
        '--mode=[generation mode]:mode:(file crate)'
        '--force[overwrite the output destination if it exists]'
        '--pyo3[emit PyO3 bindings alongside the Rust types]'
        '--serde[derive serde Serialize / Deserialize on generated types]'
        '--handwritten-lib[do not regenerate src/lib.rs when generating a crate]'
        '--no-handwritten-lib[regenerate src/lib.rs (overrides handwritten)]'
        '(-n --crate-name)'{-n+,--crate-name=}'[name of the generated crate / module]:name:'
        '(-o --output)'{-o+,--output=}'[output file or crate directory]:path:_files'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into generated output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-rust "$@"
