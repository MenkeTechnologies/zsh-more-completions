#compdef gitea
# _gitea-cli — Gitea server CLI (go-gitea/gitea)
# upstream: https://github.com/go-gitea/gitea

_gitea-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-C --custom-path)'{-C,--custom-path=}'[custom directory path]:dir:_directories' \
        '(-c --config)'{-c,--config}'=[configuration file]:file:_files' \
        '(-w --work-path)'{-w,--work-path}'=[working directory]:dir:_directories' \
        '1: :_gitea_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                web)
                    _arguments \
                        '(-p --port)'{-p,--port}'=[port to listen on]:port:' \
                        '--pid=[PID file path]:file:_files' \
                        '(-q --quiet)'{-q,--quiet}'[quiet mode]' && ret=0 ;;
                admin)
                    local -a admin_subs=(
                        'user:manage users'
                        'repo-sync-releases:sync repository releases'
                        'regenerate:regenerate specific resources'
                        'auth:manage authentication sources'
                        'send-mail:send mail to users'
                    )
                    _describe -t cmds 'admin subcommand' admin_subs && ret=0 ;;
                cert)
                    _arguments \
                        '--host=[host name]:host:_hosts' \
                        '--ecdsa-curve=[ECDSA curve]:curve:(P224 P256 P384 P521)' \
                        '--rsa-bits=[RSA key size]:bits:' \
                        '--start-date=[start date]:date:' \
                        '--duration=[certificate duration]:duration:' \
                        '--ca[generate CA certificate]' && ret=0 ;;
                dump)
                    _arguments \
                        '(-f --file)'{-f,--file}'=[output filename]:file:_files' \
                        '--skip-repository[skip repository dump]' \
                        '--skip-custom-dir[skip custom directory]' \
                        '--skip-log[skip log directory]' \
                        '(-t --type)'{-t,--type}'=[archive type]:type:(zip tar)' && ret=0 ;;
                doctor)
                    local -a doctor_subs=(
                        'check:check for problems'
                        'convert:convert database'
                        'recreate-table:recreate tables'
                    )
                    _describe -t cmds 'doctor subcommand' doctor_subs && ret=0 ;;
                manager)
                    local -a manager_subs=(
                        'shutdown:graceful shutdown'
                        'restart:graceful restart'
                        'flush-queues:flush queues'
                        'logging:manage logging'
                        'processes:display running processes'
                    )
                    _describe -t cmds 'manager subcommand' manager_subs && ret=0 ;;
                generate|migrate|convert|embedded|migrate-storage|docs|dump-repo|restore-repo) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_gitea_commands] )) ||
_gitea_commands() {
    local -a commands
    commands=(
        'web:start the web server'
        'admin:admin operations'
        'cert:generate self-signed certificate'
        'dump:dump data to a file'
        'generate:generate resources'
        'migrate:migrate database'
        'convert:convert database'
        'doctor:diagnose and fix problems'
        'manager:manage running server'
        'embedded:manage embedded resources'
        'migrate-storage:migrate storage'
        'docs:output CLI docs as Markdown'
        'dump-repo:dump a repository'
        'restore-repo:restore a repository'
    )
    _describe -t commands 'gitea command' commands
}

_gitea-cli "$@"
