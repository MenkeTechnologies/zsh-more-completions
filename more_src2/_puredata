#compdef puredata pure-data
# Documentation: https://puredata.info/docs/faq/commandline
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-r+[sample rate]:rate:(22050 44100 48000 96000)' \
  '-audioindev+[audio in device]:dev:' \
  '-audiooutdev+[audio out device]:dev:' \
  '-inchannels+[input channels]:n:' \
  '-outchannels+[output channels]:n:' \
  '-channels+[channels]:n:' \
  '-audiobuf+[audio buffer ms]:ms:' \
  '-blocksize+[block size]:n:' \
  '-sleepgrain+[sleep granularity ms]:ms:' \
  '-jack[use JACK]' \
  '-alsa[use ALSA]' \
  '-oss[use OSS]' \
  '-pa[use PortAudio]' \
  '-nogui[no gui]' \
  '-noaudio[no audio]' \
  '-nomidi[no midi]' \
  '-nrt[non-realtime]' \
  '-rt[realtime]' \
  '-batch[batch mode]' \
  '-d+[debug level]:lvl:' \
  '-stderr[errors to stderr]' \
  '-listdev[list devices]' \
  '-version[show version]' \
  '-help[show help]' \
  '-lib+[load library]:lib:' \
  '-helppath+[help path]:dir:_files -/' \
  '-path+[search path]:dir:_files -/' \
  '-stdpath+[standard search path]:dir:_files -/' \
  '-open+[open patch]:file:_files -g "*.pd"' \
  '-send+[send message]:msg:' \
  '-noprefs[no prefs]' \
  '*:patch:_files -g "*.pd"' && ret=0

return ret
