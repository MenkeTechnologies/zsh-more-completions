#compdef exllamav2 exl2 exllama2
# _exllamav2 — turboderp ExLlamaV2 rewrite of the original ExLlama inference engine supporting EXL2 quantization Mixture-of-Experts speculative decoding and tensor-parallel inference (turboderp team, Python); argparse
# upstream: https://github.com/turboderp/exllamav2

_exllamav2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-m+[model dir]:dir:_files -/' \
        '--model_dir=+[model dir]:dir:_files -/' \
        '-c+[config json]:file:_files -g "*.json"' \
        '--config=+[config json]:file:_files -g "*.json"' \
        '-cf+[ctx len]:n:' \
        '--max_seq_len=+[ctx len]:n:' \
        '-l+[length]:n:' \
        '--length=+[length]:n:' \
        '-cb+[batch size]:n:' \
        '--max_batch_size=+[batch size]:n:' \
        '-gs+[gpu split]:str:' \
        '--gpu_split=+[gpu split]:str:' \
        '-lp+[low memory]' \
        '--low_mem[low memory]' \
        '-cml+[chunk size]:n:' \
        '--chunk_size=+[chunk size]:n:' \
        '-rs+[rope scale]:f:' \
        '--rope_scale=+[rope scale]:f:' \
        '-ra+[rope alpha]:f:' \
        '--rope_alpha=+[rope alpha]:f:' \
        '-q4[use q4 cache]' \
        '--cache_q4[use q4 cache]' \
        '-q8[use q8 cache]' \
        '--cache_q8[use q8 cache]' \
        '-q6[use q6 cache]' \
        '--cache_q6[use q6 cache]' \
        '--cache_8bit[use 8bit cache]' \
        '--cache_4bit[use 4bit cache]' \
        '-fa[force flash attn]' \
        '--flash_attn[flash attention]' \
        '-nfa[no flash attn]' \
        '--no_flash_attn[no flash attention]' \
        '-tp[tensor parallel]' \
        '--tensor_parallel[tensor parallel]' \
        '-mode+[mode]:m:(llama mistral mixtral qwen yi cohere starcoder phi gemma)' \
        '--mode=+[mode]:m:(llama mistral mixtral qwen yi cohere starcoder phi gemma)' \
        '-t+[temperature]:f:' \
        '--temperature=+[temperature]:f:' \
        '-tp_pq+[top p]:f:' \
        '--top_p=+[top p]:f:' \
        '-tk+[top k]:n:' \
        '--top_k=+[top k]:n:' \
        '-typical+[typical]:f:' \
        '--typical=+[typical]:f:' \
        '-rp+[rep penalty]:f:' \
        '--rep_penalty=+[rep penalty]:f:' \
        '-p+[prompt]:str:' \
        '--prompt=+[prompt]:str:' \
        '-pn+[prompt file]:file:_files -g "*.txt"' \
        '--prompt_file=+[prompt file]:file:_files -g "*.txt"' \
        '-ngs+[tokens]:n:' \
        '--no_stream[no stream]'
}

_exllamav2 "$@"
