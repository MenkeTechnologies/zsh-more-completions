#compdef ell
# Documentation: https://github.com/simonmysun/ell
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for ell - terminal LLM assistant (simonmysun/ell)

_arguments \
  '-m[specify a model]:model:' \
  '-f[use a file as input (use - for stdin)]:file:_files' \
  '-r[record mode (capture terminal i/o as context)]' \
  '-i[run in interactive chat mode]' \
  '-t[specify a prompt template]:template:' \
  '(-h --help)'{-h,--help}'[show help]'
