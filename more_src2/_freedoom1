#compdef freedoom1
# Documentation: https://manpages.debian.org/bookworm/freedoom/freedoom1.6.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm freedoom1(6) manpage. Wrapper around
# Doom engine selected via -p / $DOOMPORT / ~/.doomport symlink.
# Removed from prior file: bogus man.archlinux.org search URL.

# freedoom1: Freedoom Phase 1 launcher
local curcontext="$curcontext" ret=1
_arguments -C \
  '-p[Doom engine to use]:engine:(prboom prboom-plus zandronum chocolate-doom crispy-doom)' \
  '--[forward following args to engine]' \
  '*:engine arg:_files' && ret=0
return ret
