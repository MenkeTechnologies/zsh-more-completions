#compdef refile
# Documentation: man refile(1)
# Source: nmh uip/refile.c (master) — file messages in other folders (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-draft[refile the draft]' \
    '(-link -nolink)-link[link instead of moving]' \
    '(-link -nolink)-nolink[move]' \
    '(-preserve -nopreserve)-preserve[preserve message numbers]' \
    '(-preserve -nopreserve)-nopreserve[renumber]' \
    '(-retainsequences -noretainsequences)-retainsequences[retain sequence assignments]' \
    '(-retainsequences -noretainsequences)-noretainsequences[do not retain sequences]' \
    '(-unlink -nounlink)-unlink[remove file from original]' \
    '(-unlink -nounlink)-nounlink[keep original]' \
    '-src+[source folder]:folder:_default' \
    '-file+[file to refile]:file:_files' \
    '-rmmproc+[external remove program]:cmd:_command_names -e' \
    '-normmproc[no external remove program]' \
    '-version[show version]' \
    '-help[show help]' \
    '*:msg or +folder:_default' \
    && ret=0

return ret
