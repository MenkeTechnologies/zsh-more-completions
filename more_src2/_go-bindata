#compdef go-bindata
# _go-bindata — go-bindata embed static assets in Go binaries (Jim Teeuwen + community forks); generates Asset() lookups for embedded files
# upstream: https://github.com/kevinburke/go-bindata

_go-bindata() {
    _arguments \
        '-debug[do not embed, read at runtime]' \
        '-dev[same as debug]' \
        '-nomemcopy[reduce memory usage of generated code]' \
        '-nocompress[do not compress assets]' \
        '-nometadata[skip metadata]' \
        '-nomkdir[skip MustMkdir helper]' \
        '-tags+[build tags]:tags:' \
        '-prefix+[prefix to strip]:prefix:_files -/' \
        '-pkg+[package name]:name:' \
        '-mode+[mode (octal)]:mode:' \
        '-modtime+[mtime override]:n:' \
        '-o+[output file]:file:_files' \
        '-ignore+[ignore regex]:regex:' \
        '-fs[generate http.FileSystem interface]' \
        '-version[show version]' \
        '*:path:_files'
}

_go-bindata "$@"
