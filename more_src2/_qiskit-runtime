#compdef qiskit-runtime qrt
# _qiskit-runtime — IBM Qiskit Runtime CLI for submitting primitive Sampler and Estimator jobs to IBM Quantum hardware (Qiskit team, Python); argparse
# upstream: https://github.com/Qiskit/qiskit-ibm-runtime

_qiskit-runtime() {
    local -a sub=(
        'service:service subcommands'
        'job:job subcommands'
        'backend:backend subcommands'
        'session:session subcommands'
        'estimator:run Estimator primitive'
        'sampler:run Sampler primitive'
        'auth:authentication subcommands'
        'token:token subcommands'
        'config:configuration subcommands'
        'metrics:show usage metrics'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--channel=+[channel]:c:(ibm_quantum ibm_cloud local)' \
        '--token=+[IBM token]:str:' \
        '--instance=+[instance]:str:' \
        '--url=+[runtime URL]:url:_urls' \
        '--proxies=+[proxies json]:str:' \
        '--verify=+[bool]:b:(true false)' \
        '--backend=+[backend name]:str:' \
        '-b+[backend name]:str:' \
        '--shots=+[shots]:n:' \
        '-s+[shots]:n:' \
        '--optimization-level=+[level]:l:(0 1 2 3)' \
        '--resilience-level=+[level]:l:(0 1 2)' \
        '--max-execution-time=+[seconds]:n:' \
        '--seed-simulator=+[seed]:n:' \
        '--seed-estimator=+[seed]:n:' \
        '--no-progress-bar[no progress bar]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qiskit-runtime subcommand' sub ;;
        args)
            case $words[1] in
                job) _arguments '1:job cmd:(get list cancel result status delete)' ;;
                backend) _arguments '1:backend cmd:(list status properties config defaults)' ;;
                session) _arguments '1:session cmd:(start status close)' ;;
                estimator|sampler) _arguments \
                    '--circuit=+[circuit file]:file:_files -g "*.qasm *.qpy *.json *.pkl"' \
                    '--observables=+[observables file]:file:_files' \
                    '--parameters=+[parameters file]:file:_files' \
                    '--method=+[method]:m:(automatic statevector matrix_product_state stabilizer extended_stabilizer)' ;;
                service) _arguments '1:service cmd:(save load delete migrate)' ;;
                auth) _arguments '1:auth cmd:(save login logout status)' ;;
                token) _arguments '1:token cmd:(set unset show)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_qiskit-runtime "$@"
