#compdef mosh-client
# Documentation: https://github.com/mobile-shell/mosh/blob/master/man/mosh-client.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mosh-client: client helper for mosh sessions. Flags from man/mosh-client.1.
local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-v[enable debug output to stderr; repeat for more verbosity]' \
  '-c[print terminal color count based on TERM]' \
  '1:server IP:' \
  '2:server UDP port:' && ret=0

return ret
