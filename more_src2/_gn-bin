#compdef gn
# _gn-bin — Google GN meta-build system (Chromium, Go/C++); fast generator that emits Ninja files
# upstream: https://gn.googlesource.com/gn

_gn-bin() {
    local -a sub=(
        'analyze:analyze impacted targets'
        'args:edit/list build args'
        'check:check header deps'
        'clean:clean build dir'
        'clean_stale:clean stale build artifacts'
        'desc:describe a target'
        'format:format BUILD files'
        'gen:generate ninja files'
        'help:show help'
        'ls:list targets'
        'meta:dump metadata'
        'outputs:print outputs of a target'
        'path:show path between targets'
        'refs:print refs to a target'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '--time[print timing]' \
        '--tracelog+[trace log file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gn subcommand' sub ;;
        args)
            case $words[1] in
                gen) _arguments \
                    '--args+[gen args]:str:' \
                    '--check[check headers]' \
                    '--ide+[IDE]:ide:(vs vs2015 vs2017 vs2019 vs2022 xcode qtcreator json eclipse)' \
                    '--root-target+[root target]:target:' \
                    '--filters+[filters]:str:' \
                    '--workspace+[workspace]:dir:_files -/' \
                    '--ninja-executable+[ninja path]:file:_files' \
                    '--export-compile-commands+[compile commands]:str:' \
                    '--export-rust-project[export rust project]' \
                    '*:build dir:_files -/' ;;
                desc) _arguments \
                    '--blame[blame source files]' \
                    '--all[show all]' \
                    '--tree[show tree]' \
                    '--type+[filter type]:type:' \
                    '--format+[output format]:fmt:(json)' \
                    '*:target:' ;;
                args) _arguments \
                    '--list[list args]' \
                    '--short[short list]' \
                    '--overrides-only[overrides only]' \
                    '--json[json output]' \
                    '*:build dir:_files -/' ;;
            esac
            ;;
    esac
}

_gn-bin "$@"
