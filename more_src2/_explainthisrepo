#compdef explainthisrepo explain-this-repo etr
# Documentation: https://www.npmjs.com/package/explainthisrepo
# Reference accessed: 2026-05-22
# Verified: npm package CLI flags and command aliases.

# Zsh completion for explainthisrepo - explain a repo in plain language

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--quick[one-sentence summary to stdout]' \
  '--detailed[detailed architecture explanation]' \
  '--simple[short simplified explanation]' \
  '--stack[include technology stack]' \
  '--map[repo map of files to ignore]' \
  '*:target:(.)' && ret=0

return ret
