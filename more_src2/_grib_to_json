#compdef grib_to_json
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_to_json
# Source: ecmwf/eccodes tools/grib_to_json.cc — convert GRIB messages to JSON header/data records (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '*:grib file:_files' \
    && ret=0

return ret
