#compdef postsrsd
# Documentation: https://github.com/roehling/postsrsd
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-C[load configuration from file]:file:_files' \
  '-c[chroot directory]:dir:_files -/' \
  '-D[daemonize by forking into background]' \
  '-p[write process ID into file]:file:_files' \
  '-u[drop root privileges and run as user]:user:_users' \
  '-v[show version number]' && ret=0

return ret
