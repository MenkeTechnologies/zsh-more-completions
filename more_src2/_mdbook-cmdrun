#compdef mdbook-cmdrun
# _mdbook-cmdrun — mdbook preprocessor that inlines shell command output (FauconFan/mdbook-cmdrun)
# upstream: https://github.com/FauconFan/mdbook-cmdrun
# Subcommands from src/main.rs (clap).

_mdbook-cmdrun() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-cmdrun "$@"
