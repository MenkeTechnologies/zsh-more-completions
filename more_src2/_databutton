#compdef databutton
# _databutton — Databutton databutton AI-driven Python data-app builder CLI for creating jobs APIs storage scheduled tasks and Streamlit-style UIs (databutton team, Python); typer
# upstream: https://databutton.com/

_databutton() {
    local -a sub=(
        'login:login'
        'logout:logout'
        'whoami:show current user'
        'create:create new app'
        'configure:configure app'
        'serve:run dev server'
        'start:start dev server'
        'deploy:deploy app'
        'open:open app in browser'
        'list:list apps'
        'list-jobs:list jobs'
        'list-apis:list APIs'
        'list-storage:list storage'
        'logs:show logs'
        'secrets:secrets operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--workspace=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'databutton subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--name=+[name]:str:' \
                    '--template=+[t]:t:(blank streamlit fastapi data-pipeline ai-app dashboard chatbot)' \
                    '--python-version=+[v]:v:(3.9 3.10 3.11 3.12)' ;;
                deploy|serve|start) _arguments \
                    '--app=+[name]:str:' \
                    '--branch=+[branch]:str:' \
                    '--region=+[r]:r:(europe-west1 us-east1 us-central1 asia-east1)' ;;
                secrets) _arguments \
                    '1:action:(list set get unset import export)' \
                    '*:key:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_databutton "$@"
