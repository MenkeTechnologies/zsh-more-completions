#compdef osc-cli osc
# Documentation: https://www.mankier.com/1/osc
# Reference accessed: 2026-05-17
# Verified: openSUSE Build Service `osc` mankier reference + OBS user
# guide. PyPI package is `osc-cli`, binary is `osc`. Not "IBM OpenAPI".
# Removed from prior file: bogus man.archlinux.org search URL;
# false IBM OpenAPI claim; generic stub missing all subcommands.

# osc: openSUSE Build Service CLI
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'add:add files to package'
  'rm:remove files'
  'delete:remove files'
  'co:checkout'
  'checkout:checkout'
  'ci:commit'
  'commit:commit'
  'st:status'
  'status:status'
  'up:update'
  'update:update'
  'ls:list packages/projects'
  'branch:branch package'
  'bco:branch+checkout'
  'linkpac:create package link'
  'detachbranch:detach branch'
  'repairlink:repair package link'
  'build:local build'
  'buildinfo:show build info'
  'buildlog:show build log'
  'rebuild:trigger rebuild'
  'rebuildpac:trigger rebuild'
  'meta:show/edit project/package meta'
  'editmeta:edit meta'
  'repos:list repositories'
  'repositories:list repositories'
  'lock:lock package'
  'unlock:unlock package'
  'setdevelproject:set devel project'
  'rq:request management'
  'request:request management'
  'review:review request'
  'sr:submit request'
  'submitrequest:submit request'
  'creq:create request'
  'createrequest:create request'
  'mbranch:maintained branch'
  'patchinfo:patchinfo'
  'createincident:create incident'
  'maintenancerequest:maintenance request'
  'info:show info'
  'log:show log'
  'diff:show diff'
  'rdiff:remote diff'
  'results:build results'
  'pr:project results'
  'prjresults:project results'
  'api:raw API call'
  'platforms:list platforms'
)

_arguments -C \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--debug[debug output]' \
  '--debugger[run with pdb]' \
  '--post-mortem[run pdb on exception]' \
  '--traceback[show traceback on error]' \
  '(-H --http-debug)'{-H,--http-debug}'[HTTP debug]' \
  '--http-full-debug[HTTP body debug]' \
  '(-A --apiurl)'{-A+,--apiurl=}'[API URL]:url:' \
  '--config=[config file]:file:_files' \
  '*--setopt=[set option KEY=VALUE]:kv:' \
  '--no-keyring[do not use keyring]' \
  '--no-pager[disable pager]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'osc command' commands && ret=0 ;;
esac
return ret
