#compdef esl-seqrange
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-seqrange.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-seqrange: compute sequence range for one of N parallel workers
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '--informat=[input sequence format]:fmt:(fasta embl genbank uniprot stockholm a2m afa psiblast clustal phylip)' \
  '*:sequence file and worker info:_files' && ret=0
return ret
