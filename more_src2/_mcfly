#compdef mcfly
# Documentation: https://github.com/cantino/mcfly
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mcfly - fly through your shell history

local curcontext="$curcontext" state line ret=1

local -a subcommands=(
  'init:print shell integration script'
  'search:search and run a command from history'
  'add:add a command to the history database'
  'train:train the McFly network on history'
  'move:move history entries between directories'
  'dump:export command history to stdout'
  'stats:display history statistics'
  'help:print help'
)

_arguments -C -s -S \
  '--debug[enable debug output]' \
  '--session-id=[session identifier]:id' \
  '--mcfly-history=[history file path]:file:_files' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:subcommand:->subcommand' \
  '*:: :->args' && ret=0

case $state in
  subcommand)
    _describe -t subcommands 'subcommand' subcommands && ret=0
    ;;
  args)
    case $line[1] in
      init)
        _arguments \
          '--shell=[target shell]:shell:(bash zsh fish powershell)' && ret=0
        ;;
      add)
        _arguments \
          '--command=[command text]:command' \
          '--exit=[exit code]:code' \
          '--append-to-histfile=[file to append to]:file:_files' \
          '--when=[timestamp]:time' \
          '--directory=[current working directory]:dir:_directories' \
          '--old-directory=[previous directory]:dir:_directories' && ret=0
        ;;
      search)
        _arguments \
          '--command=[search query]:query' \
          '--directory=[current working directory]:dir:_directories' \
          '--results=[number of results]:N' \
          '--fuzzy=[fuzzy matching level]:N' \
          '--delete-without-confirm[skip deletion confirmation]' \
          '--output-selection=[output format]:format' && ret=0
        ;;
      train)
        _arguments \
          '--refresh-cache[rebuild training cache]' && ret=0
        ;;
      move)
        _arguments \
          '--old-dir-path=[previous directory]:dir:_directories' \
          '--new-dir-path=[new directory]:dir:_directories' && ret=0
        ;;
      dump)
        _arguments \
          '--since=[start timestamp]:time' \
          '--before=[end timestamp]:time' \
          '--sort=[sort order]:order' \
          '(-r --regex)'{-r,--regex}'=[regex pattern filter]:pattern' \
          '--format=[output format]:format:(json csv)' && ret=0
        ;;
      stats)
        _arguments \
          '--min-cmd-length=[minimum command length]:N' \
          '--cmds[show command count]' \
          '--dirs[show directory count]' \
          '--global-commands-to-ignore=[exclusion threshold]:N' \
          '--only-dir=[specific directory filter]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
