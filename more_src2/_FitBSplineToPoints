#compdef FitBSplineToPoints
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/FitBSplineToPoints.cxx — B-spline curve or warp field fit to landmarks (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:pointDimension (append "w" for warp field):_default' \
    '2:inputLandmarksFile or inputPointFile:_files' \
    '*:remaining (curve: [order] [nlevels] [#cp] [sampleSpacing] [closed]; warp: inputDisplacementFile domainImage outputDisplacementField controlPointMeshSize [nlevels]):_files' \
    && ret=0

return ret
