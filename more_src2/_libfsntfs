#compdef fsntfsinfo fsntfsmount
# _libfsntfs — libfsntfs tools (libyal Windows NTFS parser; fsntfsinfo dumps NTFS metadata, MFT entries and ADS streams, fsntfsmount FUSE-mounts an NTFS image read-only; -h help, -V version, -v verbose, -o image offset, -B bytes-per-sector, -E entry filter, -F file filter, -X exclusive; positional argument is the NTFS image)
# upstream: https://github.com/libyal/libfsntfs
# Flags from libyal/libfsntfs fsntfstools/fsntfsinfo.c on tip.

_libfsntfs() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-B+[bytes per sector]:bytes:' \
        '-E+[entry filter]:entry:' \
        '-F+[file filter]:path:' \
        '-X[exclusive lock]' \
        '*:NTFS image:_files'
}

_libfsntfs "$@"
