#compdef qmove
# Documentation: https://docs.adaptivecomputing.com/torque/4-0-2/Content/topics/commands/qmove.htm
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# qmove: move a PBS/TORQUE job to a different queue.
# Synopsis: qmove destination jobId [jobId ...]  -- no flags.

local ret=1
_arguments \
  '1:destination (queue, @server, or queue@server):' \
  '*:jobid:' && ret=0
return ret
