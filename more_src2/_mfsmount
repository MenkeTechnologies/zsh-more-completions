#compdef mfsmount
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/mfsmount.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfsmount: mount a MooseFS instance
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[display help and exit]' \
  '(- *)-V[display version and exit]' \
  '-d[enable debug mode (implies -f)]' \
  '-f[foreground operation]' \
  '-s[disable multi-threaded operation]' \
  '-m[mount MFSMETA companion filesystem]' \
  '-n[omit default mount options]' \
  '-p[prompt for password]' \
  '-c[config file with additional mount options]:file:_files' \
  '-o[mount options]:opts:' \
  '-H[connect with MooseFS master on HOST]:host:_hosts' \
  '-P[connect with MooseFS master on PORT]:port:' \
  '-B[local address for connecting with master]:ip:' \
  '-L[listen ip of local master proxy]:ip:' \
  '-S[mount specified MooseFS subdirectory]:path:' \
  '*:mount point:_files -/' && ret=0
return ret
