#compdef ezmlm-make
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-make.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[archived with ezmlm-get access (default)]' \
  '-A[not archived]' \
  '-b[block archive; only moderators access]' \
  '-B[open archive access (default)]' \
  '-c[use .ezmlmrc from dot directory]' \
  '-C+[use specified ezmlmrc config file]:file:_files' \
  '-d[enable digest list]' \
  '-D[no digest (default)]' \
  '-e[edit mode; reconfigure existing list]' \
  '-E[no edit (default)]' \
  '-f[prefix subjects with list name]' \
  '-F[no subject prefix (default)]' \
  '-g[guard archive]' \
  '-G[allow archive requests from any sender (default)]' \
  '-h[help subscription; no confirmation]' \
  '-H[subscriptions require confirmation (default)]' \
  '-i[indexed for WWW archive]' \
  '-I[no WWW indexing (default)]' \
  '-j[unsubscribe without confirmation]' \
  '-J[unsubscribe requires confirmation (default)]' \
  '-l[allow remote admins to list subscribers]' \
  '-L[subscriber list not obtainable (default)]' \
  '-m[enable message moderation]' \
  '-M[no message moderation (default)]' \
  '-n[allow remote admins to edit text files]' \
  '-N[text editing disallowed (default)]' \
  '-o[reject posts from non-moderators]' \
  '-O[forward non-moderator posts to moderators (default)]' \
  '-p[public list (default)]' \
  '-P[private; limit admin functions]' \
  '-r[enable remote administration]' \
  '-R[no remote administration (default)]' \
  '-s[enable subscription moderation]' \
  '-S[subscriptions unrestricted (default)]' \
  '-t+[add trailer text]:text:' \
  '-T+[trailer file]:file:_files' \
  '-u[restrict posts/archive to subscribers]' \
  '-U[no sender-based post restrictions (default)]' \
  '-w[remove ezmlm-warn from setup]' \
  '-W[normal bounce handling (default)]' \
  '-x[configure MIME filtering]' \
  '-y[require sender confirmation for posting]' \
  '-Y[no sender confirmation (default)]' \
  '-+[make switches sticky for edits]' \
  '1:dir:_files -/' \
  '2:dot:' \
  '3:local:' \
  '4:host:_hosts' \
  '5:code:' && ret=0

return ret
