#compdef dnspy
# _dnspy — dnSpy .NET assembly editor/debugger/decompiler CLI alias (dnSpy team, C#); custom argparse
# upstream: https://github.com/dnSpyEx/dnSpy

_dnspy() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--multiple-instances[allow multiple instances]' \
        '--no-activate[no activate]' \
        '--language=+[language]:str:' \
        '--theme=+[theme]:str:' \
        '--debug=+[debug attach mode]:m:(noninvasive invasive)' \
        '--select=+[search node]:str:' \
        '--font=+[font]:str:' \
        '--font-size=+[size]:n:' \
        '-c+[file with command line]:file:_files' \
        '*:files:_files -g "*.{dll,exe,winmd,netmodule,sln,csproj,vbproj}"'
}

_dnspy "$@"
