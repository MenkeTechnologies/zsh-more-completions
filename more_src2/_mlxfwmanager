#compdef mstfwmanager mlxfwmanager
# Documentation: https://docs.nvidia.com/networking/display/mftv4350/mlxfwmanager-%E2%80%93-firmware-update-and-query-tool
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --dev)'{-d+,--dev=}'[mst device]:dev:' \
  '--query[query device firmware]' \
  '--query-format=[query output format]:fmt:(XML Text)' \
  '(-u --update)'{-u,--update}'[update firmware]' \
  '(-i --image-file)'{-i+,--image-file=}'[firmware image file]:file:_files' \
  '(-D --image-dir)'{-D+,--image-dir=}'[image directory]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[force update]' \
  '(-y --yes)'{-y,--yes}'[answer yes]' \
  '--no[answer no]' \
  '--clear-semaphore[force clear flash semaphore]' \
  '--exe-rel-path[paths relative to executable]' \
  '(-l --list-content)'{-l,--list-content}'[list contents]' \
  '--archive-names[show archive names]' \
  '--nofs[burn image non-failsafe]' \
  '--log[create log file]' \
  '(-L --log-file)'{-L+,--log-file=}'[log file path]:file:_files' \
  '--no-progress[suppress progress display]' \
  '(-o --outfile)'{-o+,--outfile=}'[output file]:file:_files' \
  '--online[fetch firmware from NVIDIA server]' \
  '--skip_if_same[skip if versions match]' && ret=0
return ret
