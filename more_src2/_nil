#compdef nil
# Documentation: https://github.com/oxalica/nil
# Reference accessed: 2026-05-19
# Verified: upstream source crates/nil/src/main.rs at the URL above.

# oxalica/nil — Nix Expression Language LSP server (argh-derived CLI).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'diagnostics:check and print diagnostics for files'
  'parse:parse a Nix file and print syntax tree'
  'ssr:structural search and replace'
)

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--stdio[use stdin/stdout for the language server]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'nil subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (diagnostics)
        _arguments \
          '--deny-warnings[treat warnings as errors]' \
          '*:paths:_files' && ret=0
        ;;
      (parse)
        _arguments \
          ':path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
