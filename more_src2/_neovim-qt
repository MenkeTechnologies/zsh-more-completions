#compdef nvim-qt
# Documentation: https://github.com/equalsraf/neovim-qt
# Reference accessed: 2026-05-19
# Verified: src/gui/app.cpp QCommandLineOption definitions in the
# equalsraf/neovim-qt repository.

# nvim-qt: Qt GUI for Neovim
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nvim=[path to nvim binary]:file:_files' \
  '--timeout=[connection timeout in ms]:ms' \
  '--geometry=[window WxH]:geometry' \
  '--qwindowgeometry=[Qt window WxH]:geometry' \
  '--stylesheet=[Qt stylesheet file]:file:_files' \
  '--maximized[start maximized]' \
  '--fullscreen[start fullscreen]' \
  '--embed[start nvim in embed mode]' \
  '--server=[connect to running nvim server]:addr' \
  '--spawn[spawn nvim and remaining args]' \
  '--nofork[do not fork from terminal (Unix)]' \
  '*:files:_files' && ret=0
return ret
