#compdef ext4attr
# _ext4attr — debugfs ext4attr (per-inode ext4 attribute query/setter that uses debugfs and the e2fsprogs API; -d device, -i inode number, -g get all attrs, -s set <attr>=<value>, -l list extended attrs in the EA xattr namespace)
# upstream: https://git.kernel.org/pub/scm/fs/ext2/e2fsprogs.git
# Argument shape from e2fsprogs misc/ext4attr.c on tip.

_ext4attr() {
    _arguments \
        '-h[show help]' \
        '-d+[device]:device:_files -g "/dev/*"' \
        '-i+[inode number]:inode:' \
        '-g[get all attributes]' \
        '-l[list xattrs]' \
        '-s+[set attr=value]:attr=value:' \
        '*:file:_files'
}

_ext4attr "$@"
