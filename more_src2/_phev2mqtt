_phev2mqtt() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file path (default $HOME/.phev2mqtt.yaml)]:path:_files -g "*.yaml *.yml"' \
        '(-v --verbosity)'{-v,--verbosity}'=[logging level (default info)]:level:(trace debug info warn error fatal panic)' \
        '(-t --log_timestamps)'{-t,--log_timestamps}'[coloured logging with timestamps]' \
        '(-s --log_syslog)'{-s,--log_syslog}'[plain logging to syslog instead of console]' \
        '1: :_phev2mqtt_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                mqtt)
                    _arguments \
                        '--mqtt_server=[MQTT server address (default tcp://127.0.0.1:1883)]:url:' \
                        '--mqtt_username=[MQTT username]:user:' \
                        '--mqtt_password=[MQTT password]:password:' \
                        '--mqtt_topic_prefix=[topic prefix (default phev)]:prefix:' \
                        '--mqtt_disable_register_set_command[disable vehicle register setting via MQTT]' \
                        '--ha_discovery=[enable Home Assistant MQTT discovery (default true)]:bool:(true false)' \
                        '--ha_discovery_prefix=[Home Assistant MQTT discovery prefix (default homeassistant)]:prefix:' \
                        '--update_interval=[force update interval (default 5m)]:duration:' \
                        '--wifi_restart_time=[attempt Wifi restart after N duration of no connection (default 0)]:duration:' \
                        '--wifi_restart_retry_time=[Wifi restart retry interval (default 2m)]:duration:' \
                        '--wifi_restart_command=[Wifi restart shell command]:command:' && ret=0 ;;
                decode)
                    _arguments \
                        '1:decode subcommand:(file hex pcap)' \
                        '*::arg:->decode_args'
                    case $state in
                        decode_args)
                            case $words[1] in
                                file|pcap)
                                    _arguments '1:capture file:_files' && ret=0 ;;
                                hex)
                                    _arguments '*:hex bytes:' && ret=0 ;;
                            esac ;;
                    esac ;;
                client|emulator|register|unregister|set|watch)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_phev2mqtt_commands] )) ||
_phev2mqtt_commands() {
    local -a commands
    commands=(
        'client:client to connect and interact with the vehicle (direct CLI mode)'
        'mqtt:start the MQTT bridge (long-lived gateway daemon)'
        'register:register client with the car (one-time pairing handshake)'
        'unregister:unregister a previously-paired client'
        'watch:connect to PHEV and watch incoming updates (live register read)'
        'set:set register value(s) on the car (one-shot register write)'
        'decode:commands to decode PHEV messages (file/hex/pcap)'
        'emulator:emulate a car for app testing'
    )
    _describe -t commands 'phev2mqtt command' commands
}

_phev2mqtt "$@"
