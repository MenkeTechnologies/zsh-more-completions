#compdef ggshield
# Documentation: https://docs.gitguardian.com/ggshield-docs/getting-started
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# GitGuardian ggshield - secrets / IaC / SCA scanner.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*'{-v,--verbose}'[verbose output]' \
  '--allow-self-signed[allow self-signed certificates]' \
  '--json[JSON output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'auth:manage authentication'
      'secret:secret detection commands'
      'iac:Infrastructure as Code scanning'
      'sca:Software Composition Analysis'
      'honeytoken:manage honeytokens'
      'install:install git hooks'
      'quota:show scanning quota'
      'api-status:show API status'
      'config:manage configuration'
    )
    _describe -t commands 'ggshield command' commands && ret=0
    ;;
  args)
    case $line[1] in
      auth)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(login logout token)' && ret=0
        ;;
      secret)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(scan ignore)' \
          '*::scanarg:->scanargs' && ret=0
        ;;
      iac)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          '1:subcommand:(scan diff)' && ret=0
        ;;
      install)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '(-m --mode)'{-m+,--mode=}'[install scope]:scope:(local global)' \
          '(-t --hook-type)'{-t+,--hook-type=}'[hook type]:type:(pre-commit pre-push cursor claude-code copilot)' \
          '(-f --force)'{-f,--force}'[overwrite existing hook]' \
          '(-a --append)'{-a,--append}'[append to existing script]' && ret=0
        ;;
    esac
    case $state in
      scanargs)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--all-policies[use all policies]' \
          '--exit-zero[exit 0 on non-blocking incidents]' \
          '--show-secrets[show secrets in output]' \
          '--no-git[do not use git]' \
          '--ignore-known-secrets[ignore already known secrets]' \
          '*:scan target:(commit pre-commit ci path repo docker)' && ret=0
        ;;
    esac
    ;;
esac

return ret
