#compdef pokemon-colorscripts
# _pokemon-colorscripts — print colorful Pokémon ASCII art (phoneybadger/pokemon-colorscripts)
# upstream: https://gitlab.com/phoneybadger/pokemon-colorscripts
# Flags from pokemon-colorscripts.py (argparse).

_pokemon-colorscripts() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-l --list)'{-l,--list}'[print the list of all supported Pokémon names]'
        '(-n --name)'{-n+,--name=}'[select a Pokémon by name (e.g. pikachu, mr-mime)]:name:'
        '(-f --form)'{-f+,--form=}'[show an alternate form of the Pokémon]:form:'
        '--no-title[do not print the Pokémon name above the sprite]'
        '(-s --shiny)'{-s,--shiny}'[show the shiny version of the Pokémon]'
        '(-b --big)'{-b,--big}'[show a larger version of the sprite]'
        '(-r --random)'{-r+,--random=}'[show a random Pokémon (optionally a generation range, default 1-8)]:gens:'
        '(-rn --random-by-names)'{-rn+,--random-by-names=}'[show a random Pokémon from a comma-separated list of names]:names:'
    )
    _arguments -s -S $args
}

_pokemon-colorscripts "$@"
