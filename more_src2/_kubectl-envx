#compdef kubectl-envx
# Documentation: https://github.com/majodev/kubectl-envx
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[Kubernetes namespace]:namespace:' \
  '(-c --container)'{-c+,--container=}'[container name]:container:' \
  '1:kind/name:_default' \
  '*::arg:_default'
