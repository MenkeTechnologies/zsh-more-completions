#compdef prebuildify
# _prebuildify — create and bundle prebuilds for native modules (prebuild/prebuildify)
# upstream: https://github.com/prebuild/prebuildify
# Flags from bin.js (minimist) + README options table.

_prebuildify() {
    _arguments \
        '*'{-t+,--target=}'[one or more targets]:target:' \
        '(-a --all)'{-a,--all}'[build all known targets]' \
        '--napi[make Node-API builds (default true)]' \
        '--no-napi[do not make Node-API builds]' \
        '--electron-compat[make two Node-API builds (node + electron)]' \
        '--debug[make debug builds]' \
        '--arch=[target CPU architecture]:arch:(x64 ia32 arm arm64 ppc64 s390x)' \
        '--platform=[target platform]:platform:(linux darwin win32 freebsd openbsd sunos aix android)' \
        '--uv=[major libuv version]:n:' \
        '--armv=[ARM version (e.g. 7)]:n:' \
        '--libc=[libc flavor]:libc:(glibc musl)' \
        '--tag-uv[tag prebuild with uv]' \
        '--tag-armv[tag prebuild with armv]' \
        '--tag-libc[tag prebuild with libc]' \
        '--preinstall=[command before build]:cmd:' \
        '--postinstall=[command after build]:cmd:' \
        '--shell=[shell to spawn commands in]:shell:_command_names -e' \
        '--artifacts=[extra files directory]:dir:_files -/' \
        '(-n --name)'{-n+,--name=}'[binding name]:name:' \
        '(-v --version)'{-v+,--version=}'[binding version]:ver:' \
        '(-c --cache)'{-c+,--cache=}'[cache directory]:dir:_files -/' \
        '--node-gyp=[path to node-gyp]:file:_files' \
        '--strip[strip symbols from output]' \
        '--strip-bin=[strip binary path]:file:_files' \
        '--quiet[quiet output]' \
        '*:native-module directory:_files -/'
}

_prebuildify "$@"
