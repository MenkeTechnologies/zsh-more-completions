#compdef daxctl
# Documentation: man daxctl(1)
# Source: pmem/ndctl daxctl/daxctl.c (main) — Linux DAX device control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'version:show daxctl version'
    'list:list DAX devices/regions'
    'help:show command help'
    'split-acpi:split SRAT/HMAT tables'
    'migrate-device-model:migrate from system-ram device model'
    'create-device:create a new DAX device'
    'destroy-device:destroy a DAX device'
    'reconfigure-device:change DAX device mode'
    'online-memory:online DAX-backed memory'
    'offline-memory:offline DAX-backed memory'
    'disable-device:disable a DAX device'
    'enable-device:enable a DAX device'
)

_arguments -s -C \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:->cmd' \
    '*::cmd args:_default' \
    && ret=0

case $state in
    cmd) _describe -t commands 'daxctl command' cmds && ret=0 ;;
esac

return ret
