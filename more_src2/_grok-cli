#compdef grok-cli grok
# Documentation: https://github.com/superagent-ai/grok-cli
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-k --api-key)'{-k+,--api-key=}'[xAI/Grok API key]:key:' \
  '(-u --base-url)'{-u+,--base-url=}'[API base URL]:url:' \
  '(-m --model)'{-m+,--model=}'[model name]:model:' \
  '(-d --directory)'{-d+,--directory=}'[working directory]:dir:_directories' \
  '(-s --session)'{-s+,--session=}'[resume prior session (id or "latest")]:session:' \
  '(-p --prompt)'{-p+,--prompt=}'[headless mode prompt for CI/CD]:prompt:' \
  '--max-tool-rounds=[max recursive tool iterations]:n:' \
  '--format=[output format]:format:(text json)' \
  '--batch-api[use xAI Batch API for unattended runs]' \
  '--verify[run build/test/smoke checks in sandbox]' \
  '--sandbox[enable sandbox mode]' \
  '--no-sandbox[disable sandbox mode]' \
  '--background-task-file=[background task state file]:file:_files' \
  '*::args: _default' && ret=0

return ret
