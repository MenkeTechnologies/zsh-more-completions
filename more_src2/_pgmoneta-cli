#compdef pgmoneta-cli
# _pgmoneta-cli — pgmoneta PostgreSQL backup/restore admin CLI (pgmoneta/pgmoneta)
# upstream: https://github.com/pgmoneta/pgmoneta
# Subcommands + flags from src/cli.c.

_pgmoneta-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config)'{-c+,--config=}'[pgmoneta_cli.conf path]:file:_files -g "*.conf"' \
        '(-h --host)'{-h+,--host=}'[pgmoneta daemon host]:host:' \
        '(-p --port)'{-p+,--port=}'[pgmoneta daemon port]:port:' \
        '(-U --user)'{-U+,--user=}'[user name]:user:' \
        '(-P --password)'{-P+,--password=}'[password]:password:' \
        '(-L --logfile)'{-L+,--logfile=}'[log file path]:file:_files' \
        '(-v --verbose)'{-v,--verbose}'[output text string of result]' \
        '(-F --format)'{-F+,--format=}'[output format]:format:(text json raw)' \
        '(-C --compress)'{-C+,--compress=}'[wire-protocol compression]:algo:(none gz zstd lz4 bz2)' \
        '(-E --encrypt)'{-E+,--encrypt=}'[wire-protocol encryption]:algo:(none aes aes256 aes192 aes128)' \
        '(-s --sort)'{-s+,--sort=}'[result sort order (for list-backup)]:order:(asc desc)' \
        '--cascade[cascade a retain / expunge backup]' \
        '--force[skip confirmation for delete]' \
        '(- *)-V[show version]' \
        '(- *)--version[show version]' \
        '(- *)-\?[show help]' \
        '(- *)--help[show help]' \
        '1: :_pgmoneta-cli_commands' \
        '*::arg:' && ret=0

    return ret
}

(( $+functions[_pgmoneta-cli_commands] )) ||
_pgmoneta-cli_commands() {
    local -a commands
    commands=(
        'backup:take a backup of <server>'
        'list-backup:list backups for <server>'
        's3:S3 backup operations (ls / delete / restore)'
        'restore:restore <server> to <directory> at the given point-in-time'
        'verify:verify a backup (all or failed files)'
        'archive:archive a backup to <directory>'
        'delete:delete a backup by timestamp / oldest / newest'
        'retain:mark a backup to be retained (use --cascade)'
        'expunge:remove the retention mark from a backup'
        'decrypt:decrypt a pgmoneta artifact'
        'encrypt:encrypt a pgmoneta artifact'
        'decompress:decompress a pgmoneta artifact'
        'compress:compress a pgmoneta artifact'
        'shutdown:shut down the pgmoneta daemon'
        'ping:ping the pgmoneta daemon'
        'status:print pgmoneta status (optionally "details")'
        'conf:reload / list / get / set configuration parameters'
        'clear:clear runtime state (currently "prometheus")'
        'info:show metadata of a specific backup'
        'annotate:add / update / remove annotations on a backup'
        'mode:set a server online / offline'
        'progress:show progress of an in-flight operation'
    )
    _describe -t commands 'pgmoneta-cli command' commands
}

_pgmoneta-cli "$@"
