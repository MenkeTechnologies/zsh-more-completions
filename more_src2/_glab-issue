#compdef glab-issue
# _glab-issue — GitLab glab issue subcommand alias (GitLab Inc., Go); spf13/cobra
# upstream: https://gitlab.com/gitlab-org/cli

_glab-issue() {
    local -a sub=(
        'board:work with issue boards'
        'close:close an issue'
        'create:create an issue'
        'delete:delete an issue'
        'list:list issues'
        'note:add a note'
        'reopen:reopen an issue'
        'subscribe:subscribe to an issue'
        'unsubscribe:unsubscribe from an issue'
        'update:update an issue'
        'view:view an issue'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--repo=+[repository]:str:' \
        '-R+[repository]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glab-issue subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--assignee=+[assignee]:list:' \
                    '-a+[assignee]:list:' \
                    '--confidential[confidential]' \
                    '--description=+[description]:str:' \
                    '-d+[description]:str:' \
                    '--label=+[label]:list:' \
                    '-l+[label]:list:' \
                    '--linked-issues=+[linked issues]:list:' \
                    '--link-type=+[link type]:t:(relates_to blocks is_blocked_by)' \
                    '--milestone=+[milestone]:str:' \
                    '-m+[milestone]:str:' \
                    '--no-editor[no editor]' \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '--yes[yes]' \
                    '-y[yes]' ;;
                list) _arguments \
                    '--all[all]' \
                    '-A[all]' \
                    '--assignee=+[assignee]:str:' \
                    '-a+[assignee]:str:' \
                    '--author=+[author]:str:' \
                    '-A+[author]:str:' \
                    '--closed[closed only]' \
                    '-c[closed only]' \
                    '--confidential[confidential only]' \
                    '--group=+[group]:str:' \
                    '-g+[group]:str:' \
                    '--label=+[label]:list:' \
                    '-l+[label]:list:' \
                    '--milestone=+[milestone]:str:' \
                    '-m+[milestone]:str:' \
                    '--mine[mine]' \
                    '--opened[open only]' \
                    '-o[open only]' \
                    '--per-page=+[per page]:n:' \
                    '-P+[per page]:n:' \
                    '--search=+[search]:str:' \
                    '-s+[search]:str:' ;;
                view|close|reopen|delete|note|subscribe|unsubscribe|update) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '*:issue-id:' ;;
                board) _arguments \
                    '1:cmd:(view)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_glab-issue "$@"
