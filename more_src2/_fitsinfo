#compdef fitsinfo
# Documentation: https://docs.astropy.org/en/stable/io/fits/usage/scripts.html#fitsinfo
# Source: astropy/astropy astropy/io/fits/scripts/fitsinfo.py — summary of HDUs in a FITS file (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)--version[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    '*:FITS file:_files -g "*.{fits,fit,fts,fits.gz,fit.gz,fts.gz}"' \
    && ret=0

return ret
