#compdef mrconvert
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrconvert.html
# Source: MRtrix3/mrtrix3 cmd/mrconvert.cpp — convert between image formats and modify header (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-coord+[extract subset along axis]:axis:_default:selection:_default' \
    '-vox+[voxel sizes (comma-separated)]:sizes:_default' \
    '-axes+[axis permutation]:axes:_default' \
    '-scaling+[intensity scaling (offset,multiplier)]:values:_default' \
    '-json_import+[import JSON into header key-values]:file:_files -g "*.json"' \
    '-json_export+[export header key-values to JSON]:file:_files -g "*.json"' \
    '*-clear_property+[clear header property]:key:_default' \
    '*-set_property+[set header property]:key:_default:value:_default' \
    '*-append_property+[append to header property]:key:_default:value:_default' \
    '-copy_properties+[copy properties from source image]:source:_files -g "*.{nii,nii.gz,mif}"' \
    '-strides+[output data strides]:strides:_default' \
    '-datatype+[output datatype]:dtype:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-export_grad_mrtrix+[export MRtrix gradient table]:file:_files' \
    '-export_grad_fsl+[export FSL bvecs bvals]:files:_files' \
    '-import_pe_table+[import phase encoding table]:file:_files' \
    '-import_pe_eddy+[import PE config in eddy format]:files:_files' \
    '-export_pe_table+[export phase encoding table]:file:_files' \
    '-export_pe_eddy+[export PE config in eddy format]:files:_files' \
    '1:input image:_files -g "*.{nii,nii.gz,mif,mih,dcm}"' \
    '2:output image:_files' \
    && ret=0

return ret
