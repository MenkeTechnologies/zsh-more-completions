#compdef pt-config-diff
# Documentation: https://docs.percona.com/percona-toolkit/pt-config-diff.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--buffer-stdout[enable STDOUT buffering (default)]' \
  '--no-buffer-stdout[disable STDOUT buffering]' \
  '(-A --charset)'{-A+,--charset=}'[connection charset]:charset' \
  '*--config=[comma-separated config files]:file:_files' \
  '(-D --database)'{-D+,--database=}'[database name]:database' \
  '(-F --defaults-file)'{-F+,--defaults-file=}'[MySQL defaults file]:file:_files' \
  '(-h --host)'{-h+,--host=}'[MySQL host]:host:_hosts' \
  '--ignore-case[case-insensitive variable comparison (default)]' \
  '--no-ignore-case[case-sensitive variable comparison]' \
  '*--ignore-variables=[variables to exclude from comparison]:vars' \
  '(-s --mysql_ssl)'{-s+,--mysql_ssl=}'[create SSL MySQL connection]:int' \
  '(-p --password)'{-p+,--password=}'[MySQL password]:password' \
  '--pid=[PID file path]:file:_files' \
  '(-P --port)'{-P+,--port=}'[MySQL port]:port' \
  '--report[print diff report (default)]' \
  '--no-report[suppress diff report output]' \
  '--report-width=[truncate report lines]:cols' \
  '*--set-vars=[set MySQL variables (variable=value pairs)]:vars' \
  '(-S --socket)'{-S+,--socket=}'[MySQL socket file]:file:_files' \
  '(-u --user)'{-u+,--user=}'[MySQL user]:user:_users' \
  '--version-check[check for software updates (default)]' \
  '--no-version-check[skip version update check]' \
  '*:CONFIG (file or DSN):' && ret=0

return ret
