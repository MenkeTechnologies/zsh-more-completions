#compdef foamRun
# Documentation: https://www.openfoam.com/documentation/user-guide/6-solving
# Source: OpenFOAM/OpenFOAM-12 applications/solvers/foamRun/foamRun.C — unified runner for modular solver libraries.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-parallel[run in parallel]' \
    '-roots+[slave root directories]:dirs:_default' \
    '-noFunctionObjects[do not execute functionObjects]' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-region+[mesh region]:region:_default' \
    '-solver+[solver module name (e.g. fluid, incompressibleFluid, isothermalFluid, multiphaseEuler)]:name:(fluid incompressibleFluid isothermalFluid multiphaseEuler multiphaseVoF solid)' \
    && ret=0

return ret
