#compdef mm2gv
# Documentation: man mm2gv(1) (graphviz)
# Source: GraphViz mm2gv — convert Matrix Market (.mm/.mtx) to DOT.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[scale matrix elements to RGB and store as edge color]' \
    '-l[attach label showing filename, node count, edge count]' \
    '-u[treat output graph as undirected]' \
    '-v[store matrix value as edge "len"]' \
    '-U+[square-matrix interpretation]:bflag:(0 1 2 3)' \
    '-o+[output file]:file:_files' \
    '(- *)-?[show usage]' \
    '(- *)-h[show usage]' \
    '*:Matrix Market file:_files -g "*.{mm,mtx}"' \
    && ret=0

return ret
