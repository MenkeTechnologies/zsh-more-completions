#compdef reg_jacobian
# Documentation: https://github.com/KCL-BMEIS/niftyreg
# Source: KCL-BMEIS/niftyreg reg-apps/reg_jacobian.cpp — Jacobian determinant of transformation (C++; single-dash long opts).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-help[show help]' \
    '(- *)-v[print version]' \
    '(- *)-version[print version]' \
    '(-omp --omp)'{-omp+,--omp=}'[OpenMP threads]:n:_default' \
    '(-ref -target)-ref+[reference image]:file:_files -g "*.{nii,nii.gz,hdr,img}"' \
    '-trans+[input transformation]:file:_files' \
    '-jac+[output Jacobian determinant image]:file:_files' \
    '-jacM+[output Jacobian matrix image]:file:_files' \
    '-jacL+[output log-Jacobian determinant image]:file:_files' \
    && ret=0

return ret
