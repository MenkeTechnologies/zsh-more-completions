#compdef qcowinfo qcowmount
# _libqcow — libqcow tools (libyal QEMU QCoW1/QCoW2 image parser; qcowinfo prints metadata for qcow1/qcow2 images including snapshots, qcowmount FUSE-mounts the disk read-only; -h help, -V version, -v verbose, -o image offset, -p password, -k key file; positional argument is the .qcow / .qcow2 file)
# upstream: https://github.com/libyal/libqcow
# Flags from libyal/libqcow qcowtools/qcowinfo.c on tip.

_libqcow() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-k+[key file]:file:_files' \
        '*:QCoW file:_files -g "*.(qcow|qcow2)"'
}

_libqcow "$@"
