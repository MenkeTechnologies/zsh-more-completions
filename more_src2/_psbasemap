#compdef psbasemap
# Documentation: https://docs.generic-mapping-tools.org/latest/basemap.html
# Source: GenericMappingTools/gmt classic-mode basemap — draw a base map frame / scale / rose.
# Reference accessed: 2026-06-10
#
# At minimum one of -B, -L, or -T must be specified.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection]:proj:_default' \
    '-A+[output map-domain polygon coordinates]:opts:_default' \
    '-B+[frame/axes spec]:basemap:_default' \
    '-F+[panel/box around embellishments]:opts:_default' \
    '-L+[map scale bar]:opts:_default' \
    '-Td+[direction (cardinal) rose]:opts:_default' \
    '-Tm+[magnetic rose with declination]:opts:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-t+[transparency percent]:pct:_default' \
    && ret=0

return ret
