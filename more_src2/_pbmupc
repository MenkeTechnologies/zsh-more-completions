#compdef pbmupc
# Documentation: man pbmupc (Netpbm)
# Source: render a UPC barcode as a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s1 -s2)-s1[style 1 (default)]' \
    '(-s1 -s2)-s2[style 2]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:UPC type:' \
    '2:manufacturer code:' \
    '3:product code:' \
    && ret=0

return ret
