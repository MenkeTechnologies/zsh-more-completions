#compdef klee-stats
# Documentation: https://github.com/klee/klee/blob/master/tools/klee-stats/klee-stats
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Removed invented flags: --version, --compare-by, --compare-against,
# --sort-by, --print-rel-pct, --print-abs-cov. Added real:
# --print-abs-times, --print-columns, --grafana, --grafana-host, --grafana-port.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--to-csv[output run.stats data as comma-separated values]' \
  '--table-format=[table format for the summary]:fmt:(klee csv readable-csv plain simple github grid fancy_grid pipe orgtbl jira presto pretty psql rst mediawiki moinmoin youtrack html unsafehtml latex latex_raw latex_booktabs latex_longtable textile tsv)' \
  '--print-all[print all available information]' \
  '--print-rel-times[print only measured time values, relative]' \
  '--print-abs-times[print only measured time values, absolute]' \
  '--print-more[print extra information]' \
  '--print-columns=[comma-separated list of table columns]:columns:' \
  '--grafana[start a grafana web server]' \
  '--grafana-host=[IP address grafana web server should listen to]:host:' \
  '--grafana-port=[port grafana web server should listen to]:port:' \
  '*:KLEE output dir:_files -/' && ret=0

return ret
