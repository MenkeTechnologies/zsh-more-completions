#compdef sox
# Documentation: https://manpages.debian.org/sox.1
# Source: SoX (Sound eXchange) — audio file converter + effects engine.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-t,--type=}'[file type (for raw/unknown formats)]:type:(raw wav mp3 ogg flac aiff au sndr voc 8svx amb avr cdda cdr maud nist prc smp sndt txw vox xa al la sl ul)' \
    '*'{-r,--rate=}'[sample rate (Hz or kHz with k suffix)]:hz:' \
    '*'{-b,--bits=}'[sample bit-depth]:bits:(8 16 24 32 64)' \
    '*'{-c,--channels=}'[number of channels]:n:(1 2 4 6 8)' \
    '*'{-e,--encoding=}'[audio encoding]:enc:(signed-integer unsigned-integer floating-point a-law u-law oki-adpcm ima-adpcm ms-adpcm gsm-full-rate mu-law)' \
    '(-L --endian -B --endian -x --endian)'{-L,--endian=little}'[little-endian samples]' \
    '(-L --endian -B --endian -x --endian)'{-B,--endian=big}'[big-endian samples]' \
    '(-L --endian -B --endian -x --endian)'{-x,--endian=swap}'[swap endianness]' \
    '*'{-v,--volume=}'[volume factor for the file]:factor:' \
    '(-q --no-show-progress -S --show-progress)'{-q,--no-show-progress}'[quiet mode]' \
    '(-q --no-show-progress -S --show-progress)'{-S,--show-progress}'[show input format + progress]' \
    '-V[verbosity level]:level:(0 1 2 3 4)' \
    '-G[guard against clipping (auto gain)]' \
    '(-D)-D[disable automatic dither]' \
    '--buffer=[processing buffer size in bytes]:bytes:' \
    '--norm=-[auto-normalize (optional dB level)]:db:' \
    '--no-glob[do not glob filenames]' \
    '--no-clobber[prompt before overwrite]' \
    '--plot=[plotting mode]:mode:(gnuplot octave off)' \
    '(--multi-threaded --single-threaded)--multi-threaded[per-channel parallel processing]' \
    '(--multi-threaded --single-threaded)--single-threaded[single-threaded processing]' \
    '--combine=[input combining method]:method:(concatenate merge mix mix-power multiply sequence)' \
    '--temp=[temp file directory]:dir:_directories' \
    '--help-effect=[help for an effect]:effect:' \
    '*:input/output file or effect:_files' \
    && ret=0

return ret
