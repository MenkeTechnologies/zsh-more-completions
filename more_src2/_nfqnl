#compdef nfqnl
# _nfqnl — netfilter libnetfilter_queue userspace helper (reader that attaches to a kernel NFQUEUE queue and dispatches packets to a user verdict; -q queue number, -p pcap output, -d daemonize, -v verbose, -V version; useful when configuring iptables --jump NFQUEUE --queue-num N)
# upstream: https://git.netfilter.org/libnetfilter_queue (utils)
# Flags from libnetfilter_queue examples/nf-queue.c on tip.

_nfqnl() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-q+[queue number]:n:' \
        '-p+[pcap output]:file:_files -g "*.(pcap|pcapng)"' \
        '-d[daemonize]' \
        '-v[verbose]'
}

_nfqnl "$@"
