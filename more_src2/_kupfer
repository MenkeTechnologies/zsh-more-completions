#compdef kupfer
# _kupfer — Kupfer (Python+GTK keyboard-driven application launcher; --no-splash skips first-run dialog, --debug prints actions to stdout, --relay forwards remote actions to a running instance, --quit exits the running instance, --no-status-icon hides tray icon)
# upstream: https://github.com/kupferlauncher/kupfer
# Flags from kupfer kupfer/main.py on tip.

_kupfer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[print debug actions]' \
        '--no-splash[no first-run dialog]' \
        '--no-status-icon[hide tray icon]' \
        '--relay[relay actions to running instance]' \
        '--quit[quit running instance]' \
        '--bring-up[bring up running instance]' \
        '--list-actions[list all actions and exit]' \
        '--exec-action+[run action by name]:action:' \
        '*::query:'
}

_kupfer "$@"
