#compdef ldns-signzone
# _ldns-signzone — NLnet Labs ldns-signzone (DNSSEC zone signer; signs zonefiles with one or more DNSSEC keys, supports ZONEMD)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from examples/ldns-signzone.c usage on tip.

_ldns-signzone() {
    _arguments \
        '-b[layout signed zone + emit DNSSEC comments]' \
        '-d[do not add used keys to the zone]' \
        '-e+[expiration date (YYYYMMDD[HHMMSS] or +N)]:date:' \
        '-f+[output file (default <name>.signed)]:file:_files' \
        '-i+[inception date]:date:' \
        '-o+[origin for the zone]:domain:' \
        '-u[set SOA serial to seconds since epoch]' \
        '-v[show version and exit]' \
        '*-z+[add ZONEMD record (scheme:hash)]:zonemd:' \
        '-Z[allow ZONEMDs without signing]' \
        '-O[only calculate + sign ZONEMD for the input zone]' \
        '-A[sign DNSKEY with all keys (not minimal)]' \
        '-U[sign once per unique algorithm in the keys]' \
        '-E+[crypto engine name (OpenSSL)]:engine:' \
        '*-k+[engine key alg,key]:keyspec:' \
        '1:zonefile:_files' \
        '*:keyfile-basename:_files'
}

_ldns-signzone "$@"
