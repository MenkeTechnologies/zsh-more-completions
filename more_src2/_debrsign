#compdef debrsign
# Documentation: https://manpages.debian.org/debrsign
# Source: debian/devscripts scripts/debrsign.sh — GPG-sign a Debian upload on a remote host (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-p+[signing command]:cmd:_command_names' \
    '-e+[maintainer]:maintainer:_default' \
    '-m+[maintainer (same as -e)]:maintainer:_default' \
    '-k+[GPG key id]:keyid:_default' \
    '-S[use changes file made for source-only upload]' \
    '-a+[Debian target architecture]:arch:_default' \
    '-t+[GNU target architecture]:target:_default' \
    '--multi[use most recent multiarch .changes]' \
    '--path=-[remote GPG binary directory]:dir:_files -/' \
    '--help[show help]' \
    '--version[show version]' \
    '1:user@remotehost:_default' \
    '*:changes/dsc file:_files -g "*.{changes,dsc}"' \
    && ret=0

return ret
