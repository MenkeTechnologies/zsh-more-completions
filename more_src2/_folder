#compdef folder folders
# Documentation: man folder(1) / folders(1)
# Source: nmh uip/folder.c (master) — set/list nmh folders (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-all -noall)-all[show information about all folders]' \
    '(-all -noall)-noall[do not show all folders]' \
    '(-create -nocreate)-create[create folder if missing]' \
    '(-create -nocreate)-nocreate[do not create folder]' \
    '(-fast -nofast)-fast[fast output (no message counts)]' \
    '(-fast -nofast)-nofast[full output]' \
    '(-header -noheader)-header[print header line]' \
    '(-header -noheader)-noheader[no header]' \
    '(-pack -nopack)-pack[renumber messages]' \
    '(-pack -nopack)-nopack[no pack]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '(-recurse -norecurse)-recurse[recursively list subfolders]' \
    '(-recurse -norecurse)-norecurse[do not recurse]' \
    '(-total -nototal)-total[show grand total]' \
    '(-total -nototal)-nototal[no grand total]' \
    '(-list -nolist)-list[list folders on stdout]' \
    '(-list -nolist)-nolist[no list]' \
    '(-print -noprint)-print[print folder info]' \
    '(-print -noprint)-noprint[no print]' \
    '(-push -pop)-push[push folder onto stack]' \
    '(-push -pop)-pop[pop folder from stack]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
