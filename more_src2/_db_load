#compdef db_load
# Documentation: db_load usage (Berkeley DB 18.1.40)
# Source: load a Berkeley DB database from db_dump output.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-n[no-overwrite mode]' \
    '-T[text format input]' \
    '*-c+[set name=value DB config]:key=value:' \
    '-f+[input file]:file:_files' \
    '-h+[environment home]:dir:_files -/' \
    '-P+[password]:password:' \
    '-t+[database access method]:type:(btree hash recno queue)' \
    '-r+[LSN or fileid for log-record recovery]:lsn or fileid:' \
    '-b+[blob directory]:dir:_files -/' \
    '-o+[blob threshold]:threshold:' \
    '1:db file:_files' \
    && ret=0

return ret
