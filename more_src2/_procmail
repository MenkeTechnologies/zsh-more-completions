#compdef procmail
# _procmail — Stephen R. van den Berg's procmail (autonomous mail processor / MDA; reads message on stdin, applies recipes from procmailrc to filter and deliver mail)
# upstream: https://github.com/BuGlessRB/procmail
# Flags from src/procmail.c + man/procmail.man on tip; option letters come from autoconf substitutions but the defaults below match the standard install.

_procmail() {
    _arguments \
        '-v[print version + compile-time configuration and exit]' \
        '-p[preserve old environment]' \
        '-t[tempfail mode (requeue undeliverable instead of bouncing)]' \
        '-f+[regenerate leading From_ line with fromwhom]:fromwhom:' \
        '-o[override fake From_ lines]' \
        '-B[assume traditional Berkeley mailbox (ignore Content-Length:)]' \
        '-Y[same as -B (backwards-compat alias)]' \
        '*-a+[set positional parameter ($1, $2, ...)]:argument:' \
        '-d[delivery mode (recipients follow)]' \
        '-m[mail-filter mode (rcfile = first positional arg)]' \
        '-z[zap timestamp updates only]' \
        '*::recipe:_files'
}

_procmail "$@"
