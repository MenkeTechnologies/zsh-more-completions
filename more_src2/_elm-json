#compdef elm-json
# Documentation: https://github.com/zwilias/elm-json
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for elm-json - Elm project manifest management

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'install:install a package'
  'uninstall:uninstall a package'
  'upgrade:upgrade dependencies'
  'new:create a new elm.json file'
  'tree:print the dependency tree'
  'solve:figure out a set of dependencies to use'
  'completions:generate shell completions'
  'help:show help for a subcommand'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '(-V --version)'{-V,--version}'[show elm-json version]' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--offline[disable all HTTP requests]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'elm-json command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (install)
        _arguments \
          '--test[install as test-dependency]' \
          '--yes[skip confirmation prompts]' \
          '*:package:' && ret=0
        ;;
      (uninstall)
        _arguments \
          '--yes[skip confirmation prompts]' \
          '*:package:' && ret=0
        ;;
      (upgrade)
        _arguments \
          '--unsafe[allow major version bumps]' \
          '--yes[skip confirmation prompts]' && ret=0
        ;;
      (solve)
        _arguments \
          '(-m --minimize)'{-m,--minimize}'[select lowest available versions]' \
          '--test[treat test-dependencies as top-level]' \
          '(-e --extra)'{-e,--extra}'[additional dependency]:dep:' \
          '*:package:' && ret=0
        ;;
      (new)
        _arguments '1:file:_files' && ret=0
        ;;
      (tree)
        _arguments \
          '--test[include test dependencies]' \
          '1:elm.json:_files -g "elm.json"' && ret=0
        ;;
      (completions)
        _arguments '1:shell:(bash zsh fish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
