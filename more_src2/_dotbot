#compdef dotbot
# Documentation: https://github.com/anishathalye/dotbot
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dotbot - dotfile bootstrapper

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  {-c,--config-file}'=[configuration file]:config file:_files' \
  {-d,--base-directory}'=[base directory]:directory:_directories' \
  '--plugin-dir=[directory to load plugins from]:directory:_directories' \
  '*'{-p,--plugin}'=[plugin file]:plugin file:_files' \
  '--disable-built-in-plugins[disable built-in plugins]' \
  '--only=[run only the specified directives]:directives:' \
  '--except=[run all directives except the specified]:directives:' \
  '--no-color[disable color output]' \
  '-x[exit on error]' \
  '--exit-on-failure[exit on error]' \
  '-n[dry run, do not modify files]' \
  '--dry-run[dry run, do not modify files]' \
  {-Q,--super-quiet}'[suppress almost all output]' \
  {-q,--quiet}'[suppress most output]' \
  {-v,--verbose}'[enable verbose output]'
