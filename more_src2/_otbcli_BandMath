#compdef otbcli_BandMath
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_BandMath.html
# Source: orfeotoolbox/OTB BandMath application — muParser pixel-math across raster bands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-il+[input image list (operands)]:images:_files' \
    '-out+[output image]:image:_files' \
    '-exp+[muParser mathematical expression]:expr:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
