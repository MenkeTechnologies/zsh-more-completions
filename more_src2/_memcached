#compdef memcached
# Documentation: https://manpages.debian.org/testing/memcached/memcached.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream memcached(1) man page.

# Zsh completion for memcached - distributed memory object caching system

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-p --port)'{-p,--port}'[TCP port to listen on]:port' \
  '(-U --udp-port)'{-U,--udp-port}'[UDP port to listen on]:port' \
  '(-s --unix-socket)'{-s,--unix-socket}'[UNIX socket to listen on]:path:_files' \
  '(-a --unix-mask)'{-a,--unix-mask}'[UNIX socket access mask]:mask' \
  '(-A --enable-shutdown)'{-A,--enable-shutdown}'[enable ascii shutdown command]' \
  '(-l --listen)'{-l,--listen}'[interface to listen on]:address' \
  '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
  '(-r --enable-coredumps)'{-r,--enable-coredumps}'[raise core file size limit]' \
  '(-u --user)'{-u,--user}'[assume identity of user]:user:_users' \
  '(-m --memory-limit)'{-m,--memory-limit}'[max memory to use in megabytes]:MB' \
  '(-M --disable-evictions)'{-M,--disable-evictions}'[return error on memory exhausted]' \
  '(-c --conn-limit)'{-c,--conn-limit}'[max simultaneous connections]:connections' \
  '(-k --lock-memory)'{-k,--lock-memory}'[lock down paged memory]' \
  '(-v --verbose)'{-v,--verbose}'[verbose (multiple for more)]' \
  '(-i --license)'{-i,--license}'[print licenses]' \
  '(-P --pidfile)'{-P,--pidfile}'[save PID in file]:file:_files' \
  '(-f --slab-growth-factor)'{-f,--slab-growth-factor}'[chunk size growth factor]:factor' \
  '(-n --slab-min-size)'{-n,--slab-min-size}'[min allocated space for key+value+flags]:bytes' \
  '(-t --threads)'{-t,--threads}'[number of threads]:threads' \
  '-D[delimiter for key prefix stats]:char' \
  '(-R --max-reqs-per-event)'{-R,--max-reqs-per-event}'[max requests per event]:requests' \
  '(-C --disable-cas)'{-C,--disable-cas}'[disable use of CAS]' \
  '(-b --listen-backlog)'{-b,--listen-backlog}'[set backlog queue limit]:limit' \
  '(-B --protocol)'{-B,--protocol}'[binding protocol]:protocol:(auto binary ascii)' \
  '(-I --max-item-size)'{-I,--max-item-size}'[max item size]:size' \
  '(-S --enable-sasl)'{-S,--enable-sasl}'[enable SASL authentication]' \
  '(-F --disable-flush-all)'{-F,--disable-flush-all}'[disable flush_all command]' \
  '(-X --disable-dumping)'{-X,--disable-dumping}'[disable stats cachedump commands]' \
  '(-L --enable-largepages)'{-L,--enable-largepages}'[enable large memory pages]' \
  '(-o --extended)'{-o,--extended}'[extended/experimental options]:options'
