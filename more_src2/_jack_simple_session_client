#compdef jack_simple_session_client
# Documentation: https://github.com/jackaudio/jack-example-tools/blob/main/example-clients/simple_session_client.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jack_simple_session_client: minimal JACK session-aware client.
# Source main() takes NO option flags; an optional single positional
# arg is the JACK session UUID. Removed fabricated
# -n/-s/--name/--server/-h/--help flags (not in source).
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:session uuid:' && ret=0
return ret
