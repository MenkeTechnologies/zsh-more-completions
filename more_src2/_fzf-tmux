#compdef fzf-tmux
# Documentation: https://github.com/junegunn/fzf
# Source: junegunn/fzf bin/fzf-tmux — wraps fzf in a tmux popup or split pane.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-u -d -l -r -p)-p[popup window (tmux 3.2+; optional WIDTH[%][,HEIGHT[%]])]:size:' \
    '-w[popup width]:width:' \
    '-h[popup height]:height:' \
    '-x[popup column position]:col:' \
    '-y[popup row position]:row:' \
    '(-u -d -l -r -p)-u[split pane upward]:height:' \
    '(-u -d -l -r -p)-d[split pane downward]:height:' \
    '(-u -d -l -r -p)-l[split pane left]:width:' \
    '(-u -d -l -r -p)-r[split pane right]:width:' \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*::fzf options:' \
    && ret=0

return ret
