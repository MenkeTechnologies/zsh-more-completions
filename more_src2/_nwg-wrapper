#compdef nwg-wrapper
# Documentation: https://github.com/nwg-piotr/nwg-wrapper
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nwg-wrapper (GTK3-based wrapper for scripts on Wayland)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[display version information]' \
  '(-s --script)'{-s,--script=}'[script to execute]:script:_files' \
  '(-t --text)'{-t,--text=}'[path to text file to display]:text file:_files' \
  '(-c --css)'{-c,--css=}'[CSS style file]:css file:_files' \
  '(-o --output)'{-o,--output=}'[output to place the window on]:output:' \
  '(-p --position)'{-p,--position=}'[position]:position:(left right)' \
  '(-a --alignment)'{-a,--alignment=}'[vertical alignment]:alignment:(start end)' \
  '(-j --justify)'{-j,--justify=}'[text justification]:justify:(right center)' \
  '(-mt --margin_top)'{-mt,--margin_top=}'[top margin]:pixels:' \
  '(-mb --margin_bottom)'{-mb,--margin_bottom=}'[bottom margin]:pixels:' \
  '(-ml --margin_left)'{-ml,--margin_left=}'[left margin]:pixels:' \
  '(-mr --margin_right)'{-mr,--margin_right=}'[right margin]:pixels:' \
  '(-l --layer)'{-l,--layer=}'[initial layer (1 bottom, 2 top)]:layer:(1 2)' \
  '(-i --invisible)'{-i,--invisible}'[make instance invisible on launch]' \
  '(-sl --sig_layer)'{-sl,--sig_layer=}'[signal for layer switching]:signal:' \
  '(-sv --sig_visibility)'{-sv,--sig_visibility=}'[signal for toggling visibility]:signal:' \
  '(-sq --sig_quit)'{-sq,--sig_quit=}'[signal to quit wrapper instance]:signal:' \
  '(-r --refresh)'{-r,--refresh=}'[refresh rate in milliseconds]:interval:' && ret=0

return ret
