#compdef modd
# Documentation: https://github.com/cortesi/modd/blob/master/cmd/modd/main.go
# Reference accessed: 2026-05-19
# Verified: upstream cmd/modd/main.go (kingpin flag definitions).

# Zsh completion for modd - developer tool that watches files and runs commands

_arguments -s -S \
  '(-f --file)'{-f,--file}'[path to modfile]:config file:_files' \
  '(-c --noconf)'{-c,--noconf}'[do not watch the configuration file]' \
  '(-b --bell)'{-b,--bell}'[ring terminal bell if any command returns an error]' \
  '(-i --ignores)'{-i,--ignores}'[list default ignore patterns and exit]' \
  '(-n --notify)'{-n,--notify}'[send stderr to system notifier on errors]' \
  '(-p --prep)'{-p,--prep}'[run prep commands and exit]' \
  '--debug[enable modd development debugging]' \
  '--exec[execute a command in the built-in shell]:command:' \
  '(- *)--version[show version]' \
  '(- *)--help[show help]'
