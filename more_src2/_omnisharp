#compdef omnisharp omnisharp-roslyn
# Documentation: https://github.com/OmniSharp/omnisharp-roslyn/blob/master/src/OmniSharp.Host/CommandLineApplication.cs
# Reference accessed: 2026-05-20
# Verified: upstream OmniSharp.Host and stdio/http driver sources.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --source)'{-s+,--source=}'[solution or directory]:path:_files' \
  '(-l --loglevel)'{-l+,--loglevel=}'[log level]:level:(Trace Debug Information Warning Error Critical None)' \
  '(-v --verbose -d --debug)'{-v,--verbose}'[set Debug log level]' \
  '(-stdio --stdio)'{-stdio,--stdio}'[use STDIO transport]' \
  '(-lsp --languageserver)'{-lsp,--languageserver}'[use Language Server Protocol]' \
  '(-e --encoding)'{-e+,--encoding=}'[STDIO encoding name]:encoding:' \
  '(-hpid --hostPID)'{-hpid+,--hostPID=}'[host process ID]:pid:' \
  '(-z --zero-based-indices)'{-z,--zero-based-indices}'[use zero-based indices]' \
  '(-p --port)'{-p+,--port=}'[HTTP server port]:port:' \
  '(-i --interface)'{-i+,--interface=}'[HTTP interface]:host:' \
  '*'{-pl+,--plugin=}'[load plugin]:plugin:' \
  '--locale=[locale for localization]:locale:' \
  '(-d --debug -v --verbose)'{-d,--debug}'[wait for debugger to attach]' \
  '*::passthrough:' && ret=0

return ret
