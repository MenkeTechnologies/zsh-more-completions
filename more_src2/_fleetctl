#compdef fleetctl
# Documentation: https://github.com/fleetdm/fleet/tree/main/cmd/fleetctl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fleetctl: GitOps and admin CLI for Fleet (fleetdm/fleet, urfave/cli v2).
_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '--debug[debug HTTP requests]' \
  '--fleet-certificate=[TLS cert path for debugging]:file:_files' \
  '--stdout[print contents to stdout]' \
  '--enable-log-topics=[comma-separated log topics to enable]:topics' \
  '--disable-log-topics=[comma-separated log topics to disable]:topics' \
  '1:command:(api apply delete setup login logout query get config convert goquery user debug preview updates hosts vulnerability-data-stream package generate prepare trigger mdm upgrade-packs run-script gitops generate-gitops new)' \
  '*::arguments:_default'
