  '(-s --no-unused-secondaries)'{-s,--no-unused-secondaries}'[filter out warnings related to unused secondaries]' \
  '--no-self[filter out warnings related to implicit self argument]' \
  '*'{-i+,--ignore=}'[filter out warnings matching patterns (repeatable; concat)]:pattern:' \
  '*'{-e+,--enable=}'[do not filter out warnings matching patterns]:pattern:' \
  '*'{-o+,--only=}'[filter out warnings not matching patterns]:pattern:' \
  '*--operators=[allow compound operators matching patterns]:pattern:' \
  '--std=[standard globals set]:std:(($stds))' \
