  'lua52c:Lua 5.2 with LUA_COMPAT_ALL'
  'lua53:Lua 5.3'
  'lua53c:Lua 5.3 with LUA_COMPAT_5_2'
  'lua54:Lua 5.4'
  'lua54c:Lua 5.4 with LUA_COMPAT_5_3'
  'luajit:LuaJIT 2.x'
  'ngx_lua:OpenResty lua-nginx-module 0.10.10'
  'love:LÖVE game framework globals'
  'luanti:Luanti (Minetest) globals'
