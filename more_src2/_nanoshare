#compdef nanoshare
# ============================================================================
# nanoshare - local screen + audio sharing over WebRTC (Node, MIT)
#
# Author : extoci
# Upstream: https://github.com/extoci/nanoshare
# npm    : nanoshare
#
# nanoshare is a small Bun-runtime Node CLI that shares the current
# desktop screen + system audio over WebRTC to anyone on the local
# network who hits the served URL with the access PIN. Capture is
# done via FFmpeg subprocess into RTP, WebRTC streaming is via
# `werift-webrtc`'s pure-TypeScript stack. PIN auth + session
# cookies gate watch access. Designed for ad-hoc "show my screen
# to a colleague on the same wifi" workflows with zero external
# infrastructure.
#
# The WebRTC lane is built on `werift ^0.22.9` (declared verbatim
# at upstream package.json HEAD), the canonical pure-TypeScript
# WebRTC stack by Yoshiaki Shinya (github.com/shinyoshiaki/werift-
# webrtc, 600+ stars). werift is a port of Pion's WebRTC design
# to TypeScript - it implements the W3C WebRTC 1.0 API surface
# (RTCPeerConnection, RTCDataChannel, RTCRtpSender / RTCRtpReceiver,
# SDP offer/answer) entirely in JavaScript / TypeScript, with no
# native-binding dependency on libwebrtc / Chromium / node-webrtc.
# This makes it the only pure-Node WebRTC implementation in active
# 2026 maintenance (the older `node-webrtc` / `wrtc` package is
# unmaintained and stuck on Node 16).
#
# ----------------------------------------------------------------------------
# AXIS 210 :: WEBRTC (RTC 1.0 / RFC 8825 + RTP/RTCP/SRTP/DTLS/ICE/SCTP)  [CLOSES]
# Round 1330 :: TS-Node slot 3 of 4 :: CLOSES Axis 210 (203rd axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : webrtc-rs/webrtc      [R1328 _h26forge]
#   Go      : pion/webrtc           [R1329 _srs_bench]
#   TS/Node : werift-webrtc         [R1330 THIS FILE]
#
# Round-number landmark R1330. The closure here is structurally
# distinctive: all three lanes converge on Pion's design lineage.
# pion/webrtc shipped in 2018 as the first pure-language WebRTC
# stack; webrtc-rs ported the design to async-Rust in 2020-2021;
# werift-webrtc ported the design to TypeScript starting around
# the same time. All three implement the same wire protocols
# (DTLS/SRTP/SCTP/ICE/RTP/RTCP/SDP) and the same RTCPeerConnection
# API surface but with no shared C/C++ code path between any pair
# of lanes - clean-room ports informed by Pion's pure-Go
# reference. 203rd axis closed in the corpus.
# ============================================================================

_nanoshare() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-p --port)'{-p,--port}'[HTTP server port (default 37777)]:port:' \
        '--pin[access PIN for viewers]:pin:' \
        '(-f --fps)'{-f,--fps}'[capture and encode frame rate (default 30)]:fps:' \
        '(-b --video-bitrate)'{-b,--video-bitrate}'[video bitrate (e.g., 14M, default 14M)]:bitrate:' \
        '--use-hwaccel[enable hardware encoder on macOS (h264_videotoolbox)]' \
        '--source[capture source]:source:(screen testsrc)' \
        '--rtp-port[local RTP ingress port for video (default 5004)]:port:' \
        '--audio[enable system audio streaming]' \
        '--audio-device[override system audio input device]:device:' \
        '--audio-rtp-port[local RTP ingress port for audio (default 5006)]:port:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_nanoshare "$@"
