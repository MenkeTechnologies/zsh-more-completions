#compdef parqeye
# Documentation: https://github.com/kaushiksrini/parqeye
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# parqeye takes a single Parquet file argument and launches an
# interactive TUI; no documented flags beyond the path.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '*:parquet file:_files -g "*.parquet"' && ret=0

return ret
