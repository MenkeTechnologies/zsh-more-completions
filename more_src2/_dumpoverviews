#compdef dumpoverviews
# Documentation: https://github.com/OSGeo/gdal
# Source: OSGeo/gdal apps/dumpoverviews.cpp — dump GDAL raster overviews + masks to TIFF (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '-masks[also dump mask overviews]' \
    '1:filename:_files -g "*.{tif,tiff,vrt,nc,hdf,jp2}"' \
    '*:overview indices:_default' \
    && ret=0

return ret
