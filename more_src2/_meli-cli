#compdef meli-cli meli
# _meli-cli — Manos Pitsidianakis meli terminal mail reader CLI alias (meli team, Rust); clap-rs
# upstream: https://github.com/meli/meli

_meli-cli() {
    local -a sub=(
        'create-config:create default config'
        'test-config:test config'
        'view:view email file'
        'compiled-with:show compile features'
        'edit-config:open editor on config'
        'man:print manual page'
        'install-man:install man pages'
        'tools:imap:imap tools'
        'tools:smtp:smtp tools'
        'tools:imap:listen:listen to IMAP idle'
        'tools:smtp:send-mail:send mail via SMTP'
        'help:show help'
        'version:show version'
        'print-config:print config'
        'print-account:print account info'
        'print-account-config:print account config'
        'completion:generate completion'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--no-config[no config]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--no-tui[no TUI]' \
        '--log-level=+[level]:l:(trace debug info warn error)' \
        '--log-dest=+[dest]:d:(file stdout)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meli subcommand' sub ;;
        args)
            case $words[1] in
                view) _arguments '1:file:_files' ;;
                print-account|print-account-config) _arguments '1:account:' ;;
                man) _arguments '1:page:(meli meli.conf meli.themes meli-themes meli.conf.5 meli-themes.5)' ;;
                completion) _arguments '1:shell:(bash zsh fish elvish powershell)' ;;
            esac
            ;;
    esac
}

_meli-cli "$@"
