#compdef mp3info mp3info-gtk
# _mp3info — Cedric Tefft Ricardo Cerqueira mp3info MP3 ID3v1 tag editor and audio info reader (mp3info team, C); getopt
# upstream: https://github.com/mp3info/mp3info

_mp3info() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '-G[show genres]' \
        '-a+[artist]:str:' \
        '-A+[album]:str:' \
        '-c+[comment]:str:' \
        '-g+[genre]:str:' \
        '-n+[track]:n:' \
        '-t+[title]:str:' \
        '-y+[year]:str:' \
        '-d[delete tag]' \
        '-D[show tag info]' \
        '-F[run thorough scan]' \
        '-i[show info]' \
        '-x[show extended info]' \
        '-p+[format string]:str:' \
        '-r+[bitrate mode]:m:(m v a)' \
        '-R[show all]' \
        '-f[force read]' \
        '*:mp3 file:_files -g "*.mp3 *.mp2"'
}

_mp3info "$@"
