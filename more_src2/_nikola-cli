#compdef nikola-cli nikola
# _nikola-cli — Roberto Alsina Nikola Python static site generator CLI alias (getnikola team, Python); doit
# upstream: https://github.com/getnikola/nikola

_nikola-cli() {
    local -a sub=(
        'init:initialize new site'
        'new_post:create new post'
        'new_page:create new page'
        'build:build the site'
        'serve:serve the site'
        'auto:build, serve, watch and rebuild'
        'check:check the site for problems'
        'console:interactive python console'
        'deploy:deploy the site'
        'github_deploy:deploy to github pages'
        'theme:download/install theme'
        'plugin:install/upgrade plugin'
        'tabcompletion:emit tab completion script'
        'help:show help'
        'version:show version'
        'list:list tasks'
        'clean:delete build artifacts'
        'forget:forget done tasks'
        'info:show task info'
        'reset-dep:reset dependencies'
        'orphans:find orphans'
        'rss-import:import rss feeds'
        'import_wordpress:import wordpress'
        'import_blogger:import blogger'
        'import_feed:import feed'
        'install_theme:install theme'
        'install_plugin:install plugin'
        'subtheme:create subtheme'
        'mincss:minify css'
        'minify_html:minify html'
        'status:show status'
        'cstatus:concise status'
        'github_deploy:deploy to github pages'
        'serve:serve site'
        'serve:start dev server'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '-d[debug]' \
        '--strict[strict mode]' \
        '--conf=+[config file]:file:_files -g "conf.py"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nikola subcommand' sub ;;
        args)
            case $words[1] in
                new_post|new_page) _arguments \
                    '-t+[title]:str:' \
                    '--title=+[title]:str:' \
                    '-a+[author]:str:' \
                    '--author=+[author]:str:' \
                    '--tags=+[tags csv]:str:' \
                    '-c+[content type]:str:' \
                    '--category=+[category]:str:' \
                    '-1[disable two file mode]' \
                    '-e[edit in editor]' \
                    '-d+[date]:str:' \
                    '--date=+[date]:str:' \
                    '-f+[format]:f:(rest markdown html)' \
                    '--format=+[format]:f:(rest markdown html)' \
                    '-s+[schedule]:str:' \
                    '--schedule=+[schedule]:str:' ;;
                init) _arguments '1:dir:_files -/' '--demo[install demo site]' '--quiet[quiet]' ;;
                build|auto|serve) _arguments \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--address=+[address]:host:_hosts' \
                    '-a+[address]:host:_hosts' \
                    '--browser[open browser]' \
                    '-b[open browser]' \
                    '--detach[detach process]' ;;
                check) _arguments \
                    '-l[check links]' \
                    '--links[check links]' \
                    '-f[check files]' \
                    '--files[check files]' \
                    '-c[clean unknown files]' \
                    '--clean-files[clean unknown files]' \
                    '--remote[check remote]' \
                    '-r[check remote]' \
                    '--remote-max-redirects=+[max redirects]:n:' \
                    '--remote-ignore-query[ignore query strings]' ;;
                tabcompletion) _arguments '--hardcode-tasks[hardcode tasks]' '-f+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_nikola-cli "$@"
