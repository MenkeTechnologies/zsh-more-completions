#compdef mft
# Documentation: mft --help
# Source: TeX mft — translate MetaFont / MetaPost source to TeX for printing.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-change=[apply change file]:file:_files -g "*.ch"' \
    '-metapost[assume input is MetaPost source]' \
    '*-style=[mft style file]:file:_files -g "*.mft"' \
    '(- *)-help[show help]' \
    '(- *)-version[show version]' \
    '1:MetaFont / MetaPost source:_files -g "*.{mf,mp}"' \
    && ret=0

return ret
