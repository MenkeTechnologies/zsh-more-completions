#compdef jakt
# =============================================================================
# jakt — the Jakt programming language compiler.  Jakt is a memory-safe systems
#        language created by Andreas Kling (founder of SerenityOS, ex-Apple
#        WebKit engineer) and JT (Jonathan Turner, ex-Mozilla/Microsoft Rust
#        and TypeScript core teams, creator of Nushell).  Jakt compiles to
#        modern C++ using AK (the SerenityOS Adopted Kernel library) as the
#        standard library, and is the official application programming
#        language of the SerenityOS operating system.
#
# Author:  Andreas Kling, JT, SerenityOS contributors
# Source:  https://github.com/SerenityOS/jakt
# CLI:     selfhost/main.jakt (entry point), runtime/jaktlib/arguments.jakt
# Library: jakt::arguments::ArgsParser   (Jakt stdlib hand-rolled CLI parser)
# License: BSD-2-Clause
# Status:  Active development — 2,989+ stars, self-hosted compiler (Stage 0 →
#          Stage 1 bootstrap via C++ codegen).  Jakt is the modern successor
#          to SerenityOS C++ application code and is one of the most active
#          systems-language projects of the SerenityOS ecosystem.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — JAKT IS NOW LANGUAGE 43
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 42 to 43 documented languages.  Jakt joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, and now Jakt.
# jakt is documented as the FIRST Jakt CLI library variant in the taxonomy
# (jakt::arguments::ArgsParser) — bringing the total to 196 cross-language
# CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS JAKT AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# Jakt is a memory-safe systems programming language designed for application
# development on SerenityOS.  Created in 2022 by Andreas Kling and JT, Jakt
# compiles to modern C++ (C++20) using the AK standard library — the same
# template-heavy header-only library that powers the entire SerenityOS userland.
# Jakt is self-hosted: the compiler is itself written in Jakt and bootstraps
# via a C++-emitted Stage 0 binary that re-compiles the Stage 1 selfhost.
#
# Jakt is distinct from every other language documented in the corpus because:
#
#   * It is the FIRST documented language designed to TARGET C++ AS A RUNTIME.
#     Most compiled-to-C languages (Nim, Vala, Pony's earlier prototypes,
#     V's optional C backend) target C; Jakt targets C++20 specifically to
#     leverage AK's template metaprogramming, RAII destructors, exception
#     unwinding, and the existing SerenityOS userland ABI.  This is closer
#     to Carbon's relationship with C++ than to Rust's relationship with LLVM.
#   * It uses TRUE STRUCTURED ERROR HANDLING via `throws`/`try`/`must` — every
#     function that can fail is annotated `throws` at the type level
#     (similar to Swift, Java checked exceptions, or C++ noexcept inversion);
#     callers must use `try` to propagate, `must` to assert success at runtime,
#     or pattern-match the result.  Errors are `Error` types backed by errno
#     or `from_string_literal`; they are NOT thrown-and-caught at runtime in
#     the C++ sense — they compile to early-return tagged-union plumbing.
#   * It has FIRST-CLASS REFERENCE TYPES distinct from POINTERS: `&T` for
#     immutable borrowed reference, `&mut T` for mutable borrowed reference,
#     `raw T*` for explicit pointer escape hatch.  Unlike Rust's borrow checker
#     Jakt does NOT track aliasing at compile time — references are RUNTIME
#     non-null guarantees, with a future plan for static analysis.
#   * It has NAMED ARGUMENTS BY DEFAULT: `foo(name: "Alice", age: 30)` is
#     idiomatic and the compiler refuses positional calls for multi-argument
#     functions unless `anon` is specified per parameter.
#   * It has BUILT-IN ARRAY, DICTIONARY, SET, TUPLE, OPTIONAL with concise
#     literal syntax: `[1, 2, 3]`, `[String:Int](["one":1, "two":2])`,
#     `{1, 2, 3}`, `(1, "hi", true)`, `Int?`.
#   * It has YIELD-MATCH (`match x { Foo => { yield 1 } else => yield 2 }`),
#     making `match` an EXPRESSION returning a value (like Rust match or
#     Scala match).
#   * It has SELFHOST-FIRST DEVELOPMENT — the compiler bootstraps through its
#     own C++ emission; there is no separate "frontend" or LLVM IR step.
#
# -----------------------------------------------------------------------------
# JAKT'S OFFICIAL CLI LIBRARY — jakt::arguments::ArgsParser
# -----------------------------------------------------------------------------
#
# Jakt ships a hand-rolled CLI parser in its standard library at
# `runtime/jaktlib/arguments.jakt`.  This is THE Jakt CLI library variant —
# the official, stdlib-blessed, used-by-the-compiler-itself CLI parser.
# There is no competing third-party Jakt CLI library because the Jakt
# ecosystem is too young; the stdlib parser is the canonical choice.
#
# The ArgsParser struct (verbatim from runtime/jaktlib/arguments.jakt):
#
#     struct ArgsParser {
#         args: [String]
#         removed_indices: [usize]
#         definitely_positional_args: [String]
#
#         fn flag(mut this, anon names: [String]) throws -> bool
#         fn option(mut this, anon names: [String]) throws -> String?
#         fn option_multiple(mut this, anon names: [String]) throws -> [String]
#         fn from_args(anon args: [String]) -> ArgsParser
#         fn remaining_arguments(this) -> [String]
#     }
#
# API SURFACE (from runtime/jaktlib/arguments.jakt):
#
#   ArgsParser::from_args(args)             — construct parser from argv slice.
#                                              Splits on `--` to mark explicit
#                                              positional-only segment.
#   parser.flag(["--verbose", "-v"])         — check if any of the given names
#                                              appears in argv.  Returns bool.
#                                              Consumes the flag (marks the
#                                              index as removed).
#   parser.option(["--output", "-o"])        — extract a String value associated
#                                              with one of the given names.
#                                              Supports BOTH:
#                                                * separated: `--output FILE`
#                                                * attached:  `--output=FILE`
#                                                             `-oFILE`
#                                              Returns Option<String>.
#                                              Throws if name is found but
#                                              no following value exists.
#   parser.option_multiple(["--include"])    — same as option() but collects
#                                              every occurrence.  Returns
#                                              Array<String>.
#   parser.remaining_arguments()             — all argv slots NOT consumed by
#                                              flag()/option()/option_multiple,
#                                              with `--` positional segment
#                                              appended verbatim.
#
# JAKT'S ArgsParser IS DISTINCT FROM EVERY OTHER CLI LIBRARY DOCUMENTED BECAUSE:
#
#   * It is HAND-ROLLED for Jakt's own self-hosting needs.  The compiler binary
#     (selfhost/main.jakt) uses ArgsParser directly to parse its own argv,
#     making this the FIRST documented "stdlib CLI parser used by the language's
#     OWN COMPILER" pattern (distinct from Rust's clap which is not in std,
#     Go's flag which is in std but compilers like rustc/zigc don't use it,
#     Swift's ArgumentParser which is not in std).
#   * It has EXPLICIT `--` POSITIONAL TERMINATOR semantics with the entire
#     post-`--` segment captured as `definitely_positional_args` before any
#     flag/option parsing begins — this matches POSIX convention exactly.
#   * It supports BOTH attached (`-oFILE`) AND separated (`-o FILE`) value
#     syntaxes via the `starts_with(name)` fallback path, which mirrors the
#     LINKER ARGV CONVENTION documented for R454 wild and used by GNU ld /
#     LLD / mold (NOT a general-purpose POSIX-style convention).
#   * It is throws-typed at the API surface — every method that can fail is
#     `throws` and must be invoked with `try` from callers.  This integrates
#     ArgsParser into Jakt's STRUCTURED ERROR HANDLING — failures during
#     argv parsing don't panic, they propagate as `Error` values.
#   * It is INDEX-CONSUMING via `removed_indices: [usize]` rather than
#     mutation-of-argv — the original argv slice is preserved, with consumed
#     indices marked as removed.  This allows multiple parsing passes against
#     the same argv.
#   * The names: `[String]` parameter takes a LIST of aliases for the same
#     flag, so a single `parser.flag(["-v", "--verbose", "-V"])` call accepts
#     any of those names without separate registration.
#
# CONTRAST WITH OTHER COMPILER CLI PARSERS DOCUMENTED IN THE CORPUS
#
#   * rustc                     — hand-rolled getopt-style argv parser
#   * zigc                      — hand-rolled stdlib getopts call
#   * gcc                       — hand-rolled spec-file driver (since 1987)
#   * clang driver              — hand-rolled DriverOption table from .td files
#   * mold / wild / GNU ld      — hand-rolled linker-convention parser (R454)
#   * crystal compiler          — uses Crystal stdlib OptionParser
#   * scala compiler            — uses scala.tools.cmd.Settings hand-rolled
#   * elixir compiler           — uses Erlang :init.get_argument
#   * ocaml compiler            — uses Arg stdlib module
#   * haskell ghc               — uses System.Console.GetOpt + hand-rolled
#   * pony compiler             — uses cli stdlib package
#   * jakt compiler             — uses jakt::arguments::ArgsParser stdlib  ← THIS
#
# jakt's ArgsParser is closest in spirit to OCaml's Arg, Pony's cli stdlib,
# and Crystal's OptionParser — all stdlib-blessed parsers used by the
# language's own self-hosted compiler.  But Jakt's is unique in being
# throws-typed at the API level, which no other documented stdlib CLI is.
#
# -----------------------------------------------------------------------------
# JAKT'S CLI SURFACE (extracted verbatim from selfhost/main.jakt help() string)
# -----------------------------------------------------------------------------
#
# USAGE: jakt [cross] [-h] [OPTIONS] <filename>
#
# Top-level mode selector:
#   cross                  Enter cross-compilation mode (subset of options below)
#
# General (non-cross mode):
#   -h, --help             Print help and exit
#   -v, --version          Print compiler version and exit
#   -cr, --compile-run     Build and run an executable file
#   -r, --run              Run the given file without compiling
#                          (positional args after filename passed to main)
#   --repl                 Start Read-Eval-Print loop session
#   --create NAME          Create sample project in $PWD/NAME
#
# Compilation:
#   --config KEY=VALUE     Set a user configuration value
#   -c, --check-only       Only check the code for errors
#   -d                     Insert debug statement spans in generated C++ code
#   -O                     Build an optimized executable
#   -S, --emit-cpp-source-only   Only output source (do not build)
#   --ak-is-my-only-stdlib       Forget about interop, AK is the one STL
#   --cxx-compiler-path PATH     Path of C++ compiler (default: clang++)
#   -M, --dep-file FILE          Emit depfile listing dependencies
#   --extra-cpp-flag FLAG        Pass FLAG to compiler (repeatable)
#   --use-ccache                 Use ccache when compiling
#   -o, --output-filename FILE   Name of output binary
#   -B, --binary-dir PATH        Output directory for compiled files
#   -E, --exports-dir PATH       Output directory for exported files
#   -I PATH                      Add PATH to compiler include list (repeatable)
#   -J, --jobs NUMBER            Number of jobs to run in parallel (default 2)
#   -L PATH                      Add PATH to linker search list (repeatable)
#   -l, --link-with LIB          Link with LIB (repeatable)
#   -T, --target-triple TARGET   Target triple (default: native)
#   -Wl ARG                      Pass ARG to linker (repeatable)
#   -X FILE                      Pass FILE to compiler (repeatable)
#
# Debugging:
#   -dl                          Print debug info for the lexer
#   -dp                          Print debug info for the parser
#   -dt                          Print debug info for the typechecker
#   -fd, --format-debug          Output debug info for the formatter
#   -p, --prettify-cpp-source    Run emitted C++ through clang-format
#   -D, --dot-clang-format-path PATH    Path to .clang-format file
#   -F, --clang-format-path PATH        Path to clang-format executable
#   --debug-print                Output debug print
#   --debug-print-cpp-import     Output debug print for C++ import processor
#
# Formatting:
#   -f, --format                 Format file or directory, output result
#   -fi, --format-inplace        Format file or directory, save in place
#   -fr, --format-range RANGE    Emit part of document with formatting applied
#
# IDE integration:
#   -e, --hover INDEX            Return type of element at index
#   -g, --goto-def INDEX         Return span for definition at index
#   -H, --type-hints             Emit machine-readable type hints
#   -m, --completions INDEX      Return dot completions at index
#   --print-symbols              Emit machine-readable (JSON) symbol tree
#   --try-hints                  Emit machine-readable try hints
#   -t, --goto-type-def INDEX    Return span for type definition at index
#
# Misc:
#   --discover                   Discover all files, print deps + outputs, exit
#   -j, --json-errors            Emit machine-readable (JSON) errors
#   --runtime-library-path PATH  Path to runtime library
#   --runtime-path PATH          Path to host runtime headers
#   -R, --runtime-path PATH      Path of Jakt runtime headers
#   --assume-main-file-path PATH Assume main file is at PATH
#
# Cross mode (jakt cross [OPTIONS]):
#   --source-file PATH           Source file to compile
#   -T, --target-triple TARGET   Target triple
#   --sysroot PATH               Sysroot for build
#   --system-include-dir PATH    System include directory
#   --system-lib-dir PATH        System library directory
#   --compiler-include-dir PATH  Compiler include directory
#   --compiler-lib-dir PATH      Compiler library directory
#   --install-root PATH          Root directory to install to
#   --only-support-libs          Only build/install support libraries
#   --target-links-ak            Assume AK provided by target platform
#   --runtime-lib-path PATH      Path to host runtime library
#
# =============================================================================

_jakt() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a non_cross_args cross_args

    non_cross_args=(
        '(-h --help)'{-h,--help}'[print help and exit]'
        '(-v --version)'{-v,--version}'[print compiler version]'
        '(-cr --compile-run)'{-cr,--compile-run}'[build and run an executable]'
        '(-r --run)'{-r,--run}'[run file without compiling]'
        '--repl[start REPL session]'
        '--create[create sample project]:project name:'
        '*--config[set user configuration value]:KEY=VALUE:'
        '(-c --check-only)'{-c,--check-only}'[only check code for errors]'
        '-d[insert debug spans in generated C++]'
        '-O[build optimized executable]'
        '(-S --emit-cpp-source-only)'{-S,--emit-cpp-source-only}'[only output C++ source, no build]'
        '--ak-is-my-only-stdlib[AK is the one and only STL (no interop)]'
        '--cxx-compiler-path[C++ compiler path]:compiler:_command_names -e'
        '(-M --dep-file)'{-M,--dep-file}'[emit depfile]:depfile:_files'
        '*--extra-cpp-flag[pass flag to C++ compiler]:flag:'
        '--use-ccache[use ccache when compiling]'
        '(-o --output-filename)'{-o,--output-filename}'[output binary name]:output:_files'
        '(-B --binary-dir)'{-B,--binary-dir}'[output directory for compiled files]:dir:_directories'
        '(-E --exports-dir)'{-E,--exports-dir}'[output directory for exported files]:dir:_directories'
        '*-I+[add path to compiler include list]:include path:_directories'
        '(-J --jobs)'{-J,--jobs}'[parallel jobs]:N:'
        '*-L+[add path to linker search list]:lib path:_directories'
        '*'{-l,--link-with}'[link with library]:lib:'
        '(-T --target-triple)'{-T,--target-triple}'[target triple]:triple:'
        '*-Wl+[pass arg to linker]:linker arg:'
        '*-X+[pass file to compiler]:file:_files'
        '-dl[print lexer debug info]'
        '-dp[print parser debug info]'
        '-dt[print typechecker debug info]'
        '(-fd --format-debug)'{-fd,--format-debug}'[output formatter debug info]'
        '(-p --prettify-cpp-source)'{-p,--prettify-cpp-source}'[run emitted C++ through clang-format]'
        '(-D --dot-clang-format-path)'{-D,--dot-clang-format-path}'[path to .clang-format file]:path:_files'
        '(-F --clang-format-path)'{-F,--clang-format-path}'[clang-format executable path]:exe:_command_names -e'
        '--debug-print[output debug print]'
        '--debug-print-cpp-import[output debug print for cpp import]'
        '(-f --format)'{-f,--format}'[format file/dir and output]'
        '(-fi --format-inplace)'{-fi,--format-inplace}'[format file/dir in place]'
        '(-fr --format-range)'{-fr,--format-range}'[format partial range]:start\:end:'
        '(-e --hover)'{-e,--hover}'[return type at index]:index:'
        '(-g --goto-def)'{-g,--goto-def}'[return span for definition at index]:index:'
        '(-H --type-hints)'{-H,--type-hints}'[emit machine-readable type hints]'
        '(-m --completions)'{-m,--completions}'[return dot completions at index]:index:'
        '--print-symbols[emit JSON symbol tree]'
        '--try-hints[emit machine-readable try hints]'
        '(-t --goto-type-def)'{-t,--goto-type-def}'[return span for type def at index]:index:'
        '--discover[discover files, print deps+outputs, exit]'
        '(-j --json-errors)'{-j,--json-errors}'[emit JSON errors]'
        '--runtime-library-path[runtime library path]:path:_directories'
        '--runtime-path[host runtime headers path]:path:_directories'
        '(-R)-R[Jakt runtime headers path]:path:_directories'
        '--assume-main-file-path[assume main file path]:path:_files'
        '*:source file:_files -g "*.jakt"'
    )

    cross_args=(
        '(-h --help)'{-h,--help}'[print help and exit]'
        '--source-file[source file to compile]:file:_files -g "*.jakt"'
        '(-T --target-triple)'{-T,--target-triple}'[target triple]:triple:'
        '--sysroot[sysroot path]:dir:_directories'
        '--system-include-dir[system include dir]:dir:_directories'
        '--system-lib-dir[system lib dir]:dir:_directories'
        '--compiler-include-dir[compiler include dir]:dir:_directories'
        '--compiler-lib-dir[compiler lib dir]:dir:_directories'
        '--install-root[install root dir]:dir:_directories'
        '--only-support-libs[build/install only support libraries]'
        '--target-links-ak[assume AK provided by target platform]'
        '--runtime-lib-path[host runtime library path]:dir:_directories'
        '*:passthrough to compiler:'
    )

    _arguments -C \
        '1: :->mode' \
        '*::arg:->args' && ret=0

    case $state in
        (mode)
            local -a modes
            modes=(
                'cross:cross-compilation mode'
            )
            _describe -t modes 'jakt mode' modes
            _files -g "*.jakt" && ret=0
            _arguments $non_cross_args && ret=0
            ;;
        (args)
            if [[ $line[1] == "cross" ]]; then
                _arguments $cross_args && ret=0
            else
                _arguments $non_cross_args && ret=0
            fi
            ;;
    esac

    return ret
}

_jakt "$@"
