#compdef gitea-server gitea-web
# _gitea-server — Gitea team gitea web binary CLI subcommand operates as the self-hosted Gitea Git service daemon (gitea team, Go); urfave/cli
# upstream: https://github.com/go-gitea/gitea

_gitea-server() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-p+[port]:port:_ports' \
        '--port=+[port]:port:_ports' \
        '--pid=+[pid file]:file:_files' \
        '-P+[pid file]:file:_files' \
        '-c+[config file]:file:_files -g "app.ini *.ini"' \
        '--config=+[config file]:file:_files -g "app.ini *.ini"' \
        '--custom-path=+[custom path]:dir:_files -/' \
        '-C+[custom path]:dir:_files -/' \
        '--work-path=+[working dir]:dir:_files -/' \
        '-w+[working dir]:dir:_files -/' \
        '--install-lock[lock installer]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]'
}

_gitea-server "$@"
