#compdef icewmhint
# Documentation: https://ice-wm.org/man/icewmhint.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# icewmhint: set IceWM hints on a window
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-V[show version]' \
  '*:hint:(workspace:N layer:N hidden minimized fullscreen sticky skipTaskBar)' && ret=0
return ret
