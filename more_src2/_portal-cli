#compdef portal-cli
# _portal-cli — Chris Badahdah djblue/portal data inspector for clj/cljs/bb/joker CLI alias (djblue team, Clojure); tools.deps function CLI
# upstream: https://github.com/djblue/portal

_portal-cli() {
    local -a sub=(
        'open:open the portal UI'
        'close:close portal'
        'clear:clear portal data'
        'submit:submit edn from stdin'
        'tap:start tap> listener'
        'register:register custom viewer'
        'theme:set theme'
        'http:start http server'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--port=+[port]:port:' \
        '-p+[port]:port:' \
        '--host=+[host]:host:_hosts' \
        '-H+[host]:host:_hosts' \
        '--launcher=+[launcher]:l:(vs-code intellij browser cli web)' \
        '--theme=+[theme]:t:(portal.colors/nord portal.colors/zenburn portal.colors/solarized-light portal.colors/solarized-dark portal.colors/material-ui portal.colors/gruvbox)' \
        '--mode=+[mode]:m:(dev release)' \
        '--no-open[do not open browser]' \
        '--format=+[format]:f:(json edn transit yaml csv)' \
        '--bind=+[bind address]:str:' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'portal subcommand' sub ;;
        args)
            case $words[1] in
                submit) _arguments \
                    '1:edn data:' \
                    '--file=+[input file]:file:_files' \
                    '-f+[input file]:file:_files' ;;
                open) _arguments \
                    '--launcher=+[launcher]:l:(vs-code intellij browser cli web)' \
                    '--theme=+[theme]:str:' \
                    '--port=+[port]:port:' \
                    '--host=+[host]:host:_hosts' \
                    '--no-open[do not open browser]' ;;
                theme) _arguments '1:theme:' ;;
            esac
            ;;
    esac
}

_portal-cli "$@"
