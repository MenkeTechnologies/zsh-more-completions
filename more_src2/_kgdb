#compdef kgdb
# _kgdb — Linux kernel KGDB front-end (Jason Wessel et al, kernel.org); attach gdb to running kernel over serial/eth/usb
# upstream: kernel.org Documentation/dev-tools/kgdb.rst

_kgdb() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '*:vmlinux:_files'
}

_kgdb "$@"
