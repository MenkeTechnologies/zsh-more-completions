#compdef dtool
# dtool - Developer's toolbox CLI (encoding, hashing, conversion, etc.)

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a commands=(
  'h2s:hex to string'
  's2h:string to hex'
  'h2b:hex to binary'
  'b2h:binary to hex'
  'h2a:hex to array'
  'a2h:array to hex'
  's2b:string to binary'
  'b2s:binary to string'
  'ts:timestamp conversion'
  'ns:number system conversion'
  'hash:calculate hash'
  'ue:URL encode'
  'ud:URL decode'
  'he:HTML entity encode'
  'hd:HTML entity decode'
  'be:base64 encode'
  'bd:base64 decode'
  're:regex match'
  'pbkdf2:PBKDF2 derive'
  'case:case conversion'
  'ecdsa:ECDSA utils'
  'sm2:SM2 utils'
  'ed25519:Ed25519 utils'
  'sr25519:Sr25519 utils'
  'aes:AES encrypt/decrypt'
  'jwt:JWT encode/decode'
  'unicode:unicode conversion'
  'hex2b58:hex to base58'
  'hex2b58c:hex to base58check'
  'b582hex:base58 to hex'
  'b58c2hex:base58check to hex'
)

_arguments -C -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'dtool command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      hash)
        _arguments \
          '-a[hash algorithm]:algorithm:(md5 sha1 sha2-224 sha2-256 sha2-384 sha2-512 sha3-224 sha3-256 sha3-384 sha3-512 keccak-224 keccak-256 keccak-384 keccak-512 blake2b-256 blake2b-512 crc32 xxh32 xxh64 sm3 ripemd160)' \
          '*:input:' \
          && ret=0
        ;;
      ns)
        _arguments \
          '-f[from base]:base:(2 8 10 16)' \
          '-t[to base]:base:(2 8 10 16)' \
          '*:number:' \
          && ret=0
        ;;
      ts)
        _arguments '*:timestamp or date:' && ret=0
        ;;
      case)
        _arguments \
          '-t[case type]:type:(lower upper camel snake kebab pascal title)' \
          '*:input:' \
          && ret=0
        ;;
      re)
        _arguments \
          '1:pattern:' \
          '2:input:' \
          && ret=0
        ;;
      aes)
        _arguments \
          '-m[mode]:mode:(ecb cbc ctr)' \
          '-p[padding]:padding:(pkcs7 no)' \
          '-k[key (hex)]:key:' \
          '-i[IV (hex)]:iv:' \
          '-e[encrypt]' \
          '-d[decrypt]' \
          '*:input:' \
          && ret=0
        ;;
      *)
        _arguments '*:input:' && ret=0
        ;;
    esac
    ;;
esac

return ret
