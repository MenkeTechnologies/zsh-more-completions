# iKevinY/EulerPy EulerPy/euler.py (click); Homebrew: Formula/e/euler-py.rb

local ret=1
_arguments -s \
  '(-c --cheat)'{-c,--cheat}'[view official answer]' \
  '(-g --generate)'{-g,--generate}'[generate problem file]' \
  '(-p --preview)'{-p,--preview}'[print problem text]' \
  '(-s --skip)'{-s,--skip}'[skip to next problem]' \
  '(-v --verify)'{-v,--verify}'[verify solution output]' \
  '--verify-all[verify all problem files]' \
  '--version[show EulerPy version]' \
  '::problem number:_default' && ret=0
return ret
