#compdef fan2go
# _fan2go — temperature-driven fan controller daemon (markusressel/fan2go)
# upstream: https://github.com/markusressel/fan2go
# Subcommands from cmd/*.go (cobra).

_fan2go() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.(yml|yaml)"' \
        '--no-color[disable terminal color]' \
        '--no-style[disable terminal styling]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'config:configuration-related commands'
                'curve:curve-related commands'
                'fan:fan-related commands'
                'sensor:sensor-related commands'
                'detect:detect fans and sensors'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                config) _arguments '1:subcommand:(validate)' ;;
                curve)  _arguments '1:subcommand:(list)' ;;
                fan)    _arguments '1:subcommand:(init mode reset rpm speed curve)' ;;
            esac
            ;;
    esac
}

_fan2go "$@"
