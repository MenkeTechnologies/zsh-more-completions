#compdef jamin
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/jamin.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# JAMin: JACK Audio Mastering interface. All options are single-dash;
# no long-form/--server/--no-connect/--version flags exist upstream.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[print usage message]' \
  '(- *)-V[print version and copyright, then quit]' \
  '-f[load session file on startup]:file:_files -g "*.jam"' \
  '-j[connect to JACK server]:server:' \
  '-n[set JACK client name]:name:' \
  '-s[spectrum update frequency per second (1-10)]:freq:' \
  '-c[crossfade time in seconds (0.0-2.0)]:time:' \
  '-p[do not automatically connect JACK output ports]' \
  '-i[use IIR crossover instead of default FFT]' \
  '-l[lookahead limiter type (0 or 1)]:type:(0 1)' \
  '-r[load GTK resource info from example resource file]' \
  '*-v[verbose output (repeat for more detail)]' \
  '*:JACK ports:' && ret=0
return ret
