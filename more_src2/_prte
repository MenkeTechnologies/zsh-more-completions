#compdef prte
# Documentation: https://docs.prrte.org/en/latest/man/man1/prte.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# prte: PMIx Reference Runtime Environment daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help (with optional topic)]' \
  '(-v --verbose)'{-v,--verbose}'[enable typical debug options]' \
  '(- *)'{-V,--version}'[show version]' \
  '--debug-daemons[debug daemons]' \
  '--debug-daemons-file[log daemon debug to file]' \
  '--leave-session-attached[do not discard stdout/stderr of remote daemons]' \
  '--display[display options for information]:options:' \
  '--no-aggregate-help[do not aggregate help output]' \
  '--test-suicide[suicide instead of clean abort after delay]:seconds:' \
  '--runtime-options[runtime directives for the job]:options:' \
  '--default-hostfile[default hostfile]:file:_files' \
  '(-H --host)'{-H,--host}'[list of hosts to use for the DVM]:hosts:' \
  '--hostfile[hostfile]:file:_files' \
  '--machinefile[hostfile synonym]:file:_files' \
  '--pmixmca[pass PMIx MCA parameters]:key value:' \
  '--prtemca[pass PRTE MCA parameters to DVM]:key value:' \
  '--show-progress[periodic DVM startup progress report]' \
  '*-x[export environment variable (var or var=value)]:var:_parameters -g "*export*"' \
  '--allow-run-as-root[allow execution as root]' \
  '--daemonize[daemonize the DVM daemons into the background]' \
  '--forward-signals[additional signals to forward]:signals:' \
  '--keepalive[pipe to monitor; DVM terminates upon closure]:pipe:' \
  '--launch-agent[name of daemon executable on remote nodes]:executable:' \
  '--max-vm-size[max number of daemons to start]:size:' \
  '--no-ready-msg[do not print DVM ready message]' \
  '--noprefix[disable automatic prefix behavior]' \
  '--prefix[prefix for RTE executables on remote nodes]:dir:_files -/' \
  '--pmix-prefix[prefix for PMIx library on remote nodes]:dir:_files -/' \
  '--report-pid[print PID to stdout (-), stderr (+), or file]:target:' \
  '--report-uri[write URI to file/handle]:file:_files' \
  '--system-server[run as system PRRTE]' \
  '--no-daemonize[run in foreground]' && ret=0
return ret
