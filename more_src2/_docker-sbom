#compdef docker-sbom
# docker-sbom: generate SBOM for Docker images (Docker Desktop plugin using Syft)
# https://github.com/docker/sbom-cli-plugin

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-D --debug)'{-D,--debug}'[enable debug logging]' \
  '--format=[output format]:format:(syft-json spdx-json spdx-tag-value cyclonedx-json cyclonedx-xml github table text)' \
  '(-o --output)'{-o+,--output=}'[write output to file]:file:_files' \
  '--platform=[platform for multi-platform images]:platform' \
  '--layers=[scan layer content]:mode:(squashed all)' \
  '--exclude=[exclude paths]:glob pattern' \
  '--quiet[suppress all output except SBOM]' \
  '1:image:_guard "^-*" image'
