#compdef dh-make dh_make
# Documentation: https://manpages.debian.org/bookworm/dh-make/dh_make.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dh-make (dh_make) - Debianize source trees.
# dh-make is the package; dh_make is the binary. Flags are documented in dh_make(1).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --copyright)'{-c,--copyright}'[license type]:license:(gpl gpl2 gpl3 lgpl lgpl2 lgpl3 artistic apache bsd mit custom)' \
  '--copyrightfile[copyright file]:file:_files' \
  '--docs[provide documentation files]' \
  '(-e --email)'{-e,--email}'[maintainer email]:email' \
  '(-n --native)'{-n,--native}'[create a native Debian package]' \
  '(-f --file)'{-f,--file}'[upstream tarball]:tarball:_files -g "*.tar.*(-.)"' \
  '(-l --library)'{-l,--library}'[library package class]' \
  '(-s --single)'{-s,--single}'[single binary package class]' \
  '(-i --indep)'{-i,--indep}'[architecture-independent package class]' \
  '(-a --addmissing)'{-a,--addmissing}'[add missing files to debian directory]' \
  '(-t --templates)'{-t,--templates}'[use templates from directory]:directory:_directories' \
  '(-o --overlay)'{-o,--overlay}'[reuse existing debian directory]:directory:_directories' \
  '(-p --packagename)'{-p,--packagename}'[set package name]:package name' \
  '(-C --packageclass)'{-C,--packageclass}'[set package class directly]:class' \
  '(-d --defaultless)'{-d,--defaultless}'[skip generation of default content]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[automatic yes to prompts]' && ret=0

return ret
