#compdef orogene oro
# Documentation: https://orogene.dev/book/
# Reference accessed: 2026-05-17
# Verified: orogene.dev book + orogene/orogene README. Binary is `oro`.
# Per-subcommand flags not fully published; defer to `oro <cmd> --help`.
# Removed from prior file: bogus man.archlinux.org search URL.

# orogene: Node node_modules/ package manager (binary `oro`)
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'add:add a package to dependencies'
  'apply:apply package set to node_modules'
  'reapply:re-apply package set'
  'remove:remove a package'
  'rm:remove a package'
  'login:login to a registry'
  'logout:logout from a registry'
  'ping:ping a registry'
  'view:view package metadata'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'oro command' commands && ret=0 ;;
esac
return ret
