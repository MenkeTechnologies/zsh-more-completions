#compdef rakarrack
# Documentation: https://manpages.debian.org/bookworm/rakarrack/rakarrack.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show summary of options]' \
  '(-n --no-gui)'{-n,--no-gui}'[disable GUI]' \
  '(-b --Bank)'{-b,--Bank}'[load a Bank File]:file:_files' \
  '(-l --Load)'{-l,--Load}'[load a Preset File]:file:_files' && ret=0

return ret
