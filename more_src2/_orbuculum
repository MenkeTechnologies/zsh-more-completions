#compdef orbuculum
# _orbuculum — orbuculum project orbuculum CLI core daemon collecting raw ARM Cortex-M SWO ITM ETM TPIU trace streams from FTDI Black Magic Probe ORBTrace J-Link USB hardware demuxing to nn channel sockets for downstream orb* clients (Dave Marples team, C); custom argparse
# upstream: https://github.com/orbcode/orbuculum

_orbuculum() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:l:(0 1 2 3 4)' \
        '-a+[ip:port]:host:port:' \
        '-A+[avg report ms]:n:' \
        '-E[engineering mode]' \
        '-f+[file source]:file:_files' \
        '-l+[listen port]:n:' \
        '-m+[number of channels]:n:' \
        '-n[no idle]' \
        '-o+[output file]:file:_files' \
        '-p+[serial port]:file:_files -g "/dev/tty* /dev/cu.*"' \
        '-P+[protocol]:p:(itm tpiu etm)' \
        '-s+[swo speed Hz]:n:' \
        '-T[TPIU framing]' \
        '-t+[orb host]:host:' \
        '-i+[hardware iface]:i:(usb ftdi serial file orbtrace bmp jlink stlink)' \
        '*:config:_files'
}

_orbuculum "$@"
