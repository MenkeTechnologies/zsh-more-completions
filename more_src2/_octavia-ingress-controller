#compdef octavia-ingress-controller
# _octavia-ingress-controller — OpenStack Octavia LBaaS Ingress controller
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from pkg/ingress/cmd/root.go on tip.

_octavia-ingress-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[ingress controller config file]:file:_files -g "*.(yaml|yml)"' \
        '--debug=[print more detailed information]:bool:(true false)' \
        '-v[klog verbosity level]:n:'
}

_octavia-ingress-controller "$@"
