#compdef kristall
# _kristall — Kristall small-internet browser (Qt5); GUI client for gemini://, gopher://, finger://, http(s)://
# upstream: https://kristall.random-projects.net

_kristall() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--stylesheet+[Qt stylesheet]:file:_files -g "*.qss"' \
        '--platform+[Qt platform]:platform:' \
        '--display+[X display]:display:' \
        '*:URL:_urls'
}

_kristall "$@"
