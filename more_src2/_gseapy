#compdef gseapy
# _gseapy — Zhuoqing Fang gseapy Python implementation of Gene Set Enrichment Analysis with prerank ssGSEA Enrichr command line (zqfang team, Python); argparse subcommands
# upstream: https://github.com/zqfang/GSEApy

_gseapy() {
    local -a sub=(
        'gsea:run standard GSEA from expression matrix'
        'prerank:run GSEA from pre-ranked gene list'
        'ssgsea:single-sample GSEA'
        'gsva:GSVA single-sample enrichment'
        'replot:replot enrichment from GSEA results'
        'enrichr:run Enrichr enrichment'
        'biomart:query BioMart database'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gseapy subcommand' sub ;;
        args)
            case $words[1] in
                gsea) _arguments \
                    '-d+[expression matrix]:file:_files -g "*.txt *.tsv *.csv *.gct"' \
                    '--data=+[expression matrix]:file:_files -g "*.txt *.tsv *.csv *.gct"' \
                    '-c+[class file]:file:_files -g "*.cls"' \
                    '--cls=+[class file]:file:_files -g "*.cls"' \
                    '-g+[gene set file]:file:_files -g "*.gmt *.gmx"' \
                    '--gmt=+[gene set file]:file:_files -g "*.gmt *.gmx"' \
                    '-o+[output dir]:dir:_files -/' \
                    '--outdir=+[output dir]:dir:_files -/' \
                    '-n+[N permutations]:n:' \
                    '--permu-num=+[N permutations]:n:' \
                    '-t+[permutation type]:t:(gene_set phenotype)' \
                    '--permu-type=+[permutation type]:t:(gene_set phenotype)' \
                    '-m+[ranking method]:m:(signal_to_noise t_test ratio_of_classes diff_of_classes log2_ratio_of_classes)' \
                    '--method=+[ranking method]:m:(signal_to_noise t_test ratio_of_classes diff_of_classes log2_ratio_of_classes)' \
                    '--min-size=+[N]:n:' \
                    '--max-size=+[N]:n:' \
                    '-w+[weight]:f:' \
                    '--weighted-score-type=+[weight]:f:' \
                    '-r+[rank order]:r:(positive negative)' \
                    '--ascending[ascending order]' \
                    '-s+[seed]:n:' \
                    '--seed=+[seed]:n:' \
                    '-p+[threads]:n:' \
                    '--threads=+[threads]:n:' \
                    '-f+[output format]:f:(png pdf jpg svg)' \
                    '--format=+[output format]:f:(png pdf jpg svg)' \
                    '--graph-num=+[N plots]:n:' \
                    '--no-plot[no plots]' \
                    '-v[verbose]' \
                    '--verbose[verbose]' ;;
                prerank|ssgsea|gsva|replot|enrichr) _arguments \
                    '-r+[rank file]:file:_files -g "*.rnk *.txt *.csv *.tsv"' \
                    '--rnk=+[rank file]:file:_files -g "*.rnk *.txt *.csv *.tsv"' \
                    '-g+[gene set file]:file:_files -g "*.gmt *.gmx"' \
                    '--gmt=+[gene set file]:file:_files -g "*.gmt *.gmx"' \
                    '-o+[output dir]:dir:_files -/' \
                    '--outdir=+[output dir]:dir:_files -/' \
                    '-n+[N permutations]:n:' \
                    '--permu-num=+[N permutations]:n:' \
                    '-s+[seed]:n:' \
                    '--seed=+[seed]:n:' \
                    '--min-size=+[N]:n:' \
                    '--max-size=+[N]:n:' \
                    '-w+[weight]:f:' \
                    '--weighted-score-type=+[weight]:f:' \
                    '-p+[threads]:n:' \
                    '--threads=+[threads]:n:' \
                    '-f+[output format]:f:(png pdf jpg svg)' \
                    '--format=+[output format]:f:(png pdf jpg svg)' \
                    '--ascending[ascending order]' \
                    '-v[verbose]' \
                    '--verbose[verbose]' \
                    '--no-plot[no plots]' ;;
                biomart) _arguments \
                    '--biomart=+[biomart]:str:' \
                    '--dataset=+[dataset]:str:' \
                    '--filters=+[filters json]:str:' \
                    '--attributes=+[attributes csv]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_gseapy "$@"
