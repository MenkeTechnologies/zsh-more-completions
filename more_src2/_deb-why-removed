#compdef deb-why-removed
# Documentation: https://manpages.debian.org/deb-why-removed
# Source: debian/devscripts scripts/deb-why-removed.pl — look up why a Debian package was removed (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help -?)'{-h,--help,-\?}'[show help]' \
    '--version[show version]' \
    {-u+,--url=}'[removed-packages URL]:url:_default' \
    '--no-refresh[do not refresh cached file]' \
    '*:package:_default' \
    && ret=0

return ret
