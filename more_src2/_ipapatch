#compdef ipapatch
# Documentation: https://github.com/asdfzxcvbn/ipapatch/blob/main/cmd.go
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show usage]' \
  '--version[show version]' \
  '--input=[IPA file to patch (required)]:ipa:_files -g "*.ipa"' \
  '--output=[patched IPA path]:ipa:_files' \
  '--dylib=[dylib to use instead of embedded zxPluginsInject]:dylib:_files' \
  '--inplace[overwrite --input file (takes priority over --output)]' \
  '--noconfirm[skip interactive confirmation prompts]' \
  '--plugins-only[inject only into plugin binaries]' \
  '--zip[use zip CLI tool for file removals]'
