#compdef dovecot-sysreport
# Documentation: https://www.mankier.com/1/dovecot-sysreport
# Reference accessed: 2026-05-16
# Verified: dovecot-sysreport(1) manpage.

# dovecot-sysreport: collect Dovecot system info for support
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config=}'[root config file]:file:_files' \
  '(-o --core)'{-o,--core=}'[include core files]:binary core...:_files' \
  '(-d --destination)'{-d,--destination=}'[output archive location]:file:_files' \
  '(-k --keeptemp)'{-k,--keeptemp}'[do not delete temp files]' && ret=0
return ret
