#compdef e2pall
# Documentation: man e2pall(1) (TeX Live)
# Source: TeX e2pall — convert EPS files referenced in a LaTeX source to PDF via epstopdf.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:LaTeX source file:_files -g "*.{tex,ltx,latex}"' \
    && ret=0

return ret
