#compdef jo
# Documentation: https://github.com/jpmens/jo/blob/master/jo.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: -v is "show version" (not -V); -V shows
# version as a JSON object; -e means "ignore empty stdin"; -n means
# "do not add keys with empty values"; added -D (dedup keys) and
# -f (load JSON from file). Removed invented -h (not documented).
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-v[show version and exit]' \
  '(- *)-V[show version as a JSON object and exit]' \
  '-a[interpret words as array values and produce an array]' \
  '-B[disable boolean true/false interpretation]' \
  '-D[deduplicate object keys]' \
  '-d+[key delimiter for nested object paths]:keydelim' \
  '-e[ignore empty stdin]' \
  '-f+[load and modify JSON from file]:file:_files' \
  '-n[do not add keys with empty values]' \
  '-p[pretty-print the JSON output]' \
  '*:word (key=value):' && ret=0

return ret
