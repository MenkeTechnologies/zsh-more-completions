#compdef fickling
# Documentation: https://github.com/trailofbits/fickling
# Reference accessed: 2026-05-23
# Verified: fickling --help (fickling PyPI).

# Zsh completion for fickling - Python pickle static analyzer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-i --inject)'{-i+,--inject=}'[inject Python code into pickle]:code:' \
  '--inject-target[index of pickle in stacked file]:index:' \
  '(-c --create)'{-c+,--create=}'[create pickle from code]:code:' \
  '(-l --run-last)'{-l,--run-last}'[run injected code after existing code]' \
  '(-r --replace-result)'{-r,--replace-result}'[replace unpickling result]' \
  '(-s --check-safety)'{-s,--check-safety}'[test if pickle is unsafe]' \
  '--json-output[output JSON path]:file:_files' \
  '(-p --print-results)'{-p,--print-results}'[print safety results]' \
  '(-t --trace)'{-t,--trace}'[print runtime trace]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '--huggingface[scan HuggingFace model]:repo:' \
  '--hf-revision[HF revision]:revision:' \
  '--hf-token[HF API token]:token:' \
  ':pickle file:_files' && ret=0

return ret
