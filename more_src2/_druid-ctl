#compdef druid
# _druid-ctl — Apache Druid runtime launcher (single-binary entrypoint dispatched to per-role processes: tools, coordinator, broker, historical, middleManager, indexer, overlord, router, peon, coordinator-overlord, real-time, internal-cli, validator, server; -c config dir override, -p properties, -l log file)
# upstream: https://github.com/apache/druid
# Subcommands from Apache Druid bin/start-druid + services on tip.

_druid-ctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[config dir]:dir:_files -/' \
        '-p+[properties file]:file:_files' \
        '-l+[log file]:file:_files' \
        '1: :->role' \
        '*::arg:->args'
    case $state in
        role) _describe -t commands 'druid role' '(tools coordinator broker historical middleManager indexer overlord router peon coordinator-overlord internal-cli validator server)' ;;
        args) _arguments '*:argument:_files' ;;
    esac
}

_druid-ctl "$@"
