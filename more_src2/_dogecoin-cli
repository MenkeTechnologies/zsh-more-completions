#compdef dogecoin-cli
# _dogecoin-cli — Dogecoin Core dogecoin-cli JSON-RPC client CLI for the Scrypt PoW Dogecoin reference daemon issuing wallet getbalance sendtoaddress listunspent generate getblockchaininfo getmempoolinfo addnode setban getnewaddress (dogecoin team, C++); custom argparse
# upstream: https://github.com/dogecoin/dogecoin

_dogecoin-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf dogecoin.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getblockheader getnetworkinfo getmempoolinfo getmininginfo getbalance listunspent listaddressgroupings listtransactions sendtoaddress sendmany getnewaddress getaccountaddress validateaddress dumpprivkey importprivkey importwallet dumpwallet generate generatetoaddress getrawtransaction createrawtransaction signrawtransaction sendrawtransaction decoderawtransaction addnode getpeerinfo getnettotals setban listbanned)'
}

_dogecoin-cli "$@"
