#compdef fsx fsxc
# Documentation: https://github.com/nblockchain/fsx/blob/master/src/fsxc/Fsxc.fs
# Reference accessed: 2026-05-27
# Verified: upstream `ParseArgsInternal` flag list and `PrintUsage` block
# in src/fsxc/Fsxc.fs (nblockchain/fsx). The same binary is launched as
# both `fsx` (script runner) and `fsxc` (compiler-only); both accept the
# same flag set.

_arguments \
  '(- *)--help[show help]' \
  '(-d --debug)'{-d,--debug}'[show debugging information]' \
  '(-f --force)'{-f,--force}'[always regenerate binaries even if existing ones are new enough]' \
  '(-k --check)'{-k,--check}'[only check the script (do not run/produce binaries)]' \
  '(-v --verbose)'{-v,--verbose}'[show verbose output]' \
  '*:script:_files -g "*.fsx"'
