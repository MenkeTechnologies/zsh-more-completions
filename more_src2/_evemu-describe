#compdef evemu-describe
# Documentation: https://man.archlinux.org/man/evemu-describe.1
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*:device:_files -g "/dev/input/event*"' && ret=0

return ret
