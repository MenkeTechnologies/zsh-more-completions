#compdef dh_installsystemd
# _dh_installsystemd — debhelper to install systemd units (Debian/debhelper)
# upstream: https://salsa.debian.org/debian/debhelper
# Flags from dh_installsystemd(1) man page.

_dh_installsystemd() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '(-n --no-scripts)'{-n,--no-scripts}'[do not modify maintainer scripts]' \
        '--no-enable[disable on purge but do not enable on install]' \
        '--name=[unit file basename / lookup name]:name:' \
        '(--restart-after-upgrade --no-restart-after-upgrade)--restart-after-upgrade[restart after upgrade completes (default compat 10+)]' \
        '(--restart-after-upgrade --no-restart-after-upgrade)--no-restart-after-upgrade[revert restart-after-upgrade default]' \
        '(-r --no-stop-on-upgrade --no-restart-on-upgrade)'{-r,--no-stop-on-upgrade,--no-restart-on-upgrade}'[do not stop on upgrade]' \
        '--no-start[do not start unit after install/upgrade]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-a[arch-dep packages only]' \
        '-i[arch-indep packages only]' \
        '-O+[option passed to the helper]:opt:' \
        '*:unit file:_files -g "*.{service,socket,timer,target,path,mount,automount,swap,slice,scope}"'
}

_dh_installsystemd "$@"
