#compdef grub-rescue grub-rescue-pc
# _grub-rescue — GRUB grub-rescue / grub-rescue-pc (boot rescue shell + image builder family for unbootable machines; --boot-directory points at the rescue /boot copy, --modules preloads modules, --themes themes, --output writes a bootable image; interactive shell accepts the standard GRUB commands)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mkrescue.in on tip.

_grub-rescue() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--directory+[GRUB lib dir]:dir:_files -/' \
        '--boot-directory+[/boot dir]:dir:_files -/' \
        '-o+[output image]:file:_files' \
        '--output+[output image]:file:_files' \
        '--locale-directory+[locale dir]:dir:_files -/' \
        '--themes+[themes list]:themes:' \
        '--locales+[locales list]:locales:' \
        '--fonts+[fonts list]:fonts:' \
        '--install-modules+[module list]:modules:' \
        '--modules+[loaded modules]:modules:' \
        '--label+[ISO volume label]:label:' \
        '--label-bgcolor+[label bg color]:color:' \
        '--label-color+[label fg color]:color:' \
        '--label-font+[label font]:file:_files' \
        '--product-name+[product name]:name:' \
        '--product-version+[product version]:version:' \
        '--rom-directory+[ROM dir]:dir:_files -/' \
        '--xorriso+[xorriso binary]:file:_files'
}

_grub-rescue "$@"
