#compdef glirc glirc2
# _glirc — glirc Haskell IRC client (TUI); modern Vim-like client with TLS/SASL/STS support
# upstream: https://github.com/glguy/irc-core

_glirc() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --config)'{-c,--config}'+[config file]:file:_files' \
        '(-l --lib)'{-l,--lib}'+[Lua plugin dir]:dir:_files -/' \
        '*:host:_hosts'
}

_glirc "$@"
