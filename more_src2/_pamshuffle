#compdef pamshuffle
# Documentation: man pamshuffle (Netpbm)
# Source: shuffle the rows (or columns) of a PAM image at random.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-column[shuffle columns instead of rows]' \
    '-randomseed+[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
