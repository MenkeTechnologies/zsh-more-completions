#compdef genkit
# _genkit — Google Genkit AI app framework CLI for building Node TS Go flows tools traces and deploying to Cloud Run Firebase with Gemini/Vertex/OpenAI providers (firebase team, TypeScript); commander.js
# upstream: https://github.com/firebase/genkit

_genkit() {
    local -a sub=(
        'init:initialize project'
        'start:start dev UI'
        'flow:flow operations'
        'eval:run evals'
        'eval:run:run eval'
        'eval:extractData:extract eval data'
        'config:show config'
        'mcp:MCP operations'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'genkit subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--platform=+[p]:p:(firebase nextjs nodejs go)' \
                    '--lang=+[l]:l:(typescript javascript go)' \
                    '--model=+[m]:m:(gemini-2.5-pro gemini-2.5-flash gemini-1.5-pro gemini-1.5-flash gpt-4o claude-opus-4-7 claude-sonnet-4-6)' ;;
                start) _arguments \
                    '--port=+[port]:n:' \
                    '--non-interactive[non interactive]' \
                    '-x+[noop]:str:' \
                    '--watch[watch]' \
                    '--no-watch[no watch]' \
                    '*:command:_command_names -e' ;;
                flow) _arguments \
                    '1:action:(run list)' \
                    '*:flow name:' ;;
                eval) _arguments \
                    '1:action:(run extractData)' \
                    '--input=+[file]:file:_files' \
                    '--output=+[file]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_genkit "$@"
