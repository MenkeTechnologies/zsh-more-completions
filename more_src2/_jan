#compdef jan
# _jan — Jan Labs jan local-first ChatGPT alternative CLI for running open-source LLMs locally with Cortex server tools assistants and OpenAI-compatible API (janhq team, TypeScript); commander.js
# upstream: https://github.com/janhq/jan

_jan() {
    local -a sub=(
        'start:start Jan app'
        'stop:stop Jan app'
        'status:show status'
        'models:model operations'
        'serve:start API server'
        'chat:interactive chat'
        'pull:pull model'
        'run:run model'
        'embed:compute embedding'
        'config:show config'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--data-dir=+[dir]:dir:_files -/' \
        '--port=+[port]:n:' \
        '--host=+[host]:str:' \
        '--engine=+[e]:e:(cortex.llamacpp cortex.python cortex.onnx cortex.tensorrt-llm cortex.openai)' \
        '--model-dir=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'jan subcommand' sub ;;
        args)
            case $words[1] in
                models) _arguments \
                    '1:action:(list pull start stop remove import export update)' \
                    '*:model name:' ;;
                chat|run) _arguments \
                    '--model=+[id]:str:' \
                    '--temperature=+[F]:f:' \
                    '--max-tokens=+[N]:n:' \
                    '--top-p=+[F]:f:' \
                    '--top-k=+[N]:n:' \
                    '--system=+[prompt]:str:' \
                    '*:message:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_jan "$@"
