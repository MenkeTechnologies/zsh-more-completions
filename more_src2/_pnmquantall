#compdef pnmquantall
# Documentation: man pnmquantall (Netpbm)
# Source: quantise multiple Netpbm images to a single shared palette of N colors.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-ext+[file-extension suffix for outputs]:extension:' \
    '*:ncolors and pnm files:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
