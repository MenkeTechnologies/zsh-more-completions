#compdef p11tool
# Documentation: p11tool --help (GnuTLS PKCS#11 tool)
# Source: manage objects in PKCS #11 tokens.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-\!,--more-help}'[extended help via pager]' \
    '(- *)'{-v-,--version=-}'[show version]::level:(v c n)' \
    {-d+,--debug=}'[debug level 0-9999]:level:' \
    '--list-tokens[list available tokens]' \
    '--list-token-urls[list URLs of available tokens]' \
    '--list-mechanisms[list mechanisms in a token]' \
    '--initialize[initialize a PKCS#11 token]' \
    '--initialize-pin[init/reset user PIN]' \
    '--initialize-so-pin[init/reset SO PIN]' \
    '--set-pin=[PIN for token operations]:pin:' \
    '--set-so-pin=[SO PIN for token initialization]:pin:' \
    '--list-all[list all objects in a token]' \
    '--list-all-certs[list all certificates in a token]' \
    '--list-certs[list certificates with private key]' \
    '--list-all-privkeys[list all private keys]' \
    '--list-privkeys[alias for --list-all-privkeys]' \
    '--list-keys[alias for --list-all-privkeys]' \
    '--list-all-trusted[list all trusted certificates]' \
    '(--export-stapled --export-chain)--export[export object specified by URL]' \
    '(--export --export-chain)--export-stapled[export with stapled OCSP]' \
    '(--export --export-stapled)--export-chain[export object chain]' \
    '--export-pubkey[export public key]' \
    '--info[show information about object]' \
    '--trusted[mark certificate as trusted]' \
    '--distrusted[mark certificate as distrusted]' \
    '--test-sign[sign with object]' \
    '--write[write object to token]' \
    '--delete[delete object]' \
    '--label=[set object label]:label:' \
    '--id=[set object ID]:id:' \
    '--mark-wrap[mark object as wrap]' \
    '--mark-trusted[mark certificate trusted in token]' \
    '--mark-distrusted[mark certificate distrusted]' \
    '--mark-decrypt[mark for decryption]' \
    '--mark-sign[mark for signing]' \
    '--mark-ca[mark as CA]' \
    '--mark-private[mark as private]' \
    '--ca[generate self-signed certificate]' \
    '--generate-privkey=[generate private key]:type:(rsa dsa ecdsa ed25519)' \
    '--bits=[key size in bits]:bits:' \
    '--curve=[curve for ECC]:curve:(secp192r1 secp224r1 secp256r1 secp384r1 secp521r1 ed25519)' \
    '--sec-param=[security parameter]:level:(low legacy medium high ultra)' \
    '--login[force login to token]' \
    '--admin-login[force admin login]' \
    '--so-login[force security officer login]' \
    '--load-privkey=[file containing the private key]:file:_files' \
    '--load-pubkey=[file containing public key]:file:_files' \
    '--load-certificate=[file containing the certificate]:file:_files' \
    '--secret-key=[secret key as hex]:hex:' \
    '--provider=[PKCS#11 provider library]:file:_files' \
    '--provider-opts=[provider options]:opts:' \
    '--detailed-url[detailed URL output]' \
    '--only-urls[only URL output]' \
    '--outfile=[output file]:file:_files' \
    '--batch[disable interactive prompts]' \
    '--inder[input is DER]' \
    '--outder[output as DER]' \
    '*:url:' \
    && ret=0

return ret
