#compdef ioquake3 ioq3ded quake3
# Documentation: https://ioquake3.readthedocs.io/command-line-options/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '*+set[set cvar to value]:cvar+value:' \
  '*+exec+[execute cfg file]:file:_files' \
  '*+connect+[connect to server]:addr:' \
  '*+map+[start map]:map:' \
  '*+devmap+[start map dev mode]:map:' \
  '*+spdevmap+[single-player dev map]:map:' \
  '*+spmap+[single-player map]:map:' \
  '*: :_files' && ret=0

return ret
