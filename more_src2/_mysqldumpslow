#compdef mysqldumpslow
# Documentation: mysqldumpslow (MySQL)
# Source: parse and summarize MySQL slow query logs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-d --debug)'{-d,--debug}'[debug]' \
    '-s+[sort order]:order:(al at ar c l r t)' \
    '-r[reverse sort order]' \
    '-t+[top N queries]:n:' \
    '-a[do not abstract numbers/strings to N/S]' \
    '-n+[abstract numbers with N digits in names]:n:' \
    '-g+[grep pattern]:pattern:' \
    '-h+[hostname (wildcard ok)]:hostname:_hosts' \
    '-i+[server instance name]:instance:' \
    '-l[do not subtract lock time]' \
    '*:slow log:_files -g "*.(log|slow*)"' \
    && ret=0

return ret
