#compdef flux-jobs
# Documentation: source-direct extraction from upstream
# flux-framework/flux-core src/cmd/flux-jobs.py argparse
# `parser.add_argument(...)` declarations (the
# `argparse.ArgumentParser(prog="flux-jobs", ...)` block).
# Reference accessed: 2026-05-30 via gh api.
# flux-framework flux-core R162c — flux-jobs is the per-user
# job listing / filtering CLI for the flux scheduler.  Sister
# tool to the already-covered `flux` umbrella driver — the
# `flux-*` family ships as standalone executables in PATH so
# `flux jobs` and `flux-jobs` are both valid invocations.

_arguments -s -S \
  '-a[list jobs in all states (pending, running, inactive)]' \
  '-A[list all jobs for all users]' \
  '(-c --count)'{-c+,--count=}'[limit output to N jobs (default 1000)]:n:' \
  '(-f --filter)'{-f+,--filter=}'[list jobs with specific job state or result]:filter:(pending running inactive completed failed canceled timeout)' \
  '--since=[include jobs that became inactive since WHEN]:when:' \
  '(-n --no-header)'{-n,--no-header}'[suppress header line]' \
  '(-u --user)'{-u+,--user=}'[limit output to username/UID (or "all")]:user:_users' \
  '--name=[limit output to a specific job name]:job-name:' \
  '(-q --queue)'{-q+,--queue=}'[limit output to comma-separated queues]:queues:' \
  '(-i --include)'{-i+,--include=}'[limit to jobs allocated to HOSTS or RANKS]:hosts-or-ranks:' \
  '(-o --format)'{-o+,--format=}'[output format (Python str.format) or named format ("help" lists names)]:format:' \
  '--sort=[comma-separated sort keys]:keys:' \
  '(-w --width)'{-w-,--width=-}'[truncate output at width N (0 = terminal width)]::n:' \
  '--json[output jobs in JSON]' \
  '--color=[colour mode]:mode:(always never auto)' \
  '(-R --recursive)'{-R,--recursive}'[list jobs recursively]' \
  '(-L --level)'{-L+,--level=}'[with --recursive, only descend N levels]:n:' \
  '--recurse-all[with --recursive, recurse all users not just current]' \
  '--threads=[max worker threads]:n:' \
  '--stats[print job statistics before header]' \
  '--stats-only[print stats only; exit nonzero if no active jobs]' \
  '*:JOB-ID:'
