#compdef elasticsearch-syskeygen
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/syskeygen.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elasticsearch-syskeygen: generate system_key for Elasticsearch
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '--silent[silent]' \
  '-v[verbose]' \
  '--verbose[verbose]' \
  '-E[config setting key=value]:kv:' \
  '*::elasticsearch-syskeygen args:_files' && ret=0
return ret
