#compdef lvmsar
# _lvmsar — LVM2 lvmsar CLI sysstat-style I/O activity reporter reading sample buffer files produced by lvmsadc replaying time-binned per-device read write iops kbytes from the LVM monitoring activity collector daemon (LVM team, C); getopt
# upstream: https://gitlab.com/lvmteam/lvm2

_lvmsar() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-d[show device totals]' \
        '-f+[sample file]:file:_files' \
        '-v[verbose]' \
        '*:sample file:_files -g "*.lvmsar *.dat"'
}

_lvmsar "$@"
