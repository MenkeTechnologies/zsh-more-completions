#compdef git-integration
# Documentation: https://github.com/johnkeeping/git-integration/blob/master/Documentation/git-integration.txt
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-integration: manage integration branches in Git

_arguments -s -S \
  '--create[create a new integration branch]:name:' \
  '--edit[modify the instruction sheet]' \
  '--rebuild[reconstruct the branch]' \
  '--no-rebuild[suppress reconstruction]' \
  '--cat[display the instruction sheet]' \
  '--status[show integration branch status]' \
  '*--add=[include additional branches]:branch:' \
  '--continue[resume building after resolving conflicts]' \
  '--abort[cancel the rebuild and restore original state]' \
  '--autocontinue[auto-proceed when rerere resolves conflicts]' \
  '--no-autocontinue[disable autocontinue]' \
  '--prefix=[prepend string to each reference during building]:prefix:' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::args:_default' && return 0
