#compdef ewfacquirestream
# Documentation: https://github.com/libyal/libewf
# Source: libyal/libewf manuals/ewfacquirestream.1 — acquire stdin data to EWF E01/Ex01.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a codepages=(ascii windows-874 windows-932 windows-936 windows-949 windows-950 windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)
local -a chunk_sectors=(16 32 64 128 256 512 1024 2048 4096 8192 16384 32768)
local -a formats=(ftk encase2 encase3 encase4 encase5 encase6 encase7 encase7-v2 linen5 linen6 linen7 ewfx)

_arguments -s \
    "-A[codepage of header section]:codepage:($codepages)" \
    "-b[number of sectors per chunk]:n:($chunk_sectors)" \
    '-B[number of bytes to acquire]:bytes:' \
    '-c[compression values (level or method:level)]:values:' \
    '-C[case number]:case number:' \
    '-d[additional digest type besides md5]:digest:(sha1 sha256)' \
    '-D[description]:description:' \
    '-e[examiner name]:examiner:' \
    '-E[evidence number]:evidence number:' \
    "-f[EWF file format]:format:($formats)" \
    '-h[show help]' \
    '-j[number of concurrent jobs (threads)]:jobs:' \
    '-l[log filename for acquisition errors and digest]:log:_files' \
    '-m[media type]:media type:(fixed removable optical memory)' \
    '-M[media flags]:media flags:(logical physical)' \
    '-N[notes]:notes:' \
    '-o[offset to start to acquire]:offset:' \
    '-p[process buffer size]:size:' \
    '-P[bytes per sector (default 512)]:n:(512 1024 2048 4096)' \
    '-q[quiet (minimal status info)]' \
    '-s[swap byte pairs of media data (AB to BA)]' \
    '-S[segment file size in bytes]:size:' \
    '-t[target file (without extension)]:target:_files' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '-x[use data chunk functions instead of buffered I/O]' \
    '-2[secondary target file (without extension)]:target:_files' \
    && ret=0

return ret
