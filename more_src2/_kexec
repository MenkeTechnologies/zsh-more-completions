#compdef kexec
# _kexec — Linux kexec-tools kexec (load + execute a new kernel without going through firmware reset; -l loads, -e executes, -u unloads, -p loads for crash-dump (kdump), -t image type (bzImage|elf|multiboot), --initrd, --command-line, --reuse-cmdline, --append, -f no signature check)
# upstream: https://git.kernel.org/pub/scm/utils/kernel/kexec/kexec-tools.git
# Flags from kexec-tools kexec/kexec.c on tip.

_kexec() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d[debug]' \
        '-f[no signature check]' \
        '-x[no ifdown on shutdown]' \
        '-y[no sync on shutdown]' \
        '-l[load image]' \
        '--load[load image]' \
        '-p[load for kdump]' \
        '--load-panic[load for kdump]' \
        '-u[unload image]' \
        '--unload[unload image]' \
        '-e[execute loaded image]' \
        '--exec[execute loaded image]' \
        '-i[load + execute kdump immediately]' \
        '--load-jump-back-helper[load jump-back helper]' \
        '-t+[image type]:type:(bzImage elf-x86 multiboot-x86 elf-ppc64 image-arm64 zImage-arm xen-multiboot uki)' \
        '--type+[image type]:type:' \
        '--initrd+[initrd]:file:_files' \
        '--reuse-initrd[reuse current initrd]' \
        '--command-line+[cmdline]:cmdline:' \
        '--append+[append to cmdline]:append:' \
        '--reuse-cmdline[reuse current cmdline]' \
        '--dtb+[device tree blob]:file:_files' \
        '--no-checks[skip safety checks]' \
        '--mem-min+[bytes]:bytes:' \
        '--mem-max+[bytes]:bytes:' \
        '*:kernel image:_files'
}

_kexec "$@"
