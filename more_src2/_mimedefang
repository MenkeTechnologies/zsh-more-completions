#compdef mimedefang
# Documentation: https://manpages.debian.org/bookworm/mimedefang/mimedefang.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm mimedefang(8) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL; fake --version
# long flag (mimedefang uses single-letter opts only).

# mimedefang: Sendmail/Postfix milter for MIME-based filtering
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-p[socket for receiving connections]:spec:' \
  '-m[socket to communicate with mimedefang-multiplexor]:spec:' \
  '-U[run as this user]:user:_users' \
  '-z[spool directory]:dir:_files -/' \
  '-b[backlog argument for listen()]:n:' \
  '-G[set group write/read permissions on socket]' \
  '-d[no daemon mode (log to stderr)]' \
  '-r[do relay checks even for relay clients]' \
  '-H[do HELO check on all hosts]' \
  '-s[turn on suspicious-character checks]' \
  '-t[trust all hosts named or addressed in mail headers]' \
  '-q[in case of error, queue mail instead of bouncing]' \
  '-k[keep working directory on error]' \
  '-P[write process ID to file]:file:_files' \
  '-o[lock file]:file:_files' \
  '-R[set recipient response message length limit]:n:' \
  '-C[do connection-time checks]' \
  '-T[print timing info on each message]' \
  '-x[add X-Scanned-By header with given string]:string:' \
  '-X[suppress default X-Scanned-By header]' \
  '-D[do not become a daemon]' \
  '-M[indicates Sendmail milter is built with TLS support]' \
  '-N[skip status update reports]' \
  '-S[syslog facility]:facility:(daemon mail local0 local1 local2 local3 local4 local5 local6 local7)' \
  '-a[macros to pass to filter]:macro:' \
  '-c[strict Content-Type header checks]' \
  '-y[allow milter to set new envelope recipients]' && ret=0
return ret
