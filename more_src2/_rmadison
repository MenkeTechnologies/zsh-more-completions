#compdef rmadison
# Documentation: https://manpages.debian.org/rmadison
# Source: debian/devscripts scripts/rmadison.pl — query Debian/Ubuntu archive (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-a --architecture)'{-a+,--architecture=}'[restrict to architecture(s)]:arch:_default' \
    '(-b --binary-type)'{-b+,--binary-type=}'[binary type]:type:(deb udeb dsc)' \
    '(-c --component)'{-c+,--component=}'[restrict to component]:comp:(main contrib non-free non-free-firmware universe multiverse restricted)' \
    '(-g --greaterorequal)'{-g,--greaterorequal}'[show only versions >= each match]' \
    '(-G --greaterthan)'{-G,--greaterthan}'[show only versions > each match]' \
    '(--no-conf --noconf)'{--noconf,--no-conf}'[ignore conf files]' \
    '(-r --regex)'{-r,--regex}'[treat package names as regex]' \
    '(-s --suite)'{-s+,--suite=}'[restrict to suite]:suite:_default' \
    '(-S --source-and-binary)'{-S,--source-and-binary}'[query source and binary]' \
    '(-t --time)'{-t,--time}'[show time of upload]' \
    '(-u --url)'{-u+,--url=}'[query URL]:url:(debian new ubuntu udd qa actual)' \
    '*:package:_default' \
    && ret=0

return ret
