#compdef osmconvert
# Documentation: https://manpages.debian.org/bookworm/osmctools/osmconvert.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm osmconvert(1) manpage. All options use
# `=value` style, not GNU `--flag value`.
# Removed from prior file: fabricated -V/--version (real is --help only)
# and bogus man.archlinux.org search URL.

# osmconvert: OpenStreetMap data format converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '-b=[bbox limit: minlon,minlat,maxlon,maxlat]:bbox:' \
  '-B=[border polygon file]:file:_files' \
  '--complete-ways[include all nodes referenced by ways]' \
  '--complex-multipolygons[reconstruct complex multipolygons]' \
  '--complex-boundaries[reconstruct complex boundaries]' \
  '--all-to-nodes[convert ways and relations to nodes]' \
  '--add-bbox-tags[add bbox tags to ways/relations]' \
  '--add-bboxarea-tags[add bbox area tags]' \
  '--add-bboxweight-tags[add bbox weight tags]' \
  '--add-bboxwidth-tags[add bbox width tags]' \
  '--object-type-offset=[start ID offset]:n:' \
  '--drop-broken-refs[drop refs to missing objects]' \
  '--drop-author[drop author info]' \
  '--drop-version[drop version info]' \
  '--drop-nodes[drop all nodes]' \
  '--drop-ways[drop all ways]' \
  '--drop-relations[drop all relations]' \
  '--diff[diff between two files]' \
  '--diff-contents[diff with full contents]' \
  '--subtract[subtract second file from first]' \
  '--pbf-granularity=[PBF coordinate granularity]:n:' \
  '--emulate-osmosis[mimic osmosis output]' \
  '--emulate-pbf2osm[mimic pbf2osm output]' \
  '--fake-author[use fake author info]' \
  '--fake-version[use fake version info]' \
  '--fake-lonlat[use fake coordinates]' \
  '--merge-versions[merge multiple versions]' \
  '(--out-osc --out-osh --out-o5m --out-o5c --out-pbf --out-csv --out-none)--out-osm[output XML format]' \
  '(--out-osm --out-osh --out-o5m --out-o5c --out-pbf --out-csv --out-none)--out-osc[output OSC changeset format]' \
  '(--out-osm --out-osc --out-o5m --out-o5c --out-pbf --out-csv --out-none)--out-osh[output OSH history format]' \
  '(--out-osm --out-osc --out-osh --out-o5c --out-pbf --out-csv --out-none)--out-o5m[output O5M binary format]' \
  '(--out-osm --out-osc --out-osh --out-o5m --out-pbf --out-csv --out-none)--out-o5c[output O5C change format]' \
  '(--out-osm --out-osc --out-osh --out-o5m --out-o5c --out-csv --out-none)--out-pbf[output PBF binary format]' \
  '(--out-osm --out-osc --out-osh --out-o5m --out-o5c --out-pbf --out-none)--out-csv[output CSV]' \
  '(--out-osm --out-osc --out-osh --out-o5m --out-o5c --out-pbf --out-csv)--out-none[no output]' \
  '--csv-headline[include CSV header line]' \
  '--csv-separator=[CSV separator]:sep:' \
  '--csv=[CSV column list]:cols:' \
  '--timestamp=[timestamp value]:ts:' \
  '--out-timestamp[output timestamp]' \
  '--statistics[output statistics]' \
  '--out-statistics[output statistics only]' \
  '-o=[output file]:file:_files' \
  '-t=[temporary file prefix]:prefix:' \
  '--parameter-file=[parameter file]:file:_files' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--hash-memory=[hash memory in MB]:n:' \
  '--max-objects=[max objects to process]:n:' \
  '--max-refs=[max references]:n:' \
  '*:OSM file:_files -g "*.(osm|pbf|o5m|osc)(-.)"' && ret=0
return ret
