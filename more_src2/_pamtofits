#compdef pamtofits
# Documentation: man pamtofits (Netpbm)
# Source: convert a Netpbm image to NASA FITS astronomical format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-max+[max sample value mapped to white]:f:' \
    '-min+[min sample value mapped to black]:f:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
