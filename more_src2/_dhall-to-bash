#compdef dhall-to-bash
# Zsh completion for dhall-to-bash (convert Dhall expressions to Bash)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--declare=[output a bash declare statement for the given variable]:variable name:' \
  '--file=[read Dhall expression from file instead of stdin]:file:_files' \
  '--explain[explain error messages in detail]' \
  '(- *)--version[display version]' \
  '(- *)'{-h,--help}'[show help]' \
  && ret=0

return ret
