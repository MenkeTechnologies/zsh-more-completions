#compdef gardener-extension-provider-aws
# _gardener-extension-provider-aws — Gardener AWS provider extension controller
# upstream: https://github.com/gardener/gardener-extension-provider-aws
# Flag families from gardener extensions/pkg/controller/cmd Options on tip.

_gardener-extension-provider-aws() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-id=[leader-election lease name]:id:' \
        '--leader-election-namespace=[leader-election lease namespace]:ns:' \
        '--webhook-config-server-host=[webhook server bind host]:host:' \
        '--webhook-config-server-port=[webhook server bind port]:port:' \
        '--webhook-config-cert-dir=[webhook TLS cert directory]:dir:_files -/' \
        '--metrics-bind-address=[metrics bind host\:port]:host\:port:' \
        '--health-bind-address=[health probe bind host\:port]:host\:port:' \
        '--log-level=[log level]:level:(debug info error)' \
        '--log-format=[log format]:fmt:(json text)' \
        '--gardener-version=[gardenlet/gardener-operator version]:ver:' \
        '--self-hosted-shoot-cluster=[running in self-hosted shoot]:bool:(true false)' \
        '--extension-classes=[csv of extension classes this controller handles]:csv:' \
        '--kubeconfig=[kubeconfig file (out-of-cluster)]:file:_files' \
        '--master=[Kubernetes API server URL]:url:_urls' \
        '*--controllers=[csv of controllers to enable]:csv:(backupbucket backupentry bastion controlplane dnsrecord healthcheck infrastructure worker)' \
        '*--disable-controllers=[csv of controllers to disable]:csv:' \
        '--backupbucket-max-concurrent-reconciles=[backupbucket reconcile concurrency]:n:' \
        '--backupentry-max-concurrent-reconciles=[backupentry reconcile concurrency]:n:' \
        '--bastion-max-concurrent-reconciles=[bastion reconcile concurrency]:n:' \
        '--controlplane-max-concurrent-reconciles=[controlplane reconcile concurrency]:n:' \
        '--healthcheck-max-concurrent-reconciles=[healthcheck reconcile concurrency]:n:' \
        '--infrastructure-max-concurrent-reconciles=[infrastructure reconcile concurrency]:n:' \
        '--worker-max-concurrent-reconciles=[worker reconcile concurrency]:n:' \
        '--ignore-operation-annotation[ignore gardener.cloud/operation annotation]' \
        '--reconcile-period=[periodic reconcile interval]:dur:' \
        '--reconcile-sync-period=[informer sync period]:dur:' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '--version[print version and exit]' \
        '-v[klog verbosity level]:n:'
}

_gardener-extension-provider-aws "$@"
