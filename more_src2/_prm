#compdef prm
# Documentation: https://github.com/EivindArvesen/prm/blob/master/README.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_prm_commands() {
  local -a commands=(
    'active:list active project instances'
    'add:add project(s)'
    'copy:copy project'
    'edit:edit project(s)'
    'list:list all projects'
    'remove:remove project(s)'
    'rename:rename project'
    'start:start project'
    'stop:stop active project'
  )
  _describe 'command' commands
}

_prm_projects() {
  local -a projects
  projects=(${(f)"$(prm list 2>/dev/null | grep -v '^\s*$')"})
  _describe 'project' projects
}

_prm() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[display help information]' \
    '(- *)'{-v,--version}'[display version info]' \
    '1:command:_prm_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        start|edit|remove)
          _arguments \
            '*:project:_prm_projects'
          ;;
        copy|rename)
          _arguments \
            '1:old project:_prm_projects' \
            '2:new project name'
          ;;
        add)
          _arguments \
            '*:project name'
          ;;
      esac
      ;;
  esac
}

_prm "$@"
