#compdef external-secrets-controller eso-controller
# _external-secrets-controller — External Secrets Operator (ESO) controller manager
# upstream: https://github.com/external-secrets/external-secrets
# Flags from cmd/controller/root.go rootCmd.Flags on tip.

_external-secrets-controller() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-addr=[metrics bind host\:port]:host\:port:' \
        '--metrics-auth=[require RBAC auth for metrics endpoint]:bool:(true false)' \
        '--metrics-secure=[enable HTTPS for metrics endpoint]:bool:(true false)' \
        '--metrics-cert-dir=[metrics TLS cert directory]:dir:_files -/' \
        '--metrics-cert-name=[metrics TLS cert filename]:name:' \
        '--metrics-key-name=[metrics TLS key filename]:name:' \
        '--controller-class=[controller-class label filter]:class:' \
        '--enable-leader-election=[enable leader election]:bool:(true false)' \
        '--leader-election-id=[leader-election lease name]:id:' \
        '--concurrent=[concurrent reconciles per controller]:n:' \
        '--client-qps=[REST client QPS]:f:' \
        '--client-burst=[REST client burst]:n:' \
        '--live-addr=[liveness probe bind host\:port]:host\:port:' \
        '--loglevel=[log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-time-encoding=[zap time encoding]:fmt:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--namespace=[scope ExternalSecrets to a single namespace]:ns:' \
        '--enable-cluster-store-reconciler=[enable ClusterSecretStore reconciler]:bool:(true false)' \
        '--enable-secret-store-reconciler=[enable SecretStore reconciler]:bool:(true false)' \
        '--enable-cluster-external-secret-reconciler=[enable ClusterExternalSecret reconciler]:bool:(true false)' \
        '--enable-cluster-push-secret-reconciler=[enable ClusterPushSecret reconciler]:bool:(true false)' \
        '--enable-push-secret-reconciler=[enable PushSecret reconciler]:bool:(true false)' \
        '--enable-secrets-caching=[cache ALL Secrets cluster-wide]:bool:(true false)' \
        '--enable-configmaps-caching=[cache ALL ConfigMaps cluster-wide]:bool:(true false)' \
        '--enable-managed-secrets-caching=[cache Secrets managed by an ExternalSecret]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_external-secrets-controller "$@"
