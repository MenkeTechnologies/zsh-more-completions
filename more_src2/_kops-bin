#compdef kops
# _kops-bin — kops k8s ops CLI (kubernetes/kops, Go); production-grade k8s cluster lifecycle on cloud providers
# upstream: https://github.com/kubernetes/kops

_kops-bin() {
    local -a sub=(
        'completion:print shell completion'
        'create:create cluster/secret/etc'
        'delete:delete a cluster'
        'distrust:distrust ca cert/key'
        'edit:edit a resource'
        'export:export kubeconfig'
        'get:get clusters/instancegroups/etc'
        'help:show help'
        'rolling-update:rolling-update a cluster'
        'set:set fields on resources'
        'toolbox:dump/template etc'
        'trust:trust a ca cert/key'
        'update:update cluster'
        'upgrade:upgrade cluster'
        'validate:validate cluster'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--add_dir_header[add dir header]' \
        '--alsologtostderr[log to stderr too]' \
        '--config+[config file]:file:_files' \
        '--log_backtrace_at+[log backtrace]:str:' \
        '--log_dir+[log dir]:dir:_files -/' \
        '--log_file+[log file]:file:_files' \
        '--logtostderr[log to stderr]' \
        '--name+[cluster name]:name:' \
        '--state+[state store]:str:' \
        '-v+[verbosity]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kops subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments '1:create what:(cluster instancegroup secret sshpublickey)' '*:args:' ;;
                delete) _arguments '1:delete what:(cluster instancegroup secret sshpublickey)' '*:args:' ;;
                get) _arguments '1:get what:(all assets cluster clusters instancegroups secrets sshpublickeys)' '*:args:' \
                    '-o+[output format]:fmt:(table json yaml)' \
                    '--output+[output format]:fmt:' ;;
                update) _arguments '1:update what:(cluster)' '*:cluster:' \
                    '--yes[apply changes]' \
                    '--lifecycle-overrides+[lifecycle overrides]:str:' ;;
                rolling-update) _arguments '1:rolling-update what:(cluster)' '*:cluster:' \
                    '--yes[apply]' \
                    '--force[force]' \
                    '--cloud-only[cloud only]' \
                    '--master-interval+[master interval]:duration:' \
                    '--node-interval+[node interval]:duration:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_kops-bin "$@"
