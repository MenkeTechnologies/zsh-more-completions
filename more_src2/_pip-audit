#compdef pip-audit
# Documentation: https://github.com/pypa/pip-audit
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Zsh completion for pip-audit
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-r --requirement)'{-r,--requirement}'[audit requirements file]:file:_files' \
  '(-l --local)'{-l,--local}'[only audit packages in the local environment]' \
  '--locked[audit lock files from a Python project]' \
  '--desc=[enable vulnerability descriptions]:mode:(on off auto)' \
  '--aliases=[include alias IDs for vulnerabilities]:mode:(on off auto)' \
  '(-f --format)'{-f,--format}'=[output format]:format:(columns json cyclonedx-json cyclonedx-xml markdown)' \
  '(-o --output)'{-o,--output}'=[output file]:file:_files' \
  '(-S --strict)'{-S,--strict}'[fail if dependency collection fails on any package]' \
  '--fix[attempt to fix vulnerable dependencies]' \
  '(-d --dry-run)'{-d,--dry-run}'[skip actual auditing or fixing]' \
  '--skip-editable[skip editable packages]' \
  '--no-deps[do not audit dependencies]' \
  '--require-hashes[require hashes for repeatable audits]' \
  '(-i --index-url)'{-i,--index-url}'=[base URL of the Python Package Index]:url:_urls' \
  '*--extra-index-url=[extra index URL]:url:_urls' \
  '(-s --vulnerability-service)'{-s,--vulnerability-service}'=[vulnerability service to use]:service:(osv pypi esms)' \
  '--osv-url=[custom OSV API endpoint]:url:_urls' \
  '*--ignore-vuln=[ignore a specific vulnerability by ID]:id:' \
  '--disable-pip[disable pip for dependency resolution]' \
  '--progress-spinner=[enable or disable progress spinner]:mode:(on off)' \
  '--timeout=[timeout for HTTP requests]:seconds:' \
  '--cache-dir=[cache directory]:dir:_directories' \
  '--no-cache[disable caching]' \
  '*'{-v,--verbose}'[enable debug logging]' \
  '(- *)'{-h,--help}'[show help message]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:project path:_directories' && ret=0
return ret
