#compdef quartus_eda
# _quartus_eda — Intel Altera Quartus quartus_eda CLI for the EDA Netlist Writer stage of the Quartus Prime FPGA flow generating output netlists for third-party simulation synthesis IBIS SDF formal-verification tools Verilog VHDL SystemVerilog (Intel team, C++); custom argparse
# upstream: https://www.intel.com/content/www/us/en/products/details/fpga/development-tools/quartus-prime.html

_quartus_eda() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '--rev=+[revision]:str:' \
        '--revision=+[revision]:str:' \
        '--tool=+[t]:t:(modelsim modelsim_altera questa questa_simulation questa_synthesis questa_intel_fpga ncsim vcs xcelium verilator riviera-pro icarus ghdl synplify-pro design-compiler dcfpga primetime formality conformal ibis stamodel sdfwriter)' \
        '--simulation[simulation]' \
        '--synthesis[synthesis]' \
        '--timing_analysis[timing analysis]' \
        '--formal_verification[formal verification]' \
        '--board_level=+[type]:t:(ibis signal_integrity hspice symbols)' \
        '--write_settings_files[write settings files]' \
        '--read_settings_files[read settings files]' \
        '--format=+[f]:f:(verilog systemverilog vhdl)' \
        '--vector_source=+[file]:file:_files' \
        '--testbench=+[file]:file:_files' \
        '--gen_functional_sim_netlist[generate functional netlist]' \
        '--list-extensions[list extensions]' \
        '--archive=+[file]:file:_files -g "*.qar"' \
        '--64bit[64-bit mode]' \
        '*:project name:_files -g "*.qpf *.qsf"'
}

_quartus_eda "$@"
