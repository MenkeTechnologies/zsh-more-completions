#compdef packetbeat-cli packetbeat
# _packetbeat-cli — Elastic Beats packetbeat-cli CLI command-line frontend to the Packetbeat lightweight network packet analyzer monitoring HTTP HTTPS DNS MySQL PostgreSQL Redis Memcached MongoDB AMQP CASSANDRA TLS network protocols on the wire shipping flow records to Elasticsearch Logstash Kafka for application performance monitoring (Elastic team, Go); cobra
# upstream: https://www.elastic.co/beats/packetbeat

_packetbeat-cli() {
    local -a sub=(
        'run:run beat'
        'devices:list available network devices'
        'test:test config or output'
        'export:export config templates dashboards'
        'keystore:keystore management'
        'setup:setup index templates dashboards'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[selectors]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--c=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-e[log to stderr]' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '-E+[k=v]:str:' \
        '-I+[interface]:_net_interfaces' \
        '-O[one shot]' \
        '-F+[bpf filter]:str:' \
        '-l[disable promisc]' \
        '-N[do not publish events]' \
        '-p+[pcap file]:file:_files -g "*.pcap *.pcapng"' \
        '-snaplen=+[N]:n:' \
        '-t[interactive test]' \
        '--memprofile=+[file]:file:_files' \
        '--httpprof=+[host:port]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'packetbeat-cli subcommand' sub ;;
    esac
}

_packetbeat-cli "$@"
