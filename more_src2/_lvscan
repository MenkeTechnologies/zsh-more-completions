#compdef lvscan vgscan pvscan
# _lvscan — LVM scan helpers; lvscan/vgscan/pvscan rebuild metadata cache + activate
# upstream: https://gitlab.com/lvmteam/lvm2

_lvscan() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --activate)'{-a,--activate}'+[activate]:mode:(y n ay)' \
        '(-b --blocked)'{-b,--blocked}'[block until done]' \
        '-q[quiet]' \
        '-v[verbose]' \
        '-d[debug]' \
        '--cache[update lvmetad cache]' \
        '--mknodes[create device nodes]' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '--ignorelockingfailure[ignore locking failure]' \
        '--major+[major]:n:' \
        '--minor+[minor]:n:' \
        '--background[run in background]' \
        '--all[scan all]' \
        '*:device:_files'
}

_lvscan "$@"
