#compdef kuadrantctl
# _kuadrantctl — configure Kuadrant APIs / policies for Kubernetes (Kuadrant/kuadrantctl)
# upstream: https://github.com/Kuadrant/kuadrantctl
# Subcommands from cmd/*.go (cobra).

_kuadrantctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_kuadrantctl_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                generate)
                    _arguments \
                        '1: :(gatewayapi kuadrant)' \
                        '*::generate arg:->genargs' && ret=0
                    case $state in
                        genargs)
                            case $words[1] in
                                gatewayapi)
                                    _arguments \
                                        '1: :(httproute)' \
                                        '--oas=[path to OpenAPI spec]:file:_files -g "*.(yaml|yml|json)"' \
                                        '-o+[output file]:file:_files' && ret=0 ;;
                                kuadrant)
                                    _arguments \
                                        '1: :(authpolicy ratelimitpolicy)' \
                                        '--oas=[path to OpenAPI spec]:file:_files -g "*.(yaml|yml|json)"' \
                                        '-o+[output file]:file:_files' && ret=0 ;;
                            esac ;;
                    esac ;;
                topology)
                    _arguments \
                        '-n+[Kubernetes namespace]:namespace:' \
                        '-o+[output file]:file:_files -g "*.dot"' && ret=0 ;;
                dns)
                    _arguments \
                        '*:dns subcommand args:' && ret=0 ;;
                version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_kuadrantctl_commands] )) ||
_kuadrantctl_commands() {
    local -a commands
    commands=(
        'generate:generate Kubernetes objects (Gateway API or Kuadrant policies)'
        'topology:emit the Kuadrant API topology as a Graphviz dot file'
        'dns:DNS operator helpers (requires the kubectl-kuadrant_dns plugin)'
        'version:print kuadrantctl version'
    )
    _describe -t commands 'kuadrantctl command' commands
}

_kuadrantctl "$@"
