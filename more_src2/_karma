#compdef karma
# Documentation: https://github.com/karma-runner/karma/blob/master/lib/cli.js
# Reference accessed: 2026-05-19
# Verified: upstream source (yargs .command/.describe) at the URL above.
# Added missing "stop" command; removed invented --hostname; added
# --detached --capture-timeout --report-slower-than --format-error.

# Zsh completion for karma - Karma JavaScript test runner

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'init:initialize a config file'
      'start:start the server / do a single run'
      'run:trigger a test run'
      'stop:stop the server'
      'completion:shell completion for karma'
    )
    _describe -t commands 'karma command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      start)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--single-run[run tests once and exit]' \
          '--no-single-run[do not run tests once and exit]' \
          '--auto-watch[auto-watch files for changes]' \
          '--no-auto-watch[do not auto-watch files]' \
          '--log-level=[log level]:level:(disable error warn info debug)' \
          '--colors[use colors in output]' \
          '--no-colors[do not use colors in output]' \
          '--reporters=[list of reporters]:reporter' \
          '--port=[port where the server is running]:port' \
          '--browsers=[list of browsers to start]:browser:(Chrome ChromeHeadless ChromeCanary Firefox FirefoxHeadless Safari)' \
          '--detached[detach the server]' \
          '--capture-timeout=[kill browser if it does not capture in given time ms]:ms' \
          '--report-slower-than=[report tests slower than given time ms]:ms' \
          '--format-error=[path to a file that exports the format function]:file:_files' \
          '--fail-on-empty-test-suite[fail on empty test suite]' \
          '--no-fail-on-empty-test-suite[do not fail on empty test suite]' \
          '--fail-on-failing-test-suite[fail on failing test suite]' \
          '--no-fail-on-failing-test-suite[do not fail on failing test suite]' \
          '1:config file:_files' && ret=0
        ;;
      init)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:config file:_files' && ret=0
        ;;
      run)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port where the server is listening]:port' \
          '--no-refresh[do not re-glob all the patterns]' \
          '--fail-on-empty-test-suite[fail on empty test suite]' \
          '--no-fail-on-empty-test-suite[do not fail on empty test suite]' \
          '--log-level=[log level]:level:(disable error warn info debug)' \
          '--colors[use colors when reporting and printing logs]' \
          '--no-colors[do not use colors when reporting or printing logs]' \
          '--removed-files=[comma-separated paths to removed files]:files' \
          '--changed-files=[comma-separated paths to changed files]:files' \
          '--added-files=[comma-separated paths to added files]:files' \
          '1:config file:_files' && ret=0
        ;;
      stop)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '--port=[port where the server is listening]:port' \
          '--log-level=[log level]:level:(disable error warn info debug)' \
          '1:config file:_files' && ret=0
        ;;
      completion)
        ;;
    esac
    ;;
esac

return ret
