#compdef kafka-topics kafka-console-producer kafka-console-consumer kafka-configs kafka-consumer-groups kafka-acls kafka-broker-api-versions kafka-delete-records kafka-leader-election kafka-log-dirs kafka-reassign-partitions kafka-replica-verification kafka-storage kafka-streams-application-reset kafka-server-start kafka-server-stop kafka-zookeeper-start kafka-zookeeper-shell kafka-mirror-maker kafka-cluster
# _kafka — Apache Kafka shell helpers (per-tool flags vary, but common ones include --bootstrap-server, --command-config, --topic, --partitions, --replication-factor, --create, --delete, --describe, --list, --alter, --producer-property, --consumer-property, --group, --offset, --from-beginning)
# upstream: https://github.com/apache/kafka
# Common flags from Apache Kafka bin/*.sh + core/src/main/scala/kafka/admin on tip.

_kafka() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--bootstrap-server+[broker]:broker:_hosts' \
        '--command-config+[config file]:file:_files' \
        '--topic+[topic]:topic:' \
        '--partitions+[partitions]:n:' \
        '--replication-factor+[replication factor]:n:' \
        '--create[create]' \
        '--delete[delete]' \
        '--describe[describe]' \
        '--list[list]' \
        '--alter[alter]' \
        '--config+[property]:property:' \
        '--group+[consumer group]:group:' \
        '--from-beginning[consume from beginning]' \
        '--offset+[offset]:offset:(earliest latest)' \
        '--property+[key=value]:property:' \
        '--producer-property+[key=value]:property:' \
        '--consumer-property+[key=value]:property:' \
        '--zookeeper+[zookeeper conn]:zk:' \
        '*::extra:_files'
}

_kafka "$@"
