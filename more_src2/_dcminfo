#compdef dcminfo
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dcminfo.html
# Source: MRtrix3/mrtrix3 cmd/dcminfo.cpp — output DICOM fields in human-readable format (C++, MRtrix parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-all[print all DICOM fields]' \
    '-csa[print Siemens CSA fields (excluding Phoenix)]' \
    '-phoenix[print Siemens Phoenix protocol information]' \
    '*-tag+[print field by hex group,element]:tag:_default' \
    '1:DICOM file:_files -g "*.{dcm,DCM,dicom,IMA}"' \
    && ret=0

return ret
