#
# -----------------------------------------------------------------------------
#
# WHAT IS tabled AND WHY IS IT THE 60TH RUST CLI LIBRARY?
#
# tabled (https://github.com/zhiburt/tabled, 2,300+ stars) is **Maxim
# Zhiburt's "easy to use library for pretty print tables of Rust
# structs and enums"** — the FIRST Rust table library built around
# DERIVE MACROS, mirroring the philosophy of serde's `#[derive(
# Serialize)]` + clap's `#[derive(Parser)]` + thiserror's `#[derive(
# Error)]` (R602) — declarative, struct-driven, zero runtime overhead.
#
# tabled's distinguishing characteristics:
#
#   1. `#[derive(Tabled)]` PROC-MACRO — tabled's central feature is
#      the derive macro that turns any struct into a row in a table:
#
#          use tabled::{Table, Tabled};
#
#          #[derive(Tabled)]
#          struct Player {
#              name: String,
#              team: String,
#              #[tabled(rename = "PTS")]
#              points: f64,
#              #[tabled(rename = "AST")]
#              assists: f64,
#              #[tabled(skip)]
#              internal_id: u64,
#          }
#
#          let players = vec![
#              Player { name: "Stephen Curry".into(), team: "GSW".into(),
#                       points: 30.7, assists: 5.8, internal_id: 1 },
#              Player { name: "LeBron James".into(), team: "LAL".into(),
#                       points: 27.2, assists: 8.3, internal_id: 2 },
#          ];
#
#          let table = Table::new(&players).to_string();
#          println!("{}", table);
#          // ┌───────────────┬──────┬──────┬─────┐
#          // │ name          │ team │ PTS  │ AST │
#          // ├───────────────┼──────┼──────┼─────┤
#          // │ Stephen Curry │ GSW  │ 30.7 │ 5.8 │
#          // │ LeBron James  │ LAL  │ 27.2 │ 8.3 │
#          // └───────────────┴──────┴──────┴─────┘
#
#      Per-field tabled attributes:
#         * `#[tabled(rename = "...")]` — column header override
#         * `#[tabled(skip)]` — exclude field from table
#         * `#[tabled(display = "fn_name")]` — custom Display
#         * `#[tabled(inline)]` — flatten nested struct
#         * `#[tabled(order = N)]` — explicit column ordering
#         * `#[tabled(format = "{:.2}")]` — printf-style formatting
#      Compare:
#         * prettytable-rs: builder API with row!() macro
#         * comfy-table: builder API with .add_row(...)
#         * cli-table: derive-based but with cli_table attribute
#         * Node.js cli-table3 (R608): imperative push() API
#         * Python tabulate: list-of-lists with auto-headers
#         * Python rich.table: builder API with .add_column +
#                               .add_row
#         * tabled: DERIVE MACRO + struct-as-row philosophy
#      FIRST documented Rust Axis 10 library with derive-macro-
#      driven struct-as-row API.
#
#   2. SETTING TRAIT FOR DECLARATIVE TABLE MODIFICATIONS — tabled
#      uses a `Setting` trait for table-wide modifications.  Each
#      modification is a value implementing Setting; you chain
#      them via `.with(setting)`:
#
#          use tabled::settings::{Style, Alignment, Padding,
#                                  Modify, object::Rows,
#                                  Width, Color};
#
#          let mut table = Table::new(&players);
#          table
#              .with(Style::modern())                  // Unicode borders
#              .with(Alignment::center())              // center cells
#              .with(Padding::new(1, 1, 0, 0))         // 1-space padding
#              .with(Modify::new(Rows::first())        // first row only
#                    .with(Color::FG_BRIGHT_CYAN));    // cyan header
#
#      Settings include:
#         * Style: blank, ascii, modern, rounded, dots, psql,
#                   markdown, sharp, extended, restructured_text, ...
#         * Alignment: left, center, right
#         * Padding: per-cell padding (left, right, top, bottom)
#         * Width: per-column width constraints
#         * Color: ANSI color via crossterm/owo-colors
#         * Border: per-cell border override
#         * Highlight: row/column highlighting
#         * Margin: outer table margin
#         * Span: cell-span (colspan/rowspan)
#      Compare:
#         * prettytable-rs: format::FormatBuilder builder pattern
#         * comfy-table: .set_content_arrangement(...) + .apply_modifier
#         * cli-table3 (Node, R608): chars/style object literal
#         * tabled: Setting trait with .with() chain
#      FIRST documented Rust Axis 10 library with trait-based
#      declarative settings API.
#
#   3. 30+ BUILT-IN STYLES — tabled ships with 30+ pre-defined
#      Style values covering the entire ASCII + Unicode + Markdown
#      + ReStructuredText box-drawing space:
#
#          use tabled::settings::Style;
#
#          table.with(Style::blank());          // no borders
#          table.with(Style::ascii());          // +-+-+
#          table.with(Style::ascii_rounded());  // .-.
#          table.with(Style::modern());         // ┌─┬─┐
#          table.with(Style::rounded());        // ╭─┬─╮
#          table.with(Style::dots());           // ⠐⠐⠐
#          table.with(Style::psql());           // PSQL style
#          table.with(Style::markdown());       // Markdown tables
#          table.with(Style::sharp());          // ┏━┳━┓
#          table.with(Style::extended());       // ╔═╦═╗
#          table.with(Style::re_structured_text()); // ReST
#          // ...30+ more
#
#      Compare:
#         * prettytable-rs: ~10 built-in formats
#         * comfy-table: ~10 built-in styles
#         * cli-table3 (Node, R608): manual 17-key chars override
#         * tabled: 30+ built-in styles + per-style customization
#      FIRST documented Rust Axis 10 library with 30+ pre-defined
#      box-drawing style values.
#
#   4. PRINTER + COLOR INTEGRATION — tabled integrates with
#      crossterm + owo-colors for per-cell ANSI styling:
#
#          use tabled::settings::{Color, themes::Colorization};
#          use owo_colors::OwoColorize;
#
#          // Per-cell color via Format
#          table.with(Modify::new(Cell::new(1, 2)).with(Format::new(|s|
#              s.red().to_string())));
#
#          // Alternating-row colorization
#          table.with(Colorization::columns([Color::FG_RED,
#                                            Color::FG_BLUE]));
#
#      Compare:
#         * prettytable-rs: limited color support
#         * comfy-table: ContentArrangement::Dynamic with color
#         * tabled: Color setting via crossterm + owo-colors
#      FIRST documented Rust Axis 10 library with explicit
#      crossterm + owo-colors integration for per-cell coloring.
#
#   5. MAXIM-ZHIBURT / DECLARATIVE-RUST PROVENANCE — tabled is
#      maintained by Maxim Zhiburt who has built a family of
#      declarative Rust crates around the table-rendering theme:
#         * tabled (this) — main table library
#         * tabled_derive — proc-macro crate (separated for
#                             compile-time)
#         * papergrid — low-level grid renderer that tabled
#                        builds on
#      Downstream users (per crates.io reverse-deps + GitHub
#      code search):
#         * gluesql (THIS — SQL database)
#         * casey/just (command runner — 34k stars; uses tabled
#                        in `just --variables` output)
#         * cloudflare/quiche (qlog-dancer subcrate)
#         * huggingface/ratchet (ML inference)
#         * risc0/risc0 (ZK-STARK platform)
#         * juspay/omnix (Nix companion)
#         * ribbondz/rsv (CSV tool)
#         * 800+ more Rust CLI tools
#      FIRST documented Rust Axis 10 library with this specific
#      Maxim-Zhiburt + papergrid-backed declarative-Rust
#      provenance.
#
# tabled's relationship to other Rust table libraries (only one
# documented in Axis 10 — cli-table3, but that's Node.js):
#
#   * Unlike prettytable-rs — prettytable uses imperative
#                              row!()/cell!() macros without derive
#   * Unlike comfy-table — comfy-table uses builder API with
#                            ContentArrangement enums; no derive
#   * Unlike cli-table (Rust) — cli-table has derive but separate
#                                 #[table(...)] attribute syntax
#   * Unlike term-table — term-table is minimal builder no derive
#   * Closest cross-language analog: Node.js cli-table3 (R608) —
#                                       both serve same role but
#                                       different API style
#                                       (declarative derive vs.
#                                        imperative push)
#     tabled is the FIRST documented Rust Axis 10 library providing
#     derive-macro-driven struct-as-row table rendering with 30+
#     built-in styles + trait-based Setting modifications +
#     crossterm/owo-colors integration.
#
# -----------------------------------------------------------------------------
#
# THE gluesql CLI — clap-derive + tabled + rustyline REPL + 7 storage backends
#
# gluesql's CLI is in cli/src/lib.rs.  Uses clap 3.x with derive:
#
#     use clap::Parser;
#
#     #[derive(Parser, Debug)]
#     #[clap(name = "gluesql", about, version)]
#     struct Args {
#         /// SQL file to execute
#         #[clap(short, long, value_parser)]
#         execute: Option<PathBuf>,
#
#         /// PATH to dump whole database
#         #[clap(short, long, value_parser)]
#         dump: Option<PathBuf>,
#
#         /// Storage type to store data, default is memory
#         #[clap(short, long, value_parser)]
#         storage: Option<Storage>,
#
#         /// Storage path to load
#         #[clap(short, long, value_parser)]
#         path: Option<PathBuf>,
#
#         /// Upgrade storage data format to the latest version
#         #[clap(long, requires_all = &["storage", "path"],
#                       conflicts_with_all = &["execute", "dump"])]
#         upgrade: bool,
#     }
#
#     #[derive(clap::ValueEnum, Debug, Clone, Copy, PartialEq, Eq)]
#     enum Storage {
#         Memory, Sled, Redb, Json, Csv, Parquet, File,
#     }
#
# tabled is used in cli/src/print.rs to render query results.  When
# a SELECT statement returns rows, each row is converted into a
# Vec<Vec<String>> and rendered via tabled's runtime table-builder
# API (since query schemas are dynamic, gluesql doesn't use the
# derive macro directly — it uses tabled's builder for arbitrary-
# width tables).
#
# Five-axis distinctness from every other Rust Axis 10 library:
#
#   1. DERIVE MACRO STRUCT-AS-ROW — Only Rust table lib whose
#      PRIMARY API is `#[derive(Tabled)]` turning a struct's
#      fields into a row.
#
#   2. SETTING TRAIT DECLARATIVE MODIFICATIONS — Only Rust table
#      lib with `.with(Setting)` chain where every setting impls
#      a unified Setting trait.
#
#   3. 30+ BUILT-IN STYLES — Most extensive style library among
#      Rust table libs.
#
#   4. CROSSTERM + OWO-COLORS INTEGRATION — Explicit color
#      integration via established Rust color crates.
#
#   5. MAXIM-ZHIBURT + PAPERGRID PROVENANCE — Built on papergrid
#      low-level grid renderer with declarative-Rust philosophy.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/gluesql/gluesql/blob/main/cli/src/lib.rs
# clap derive declarations.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _gluesql_storages
_gluesql_storages=(
    'memory:in-memory storage (default)'
    'sled:Sled embedded key-value store'
    'redb:redb embedded key-value store'
    'json:one JSON file per table'
    'csv:one CSV file per table'
    'parquet:one Parquet file per table'
    'file:one file per row (filesystem-backed)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-e --execute)'{-e+,--execute=}'[SQL file to execute non-interactively]:sql file:_files -g "*.sql"' \
    '(-d --dump)'{-d+,--dump=}'[path to dump whole database]:dump path:_files' \
    '(-s --storage)'{-s+,--storage=}'[storage backend (default memory)]:storage:(memory sled redb json csv parquet file)' \
    '(-p --path)'{-p+,--path=}'[storage path to load]:path:_files' \
    '--upgrade[upgrade storage data format to the latest version (requires --storage + --path)]' \
    && ret=0

return ret
