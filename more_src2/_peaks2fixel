#compdef peaks2fixel
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/peaks2fixel.html
# Source: MRtrix3/mrtrix3 cmd/peaks2fixel.cpp — convert peak directions image to fixel directory (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-dataname+[output fixel data filename (no ext)]:path:_default' \
    '1:directions (input peaks image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:fixels (output fixel dir):_files -/' \
    && ret=0

return ret
