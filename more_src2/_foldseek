#compdef foldseek
# _foldseek — Steinegger Lab foldseek CLI ultra-fast protein structure search using 3Di-structural alphabet seeded with MMseqs2 prefilter for AlphaFold ESMfold PDB-format CIF protein structures with TM-score local global alignment foldseek-easy-search easy-cluster easy-rbh easy-multimer pipelines (Martin Steinegger team, C++); getopt
# upstream: https://github.com/steineggerlab/foldseek

_foldseek() {
    local -a sub=(
        'easy-search:run easy-search workflow'
        'easy-cluster:run easy-cluster workflow'
        'easy-rbh:run easy reciprocal-best-hit workflow'
        'easy-multimerwithdb:multimer with db'
        'createdb:create database'
        'search:run search'
        'cluster:cluster a database'
        'tmalign:run tmalign on hits'
        'convertalis:convert alignment file'
        'convert2fasta:convert db to fasta'
        'structureto3didescriptor:convert structure to 3Di descriptor'
        'rbh:reciprocal best hits'
        'databases:list pre-built databases'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]:l:(0 1 2 3)' \
        '--threads=+[N]:n:' \
        '--alignment-type=+[t]:t:(0 1 2)' \
        '--format-mode=+[m]:m:(0 1 2 3 4 5)' \
        '--format-output=+[fields]:str:' \
        '-e+[evalue]:str:' \
        '--e-profile=+[N]:str:' \
        '--exhaustive-search[exhaustive]' \
        '--max-seqs=+[N]:n:' \
        '--max-seq-len=+[N]:n:' \
        '-c+[coverage]:n:' \
        '--cov-mode=+[m]:m:(0 1 2 3 4 5)' \
        '--min-seq-id=+[N]:n:' \
        '--tmscore-threshold=+[N]:n:' \
        '-a[full alignment output]' \
        '--realign[realign hits]' \
        '--db-load-mode=+[m]:m:(0 1 2 3)' \
        '--remove-tmp-files[remove temp files]' \
        '--prefilter-mode=+[m]:m:(0 1)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'foldseek subcommand' sub ;;
        args)
            case $words[1] in
                easy-search|easy-cluster|easy-rbh|easy-multimerwithdb) _arguments \
                    '*:input files:_files -g "*.pdb *.cif *.pdb.gz *.cif.gz *.fa *.fasta *.faa"' ;;
                createdb) _arguments '*:fasta/pdb file:_files' ;;
            esac
            ;;
    esac
}

_foldseek "$@"
