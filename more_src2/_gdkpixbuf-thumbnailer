#compdef gdk-pixbuf-thumbnailer gdkpixbuf-thumbnailer
# Documentation: https://gitlab.gnome.org/GNOME/gdk-pixbuf/-/tree/master/thumbnailer
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-s+[set output thumbnail size in pixels]:size:' \
  '*:source destination:_files' && ret=0

return ret
