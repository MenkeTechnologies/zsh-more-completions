#compdef keadm
# _keadm — KubeEdge installation/upgrade tool (kubeedge/kubeedge)
# upstream: https://github.com/kubeedge/kubeedge
# Subcommands from keadm/cmd/keadm/app/cmd/{cmd_others,config,cloud,edge}.go on tip.

_keadm() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                init:'bootstrap a cloud (cloudcore) installation'
                join:'bootstrap an edge node and join a cloud'
                reset:'reset a cloudcore/edgecore node'
                upgrade:'upgrade KubeEdge components'
                rollback:'rollback an upgrade'
                backup:'backup edge node state before upgrade'
                ctl:'kubectl-like CLI for edge resources'
                manifest:'generate KubeEdge install manifests'
                gettoken:'print the bootstrap join token'
                config:'configure keadm (image cache)'
                debug:'edge node debug commands'
                beta:'experimental beta commands'
                batch:'edge batch join from config'
                config-update:'update edgecore configuration'
                deprecated:'deprecated commands'
                version:'print keadm version'
            )
            _describe -t commands 'keadm command' cmds
            ;;
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--kubeedge-version=[KubeEdge version to install]:ver:' \
                        '--advertise-address=[cloudcore advertise IP]:ip:' \
                        '--kube-config=[kubeconfig file]:file:_files' \
                        '--manifests=[manifest file or directory]:path:_files' \
                        '(-f --files)'{-f,--files=}'[manifest file or directory]:path:_files' \
                        '(-d --dry-run)'{-d,--dry-run}'[print manifests, do not install]' \
                        '--external-helm-root=[external Helm chart root]:dir:_files -/' \
                        '--image-repository=[image repository override]:repo:' \
                        '--skip-preflight-checks[skip pre-install checks]' \
                        '*--set=[helm-style set key=value]:kv:' \
                        '--profile=[install profile or version=vX.Y]:profile:' \
                        '--force[force install over existing]'
                    ;;
                join)
                    _arguments \
                        '--cloudcore-ipport=[cloudcore IP:port]:host\:port:' \
                        '--token=[bootstrap token]:token:' \
                        '--edgenode-name=[edge node name]:name:' \
                        '--kubeedge-version=[KubeEdge version to install]:ver:' \
                        '--remote-runtime-endpoint=[CRI runtime endpoint]:uri:' \
                        '--image-repository=[image repository override]:repo:' \
                        '*--set=[helm-style set key=value]:kv:'
                    ;;
                config)
                    local -a sub=(
                        images:'manage container images keadm uses'
                    )
                    _describe -t subcommands 'keadm config subcommand' sub
                    ;;
            esac
            ;;
    esac
}

_keadm "$@"
