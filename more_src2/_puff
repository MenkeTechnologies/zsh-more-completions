#compdef puff
# Documentation: https://github.com/marcinjahn/puff
# Reference accessed: 2026-05-20
# Verified: upstream puff README at the URL above.

# puff: project files (configs) manager

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a project in the current directory'
  'add:add files or directories to puff'
  'forget:stop managing files (restore to project directory)'
  'status:show puff status for the current directory'
  'list:list all projects'
  'link:create symlinks for a project files in current directory'
  'project:manage projects'
  'cd:open shell in puff data directory'
  'completions:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'puff command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (init)
        _arguments \
          '-n+[project name]:name:' \
          '--associate=[link to existing managed configs]:name:' && ret=0
        ;;
      (add)
        _arguments \
          '-g[also add path to .gitignore]' \
          '--dir[indicate a non-existing directory path]' \
          '*:path:_files' && ret=0
        ;;
      (forget)
        _arguments \
          '-d[delete files instead of restoring them]' \
          '*:path:_files' && ret=0
        ;;
      (list)
        _arguments \
          '-a[show associated projects only]' \
          '-u[show unassociated projects only]' && ret=0
        ;;
      (link)
        _arguments '1:project:' && ret=0
        ;;
      (project)
        _arguments \
          '1:project subcommand:(forget)' \
          '*::project arg:' && ret=0
        ;;
      (cd)
        _arguments '-p[print the path instead of opening a shell]' && ret=0
        ;;
      (completions)
        _arguments '1:shell:(bash zsh fish powershell elvish)' && ret=0
        ;;
    esac
    ;;
esac

return ret
