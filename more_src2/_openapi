#compdef openapi
# Documentation: https://github.com/Redocly/redocly-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for the openapi CLI (Redocly CLI, formerly @redocly/openapi-cli)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    local -a cmds=(
      'lint:validate API descriptions'
      'bundle:bundle multiple OpenAPI documents into one'
      'build-docs:generate API reference HTML'
      'generate-arazzo:generate Arazzo workflows from OpenAPI'
      'respect:run Arazzo-based API contract tests'
      'help:show help'
    )
    _describe -t commands 'openapi command' cmds && ret=0
    ;;
  args) _files && ret=0 ;;
esac

return ret
