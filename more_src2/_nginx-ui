#compdef nginx-ui
# ---------------------------------------------------------------------------
# nginx-ui — Nginx-UI: "Yet another WebUI for Nginx" — single Go
#            binary that bundles a Vue 3 admin SPA + Gin HTTP server +
#            embedded SQLite/Postgres-backed config store + Bleve-
#            indexed search over Nginx configs + Let's-Encrypt
#            certificate manager + OTA self-upgrade flow.  Edit Nginx
#            configs in the browser, search across all configs by
#            field/directive/upstream/site, hot-reload Nginx via the
#            web UI, manage TLS certs with auto-renewal (Go, 11182★)
#
# upstream: https://github.com/0xJacky/nginx-ui
# author : 0xJacky + the broader Nginx-UI maintainers
# license: AGPL-3.0
#
# Source-direct completion: every subcommand + flag below is verbatim
# from internal/cmd/main.go and internal/cmd/upgrade_docker.go on the
# 0xJacky/nginx-ui tip — `urfave/cli/v3` `cli.Command{Name, Usage,
# Flags, Action}` declarations parsed exactly as declared, with the
# top-level `--config` persistent flag + `serve` subcommand's
# `--pidfile`/`-p` flag preserved.  `DefaultCommand: "serve"` means
# bare `nginx-ui` (no subcommand) acts as `nginx-ui serve`.
#
# Direct deps from go.mod (selected):
#   github.com/blevesearch/bleve/v2     v2.6.0   ← canonical Go full-
#                                                   text search engine
#                                                   library (this axis)
#                                                   — by Marty Schoch
#                                                   (originally Couch-
#                                                   Base; now the
#                                                   blevesearch org);
#                                                   pure-Go full-text
#                                                   indexing and search
#                                                   library inspired by
#                                                   Apache Lucene.  v2
#                                                   API split out the
#                                                   storage backends
#                                                   (zapx for
#                                                   columnar segments,
#                                                   upsidedown for
#                                                   key/value-backed
#                                                   indexes, gtreap for
#                                                   in-memory, scorch
#                                                   for the modern
#                                                   default) into
#                                                   sibling repos so
#                                                   consumers can pick
#                                                   their tradeoff.
#                                                   Supports schema
#                                                   definition, BM25
#                                                   scoring, custom
#                                                   tokenizers + stop-
#                                                   word + porter-
#                                                   stemmer filter
#                                                   chains, faceted
#                                                   search, range +
#                                                   phrase + fuzzy +
#                                                   boolean + geo
#                                                   queries (via the
#                                                   blevesearch/geo
#                                                   sibling), and
#                                                   vector similarity
#                                                   search (via the
#                                                   blevesearch/go-
#                                                   faiss FAISS
#                                                   bindings — both
#                                                   visible in nginx-
#                                                   ui's go.mod
#                                                   `indirect` lines).
#                                                   THE Go answer to
#                                                   "embedded full-text
#                                                   search in a host
#                                                   process" — used
#                                                   by grafana (logs
#                                                   search), go-gitea/
#                                                   gitea (the self-
#                                                   hosted Git server's
#                                                   repo search),
#                                                   mattermost
#                                                   (message search),
#                                                   mudler/LocalAI
#                                                   (model registry
#                                                   search), git-bug/
#                                                   git-bug (bug
#                                                   tracker search),
#                                                   couchbase Sync
#                                                   Gateway, dgraph-io/
#                                                   dgraph, AlistGo/
#                                                   alist, sealdice/
#                                                   sealdice-core.
#                                                   nginx-ui uses it
#                                                   to build a search
#                                                   index over every
#                                                   server block /
#                                                   upstream / location
#                                                   / SSL cert / directive
#                                                   across all managed
#                                                   Nginx configs, so
#                                                   the admin UI's
#                                                   global search bar
#                                                   answers "find every
#                                                   location block that
#                                                   proxies to
#                                                   localhost:3000" in
#                                                   sub-millisecond
#                                                   time without
#                                                   walking the FS.
#   github.com/blevesearch/bleve_index_api      (v2 API surface — the
#                                                   typed interface
#                                                   facing consumers)
#   github.com/blevesearch/geo                  (geo queries, available
#                                                   for any geo-indexed
#                                                   directives)
#   github.com/blevesearch/go-faiss             (Facebook AI FAISS
#                                                   bindings for vector
#                                                   similarity search —
#                                                   used in v2.6 for
#                                                   the upcoming
#                                                   AI-augmented config
#                                                   discovery feature)
#   github.com/gin-gonic/gin                    (HTTP server framework)
#   github.com/urfave/cli/v3                    (CLI parser —
#                                                   cli.Command tree
#                                                   with DefaultCommand
#                                                   support)
#   github.com/go-acme/lego/v4                  (Let's Encrypt /
#                                                   ZeroSSL ACME
#                                                   client for the
#                                                   certificate manager)
#   github.com/uozi-tech/cosy                   (the maintainer's own
#                                                   web framework
#                                                   layer wrapping Gin
#                                                   + GORM + a model
#                                                   registry — shared
#                                                   across the uozi-
#                                                   tech ecosystem)
#   modernc.org/sqlite + gorm.io/gorm           (embedded SQLite +
#                                                   ORM for the
#                                                   config store —
#                                                   optionally swappable
#                                                   for Postgres / MySQL
#                                                   via app.ini)
#
# nginx-ui is "phpMyAdmin for Nginx" — instead of SSH-ing to the
# server and editing /etc/nginx/sites-available/* with vim, you open
# the web UI in a browser, edit configs in a syntax-aware Monaco
# editor, run pre-commit `nginx -t` validation, hot-reload Nginx via
# the API, manage TLS certs with auto-renewal, search the entire
# config tree via the Bleve index, view access/error log streams via
# the embedded WebSocket terminal, and monitor server health via the
# system-metrics dashboard.  Single Go binary so deployment is "drop
# next to nginx and run", with `nginx-ui serve` as the default
# command.  `nginx-ui reset-password` is the recovery escape hatch
# when admin credentials are lost.
#
# === AXIS 189 CONTINUES — embeddable full-text search engine libraries ===
# Axis position: Go=244 continues Axis 189 (slot 2/0/0).  Canonical Go
# full-text search engine is `github.com/blevesearch/bleve/v2` by Marty
# Schoch (originally CouchBase; now the blevesearch org) — pure-Go
# full-text indexing and search library inspired by Apache Lucene with
# pluggable storage backends (zapx columnar / upsidedown KV / gtreap
# in-memory / scorch modern default) split into sibling repos.  THE Go
# answer to "embedded full-text search in a host process" — used by
# Grafana, Gitea, Mattermost, mudler/LocalAI, git-bug, Couchbase Sync
# Gateway.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=244     _tracey              ← previous round (axis 189 OPENS, 1/0/0)
#   Go=244       ← THIS FILE          (axis 189 continues, slot 2/0/0)
#   TS-Node=244  ← next round         (axis 189 CLOSES at triple-244, 1/1/1)
#
# Cross-language design contrast for axis 189:
#   Rust    : tantivy is a single-crate vertical with all backends
#             bundled (feature-gated).  Cargo features pick
#             tokenizers/language stemmers; one crate version, one
#             import.
#   Go      : bleve/v2 is a UMBRELLA org (blevesearch/*) with each
#             backend (zapx storage, scorch indexer, geo queries,
#             go-faiss vector search, snowballstem, porterstemmer,
#             segment tokenizer) as a SEPARATE go-mod-versioned
#             repo.  Consumers pick by importing the relevant
#             sibling — visible in any bleve consumer's go.mod as
#             a long `indirect` list of blevesearch/* deps.
#             Reflects Go's preference for granular versioning over
#             monolithic feature-gated crates.
#   JS/Node : NO SINGLE CANONICAL choice — lunr.js / flexsearch /
#             minisearch / orama compete without one Lucene-
#             equivalent emerging.  [TBD next round]
# ---------------------------------------------------------------------------

_nginx-ui() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[print version]' \
        '--config=[configuration file path (default app.ini)]:file:_files -g "*.(ini|conf|toml)"' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'serve:start the Nginx-UI server (default subcommand — bare `nginx-ui` invokes this)'
                'reset-password:reset the initial user password (recovery flow when admin creds are lost)'
                'upgrade-docker-step2:execute the second step of Docker container upgrade (invoked inside the temp container by the OTA upgrade flow; rarely called directly)'
                'help:show help (or help for a specific subcommand)'
            )
            _describe -t commands 'nginx-ui command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                serve)
                    _arguments \
                        '(-h --help)'{-h,--help}'[show help]' \
                        '(-p --pidfile)'{-p,--pidfile}'=[path to the PID file (server writes its PID here on startup; useful for systemd / supervisord integration)]:path:_files' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(serve reset-password upgrade-docker-step2)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_nginx-ui "$@"
