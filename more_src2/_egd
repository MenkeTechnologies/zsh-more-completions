# egd: Entropy Gathering Daemon (legacy Perl daemon)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-b[bind path]:path:_files' \
  '-w[wait for connections]' \
  '-d[daemonize]' \
  '*::egd args:_files' && ret=0
return ret
