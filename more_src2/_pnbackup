# Pinboard notes backup (pnbackup) — Haskell tool for syncing Pinboard notes.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[display more information about sync progress]' \
  '-t+[Pinboard username:api token]:username\:token:' \
  '*:output file:_files' && return 0
