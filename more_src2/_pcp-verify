#compdef pcp-verify
# _pcp-verify — verify a PCP installation or archive (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/verify/pcp-verify.1 SYNOPSIS.

_pcp-verify() {
    _arguments \
        '(- *)-?[show help]' \
        '(- *)-V[show version]' \
        '-a+[PCP archive folio]:archive:_files' \
        '-D+[debug specification]:spec:' \
        '-h+[remote host]:host:_hosts' \
        '-c[client side verification]' \
        '-s[server side verification]' \
        '-v[verbose output]'
}

_pcp-verify "$@"
