#compdef pg_restore
# Documentation: pg_restore --help (PostgreSQL)
# Source: restore a PostgreSQL database from a pg_dump archive.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-d+,--dbname=}'[connect to database name]:db:' \
    {-f+,--file=}'[output file name (- for stdout)]:file:_files' \
    {-F+,--format=}'[backup format]:format:(c d t)' \
    {-l,--list}'[print summarized TOC]' \
    {-v,--verbose}'[verbose]' \
    {-a,--data-only}'[restore data only]' \
    {-c,--clean}'[drop objects before recreating]' \
    {-C,--create}'[create target database]' \
    {-e,--exit-on-error}'[exit on error]' \
    '*'{-I+,--index=}'[restore named index]:name:' \
    {-j+,--jobs=}'[parallel jobs]:n:' \
    {-L+,--use-list=}'[use TOC list file]:file:_files' \
    '*'{-n+,--schema=}'[restore matching schemas]:name:' \
    '*'{-N+,--exclude-schema=}'[exclude schemas]:name:' \
    {-O,--no-owner}'[skip ownership restore]' \
    '*'{-P+,--function=}'[restore named function(args)]:func:' \
    {-s,--schema-only}'[restore schema only]' \
    {-S+,--superuser=}'[superuser for disabling triggers]:user:_users' \
    '*'{-t+,--table=}'[restore matching tables]:name:' \
    '*'{-T+,--trigger=}'[restore named trigger]:name:' \
    {-x,--no-privileges}'[skip GRANT/REVOKE restore]' \
    {-1,--single-transaction}'[restore as single transaction]' \
    '--disable-triggers[disable triggers during data-only restore]' \
    '--enable-row-security[enable row security]' \
    '--if-exists[use IF EXISTS when dropping]' \
    '--no-comments[skip comments]' \
    '--no-data-for-failed-tables[skip data for failed tables]' \
    '--no-publications[skip publications]' \
    '--no-security-labels[skip security labels]' \
    '--no-subscriptions[skip subscriptions]' \
    '--no-tablespaces[skip tablespace assignments]' \
    '--restrict-key=[restrict key string]:key:' \
    '--section=[restore named section]:section:(pre-data data post-data)' \
    '--strict-names[require include patterns to match]' \
    '--use-set-session-authorization[ALTER OWNER → SET SESSION AUTHORIZATION]' \
    {-h+,--host=}'[server host/socket]:host:_hosts' \
    {-p+,--port=}'[server port]:port:_ports' \
    {-U+,--username=}'[connect as user]:user:_users' \
    {-w,--no-password}'[never prompt for password]' \
    {-W,--password}'[force password prompt]' \
    '--role=[do SET ROLE before restore]:role:' \
    ':archive file:_files' \
    && ret=0

return ret
