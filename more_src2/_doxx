#compdef doxx
# Documentation: https://github.com/bgreenwell/doxx
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# doxx: terminal-based Word document viewer

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --outline)'{-o,--outline}'[start with outline view]' \
  '(-p --page)'{-p,--page}'[jump to page on startup]:page' \
  '(-s --search)'{-s,--search}'[search and highlight term]:term' \
  '--force-ui[force interactive UI mode]' \
  '--color[enable color support]' \
  '--export=[export format]:format:(markdown text csv json ansi)' \
  '(-w --terminal-width)'{-w,--terminal-width}'[set formatting width]:cols' \
  '--color-depth=[control colors]:depth:(auto 1 4 8 24)' \
  '--images[display images inline]' \
  '--extract-images=[save images to directory]:dir:_files -/' \
  '--image-width=[image width]:width' \
  '--image-height=[image height]:height' \
  '--image-scale=[image scale]:scale' \
  '*:docx file:_files -g "*.docx"'
