#compdef makeself makeself.sh
# Documentation: https://makeself.io/
# Source: megastep/makeself makeself.sh (master) — make self-extractable shell archives (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --version)'{-v,--version}'[show version]' \
    '(-h --help)'{-h,--help}'[show help]' \
    '--tar-quietly[suppress tar verbose output]' \
    '(-q --quiet)'{-q,--quiet}'[suppress non-error messages]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--gzip[compress with gzip]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--pigz[compress with pigz]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--zstd[compress with zstd]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--bzip2[compress with bzip2]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--pbzip2[compress with pbzip2]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--bzip3[compress with bzip3]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--xz[compress with xz]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--lzo[compress with lzop]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--lz4[compress with lz4]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--compress[compress with UNIX compress]' \
    '(--gzip --pigz --zstd --bzip2 --pbzip2 --bzip3 --xz --lzo --lz4 --compress --nocomp)--nocomp[do not compress]' \
    '--complevel=[compression level]:level:_default' \
    '--comp-extra=[extra options to compressor]:opts:_default' \
    '--threads=[number of threads]:N:_default' \
    '--base64[base64-encode final archive]' \
    '(--gpg-encrypt --gpg-asymmetric-encrypt-sign --ssl-encrypt)--gpg-encrypt[GPG-encrypt the archive]' \
    '(--gpg-encrypt --gpg-asymmetric-encrypt-sign --ssl-encrypt)--gpg-asymmetric-encrypt-sign[GPG asymmetric encrypt and sign]' \
    '--gpg-extra=[extra GPG options]:opt:_default' \
    '(--gpg-encrypt --gpg-asymmetric-encrypt-sign --ssl-encrypt)--ssl-encrypt[OpenSSL-encrypt the archive]' \
    '--ssl-passwd=[OpenSSL password]:password:_default' \
    '--ssl-pass-src=[OpenSSL pass source]:src:_default' \
    '--ssl-no-md[do not use -md option]' \
    '(--chown --nochown)--nochown[do not chown target]' \
    '(--chown --nochown)--chown[chown target recursively]' \
    '--notemp[install archive_dir in CWD]' \
    '--needroot[require root for extraction]' \
    '--copy[archive copies itself first]' \
    '--append[append files to existing archive]' \
    '(--target --current)--target=[extract to target directory]:dir:_files -/' \
    '(--target --current)--current[extract to current dir]' \
    '--nooverwrite[do not overwrite existing target]' \
    '--tar-format=[tar archive format]:format:(ustar pax v7 oldgnu gnu)' \
    '--tar-extra=[extra tar options]:opts:_default' \
    '--untar-extra=[extra untar options]:opts:_default' \
    '--nomd5[do not compute MD5]' \
    '--nocrc[do not compute CRC]' \
    '--sha256[compute SHA256 checksum]' \
    '--header=[header script]:file:_files' \
    '--preextract=[pre-extraction script]:file:_files' \
    '--cleanup=[cleanup script]:file:_files' \
    '--follow[follow symlinks in archive]' \
    '--sign=[GPG key id to sign archive]:keyid:_default' \
    '1:archive directory:_files -/' \
    '2:archive filename:_files -g "*.run"' \
    '3:label string:_default' \
    '4:startup script:_command_names -e' \
    '*::script args:_default' \
    && ret=0

return ret
