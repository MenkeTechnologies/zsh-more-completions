#compdef kirox
# Documentation: https://www.npmjs.com/package/kiro-cli
# Reference accessed: 2026-05-23
# Verified: https://yukihirop.github.io/kirox/ CLI reference.

# Zsh completion for kirox - fetch Kiro spec and steering files from GitHub (kiro-cli npm)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'add:incrementally add new projects'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--steering[fetch only steering documents]' \
  '--track[detect remote changes and update modified files]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'kirox command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
