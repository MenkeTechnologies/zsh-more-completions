#compdef fnid
# Documentation: man fnid(1)
# Source: GNU idutils fnid (man) — print file names from ID database matching a pattern (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-f --file)'{-f+,--file=}'[ID database file]:file:_files' \
    '(-S --separator)'{-S+,--separator=}'[output separator style]:style:(braces space newline)' \
    '--help[show help]' \
    '--version[show version]' \
    '*:pattern:_default' \
    && ret=0

return ret
