#compdef gnome-screensaver
# Documentation: https://manpages.debian.org/gnome-screensaver
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gnome-screensaver: GNOME 2-era screensaver daemon.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)--help-gtk[show GTK options]' \
  '--no-daemon[do not become a daemon]' \
  '--debug[enable debugging code]' \
  '*::gnome-screensaver args:_files' && ret=0
return ret
