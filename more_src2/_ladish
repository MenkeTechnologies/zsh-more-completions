#compdef ladish ladishd ladish_control gladish
# _ladish — Nedko Arnaudov LADI Session Handler ladishd daemon ladish_control client and gladish GUI for JACK-based audio session management with studio save/load (linuxaudio team, C); getopt
# upstream: https://www.ladish.org/

_ladish() {
    local -a sub=(
        'load:load studio'
        'save:save studio'
        'rename:rename studio'
        'unload:unload studio'
        'new:create new studio'
        'delete:delete studio'
        'start:start studio'
        'stop:stop studio'
        'rename-room:rename room'
        'create-room:create room'
        'delete-room:delete room'
        'create-app:create app'
        'list:list studios'
        'list-rooms:list rooms'
        'list-apps:list apps'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--no-jack[no JACK]' \
        '--no-a2j[no a2j]' \
        '--studio=+[name]:str:' \
        '--room=+[name]:str:' \
        '--app=+[name]:str:' \
        '--terminal[run app in terminal]' \
        '--level=+[level]:l:(0 1 2 3 jack lash ladish)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ladish subcommand' sub ;;
        args)
            case $words[1] in
                load|save|delete|rename|new|start|stop) _arguments '*:studio name:' ;;
                create-app) _arguments '*:command:_command_names -e' ;;
            esac
            ;;
    esac
}

_ladish "$@"
