#compdef kglobalaccel5
# Documentation: https://github.com/KDE/kglobalaccel
# Reference accessed: 2026-05-19
# Verified: kglobalaccel5 is the KDE global-shortcut D-Bus daemon
# (KDE/kglobalaccel framework); it is started by the session, takes no
# documented custom command-line options beyond the Qt/KAboutData
# standard set. STUB. Corrected from prior file: removed fabricated
# --display= and the bogus man.archlinux.org search URL.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options including Qt options]' && ret=0

return ret
