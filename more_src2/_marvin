#compdef marvin
# Documentation: https://github.com/PrefectHQ/marvin
# Reference accessed: 2026-05-22
# Verified: src/marvin/cli/main.py and config.py Typer apps.

# Zsh completion for marvin - Marvin AI engineering toolkit CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'marvin command' \
      'version[show Marvin version info]' \
      'x[extract cast or generate from stdin]' \
      'dev[development utilities]' \
      'db[database migrations]' \
      'config[manage Marvin configuration]' && ret=0
    ;;
  args)
    case $line[1] in
      x)
        _arguments \
          '(-o --operation)'{-o,--operation}'[operation]:op:(extract cast generate)' \
          '(-t --type)'{-t,--type}'[target type to eval]:type:' \
          '(-i --instructions)'{-i,--instructions}'[extraction instructions]:text:' \
          '(-n --n)'{-n,--n}'[number of results for generate]:n:' \
          '*:stdin data:' && ret=0
        ;;
      config)
        _arguments '1:config command:(view get)' && ret=0
        ;;
    esac
    ;;
esac

return ret
