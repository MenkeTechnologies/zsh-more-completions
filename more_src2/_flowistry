#compdef flowistry cargo-flowistry flowistry-driver
# _flowistry — Flowistry: information-flow IDE plugin for Rust (willcrichton/flowistry)
# upstream: https://github.com/willcrichton/flowistry
# Subcommands from crates/flowistry_ide/src/plugin.rs (clap derive).

_flowistry() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--bench=[run as benchmark]:bool:(true false)' \
        '--context-mode=[function-context evaluation mode]:mode:(sig-only recurse)' \
        '--mutability-mode=[mutability handling in slicing]:mode:(distinguish-mut ignore-mut)' \
        '--pointer-mode=[pointer-analysis precision]:mode:(precise imprecise)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_flowistry_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                spans)
                    _arguments \
                        '1:Rust source file:_files -g "*.rs"' && ret=0 ;;
                focus)
                    _arguments \
                        '1:Rust source file:_files -g "*.rs"' \
                        '2:line:' \
                        '3:column:' && ret=0 ;;
                decompose)
                    _arguments \
                        '1:Rust source file:_files -g "*.rs"' \
                        '2:byte position:' && ret=0 ;;
                playground)
                    _arguments \
                        '1:Rust source file:_files -g "*.rs"' \
                        '2:start line:' \
                        '3:start column:' \
                        '4:end line:' \
                        '5:end column:' && ret=0 ;;
                preload|rustc-version) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_flowistry_commands] )) ||
_flowistry_commands() {
    local -a commands
    commands=(
        'spans:emit body spans for a file (IDE consumption)'
        'focus:compute the focus highlights for a cursor position'
        'decompose:decompose a function around a byte position'
        'playground:compute slicing for the given selection range'
        'preload:pre-build dependencies so the driver runs fast later'
        'rustc-version:print the rustc version Flowistry was built against'
    )
    _describe -t commands 'cargo flowistry command' commands
}

_flowistry "$@"
