#compdef kam
# Documentation: https://github.com/redhat-developer/kam/blob/master/docs/commands/kam_bootstrap.md
# Reference accessed: 2026-05-19
# Verified: upstream docs/commands at the URL above.

# GitOps Application Manager (kam). Bootstrap flags corrected/expanded
# from prior file against docs/commands/kam_bootstrap.md: added
# --gitops-webhook-secret, -p/--prefix, --private-repo-driver,
# --save-token-keyring, --service-webhook-secret.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      bootstrap:'bootstrap GitOps CI/CD'
      build:'build pipeline definitions'
      completion:'emit shell completion scripts'
      environment:'manage GitOps environments'
      service:'manage services in an environment'
      version:'print version details'
      webhook:'configure Git webhooks'
    )
    _describe -t commands command commands && ret=0
    ;;
  (args)
    case $words[1] in
      bootstrap)
        _arguments -s -S \
          '--service-repo-url=[service repository URL]:url:' \
          '--gitops-repo-url=[gitops repository URL]:url:' \
          '--git-host-access-token=[Git provider access token]:token:' \
          '--image-repo=[image registry/repository]:repo:' \
          '--dockercfgjson=[filepath to config.json for image push auth]:file:_files' \
          '--output=[path to write GitOps resources]:dir:_directories' \
          '--gitops-webhook-secret=[secret to authenticate GitOps repo hooks]:secret:' \
          '--service-webhook-secret=[secret to authenticate Service repo hooks]:secret:' \
          '(-p --prefix)'{-p,--prefix}'=[prefix added to environment names]:prefix:' \
          '--private-repo-driver=[driver for custom-domain repos]:driver:(github gitlab)' \
          '--save-token-keyring[update git-host-access-token in keyring]' \
          '--push-to-git[create and populate gitops-repo-url]' \
          '--interactive[prompt for unset options]' \
          '--overwrite[overwrite existing GitOps configuration]' \
          '(- *)'{-h,--help}'[show help]' && ret=0
        ;;
      *)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
