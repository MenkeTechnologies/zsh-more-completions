#compdef eg
# _eg-examples — srsudar/eg (Python tool printing example usage of common Unix commands; eg <prog> prints the matching example file, --list lists all known programs, --edit opens entry in $EDITOR, --custom-dir / --examples-dir add extra example dirs, --config-file picks an alt config)
# upstream: https://github.com/srsudar/eg
# Flags from eg eg/cli.py on tip.

_eg-examples() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-l[list known programs]' \
        '--list[list known programs]' \
        '-e+[edit example]:program:' \
        '--edit+[edit example]:program:' \
        '-f+[config file]:file:_files' \
        '--config-file+[config file]:file:_files' \
        '--custom-dir+[user-custom examples dir]:dir:_files -/' \
        '--examples-dir+[bundled examples dir]:dir:_files -/' \
        '--use-color[force color]' \
        '--no-color[disable color]' \
        '--pager-cmd+[pager command]:pager:_command_names -e' \
        '*:program:_command_names -e'
}

_eg-examples "$@"
