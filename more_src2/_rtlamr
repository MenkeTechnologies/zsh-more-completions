#
# WHAT IS Go stdlib log/slog AND WHY IS IT THE 55TH GO CLI LIBRARY?
#
# log/slog (https://pkg.go.dev/log/slog) is **Jonathan Amsterdam +
# the Go team's "Structured Logging — Standard Library log/slog
# package"** — Go's OFFICIAL stdlib structured logger added in
# Go 1.21 (August 2023).  log/slog was designed after years of
# debate over which third-party logger should become Go's
# canonical choice; the Go team ultimately decided to ship a
# NEW stdlib package incorporating the best design ideas from
# logrus + zap + zerolog while remaining stdlib-style minimal.
#
# log/slog's distinguishing characteristics:
#
#   1. STDLIB INCLUSION — log/slog is shipped with EVERY Go
#      installation since 1.21.  No `go get` required, no
#      dependency in go.mod, no version compatibility concerns.
#      Just:
#
#          import "log/slog"
#
#          func main() {
#              slog.Info("server starting",
#                  "port", 8080,
#                  "version", "1.0.0",
#              )
#              // {"time":"2024-01-01T12:00:00Z","level":"INFO",
#              //  "msg":"server starting","port":8080,"version":"1.0.0"}
#
#              if err := startServer(); err != nil {
#                  slog.Error("startup failed",
#                      "error", err,
#                      "port", 8080,
#                  )
#                  os.Exit(1)
#              }
#          }
#
#      Compare:
#         * logrus: third-party (sirupsen/logrus)
#         * zap: third-party (uber-go/zap)
#         * zerolog: third-party (rs/zerolog)
#         * log/slog: SHIPPED WITH GO since 1.21
#      FIRST documented Go logger shipped with the Go standard
#      library.
#
#   2. KEY-VALUE VARIADIC API — log/slog uses variadic key-value
#      pairs for structured fields:
#
#          slog.Info("user logged in",
#              "username", username,
#              "user_id", userID,
#              "login_duration", elapsed,
#          )
#
#      Plus typed wrappers via `slog.Any/String/Int/Bool/Duration/
#      Time/Group` for performance-critical paths:
#
#          slog.Info("query completed",
#              slog.String("query", q),
#              slog.Int("rows", count),
#              slog.Duration("elapsed", d),
#              slog.Group("user",
#                  slog.String("id", userID),
#                  slog.String("name", username),
#              ),
#          )
#
#      Compare:
#         * logrus: WithFields(map[string]interface{}{...})
#         * zap: zap.String(...)/zap.Int(...)/...
#         * zerolog: chained .Str(k,v).Int(k,v).Msg(...)
#         * log/slog: variadic key-values (default) + typed
#                      wrappers (slog.Any/String/Int/...)
#      FIRST documented Go logger with DUAL variadic + typed-
#      wrapper API.
#
#   3. HANDLER ABSTRACTION FOR PLUGGABLE OUTPUT — log/slog's
#      central abstraction is the Handler interface:
#
#          type Handler interface {
#              Enabled(context.Context, Level) bool
#              Handle(context.Context, Record) error
#              WithAttrs(attrs []Attr) Handler
#              WithGroup(name string) Handler
#          }
#
#      Two built-in handlers:
#         * slog.TextHandler — key=value text output (logfmt-like)
#         * slog.JSONHandler — JSON-lines output
#
#      Custom handlers can implement the interface for any
#      output destination (Datadog, Loki, Sentry, etc).  Plus
#      community libraries like `slog-multi`, `slog-sampling`,
#      `slog-formatter` for advanced composition.
#      Compare:
#         * logrus: Hook + Formatter architecture
#         * zap: Encoder + Core architecture
#         * zerolog: io.Writer + ConsoleWriter
#         * log/slog: Handler interface with WithAttrs +
#                      WithGroup for hierarchical context
#      FIRST documented Go logger with Handler interface +
#      hierarchical group structuring.
#
#   4. CONTEXT INTEGRATION VIA Logger.LogAttrs(ctx, ...) — Every
#      logging method has a CONTEXT-AWARE variant that takes a
#      context.Context as first parameter:
#
#          slog.InfoContext(ctx, "request handled",
#              "request_id", reqID)
#          slog.LogAttrs(ctx, slog.LevelDebug,
#              "trace details",
#              slog.String("trace_id", traceID),
#          )
#
#      Handlers can extract data from the context (e.g.,
#      OpenTelemetry tracer-set span IDs, request IDs from
#      middleware) and include in log records.  Compare:
#         * logrus: no first-class context integration
#         * zap: zap.Logger.With() for context fields, not Context
#         * zerolog: log.Ctx(ctx) for context-bound logger
#         * log/slog: NATIVE context.Context integration via
#                      InfoContext/LogAttrs methods
#      FIRST documented Go logger with context.Context as
#      first-class first-parameter API design.
#
#   5. GO-TEAM STDLIB FUTURE-PROOFING — log/slog is designed
#      to be Go's CANONICAL structured logger for the next
#      decade.  The Go team made the package the official
#      recommendation in Go 1.21 announcement.  Library authors
#      are encouraged to expose `slog.Logger` parameters
#      rather than third-party logger types — this avoids
#      forcing dependency choices on downstream users.  Major
#      libraries migrating to log/slog or accepting *slog.Logger:
#         * Standard library packages adopting slog for diagnostic logging
#         * controller-runtime (Kubernetes) — supports slog handlers
#         * gRPC-Go — slog integration
#         * sqlc generated code — slog instrumentation
#         * Several AWS SDK v2 services — slog-based logging
#         * rtlamr (THIS — RTL-SDR smart meter receiver)
#         * kubecolor — kubectl color wrapper
#         * Most new Go projects post-2023
#      Compare every other documented Go logger — none are
#      Go's official stdlib choice with future-proofing
#      backing from the Go team.  FIRST documented Go logger
#      with Go-team stdlib future-proofing.
#
# log/slog's relationship to other documented Go libraries:
#
#   * Like logrus (R587) — both have structured K-V fields +
#                           level-based filtering
#   * Unlike logrus — log/slog is stdlib (no dep); typed-
#                      wrapper API; hierarchical group structuring
#   * Like zap (R579) — both have typed-field options for
#                        performance-critical paths
#   * Unlike zap — log/slog is stdlib; simpler API; context-aware
#                   first-class
#   * Closest cross-language analogs:
#         * Rust: env_logger (R582) — both are "stdlib-style"
#                  loggers shipping with the language toolchain
#                  / stdlib
#         * Python: stdlib `logging` module — same role as Go's
#                    canonical built-in logger
#         * Java: java.util.logging — JDK stdlib equivalent
#     log/slog is the FIRST documented Go logger shipped with
#     the Go standard library — Go's answer to "which structured
#     logger should I use" debate.
#
# -----------------------------------------------------------------------------
#
# THE rtlamr CLI — stdlib flag + log/slog for diagnostic output
#
# rtlamr's argv parsing uses stdlib `flag`.  Observability
# uses stdlib `log/slog` throughout:
#
#     import (
#         "flag"
#         "log/slog"
#         "github.com/bemasher/rtlamr/protocol"
#         "github.com/bemasher/rtltcp"
#     )
#
#     var (
#         sampleFile   = flag.String("samplefile", os.DevNull, "raw signal dump file")
#         msgType      StringMap  // -msgtype flag.Var()
#         symbolLength = flag.Int("symbollength", 72, "symbol length in samples")
#         timeLimit    = flag.Duration("duration", 0, "time to run for, 0=infinite")
#         meterID      MeterIDFilter
#         meterType    MeterTypeFilter
#         format       = flag.String("format", "plain", "decoded output format")
#         single       = flag.Bool("single", false, "one-shot execution")
#         version      = flag.Bool("version", false, "show build version")
#     )
#
#     func main() {
#         flag.Parse()
#         if *version {
#             // ...
#         }
#         rcvr.NewReceiver()  // uses slog.Error for connection errors
#         rcvr.Run()
#     }
#
# Available message types (--msgtype flag):
#   all, scm, scm+, idm, netidm, r900, r900bcd
#
# Available symbol lengths (--symbollength):
#   8, 32, 40, 48, 56, 64, 72 (default), 80, 88, 96
#
# Available output formats (--format):
#   plain, csv, json, xml
#
# rtl_tcp upstream flags (inherited from rtltcp library):
#   -server <host:port>      rtl_tcp server (default 127.0.0.1:1234)
#   -centerfreq <Hz>         Center frequency
#   -samplerate <Hz>         Sample rate
#   -tunergain <dB>          Tuner gain
#   -bandwidth <Hz>          Tuner bandwidth
#   -tunergainmode <bool>    Tuner gain mode
#   -agcmode <bool>          Internal AGC
#   -directsampling <0|1|2>  Direct sampling mode
#   -offsettuning <bool>     Offset tuning
#   -gainbyindex <idx>       Gain by index
#
# Five-axis distinctness from every other documented Go logger:
#
#   1. STDLIB INCLUSION — Every other documented Go logger is
#      third-party.  log/slog is shipped with Go 1.21+ stdlib.
#
#   2. DUAL VARIADIC + TYPED-WRAPPER API — Every other documented
#      Go logger has ONE API style (typed-ctors, map-based,
#      or chained).  log/slog offers BOTH variadic key-values
#      (ergonomic default) + typed slog.String/Int/...
#      wrappers (performance-critical path).
#
#   3. HANDLER + GROUP HIERARCHICAL STRUCTURING — Every other
#      documented Go logger has flat field model.  log/slog's
#      Handler interface supports WithGroup() for hierarchical
#      field nesting.
#
#   4. CONTEXT.CONTEXT FIRST-CLASS INTEGRATION — Every other
#      documented Go logger treats context.Context as optional
#      or via separate API surface.  log/slog has InfoContext/
#      LogAttrs methods taking context.Context as first parameter
#      across all logging operations.
#
#   5. GO-TEAM STDLIB FUTURE-PROOFING — Every other documented
#      Go logger is community-maintained third-party.  log/slog
#      has Go team backing as the canonical stdlib choice for
#      the next decade, with library-author migration encouraged.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/bemasher/rtlamr/blob/master/flags.go
# variable initializations using `flag.<Type>()` calls + the
# `RegisterFlags()` function for additional setup.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help and exit]' \
    '-help[show help and exit]' \
    '-version[display build date and commit hash]' \
    '-samplefile=[raw signal dump file (default /dev/null)]:file:_files' \
    '-msgtype=[comma-separated message types]:types:_values -s , type all scm scm+ idm netidm r900 r900bcd' \
    '-symbollength=[symbol length in samples]:length:(8 32 40 48 56 64 72 80 88 96)' \
    '-duration=[time to run (0 = infinite, e.g. 1h5m10s)]:duration:' \
    '-filterid=[comma-separated meter IDs to display]:ids:' \
    '-filtertype=[comma-separated meter types to display]:types:' \
    '-format=[decoded message output format]:format:(plain csv json xml)' \
    '-unique[suppress duplicate messages from each meter]' \
    '-single[one-shot execution per meter id]' \
    '-cpuprofile=[CPU profile output file]:file:_files' \
    '-server=[rtl_tcp server (default 127.0.0.1:1234)]:host:port:' \
    '-centerfreq=[center frequency in Hz]:Hz:' \
    '-samplerate=[sample rate in Hz]:Hz:' \
    '-tunergain=[tuner gain in dB]:dB:' \
    '-bandwidth=[tuner bandwidth in Hz]:Hz:' \
    '-tunergainmode=[tuner gain mode]:bool:(true false)' \
    '-agcmode=[internal AGC]:bool:(true false)' \
    '-directsampling=[direct sampling mode]:mode:(0 1 2)' \
    '-offsettuning=[offset tuning]:bool:(true false)' \
    '-gainbyindex=[gain by index]:idx:' \
    '-rtltunerfreqcorrection=[tuner frequency correction (ppm)]:ppm:' \
    '-testmode=[test mode]:bool:(true false)' \
    && ret=0

return ret
