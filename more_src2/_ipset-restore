#compdef ipset-restore
# _ipset-restore — netfilter ipset restore (load a save-formatted dump (from `ipset save`) back into the kernel; -f reads from a file instead of stdin, -! continues past errors that would otherwise abort restore, -e disable exclamation in output, -q quiet mode; companion to ipset-save and the parent ipset binary)
# upstream: https://git.netfilter.org/ipset
# Flags from netfilter/ipset src/ipset.c on tip.

_ipset-restore() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-f+[input file]:file:_files' \
        '-!+[continue past errors]:bool:' \
        '-q[quiet]' \
        '-e[disable exclamation]'
}

_ipset-restore "$@"
