#compdef mednafen
# Documentation: https://mednafen.github.io/documentation/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: mednafen uses single-dash options of the form `-setting value`.
# Only six top-level switches are listed in the canonical CLI table; every
# other entry below is a documented setting (see Settings section and per-
# module sub-documents) which may also be set on the command line.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-force_module=[specify emulation module]:module:(nes pce pce_fast pcfx md sms gg gb gba lynx ngp psx ss snes snes_faust vb wswan)' \
  '-which_medium=[start with disk/CD inserted (-1 to eject)]:n:' \
  '-connect=[trigger netplay connection after load]:host:_hosts' \
  '-soundrecord=[record sound to WAV]:file:_files' \
  '-qtrecord=[record video to QuickTime]:file:_files' \
  '-ovconfig=[load override settings from file]:file:_files' \
  '-fps.autoenable=[auto enable fps display]:bool:(0 1)' \
  '-fps.position=[fps display position]:pos:(upper_left upper_right lower_left lower_right center)' \
  '-fps.scale=[fps font scale]:n:' \
  '-fps.bgcolor=[fps bg color]:hex:' \
  '-fps.textcolor=[fps text color]:hex:' \
  '-mouse_sensitivity=[mouse sensitivity]:n:' \
  '-netplay.host=[netplay host]:host:_hosts' \
  '-netplay.port=[netplay port]:port:' \
  '-netplay.password=[netplay password]:pw:' \
  '-netplay.localplayers=[local players]:n:' \
  '-netplay.nick=[nickname]:nick:' \
  '-netplay.gamekey=[game key]:key:' \
  '-cheats=[enable cheats]:bool:(0 1)' \
  '-autosave=[auto save state]:bool:(0 1)' \
  '-fs=[fullscreen]:bool:(0 1)' \
  '-video.fs=[video fullscreen]:bool:(0 1)' \
  '-video.driver=[video driver]:drv:(default opengl softfb)' \
  '-video.glvsync=[GL vsync]:bool:(0 1)' \
  '-sound=[enable sound]:bool:(0 1)' \
  '-sound.driver=[sound driver]:drv:(default sdl alsa openbsd jack oss dummy)' \
  '-sound.device=[sound device]:dev:' \
  '-sound.rate=[sample rate]:hz:' \
  '-sound.volume=[volume 0-150]:n:' \
  '-input.autofireperiod=[autofire period]:ticks:' \
  '-input.joystick.global_focus=[joystick global focus]:bool:(0 1)' \
  '-snapformat=[screenshot format]:fmt:(png pcx)' \
  '*:ROM file:_files' && ret=0

return ret
