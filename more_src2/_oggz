#compdef oggz
# Documentation: https://www.xiph.org/oggz/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for oggz (oggz-tools)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _values 'oggz' chop codecs comment diff dump info known-codecs merge rip scan sort validate help && ret=0
    ;;
  args) _files -g "*.(ogg|ogv|opus)" && ret=0 ;;
esac

return ret
