#compdef gdaldem
# Documentation: https://gdal.org/programs/gdaldem.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a modes

modes=(
  'hillshade:generate shaded relief map'
  'slope:generate slope map'
  'aspect:generate aspect map'
  'color-relief:generate colored relief map'
  'TRI:Terrain Ruggedness Index'
  'TPI:Topographic Position Index'
  'roughness:roughness map'
)

_arguments -C -s -S \
  '(- *)--help[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '-of+[output format]:format:' \
  '*-co+[creation option]:NAME=VALUE:' \
  '-b+[band]:band:' \
  '(-q --quiet)'{-q,--quiet}'[suppress progress messages]' \
  '-z+[vertical exaggeration factor]:factor:' \
  '-s+[vertical to horizontal ratio]:scale:' \
  '-xscale+[X-axis scale ratio]:scale:' \
  '-yscale+[Y-axis scale ratio]:scale:' \
  '-az+[light azimuth (degrees)]:angle:' \
  '-alt+[light altitude (degrees)]:angle:' \
  '-alg+[algorithm]:alg:(Horn ZevenbergenThorne Wilson Riley)' \
  '-combined[combined hillshade]' \
  '-multidirectional[multidirectional hillshade]' \
  '-igor[Igor hillshade mode]' \
  '-compute_edges[compute values at edges]' \
  '-p[express slope as percent (slope mode)]' \
  '-trigonometric[trigonometric output (aspect mode)]' \
  '-zero_for_flat[zero for flat areas (aspect mode)]' \
  '-alpha[add alpha channel (color-relief)]' \
  '-exact_color_entry[exact color entries only (color-relief)]' \
  '-nearest_color_entry[nearest color entry (color-relief)]' \
  '1: :->mode' \
  '*::arg:->args' && ret=0

case $state in
  (mode)
    _describe -t modes 'gdaldem mode' modes && ret=0
    ;;
  (args)
    _files && ret=0
    ;;
esac

return ret
