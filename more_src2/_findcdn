#compdef findcdn
# _findcdn — CISA findcdn CLI Cybersecurity and Infrastructure Security Agency tool detecting CDN content-delivery-network endpoints behind input list of domains by querying authoritative DNS records mapping to AWS-CloudFront Cloudflare Akamai Fastly StackPath Edgio MaxCDN providers producing JSON output (CISA team, Python); argparse
# upstream: https://github.com/cisagov/findcdn

_findcdn() {
    local -a sub=(
        'file:scan from file'
        'list:scan from list'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-t+[threads]:n:' \
        '--threads=+[N]:n:' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-d[double scan]' \
        '--double-in[double scan input]' \
        '-c[only show CDN]' \
        '--checks[only show CDN flagged]' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '--pbar[show progress bar]' \
        '-u+[user agent]:str:' \
        '--user-agent=+[ua]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'findcdn subcommand' sub ;;
        args)
            case $words[1] in
                file) _arguments '*:input file:_files -g "*.txt *.csv *.json"' ;;
                list) _arguments '*:domain:' ;;
            esac
            ;;
    esac
}

_findcdn "$@"
