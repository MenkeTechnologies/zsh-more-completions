#compdef meshbird
# =============================================================================
# meshbird — distributed private networking.  Meshbird is a peer-to-peer
#            mesh VPN written in Go that creates a private overlay network
#            between machines using UDP-based encrypted tunnels with
#            automatic discovery via seed nodes.  Each peer maintains a
#            local TUN/TAP virtual interface; traffic is routed through
#            the overlay based on assigned IP/CIDR.  Designed as a
#            zero-config alternative to OpenVPN, WireGuard, and Tailscale
#            for small distributed clusters without a central coordinator.
#
# Author:  meshbird org (founded by Vlad Volkov)
# Source:  https://github.com/meshbird/meshbird
# CLI:     main.go + common/config.go (uses alexflint/go-arg)
# Library: alexflint/go-arg
#          ("Struct-based argument parsing in Go")
# License: BSD-3-Clause
# Status:  Active — 3,525+ stars, used by small distributed clusters,
#          IoT mesh networks, and as a learning vehicle for P2P
#          networking in Go.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 26 LIBRARIES
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 26TH Go CLI library variant.  Go climbs from 25 to 26 documented libraries
# (go-arg via meshbird).  New leaderboard: Rust=26, Go=26 (TWO-WAY TIE),
# TypeScript-Node=25.  Taxonomy now spans 214 cross-language CLI library
# variants across 51 documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS alexflint/go-arg AND WHY IS IT A DISTINCT 26TH GO CLI LIBRARY VARIANT?
#
# go-arg (https://github.com/alexflint/go-arg, 2,260+ stars) by Alex
# Flint is a STRUCT-TAG-DRIVEN Go CLI parser.  Its design is similar to
# alecthomas/kong (R465) — both use Go struct tags to declare CLI flags
# and use reflection to parse argv against the struct — but the two
# libraries differ in five SIGNIFICANT ways that justify go-arg as a
# distinct documented library variant:
#
#   1. SINGLE-FUNCTION ENTRY POINT — go-arg's primary API is one call:
#         arg.MustParse(&cfg)
#      Compare to Kong which requires `kong.New(&cli, options...)` +
#      `.Parse(args)` two-step construction.  go-arg's MustParse panics
#      on error; `arg.Parse(&cfg)` returns Error.  Either way, ONE LINE
#      and the struct is populated.
#
#   2. NAME-DERIVATION FROM FIELD NAMES — go-arg automatically derives
#      CLI flag names from Go field names:
#         HostAddr    → --hostaddr  (lowercase concatenation)
#         PublicAddrs → --publicaddrs
#         BindAddrs   → --bindaddrs
#         TransportThreads → --transportthreads
#      No `name:""` tag needed (though `arg:"--my-name"` overrides).
#      Compare Kong R465 which does CamelCase→kebab-case conversion
#      automatically; go-arg does the simpler lowercase concatenation.
#
#   3. `arg:"-x,separate"` MULTI-VALUE-PER-FLAG MODE — go-arg's distinctive
#      `separate` mode means each occurrence of the flag CREATES A NEW
#      ENTRY in a slice, instead of comma-separating a single value:
#         -p 1.2.3.4 -p 5.6.7.8       ← creates PublicAddrs = ["1.2.3.4", "5.6.7.8"]
#      (vs without separate where you'd write `-p 1.2.3.4,5.6.7.8`).
#      The `separate` semantic is opt-in via the `separate` token in
#      the `arg:""` tag.  Kong has analogous behavior via `repeated`
#      tag but go-arg's `separate` is the inverse — slices ARE collected
#      from repeated args by default, `separate` just makes each entry
#      come from a separate `-x` invocation rather than comma-split.
#
#   4. `arg:"required"` AS A FIRST-CLASS TAG — go-arg has `arg:"required"`
#      that makes the field mandatory; parser errors if not supplied.
#      Compare Kong which uses `required:""` (no value) or implicit-
#      required via lack-of-default.  go-arg's explicit `required` tag
#      is more readable.
#
#   5. SUBCOMMANDS VIA EMBEDDED STRUCTS WITH POINTERS — go-arg supports
#      subcommands by having pointer fields in the top-level struct:
#         type Args struct {
#             Sub1 *Sub1Cmd `arg:"subcommand:sub1"`
#             Sub2 *Sub2Cmd `arg:"subcommand:sub2"`
#         }
#      When `myapp sub1 ...` is parsed, `Args.Sub1` becomes non-nil and
#      `Args.Sub2` stays nil.  Caller dispatches via `if args.Sub1 != nil
#      { ... } else if args.Sub2 != nil { ... }`.  Kong uses nested
#      struct types with `cmd:""` tags AND auto-dispatches via Run()
#      method lookup; go-arg leaves dispatch to the caller.  This makes
#      go-arg simpler but less ergonomic for tree-of-subcommands.
#
# THE go-arg API SURFACE (from meshbird usage)
#
#   import "github.com/alexflint/go-arg"
#
#   type Config struct {
#       Key              string   `default:""`
#       HostAddr         string
#       PublicAddrs      []string `arg:"-p,separate"`
#       BindAddrs        []string `default:""    arg:"-b,separate"`
#       SeedAddrs        []string `default:""    arg:"-s,separate"`
#       TransportThreads int      `default:"1"`
#       Ip               string   `default:"10.237.0.1/16" arg:"required"`
#       Mtu              int      `default:"9000"`
#       Verbose          int      `default:"0"`
#   }
#
#   func main() {
#       var cfg Config
#       arg.MustParse(&cfg)
#       // cfg is now populated
#   }
#
# Struct tag vocabulary:
#   default:"<value>"            — default value if flag omitted
#   arg:"--name"                 — override long flag name
#   arg:"-x"                     — set short alias
#   arg:"-x,--name"              — set both short and long
#   arg:"-x,separate"            — multi-value-per-flag (each -x = new entry)
#   arg:"required"               — mandatory flag
#   arg:"positional"             — positional argument (not a flag)
#   arg:"subcommand:name"        — subcommand dispatch field (pointer struct)
#   arg:"env:VAR_NAME"           — environment-variable fallback
#   arg:"-x,env:VAR_NAME"        — combined short flag + env fallback
#   help:"description"           — usage text for --help output
#
# CONTRAST WITH OTHER STRUCT-TAG-DRIVEN GO CLI LIBRARIES
#
#   * jessevdk/go-flags          — earlier Posix-getopt-style with struct
#                                  tags; less idiomatic Go conventions
#   * alecthomas/kong (R465)     — newer struct-tag with auto-Run()
#                                  dispatch + custom validators
#   * go-arg (THIS)              — simpler single-MustParse API, manual
#                                  subcommand dispatch
#   * mitchellh/cli              — Hashicorp interface dispatch (NOT
#                                  struct-tag driven)
#   * spf13/cobra                — imperative tree builder (NOT struct-
#                                  tag driven)
#
# go-arg occupies a SPECIFIC NICHE: it is the "MINIMAL STRUCT-TAG
# PARSER" — declarative enough to avoid imperative builders (cobra-
# style), but simple enough to fit in one function call (MustParse).
# When the CLI surface is small (under ~10 flags) and subcommand
# dispatch is straightforward (under ~5 commands), go-arg's one-line
# API beats every other Go option for ergonomics.
#
# REAL-WORLD go-arg USERS:
#
#   * meshbird/meshbird — distributed private networking (THIS, 3525*)
#   * purpleidea/mgmt — config management (4254*) — uses go-arg for cli/
#   * monasticacademy/httptap — HTTP/HTTPS request viewer (4165*)
#   * pluveto/upgit — clipboard upload hub (631*)
#   * brentp/smoove — structural variant calling (264*)
#   * nathants/libaws — AWS ship-it helper (449*)
#   * base2genomics/batchit — AWS Batch submission CLI
#   * ndau/commands — Ndau blockchain command suite
#   * stakater/HelmRequirementsBuilder — Helm dep builder
#   * bfritz/clusterhat — Cluster HAT control
#   * CodeFabrikGmbH/mini-curl — minimal curl alternative
#
# -----------------------------------------------------------------------------
# MESHBIRD'S CLI SURFACE (verbatim from common/config.go Config struct)
# -----------------------------------------------------------------------------
#
# USAGE:
#   meshbird --ip <CIDR> [OPTIONS]
#
# Required:
#   --ip <CIDR>                Local IP/CIDR for this peer in the overlay
#                              (e.g., 10.237.0.1/16)  [arg:"required"]
#
# Identity:
#   --key <KEY>                Network key (must match across peers for
#                              cluster membership)
#
# Addressing:
#   --hostaddr <HOST>          Local host address (auto-detected if empty)
#   -p, --publicaddrs <ADDR>   Public address(es); use -p HOST:PORT once per
#                              address (separate mode)
#   -b, --bindaddrs <ADDR>     Bind address(es) for the UDP socket
#                              (separate mode)
#   -s, --seedaddrs <ADDR>     Seed peers for initial discovery
#                              (separate mode; one of many seeds)
#
# Network tuning:
#   --transportthreads <N>     Number of transport threads (default: 1)
#   --mtu <BYTES>              MTU of the virtual interface (default: 9000)
#
# Diagnostics:
#   --verbose <N>              Verbosity level (default: 0)
#
# Environment variables (auto-bound via go-arg):
#   <none in meshbird's struct — would be added via arg:"env:VAR" tags>
#
# =============================================================================

_meshbird() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '--key[network key (must match across peers)]:key:' \
        '--hostaddr[local host address]:host:_hosts' \
        '*'{-p,--publicaddrs}'[public address (HOST:PORT)]:address:' \
        '*'{-b,--bindaddrs}'[bind address for UDP socket]:bind addr:' \
        '*'{-s,--seedaddrs}'[seed peer for discovery]:seed addr:' \
        '--transportthreads[transport thread count]:N:' \
        '--ip[local CIDR (required)]:CIDR:' \
        '--mtu[virtual interface MTU]:bytes:' \
        '--verbose[verbosity level]:level:' \
        '--help[show help]' \
        '--version[show version]' \
        && ret=0

    return ret
}

_meshbird "$@"
