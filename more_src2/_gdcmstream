#compdef gdcmstream
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmstream.cxx — DICOM stream/whole-slide tools (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input DICOM file]:file:_files -g "*.{dcm,DCM,dicom}"' \
    '(-o --output)'{-o+,--output=}'[output DICOM file]:file:_files' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '(-n --resolution)'{-n+,--resolution=}'[number of resolutions]:n:_default' \
    '(-r --resolution-only)'{-r+,--resolution-only=}'[extract a single resolution]:n:_default' \
    '--roi-start=[ROI start coordinates]:roi:_default' \
    '--roi-end=[ROI end coordinates]:roi:_default' \
    && ret=0

return ret
