#compdef kresd
# Documentation: https://manpages.debian.org/testing/knot-resolver/kresd.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. -S/-T are repeatable
# like -a/-t; -f/--forks confirmed (deprecated since 5.0.0).

_arguments -s \
  '*'{-a,--addr}'=[listen on given address[@port], repeatable]:addr[@port]:' \
  '*'{-t,--tls}'=[listen via TLS on address[@port], repeatable]:addr[@port]:' \
  '*'{-S,--fd}'=[listen on inherited file descriptor, repeatable]:fd:' \
  '*'{-T,--tlsfd}'=[listen via TLS on inherited fd, repeatable]:fd:' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files -g "*.(lua|conf)"' \
  '(-f --forks)'{-f,--forks}'=[number of forks (deprecated since 5.0.0)]:n:' \
  '(-n --noninteractive)'{-n,--noninteractive}'[do not enter the read-eval-print loop]' \
  '(-q --quiet)'{-q,--quiet}'[do not print the command prompt]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging to debug level]' \
  '(- *)-h[show help]' \
  '(- *)-V[show version]'
