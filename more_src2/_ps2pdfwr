#compdef ps2pdfwr ps2pdf ps2pdf12 ps2pdf13 ps2pdf14 ps2pdf15
# Documentation: man ps2pdfwr(1)
# Source: Ghostscript ghostpdl ps2pdfwr (master) — PS-to-PDF wrapper around gs (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*-d-[gs -d option]:option:_default' \
    '*-s-[gs -s option]:option:_default' \
    '1:input PostScript file:_files -g "*.{ps,eps}"' \
    '2::output PDF file:_files -g "*.pdf"' \
    && ret=0

return ret
