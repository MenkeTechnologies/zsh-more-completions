#compdef gsc2cat
# _gsc2cat — convert GSC catalog to WCSTools tab-table format (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from gsc2cat.c (single-letter getopt-style).

_gsc2cat() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-d+[new root directory]:dir:_files -/' \
        '-l+[new root directory]:dir:_files -/' \
        '-@+[file with list of inputs]:file:_files' \
        '*:GSC file:_files'
}

_gsc2cat "$@"
