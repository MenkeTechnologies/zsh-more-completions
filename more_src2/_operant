#compdef operant
# Documentation: https://github.com/ishan-parihar/operant
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Source: https://github.com/ishan-parihar/operant/blob/677e8567404f8de6e8bc228a7de8efea259144f3/completion/operant.zsh
# Repository: ishan-parihar/operant (completion/operant.zsh)
# Operant CLI zsh completion
# Install: copy to ~/.zsh/completion/_operant and add fpath

_operant() {
    local -a commands
    commands=(
        'onboard:interactive setup wizard (quickstart or advanced)'
        'doctor:comprehensive health diagnostics'
        'configure:section-based interactive config editor'
        'mcp:MCP server management'
        'daemon:systemd service management'
        'status:system status overview'
        'reset:configuration reset with scope control'
        'migrate:config migration for version upgrades'
        'help:show help'
        'version:show version'
    )

    _arguments -C \
        '1: :->command' \
        '*::arg:->subcommand' \
        '--config[path to config file]:file:_files' \
        '--verbose[enable verbose output]' \
        '--help[show help]' \
        '--version[show version]'

    case "$state" in
        command)
            _describe 'command' commands
            ;;
        subcommand)
            case "$words[1]" in
                onboard)
                    _arguments \
                        '--mode[setup mode]:mode:(quickstart advanced)' \
                        '--reset-scope[reset scope]:scope:(config config+creds full)' \
                        '--help[show help]'
                    ;;
                doctor)
                    _arguments \
                        '--yes[auto-accept fixes]' \
                        '--repair[apply repairs]' \
                        '--help[show help]'
                    ;;
                status)
                    _arguments \
                        '--deep[include deep checks]' \
                        '--json[output as JSON]' \
                        '--help[show help]'
                    ;;
                configure)
                    _arguments \
                        '--section[config section]:section:(llm telegram mcp embedding paths logging)' \
                        '--help[show help]'
                    ;;
                mcp)
                    _arguments \
                        '1:action:(list add remove enable disable status)' \
                        '--help[show help]'
                    ;;
                daemon)
                    _arguments \
                        '1:action:(install start stop restart status uninstall)' \
                        '--help[show help]'
                    ;;
                reset)
                    _arguments \
                        '--scope[reset scope]:scope:(config config+creds full)' \
                        '--help[show help]'
                    ;;
            esac
            ;;
    esac
}

_operant "$@"
