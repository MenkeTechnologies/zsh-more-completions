#compdef gnt-filter
# _gnt-filter — Google Ganeti gnt-filter CLI for managing per-cluster job-filter rules priority predicates action ACCEPT PAUSE REJECT CONTINUE RATE_LIMIT user opcodes for fine-grained access-control across queues (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-filter() {
    local -a sub=(
        'add:add a filter rule'
        'delete:delete a filter rule'
        'info:show filter info'
        'list:list filter rules'
        'replace:replace a filter rule'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '--reason=+[text]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-filter subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '--priority=+[N]:n:' \
                    '--predicates=+[csv]:str:' \
                    '--action=+[a]:a:(ACCEPT PAUSE REJECT CONTINUE RATE_LIMIT)' \
                    '--reason-trail=+[text]:str:' ;;
                delete|info|replace) _arguments '*:filter uuid:' ;;
            esac
            ;;
    esac
}

_gnt-filter "$@"
