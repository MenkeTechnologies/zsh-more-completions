autoload -U is-at-least

_planus() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--ignore-docstring-errors[]' \
'-h[Print help]' \
'--help[Print help]' \
":: :_planus_commands" \
"*::: :->planus-cli" \
&& ret=0
    case $state in
    (planus-cli)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:planus-command-$line[1]:"
        case $line[1] in
            (dot)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file]:OUTPUT_FILENAME:_files' \
'-h[Print help]' \
'--help[Print help]' \
'*::files:_files' \
&& ret=0
;;
(rust)
_arguments "${_arguments_options[@]}" : \
'-o+[Output file]:OUTPUT_FILENAME:_files' \
'--format=[Run rustfmt on the generated code]:FORMAT:(true false)' \
'-h[Print help]' \
'--help[Print help]' \
'*::files:_files' \
&& ret=0
;;
(view)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':schema_file:_files' \
':root_type:_default' \
':data_file:_files' \
&& ret=0
;;
(format)
_arguments "${_arguments_options[@]}" : \
'--ignore-errors[Try to generate output even if the input has errors]' \
'-h[Print help]' \
'--help[Print help]' \
':file:_files' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'*::files:_files' \
&& ret=0
;;
(generate-completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Which shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_planus__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:planus-help-command-$line[1]:"
        case $line[1] in
            (dot)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(rust)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(view)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(format)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_planus_commands] )) ||
_planus_commands() {
    local commands; commands=(
'dot:Generate a dot graph' \
'rust:Generate rust code' \
'view:View a binary file with a schema in the TUI viewer' \
'format:Format .fbs files' \
'check:Check validity of .fbs files' \
'generate-completions:Generate shell completion scripts' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'planus commands' commands "$@"
}
