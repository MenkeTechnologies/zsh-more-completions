#compdef quicinterop quicattack
# Documentation: https://github.com/microsoft/msquic/tree/main/src/tools
# Reference accessed: 2026-05-27
# Verified: upstream src/tools/interop/interop.cpp and src/tools/attack/attack.cpp
# Note: tool binary names follow msquic build output (quicinterop, quicattack).
# msquictest is the gtest runner; no completions provided for it here.

local curcontext="$curcontext" state line ret=1

_quicinterop() {
  _arguments -s -S \
    '-help[display usage information]' \
    '-?[display usage information]' \
    '-list[show known implementations and servers]' \
    '-serial[run tests sequentially instead of in parallel]' \
    '-test\:-[specify test cases to run (codes or numeric bitmask)]:tests:' \
    '-target\:-[target a specific QUIC implementation by name]:implementation:' \
    '-custom\:-[test a custom server by hostname]:hostname:_hosts' \
    '-port\:-[custom port number]:port:' \
    '-timeout\:-[wait timeout in milliseconds]:milliseconds:' \
    '-version\:-[initial QUIC version to offer (hex)]:version:' \
    '-sslkeylogfile\:-[SSL key log file output path]:file:_files' \
    '-urls\:-[custom URLs to request]:urls:_urls' && ret=0
}

_quicattack() {
  _arguments -s -S \
    '-list[display supported attack types]' \
    '-type\:-[attack type (0-4)]:type:(0 1 2 3 4)' \
    '-ip\:-[target server IP and port]:ip\:port:' \
    '-alpn\:-[application protocol (default h3)]:alpn:' \
    '-sni\:-[server name for DNS resolution]:hostname:_hosts' \
    '-timeout\:-[attack duration in milliseconds]:milliseconds:' \
    '-rate\:-[packet transmission rate]:packets-per-second:' \
    '-threads\:-[number of worker threads]:count:' && ret=0
}

case $service in
  quicinterop)
    _quicinterop
    ;;
  quicattack)
    _quicattack
    ;;
esac

return ret
