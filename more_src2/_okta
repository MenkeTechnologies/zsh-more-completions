#compdef okta
# Documentation: https://github.com/okta/okta-cli
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start with an Okta sample app or onboard'
  'register:sign up for a new Okta organization'
  'login:log into an existing Okta organization'
  'logout:log out of your Okta organization'
  'apps:manage Okta applications'
  'help:show help for a subcommand'
  'generate-completion:generate bash/zsh completion scripts'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help information]' \
  '--version[show okta version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'okta command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (apps)
        _arguments \
          '1:subcommand:(create)' \
          '--redirect-uri=[OAuth redirect URI]:uri:' && ret=0
        ;;
      (generate-completion)
        _arguments '1:shell:(bash zsh)' && ret=0
        ;;
    esac
    ;;
esac

return ret
