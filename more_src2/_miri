#compdef miri
# Documentation: https://github.com/rust-lang/miri
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'run:run the main binary of the local package'
      'test:run the tests of the local package'
      'nextest:run tests via cargo-nextest'
      'setup:set up Miri for the current toolchain'
    )
    _describe -t commands 'cargo miri command' commands && ret=0
    ;;
  args)
    case $line[1] in
      run|test)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '-p+[package to run]:package:' \
          '--package=[package to run]:package:' \
          '--lib[run lib target]' \
          '--bin=[run specified binary]:binary:' \
          '--example=[run specified example]:example:' \
          '--test=[run specified test]:test:' \
          '--features=[features to activate]:features:' \
          '--all-features[activate all features]' \
          '--no-default-features[do not activate default features]' \
          '--release[run in release mode]' \
          '--target=[target triple]:target:' \
          '-j+[number of parallel jobs]:jobs:' \
          '--jobs=[number of parallel jobs]:jobs:' \
          '-v[verbose output]' \
          '--verbose[verbose output]' \
          '-Zmiri-disable-validation[disable memory validity checks]' \
          '-Zmiri-disable-stacked-borrows[disable Stacked Borrows checks]' \
          '-Zmiri-disable-data-race-detector[disable data race detection]' \
          '-Zmiri-disable-alignment-check[disable alignment checks]' \
          '-Zmiri-disable-isolation[allow host system API access]' \
          '-Zmiri-disable-leak-backtraces[disable leak backtraces]' \
          '-Zmiri-ignore-leaks[do not report memory leaks]' \
          '-Zmiri-isolation-error=[isolation error behavior]:behavior:(abort hide warn warn-nobacktrace)' \
          '-Zmiri-seed=[random seed]:seed:' \
          '-Zmiri-many-seeds=[run with many seeds]:range:' \
          '-Zmiri-strict-provenance[enable strict provenance]' \
          '-Zmiri-permissive-provenance[allow exposing pointer provenance]' \
          '-Zmiri-symbolic-alignment-check[enable symbolic alignment checking]' \
          '-Zmiri-provenance-gc=[run the provenance GC at the given interval]:interval:' \
          '-Zmiri-track-alloc-id=[track allocation ID]:id:' \
          '-Zmiri-track-alloc-accesses[track accesses to tracked allocations]' \
          '-Zmiri-track-pointer-tag=[track pointer tag]:tag:' \
          '-Zmiri-backtrace=[control backtrace printing]:value:(0 1 full)' \
          '-Zmiri-num-cpus=[number of simulated CPUs]:n:' \
          '-Zmiri-preemption-rate=[thread preemption probability]:rate:' \
          '-Zmiri-deterministic-concurrency[make concurrency fully deterministic]' \
          '-Zmiri-tree-borrows[use Tree Borrows instead of Stacked Borrows]' \
          '*:args:' && ret=0
        ;;
    esac
    ;;
esac

return ret
