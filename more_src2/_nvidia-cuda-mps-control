#compdef nvidia-cuda-mps-control
# Documentation: https://docs.nvidia.com/deploy/mps/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvidia-cuda-mps-control: NVIDIA CUDA Multi-Process Service control daemon
local curcontext="$curcontext" ret=1 state line
local -a commands=(
  'quit:shut down daemon and all servers'
  'shutdown_server:terminate a server by PID'
  'get_server_list:list active MPS server PIDs'
  'get_server_status:show status of a server'
  'start_server:start a server for a UID'
  'get_client_list:list clients of a server'
  'get_device_client_list:list devices and client PIDs'
  'terminate_client:stop GPU work for a client'
  'get_active_thread_percentage:query active thread percentage for a server'
  'set_active_thread_percentage:set active thread percentage for a server'
  'get_default_active_thread_percentage:query default active thread percentage'
  'set_default_active_thread_percentage:set default active thread percentage'
  'get_device_pinned_mem_limit:query pinned memory limit for server/device'
  'set_device_pinned_mem_limit:set pinned memory limit for server/device'
  'get_default_device_pinned_mem_limit:query default pinned memory limit'
  'set_default_device_pinned_mem_limit:set default pinned memory limit'
  'get_default_client_priority:query default client priority'
  'set_default_client_priority:set default client priority'
  'ps:snapshot of current client processes'
  'help:print available commands'
)
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '-d[start daemon in background]' \
  '-f[start daemon in foreground]' \
  '-multiuser-server[permit multiple UIDs to share an MPS server]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mps-control command' commands && ret=0 ;;
esac
return ret
