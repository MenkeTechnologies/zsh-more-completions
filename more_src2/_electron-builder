#compdef electron-builder
# Documentation: https://www.electron.build/cli
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'build:build (default)'
  'install-app-deps:install app native deps'
  'node-gyp-rebuild:rebuild native modules with node-gyp'
  'create-self-signed-cert:create a self-signed code-signing cert'
  'start:run development build'
  'publish:publish artifacts'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--mac[build for macOS]' \
  '-m[build for macOS]' \
  '-o[build for macOS]' \
  '--macos[build for macOS]' \
  '--linux[build for Linux]' \
  '-l[build for Linux]' \
  '--win[build for Windows]' \
  '--windows[build for Windows]' \
  '-w[build for Windows]' \
  '--x64[build for x64]' \
  '--ia32[build for ia32]' \
  '--armv7l[build for armv7l]' \
  '--arm64[build for arm64]' \
  '--universal[build universal binary (macOS)]' \
  '--dir[build unpacked dir]' \
  '(-c --config)'{-c,--config}'=[path to config file or inline config]:config:_files' \
  '--projectDir=[project dir]:directory:_directories' \
  '--project=[project dir]:directory:_directories' \
  '(-p --publish)'{-p,--publish}'=[publish artifacts]:publish:(onTag onTagOrDraft always never)' \
  '--pd=[prepackaged app directory]:directory:_directories' \
  '--prepackaged=[prepackaged app directory]:directory:_directories' \
  '1: :->cmd' && ret=0

case $state in
  (cmd) _describe -t commands 'electron-builder command' commands && ret=0 ;;
esac

return ret
