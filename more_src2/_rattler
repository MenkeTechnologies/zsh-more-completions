#compdef rattler
# _rattler — Rust conda package management (conda/rattler)
# upstream: https://github.com/conda/rattler
# Subcommands from crates/rattler-bin/src/main.rs (clap).

_rattler() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_rattler_commands' \
        '*::arg:->args' && ret=0

    return ret
}

(( $+functions[_rattler_commands] )) ||
_rattler_commands() {
    local -a commands
    commands=(
        'auth:manage authentication for conda channels'
        'completion:generate shell completion'
        'create:create an environment from a spec'
        'download:download conda packages'
        'fetch-file:fetch a single file from a registered registry'
        'inspect:inspect a conda package archive'
        'search:search for conda packages in a channel'
        'shell-hook:print the shell hook code for activation'
        'virtual-packages:print detected virtual packages on this system'
        'install-menu:install menu entries for an environment'
        'remove-menu:remove menu entries for an environment'
        'run:run a command in an environment'
        'extract:extract a conda package archive'
        'link:link a previously extracted package into a prefix'
        'upload:upload a conda package to a channel'
        'list:list packages installed in a prefix'
    )
    _describe -t commands 'rattler command' commands
}

_rattler "$@"
