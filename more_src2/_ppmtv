#compdef ppmtv
# Documentation: man ppmtv (Netpbm)
# Source: simulate a CRT 'TV' look in a PPM image (dim every other line).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:dim factor 0..1:' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
