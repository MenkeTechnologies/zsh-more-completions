#compdef rollup-cli
# _rollup-cli — Rich Harris Rollup module bundler CLI alias (Rich Harris / Rollup team, JavaScript); custom argparse
# upstream: https://github.com/rollup/rollup

_rollup-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--bundleConfigAsCjs[load config as commonjs]' \
        '-c+[config file]:file:_files -g "rollup.config.* *.cjs *.mjs *.ts *.js"' \
        '--config=+[config file]:file:_files -g "rollup.config.* *.cjs *.mjs *.ts *.js"' \
        '--configPlugin=+[config plugin]:list:' \
        '--context=+[context]:str:' \
        '-d+[output dir]:dir:_files -/' \
        '--dir=+[output dir]:dir:_files -/' \
        '--environment=+[env vars key=value]:list:' \
        '--external=+[external modules]:list:' \
        '-e+[external modules]:list:' \
        '-f+[output format]:f:(amd cjs es iife system umd)' \
        '--format=+[output format]:f:(amd cjs es iife system umd)' \
        '--filterLogs=+[filter logs]:str:' \
        '-g+[globals]:str:' \
        '--globals=+[globals]:str:' \
        '-i+[entry module]:file:_files' \
        '--input=+[entry module]:file:_files' \
        '-l+[loglevel]:level:(silent error warn info debug)' \
        '--logLevel=+[loglevel]:level:(silent error warn info debug)' \
        '-m[generate sourcemap]' \
        '--sourcemap=+[sourcemap]:m:(true false inline hidden)' \
        '-n+[name]:str:' \
        '--name=+[name]:str:' \
        '-o+[output file]:file:_files' \
        '--file=+[output file]:file:_files' \
        '-p+[plugin]:str:' \
        '--plugin=+[plugin]:str:' \
        '--silent[silent]' \
        '--stdin[use stdin]' \
        '--no-stdin[no stdin]' \
        '--strictDeprecations[treat deprecations as errors]' \
        '-w[watch mode]' \
        '--watch[watch mode]' \
        '--watch.skipWrite[watch skip write]' \
        '--validate[validate output]' \
        '*:input:_files'
}

_rollup-cli "$@"
