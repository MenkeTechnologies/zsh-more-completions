#compdef newsbeuter
# Documentation: https://manpages.debian.org/unstable/newsbeuter/newsbeuter.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-r --refresh-on-start)'{-r,--refresh-on-start}'[refresh feeds on start]' \
  '(-e --export-to-opml)'{-e,--export-to-opml}'[export feeds as OPML to stdout]' \
  '(-X --vacuum)'{-X,--vacuum}'[compact cache]' \
  '(-i --import-from-opml)'{-i,--import-from-opml}'+[import feeds from OPML file]:file:_files -g "*.opml"' \
  '(-u --url-file)'{-u,--url-file}'+[URLs file]:file:_files' \
  '(-c --cache-file)'{-c,--cache-file}'+[cache database file]:file:_files' \
  '(-C --config-file)'{-C,--config-file}'+[config file]:file:_files' \
  '(-x --execute)'{-x,--execute}'+[execute command]:cmd:(reload print-unread)' \
  '(-q --quiet)'{-q,--quiet}'[suppress startup messages]' \
  '(-l --log-level)'{-l,--log-level}'+[log level 1-6]:level:(1 2 3 4 5 6)' \
  '(-d --log-file)'{-d,--log-file}'+[log file]:file:_files' \
  '(-E --export-to-file)'{-E,--export-to-file}'+[export read items to file]:file:_files' \
  '(-I --import-from-file)'{-I,--import-from-file}'+[import read items from file]:file:_files' && ret=0

return ret
