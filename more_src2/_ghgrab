#compdef ghgrab
# _ghgrab — terminal GitHub/GitLab/Codeberg/Gitea/Forgejo file fetcher (abhixdd/ghgrab)
# upstream: https://github.com/abhixdd/ghgrab
# Subcommands + flags from src/cli.rs (clap).

_ghgrab() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--cwd[download files to the current directory]' \
        '--no-folder[download directly into target without the repo folder]' \
        '--token=[one-time token (use `auto` / `gh` to read from gh CLI)]:token:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_ghgrab_commands' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                release|rel)
                    _arguments \
                        '--tag=[download a specific release tag]:tag:' \
                        '--prerelease[allow selecting prereleases]' \
                        '--asset-regex=[regex for matching a specific asset]:regex:' \
                        '--os=[override detected OS]:os:(linux darwin windows freebsd)' \
                        '--arch=[override detected arch]:arch:(amd64 arm64 386 arm armv7)' \
                        '--file-type=[preferred artifact type]:type:(any archive binary)' \
                        '--extract[extract archive assets after download]' \
                        '--out=[custom output directory]:dir:_files -/' \
                        '--bin-path=[install the selected binary into this directory]:dir:_files -/' \
                        '--cwd[download files to the current directory]' \
                        '--token=[one-time token]:token:' \
                        '1:owner/repo:'
                    ;;
                config)
                    _arguments '1:config subcommand:(set unset list)'
                    ;;
                agent)
                    _arguments '1:agent subcommand:(tree download)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ghgrab_commands] )) ||
_ghgrab_commands() {
    local -a commands
    commands=(
        'config:manage persisted ghgrab config (token / path)'
        'agent:download via the agent protocol (tree / download)'
        'release:download a release artifact (alias: rel)'
    )
    _describe -t commands 'ghgrab command' commands
}

_ghgrab "$@"
