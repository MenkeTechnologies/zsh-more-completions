#compdef mksdcard
# Documentation: https://developer.android.com/studio/command-line/mksdcard
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '-l+[volume label for the disk image]:label:'
    '1:size (bytes, or N{K,M,G}; min 9M):'
    '2:image file:_files'
)

_arguments -s -S $arguments
