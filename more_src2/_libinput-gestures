local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-c[config file]:config file:_files' \
  '-d[debug mode]' \
  '-l[list gestures]' \
  '-r[restart]' \
  '-v[verbose output]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' && ret=0
return ret
