#compdef oclif
# Documentation: https://github.com/oclif/oclif
# Reference accessed: 2026-05-19
# Verified: oclif upstream README commands. Real top-level
# commands: init, generate, generate:command, generate:hook,
# manifest, pack, pack:deb, pack:macos, pack:win, promote,
# readme, upload, upload:deb, upload:macos, upload:win, help.
# Corrected from prior file: removed bogus 'pack:tarballs' /
# 'pack:tarballs' as a real subcommand (the tarball flow is the
# default `pack` command); added 'init', 'help', upload:deb,
# upload:macos, upload:win.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:initialize a new oclif CLI'
  'generate:generate a new CLI project'
  'generate\:command:add a command to an existing CLI'
  'generate\:hook:add a hook to an existing CLI'
  'manifest:generate oclif.manifest.json'
  'pack:pack CLI into tarballs'
  'pack\:deb:pack CLI into a deb package'
  'pack\:macos:pack CLI into a macOS installer'
  'pack\:win:pack CLI into a Windows installer'
  'promote:promote a release channel to S3'
  'readme:generate README.md from commands'
  'upload:upload packed CLI assets to S3'
  'upload\:deb:upload deb package'
  'upload\:macos:upload macOS installer'
  'upload\:win:upload Windows installer'
  'help:display help'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'oclif command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (generate|init)
        _arguments \
          '--defaults[use default values for prompts]' \
          '1:output directory:_directories' && ret=0
        ;;
      (manifest)
        _arguments '1:path:_directories' && ret=0
        ;;
      (readme)
        _arguments \
          '--dir=[directory of README]:directory:_directories' \
          '--multi[generate multi-page docs]' \
          '--aliases[include aliases in output]' && ret=0
        ;;
      (pack)
        _arguments \
          '(-r --root)'{-r+,--root=}'[root directory]:directory:_directories' \
          '(-t --targets)'{-t+,--targets=}'[target platforms]:targets:' \
          '--xz[also compress with xz]' && ret=0
        ;;
      (pack:deb|pack:macos|pack:win)
        _arguments \
          '(-r --root)'{-r+,--root=}'[root directory]:directory:_directories' && ret=0
        ;;
      (promote)
        _arguments \
          '--channel=[channel to promote to]:channel:' \
          '--version=[version to promote]:version:' \
          '--sha=[Git SHA to promote]:sha:' \
          '--indexes[update channel indexes]' \
          '--win[promote Windows installer]' \
          '--macos[promote macOS installer]' \
          '--deb[promote deb package]' && ret=0
        ;;
    esac
    ;;
esac

return ret
