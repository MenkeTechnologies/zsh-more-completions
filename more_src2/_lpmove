#compdef lpmove
# Documentation: lpmove --help (CUPS 26)
# Source: move a queued print job to a different destination.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[encrypt connection to the server]' \
    '-h+[server[:port]]:server:_hosts' \
    '-U+[username for authentication]:user:_users' \
    '*:job or source-destination, then destination:' \
    && ret=0

return ret
