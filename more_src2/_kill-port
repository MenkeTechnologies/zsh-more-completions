#compdef kill-port
# Documentation: https://github.com/tiaanduplessis/kill-port/blob/master/cli.js
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '--port=[port or comma-separated list of ports to kill]:port:' \
  '--method=[connection method]:method:(tcp udp)' \
  '--verbose[print the kill/error result]' \
  '*:port:' && ret=0

return ret
