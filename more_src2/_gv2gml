#compdef gv2gml
# Documentation: man gv2gml(1) (graphviz)
# Source: GraphViz gv2gml — convert a DOT graph to GML.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[output file]:file:_files' \
    '(- *)-?[show usage]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
