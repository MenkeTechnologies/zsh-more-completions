#compdef gh-repo
# _gh-repo — GitHub gh repo repository subcommand alias (GitHub Inc., Go); spf13/cobra
# upstream: https://github.com/cli/cli

_gh-repo() {
    local -a sub=(
        'archive:archive a repository'
        'autolink:autolink references'
        'clone:clone a repository'
        'create:create a repository'
        'delete:delete a repository'
        'deploy-key:deploy keys'
        'edit:edit repository settings'
        'fork:fork a repository'
        'list:list repositories'
        'rename:rename a repository'
        'set-default:set default repo'
        'sync:sync repository fork'
        'unarchive:unarchive a repository'
        'view:view a repository'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gh-repo subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--description=+[description]:str:' \
                    '-d+[description]:str:' \
                    '--homepage=+[homepage]:url:_urls' \
                    '-h+[homepage]:url:_urls' \
                    '--private[private]' \
                    '--public[public]' \
                    '--internal[internal]' \
                    '--team=+[team]:str:' \
                    '-t+[team]:str:' \
                    '--license=+[license]:str:' \
                    '-l+[license]:str:' \
                    '--gitignore=+[gitignore]:str:' \
                    '-g+[gitignore]:str:' \
                    '--source=+[source dir]:dir:_files -/' \
                    '-s+[source dir]:dir:_files -/' \
                    '--remote=+[remote]:str:' \
                    '-r+[remote]:str:' \
                    '--push[push existing]' \
                    '--include-all-branches[include all branches]' \
                    '--disable-issues[disable issues]' \
                    '--disable-wiki[disable wiki]' \
                    '--add-readme[add README]' \
                    '--clone[clone after create]' \
                    '--template=+[template]:str:' \
                    '-p+[template]:str:' \
                    '*:name:' ;;
                clone) _arguments \
                    '1:repo:' \
                    '*:dir:_files -/' ;;
                list) _arguments \
                    '--archived[only archived]' \
                    '--no-archived[exclude archived]' \
                    '--fork[only forks]' \
                    '--source[exclude forks]' \
                    '--json=+[json fields]:list:' \
                    '--language=+[language]:str:' \
                    '-l+[language]:str:' \
                    '--limit=+[max items]:n:' \
                    '-L+[max items]:n:' \
                    '--topic=+[topic]:list:' \
                    '--visibility=+[visibility]:v:(public private internal)' \
                    '*:owner:' ;;
                view|fork|delete|archive|unarchive|edit|sync|rename|set-default) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '*:repo:' ;;
                deploy-key|autolink) _arguments \
                    '1:cmd:(add delete list)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_gh-repo "$@"
