#compdef kubectl-commatrix
# Documentation: https://github.com/openshift-kni/commatrix/blob/main/cmd/README.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--format=[desired format]:format:(json yaml csv nft butane mc)' \
  '--destDir=[output files dir]:dir:_files -/' \
  '--customEntriesPath=[add custom entries from a file to the matrix]:file:_files' \
  '--customEntriesFormat=[format of the custom entries file]:format:(json yaml csv)' \
  '--custom-node-group=[assign nodes matching a label selector to a custom group (groupName=labelSelector)]:group:' \
  '--host-open-ports[generate matrix, host open port matrix, and their difference]' \
  '--debug[enable debug logging]' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '*::arg:_default' && ret=0

return ret
