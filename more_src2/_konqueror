#compdef konqueror
# Documentation: https://manpages.debian.org/testing/konqueror/konqueror.1.en.html
# Reference accessed: 2026-05-19
# Verified: konqueror(1) manpage.

# Fixed #compdef: real binary is `konqueror` (konqueror-cli/konq-cli
# are not real commands). Replaced invented flags (--silent kept,
# --tempfile removed) with the manpage option set.
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help about options]' \
  '--help-qt[show Qt specific options]' \
  '--help-kde[show KDE specific options]' \
  '--help-all[show all options]' \
  '--author[show author information]' \
  '(- *)'{-v,--version}'[show version information]' \
  '--license[show license information]' \
  '--silent[start without a default window, when called without URLs]' \
  '--preload[preload for later use]' \
  '--profile=[profile to open]:profile:' \
  '--profiles[list available profiles]' \
  '--mimetype=[mimetype to use for this URL (e.g. text/html)]:mime:' \
  '--select[select the file in the containing folder instead of opening it]' \
  '*:url_or_file:_files' && ret=0

return ret
