#compdef easyrsa easy-rsa
# _easy-rsa — OpenVPN Easy-RSA (CLI wrapping OpenSSL for a small PKI: init-pki, build-ca, gen-dh, gen-crl, build-server-full, build-client-full, sign-req, revoke, show-cert, show-req, export-p12; --pki-dir overrides default $EASYRSA_PKI)
# upstream: https://github.com/OpenVPN/easy-rsa
# Subcommands from easy-rsa easyrsa script on tip.

_easy-rsa() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--vars+[vars file]:file:_files' \
        '--pki-dir+[PKI directory]:dir:_files -/' \
        '--keysize+[key size bits]:bits:' \
        '--use-algo+[key algo]:algo:(rsa ec ed)' \
        '--curve+[ec curve]:curve:(secp384r1 secp521r1 prime256v1)' \
        '--digest+[message digest]:digest:(sha256 sha384 sha512)' \
        '--days+[validity days]:days:' \
        '--batch[non-interactive]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'easy-rsa command' \
                '(init-pki build-ca renew rebuild revoke gen-crl update-db gen-req sign-req import-req build-server-full build-client-full build-serverClient-full inline gen-dh show-req show-cert show-ca export-p7 export-p8 export-p12 export-keychain set-rsa-pass set-ec-pass set-ed-pass)'
            ;;
        args) _arguments '*:name:' ;;
    esac
}

_easy-rsa "$@"
