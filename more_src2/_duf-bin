#compdef duf
# _duf-bin — duf disk usage / free utility (Mufeed VH, Go); user-friendly tabular df replacement
# upstream: https://github.com/muesli/duf

_duf-bin() {
    _arguments \
        '-help[show help]' \
        '-version[show version]' \
        '-all[include pseudo, duplicate, inaccessible fs]' \
        '-avail-threshold+[avail color threshold]:str:' \
        '-usage-threshold+[usage color threshold]:str:' \
        '-hide+[hide types]:types:(local network fuse special loops binds)' \
        '-hide-fs+[hide fs types]:fs:' \
        '-hide-mp+[hide mount points]:mp:' \
        '-only+[only show types]:types:' \
        '-only-fs+[only fs types]:fs:' \
        '-only-mp+[only mount points]:mp:' \
        '-json[json output]' \
        '-output+[output columns]:cols:' \
        '-sort+[sort key]:key:(mountpoint size used avail usage inodes inodes_used inodes_avail inodes_usage filesystem type)' \
        '-theme+[theme]:theme:(dark light ansi)' \
        '-style+[style]:style:(unicode ascii)' \
        '-hide-binary-prefix[hide binary prefix]' \
        '-inodes[show inode info]' \
        '-width+[terminal width]:n:' \
        '-warnings[show warnings]' \
        '*:path:_files'
}

_duf-bin "$@"
