#compdef R-CMD-Sd2Rd
# _R-CMD-Sd2Rd — R Core Team R CMD Sd2Rd convert legacy S Sd documentation format to Rd format (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Sd2Rd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '--encoding=+[encoding]:str:' \
        '-d[debug]' \
        '--debug[debug]' \
        '*:Sd file or directory:_files'
}

_R-CMD-Sd2Rd "$@"
