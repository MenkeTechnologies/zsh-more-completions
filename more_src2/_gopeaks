_gopeaks() {
    _arguments -s -S \
        '(-b --bam)'{-b,--bam}'=[input BAM file (paired-end reads required)]:bam:_files -g "*.bam"' \
        '(-c --control)'{-c,--control}'=[control BAM (IgG, Input) for normalization]:bam:_files -g "*.bam"' \
        '(-s --chromsize)'{-s,--chromsize}'=[chromosome sizes file]:file:_files' \
        '(-m --mdist)'{-m,--mdist}'=[merge peaks within bp (default 1000)]:bp:' \
        '(-r --minreads)'{-r,--minreads}'=[min read pairs per candidate bin (default 15)]:n:' \
        '(-p --pval)'{-p,--pval}'=[significance threshold (default 0.05)]:p:' \
        '(-t --step)'{-t,--step}'=[bin size in bp (default 100; --broad resets to 5000)]:bp:' \
        '(-l --slide)'{-l,--slide}'=[slide size in bp (default 50; --broad resets to 1000)]:bp:' \
        '(-w --minwidth)'{-w,--minwidth}'=[minimum peak width in bp (default 150)]:bp:' \
        '(-o --prefix)'{-o,--prefix}'=[output prefix (default sample)]:prefix:' \
        '(-v --version)'{-v,--version}'[print version + exit]' \
        '--broad[broad-mark mode (H3K27ac/H3K4me1/H3K27me3/H3K9me3/H3K36me3)]' \
        '--verbose[verbose progress logging]' \
        '(-h --help)'{-h,--help}'[show help]'
}

_gopeaks "$@"
