#compdef nats-sub
# Documentation: https://github.com/nats-io/go-nats-examples/blob/main/tools/nats-sub/nats-sub.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nats-sub: simple NATS message subscriber
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[NATS servers (comma separated)]:servers:' \
  '-creds[user credentials file]:file:_files' \
  '-t[show timestamps]' \
  '1:subject:' && ret=0
return ret
