#compdef openfoam openfoam-docker openfoam-docker-arm
# Documentation: https://raw.githubusercontent.com/gerlero/openfoam-docker-arm/main/openfoam-docker-arm
# Reference accessed: 2026-05-27
# Verified: upstream openfoam-docker(-arm) wrapper script printHelp() output

# openfoam: container wrapper for OpenFOAM (openfoam.com). Runs OpenFOAM
# inside a docker/podman image. Flags below are from the script's printHelp.
local curcontext="$curcontext" ret=1
_arguments -s -S \
  '-c[shell commands read from the first non-option argument]' \
  '-data=[mount dir for container /data]:dir:_files -/' \
  '-dir=[mount dir for container HOME (default: pwd)]:dir:_files -/' \
  '-case=[mount dir for container HOME (alias of -dir)]:dir:_files -/' \
  '-home=[mount dir for container HOME (alias of -dir)]:dir:_files -/' \
  '-base[use base image flavour]' \
  '-dev[use dev image flavour]' \
  '-run[use run image flavour (default)]' \
  '-tut[use tutorials image flavour]' \
  '-default[use default image flavour]' \
  '-X[enable X11 forwarding]' \
  '-x[disable X11 forwarding]' \
  '-xhost[allow container access to host network (implies -X)]' \
  '-update[update (pull) the image, do not run]' \
  '-dry-run[report the start command, without running]' \
  '-verbose[additional verbosity when starting (FOAM_VERBOSE)]' \
  '-entry=[alternative entry point]:path:_files' \
  '-image=[specify image to run]:name:' \
  '-i=[specify image to run]:name:' \
  '-docker[use docker (default)]' \
  '-podman[use podman instead of docker]' \
  '-sudo[prefix container calls with sudo]' \
  '--shm-size=[size of /dev/shm (e.g. --shm-size=4G)]:size:' \
  '-h[display short help and exit]' \
  '-help[display short help and exit]' \
  '-help-full[display full help and exit]' \
  '*::application or command:_command_names -e' && ret=0
return ret
