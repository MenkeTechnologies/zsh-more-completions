#compdef lldb
# _lldb-bin — LLVM debugger (Apple + LLVM project); modern alternative to gdb with clang integration
# upstream: https://github.com/llvm/llvm-project

_lldb-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '(-O --one-line-on-crash)'{-O,--one-line-on-crash}'+[command]:cmd:' \
        '(-K --one-line-before-file)'{-K,--one-line-before-file}'+[command]:cmd:' \
        '(-k --one-line)'{-k,--one-line}'+[command]:cmd:' \
        '(-c --core)'{-c,--core}'+[core file]:file:_files' \
        '(-d --debug)'{-d,--debug}'[print debug log]' \
        '(-l --no-lldbinit)'{-l,--no-lldbinit}'[do not load init file]' \
        '(-s --source)'{-s,--source}'+[command file]:file:_files' \
        '(-S --source-on-crash)'{-S,--source-on-crash}'+[command file]:file:_files' \
        '(-b --batch)'{-b,--batch}'[batch mode]' \
        '(-Q --source-quietly)'{-Q,--source-quietly}'[suppress command echo]' \
        '(-x --no-use-colors)'{-x,--no-use-colors}'[no colors]' \
        '(-X --use-colors)'{-X,--use-colors}'[force colors]' \
        '(-a --arch)'{-a,--arch}'+[architecture]:arch:' \
        '(-w --no-wait-for)'{-w,--no-wait-for}'[do not wait for process]' \
        '(-W --wait-for)'{-W,--wait-for}'[wait for process]' \
        '(-n --attach-name)'{-n,--attach-name}'+[process name]:name:' \
        '(-p --attach-pid)'{-p,--attach-pid}'+[PID]:pid:_pids' \
        '(-r --repl)'{-r,--repl}'[interactive REPL mode]' \
        '(-R --repl-language)'{-R,--repl-language}'+[REPL language]:lang:' \
        '(-T --no-multiline)'{-T,--no-multiline}'[disable multiline]' \
        '(-y --batch)'{-y,--batch}'[batch mode]' \
        '*::args:_files'
}

_lldb-bin "$@"
