#compdef dotfile
# Documentation: https://github.com/towry/dotfile-cli
# Source: towry/dotfile-cli — minimal Rust dotfile manager (archived 2024-08).
# Reference accessed: 2026-06-01

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-a --add)'{-a+,--add=}'[add files to the dotfiles directory]:file:_files' \
    '(-r --remove)'{-r+,--remove=}'[remove files from the dotfiles directory]:file:_files' \
    '(-s --sync)'{-s,--sync}'[synchronize dotfiles]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
