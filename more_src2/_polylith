#compdef polylith
# _polylith — Joakim Tengstrand Polylith Clojure architecture/build tool CLI alias (polyfy team, Clojure); custom argparse
# upstream: https://github.com/polyfy/polylith

_polylith() {
    local -a sub=(
        'check:check the workspace'
        'create:create components, bases, projects, workspaces'
        'create-c:alias for create c'
        'create-b:alias for create b'
        'create-p:alias for create p'
        'create-w:alias for create w'
        'deps:print dependencies'
        'diff:print diff'
        'help:print help'
        'info:print workspace info'
        'libs:print libs in workspace'
        'migrate:migrate workspace'
        'overview:print overview'
        'shell:open polylith shell'
        'sync:sync workspace state'
        'test:run tests'
        'ws:print workspace'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'polylith subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '1:kind:(c b p w workspace base component project)' \
                    'name=+[name]:str:' \
                    'top-ns=+[top namespace]:str:' \
                    'interface=+[interface]:str:' \
                    'language=+[language]:l:(clj cljs cljc)' \
                    'branch=+[branch]:str:' ;;
                check|info|deps|libs|ws|overview|test) _arguments \
                    'project=+[project]:str:' \
                    'projects=+[projects]:str:' \
                    'brick=+[brick]:str:' \
                    'bricks=+[bricks]:str:' \
                    'since=+[since]:str:' \
                    'branch=+[branch]:str:' \
                    'fake-sha=+[sha]:str:' \
                    'color-mode=+[mode]:m:(dark light none)' \
                    ':all[all projects]' \
                    ':all-bricks[all bricks]' \
                    ':changes[only changes]' \
                    ':no-changes[no changes]' \
                    ':keep-cache[keep cache]' \
                    ':loc[lines of code]' \
                    ':deps[show deps]' \
                    ':ignore[ignore failures]' ;;
                test) _arguments \
                    'project=+[project]:str:' \
                    'projects=+[projects]:str:' \
                    'brick=+[brick]:str:' \
                    'mode=+[mode]:m:(all dev compile)' \
                    ':parallel[parallel]' \
                    ':all[all projects]' ;;
                migrate) _arguments ':keep-cache[keep cache]' ':deps-update[update deps]' ;;
            esac
            ;;
    esac
}

_polylith "$@"
