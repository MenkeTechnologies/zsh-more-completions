#compdef rmarkdown rmd-cli rmd
# _rmarkdown — RStudio R Markdown dynamic doc framework CLI alias (RStudio / Posit, R); custom argparse via R wrapper
# upstream: https://github.com/rstudio/rmarkdown

_rmarkdown() {
    local -a sub=(
        'render:render an Rmd file'
        'run:run a Shiny Rmd'
        'draft:create a new Rmd draft'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--input=+[input Rmd]:file:_files -g "*.Rmd *.qmd *.md"' \
        '-i+[input Rmd]:file:_files -g "*.Rmd *.qmd *.md"' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--output-format=+[output format]:f:(html_document pdf_document word_document md_document html_notebook beamer_presentation ioslides_presentation slidy_presentation revealjs_presentation rtf_document odt_document html_vignette pdf_vignette github_document jekyll_document tufte_handout tufte_html)' \
        '-f+[output format]:f:(html_document pdf_document word_document md_document html_notebook beamer_presentation ioslides_presentation slidy_presentation revealjs_presentation rtf_document odt_document html_vignette pdf_vignette github_document jekyll_document tufte_handout tufte_html)' \
        '--output-options=+[output options yaml]:str:' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--params=+[params yaml]:str:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--encoding=+[encoding]:str:' \
        '--clean[clean intermediate]' \
        '--knit-root-dir=+[knit root dir]:dir:_files -/' \
        '--envir=+[environment]:str:' \
        '--runtime=+[runtime]:r:(auto static shiny shinyrmd)' \
        '--intermediates-dir=+[intermediates dir]:dir:_files -/' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rmarkdown subcommand' sub ;;
        args)
            case $words[1] in
                draft) _arguments \
                    '1:file:_files' \
                    '--template=+[template]:str:' \
                    '--package=+[package]:str:' ;;
            esac
            ;;
    esac
}

_rmarkdown "$@"
