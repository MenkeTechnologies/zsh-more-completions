#compdef flmsg
# Documentation: https://github.com/w1hkj/flmsg/blob/master/src/flmsg.cxx
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--server-port=[starting port number for forms web server (default 8080)]:port:' \
  '--flmsg-dir=[full path of folder for all FLMSG folders]:dir:_files -/' \
  '--auto-dir=[full path of folder for autosend files]:dir:_files -/' \
  '--p[print FILENAME and exit]:file:_files' \
  '--b[print FILENAME and stay open]:file:_files' \
  '*:message file:_files' && ret=0

return ret
