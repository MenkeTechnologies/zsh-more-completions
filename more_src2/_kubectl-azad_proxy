#compdef kubectl-azad_proxy
# Documentation: https://github.com/XenitAB/azad-kube-proxy
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-azad_proxy (XenitAB/azad-kube-proxy): generate/handle auth for
# azad-kube-proxy.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[enable verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:create kubeconfig with Azure AD authentication'
      'login:authenticate and rotate token'
      'menu:interactive prompt for proxy configuration'
      'discover:list available proxies'
    )
    _describe -t commands 'kubectl azad-proxy command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s -S \
          '--cluster-name=[name of the cluster]:name:' \
          '--proxy-url=[URL of the proxy]:url:' \
          '--resource=[resource URI for Azure AD application]:resource:' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '--tls-insecure-skip-verify[skip TLS verification]' \
          '--overwrite[overwrite existing configuration]' && ret=0
        ;;
      discover)
        _arguments -s -S \
          '--output=[output format]:format:(JSON TABLE)' && ret=0
        ;;
    esac
    ;;
esac

return ret
