#compdef gmx_d
# Documentation: https://manual.gromacs.org/current/user-guide/cmdline.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# GROMACS gmx_d: double-precision build of the gmx driver
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'pdb2gmx:generate topology from coordinates'
  'editconf:edit configuration files'
  'solvate:solvate the system'
  'genion:add counterions'
  'grompp:preprocess MD input (TPR)'
  'mdrun:run a simulation'
  'energy:analyze energies'
  'rms:compute RMSD'
  'rmsf:compute RMSF'
  'gyrate:compute radius of gyration'
  'do_dssp:secondary structure analysis'
  'trjconv:convert/process trajectories'
  'trjcat:concatenate trajectories'
  'check:check trajectory'
  'eneconv:concatenate/edit energy files'
  'distance:distance analysis'
  'hbond:hydrogen bond analysis'
  'rdf:radial distribution function'
  'msd:mean square displacement'
  'sasa:solvent-accessible surface area'
  'wham:weighted histogram analysis method'
)

_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-quiet[silence header output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'gmx_d command' commands && ret=0 ;;
esac
return ret
