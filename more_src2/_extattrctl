#compdef extattrctl
# Documentation: man extattrctl(8)
# Source: netbsd/src usr.sbin/extattrctl — UFS1 extended attributes control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[permit overwriting existing backing files]' \
    '-p+[preallocate space instead of sparse files]:path:_files -/' \
    '1:command:(start stop initattr showattr enable disable)' \
    '*::path, attrsize, attrnamespace, attrname, or attrfile:_files' \
    && ret=0

return ret
