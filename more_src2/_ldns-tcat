#compdef ldns-tcat
# _ldns-tcat — NLnet Labs ldns-tcat (transparent DNS proxy + simple BIND-style stub that prints every received message as wire-format hex; -p listen port, -P pidfile, -f forwarder, -t TCP only, -6 IPv6 only, -4 IPv4 only, -v verbose; positional argument is the working directory or none)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldns-tcat.c on tip.

_ldns-tcat() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-p+[listen port]:port:' \
        '-P+[pidfile]:file:_files' \
        '-f+[forwarder]:host:_hosts' \
        '-t[TCP only]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]'
}

_ldns-tcat "$@"
