#compdef rasdaemon
# Documentation: https://github.com/mchehab/rasdaemon/blob/master/rasdaemon.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--help[show help]' \
  '--usage[brief usage]' \
  '--version[show version]' \
  '-e[enable RAS events and exit]' \
  '--enable[enable RAS events and exit]' \
  '-d[disable RAS events and exit]' \
  '--disable[disable RAS events and exit]' \
  '-r[record events via sqlite3]' \
  '--record[record events via sqlite3]' \
  '-f[run in foreground]' \
  '--foreground[run in foreground]' \
  '-i[enable ipmitool logging]' \
  '-p[post-process MCEs with raw register values]' \
  '--smca[AMD SMCA error decoding]' \
  '--model=[CPU model]:model:' \
  '--family=[CPU family]:family:' \
  '--bank=[bank number]:bank:' \
  '--ipid=[IPID register (SMCA only)]:reg:' \
  '--status=[status register]:reg:' \
  '--synd=[syndrome register]:reg:' && ret=0

return ret
