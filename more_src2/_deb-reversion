#compdef deb-reversion
# Documentation: https://manpages.debian.org/deb-reversion
# Source: debian/devscripts scripts/deb-reversion.sh — change version number of a binary Debian package (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-v --new-version)'{-v+,--new-version=}'[set new version]:version:_default' \
    '(-o --old-version)'{-o+,--old-version=}'[old version to base new version on]:version:_default' \
    '(-c --calculate-only --print-only)'{-c,--calculate-only,--print-only}'[only calculate and print new version]' \
    '(-s --string)'{-s+,--string=}'[append string instead of default VERSTR]:string:_default' \
    '(-k --hook)'{-k+,--hook=}'[script to run before repacking]:script:_files' \
    '(-D --debug)'{-D,--debug}'[run dpkg-deb in debug mode]' \
    '(-b --force-bad-version)'{-b,--force-bad-version}'[pass --force-bad-version to dch]' \
    '1:deb file:_files -g "*.deb"' \
    '*:log message:_default' \
    && ret=0

return ret
