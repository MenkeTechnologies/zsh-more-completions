#compdef lvmlockctl
# Documentation: https://man7.org/linux/man-pages/man8/lvmlockctl.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# lvmlockctl: control runtime state of lvmlockd
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-q,--quit}'[tell lvmlockd to quit]' \
  {-i,--info}'[print lock state info from lvmlockd]' \
  {-d,--dump}'[print log buffer from lvmlockd]' \
  {-w+,--wait=}'[wait option]:value:(0 1)' \
  {-f+,--force=}'[force option]:value:(0 1)' \
  {-k+,--kill=}'[kill access to the VG]:vgname:' \
  {-r+,--drop=}'[clear locks for the VG]:vgname:' \
  {-E+,--gl-enable=}'[enable the global lock in a sanlock VG]:vgname:' \
  {-D+,--gl-disable=}'[disable the global lock in a sanlock VG]:vgname:' \
  {-S,--stop-lockspaces}'[stop all lockspaces]' \
  '*::lvmlockctl args:_files' && ret=0
return ret
