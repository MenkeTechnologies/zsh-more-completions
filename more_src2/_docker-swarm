#compdef docker-swarm
# _docker-swarm — Docker Swarm classic (deprecated standalone Swarm CLI superseded by Docker Engine swarm mode; subcommands: create token, manage, join, list, info, version; -H Docker host, --tlscacert, --tlscert, --tlskey, --tls, --tlsverify; replaced by docker swarm in modern engines)
# upstream: https://github.com/docker/swarm-classic
# Subcommands from docker swarm-classic on tip.

_docker-swarm() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '-H+[Docker host]:host:_hosts' \
        '--tlscacert+[CA file]:file:_files' \
        '--tlscert+[cert file]:file:_files' \
        '--tlskey+[key file]:file:_files' \
        '--tls[enable TLS]' \
        '--tlsverify[verify TLS]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'docker-swarm command' '(create manage join list info help version)' ;;
        args)
            case $line[1] in
                join|manage|list) _arguments \
                    '--addr+[advertise address]:addr:' \
                    '--discovery+[discovery url]:url:' \
                    '--heartbeat+[heartbeat]:duration:' \
                    '--strategy+[strategy]:strategy:(spread binpack random)' \
                    '--filter+[filter]:filter:(health label affinity port dependency constraint)' \
                    '-H+[Docker host]:host:_hosts' ;;
            esac
            ;;
    esac
}

_docker-swarm "$@"
