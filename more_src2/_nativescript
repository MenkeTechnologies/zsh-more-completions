#compdef tns nativescript
# ---------------------------------------------------------------------------
# tns / nativescript — NativeScript CLI: command-line interface for
#                       building cross-platform iOS / Android / VisionOS
#                       / Android-TV / watchOS apps with shared JS/TS
#                       codebase (JavaScript, 1053★)
#
# upstream: https://github.com/NativeScript/nativescript-cli
# author : NativeScript org / OpenJS Foundation incubation
# license: Apache-2.0
# npm    : `nativescript` (provides four bin aliases — `tns` /
#          `nativescript` / `nsc` / `ns` — all symlinked to ./bin/tns).
#          This completion covers only `tns` and `nativescript` because
#          `nsc` collides with NATS' nsc binary (covered by a separate
#          completion in this corpus) and `ns` is too generic (in
#          blacklist.txt — single-letter / two-letter binary names
#          intentionally skipped from auto-generation to avoid
#          collisions with shell builtins / aliases / other generic
#          tools).
#
# Source-direct completion: every subcommand below is verbatim from the
# `lib/commands/*.ts` and `lib/commands/{plugin,extensibility,embedding,
# resources,hooks}/*.ts` directory listings on the NativeScript/
# nativescript-cli tip — each `.ts` file corresponds to a command
# registered via injector.requireCommand on the yok DI container.
# Global flags come from lib/options.ts + lib/common/options.ts decl
# arrays.  Platform-arg completion (android/ios/visionos) reflects the
# platforms registered in lib/services/platform-service.ts.
#
# Direct deps from package.json (selected):
#   marked-terminal       ^7.3.0  ← canonical JS terminal markdown
#                                    renderer (this axis) — by Mikael
#                                    Brevik (mikaelbr/marked-terminal);
#                                    a `marked` parser RENDERER plugin
#                                    (not a parser) that emits ANSI-
#                                    styled output instead of HTML, with
#                                    chalk-based color styling, cli-
#                                    table3 for table layout,
#                                    cli-highlight (chroma analog for
#                                    Node) for code-block syntax
#                                    highlighting, and configurable
#                                    options for heading colors, list
#                                    bullets, code fence borders, etc.
#                                    Used by hundreds of npm-ecosystem
#                                    CLI tools that need to render
#                                    embedded markdown documentation /
#                                    README content / changelogs in the
#                                    terminal.  NativeScript CLI uses
#                                    it for the `tns help` / `tns
#                                    <command> --help` output, which
#                                    embeds rich markdown-formatted
#                                    documentation pages (each command
#                                    has a corresponding .md file under
#                                    lib/common/docs/man_pages/ that
#                                    gets rendered to ANSI when
#                                    displayed in the terminal,
#                                    matching the help shown by the
#                                    `docs/` site for the web docs).
#   marked               ^15.0.12 (the parser that marked-terminal
#                                    wraps with the renderer plugin)
#   yargs                          (CLI arg parsing — alternative to
#                                    commander; the official yargs
#                                    bash/zsh completion bridge is
#                                    triggered with the special
#                                    --get-yargs-completions flag
#                                    handled at the top of
#                                    nativescript-cli.ts)
#   chalk + cli-table3 + ora + inquirer + shelljs + uuid + plist + xml2js
#   ... + a large surface of build/deploy/run service deps for the
#   actual platform tooling (Xcode / Android SDK / adb / ideviceinstaller).
#
# `tns` (and its `nativescript` alias) is a polyglot mobile build tool
# that bridges JavaScript / TypeScript / Vue / Svelte / Angular /
# Solid front-end code to native iOS / Android / VisionOS apps via the
# NativeScript runtime (the bridge that exposes platform APIs directly
# to JS without a webview).  Major workflow: `tns create <name>`
# scaffolds a project, `tns add platform <ios|android>` adds a target
# platform, `tns prepare` syncs JS code into the platform-specific
# build directory, `tns build <platform>` produces an .ipa / .apk,
# `tns run <platform>` runs on emulator / device with LiveSync (hot-
# reload on code changes), `tns debug <platform>` attaches Chrome
# DevTools to the running app, `tns plugin add <pkg>` installs a
# native plugin, `tns appstore upload` ships to App Store Connect.
# Help output is rich markdown-rendered to ANSI via marked-terminal.
#
# ============================================================================
# === AXIS 183 CLOSES — terminal markdown rendering libraries =============
# === TRIPLE-238 ROUND-NUMBER LANDMARK · 176th AXIS CLOSED ================
# ============================================================================
# Axis position: TS-Node=238 CLOSES Axis 183 at slot 1/1/1 — quadruple-clean
# closure of the canonical terminal markdown rendering library ecosystem
# spanning the three major systems languages.  All three lanes anchor on
# a single pure-host-language library for "render this markdown source
# as a beautifully styled terminal block with ANSI color escapes,
# aligned bullets, code-block syntax highlighting, table column
# alignment, and skin-able theming":
#
#     Rust    : termimad                     by Denys Séguret (Canop /
#                                              the broot author); pure-
#                                              Rust markdown parser +
#                                              ANSI renderer with
#                                              skinnable styling.
#                                              Wraps `minimad` for the
#                                              parser and adds
#                                              rendering / skinning /
#                                              scrolling / interactive
#                                              paging.
#                 → ggsql (Posit PBC ggsql Team — declarative data
#                           visualization language extending SQL with
#                           grammar-of-graphics primitives; compiles to
#                           Vega-Lite JSON; `ggsql docs` uses termimad
#                           to render embedded markdown documentation
#                           for every clause / layer / scale / aesthetic
#                           / coord primitive; 483★ MIT)
#                 _ggsql            [Rust=238 OPENED Axis 183, slot 1/0/0]
#
#     Go      : github.com/charmbracelet/glamour
#                                            by Charmbracelet (the
#                                              bubbletea / lipgloss /
#                                              glow org); pure-Go
#                                              markdown renderer
#                                              wrapping goldmark as the
#                                              parser and adding a
#                                              TermRenderer that emits
#                                              ANSI-styled output with
#                                              skinnable themes
#                                              (dracula / dark / light /
#                                              pink / notty / ascii) +
#                                              chroma-backed code-block
#                                              syntax highlighting.
#                 → reader (Marius mrusme — readability-style web
#                            article reader for the terminal; strips
#                            chrome/navigation/ads via Mozilla-
#                            Readability extraction, converts cleaned
#                            HTML to Markdown via JohannesKaufmann/
#                            html-to-markdown, then ANSI-renders via
#                            glamour.NewTermRenderer with
#                            WithEnvironmentConfig + WithWordWrap;
#                            also handles EML/email input mode;
#                            408★ GPL-3.0)
#                 _reader           [Go=238 CONTINUED Axis 183, slot 2/0/0]
#
#     JS/Node : marked-terminal               by Mikael Brevik
#                                              (mikaelbr/marked-terminal);
#                                              a `marked` parser
#                                              RENDERER plugin (not a
#                                              parser) — installed via
#                                              `marked.use({ renderer:
#                                              new TerminalRenderer()
#                                              })` to swap the default
#                                              HTML output for ANSI-
#                                              styled terminal output.
#                                              Uses chalk for color,
#                                              cli-table3 for table
#                                              layout, cli-highlight
#                                              (the Node analog of
#                                              chroma) for code-block
#                                              syntax highlighting, and
#                                              configurable options for
#                                              heading colors / list
#                                              bullets / code fence
#                                              borders / link
#                                              presentation.  Used by
#                                              hundreds of npm-
#                                              ecosystem CLI tools.
#                 → tns / nativescript (NativeScript org / OpenJS
#                                        Foundation — NativeScript CLI
#                                        for building cross-platform
#                                        iOS / Android / VisionOS apps
#                                        with shared JavaScript /
#                                        TypeScript codebase; help /
#                                        man-page output is rich
#                                        markdown rendered to ANSI via
#                                        marked-terminal; 35+ commands
#                                        spanning project scaffolding /
#                                        platform management / build /
#                                        run / debug / preview / deploy
#                                        / plugin management / app
#                                        store upload; 1053★ Apache-2.0)
#                 _nativescript     [TS-Node=238 CLOSES Axis 183, 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 marked-terminal differs architecturally from termimad
#                 and glamour: it's a RENDERER PLUGIN injected into the
#                 host parser (`marked`), whereas termimad and glamour
#                 BUNDLE their parsers (minimad / goldmark) into a
#                 unified package.  This reflects the JS ecosystem's
#                 preference for composable single-purpose packages —
#                 the parser and renderer are separately versioned and
#                 independently swappable.
#
# Round-number 238 landmark fires simultaneously across all three lanes:
# Rust completion #238 (_ggsql) + Go completion #238 (_reader) + TS-Node
# completion #238 (_nativescript) = triple-238.  Axis #176 closed in
# the lifetime of the corpus — every canonical terminal markdown
# rendering library in the three big systems languages now has both a
# representative consumer completion AND a documented axis closure
# landmark; the lanes are tied together by a common design discipline
# (pure-host-language ANSI-emitting markdown renderer with skinnable
# styling, no shelling out to glow / mdcat / bat-markdown).
# ============================================================================

_nativescript() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a global_opts
    global_opts=(
        '--path=[project directory (default: cwd)]:path:_files -/'
        '--log=[log level]:level:(trace debug info warn error fatal)'
        '(--verbose -v)'{--verbose,-v}'[verbose output (alias for --log trace)]'
        '--analyticsLogFile=[write analytics events to file]:path:_files'
        '--analyticsClient=[analytics client identifier]:client:'
        '--bundle[bundle JS via webpack (default true in modern projects)]'
        '--hmr[enable Hot Module Replacement during run/debug]'
        '--debug-brk[break on first line of JS in debug mode]'
        '--no-watch[disable LiveSync file watching]'
        '--justlaunch[do not stream device logs after run]'
        '--clean[clean intermediate build artefacts before action]'
        '--release[release build (signed, optimized) instead of debug]'
        '--for-device[build for physical device instead of simulator (iOS)]'
        '--device=[device identifier (UDID or serial)]:device:'
        '--emulator[force run on emulator/simulator]'
        '--avd=[Android AVD name to run on]:avd:'
        '--key-store-path=[Android keystore path for release builds]:path:_files'
        '--key-store-password=[Android keystore password]:password:'
        '--key-store-alias=[Android keystore key alias]:alias:'
        '--key-store-alias-password=[Android keystore key alias password]:password:'
        '--provision=[iOS provisioning profile UUID/name]:profile:'
        '--teamId=[Apple Developer Team ID for code signing]:teamId:'
        '--ipa=[path to .ipa file (for appstore upload)]:ipa:_files -g "*.ipa"'
        '--apk=[path to .apk file]:apk:_files -g "*.apk"'
        '--aab=[path to .aab Android App Bundle]:aab:_files -g "*.aab"'
        '--env=[webpack env values (KEY=VALUE; repeat for multiple)]:env:'
        '--syncAllFiles[sync all files including those typically excluded]'
        '--force[force action even if validation warns]'
        '--no-hooks[disable executing custom hooks]'
        '--disable-npm-install[skip npm install step]'
        '--ignore-scripts[pass --ignore-scripts to npm install]'
        '--use-only-current-host-name[do not auto-detect alternate hostnames]'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help (rendered via marked-terminal to ANSI)]' \
        '(- *)--version[print CLI version]' \
        $global_opts \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'create:create a new NativeScript project from template (alias: create-project)'
                'create-project:create a new NativeScript project (canonical name)'
                'add:add a platform / plugin / native dependency to the project'
                'add-platform:add a target platform (ios / android / visionos) to the project'
                'native-add:add a native iOS/Android dependency declaration'
                'remove:remove a platform / plugin'
                'remove-platform:remove a target platform from the project'
                'list:list installed platforms / plugins / extensions / devices'
                'list-platforms:list platforms installed in this project'
                'platform:manage platforms (add / list / remove / update / clean)'
                'platform-clean:remove + re-add the platforms directory'
                'update:update the platforms / dependencies / CLI'
                'update-platform:update a specific platform runtime'
                'migrate:migrate the project to the current CLI / runtime conventions'
                'prepare:sync JS source into the platform-specific build directory'
                'build:build the app for a platform (--release for signed/optimized)'
                'run:build + deploy + launch on emulator/device with LiveSync'
                'debug:build + deploy + launch + attach Chrome DevTools'
                'deploy:build + deploy without launching'
                'preview:scan QR code to preview the app on Preview-app on a device'
                'test:run the unit-test suite (mocha/jasmine/qunit) on emulator/device'
                'test-init:scaffold the test framework setup'
                'install:install a NativeScript plugin from npm'
                'clean:clean intermediate build artifacts (platforms/ + node_modules/)'
                'config:read / write per-project NativeScript configuration values'
                'info:print environment info (CLI / runtime / Node / npm / Xcode / Android SDK versions)'
                'doctor:run environment diagnostics for missing/misconfigured tooling'
                'setup:run the environment setup wizard'
                'start:run the LiveSync server only (without deploying to a device)'
                'generate:scaffold a component / page / module via the generate tooling'
                'generate-assets:generate icon / splash screen assets from a single source'
                'fonts:list / inspect custom fonts loaded into the project'
                'typings:fetch / regenerate iOS+Android native typings for TypeScript'
                'widget:scaffold a NativeScript widget'
                'apple-login:authenticate with Apple ID for App Store Connect actions'
                'appstore:App Store Connect interactions (list / upload subcommands)'
                'plugin:manage NativeScript plugins (add / build / create / list / remove / update)'
                'extension:manage NativeScript CLI extensions (install / list / uninstall)'
                'embedding:NativeScript-as-Library workflows (embed NS runtime in native app)'
                'resources:manage / generate app icons / splash screens / launch storyboards'
                'help:print help for a specific command (rendered via marked-terminal)'
                'autocomplete:enable / disable / get yargs-style shell autocomplete'
                'usage-reporting:enable / disable / status of CLI usage telemetry'
                'error-reporting:enable / disable / status of CLI error reporting'
                'proxy:configure CLI HTTP proxy for downloads'
            )
            _describe -t commands 'NativeScript command' subcmds && ret=0
            ;;
        args)
            local -a platforms=(android ios visionos)
            case $words[1] in
                build|run|debug|deploy|prepare|clean|test|generate-assets|platform-clean|add-platform|remove-platform|update-platform|list-platforms|preview)
                    _arguments \
                        $global_opts \
                        '1:platform:(android ios visionos)' && ret=0
                    ;;
                create|create-project)
                    _arguments \
                        $global_opts \
                        '--template=[scaffold from a template (npm pkg, git URL, or builtin)]:template:' \
                        '--ng[Angular template]' \
                        '--vue[Vue template]' \
                        '--react[React template]' \
                        '--svelte[Svelte template]' \
                        '--solid[Solid template]' \
                        '--ts[TypeScript template]' \
                        '--js[JavaScript template]' \
                        '--appid=[application bundle id (e.g. com.example.app)]:appid:' \
                        '1:project name:' && ret=0
                    ;;
                plugin)
                    _arguments \
                        $global_opts \
                        '1: :->plugincmds' \
                        '*::plugin-arg:->pluginargs' && ret=0
                    case $state in
                        plugincmds)
                            local -a pluginsubs
                            pluginsubs=(
                                'add:install a NativeScript plugin from npm or path'
                                'build:build a plugin from source (for plugin authors)'
                                'create:scaffold a new NativeScript plugin'
                                'list:list installed plugins'
                                'remove:uninstall a plugin'
                                'update:update one or more plugins'
                            )
                            _describe -t plugin-commands 'plugin subcommand' pluginsubs && ret=0
                            ;;
                        pluginargs)
                            _arguments $global_opts '*:plugin name (npm package / path):' && ret=0
                            ;;
                    esac
                    ;;
                extension)
                    _arguments \
                        $global_opts \
                        '1: :->extcmds' \
                        '*::ext-arg:->extargs' && ret=0
                    case $state in
                        extcmds)
                            local -a extsubs
                            extsubs=(
                                'install:install a CLI extension from npm'
                                'list:list installed extensions'
                                'uninstall:uninstall a CLI extension'
                            )
                            _describe -t extension-commands 'extension subcommand' extsubs && ret=0
                            ;;
                        extargs)
                            _arguments $global_opts '*:extension package:' && ret=0
                            ;;
                    esac
                    ;;
                appstore)
                    _arguments \
                        $global_opts \
                        '1: :->ascmds' \
                        '*::as-arg:->asargs' && ret=0
                    case $state in
                        ascmds)
                            local -a assubs
                            assubs=(
                                'list:list apps registered in App Store Connect for the authenticated team'
                                'upload:upload an .ipa to App Store Connect'
                            )
                            _describe -t appstore-commands 'appstore subcommand' assubs && ret=0
                            ;;
                        asargs)
                            _arguments \
                                $global_opts \
                                '--username=[Apple ID]:username:' \
                                '--password=[Apple ID password / app-specific password]:password:' \
                                '--ipa=[path to .ipa file]:file:_files -g "*.ipa"' && ret=0
                            ;;
                    esac
                    ;;
                help)
                    local -a allcmds
                    allcmds=(create add build run debug deploy plugin extension appstore platform prepare clean info doctor setup test config generate fonts typings install update migrate)
                    _describe -t commands 'subcommand for help' allcmds && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_nativescript "$@"
