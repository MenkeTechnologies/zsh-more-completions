#compdef gtk-query-immodules gtk-query-immodules-2.0 gtk-query-immodules-3.0
# Documentation: https://manpages.debian.org/gtk-query-immodules
# Source: GNOME/gtk gtk/queryimmodules.c — list GTK input method modules (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '--update-cache[update the IM module cache file]' \
    '*:input method module:_files -g "*.so"' \
    && ret=0

return ret
