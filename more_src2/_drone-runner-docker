#compdef drone-runner-docker
# _drone-runner-docker — Drone CI Docker pipeline runner (drone-runners/drone-runner-docker)
# upstream: https://github.com/drone-runners/drone-runner-docker
# Subcommands from command/command.go (kingpin) on tip.

_drone-runner-docker() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                daemon:'run the runner daemon (reads .env / envfile)'
                exec:'execute a pipeline locally'
                compile:'compile a pipeline YAML and print the intermediate'
                copy:'copy the runner entrypoint binary'
            )
            _describe -t commands 'drone-runner-docker command' cmds
            ;;
        args)
            case $words[1] in
                daemon)
                    _arguments ':envfile:_files'
                    ;;
                exec)
                    _arguments \
                        '--clone=[enable cloning]:bool:(true false)' \
                        '*--secrets=[secret param key=value]:secret:' \
                        '*--include=[include pipeline step]:step:' \
                        '*--exclude=[exclude pipeline step]:step:' \
                        '*--environ=[set environment variable]:var:' \
                        '*--labels=[container label key=value]:label:' \
                        '*--networks=[container network]:net:' \
                        '*--volumes=[container bind volume]:vol:' \
                        '*--privileged=[privileged image]:img:' \
                        '--cpu-period=[container cpu period]:n:' \
                        '--cpu-quota=[container cpu quota]:n:' \
                        '--cpu-set=[container cpuset]:set:' \
                        '--cpu-shares=[container cpu shares]:n:' \
                        '--memory=[container memory limit]:bytes:' \
                        '--memory-swap=[container memory swap limit]:bytes:' \
                        '--public-key=[public key file]:file:_files' \
                        '--private-key=[private key file]:file:_files' \
                        '--docker-config=[docker config file]:file:_files' \
                        '--debug[enable debug logging]' \
                        '--trace[enable trace logging]' \
                        '--dump[dump pipeline state to stdout]' \
                        ':source-file:_files'
                    ;;
                compile)
                    _arguments \
                        '--source=[source file location]:file:_files' \
                        '--clone=[enable cloning]:bool:(true false)' \
                        '*--secrets=[secret param key=value]:secret:' \
                        '*--environ=[set environment variable]:var:' \
                        '*--labels=[container label key=value]:label:' \
                        '*--networks=[container network]:net:' \
                        '*--volumes=[container bind volume]:vol:' \
                        '--memory=[container memory limit]:bytes:' \
                        '--docker-config=[docker config file]:file:_files'
                    ;;
                copy)
                    _arguments \
                        '--source=[source binary path]:file:_files' \
                        '--target=[target binary path]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_drone-runner-docker "$@"
