#compdef lctl
# Documentation: https://manpages.org/lctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; cross-checked rread/lustre lctl.8.

# lctl: Low level Lustre filesystem configuration utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'help:show help'
  'quit:exit interactive session'
  'exit:exit interactive session'
  'list_param:list Lustre proc/sys params'
  'get_param:get a param'
  'set_param:set a param'
  'conf_param:set a config param'
  'activate:activate device'
  'deactivate:deactivate device'
  'abort_recovery:abort recovery'
  'mark:mark debug log'
  'debug_kernel:flush kernel debug ring buffer'
  'debug_daemon:debug log daemon'
  'debug_file:read/write debug file'
  'debug_list:list debug subsystem masks'
  'filter:set debug log filter'
  'show:show debug log'
  'clear:clear debug log'
  'modules:print debug module info'
  'dl:list Lustre devices'
  'dk:dump kernel debug log'
  'device:set current device'
  'device_list:list Lustre devices'
  'network:network configuration'
  'list_nids:list LNet NIDs'
  'which_nid:identify which NID to use'
  'replace_nids:replace NIDs'
  'ping:LNet ping'
  'interface_list:list LNet interfaces'
  'peer_list:list LNet peers'
  'conn_list:list LNet connections'
  'route_list:list LNet routes'
  'active_tx:list active transmits'
  'changelog_register:register changelog user'
  'changelog_deregister:deregister changelog user'
  'blockdev_attach:attach virtual block device'
  'blockdev_detach:detach virtual block device'
  'blockdev_info:info on virtual block device'
  'clear_conf:clear configuration log'
  'lfsck-start:start LFSCK'
  'lfsck-stop:stop LFSCK'
  'lfsck-query:query LFSCK'
  'barrier:write barrier control'
  'snapshot-create:create snapshot'
  'snapshot-destroy:destroy snapshot'
  'snapshot-modify:modify snapshot'
  'snapshot-list:list snapshots'
  'snapshot-mount:mount snapshot'
  'snapshot-umount:unmount snapshot'
  'nodemap-activate:activate nodemap'
  'nodemap-add:add nodemap'
  'nodemap-del:delete nodemap'
  'nodemap-add-range:add nodemap range'
  'nodemap-del-range:delete nodemap range'
  'nodemap-add-idmap:add nodemap idmap'
  'nodemap-del-idmap:delete nodemap idmap'
  'nodemap-modify:modify nodemap'
  'nodemap-set-fileset:set nodemap fileset'
  'nodemap-set-sepol:set nodemap SELinux policy'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--device=[device for operation]:devno:' \
  '--ignore_errors[proceed despite errors]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'lctl command' commands && ret=0 ;;
esac
return ret
