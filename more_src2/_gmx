#compdef gmx
# Documentation: https://manual.gromacs.org/current/user-guide/cmdline.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '-quiet[suppress informational messages]' \
  '-nocopyright[do not display copyright]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'mdrun:Perform molecular dynamics simulation'
      'grompp:Generate portable binary run input file'
      'editconf:Edit structure file'
      'genconf:Multiply a conformation'
      'solvate:Solvate a system'
      'genion:Generate ions in simulation box'
      'pdb2gmx:Convert PDB to GROMACS format'
      'make_ndx:Make an index file'
      'genrestr:Generate position restraints'
      'energy:Extract energy data'
      'trjconv:Convert and manipulate trajectory files'
      'trjcat:Concatenate trajectory files'
      'rms:Calculate RMSD'
      'rmsdist:Calculate RMSD between atoms'
      'rmsf:Calculate RMSF'
      'gyrate:Calculate radius of gyration'
      'msd:Calculate mean square displacement'
      'hbond:Calculate hydrogen bonds'
      'sasa:Calculate solvent accessible surface area'
      'cluster:Cluster analysis'
      'covar:Covariance analysis'
      'anaeig:Analyze eigenvectors'
      'mindist:Calculate minimum distance'
      'distance:Calculate distances'
      'angle:Calculate angles'
      'rama:Generate Ramachandran plot data'
      'density:Calculate density profiles'
      'rdf:Calculate radial distribution functions'
      'potential:Calculate electrostatic potential'
      'dipoles:Calculate dipole moments'
      'order:Calculate order parameters'
      'check:Check and compare files'
      'dump:Dump binary files'
      'convert-tpr:Convert tpr files'
      'insert-molecules:Insert molecules into existing system'
      'do_dssp:Assign secondary structure'
      'select:Print selections'
      'view:Visualize trajectory'
      'help:Show help for a command'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
  (args)
    _arguments \
      '-h[show help]' \
      '-s+[input structure/tpr file]:file:_files -g "*.(tpr|gro|pdb|g96)"' \
      '-f+[input trajectory file]:file:_files -g "*.(xtc|trr|gro|pdb|g96|cpt)"' \
      '-n+[index file]:file:_files -g "*.ndx"' \
      '-o+[output file]:file:_files' \
      '-p+[topology file]:file:_files -g "*.top"' \
      '-c+[structure file]:file:_files -g "*.(gro|pdb|g96)"' \
      '-e+[energy file]:file:_files -g "*.edr"' \
      '-b+[begin time]:time:' \
      '-e+[end time]:time:' \
      '-dt+[time step]:time:' \
      '-nice+[nice level]:level:' \
      '-nthreads+[number of threads]:threads:' \
      '-maxwarn+[maximum warnings]:count:' \
      '*:file:_files' && ret=0
    ;;
esac

return ret
