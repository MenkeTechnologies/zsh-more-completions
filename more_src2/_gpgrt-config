#compdef gpgrt-config
# Documentation: gpgrt-config --help (GnuPG / libgpg-error)
# Source: pkg-config-style helper for gpg-error / libassuan / npth modules.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--libdir=[library directory]:dir:_files -/' \
    '--exists[test if module is installed]' \
    '--modversion[print module version]' \
    '--libs[print linker flags]' \
    '--cflags[print compiler flags]' \
    '--static[include static link flags]' \
    '--variable=[print a module variable]:varname:' \
    '--prefix[print prefix]' \
    '--exec-prefix[print exec-prefix]' \
    '--version[print gpgrt-config version]' \
    '*:module:(gpg-error libassuan npth)' \
    && ret=0

return ret
