#
# reek is the **Ruby code-smell detector** by
# troessner — static analysis for Ruby that detects
# code smells like Long Method, Long Parameter List,
# Duplicate Method Call, etc.  Sister to rubocop (in
# corpus) / standardrb (in corpus).  Pivots from Dart
# args (R279 gpth) into the **Ruby language tooling
# cluster**.  **MAJOR MILESTONE**: corpus's **first
# documented Ruby OptionParser CLI** — adds Ruby to
# the cross-language CLI taxonomy (19 library variants
# now).
#
# Critical extraction note: reek uses **Ruby's stdlib
# `OptionParser`** at `OptionParser.new` — corpus's
# **first documented Ruby OptionParser CLI**.
# `OptionParser` is **the** standard Ruby CLI library
# — built into the Ruby stdlib (no gem install
# needed).  Used by Bundler, rubocop, standardrb, and
# most Ruby tooling.  Extends the **cross-language
# CLI taxonomy** to NINETEEN library variants
# (R279 added Dart; R280 adds Ruby): Rust (6: clap
# derive/builder/v3/hand-rolled/pico_args/lexopt), Go
# (4: cobra/pflag/flaggy/stdlib flag), Python (3:
# Click/argparse/Typer), Crystal OptionParser (R269),
# Haskell optparse-applicative (R270), OCaml Cmdliner
# (R271), C POSIX getopt (R272), Java picocli (R276),
# Kotlin clikt (R277), Scala decline (R278), Dart args
# (R279), **Ruby OptionParser** (R280 — NEW).
# Documents the **Ruby block-handler-per-flag pattern**:
# ```ruby
#   parser.on('-c', '--config FILE', 'Help text') do |file|
#     self.config_file = Pathname.new(file)
#   end
# ```
# Distinct from Crystal's OptionParser (R269 shards)
# despite the name similarity — Ruby's OptionParser
# is **the original**; Crystal's is inspired by it
# but uses different DSL.
#
# Critical extraction note: reek uses **`'--[no-]flag'`
# EXPLICIT auto-negatable flag syntax** at options.rb:
# 153, 160, 164, 168, 175, 186 — Ruby OptionParser's
# convention for declaring **both `--flag` AND
# `--no-flag`** in a single declaration.  The `[no-]`
# prefix in the long name tells OptionParser to
# generate both forms.  Documents the **Ruby `[no-]`
# explicit auto-negatable syntax** — distinct from:
#   - Dart args (R279 gpth) auto-negatable OPT-OUT
#     via `negatable: false` (default IS auto-
#     negatable)
#   - Click (R266 uvicorn) `--FLAG/--no-FLAG` PAIRED
#     slash syntax
#   - Rust clap explicit separate `--no-X` flag
# Ruby's approach is OPT-IN syntactic sugar in the
# flag name itself.  **4 enable/disable flag patterns
# NOW documented**: (a) Click explicit slash-paired
# (R266), (b) Rust clap explicit separate (typical),
# (c) Dart args auto-negatable opt-out (R279), (d)
# Ruby OptionParser `[no-]` explicit syntax (R280).
# Corpus's **first documented `[no-]` explicit
# auto-negatable syntax**.
#
# Critical extraction note: reek uses **INLINE
# ALLOWED-VALUES LIST as 3rd positional** at options.rb:
# 134 + 193 — Ruby OptionParser's signature is
# `parser.on(short, long, ALLOWED_LIST, help, help...)
# do |val| ... end` where the ALLOWED_LIST is a Ruby
# array of Symbols.  Examples:
#   `parser.on('-f', '--format FORMAT', [:html, :text,
#              :yaml, :json, :xml, :github], 'help')
#       do |opt| ... end`
#   `parser.on('--sort-by SORTING', [:smelliness, :none],
#              'help') do |sorting| ... end`
# When the user passes `--format yaml`, OptionParser
# validates that `"yaml"` matches one of the Symbols
# (`:yaml`) and converts it to the Symbol automatically.
# Documents the **inline-allowed-values-list pattern**
# — distinct from clap's `value_parser = [...]` (R209),
# Click's `click.Choice([...])` (R266), Dart args's
# `allowed: [...]` (R279).  Ruby's approach is unique
# in passing the allowed list as a POSITIONAL ARG to
# the `.on` method rather than as a keyword arg.
# Corpus's **first documented Ruby inline-allowed-
# values positional pattern**.
#
# Critical extraction note: reek uses **`parser.on_tail`
# for utility options** at options.rb:227, 231, 238 —
# OptionParser distinguishes between:
#   - `.on(...)` — flag added at CURRENT position in
#     help output
#   - `.on_tail(...)` — flag added at the END of help
#     output (always last, regardless of declaration
#     order)
# Used for `-h/--help`, `-l/--list`, `-v/--version`
# — the "utility" flags that should appear at the
# bottom of `--help`.  Documents the **`on_tail`
# help-positioning pattern** — distinct from clap's
# auto-help-flag-position (always at top) and from
# Click's no-positioning-control.  Ruby OptionParser
# is one of the few CLI libraries that gives the
# developer EXPLICIT control over flag ORDERING in
# help text.  Corpus's **first documented help-flag-
# positioning control**.
#
# Critical extraction note: reek uses **`parser
# .separator '...'`** at options.rb:106, 125, 132,
# 143, 211, 226 — OptionParser's API for adding visual
# section headers in the help output (e.g.
# "Configuration:", "Generate a todo list:", "Report
# format:", "Text format options:", "Exit codes:",
# "Utility options:").  Documents the **help-section-
# separator pattern** — distinct from Cmdliner's
# `\`S` man-page sections (R271 dune) and from clap's
# `next_help_heading` (R251 torii).  Ruby's `separator`
# is the most flexible: insert ANY string at the
# current position in help.  Plus the separator can
# include `\n` for blank lines.  Corpus's **first
# documented help-section-separator pattern in Ruby**.

local curcontext="$curcontext" state line

# 6 format values from options.rb:134.
local -a formats=(
  'html:HTML formatted report'
  'text:plain text (default)'
  'yaml:YAML formatted report'
  'json:JSON formatted report'
  'xml:XML formatted report'
  'github:GitHub Actions annotation format'
)

# 2 sort-by values from options.rb:193.
local -a sort_options=(
  'smelliness:smelliest files first'
  'none:processing order (default)'
)

# 19 flags decoded source-direct from options.rb.
_arguments -s -S \
  '(- *)'{-h,--help}'[show help (on_tail; placed at end)]' \
  '(- *)'{-v,--version}'[show version (on_tail; placed at end)]' \
  '(- *)'{-l,--list}'[list all available smell detectors (on_tail)]' \
  '(-c --config)'{-c+,--config=}'[read configuration options from FILE]:file:_files -g "*.{reek,yml,yaml}"' \
  '*--smell=[only look for specific smell (repeatable; e.g. MissingSafeMethod)]:smell:' \
  '--stdin-filename=[filename to use when reading code via pipe]:file:' \
  '(-t --todo)'{-t,--todo}'[generate a todo list]' \
  '(-f --format)'{-f+,--format=}'[report format (default: text)]:format:(($formats))' \
  '(--no-color)--color[use colors for output (default: true; [no-] syntax)]' \
  '(--color)--no-color[disable colors]' \
  '(-V --no-empty-headings)'{-V,--empty-headings}'[show headings for smell-free files (default: false)]' \
  '(-V --empty-headings)--no-empty-headings[do NOT show headings for smell-free files (default; [no-] syntax)]' \
  '(-U --no-documentation)'{-U,--documentation}'[show documentation link per smell (default: true)]' \
  '(-U --documentation)--no-documentation[disable documentation links ([no-] syntax)]' \
  '(--no-show-configuration-path)--show-configuration-path[show which config file Reek is using]' \
  '(--show-configuration-path)--no-show-configuration-path[do NOT show config path (default; [no-] syntax)]' \
  '(-n --no-line-numbers)'{-n,--line-numbers}'[show line numbers in output (default: true)]' \
  '(-n --line-numbers)--no-line-numbers[hide line numbers ([no-] syntax)]' \
  '(-s --single-line -n --line-numbers --no-line-numbers)'{-s,--single-line}'[show location in editor-compatible single-line format]' \
  '(-P --no-progress)'{-P,--progress}'[show progress as files are examined (default: true)]' \
  '(-P --progress)--no-progress[hide progress ([no-] syntax)]' \
  '--sort-by=[sort reported files (default: none)]:criterion:(($sort_options))' \
  '--force-exclusion[force excluding configured `exclude_paths` even when explicitly passed]' \
  '--success-exit-code=[exit code when no smells found (default: 0)]:code:' \
  '--failure-exit-code=[exit code when smells found (default: 2)]:code:' \
  '*:Ruby source files or directories:_files -g "*.rb"'
