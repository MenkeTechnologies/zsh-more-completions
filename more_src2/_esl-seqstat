#compdef esl-seqstat
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-seqstat.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-seqstat: summary statistics of a sequence file
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-a[show stats per sequence]' \
  '-c[count composition (residue frequencies)]' \
  '--informat=[input sequence format]:fmt:(fasta embl genbank ddbj uniprot stockholm pfam a2m afa psiblast clustal phylip phylips)' \
  '--rna[assume RNA]' \
  '--dna[assume DNA]' \
  '--amino[assume protein]' \
  '*:sequence file:_files' && ret=0
return ret
