#compdef KellyKapowski
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/KellyKapowski.cxx — DiReCT cortical thickness with priors (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3)' \
    '(-s --segmentation-image)'{-s+,--segmentation-image=}'[segmentation image (filename or [filename,gmLabel,wmLabel])]:spec:_default' \
    '(-g --gray-matter-probability-image)'{-g+,--gray-matter-probability-image=}'[gray-matter probability image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-w --white-matter-probability-image)'{-w+,--white-matter-probability-image=}'[white-matter probability image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-c --convergence)'{-c+,--convergence=}'[convergence [iters,threshold,window]]:spec:_default' \
    '(-t --thickness-prior-estimate)'{-t+,--thickness-prior-estimate=}'[thickness prior scalar]:n:_default' \
    '(-a --thickness-prior-image)'{-a+,--thickness-prior-image=}'[thickness prior image]:file:_files' \
    '(-r --gradient-step)'{-r+,--gradient-step=}'[step size]:n:_default' \
    '(-l --smoothing-variance)'{-l+,--smoothing-variance=}'[smoothing variance]:n:_default' \
    '(-m --smoothing-velocity-field-parameter)'{-m+,--smoothing-velocity-field-parameter=}'[smoothing velocity field parameter]:n:_default' \
    '(-b --use-bspline-smoothing)'{-b+,--use-bspline-smoothing=}'[use B-spline smoothing]:n:(0 1)' \
    '(-x --use-masked-smoothing)'{-x+,--use-masked-smoothing=}'[use masked smoothing]:n:(0 1)' \
    '(-q --time-points)'{-q+,--time-points=}'[time-point spec]:spec:_default' \
    '(-e --restrict-deformation)'{-e+,--restrict-deformation=}'[restrict deformation per axis]:spec:_default' \
    '(-n --number-of-integration-points)'{-n+,--number-of-integration-points=}'[integration points]:n:_default' \
    '(-p --maximum-number-of-invert-displacement-field-iterations)'{-p+,--maximum-number-of-invert-displacement-field-iterations=}'[max invert-displacement iters]:n:_default' \
    '(-o --output)'{-o+,--output=}'[output thickness image (or [thickness,corticalLabel,warpedWhiteMatter])]:spec:_default' \
    '(- *)'{-v,--verbose}'[verbose]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
