#compdef ffuf-cli
# _ffuf-cli — Joohoi ffuf Fast web fuzzer in Go CLI alias (ffuf team, Go); custom argparse
# upstream: https://github.com/ffuf/ffuf

_ffuf-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-W+[wordlist files]:file:_files' \
        '-w+[wordlist file:keyword]:file:_files' \
        '-u+[target URL]:url:_urls' \
        '-X+[HTTP method]:m:(GET POST PUT PATCH DELETE OPTIONS HEAD TRACE CONNECT)' \
        '-d+[data]:str:' \
        '-D+[dir to use]:dir:_files -/' \
        '-H+[header]:str:' \
        '-b+[cookies]:str:' \
        '-x+[proxy URL]:url:_urls' \
        '-replay-proxy=+[replay proxy URL]:url:_urls' \
        '-recursion[recursive]' \
        '-recursion-depth=+[depth]:n:' \
        '-recursion-strategy=+[strategy]:s:(default greedy)' \
        '-mc+[match status codes csv]:str:' \
        '-ml+[match line count csv]:str:' \
        '-mr+[match regex]:str:' \
        '-ms+[match size csv]:str:' \
        '-mt+[match time]:str:' \
        '-mw+[match word count csv]:str:' \
        '-mmode=+[match mode]:m:(and or)' \
        '-fc+[filter status codes csv]:str:' \
        '-fl+[filter line count csv]:str:' \
        '-fr+[filter regex]:str:' \
        '-fs+[filter size csv]:str:' \
        '-ft+[filter time]:str:' \
        '-fw+[filter word count csv]:str:' \
        '-fmode=+[filter mode]:m:(and or)' \
        '-o+[output file]:file:_files' \
        '-of+[output format]:f:(all html json md ejson csv ecsv)' \
        '-or[output non-matching results]' \
        '-od+[output dir]:dir:_files -/' \
        '-debug-log=+[debug log file]:file:_files' \
        '-c[colorize output]' \
        '-noninteractive[non interactive]' \
        '-s[silent mode]' \
        '-sa[silent mode all]' \
        '-rate=+[requests per second]:n:' \
        '-r[follow redirects]' \
        '-t+[threads]:n:' \
        '-timeout=+[seconds]:n:' \
        '-v[verbose]' \
        '-V[show version]' \
        '-ic[ignore wordlist comments]' \
        '-ignore-body[ignore body]' \
        '-input-cmd=+[command]:str:' \
        '-input-num=+[n]:n:' \
        '-input-shell=+[shell]:str:' \
        '-config=+[config file]:file:_files' \
        '-e+[file extensions csv]:str:' \
        '-p+[pause between]:str:' \
        '-ac[auto calibration]' \
        '-acs=+[auto cal strategy]:s:(basic advanced)' \
        '-ack=+[keyword]:str:' \
        '-sf[stop on spurious 403s]' \
        '-se[stop on spurious errors]' \
        '-sall[stop all]' \
        '-maxtime=+[seconds]:n:' \
        '-maxtime-job=+[seconds]:n:' \
        '-enc=+[transformations]:str:' \
        '-request=+[request file]:file:_files' \
        '-request-proto=+[proto]:p:(http https)' \
        '*:arg:'
}

_ffuf-cli "$@"
