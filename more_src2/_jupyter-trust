#compdef jupyter-trust
# Documentation: jupyter-trust docs
# Source: jupyter-trust — sign a notebook with user trust (nbformat.sign).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--reset[delete existing trust DB then continue]' \
    '--trust[trust signature in NOTEBOOK (default action)]' \
    '--TrustNotebookApp.notebooks=[notebook list]:notebooks:' \
    '--TrustNotebookApp.store_signed_html=[also store signed HTML]:bool:(True False)' \
    '--profile=[Jupyter profile]:profile:' \
    '--config=[config file]:file:_files' \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '(- *)--help-all[show all help]' \
    '*:notebook file:_files -g "*.ipynb"' \
    && ret=0

return ret
