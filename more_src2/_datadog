#compdef datadog dog ddog
# _datadog — Datadog dog Datadog REST API CLI for managing metrics events monitors dashboards alerts incidents service-checks tags hosts downtime users service-level objectives via DD_API_KEY (DataDog team, Python); argparse
# upstream: https://github.com/DataDog/datadogpy

_datadog() {
    local -a sub=(
        'event:event operations'
        'metric:metric operations'
        'monitor:monitor operations'
        'dashboard:dashboard operations'
        'screenboard:screenboard operations'
        'timeboard:timeboard operations'
        'tag:tag operations'
        'comment:comment operations'
        'downtime:downtime operations'
        'host:host operations'
        'incident:incident operations'
        'search:search'
        'service-check:service-check operations'
        'service-level-objective:SLO operations'
        'user:user operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--api-key=+[key]:str:' \
        '-k+[key]:str:' \
        '--application-key=+[key]:str:' \
        '-a+[key]:str:' \
        '--api-host=+[host]:h:_hosts' \
        '--proxy=+[url]:str:' \
        '--no-tls-verify[no TLS verify]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json *.ini"' \
        '--config=+[config file]:file:_files -g "*.yaml *.yml *.json *.ini"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datadog subcommand' sub ;;
        args)
            case $words[1] in
                metric) _arguments \
                    '1:action:(post push query show)' \
                    '--name=+[name]:str:' \
                    '--from=+[ts]:n:' \
                    '--to=+[ts]:n:' \
                    '*:metric value:' ;;
                event) _arguments \
                    '1:action:(post show stream)' \
                    '--title=+[title]:str:' \
                    '--text=+[text]:str:' \
                    '--alert-type=+[t]:t:(error warning info success)' \
                    '--tags=+[csv]:str:' ;;
                monitor) _arguments \
                    '1:action:(create update delete show list mute unmute search)' \
                    '*:monitor id:' ;;
                dashboard|screenboard|timeboard) _arguments \
                    '1:action:(post update delete show list pull)' \
                    '*:dashboard id:' ;;
            esac
            ;;
    esac
}

_datadog "$@"
