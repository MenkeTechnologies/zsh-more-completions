#compdef pwncat-cs
# Documentation: https://pwncat.readthedocs.io/en/latest/usage.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(-v --version)'{-v,--version}'[show version]' \
  '--download-plugins[pre-download plugins]' \
  '(-c --config)'{-c,--config}'=[config file]:file:_files' \
  '--ssl[SSL]' \
  '--ssl-cert=[PEM cert]:file:_files' \
  '--ssl-key=[PEM key]:file:_files' \
  '(-i --identity)'{-i,--identity}'=[SSH identity]:file:_files' \
  '(-l --listen)'{-l,--listen}'[bind/listen mode]' \
  '(-m --platform)'{-m,--platform}'=[platform]:platform:(linux windows)' \
  '(-p --port)'{-p,--port}'=[port]:port:' \
  '--list[list installed implants]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '1:connection string:' \
  '2:port:'
