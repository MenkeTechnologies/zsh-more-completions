#compdef go-feature-flag-relay-proxy
# Documentation: https://gofeatureflag.org/docs/relay-proxy/configure-relay-proxy
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# GO Feature Flag relay proxy (thomaspoignant/go-feature-flag).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '--config=[path to configuration YAML]:file:_files -g "*.{yaml,yml}"' \
  '*::args:_default' && return 0
