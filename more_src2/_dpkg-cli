#compdef dpkg-cli
# _dpkg-cli — Debian dpkg low-level package management CLI alias (Debian project, C); custom argparse
# upstream: https://salsa.debian.org/dpkg-team/dpkg

_dpkg-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--install[install package]' \
        '-i[install package]' \
        '--unpack[unpack package]' \
        '--configure[configure package]' \
        '--triggers-only[triggers only]' \
        '--remove[remove package]' \
        '-r[remove package]' \
        '--purge[purge package]' \
        '-P[purge package]' \
        '--verify[verify package]' \
        '-V[verify package]' \
        '--audit[audit packages]' \
        '-C[audit packages]' \
        '--update-avail[update avail file]' \
        '--merge-avail[merge avail file]' \
        '--clear-avail[clear avail file]' \
        '--forget-old-unavail[forget old unavail]' \
        '--list[list packages]' \
        '-l[list packages]' \
        '--status[show status]' \
        '-s[show status]' \
        '--print-avail[print available]' \
        '-p[print available]' \
        '--listfiles[list files]' \
        '-L[list files]' \
        '--search[search files]' \
        '-S[search files]' \
        '--get-selections[get selections]' \
        '--set-selections[set selections]' \
        '--clear-selections[clear selections]' \
        '--yet-to-unpack[show yet to unpack]' \
        '--add-architecture=+[add architecture]:str:' \
        '--remove-architecture=+[remove architecture]:str:' \
        '--print-architecture[print architecture]' \
        '--print-foreign-architectures[print foreign architectures]' \
        '--abort-after=+[abort after N errors]:n:' \
        '--admindir=+[admin dir]:dir:_files -/' \
        '--instdir=+[instdir]:dir:_files -/' \
        '--root=+[root]:dir:_files -/' \
        '-B[auto deconfigure]' \
        '--auto-deconfigure[auto deconfigure]' \
        '-D+[debug octal]:str:' \
        '--debug=+[debug octal]:str:' \
        '-E[skip if same version]' \
        '--skip-same-version[skip if same version]' \
        '--force-all[force all]' \
        '--no-force-all[no force all]' \
        '--force=+[force flags]:list:(downgrade configure-any hold remove-reinstreq remove-essential depends depends-version breaks conflicts confmiss confnew confold confdef confask overwrite overwrite-dir architecture bad-version bad-path not-root unsafe-io)' \
        '--ignore-depends=+[ignore deps]:list:' \
        '--no-act[no act]' \
        '--dry-run[dry run]' \
        '--simulate[simulate]' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-G[do not install if newer version installed]' \
        '--refuse-downgrade[refuse downgrade]' \
        '--predep-package=+[predep package]:str:' \
        '--no-pager[no pager]' \
        '--no-debsig[no debsig]' \
        '--no-triggers[no triggers]' \
        '*:package:_files -g "*.deb"'
}

_dpkg-cli "$@"
