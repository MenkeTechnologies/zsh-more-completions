#compdef mdbook-plantuml
# _mdbook-plantuml — mdBook preprocessor for PlantUML diagrams (sytsereitsma/mdbook-plantuml)
# upstream: https://github.com/sytsereitsma/mdbook-plantuml
# Flags from src/main.rs (clap derive Args + Command).

_mdbook-plantuml() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-l --log)'{-l,--log}'[log to ./output.log]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            _describe -t commands command '(supports:check whether a renderer is supported)'
            ;;
        args)
            case $words[1] in
                supports) _arguments ':renderer:(html epub markdown latex)' ;;
            esac
            ;;
    esac
}

_mdbook-plantuml "$@"
