#compdef gemgen
# Documentation: https://sr.ht/~kota/gemgen/
# Reference accessed: 2026-05-17
# Verified: ~kota/gemgen upstream flags (-d/--date, -f/--feed,
# -e/--feed-entries, -n/--no-feed, -s/--style, -t/--title,
# -y/--yaml-only, -h/--help, -v/--version).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -o/--output (gemgen writes alongside input by default).

local ret=1
_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --date)'{-d,--date}'[insert today date as h2 header]' \
  '(-f --feed)'{-f,--feed=}'[generate atom feed]:file:_files' \
  '(-e --feed-entries)'{-e,--feed-entries=}'[max entries in atom feed]:n:' \
  '(-n --no-feed)'{-n,--no-feed}'[do not generate atom feed]' \
  '(-s --style)'{-s,--style=}'[chroma style for code blocks]:style:' \
  '(-t --title)'{-t,--title=}'[atom feed title]:title:' \
  '(-y --yaml-only)'{-y,--yaml-only}'[only process YAML frontmatter, skip body]' \
  '*:Markdown:_files -g "*.md(-.)"' && ret=0
return ret
