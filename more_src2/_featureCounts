#compdef featureCounts
# Documentation: https://subread.sourceforge.net/featureCounts.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-a+[annotation file]:file:_files -g "*.(gtf|gff|saf)"' \
  '-F+[annotation format]:format:(GTF GFF SAF)' \
  '-o+[output file]:file:_files' \
  '-t+[feature type]:type:' \
  '-g+[attribute type for grouping]:attribute:' \
  '--extraAttributes+[extra attributes to extract]:attributes:' \
  '-A+[alias file for chromosome names]:file:_files' \
  '-J[count junctions]' \
  '-G+[genome fasta file]:file:_files -g "*.f(a|asta)"' \
  '-p[count fragments instead of reads]' \
  '--countReadPairs[count read pairs for paired-end]' \
  '-B[require both ends mapped]' \
  '-P[check validity of paired-end distance]' \
  '-d+[minimum fragment length]:length:' \
  '-D+[maximum fragment length]:length:' \
  '-C[do not count chimeric fragments]' \
  '-f[perform counting at feature level]' \
  '-O[allow multi-overlap]' \
  '--minOverlap+[minimum overlap bases]:bases:' \
  '--fracOverlap+[minimum overlap fraction]:fraction:' \
  '--fracOverlapFeature+[minimum fraction of feature overlap]:fraction:' \
  '--largestOverlap[assign to feature with largest overlap]' \
  '--nonOverlap+[max non-overlap bases]:bases:' \
  '--nonOverlapFeature+[max non-overlap bases in feature]:bases:' \
  '-M[count multi-mapping reads]' \
  '--fraction[fractional counting for multi-mapping]' \
  '-Q+[minimum mapping quality]:quality:' \
  '--splitOnly[count only split alignments]' \
  '--nonSplitOnly[count only non-split alignments]' \
  '--primary[count only primary alignments]' \
  '--ignoreDup[ignore duplicate reads]' \
  '-s+[strand-specificity]:type:(0 1 2)' \
  '-R+[output detailed assignment results]:format:(BAM SAM CORE)' \
  '--Rpath+[path for detailed results]:dir:_files -/' \
  '-T+[number of threads]:threads:' \
  '--tmpDir+[temporary directory]:dir:_files -/' \
  '--byReadGroup[count by read group]' \
  '--maxMOp+[max number of M operations]:count:' \
  '--verbose[verbose mode]' \
  '-v[show version]' \
  '*:BAM/SAM file:_files -g "*.(bam|sam)"' && ret=0

return ret
