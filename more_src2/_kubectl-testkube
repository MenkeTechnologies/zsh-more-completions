#compdef kubectl-testkube testkube
# Documentation: https://docs.testkube.io/cli/testkube
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--client=[API client transport]:mode:(proxy direct cluster)' \
  '--namespace=[kubernetes namespace]:ns:' \
  '--verbose[debug logging]' \
  '--api-uri=[testkube API base URL]:uri:' \
  '--insecure[allow insecure TLS]' \
  '*--header=[extra HTTP header for direct client]:header:' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'agent:manage agents'
      'cancel:cancel a running test'
      'completion:generate shell completion'
      'config:set/get global testkube config'
      'create:create a resource'
      'dashboard:open the testkube dashboard'
      'debug:debug a testkube installation'
      'delete:delete resources'
      'diagnostics:diagnose testkube installation'
      'disable:disable a feature'
      'docker:docker related commands'
      'download:download resources'
      'enable:enable a feature'
      'generate:generate boilerplate'
      'get:get resources'
      'init:install or initialize testkube'
      'install:install testkube'
      'login:log in to testkube cloud'
      'marketplace:marketplace commands'
      'mcp:manage MCP server integration'
      'migrate:migrate testkube installation'
      'pro:pro/enterprise commands'
      'purge:purge testkube installation'
      'run:execute a test or testsuite'
      'set:configure properties'
      'status:show service status'
      'update:update a resource'
      'upgrade:upgrade testkube'
      'version:show testkube version'
      'watch:watch a test execution'
    )
    _describe -t commands 'kubectl-testkube command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
