#compdef manta configManta.py
# Documentation: https://github.com/Illumina/manta/blob/master/docs/userGuide/README.md
# Reference accessed: 2026-05-19
# Verified: upstream user guide at the URL above. Note: the actual binary
# users invoke is configManta.py; "manta" is the project name.

# Manta: structural variant and indel caller (Illumina)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--config=[config file]:file:_files' \
  '--bam=[input BAM/CRAM file (specify multiple times)]:file:_files -g "*.(bam|cram)"' \
  '--tumorBam=[tumor BAM file]:file:_files -g "*.(bam|cram)"' \
  '--normalBam=[normal BAM file]:file:_files -g "*.(bam|cram)"' \
  '--exome[exome / targeted seq mode]' \
  '--rna[RNA-Seq mode]' \
  '--unstrandedRNA[unstranded RNA-Seq]' \
  '--referenceFasta=[reference FASTA]:file:_files -g "*.(fa|fasta)"' \
  '--runDir=[run directory]:dir:_files -/' \
  '--callRegions=[BGZF/Tabix-indexed BED of regions to call]:file:_files -g "*.(bed|bed.gz)"' \
  '--generateEvidenceBam[output evidence BAMs for SV calls]' \
  '--callMemMb=[memory per call job in MB]:MB:' \
  '*:options:_files' && ret=0
return ret
