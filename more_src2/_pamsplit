#compdef pamsplit
# Documentation: man pamsplit (Netpbm)
# Source: split a multi-image PAM stream into separate files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-padname=[pad output number to N digits]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:input stream:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:output pattern (e.g. img%d.pam):' \
    && ret=0

return ret
