#compdef emapper.py eggnog-mapper
# _eggnog-mapper — Jaime Huerta-Cepas Carlos Pedro Cantalapiedra eggnog-mapper CLI fast functional annotation tool using EggNOG orthology database with DIAMOND HMMER MMseqs2 searches producing GO Pfam EC KEGG SMART CAZy COG BiGG TCDB BRITE OG/COG-level annotations for protein gene predictions (Jaime Huerta-Cepas team, Python); argparse
# upstream: https://github.com/eggnogdb/eggnog-mapper

_eggnog-mapper() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-i+[input fasta]:file:_files -g "*.fa *.fasta *.faa *.fna *.gz"' \
        '--input=+[file]:file:_files -g "*.fa *.fasta *.faa *.fna *.gz"' \
        '--output=+[prefix]:str:' \
        '-o+[output prefix]:str:' \
        '--output_dir=+[dir]:dir:_files -/' \
        '--data_dir=+[dir]:dir:_files -/' \
        '--itype=+[t]:t:(proteins CDS metagenome genome)' \
        '-m+[mode]:m:(diamond mmseqs hmmer no_search cache novel_fams)' \
        '--mode=+[m]:m:(diamond mmseqs hmmer no_search cache novel_fams)' \
        '--translate[translate input]' \
        '--genepred=+[g]:g:(prodigal search)' \
        '--training_genome=+[file]:file:_files' \
        '--training_file=+[file]:file:_files' \
        '--annotate_hits_table=+[file]:file:_files' \
        '--no_annot[no annotation]' \
        '--no_orthologs[no orthologs]' \
        '--no_file_comments[no file comments]' \
        '--no_search[no homology search]' \
        '--report_orthologs[report orthologs]' \
        '--cpu=+[N]:n:' \
        '--mp_start_method=+[m]:m:(fork spawn forkserver)' \
        '--decorate_gff=+[mode]:m:(no yes file]' \
        '--decorate_gff_ID_field=+[name]:str:' \
        '--excel[output xlsx file]' \
        '--block_size=+[N]:n:' \
        '--index_chunks=+[N]:n:' \
        '--evalue=+[N]:str:' \
        '--score=+[N]:str:' \
        '--pident=+[N]:str:' \
        '--query_cover=+[N]:str:' \
        '--subject_cover=+[N]:str:' \
        '--seed_ortholog_evalue=+[N]:str:' \
        '--seed_ortholog_score=+[N]:str:' \
        '--target_taxa=+[ids]:str:' \
        '--target_orthologs=+[t]:t:(one2one many2one one2many many2many all)' \
        '--target_taxon_level=+[level]:str:' \
        '--go_evidence=+[mode]:m:(experimental non-electronic all)' \
        '--tax_scope=+[scope]:str:' \
        '--temp_dir=+[dir]:dir:_files -/' \
        '*::'
}

_eggnog-mapper "$@"
