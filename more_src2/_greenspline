#compdef greenspline
# Documentation: https://docs.generic-mapping-tools.org/latest/greenspline.html
# Source: GenericMappingTools/gmt src/greenspline.c — interpolate scattered data via Green functions splines (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid/file]:file:_files -g "*.{grd,nc,xyz}"' \
    '-A+[gradient file + format]:file:_files' \
    '-C+[approximation/conditioning]:opts:_default' \
    '-E+[misfit/report file]:file:_files' \
    '-I+[increments dx[/dy[/dz]]]:inc:_default' \
    '-L+[trend control]:opts:_default' \
    '-N+[output node file]:file:_files' \
    '-Q+[gradient query azimuth or location]:opts:_default' \
    '-R+[region]:region:_default' \
    '-S+[spline type]:type:(c l p q r t)' \
    '-T+[mask grid]:file:_files -g "*.{grd,nc}"' \
    '-W[uncertainty weights]' \
    '-Z+[mode]:mode:(0 1 2 3 4 5)' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-d+[nodata↔NaN replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[segment gaps]:gap:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[record selection]:cols:_default' \
    '-r+[grid registration]:reg:(g p)' \
    '-s+[skip records with NaN]:cols:_default' \
    '-w+[wraparound]:opts:_default' \
    '-x+[parallel jobs]:n:_default' \
    '*:input table:_files' \
    && ret=0

return ret
