#compdef mfsmetarestore
# Documentation: https://manpages.debian.org/bookworm/moosefs-master/mfsmetarestore.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: tool removed since MooseFS 1.7 (use mfsmaster -a). Minimal completion only.

# mfsmetarestore: rebuild metadata from changelogs (removed in modern MooseFS)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:metadata + changelogs:_files' && ret=0
return ret
