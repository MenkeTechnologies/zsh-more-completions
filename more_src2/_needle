#compdef needle
# Documentation: https://manpages.debian.org/unstable/emboss/needle.1e.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS needle: Needleman-Wunsch global pairwise sequence alignment.

local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[first sequence to align]:sequence USA:_files' \
  '-bsequence=[second sequence(s) to align]:sequence USA:_files' \
  '-datafile=[scoring matrix]:matrix:_files' \
  '-gapopen=[gap opening penalty]:penalty:' \
  '-gapextend=[gap extension penalty]:penalty:' \
  '-endweight[weight end gaps in the score]' \
  '-endopen=[end gap opening penalty]:penalty:' \
  '-endextend=[end gap extension penalty]:penalty:' \
  '-brief[brief identity-and-similarity report]' \
  '-aformat=[alignment output format]:format:(simple srspair pair markx0 markx1 markx2 markx3 markx10 srs score)' \
  '-outfile=[alignment output file]:file:_files' \
  '-errorfile=[error file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
