#compdef guake
# _guake-bin — Guake drop-down terminal for GNOME (Aluísio A. S. G. et al, Python); F12-toggled overlay terminal
# upstream: https://github.com/Guake/guake

_guake-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --fgcolor)'{-f,--fgcolor}'+[fg color]:color:' \
        '(-b --bgcolor)'{-b,--bgcolor}'+[bg color]:color:' \
        '(-r --rename-tab)'{-r,--rename-tab}'+[rename current tab]:title:' \
        '(-R --rename-current-tab)'{-R,--rename-current-tab}'+[rename current tab]:title:' \
        '(-t --toggle-visibility)'{-t,--toggle-visibility}'[toggle visibility]' \
        '(-q --quit)'{-q,--quit}'[quit guake]' \
        '(-e --execute-command)'{-e,--execute-command}'+[command]:cmd:_command_names -e' \
        '-i+[print info]:info:' \
        '(-n --new-tab)'{-n,--n}'+[new tab with cwd]:dir:_files -/' \
        '(-s --select-tab)'{-s,--select-tab}'+[select tab]:n:' \
        '(-g --selected-tab)'{-g,--selected-tab}'[print selected tab]' \
        '(-l --list-tabs)'{-l,--list-tabs}'[list tabs]' \
        '--show[show window]' \
        '--hide[hide window]' \
        '(-p --preferences)'{-p,--preferences}'[open prefs]' \
        '(-o --tab-index)'{-o,--tab-index}'+[tab index]:n:' \
        '(-w --execute-command-in-tab)'{-w,--execute-command-in-tab}'+[run in tab]:str:' \
        '(-T --tab-fg-color)'{-T,--tab-fg-color}'+[tab fg color]:color:' \
        '--save-preferences+[save prefs file]:file:_files' \
        '--restore-preferences+[restore prefs file]:file:_files' \
        '--reset[reset prefs]' \
        '--bgimg+[bg image]:file:_files'
}

_guake-bin "$@"
