#compdef ignition ignition-validate
# Documentation: https://github.com/coreos/ignition/blob/main/internal/main.go
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# Zsh completion for ignition - CoreOS Ignition disk-provisioning utility
# Flags harvested from coreos/ignition internal/main.go (ignitionMain).

if [[ $service == ignition-validate ]]; then
  # ignition-validate reads from stdin or accepts a config file path
  _arguments -s -S \
    '*:Ignition config file:_files -g "*.ign *.json"'
  return
fi

_arguments -s -S \
  '--config-cache=[path to cache the fetched config]:file:_files' \
  '--fetch-timeout=[initial duration to wait for config]:duration:' \
  '--needNet=[flag file to write if networking is needed]:file:_files' \
  '--platform=[current platform]:platform:' \
  '--root=[root of the filesystem]:path:_directories' \
  '--stage=[execution stage]:stage:(fetch-offline fetch kargs disks mount files umount)' \
  '--state-file=[where to store internal state]:file:_files' \
  '--log-to-stdout[log to stdout instead of the system log]' \
  '(- *)--version[print the version and exit]'
