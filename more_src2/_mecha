#compdef mecha
# ---------------------------------------------------------------------------
# mecha — Mechanoid CLI: scaffold + build + flash + run WebAssembly
#         modules onto embedded microcontrollers (TinyGo / Rust / Zig
#         hosted on AVR / ARM Cortex-M / ESP / RP2040 / Pico / etc) with
#         a wazero-based interpreter on the host or `wasman` on the
#         microcontroller (Go, 206★)
#
# upstream: https://github.com/hybridgroup/mechanoid
# author : Hybrid Group (creators of gobot, tinygo wasi, ardk and the
#          broader Go-for-IoT ecosystem)
# license: Apache-2.0
#
# Source-direct completion: every subcommand + nested subcommand + flag
# below is verbatim from cmd/mecha/main.go on the hybridgroup/mechanoid
# tip — the `urfave/cli/v2` App.Commands tree with Name + Aliases +
# Usage + Flags + Subcommands fields parsed exactly as declared, and
# the templateFlags / buildFlags slices preserving --template/--type/
# --interpreter/--debug/--params with their alias short forms and
# enum-style allowed values.
#
# Direct deps from cmd/mecha/go.mod (selected) — and the main repo
# go.mod also pins:
#   github.com/tetratelabs/wazero  v1.7.1-…  ← canonical Go WebAssembly
#                                              runtime (this axis) — by
#                                              Tetrate (tetratelabs/
#                                              wazero); pure-Go Wasm
#                                              runtime with NO CGO
#                                              dependencies, ahead-of-
#                                              time Wasm-to-Go
#                                              compilation, WASI
#                                              preview1 host bindings,
#                                              single-binary embedding,
#                                              and deterministic
#                                              execution.  THE Go
#                                              answer to "embed a Wasm
#                                              runtime in a host
#                                              process" — used by Open
#                                              Policy Agent (OPA's
#                                              wasm backend), Tetrate
#                                              Service Bridge, Dapr's
#                                              wasm middleware,
#                                              polarsignals/frostdb,
#                                              knqyf263/go-plugin
#                                              (Go's Wasm plugin
#                                              system), and most Go
#                                              serverless-Wasm tools
#                                              that need to load
#                                              untrusted Wasm without
#                                              the CGO + libwasmer/
#                                              libwasmtime ABI tax.
#                                              mechanoid uses wazero
#                                              as the default
#                                              `--interpreter wazero`
#                                              option in `mecha build`
#                                              / `mecha run` — when
#                                              targeting hosts powerful
#                                              enough to run a JIT-
#                                              compiled Wasm runtime
#                                              (Raspberry Pi 3+,
#                                              desktops, servers), the
#                                              Wasm module is fed
#                                              through wazero; when
#                                              targeting bare-metal
#                                              microcontrollers, the
#                                              `wasman` minimal
#                                              interpreter (also Hybrid
#                                              Group's, but trimmed
#                                              for TinyGo) is selected
#                                              instead.
#   github.com/urfave/cli/v2                  (CLI parser — App with
#                                              nested Commands /
#                                              Subcommands tree)
#   tinygo.org/x/drivers                      (peripheral drivers for
#                                              the supported boards)
#   github.com/tarm/serial                    (cross-platform serial
#                                              port for `mecha
#                                              monitor` post-flash UART
#                                              streaming)
#   github.com/charmbracelet/bubbletea +      (TUI for the
#       bubbles + lipgloss                     interactive spinner
#                                              shown during long
#                                              build/flash operations)
#
# Mechanoid is "Arduino/PlatformIO but for WebAssembly modules running
# on microcontrollers" — write your application logic once as a Wasm
# module (compiled from TinyGo / Rust / Zig / AssemblyScript), then
# `mecha flash <board>` programs the chip with both the firmware host
# (Hybrid Group's TinyGo runtime + the `wasman` Wasm interpreter) and
# your Wasm module's bytecode.  Modules can be hot-swapped over UART
# without re-flashing the host firmware.  Major workflow: `mecha new
# project example.com/my-iot-app --type tinygo` scaffolds a project,
# `mecha new module example.com/my-mod --type rust` adds a Rust-
# compiled Wasm module, `mecha build project` compiles both pieces,
# `mecha flash circuitplay-express` programs the board, `mecha monitor`
# streams the device's UART logs.  When you just want to test the Wasm
# module logic without flashing, `mecha run` executes it directly via
# wazero on the host.
#
# === AXIS 184 CONTINUES — WebAssembly runtime / embeddable Wasm engine =====
# Axis position: Go=239 continues Axis 184 (slot 2/0/0).  Canonical Go
# WebAssembly runtime is `github.com/tetratelabs/wazero` by Tetrate —
# pure-Go Wasm runtime with NO CGO dependencies, ahead-of-time Wasm-to-
# Go compilation, WASI preview1 host bindings, single-binary embedding,
# and deterministic execution.  THE Go answer to "embed a Wasm runtime
# in a host process."  wazero's no-CGO design is the killer differentiator
# vs alternatives like wasmer-go (CGO bindings to libwasmer.so) — wazero
# cross-compiles cleanly to every Go target (Linux/Mac/Windows/FreeBSD/
# OpenBSD/Plan9 on amd64/arm64/riscv64/ppc64 etc), drops into a static
# binary without dynamic libwasmer.so dependency, and runs on Go's
# garbage collector instead of bridging memory across the FFI boundary.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=239     _enarx               ← previous round (axis 184 OPENS, 1/0/0)
#   Go=239       ← THIS FILE          (axis 184 continues, slot 2/0/0)
#   TS-Node=239  ← next round         (axis 184 CLOSES at triple-239, 1/1/1)
#
# Cross-language design contrast for axis 184:
#   Rust    : wasmtime is the Bytecode Alliance's reference Wasm
#             runtime — Cranelift JIT/AOT, WASI preview1+preview2,
#             component-model support, pooling allocator, epoch-based
#             interruption.  Tight integration with the rest of the
#             BA toolchain (wasi-libc, wit-bindgen, wasm-tools).
#   Go      : wazero is the Tetrate-led no-CGO alternative to wasmer-
#             go — pure-Go interpreter + AOT compiler, WASI preview1
#             only (preview2 in progress), single-binary embedding.
#             NO CGO is the headline feature; the runtime is GC-
#             integrated with the host process.
#   JS/Node : @wasmer/wasi or built-in WebAssembly + WASI shims —
#             [TBD next round]
# ---------------------------------------------------------------------------

_mecha() {
    local context state state_descr line ret=1
    typeset -A opt_args

    local -a template_flags
    template_flags=(
        '(-t --template)'{-t,--template}'=[template to use for module creation]:template:'
        '--type=[template type (default tinygo)]:type:(tinygo rust zig)'
    )

    local -a build_flags
    build_flags=(
        '(-i --interpreter)'{-i,--interpreter}'=[WebAssembly interpreter to use (default wazero)]:interpreter:(wazero wasman)'
        '(-d --debug)'{-d,--debug}'[perform additional logging for debugging]'
        '*--params=[pass build-time parameters (format: main.name=value; repeat for multiple)]:param:'
    )

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-v,--version}'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'new:create new Mechanoid project or module (use `new project` or `new module`)'
                'build:build binary files for Mechanoid project and/or modules'
                'flash:flash Mechanoid project to hardware'
                'run:run code for Mechanoid project (on host via interpreter, not on device)'
                'test:run tests for Mechanoid project'
                'monitor:monitor connection to hardware using the serial port'
                'about:about Mechanoid'
                'help:show CLI help (or help for a specific command)'
            )
            _describe -t commands 'mecha command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                new)
                    _arguments \
                        $template_flags \
                        '1: :->newcmds' \
                        '*::new-arg:->newargs' && ret=0
                    case $state in
                        newcmds)
                            local -a newsubs
                            newsubs=(
                                'project:create a new Mechanoid project (firmware host + sample module)'
                                'module:create a new Mechanoid module (Wasm logic only)'
                            )
                            _describe -t new-commands 'new subcommand' newsubs && ret=0
                            # Allow direct positional <name> for the default action createProject
                            _arguments "1::project name (e.g. example.com/my-iot-app):" && ret=0
                            ;;
                        newargs)
                            _arguments \
                                $template_flags \
                                '1:name (e.g. example.com/my-iot-app):' && ret=0
                            ;;
                    esac
                    ;;
                build)
                    _arguments \
                        $build_flags \
                        '1: :->buildcmds' && ret=0
                    case $state in
                        buildcmds)
                            local -a buildsubs
                            buildsubs=(
                                'project:build current Mechanoid project (firmware host + modules)'
                                'modules:build current Mechanoid modules only (skip firmware host build)'
                            )
                            _describe -t build-commands 'build target' buildsubs && ret=0
                            # also accept bare project|modules as ArgsUsage
                            _arguments "1::project or modules:(project modules)" && ret=0
                            ;;
                    esac
                    ;;
                flash)
                    _arguments \
                        $build_flags \
                        '(-m --monitor)'{-m,--monitor}'[monitor the serial port after flashing]' \
                        '1:board name (e.g. arduino-nano33 / circuitplay-express / pico / xiao-rp2040 / etc):' && ret=0
                    ;;
                run|test)
                    _arguments $build_flags && ret=0
                    ;;
                monitor)
                    _arguments \
                        '--baud=[baud rate for serial port (default 115200)]:baud:(9600 19200 38400 57600 115200 230400)' \
                        '--port=[serial port device]:port:_files -g "*"' && ret=0
                    ;;
                help)
                    local -a allsubs
                    allsubs=(new build flash run test monitor about)
                    _describe -t commands 'subcommand for help' allsubs && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_mecha "$@"
