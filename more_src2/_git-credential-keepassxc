#compdef git-credential-keepassxc
# _git-credential-keepassxc — Git credential helper backed by KeePassXC (Frederick888/git-credential-keepassxc)
# upstream: https://github.com/Frederick888/git-credential-keepassxc
# Subcommands & flags from src/cli.rs (clap).

_git-credential-keepassxc() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[JSON config file]:file:_files -g "*.json"' \
        '(-s --socket)'{-s+,--socket=}'[KeePassXC browser socket]:file:_files' \
        '--unlock=[try unlocking DB (RETRIES[,INTERVAL_MS])]:spec:' \
        '*--group=[groups to filter credentials by]:group:' \
        '--git-groups[use the dedicated git group]' \
        '--no-filter[do not filter on KPH: git advanced field]' \
        '*-v[increase verbosity (-v warn, -vv info, -vvv debug)]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'get:get credential (used by git)'
                'totp:get TOTP'
                'store:store credential'
                'erase:erase credential'
                'lock:lock the database'
                'groups:list groups'
                'generate-password:generate a password'
                'configure:initial setup'
                'caller:manage authorized callers'
                'edit:edit a stored credential'
                'encrypt:encrypt a value'
                'decrypt:decrypt a value'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                get|totp)
                    _arguments \
                        '--totp[try also fetching TOTP]' \
                        '*--group=[groups]:group:' \
                        '--git-groups[use git groups]' \
                        '--no-filter[do not filter KPH: git]' \
                        '--advanced-fields[print advanced fields]' \
                        '--json[print JSON]' \
                        '--raw[raw KeePassXC output]'
                    ;;
            esac
            ;;
    esac
}

_git-credential-keepassxc "$@"
