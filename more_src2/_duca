#compdef duca
# Documentation: https://github.com/thomaspmurphy/duca
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# thomaspmurphy/duca — terminal reader for Dante's Divina Commedia

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _duca_cmds
    _duca_cmds=(
      'parse:process source text files (dev setup only)'
      'search:fuzzy search across the work'
      'canto:display a specific canto'
      'tui:interactive terminal UI with fuzzy search'
    )
    _describe -t commands 'duca command' _duca_cmds && ret=0
    ;;
  (args)
    case $line[1] in
      (search)
        _arguments \
          '(-c --cantica)'{-c,--cantica=}'[limit to a cantica]:cantica:(inferno purgatorio paradiso)' \
          '*:search term:' && ret=0 ;;
      (canto)
        _arguments \
          ':cantica:(inferno purgatorio paradiso)' \
          ':canto number:' && ret=0 ;;
    esac ;;
esac

return ret
