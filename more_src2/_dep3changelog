#compdef dep3changelog
# Documentation: https://manpages.debian.org/dep3changelog
# Source: debian/devscripts scripts/dep3changelog.pl — generate debian/changelog from DEP-3 patches (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    '*:DEP-3 patch file(s) -- dch options:_files -g "*.{patch,diff}"' \
    && ret=0

return ret
