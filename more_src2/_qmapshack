#compdef qmapshack
# Documentation: https://manpages.debian.org/bookworm/qmapshack/qmapshack.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm qmapshack(1) manpage.
# Removed from prior file: fabricated -V/--version (real is none -
# qmapshack has only -d/-h/-n) and bogus man.archlinux.org search URL.

# qmapshack: Qt GPS route planner for various map formats
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-d --debug)'{-d,--debug}'[run with debug output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-n --no-splash)'{-n,--no-splash}'[start without splash screen]' \
  '*:GPX/map file:_files -g "*.(gpx|qms|kml|fit|tcx)(-.)"' && ret=0
return ret
