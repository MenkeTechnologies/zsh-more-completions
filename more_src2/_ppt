#compdef ppt
# Documentation: man ppt(6)
# Source: openbsd/src games/ppt/ppt.c — display paper-tape encoding (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show usage]' \
    '-d[decode mode (read tape, write text)]' \
    '-b[binary output (only with -d)]' \
    '*:text:_default' \
    && ret=0

return ret
