#compdef promtool2
# _promtool2 — Prometheus promtool2 CLI command-line frontend wrapping the Prometheus promtool utility for validating querying analyzing debugging Prometheus rule files config files PromQL queries TSDB blocks WAL Prometheus-server interaction snapshot list-blocks dump series-cardinality-analysis chunks meta benchmarks test (Prometheus CNCF team, Go); kingpin
# upstream: https://prometheus.io/docs/prometheus/latest/command-line/promtool/

_promtool2() {
    local -a sub=(
        'check:check resources'
        'query:run queries'
        'debug:debug Prometheus'
        'push:push data'
        'test:run tests'
        'tsdb:TSDB operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--http.config.file=+[file]:file:_files -g "*.yml *.yaml"' \
        '--enable-feature=+[name]:str:' \
        '--log.level=+[level]:l:(debug info warn error)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'promtool subcommand' sub ;;
        args)
            case $words[1] in
                check) _arguments '1:type:(config rules metrics service-discovery web-config healthy ready)' '*:file:_files -g "*.yml *.yaml"' ;;
                query) _arguments '1:type:(instant range series labels analyze)' '2:server url:' '3:expr:' ;;
                debug) _arguments '1:type:(pprof metrics all)' '2:server url:' ;;
                push) _arguments '1:type:(metrics)' '*:arg:' ;;
                test) _arguments '1:type:(rules)' '*:file:_files -g "*.yml *.yaml"' ;;
                tsdb) _arguments '1:op:(bench dump dump-openmetrics list analyze create-blocks-from)' '*:arg:' ;;
            esac
            ;;
    esac
}

_promtool2 "$@"
