#compdef keyscope
# Documentation: https://github.com/spectralops/keyscope
# Reference accessed: 2026-05-19
# Verified: against the upstream README usage examples. Corrected from
# prior file: removed fabricated `providers` subcommand (provider
# listing is `validate --list`), --no-banner, -d/--dry-run, -r/--reporter
# enum, and -c/--config (the real definitions-file flag is -f). Added
# real --list, --csv-in, -p, -f.

local curcontext="$curcontext" state line ret=1
local -a subcmds
subcmds=(
  'validate:validate API keys/secrets for a provider'
  'requirements:show required params for a provider'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--verbose[show API responses and detailed output]' \
  '--flip[invert success/failure logic]' \
  '-f+[custom definitions file]:file:_files -g "*.(yaml|yml)"' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  (cmd) _describe -t subcmds 'keyscope command' subcmds && ret=0 ;;
  (args)
    case $line[1] in
      (validate)
        _arguments -s -S \
          '--list[list all available providers and validation types]' \
          '--csv-in[read credentials from a CSV file]:file:_files -g "*.csv"' \
          '--flip[invert success/failure logic]' \
          '*-p+[provider-specific parameter]:param:' \
          '1:provider:' \
          '*:key:' && ret=0
        ;;
      (requirements)
        _arguments '1:provider:' && ret=0
        ;;
    esac
    ;;
esac

return ret
