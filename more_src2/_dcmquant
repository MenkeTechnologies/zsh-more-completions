#compdef dcmquant
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmquant.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmimage/apps/dcmquant.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmimage/apps/dcmquant.cc OFCommandLine setup + docs/man/dcmquant.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(+fr --frame)'{+fr+,--frame=}'[select specified frame]:n:' \
  '(+fa --all-frames)'{+fa,--all-frames}'[select all frames (default)]' \
  '(+cp --conv-photometric)'{+cp,--conv-photometric}'[convert if YCbCr photometric interpretation (default)]' \
  '(+cl --conv-lossy)'{+cl,--conv-lossy}'[convert YCbCr to RGB if lossy JPEG]' \
  '(+cg --conv-guess)'{+cg,--conv-guess}'[convert to RGB if YCbCr is guessed by library]' \
  '(+cgl --conv-guess-lossy)'{+cgl,--conv-guess-lossy}'[convert to RGB if lossy JPEG and YCbCr is guessed]' \
  '(+ca --conv-always)'{+ca,--conv-always}'[always convert YCbCr to RGB]' \
  '(+cn --conv-never)'{+cn,--conv-never}'[never convert color space]' \
  '(+Mp --accept-palettes)'{+Mp,--accept-palettes}'[accept incorrect palette attribute tags]' \
  '(+Dr --mc-dimension-rgb)'{+Dr,--mc-dimension-rgb}'[max dimension from RGB range (default)]' \
  '(+Dl --mc-dimension-lum)'{+Dl,--mc-dimension-lum}'[max dimension from luminance]' \
  '(+Cb --mc-color-avgbox)'{+Cb,--mc-color-avgbox}'[average colors in box (default)]' \
  '(+Cp --mc-color-avgpixel)'{+Cp,--mc-color-avgpixel}'[average pixels in box]' \
  '(+Cc --mc-color-center)'{+Cc,--mc-color-center}'[select center of box]' \
  '(+pw --write-ow)'{+pw,--write-ow}'[write Palette LUT as OW (default)]' \
  '(+pu --write-us)'{+pu,--write-us}'[write Palette LUT as US (retired)]' \
  '(+pe --lut-entries-word)'{+pe,--lut-entries-word}'[write Palette LUT with 16-bit entries]' \
  '(+pf --floyd-steinberg)'{+pf,--floyd-steinberg}'[use Floyd-Steinberg error diffusion]' \
  '(+pc --colors)'{+pc+,--colors=}'[quantize to 2..65536 colors (default 256)]:colors:' \
  '(+cd --class-default)'{+cd,--class-default}'[keep SOP Class UID (default)]' \
  '(+cs --class-sc)'{+cs,--class-sc}'[convert to Secondary Capture Image (implies --uid-always)]' \
  '(+ua --uid-always)'{+ua,--uid-always}'[always assign new UID (default)]' \
  '(+un --uid-never)'{+un,--uid-never}'[never assign new UID]' \
  '(+F --write-file)'{+F,--write-file}'[write file format (default)]' \
  '(-F --write-dataset)'{-F,--write-dataset}'[write data set without file meta information]' \
  '(+t= --write-xfer-same)'{+t=,--write-xfer-same}'[write with same TS as input (default)]' \
  '(+te --write-xfer-little)'{+te,--write-xfer-little}'[write with explicit VR little endian TS]' \
  '(+tb --write-xfer-big)'{+tb,--write-xfer-big}'[write with explicit VR big endian TS]' \
  '(+ti --write-xfer-implicit)'{+ti,--write-xfer-implicit}'[write with implicit VR little endian TS]' \
  '(+u --enable-new-vr)'{+u,--enable-new-vr}'[enable support for new VRs (UN/UT) (default)]' \
  '(-u --disable-new-vr)'{-u,--disable-new-vr}'[disable support for new VRs, convert to OB]' \
  '(+g= --group-length-recalc)'{+g=,--group-length-recalc}'[recalculate group lengths if present (default)]' \
  '(+g --group-length-create)'{+g,--group-length-create}'[always write with group length elements]' \
  '(-g --group-length-remove)'{-g,--group-length-remove}'[always write without group length elements]' \
  '(+e --length-explicit)'{+e,--length-explicit}'[write with explicit lengths (default)]' \
  '(-e --length-undefined)'{-e,--length-undefined}'[write with undefined lengths]' \
  '(-p= --padding-retain)'{-p=,--padding-retain}'[do not change padding (default)]' \
  '(-p --padding-off)'{-p,--padding-off}'[no padding (implicit if --write-dataset)]' \
  '(+p --padding-create)'{+p+,--padding-create=}'[align file and items on specified byte multiples]:file-pad item-pad:' \
  '1:dcmfile-in:_files' \
  '2:dcmfile-out:_files'
