  '(-p --port)'{-p,--port}'=[connection port (default: 22)]:port:' \
  '(-i --identify)'{-i,--identify}'=[specify a username to connect with]:username:_users' \
  '(-k --key)'{-k,--key}'=[which ssh key to use]:key file:_files' \
  '(-l --list)'{-l,--list}'[list all nodes]' \
  '(-a --add)'{-a,--add}'[add a new node]' \
  '(-d --delete)'{-d,--delete}'[delete a node]' \
  '(-u --update)'{-u,--update}'[update a node]' \
  '(-f --apply)'{-f,--apply}'=[apply a new config file]:config file:_files' \
  '(-s --default)'{-s,--default}'[set a node as default]' \
  '1:node (given host name):_hosts' \
  '2:dest (destination of the host):'
