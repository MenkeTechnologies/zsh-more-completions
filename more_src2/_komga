#compdef komga
# _komga — Gauthier Roebroeck Komga free open-source self-hosted comic/manga/BD media server with OPDS and webreader (gotson team, Kotlin); spring-boot
# upstream: https://github.com/gotson/komga

_komga() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--spring.config.location=+[config file]:file:_files -g "*.yml *.yaml *.properties"' \
        '--spring.config.additional-location=+[config file]:file:_files' \
        '--server.port=+[http port]:port:_ports' \
        '--server.address=+[bind address]:host:_hosts' \
        '--server.servlet.context-path=+[base path]:str:' \
        '--server.ssl.enabled=+[bool]:b:(true false)' \
        '--server.ssl.key-store=+[keystore]:file:_files' \
        '--server.ssl.key-store-password=+[keystore password]:str:' \
        '--komga.config-dir=+[config dir]:dir:_files -/' \
        '--komga.libraries-scan-cron=+[cron]:str:' \
        '--komga.libraries-scan-startup=+[bool]:b:(true false)' \
        '--komga.delete-empty-collections=+[bool]:b:(true false)' \
        '--komga.delete-empty-read-lists=+[bool]:b:(true false)' \
        '--komga.remember-me.key=+[key]:str:' \
        '--komga.remember-me.validity=+[seconds]:n:' \
        '--komga.session-timeout=+[seconds]:n:' \
        '--komga.cors.allowed-origins=+[origins]:str:' \
        '--komga.kobo.proxy=+[bool]:b:(true false)' \
        '--komga.epub.divina=+[bool]:b:(true false)' \
        '--komga.oauth2-account-creation=+[bool]:b:(true false)' \
        '--logging.level.root=+[level]:l:(TRACE DEBUG INFO WARN ERROR OFF)' \
        '--logging.level.org.gotson.komga=+[level]:l:(TRACE DEBUG INFO WARN ERROR OFF)' \
        '--logging.file.name=+[file]:file:_files' \
        '--logging.file.path=+[dir]:dir:_files -/' \
        '--debug[debug mode]' \
        '--trace[trace mode]'
}

_komga "$@"
