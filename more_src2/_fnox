#compdef fnox
# Documentation: https://github.com/jdx/fnox
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fnox: secret manager — top-level subcommands from src/commands/mod.rs

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
  '(-P --profile)'{-P+,--profile=}'[profile name]:profile:' \
  '(-v --verbose)'{-v,--verbose}'[verbose logs]' \
  '--if-missing=[missing secret policy]:policy:(error warn ignore)' \
  '--no-color[disable color]' \
  '--no-defaults[do not merge default secrets into profile]' \
  '--age-key-file=[age key file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a _fnox_cmds
    _fnox_cmds=(
      activate check 'ci-redact' completion 'config-files' deactivate doctor edit exec export get 'hook-env' import init lease list mcp profiles provider reencrypt remove scan schema set sync tui usage version
    )
    _describe -t commands 'fnox subcommand' _fnox_cmds && ret=0
    ;;
esac

return ret
