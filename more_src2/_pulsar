#compdef pulsar-client pulsar-admin pulsar-perf
# Documentation: https://pulsar.apache.org/reference/3.3.x/
# Reference accessed: 2026-05-20
# Verified: upstream Apache Pulsar 3.3.x CLI reference.

# Zsh completion dispatcher for Apache Pulsar CLI tools

_pulsar() {
  local curcontext="$curcontext" state line ret=1
  local prog=${words[1]:t}

  case $prog in
    pulsar-client)
      local -a commands=(
        'produce:produce messages to a topic'
        'consume:consume messages from a topic'
      )
      _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[print version]' \
        '--url=[Pulsar service URL]:URL:' \
        '--auth-plugin=[authentication plugin class]:class:' \
        '--auth-params=[authentication parameters]:params:' \
        '--listener-name=[listener name]:name:' \
        '--tls-allow-insecure[allow insecure TLS connection]' \
        '--tls-enable-hostname-verification[enable TLS hostname verification]' \
        '--tls-trust-cert-path=[TLS trust certificate path]:path:_files' \
        '1:command:->command' \
        '*:: :->args' \
        && ret=0

      case $state in
        (command)
          _describe -t commands 'pulsar-client command' commands && ret=0
          ;;
        (args)
          case ${words[1]} in
            produce)
              _arguments -s -S \
                '(-m --messages)'{-m+,--messages=}'[messages to produce]:message:' \
                '(-f --files)'{-f+,--files=}'[file with messages]:file:_files' \
                '(-n --num-produce)'{-n+,--num-produce=}'[number of messages]:count:' \
                '(-r --rate)'{-r+,--rate=}'[rate of messages per second]:rate:' \
                '(-s --separator)'{-s+,--separator=}'[message separator]:separator:' \
                '(-k --key)'{-k+,--key=}'[message key]:key:' \
                '(-p --properties)'{-p+,--properties=}'[message properties]:properties:' \
                '(-vs --value-schema)'{-vs+,--value-schema=}'[value schema]:schema:' \
                '(-ks --key-schema)'{-ks+,--key-schema=}'[key schema]:schema:' \
                '(-kvk --key-value-key)'{-kvk+,--key-value-key=}'[KeyValue schema key]:key:' \
                '(-kvkf --key-value-key-file)'{-kvkf+,--key-value-key-file=}'[KeyValue schema key file]:file:_files' \
                '(-kvet --key-value-encoding-type)'{-kvet+,--key-value-encoding-type=}'[KeyValue encoding type]:type:' \
                '(-ekn --encryption-key-name)'{-ekn+,--encryption-key-name=}'[encryption key name]:name:' \
                '(-ekv --encryption-key-value)'{-ekv+,--encryption-key-value=}'[encryption key value]:value:' \
                '(-dr --disable-replication)'{-dr,--disable-replication}'[disable replication]' \
                '(-db --disable-batching)'{-db,--disable-batching}'[disable batching]' \
                '(-c --chunking)'{-c,--chunking}'[enable chunking]' \
                '1:topic:' \
                && ret=0
              ;;
            consume)
              _arguments -s -S \
                '(-s --subscription-name)'{-s+,--subscription-name=}'[subscription name]:subscription:' \
                '(-t --subscription-type)'{-t+,--subscription-type=}'[subscription type]:type:(Exclusive Shared Failover Key_Shared)' \
                '(-m --subscription-mode)'{-m+,--subscription-mode=}'[subscription mode]:mode:(Durable NonDurable)' \
                '(-p --subscription-position)'{-p+,--subscription-position=}'[subscription position]:position:(Latest Earliest)' \
                '(-n --num-messages)'{-n+,--num-messages=}'[number of messages to consume]:count:' \
                '(-r --rate)'{-r+,--rate=}'[rate of messages per second]:rate:' \
                '--hex[display message payload in hex]' \
                '--hide-content[do not display message content]' \
                '(-q --queue-size)'{-q+,--queue-size=}'[receiver queue size]:size:' \
                '(-mc --max_chunked_msg)'{-mc+,--max_chunked_msg=}'[max pending chunked messages]:n:' \
                '(-ac --auto_ack_chunk_q_full)'{-ac,--auto_ack_chunk_q_full}'[auto ack when chunk queue full]' \
                '(-st --schema-type)'{-st+,--schema-type=}'[schema type]:type:' \
                '(-pm --pool-messages)'{-pm,--pool-messages}'[pool messages]' \
                '(-rs --replicated)'{-rs,--replicated}'[replicated]' \
                '(-ekv --encryption-key-value)'{-ekv+,--encryption-key-value=}'[encryption key value]:value:' \
                '1:topic:' \
                && ret=0
              ;;
          esac
          ;;
      esac
      ;;
    pulsar-admin)
      local -a commands=(
        'brokers:manage brokers'
        'broker-stats:get broker stats'
        'bookies:manage bookies'
        'clusters:manage clusters'
        'functions:manage Pulsar Functions'
        'functions-worker:manage functions worker'
        'namespaces:manage namespaces'
        'ns-isolation-policy:manage namespace isolation policies'
        'packages:manage packages'
        'persistent:manage persistent topics'
        'non-persistent:manage non-persistent topics'
        'proxy-stats:get proxy stats'
        'schemas:manage schemas'
        'sinks:manage Pulsar IO sinks'
        'sources:manage Pulsar IO sources'
        'tenants:manage tenants'
        'topics:manage topics'
        'topicPolicies:manage topic policies'
        'resourcegroups:manage resource groups'
        'resource-quotas:manage resource quotas'
        'transactions:manage transactions'
      )
      _arguments -s -S \
        '(-h --help)'{-h,--help}'[show help]' \
        '--admin-url=[admin service URL]:URL:' \
        '--auth-plugin=[authentication plugin class]:class:' \
        '--auth-params=[authentication parameters]:params:' \
        '--tls-allow-insecure[allow insecure TLS connection]' \
        '--tls-trust-cert-path=[TLS trust certificate path]:path:_files' \
        '1:command:->command' \
        '*:: :->args' \
        && ret=0

      case $state in
        (command)
          _describe -t commands 'pulsar-admin command' commands && ret=0
          ;;
      esac
      ;;
    *)
      _arguments -s -S '*:' && ret=0
      ;;
  esac

  return ret
}

_pulsar "$@"
