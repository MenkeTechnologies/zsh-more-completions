#compdef fcitx5-configtool
# Documentation: https://github.com/fcitx/fcitx5-configtool/blob/master/src/configtool/main.cpp
# Reference accessed: 2026-05-16
# Verified: src/configtool/main.cpp uses only QCommandLineParser standard
# options (addHelpOption + addVersionOption). No custom flags registered.

# fcitx5 config tool (Qt frontend)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show help with Qt-specific options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' && ret=0
return ret
