#compdef operator-courier
# Documentation: https://github.com/operator-framework/operator-courier
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (operatorcourier/cli.py argparse).

# operator-courier: legacy Operator Framework upload/validation tool (deprecated)
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'verify:verify an operator bundle'
  'flatten:flatten an operator bundle directory'
  'push:push an operator bundle to App Registry (quay.io)'
  'nest:nest an operator bundle directory by version'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbose[enable verbose logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'operator-courier command' commands && ret=0 ;;
  args)
    case $line[1] in
      verify)
        _arguments \
          '--validation-output=[file to write validation warnings/errors as JSON]:file:_files' \
          '--ui_validate_io[validate bundle for operatorhub.io UI display]' \
          '1:source dir:_directories' && ret=0
        ;;
      push)
        _arguments \
          '--validation-output=[file to write validation warnings/errors as JSON]:file:_files' \
          '1:source dir:_directories' \
          '2:namespace:' \
          '3:repository:' \
          '4:release:' \
          '5:token:' && ret=0
        ;;
      nest)
        _arguments \
          '1:source dir:_directories' \
          '2:registry dir:_directories' && ret=0
        ;;
      flatten)
        _arguments \
          '1:source dir:_directories' \
          '2:dest dir:_directories' && ret=0
        ;;
    esac
    ;;
esac
return ret
