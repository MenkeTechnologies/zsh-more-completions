#compdef kestra-cli kestra2
# _kestra-cli — Kestra kestra-cli CLI command-line frontend wrapping the Kestra open-source orchestration scheduling YAML-driven workflow platform Java alternative to Airflow Prefect Dagster Argo Workflows managing flows templates triggers executions logs metrics tasks namespaces plugins worker scheduler executor REST API (Kestra team, Java); custom argparse
# upstream: https://kestra.io/

_kestra-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'flow:flow operations'
        'template:template operations'
        'trigger:trigger operations'
        'execution:execution operations'
        'log:log operations'
        'metric:metric operations'
        'task:task operations'
        'namespace:namespace operations'
        'plugin:plugin operations'
        'restore:restore operations'
        'sys:system operations'
        'server:run server'
        'worker:run worker'
        'scheduler:run scheduler'
        'executor:run executor'
        'standalone:run standalone'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[url]:str:' \
        '--user=+[user]:str:' \
        '--password=+[password]:str:' \
        '--token=+[token]:str:' \
        '--tenant=+[name]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.json *.properties"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.json *.properties"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kestra-cli subcommand' sub ;;
        args)
            case $words[1] in
                flow|template|trigger|execution|log|metric|task|namespace|plugin) _arguments '1:op:(list get create update delete validate dispatch run pause resume kill restart export import)' '*:id:' ;;
                server|worker|scheduler|executor|standalone) _arguments \
                    '--port=+[port]:n:' \
                    '--bind-host=+[host]:_hosts' ;;
            esac
            ;;
    esac
}

_kestra-cli "$@"
