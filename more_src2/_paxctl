#compdef paxctl
# Documentation: man paxctl(8)
# Source: netbsd/src usr.sbin/paxctl — list/modify PaX flags of ELF binaries (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-0[clear all PaX flags and reserved bits]' \
    '+a[explicitly disable PaX ASLR]' \
    '-a[unset the ASLR disable flag]' \
    '+A[explicitly enable PaX ASLR]' \
    '-A[unset the ASLR enable flag]' \
    '+g[explicitly disable PaX Segvguard]' \
    '-g[unset the Segvguard disable flag]' \
    '+G[explicitly enable PaX Segvguard]' \
    '-G[unset the Segvguard enable flag]' \
    '+m[explicitly disable PaX MPROTECT]' \
    '-m[unset the MPROTECT disable flag]' \
    '+M[explicitly enable PaX MPROTECT]' \
    '-M[unset the MPROTECT enable flag]' \
    '*:ELF program:_files' \
    && ret=0

return ret
