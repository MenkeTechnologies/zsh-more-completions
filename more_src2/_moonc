#compdef moonc
# Documentation: https://moonscript.org/reference/command_line.html
# Reference accessed: 2026-05-19
# Verified: upstream MoonScript command-line reference. Long-form variants
# are not documented upstream — only short flags are listed below.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-t+[target directory for compiled files]:directory:_directories' \
  '-p[print compiled Lua to stdout]' \
  '-l[perform lint checks instead of compiling]' \
  '-w[watch for file changes and recompile]' \
  '-h[show help]' \
  '--help[show help]' \
  '*:moonscript file:_files -g "*.moon"' && ret=0

return ret
