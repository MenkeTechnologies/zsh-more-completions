#compdef dbus-launch
# Documentation: https://manpages.debian.org/dbus-launch
# Source: freedesktop/dbus tools/dbus-launch.c — start D-Bus session bus (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--auto-syntax --binary-syntax --csh-syntax --sh-syntax)--auto-syntax[detect shell syntax]' \
    '(--auto-syntax --csh-syntax --sh-syntax)--binary-syntax[binary output]' \
    '(--auto-syntax --binary-syntax --sh-syntax)--csh-syntax[C-shell variables syntax]' \
    '(--auto-syntax --binary-syntax --csh-syntax)--sh-syntax[Bourne-shell variables syntax]' \
    '--close-stderr[close stderr in started bus]' \
    '--config-file=-[bus daemon config file]:file:_files -g "*.conf"' \
    '--exit-with-session[kill bus when session ends]' \
    '--exit-with-x11[kill bus when X11 session ends]' \
    '--autolaunch=-[autolaunch the bus for X display]:machine-id:_default' \
    '*::program and args:_command_names -e' \
    && ret=0

return ret
