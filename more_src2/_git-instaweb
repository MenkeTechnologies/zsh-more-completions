#compdef git-instaweb
# Documentation: https://git-scm.com/docs/git-instaweb
# Source: git/git git-instaweb.sh — instantly browse the working repository in gitweb (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    {-l,--local}'[only bind on 127.0.0.1]' \
    {-p+,--port=}'[port to bind to]:port:_default' \
    {-d+,--httpd=}'[the command to launch]:command:_command_names' \
    {-b+,--browser=}'[browser to launch]:browser:_command_names' \
    {-m+,--module-path=}'[module path (apache2 only)]:path:_files -/' \
    '--stop[stop the web server]' \
    '--start[start the web server]' \
    '--restart[restart the web server]' \
    '1::action:(start stop restart)' \
    && ret=0

return ret
