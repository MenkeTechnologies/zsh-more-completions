#compdef otbcli_RadiometricIndices
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_RadiometricIndices.html
# Source: orfeotoolbox/OTB RadiometricIndices — compute NDVI, EVI, SAVI, NDWI, etc.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input multispectral image]:image:_files' \
    '-out+[output indices image]:image:_files' \
    '-list+[indices to compute (space-sep)]:indices:_default' \
    '-channels.blue+[blue channel index (default 1)]:n:_default' \
    '-channels.green+[green channel index (default 1)]:n:_default' \
    '-channels.red+[red channel index (default 1)]:n:_default' \
    '-channels.nir+[NIR channel index (default 1)]:n:_default' \
    '-channels.mir+[MIR channel index (default 1)]:n:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
