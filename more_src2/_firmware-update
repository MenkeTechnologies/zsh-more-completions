#compdef firmware-update
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# firmware-update: thin wrapper around fwupdmgr update
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-y[answer yes]' \
  '--assume-yes[answer yes]' \
  '--no-reboot-check[do not prompt for reboot]' \
  '--allow-older[allow downgrade]' \
  '--allow-reinstall[allow reinstall]' \
  '--json[JSON output]' \
  '*::firmware-update args:_files' && ret=0
return ret
