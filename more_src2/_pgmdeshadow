#compdef pgmdeshadow
# Documentation: man pgmdeshadow (Netpbm)
# Source: remove background shading from a PGM image (e.g. scanned page).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
