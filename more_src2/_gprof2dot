#compdef gprof2dot
# Documentation: https://github.com/jrfonseca/gprof2dot
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-n --node-thres)'{-n+,--node-thres=}'[node threshold percent]:pct:' \
  '(-e --edge-thres)'{-e+,--edge-thres=}'[edge threshold percent]:pct:' \
  '(-f --format)'{-f+,--format=}'[input format]:format:(axe callgrind collapse dtrace hprof json perf prof pstats sleepy sysprof xperf)' \
  '(-c --colormap)'{-c+,--colormap=}'[colormap]:colormap:(bw color gray pink print)' \
  '(-s --strip)'{-s,--strip}'[strip function param info]' \
  '(-w --wrap)'{-w,--wrap}'[wrap function names]' \
  '(-z --root)'{-z+,--root=}'[root function]:func:' \
  '(-l --leaf)'{-l+,--leaf=}'[leaf function]:func:' \
  '--node-label=[node label fields]:measure:(self-time self-time-percentage total-time total-time-percentage)' \
  '--list-functions=[list matching functions]:pattern:' \
  '--depth=[max depth]:n:' \
  '--skew=[colorization skew]:val:' \
  '--total=[totals method]:method:(callratios callstacks)' \
  '--color-nodes-by-selftime[color nodes by self time]' \
  '--show-samples[display function samples]' \
  '*:file:_files' && ret=0

return ret
