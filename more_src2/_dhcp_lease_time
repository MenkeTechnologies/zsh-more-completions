#compdef dhcp_lease_time
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/dhcp_lease_time.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcp_lease_time: report DHCP lease time for an IP (dnsmasq helper)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:IPv4 address:' && ret=0
return ret
