#compdef debtap
# debtap — convert .deb packages to Arch Linux packages

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-u[update debtap database]' \
  '-q[bypass all questions, use defaults]' \
  '-Q[bypass editing of metadata files]' \
  '-s[bypass editing of install scripts]' \
  '-p[set package name]:name:' \
  '-P[edit PKGBUILD after generation]' \
  '*:deb file:_files -g "*.deb"' \
  && ret=0

return ret
