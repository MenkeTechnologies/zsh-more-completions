#compdef newlisp-cli newlisp2
# _newlisp-cli — Lutz Mueller newLISP newlisp-cli CLI command-line frontend wrapping the newLISP open-source scripting language for general-purpose applications written in C originally Lutz Mueller 1991 fast small powerful Lisp-like scripting language with built-in support for many common application areas suitable for systems administration network and Internet programming web programming networking AI fuzzy logic financial math statistics syntax stripped down compared to traditional Lisp dynamic functional programming fexpr-based-eval Lisp1-namespace lambda function CILK-like concurrency contexts pseudo-OO eval-string load eval-string -e -c -h -m -p -d -w -s -x -n -o -P -L -e -B -s --new-window --xml-callback --term-mode --maxmem --maxsymbols (Lutz Mueller newLISP team, C); custom argparse
# upstream: http://www.newlisp.org/

_newlisp-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[show version]' \
        '-c[silent server]' \
        '-C[silent client]' \
        '-d+[port]:n:' \
        '-e+[expression]:str:' \
        '*-e+[expression]:str:' \
        '-w+[dir]:dir:_files -/' \
        '-i+[image]:file:_files -g "*.lsp *.nl"' \
        '-l+[log]:file:_files' \
        '-L+[log all]:file:_files' \
        '-m+[maxmem]:n:' \
        '-n[no-init]' \
        '-o+[output]:file:_files' \
        '-p+[port]:n:' \
        '-P+[port]:n:' \
        '-s+[stack size]:n:' \
        '-x+[script extension]:str:' \
        '-T+[connect timeout]:n:' \
        '--no-readline[no readline]' \
        '--no-utf8[no UTF-8]' \
        '--no-debug[no debug]' \
        '--no-cilk[no CILK]' \
        '--no-spawn[no spawn]' \
        '--no-net-utils[no net utils]' \
        '--no-vendor[no vendor]' \
        '--no-license[no license]' \
        '--no-symbol-bind[no symbol bind]' \
        '--no-banner[no banner]' \
        '--use-spawn[use spawn]' \
        '--xml-callback=+[fn]:str:' \
        '--term-mode[terminal mode]' \
        '--maxmem=+[N]:n:' \
        '--maxsymbols=+[N]:n:' \
        '--maxstack=+[N]:n:' \
        '--maxcells=+[N]:n:' \
        '-D+[debug item]:str:' \
        '-Q[quiet error]' \
        '-B[no banner]' \
        '*:lisp file:_files -g "*.lsp *.nl *.newlisp"'
}

_newlisp-cli "$@"
