#compdef pngtopam
# Documentation: man pngtopam (Netpbm)
# Source: convert a PNG image into a Netpbm (PBM/PGM/PPM/PAM) image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[display PNG image and conversion info]' \
    '(-alphapam -alpha -mix)-alphapam[produce PAM file with alpha]' \
    '(-alphapam -alpha -mix)-alpha[produce alpha (transparency) channel only]' \
    '(-alphapam -alpha -mix)-mix[mix alpha with background color]' \
    '-background=[background color]:color:' \
    '-gamma=[output display gamma value]:value:' \
    '-text=[write tEXt chunks to file]:file:_files' \
    '-time[show last-modification time]' \
    '-byrow[process input row by row]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:png file:_files -g "*.png"' \
    && ret=0

return ret
