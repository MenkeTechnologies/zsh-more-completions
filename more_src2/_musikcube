#compdef musikcube musikcubed
# Documentation: https://github.com/clangen/musikcube/blob/master/src/musikcubed/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream src/musikcube/Main.cpp (no argv parsing) and
# src/musikcubed/main.cpp handleCommandLine() switch.

local curcontext="$curcontext" state line ret=1

case $service in
  musikcube)
    # musikcube TUI does not parse any command-line arguments.
    _message 'musikcube takes no command-line arguments'
    ret=0
    ;;
  musikcubed)
    _arguments -s -S \
      '(- *)--help[show help]' \
      '(- *)--version[print version]' \
      '(- *)--start[start the daemon]' \
      '(- *)--foreground[start the daemon in the foreground]' \
      '(- *)--stop[shut down the daemon]' \
      '(- *)--running[check if the daemon is running]' && ret=0
    ;;
esac

return ret
