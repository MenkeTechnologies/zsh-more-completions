#compdef gif2tiff
# Documentation: http://www.libtiff.org/tools.html
# Source: libtiff tools/gif2tiff.c — convert GIF file to TIFF (C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r+[rows per strip]:rows:_default' \
    '-c+[output compression]:comp:(lzw zip packbits none)' \
    '1:input.gif:_files -g "*.{gif,GIF}"' \
    '2:output.tif:_files' \
    && ret=0

return ret
