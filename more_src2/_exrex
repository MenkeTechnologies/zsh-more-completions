#compdef exrex
# Documentation: https://github.com/asciimoo/exrex
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# exrex: generate strings matching a regex.

_arguments -s -S \
  '(-c --count)'{-c,--count}'[print number of matching strings]' \
  '(-m --max-number)'{-m+,--max-number=}'[max number of strings to generate]:count:' \
  '(-l --limit)'{-l+,--limit=}'[max range limit for repetitions]:limit:' \
  '(-d --delimiter)'{-d+,--delimiter=}'[output delimiter]:delimiter:' \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-r --random)'{-r,--random}'[generate one random matching string]' \
  '(-s --simplify)'{-s,--simplify}'[simplify the regex]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:regex pattern:'
