#compdef pinentry-curses pinentry-tty pinentry-mac pinentry-gtk-2 pinentry-qt pinentry-gnome3 pinentry
# Documentation: pinentry-curses --help (GnuPG pinentry 1.3.x)
# Source: secure passphrase prompt used by gpg-agent.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-d --debug)'{-d,--debug}'[debug output]' \
    '(-D --display)'{-D+,--display=}'[X display]:display:' \
    '(-T --ttyname)'{-T+,--ttyname=}'[tty device node name]:file:_files -g "/dev/tty*"' \
    '(-N --ttytype)'{-N+,--ttytype=}'[tty terminal type]:name:_terminals' \
    '(-C --lc-ctype)'{-C+,--lc-ctype=}'[tty LC_CTYPE]:locale:' \
    '(-M --lc-messages)'{-M+,--lc-messages=}'[tty LC_MESSAGES]:locale:' \
    '(-o --timeout)'{-o+,--timeout=}'[input timeout seconds]:secs:' \
    '(-g --no-global-grab)'{-g,--no-global-grab}'[grab keyboard only when focused]' \
    '(-W --parent-wid)'{-W+,--parent-wid=}'[parent window id]:wid:' \
    '(-c --colors)'{-c+,--colors=}'[ncurses color spec]:colors:' \
    '(-a --ttyalert)'{-a+,--ttyalert=}'[tty alert mode]:mode:(none beep flash)' \
    && ret=0

return ret
