#compdef konnectivity-server proxy-server
# _konnectivity-server — Konnectivity proxy server (sits next to kube-apiserver; multiplexes egress traffic to konnectivity agents living in worker clusters)
# upstream: https://github.com/kubernetes-sigs/apiserver-network-proxy
# Flags from cmd/server/app/options/options.go on tip.

_konnectivity-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--server-cert=[TLS cert for KAS-facing connections]:file:_files' \
        '--server-key=[TLS key for KAS-facing connections]:file:_files' \
        '--server-ca-cert=[CA used to validate KAS clients]:file:_files' \
        '--cluster-cert=[TLS cert for agent-facing connections]:file:_files' \
        '--cluster-key=[TLS key for agent-facing connections]:file:_files' \
        '--cluster-ca-cert=[CA used to validate agent clients]:file:_files' \
        '--mode=[proxy mode]:mode:(grpc http-connect)' \
        '--uds-name=[UDS socket name (empty for TCP)]:socket:_files' \
        '--delete-existing-uds-file=[delete UDS file if present before listen]:bool:(true false)' \
        '--server-port=[port for KAS server connections]:port:' \
        '--server-bind-address=[bind address for KAS server connections]:addr:' \
        '--agent-port=[port for agent connections]:port:' \
        '--agent-bind-address=[bind address for agent connections]:addr:' \
        '--admin-port=[admin HTTP port]:port:' \
        '--admin-bind-address=[admin HTTP bind address]:addr:' \
        '--health-port=[health HTTP port]:port:' \
        '--health-bind-address=[health HTTP bind address]:addr:' \
        '--keepalive-time=[gRPC agent server keepalive]:duration:' \
        '--frontend-keepalive-time=[gRPC frontend server keepalive]:duration:' \
        '--enable-profiling[enable pprof at admin-port/debug/pprof]' \
        '--enable-contention-profiling[enable mutex profiling (requires --enable-profiling)]' \
        '--server-id=[unique server id (PROXY_SERVER_ID env var)]:id:' \
        '--server-count=[number of proxy server instances for HA]:n:' \
        '--agent-namespace=[expected agent namespace during auth]:ns:' \
        '--agent-service-account=[expected agent service account during auth]:sa:' \
        '--kubeconfig=[kubeconfig file for token review]:file:_files' \
        '--kubeconfig-burst=[max client burst for token review]:n:' \
        '--kube-api-content-type=[content type for requests to the apiserver]:ct:' \
        '--authentication-audience=[expected agent token audience]:aud:' \
        '--proxy-strategies=[csv of proxy strategies]:csv:(default destHost defaultRoute)' \
        '--cipher-suites=[csv of allowed TLS cipher suites]:csv:' \
        '--tls-min-version=[minimum TLS version]:ver:(VersionTLS10 VersionTLS11 VersionTLS12 VersionTLS13)' \
        '--xfr-channel-size=[transfer channel size]:n:' \
        '--enable-lease-controller[enable lease controller for proxy-server leases]' \
        '--lease-namespace=[namespace for lease objects]:ns:' \
        '--lease-label=[label selector for lease objects]:sel:' \
        '--graceful-shutdown-timeout=[graceful shutdown timeout]:duration:' \
        '--backend-dial-timeout=[timeout for DIAL_REQ → DIAL_RSP (0 disables)]:duration:' \
        '-v[klog verbosity level]:n:'
}

_konnectivity-server "$@"
