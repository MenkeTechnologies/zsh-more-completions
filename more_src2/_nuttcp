#compdef nuttcp
# Documentation: https://manpages.debian.org/bookworm/nuttcp/nuttcp.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-h[show help]' \
  '-V[show version]' \
  '-S[run as server (background)]' \
  '-1[run as one-shot server (foreground)]' \
  '-t[transmit (client mode)]' \
  '-r[receive (client mode)]' \
  '-l+[buffer length bytes]:bytes:' \
  '-w+[window size KB]:kb:' \
  '-ws+[server window size KB]:kb:' \
  '-wb[set both send and receive socket buffer sizes]' \
  '-n+[buffer count]:n:' \
  '-T+[duration seconds]:secs:' \
  '-i+[interval between reports]:secs:' \
  '-b[brief one-line output]' \
  '-N+[parallel streams]:n:' \
  '-u[UDP transfer]' \
  '-R+[bandwidth rate limit]:rate:' \
  '-D[set TCP_NODELAY (disable Nagle)]' \
  '-B[force receiver to read full buffer]' \
  '-c+[ToS DSCP]:tos:' \
  '-d[set SO_DEBUG on data socket]' \
  '-v[verbose]' \
  '-p+[data port]:port:' \
  '-P+[control port]:port:' \
  '-s[read from / write to stdin/stdout]' \
  '-4[IPv4]' \
  '-6[IPv6]' \
  '*:host:_hosts' && ret=0

return ret
