#compdef pcbnew
# Documentation: https://docs.kicad.org/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: KiCad pcbnew accepts a .kicad_pcb file argument; no documented CLI flags
# beyond standard wxWidgets options (kicad-cli covers programmatic operations).

local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:KiCad PCB file:_files -g "*.kicad_pcb"' && ret=0
return ret
