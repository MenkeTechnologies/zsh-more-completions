#compdef ovsqlite-util
# Documentation: man ovsqlite-util(8)
# Source: InterNetNews/inn storage/ovsqlite/ovsqlite-util.in — manage ovsqlite overview (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[article number or range]:range:_default' \
    '(-A -F -g -i -o -O)-A[audit DB, report issues]' \
    '(-A -F -g -i -o -O)-F[audit DB, fix issues]' \
    '(-A -F -g -i -o -O)-g[dump overview info for group]' \
    '(- *)-h[show help]' \
    '(-A -F -g -i -o -O)-i[dump group info]' \
    '(-A -F -g -i -o -O)-o[dump articles in client format]' \
    '(-A -F -g -i -o -O)-O[dump articles in overchan format]' \
    '-n+[newsgroup]:group:_default' \
    '-p+[path to ovsqlite.db directory]:dir:_files -/' \
    && ret=0

return ret
