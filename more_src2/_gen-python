#compdef gen-python gen-py-classes
# _gen-python — generate Python dataclasses from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/pythongen.py (click).

_gen-python() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.py"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(python py)'
        '--head[emit metadata heading]'
        '--no-head[suppress metadata heading]'
        '--genmeta[emit per-class metadata fields]'
        '--no-genmeta[skip per-class metadata fields]'
        '--classvars[emit class-variable definitions for slots]'
        '--no-classvars[skip class-variable definitions]'
        '--slots[emit __slots__ on generated dataclasses]'
        '--no-slots[do not emit __slots__]'
        '--validate[run schema validation before generation]'
        '--no-validate[skip schema validation]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-python "$@"
