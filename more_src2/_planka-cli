#compdef planka-cli planka
# _planka-cli — Planka open-source realtime kanban CLI alias (plankanban team, JavaScript); custom argparse over REST API
# upstream: https://github.com/plankanban/planka

_planka-cli() {
    local -a sub=(
        'login:save token'
        'logout:clear token'
        'me:show current user'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'project:list:list projects'
        'project:create:create project'
        'project:get:get project'
        'project:update:update project'
        'project:delete:delete project'
        'board:list:list boards'
        'board:create:create board'
        'board:get:get board'
        'board:update:update board'
        'board:delete:delete board'
        'list:list:list lists'
        'list:create:create list'
        'list:update:update list'
        'list:delete:delete list'
        'card:list:list cards'
        'card:create:create card'
        'card:get:get card'
        'card:update:update card'
        'card:delete:delete card'
        'card:duplicate:duplicate card'
        'card:move:move card'
        'card:member:add:add member'
        'card:member:remove:remove member'
        'card:label:add:add label'
        'card:label:remove:remove label'
        'card:attachment:list:list attachments'
        'card:attachment:add:add attachment'
        'card:attachment:remove:remove attachment'
        'card:comment:list:list comments'
        'card:comment:add:add comment'
        'card:comment:remove:remove comment'
        'task:list:list tasks'
        'task:create:create task'
        'task:update:update task'
        'task:delete:delete task'
        'task:complete:complete task'
        'label:list:list labels'
        'label:create:create label'
        'label:delete:delete label'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[planka url]:url:_urls' \
        '--user=+[username/email]:user:_users' \
        '--password=+[password]:str:' \
        '--token=+[api token]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'planka subcommand' sub ;;
        args)
            case $words[1] in
                card:create) _arguments \
                    '--list-id=+[list id]:str:' \
                    '-l+[list id]:str:' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--description=+[description]:str:' \
                    '--position=+[position]:n:' \
                    '--due-date=+[due date]:str:' \
                    '--stopwatch-total=+[stopwatch total]:n:' ;;
                board:create) _arguments \
                    '--project-id=+[project id]:str:' \
                    '--name=+[name]:str:' \
                    '-n+[name]:str:' \
                    '--position=+[position]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_planka-cli "$@"
