#compdef docbook2dvi
# Documentation: https://manpages.debian.org/testing/docbook-utils/docbook2dvi.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# docbook2dvi — wrapper from docbook-utils invoking jade/openjade backend.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --backend)'{-b,--backend}'+[backend]:backend:(jade openjade)' \
  '(-f --frontend)'{-f,--frontend}'+[input format]:frontend:(docbook)' \
  '(-c --cat)'{-c,--cat}'+[extra SGML catalog files]:file:_files' \
  '(-d --dsl)'{-d,--dsl}'+[custom DSSSL stylesheet]:file:_files' \
  '(-l --dcl)'{-l,--dcl}'+[custom SGML declaration]:file:_files' \
  '(-s --sgmlbase)'{-s,--sgmlbase}'+[SGML base directory]:dir:_files -/' \
  '(-p --parser)'{-p,--parser}'+[SGML parser]:parser:(jade openjade)' \
  '(-o --output)'{-o,--output}'+[output directory]:dir:_files -/' \
  '*-V+[set variable name=value]:var:' \
  '(-u --nochunks)'{-u,--nochunks}'[generate single output file]' \
  '(-i --include)'{-i,--include}'+[include marked section]:name:' \
  '(-w --warning)'{-w,--warning}'+[enable/disable warnings]:warn:' \
  '(-e --error)'{-e,--error}'+[disable error types]:err:' \
  '(-n --nostd)'{-n,--nostd}'[skip standard SGML catalogs]' \
  '*:file:_files -g "*.{xml,sgml,sgm}"' && ret=0

return ret
