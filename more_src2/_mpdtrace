#compdef mpdtrace
# Documentation: https://www.mpich.org/static/downloads/1.2.1p1/mpich2-1.2.1p1-README.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. MPICH2 MPD ring trace tool
# (legacy, replaced by Hydra). -l prints long form with port numbers.
# Removed from prior file: fabricated -V/-v/-f flags (do not exist).

# mpdtrace: list MPD ring members (legacy MPICH MPD)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[print usage information]' \
  '-l[long output: include host and port]' && ret=0
return ret
