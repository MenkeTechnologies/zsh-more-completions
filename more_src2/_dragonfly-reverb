#compdef dragonfly-reverb DragonflyRoomReverb DragonflyHallReverb DragonflyPlateReverb DragonflyEarlyReflections
# _dragonfly-reverb — Michael Willis Dragonfly Reverb suite of free reverbs Room Hall Plate and Early Reflections built on Faust algorithms shipping as LV2/VST/CLAP plugins (michaelwillis team, C++); custom argparse
# upstream: https://github.com/michaelwillis/dragonfly-reverb

_dragonfly-reverb() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-J+[jack client name]:str:' \
        '--jack-name=+[jack client name]:str:' \
        '-S+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-p+[preset]:p:(Bright_Room Clear_Room Dark_Room Small_Chamber Large_Chamber Medium_Hall Large_Hall Cathedral Acoustic_Lab Echo_Bunker Pool Concert_Hall Steel_Plate Aluminum_Plate Vintage_Plate Gold_Plate)' \
        '--preset=+[preset]:p:(Bright_Room Clear_Room Dark_Room Small_Chamber Large_Chamber Medium_Hall Large_Hall Cathedral Acoustic_Lab Echo_Bunker Pool Concert_Hall Steel_Plate Aluminum_Plate Vintage_Plate Gold_Plate)' \
        '-d+[dry-level %]:f:' \
        '--dry=+[dry-level %]:f:' \
        '-w+[wet-level %]:f:' \
        '--wet=+[wet-level %]:f:' \
        '-s+[size m]:f:' \
        '--size=+[size m]:f:' \
        '-w+[width %]:f:' \
        '--width=+[width %]:f:' \
        '-D+[decay s]:f:' \
        '--decay=+[decay s]:f:' \
        '-P+[predelay ms]:f:' \
        '--predelay=+[predelay ms]:f:' \
        '-l+[low cut Hz]:f:' \
        '--low-cut=+[low cut Hz]:f:' \
        '-H+[high cut Hz]:f:' \
        '--high-cut=+[high cut Hz]:f:' \
        '-m+[mod hz]:f:' \
        '--mod=+[mod hz]:f:' \
        '-r+[room model]:m:(Room Hall Plate Early)' \
        '--type=+[room model]:m:(Room Hall Plate Early)' \
        '--no-gui[no GUI]'
}

_dragonfly-reverb "$@"
