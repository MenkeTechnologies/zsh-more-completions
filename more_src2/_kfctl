#compdef kfctl
# Documentation: https://github.com/kubeflow/kfctl/tree/master/cmd/kfctl/cmd
# Reference accessed: 2026-05-19
# Verified: against upstream cmd/kfctl/cmd command files (apply.go,
# build.go, delete.go, etc). Corrected from prior file: mirror /
# mirror-build / mirror-overwrite / set-image-name are not top-level
# kfctl commands (they live under `alpha`); -V/--verbose is a
# per-command flag (not a root persistent flag); --delete_storage and
# --force_deletion belong to `delete`; `build` takes -d/--dump; `apply`
# takes --context.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'alpha:experimental subcommands'
  'apply:apply a Kubeflow config'
  'build:build manifests from a config'
  'completion:generate shell completion'
  'delete:tear down deployment'
  'generate:generate config files'
  'init:initialize project (deprecated)'
  'show:print config or status'
  'version:print kfctl version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'kfctl subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (apply)
        _arguments \
          '(-f --file)'{-f+,--file=}'[static config file or URL]:file:_files -g "*.(yaml|yml)"' \
          '(-V --verbose)'{-V,--verbose}'[verbose output]' \
          '--context=[Kubernetes context to apply resources to]:context:' && ret=0
        ;;
      (build)
        _arguments \
          '(-f --file)'{-f+,--file=}'[static config file or URL]:file:_files -g "*.(yaml|yml)"' \
          '(-V --verbose)'{-V,--verbose}'[verbose output]' \
          '(-d --dump)'{-d,--dump}'[dump manifests to stdout]' && ret=0
        ;;
      (delete)
        _arguments \
          '(-f --file)'{-f+,--file=}'[local KfDef config file]:file:_files -g "*.(yaml|yml)"' \
          '(-V --verbose)'{-V,--verbose}'[verbose output]' \
          '--delete_storage[delete the app storage cluster used for mlpipeline]' \
          '--force_deletion[best-effort deletion, skip non-fatal checks]' && ret=0
        ;;
      (completion)
        _values 'shell' 'bash' 'zsh' 'fish' 'powershell' && ret=0
        ;;
    esac
    ;;
esac

return ret
