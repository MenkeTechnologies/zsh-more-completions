#compdef policy
# _opcr-policy — CLI for building OPA policies into OCI images (opcr-io/policy)
# upstream: https://github.com/opcr-io/policy
# Subcommands from pkg/cmd/*.go (kong).

_opcr-policy() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--config=[set CLI config file]:file:_files' \
        '--insecure[disable TLS verification]' \
        '--debug[enable debug logging]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'build:build a policy from rego sources'
                'images:list locally built policies'
                'inspect:inspect a policy by digest or tag'
                'login:log in to an OCI registry'
                'logout:log out of an OCI registry'
                'pull:pull a policy from a registry'
                'push:push a policy to a registry'
                'repl:open OPA REPL with policy loaded'
                'rm:remove a local policy'
                'save:save policy as a tarball'
                'tag:tag a policy with another tag'
                'templates:manage policy templates'
                'version:print version'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                build)
                    _arguments \
                        '(-t --tag)'{-t+,--tag=}'[name:tag of resulting policy]:tag:' \
                        '*'{-a+,--annotations=}'[annotations key=value]:annotation:' \
                        '--build-config-file=[config file]:file:_files' \
                        '--target=[output bundle target]:type:(rego wasm)' \
                        '(-O --optimize)'{-O+,--optimize=}'[optimization level]:level:(0 1 2)' \
                        '*'{-e+,--entrypoint=}'[entrypoint path]:path:' \
                        '(-r --revision)'{-r+,--revision=}'[bundle revision]:rev:' \
                        '*--ignore=[file/dir name to ignore]:pattern:' \
                        '--capabilities=[capabilities.json file]:file:_files' \
                        '--verification-key=[bundle verification key (secret or PEM path)]:keyspec:' \
                        '--verification-key-id=[verification key id]:id:' \
                        '--signing-alg=[signing algorithm]:alg:(HS256 HS384 HS512 RS256 RS384 RS512 PS256 PS384 PS512 ES256 ES384 ES512)' \
                        '--scope=[scope for bundle verification]:scope:' \
                        '*--exclude-files-verify=[files to exclude during verify]:pattern:' \
                        '--signing-key=[bundle signing key]:keyspec:' \
                        '--claims-file=[optional claims JSON file]:file:_files' \
                        '--rego-version=[rego version]:version:(rego.v0 rego.v1 rego.v0v1)' \
                        '*:path:_files'
                    ;;
                tag) _arguments '1:source:' '2:target:' ;;
                rm|inspect|pull|push|save) _arguments '1:policy reference:' ;;
            esac
            ;;
    esac
}

_opcr-policy "$@"
