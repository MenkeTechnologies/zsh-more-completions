#compdef freebcp
# Documentation: freebcp usage (FreeTDS bulk copy)
# Source: bulk copy data between Microsoft SQL Server and files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-m+[max errors before abort]:maxerrors:' \
    '-f+[format file]:file:_files' \
    '-e+[error file]:file:_files' \
    '-F+[first row]:firstrow:' \
    '-L+[last row]:lastrow:' \
    '-b+[batch size]:batchsize:' \
    '-n[native format]' \
    '-c[character format]' \
    '-t+[field terminator]:terminator:' \
    '-r+[row terminator]:terminator:' \
    '-U+[username]:user:_users' \
    '-P+[password]:password:' \
    '-I+[interfaces file]:file:_files' \
    '-S+[server]:server:' \
    '-D+[database]:database:' \
    '-v[verbose]' \
    '-d[debug]' \
    '-h+[hints (comma-separated)]:hints:' \
    '-O+[connection options on|off]:options:' \
    '-A+[packet size]:bytes:' \
    '-T+[text/image size]:bytes:' \
    '-E[explicit identity insert]' \
    '-i+[input file]:file:_files' \
    '-o+[output file]:file:_files' \
    '1:table or query:' \
    '2:direction:(in out queryout)' \
    '3:data file:_files' \
    && ret=0

return ret
