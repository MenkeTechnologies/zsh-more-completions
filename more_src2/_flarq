#compdef flarq
# Documentation: https://manpages.debian.org/bookworm/fldigi/flarq.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flarq: ARQ data transfer utility for fldigi (FLTK-based).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(- *)--build-info[show build details]' \
  '--arq-protocol=[ARQ protocol]:protocol:(fldigi multipsk)' \
  '--arq-server-address=[ARQ TCP server address]:addr:' \
  '--arq-server-port=[ARQ TCP server port]:port:' \
  '--debug[enable debugging output]' \
  '--font=[widget font and optional size]:font:' \
  '-bg+[background color]:color:' \
  '-bg2+[text background color]:color:' \
  '-fg+[foreground color]:color:' \
  '-di+[X server display]:display:' \
  '-g+[initial window geometry]:geometry:' \
  '-i[start iconic]' \
  '-ti+[window title]:title:' \
  '-na+[window class name]:class:' && ret=0

return ret
