#compdef meson-setup
# _meson-setup — Meson build system meson-setup CLI alias (Meson team / Jussi Pakkanen, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-setup() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--prefix=+[install prefix]:dir:_files -/' \
        '--bindir=+[bindir]:dir:_files -/' \
        '--datadir=+[datadir]:dir:_files -/' \
        '--includedir=+[includedir]:dir:_files -/' \
        '--infodir=+[infodir]:dir:_files -/' \
        '--libdir=+[libdir]:dir:_files -/' \
        '--libexecdir=+[libexecdir]:dir:_files -/' \
        '--localedir=+[localedir]:dir:_files -/' \
        '--localstatedir=+[localstatedir]:dir:_files -/' \
        '--mandir=+[mandir]:dir:_files -/' \
        '--sbindir=+[sbindir]:dir:_files -/' \
        '--sharedstatedir=+[sharedstatedir]:dir:_files -/' \
        '--sysconfdir=+[sysconfdir]:dir:_files -/' \
        '--auto-features=+[auto features]:f:(auto enabled disabled)' \
        '--backend=+[backend]:b:(ninja vs vs2010 vs2012 vs2013 vs2015 vs2017 vs2019 vs2022 xcode none)' \
        '--vsenv[init VS env]' \
        '--buildtype=+[buildtype]:t:(plain debug debugoptimized release minsize custom)' \
        '--debug=+[debug]:b:(true false)' \
        '--default-library=+[default library]:l:(shared static both)' \
        '--errorlogs=+[errorlogs]:b:(true false)' \
        '--install-umask=+[install umask]:str:' \
        '--layout=+[layout]:l:(mirror flat)' \
        '--optimization=+[optimization]:o:(plain 0 g 1 2 3 s)' \
        '--prefer-static[prefer static]' \
        '--stdsplit=+[stdsplit]:b:(true false)' \
        '--strip[strip]' \
        '--unity=+[unity]:u:(on off subprojects)' \
        '--unity-size=+[unity size]:n:' \
        '--warnlevel=+[warnlevel]:n:(0 1 2 3 everything)' \
        '--werror[werror]' \
        '--wrap-mode=+[wrap mode]:m:(default nofallback nodownload forcefallback nopromote)' \
        '--force-fallback-for=+[force fallback for]:str:' \
        '--pkgconfig.relocatable[pkgconfig relocatable]' \
        '--python.bytecompile=+[python bytecompile]:str:' \
        '--python.install-env=+[python install env]:e:(auto prefix system venv)' \
        '--python.platlibdir=+[python platlibdir]:dir:_files -/' \
        '--python.purelibdir=+[python purelibdir]:dir:_files -/' \
        '--python.allow-limited-api=+[python allow limited api]:b:(true false)' \
        '-D+[define option key=value]:list:' \
        '--cross-file=+[cross file]:list:_files' \
        '--native-file=+[native file]:list:_files' \
        '--reconfigure[reconfigure]' \
        '--wipe[wipe build dir]' \
        '--clearcache[clear cache]' \
        '--fatal-meson-warnings[fatal meson warnings]' \
        '--cmake-prefix-path=+[cmake prefix path]:list:_files -/' \
        '--pkg-config-path=+[pkg-config path]:list:_files -/' \
        '*:build-and-source-dir:_files -/'
}

_meson-setup "$@"
