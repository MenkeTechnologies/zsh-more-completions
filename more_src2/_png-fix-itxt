#compdef png-fix-itxt
# Documentation: https://github.com/glennrp/libpng/blob/libpng16/contrib/tools/png-fix-itxt.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Usage: png-fix-itxt < bad.png > good.png  (stdin/stdout only, no flags)

local curcontext="$curcontext" ret=1

# png-fix-itxt takes no arguments; it reads stdin and writes stdout.
_message 'png-fix-itxt reads stdin and writes stdout; no arguments' && ret=0

return ret
