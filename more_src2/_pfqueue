#compdef pfqueue
# Documentation: https://manpages.org/pfqueue/8
# Reference accessed: 2026-05-16
# Verified: pfqueue(8) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL; fake long flags.

# pfqueue: curses-based Postfix/Exim queue manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show usage]' \
  '-v[show version]' \
  '-B[backend directory]:dir:_files -/' \
  '-b[backend to load]:backend:(autodetect postfix1 postfix2 exim)' \
  '-c[custom MTA configuration]:file:_files' \
  '-m[maximum messages to show (default 200)]:max:' \
  '-s[autorefresh rate in seconds (default 1)]:seconds:' \
  '-e[read from/to fields from message envelope]' \
  '-p[MTA executables path]:dir:_files -/' \
  '-q[start by scanning this queue]:queue:((1\:deferred 2\:active 3\:incoming 4\:hold))' \
  '-l[queue tree scan time limit in seconds]:seconds:' \
  '-d[delay between queue scans in seconds]:seconds:' \
  '-n[disable colors]' \
  '-r[remote host to connect to]:host:' && ret=0
return ret
