#compdef llvm-cxxfilt
# _llvm-cxxfilt — LLVM C++ demangler (LLVM project, C++); GNU c++filt-compatible Itanium/MS ABI demangler
# upstream: https://github.com/llvm/llvm-project

_llvm-cxxfilt() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-_[strip underscore]' \
        '--strip-underscore[strip underscore]' \
        '-n[no strip underscore]' \
        '--no-strip-underscore[no strip underscore]' \
        '-p[no params]' \
        '--no-params[no params]' \
        '-t[try to demangle as type]' \
        '--types[try to demangle as type]' \
        '--format=+[format]:fmt:(auto gnu lucid arm hp edg gnu-v3 java gnat dlang rust)' \
        '-s+[format]:fmt:' \
        '*:symbol:'
}

_llvm-cxxfilt "$@"
