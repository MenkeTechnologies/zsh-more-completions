#compdef playerctld
# Documentation: https://github.com/altdesktop/playerctl
# Reference accessed: 2026-05-20
# Verified: upstream source at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    local -a commands=(
      'daemon:Start the playerctld daemon'
      'shift:Shift to the next player'
      'unshift:Shift to the previous player'
    )
    _describe -t commands 'command' commands && ret=0
    ;;
esac

return ret
