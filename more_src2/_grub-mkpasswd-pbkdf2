#compdef grub-mkpasswd-pbkdf2 grub2-mkpasswd-pbkdf2
# _grub-mkpasswd-pbkdf2 — GRUB grub-mkpasswd-pbkdf2 (generate a PBKDF2 hash suitable for password_pbkdf2 in grub.cfg; -c iteration count, -l hash length bits, -s salt length bytes; prompts for password interactively)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mkpasswd-pbkdf2.c on tip.

_grub-mkpasswd-pbkdf2() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-c+[iteration count]:n:' \
        '--iteration-count+[iteration count]:n:' \
        '-l+[hash length bits]:bits:' \
        '--buflen+[hash length bits]:bits:' \
        '-s+[salt length bytes]:bytes:' \
        '--salt+[salt length bytes]:bytes:'
}

_grub-mkpasswd-pbkdf2 "$@"
