#compdef dust
# _dust-bin — du replacement showing disk usage (bootandy, Rust); colorful tree-aware du-like output
# upstream: https://github.com/bootandy/dust

_dust-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --depth)'{-d,--depth}'+[depth]:n:' \
        '(-n --number-of-lines)'{-n,--number-of-lines}'+[lines]:n:' \
        '(-p --full-paths)'{-p,--full-paths}'[show full paths]' \
        '(-P --no-percent-bars)'{-P,--no-percent-bars}'[hide percent bars]' \
        '(-i --ignore-directory)'{-i,--ignore-directory}'+[ignore dir]:dir:_files -/' \
        '(-I --ignore-all-in-file)'{-I,--ignore-all-in-file}'+[ignore file list]:file:_files' \
        '(-X --invert-filter)'{-X,--invert-filter}'+[invert match]:filter:' \
        '(-e --filter)'{-e,--filter}'+[match regex]:regex:' \
        '(-x --filesystem)'{-x,--filesystem}'[do not cross filesystems]' \
        '(-r --reverse)'{-r,--reverse}'[reverse output]' \
        '(-c --no-colors)'{-c,--no-colors}'[no color]' \
        '(-C --force-colors)'{-C,--force-colors}'[force color]' \
        '(-b --no-percent-bars)'{-b,--no-percent-bars}'[no percent bars]' \
        '(-B --bars-on-right)'{-B,--bars-on-right}'[bars on right]' \
        '(-l --limit-filesystem)'{-l,--limit-filesystem}'[limit to one fs]' \
        '(-s --apparent-size)'{-s,--apparent-size}'[apparent size]' \
        '(-z --min-size)'{-z,--min-size}'+[min size]:size:' \
        '(-R --reverse)'{-R,--reverse}'[reverse]' \
        '(-f --filecount)'{-f,--filecount}'[file count instead of size]' \
        '(-D --only-dir)'{-D,--only-dir}'[only directories]' \
        '(-F --only-file)'{-F,--only-file}'[only files]' \
        '(-t --threads)'{-t,--threads}'+[thread count]:n:' \
        '--print-errors[print errors]' \
        '--si[SI units]' \
        '(-o --output-format)'{-o,--output-format}'+[output format]:fmt:(b k m g t kb mb gb tb kib mib gib tib si)' \
        '(-w --terminal_width)'{-w,--terminal_width}'+[terminal width]:n:' \
        '*:path:_files'
}

_dust-bin "$@"
