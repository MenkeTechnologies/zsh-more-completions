# ============================================================================
# _lazurite — zsh completion for k1ngmang/Lazurite, "a simple functional
#              programming language" — Java-derived dynamic scripting
#              language with first-class libraries for games, GUI apps,
#              files, networking, and social-network bots (174th
#              programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/k1ngmang/lazurite
#                (active development continues at IxionLang/
#                 Lazurite — this is the canonical repo)
#   Maintainer : Artyom Kingmang (k1ngmang)
#   License    : MIT
#   Stars      : 163
#   Language   : Kotlin + Java
#   Module     : com.kingmang.lazurite  (Maven group)
#   Binary     : lazurite  (downstream wrapper around `java -jar
#                            Lazurite.jar`;  entry class
#                            `com.kingmang.lazurite.runner.
#                            Runner.main`)
#   Source ext : .lzr  (Lazurite source files;
#                       `using "lzr.utils.async"` import
#                       paths)
#   Last push  : 2026-05-28
#
# WHAT IT IS
#   Lazurite is "a simple functional programming language" that
#   takes advantage of Java's JVM ecosystem and simplifies it
#   for scripting use cases.  It's primarily used for creating
#   games and GUI applications (via the bundled JavaFX +
#   Darklaf-core integration), but also supports file I/O,
#   networking, social-network bot scaffolding, async/await
#   futures, pattern matching with case clauses, and stream
#   API operations on collections.  The reference runtime is
#   distributed as a single JVM jar and bundles its own command
#   console (`compile_console`), code editor (`editor`),
#   project scaffolder (`new`), and REPL.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main/java/com/
#                       kingmang/lazurite/runner/Runner.kt
#                       `main` + RunnerCommand.kt enum — every
#                       command exposes a long form (`--<full>`)
#                       AND a compact short form (e.g. `-r`,
#                       `-v`); when invoked with no arguments
#                       the interactive REPL opens)
#   lazurite [<COMMAND>]
#
#   Commands (long form = `--<full>`):
#     --run | -r                     Run a Lazurite source file
#                                    (prompts for the path)
#     --version | -v                 Print Lazurite version
#     --help | -h                    Show help
#     --compile_console | -cc        Open the compiler console
#     --editor | -e                  Open the bundled code
#                                    editor
#     --new | -n                     Create a new Lazurite
#                                    project (scaffolder)
#     --cls                          Clear the command line
#     --exit                         Exit the program
#
#   When invoked with no command, Lazurite opens an interactive
#   REPL that accepts the same set of commands above.
#
# LANGUAGE-CORPUS POSITION
#   Lazurite is the 174th programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R965 (_tesla_auth / adriankumpf Rust=149 OPENS Axis 94
#   OAuth2 / ramosbugs/oauth2-rs) and continued through R966
#   (_ghealth / rudrankriyam Go=149) and R967 (_broker / snyk
#   TS-Node=149 CLOSES Axis 94 at 1/1/1 three-language symmetry
#   — triple-149 landmark and 87th axis closed).  Lazurite
#   joins duck-lang (R964 173rd), Rascal (R960 172nd — R960
#   round-number commit landmark), Ixion (R956 171st),
#   KernelScript (R952 170th — round-number 170th-language
#   milestone), Prog8 (R948 169th), Objeck (R944 168th), Feral
#   (R940 167th — R940 round-number commit landmark), Biscuit/
#   BL (R936 166th), Rux (R932 165th), Jule (R928 164th),
#   Nevalang (R924 163rd), Corvid (R920 162nd — round-number
#   R920 commit landmark), Soppo (R916 161st), Cyrus (R912
#   160th — round-number language milestone), Lumina (R908
#   159th), Penne (R904 158th), EndBASIC (R900 157th — R900
#   TRIPLE-9 commit landmark), goboscript (R896 156th), Alan
#   (R892 155th), Mech (R888 154th — triple-8 landmark),
#   Lisette (R884 153rd), Bril (R880 152nd), Vyxal (R876
#   151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th),
#   Mochi (R860 147th), Oden (R856 146th), Hop (R852 145th),
#   Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th),
#   Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `lazurite` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_lazurite() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print Lazurite version]' \
        '(-r --run)'{-r,--run}'[run a Lazurite source file]' \
        '(-cc --compile_console)'{-cc,--compile_console}'[open the compiler console]' \
        '(-e --editor)'{-e,--editor}'[open the bundled code editor]' \
        '(-n --new)'{-n,--new}'[create a new Lazurite project]' \
        '--cls[clear the command line]' \
        '--exit[exit the program]' \
        ':Lazurite source file (optional):_files -g "*.lzr"'
}

_lazurite "$@"
