#compdef padthv1_jack
# _padthv1_jack — padthv1 PADsynth additive synth, JACK client (rncbc/padthv1)
# upstream: https://github.com/rncbc/padthv1
# Flags from src/padthv1_jack.cpp (QCommandLineParser).

_padthv1_jack() {
    _arguments \
        '(- *)'{-h,--help,-?}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-g --no-gui)'{-g,--no-gui}'[disable the GUI]' \
        '(-n --client-name)'{-n+,--client-name=}'[JACK client name]:name:' \
        '*:preset file:_files -g "*.{padthv1,xml}"'
}

_padthv1_jack "$@"
