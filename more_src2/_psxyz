#compdef psxyz
# Documentation: https://docs.generic-mapping-tools.org/latest/psxyz.html
# Source: GenericMappingTools/gmt src/psxyz.c — plot lines/polygons/symbols in 3D (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[map projection]:projection:_default' \
    '-R+[region (with z)]:region:_default' \
    '-B+[axes options]:opts:_default' \
    '-A+[straight lines (no resample)]:axis:(x y)' \
    '-C+[colour palette or 2-3 colours]:cpt:_default' \
    '-D+[label offset dx/dy]:offset:_default' \
    '-H+[per-record scaling]:scale:_default' \
    '-I+[intensity for fill]:intensity:_default' \
    '-K[allow more PS later]' \
    '-N+[do not skip points outside region]:mode:(c r)' \
    '-O[append PostScript]' \
    '-P[portrait]' \
    '-Q[do not sort symbols by depth]' \
    '-S+[symbol type+size]:symbol:_default' \
    '-T[ignore input files]' \
    '-U+[plot timestamp]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[pen attributes]:pen:_default' \
    '-X+[x shift]:shift:_default' \
    '-Z+[constant z-value or per-record file]:opts:_default' \
    '-a+[aspatial column mapping]:cols:_default' \
    '-bi+[binary input format]:format:_default' \
    '-c+[subplot panel]:panel:_default' \
    '-di+[input nodata↔NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[segment gaps]:gap:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-l+[legend setting]:opts:_default' \
    '-p+[3D perspective view]:view:_default' \
    '-qi+[record selection]:cols:_default' \
    '-t+[transparency]:value:_default' \
    '-w+[wraparound]:opts:_default' \
    '*:input table:_files' \
    && ret=0

return ret
