#compdef dovecot-fts
# _dovecot-fts — Dovecot full-text-search backend admin wrapper (helper invoked by doveadm fts {rescan|optimize|lookup|expunge-log}; -A run for every user, -u single user, -F user-list file, -i ignore errors, --version, --help; reads /etc/dovecot/conf.d/90-plugin.conf for fts_* settings)
# upstream: https://github.com/dovecot/core
# Flags from dovecot src/doveadm/doveadm-fts.c on tip.

_dovecot-fts() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '-A[all users]' \
        '-u+[user]:user:_users' \
        '-F+[user list file]:file:_files' \
        '-i[ignore errors]' \
        '1:action:(rescan optimize lookup expunge-log)'
}

_dovecot-fts "$@"
