#compdef dategrep
# Documentation: https://metacpan.org/dist/App-dategrep/view/script/dategrep
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Upstream repo: https://github.com/mdom/dategrep

_arguments -s -S \
  '--start=[start date for matching]:date expression:' \
  '--end=[end date for matching]:date expression:' \
  '--last-minutes=[print lines from N minutes ago to start of current minute]:minutes:' \
  '--format=[strftime-based input date format]:format:(rsyslog apache iso8601 tai64n)' \
  '--multiline[print all lines between start and end even if untimestamped]' \
  '--skip-unparsable[ignore lines without timestamp (disables --multiline)]' \
  '--sort[sort lines by timestamp across overlapping files]' \
  '--sort-files[sort input files by first timestamp]' \
  '--configfile=[read config from FILE instead of ~/.dategreprc]:config file:_files' \
  '--blocksize=[block size for binary search]:bytes:' \
  '--man[show full man page in pager]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:files:_files'
