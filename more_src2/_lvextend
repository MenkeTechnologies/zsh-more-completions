#compdef lvextend
# _lvextend — extend a logical volume (LVM2); grow lv size, optionally resizing the filesystem
# upstream: https://gitlab.com/lvmteam/lvm2

_lvextend() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-L --size)'{-L,--size}'+[size]:size:' \
        '(-l --extents)'{-l,--extents}'+[extents]:str:' \
        '(-r --resizefs)'{-r,--resizefs}'[resize underlying fs]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-A --autobackup)'{-A,--autobackup}'+[autobackup]:bool:(y n)' \
        '(-n --nofsck)'{-n,--nofsck}'[skip fsck]' \
        '(-i --stripes)'{-i,--stripes}'+[stripes]:n:' \
        '(-I --stripesize)'{-I,--stripesize}'+[stripe size]:size:' \
        '(-m --mirrors)'{-m,--mirrors}'+[mirrors]:n:' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '--alloc+[allocation policy]:policy:(contiguous cling normal anywhere inherit)' \
        '--poolmetadatasize+[pool metadata size]:size:' \
        '--type+[lv type]:type:' \
        '--use-policies[use config policy thresholds]' \
        '*:lv:'
}

_lvextend "$@"
