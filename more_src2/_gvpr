#compdef gvpr
# Documentation: man gvpr(1) (graphviz)
# Source: GraphViz gvpr — graph manipulation language (awk-style for DOT).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[whitespace-split args available as ARGV[]]:args:' \
    '*-f+[program file]:file:_files -g "*.gvpr"' \
    '-c[use source graph as output graph]' \
    '-i[derive node-induced subgraph extension]' \
    '-n[turn off graph read-ahead]' \
    '-o+[output file]:file:_files' \
    '-q[suppress warnings]' \
    '(- *)-V[show version]' \
    '-v[verbose]' \
    '(- *)-?[show usage]' \
    '*:DOT file:_files -g "*.{dot,gv}"' \
    && ret=0

return ret
