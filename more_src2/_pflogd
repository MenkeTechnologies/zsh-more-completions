#compdef pflogd
# _pflogd — OpenBSD pflogd (reads packets from a pflog(4) interface (default pflog0) and writes them to a tcpdump(8) binary capture file at /var/log/pflog; optional libpcap filter expression to drop captures)
# upstream: https://github.com/openbsd/src (sbin/pflogd)
# Flags from sbin/pflogd/pflogd.8 on tip.

_pflogd() {
    _arguments \
        '-D[debug (foreground + stderr)]' \
        '-x[exit on error opening logfile]' \
        '-d+[buffer flush delay (seconds)]:delay:' \
        '-f+[output capture file]:file:_files' \
        '-i+[pflog interface]:interface:_net_interfaces' \
        '-s+[snaplen bytes]:bytes:' \
        '*:filter expression:'
}

_pflogd "$@"
