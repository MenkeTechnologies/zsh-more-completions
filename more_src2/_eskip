#compdef eskip
# Documentation: https://github.com/zalando/skipper/tree/master/cmd/eskip
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# eskip: Skipper route file utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'check:validate routes'
  'print:format and print routes'
  'upsert:insert/replace routes in storage'
  'reset:sync routes from file to storage'
  'delete:delete routes'
  'patch:patch route filters'
  'version:print eskip version'
)
# Go flag package: long options take a single dash but also accept double-dash
_arguments -C \
  '-etcd-urls=[comma-separated etcd cluster URLs]:urls' \
  '-etcd-prefix=[etcd storage prefix]:prefix' \
  '-etcd-oauth-token=[OAuth token for etcd]:token' \
  '-innkeeper-url=[Innkeeper service URL]:url' \
  '-oauth-token=[OAuth token]:token' \
  '-routes=[inline route definitions]:routes' \
  '-ids=[comma-separated route IDs]:ids' \
  '-insecure[skip TLS verification]' \
  '-prepend=[prepend filters to all routes]:filters' \
  '-prepend-file=[file with filters to prepend]:file:_files' \
  '-append=[append filters to all routes]:filters' \
  '-append-file=[file with filters to append]:file:_files' \
  '-pretty[pretty-print output]' \
  '-indent=[indent string for pretty-print]:str' \
  '-json[output routes as JSON]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'eskip command' commands && ret=0 ;;
  args) _files && ret=0 ;;
esac
return ret
