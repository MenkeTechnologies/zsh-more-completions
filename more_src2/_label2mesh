#compdef label2mesh
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/label2mesh.html
# Source: MRtrix3/mrtrix3 cmd/label2mesh.cpp — generate mesh from parcellation image labels (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-blocky[blocky meshes with precise voxel-edge delineation]' \
    '1:nodes_in (parcellation image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:mesh_out (output mesh file):_files -g "*.{obj,vtk,stl,ply}"' \
    && ret=0

return ret
