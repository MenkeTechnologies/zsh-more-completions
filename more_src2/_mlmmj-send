#compdef mlmmj-send
# Documentation: https://mlmmj.org/mlmmj-send.html
# Reference accessed: 2026-05-30
# mlmmj-send — distribute mail through mlmmj mailing lists. Typically invoked by other mlmmj binaries.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-L+[full path to mailing list directory]:dir:_directories' \
  '-l+[list control variable (sending mode)]:mode:(1 2 3 4 5 6)' \
  '-m+[full path to mail file being processed]:file:_files' \
  '-a[skip archiving the message]' \
  '-D[preserve mail file after sending]' \
  '-o+[exclude this address from recipients]:addr:' \
  '-r+[relay host IP (default 127.0.0.1)]:ip:' \
  '-F+[MAIL FROM field]:from:' \
  '-R+[Reply-To header]:reply-to:' \
  '-T+[RCPT TO value]:rcpt:' \
  '-s+[subscribers file name]:file:_files' \
  && ret=0

return ret
