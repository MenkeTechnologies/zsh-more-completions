#compdef gpasswd-cli
# _gpasswd-cli — shadow gpasswd administer /etc/group and /etc/gshadow CLI alias (shadow-maint team, C); custom argparse
# upstream: https://github.com/shadow-maint/shadow

_gpasswd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-a+[user]:_users' \
        '--add=+[user]:_users' \
        '-d+[user]:_users' \
        '--delete=+[user]:_users' \
        '-Q+[chroot]:dir:_files -/' \
        '--root=+[chroot]:dir:_files -/' \
        '-r[remove password]' \
        '--remove-password[remove password]' \
        '-R[restrict access]' \
        '--restrict[restrict access]' \
        '-A+[admin csv]:str:' \
        '--administrators=+[admin csv]:str:' \
        '-M+[members csv]:str:' \
        '--members=+[members csv]:str:' \
        '-P+[prefix]:dir:_files -/' \
        '--prefix=+[prefix]:dir:_files -/' \
        '*:group:_groups'
}

_gpasswd-cli "$@"
