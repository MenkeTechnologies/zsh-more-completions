#compdef gftools
# Documentation: https://github.com/googlefonts/gftools
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Subcommands enumerated from Lib/gftools/scripts/*.py at upstream HEAD.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'add-axis:add axis'
  'add-designer:add designer'
  'add-ds-subsets:add DS subsets'
  'add-font:add METADATA.pb to family directory'
  'add-tags:add tags'
  'autohint:autohint'
  'avar2-to-avar1:convert avar2 to avar1'
  'batch-packager:batch packager'
  'build-ofl:build OFL'
  'check-bbox:check bbox'
  'check-category:check category'
  'check-copyright-notices:check copyright notices'
  'check-font-version:check font version'
  'check-name:check name'
  'check-sandbox-family:check sandbox family'
  'check-vertical-extents:check vertical extents'
  'check-vtt-compatibility:check VTT compatibility'
  'check-vtt-compile:check VTT compile'
  'compare-font:compare fonts'
  'compare-meta:compare metadata'
  'drop-hints:drop hints'
  'family-html-snippet:family HTML snippet'
  'find-features:find features'
  'fix-article:fix article'
  'fix-ascii-fontmetadata:fix ASCII metadata'
  'fix-cmap:fix cmap'
  'fix-family:fix family'
  'fix-familymetadata:fix family metadata'
  'fix-font:fix font'
  'fix-fsselection:fix fsSelection'
  'fix-fstype:fix fsType'
  'fix-gasp:fix gasp'
  'fix-glyph-private-encoding:fix glyph encoding'
  'fix-hinting:fix hinting'
  'fix-instances:fix instances'
  'fix-isfixedpitch:fix isfixedpitch'
  'fix-nameids:fix nameIDs'
  'fix-nonhinting:fix nonhinting'
  'fix-ttfautohint:fix ttfautohint'
  'fix-unwanted-tables:fix unwanted tables'
  'fix-vendorid:fix vendor ID'
  'fix-vertical-metrics:fix vertical metrics'
  'fix-weightclass:fix weight class'
  'font-dependencies:font dependencies'
  'font-weights-coverage:weights coverage'
  'fontsetter:fontsetter'
  'format-html:format HTML'
  'gen-avar2:gen avar2'
  'gen-fvar-instances:gen fvar instances'
  'gen-push-lists:gen push lists'
  'gen-spac:gen spacing'
  'gen-stat:gen STAT'
  'has-glyph:has glyph'
  'lang-support:language support'
  'list-italicangle:list italic angle'
  'list-panose:list panose'
  'list-weightclass:list weight class'
  'list-widthclass:list width class'
  'manage-traffic-jam:manage traffic jam'
  'metadata-vs-api:metadata vs API'
  'nametable-from-filename:nametable from filename'
  'ots:run OTS'
  'packager:packager'
  'push-stats:push stats'
  'push-status:push status'
  'qa:QA against Google Fonts'
  'rangify:rangify'
  'remap-font:remap font'
  'remap-layout:remap layout'
  'rename-font:rename font'
  'rename-glyphs:rename glyphs'
  'render-text:render text'
  'sanity-check:sanity check'
  'set-primary-script:set primary script'
  'tag-noto:tag Noto'
  'transfer-vtt-hints:transfer VTT hints'
  'ttf2cp:TTF to CP'
  'ufo-fix-instances:UFO fix instances'
  'ufo-merge:UFO merge'
  'ufo-set-order:UFO set order'
  'ufo-setter:UFO setter'
  'ufo-transfer-data:UFO transfer data'
  'unicode-names:unicode names'
  'update-families:update families'
  'update-nameids:update nameIDs'
  'update-version:update version'
  'varfont-info:varfont info'
  'what-subsets:what subsets'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--list-subcommands[print subcommand names]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'gftools subcommand' subcommands && ret=0 ;;
  (args) _arguments '*:arg:_files' && ret=0 ;;
esac

return ret
