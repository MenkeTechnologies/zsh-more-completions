#compdef function-cel-filter
# _function-cel-filter — Crossplane composition function that filters / mutates the desired set with a CEL expression (gRPC server consumed by crossplane)
# upstream: https://github.com/crossplane-contrib/function-cel-filter
# Flags from main.go on tip (alecthomas/kong).

_function-cel-filter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[emit debug logs in addition to info logs]' \
        '--network=[network on which to listen for gRPC connections]:net:(tcp unix)' \
        '--address=[address on which to listen for gRPC connections]:addr:' \
        '--tls-server-certs-dir=[directory containing server tls.key + tls.crt + ca.crt]:dir:_files -/' \
        '--insecure[run without mTLS credentials (--tls-server-certs-dir is ignored)]'
}

_function-cel-filter "$@"
