#compdef plausible-cli
# _plausible-cli — Plausible Analytics plausible-cli CLI command-line frontend wrapping the Plausible privacy-friendly open-source web analytics platform REST API managing sites users events stats top-pages funnels goals breakdown filters time-period dimension comparing custom-event-props referrer outbound-link cdn-token API-key (Plausible team, Go); cobra
# upstream: https://plausible.io/

_plausible-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'site:site management'
        'user:user management'
        'event:event operations'
        'stats:fetch stats'
        'aggregate:fetch aggregate stats'
        'timeseries:fetch timeseries'
        'breakdown:fetch breakdown'
        'realtime:fetch realtime'
        'funnel:funnel operations'
        'goal:goal operations'
        'top-pages:show top pages'
        'top-referrers:show top referrers'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-url=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--site-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--period=+[p]:p:(day 7d 30d month 6mo 12mo year all custom)' \
        '--date=+[YYYY-MM-DD]:str:' \
        '--metric=+[m]:m:(visitors pageviews events bounce_rate visit_duration views_per_visit)' \
        '--filters=+[expr]:str:' \
        '--dimension=+[name]:str:' \
        '--limit=+[N]:n:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'plausible-cli subcommand' sub ;;
        args)
            case $words[1] in
                site|user|event|funnel|goal) _arguments '1:op:(list get create update delete)' '*:id:' ;;
            esac
            ;;
    esac
}

_plausible-cli "$@"
