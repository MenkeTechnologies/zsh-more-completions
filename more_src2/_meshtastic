#compdef meshtastic
# _meshtastic — Meshtastic project meshtastic Python CLI for off-grid LoRa mesh radios (meshtastic team, Python); argparse
# upstream: https://github.com/meshtastic/python

_meshtastic() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--port=+[serial port]:file:_files -g "/dev/tty*"' \
        '--host=+[network host]:host:_hosts' \
        '--ble=+[bluetooth address]:str:' \
        '--ble-scan[scan for BLE]' \
        '--noproto[no protobufs print]' \
        '--debug[debug logging]' \
        '--sendtext=+[message]:str:' \
        '--sendping[send a ping]' \
        '--reply[set reply role]' \
        '--ack[require ack]' \
        '--dest=+[destination id]:str:' \
        '--reboot[reboot the device]' \
        '--reset-nodedb[reset node db]' \
        '--shutdown[shutdown device]' \
        '--factory-reset[factory reset]' \
        '--info[show device info]' \
        '--nodes[show node list]' \
        '--qr[show QR for primary channel]' \
        '--qr-all[show QR for all channels]' \
        '--get=+[config field]:str:' \
        '--set=+[field=value]:str:' \
        '--set-owner=+[long name]:str:' \
        '--set-owner-short=+[short name]:str:' \
        '--set-canned-message=+[messages]:str:' \
        '--set-ringtone=+[ringtone]:str:' \
        '--seturl=+[channel url]:str:' \
        '--ch-index=+[index]:n:' \
        '--ch-set=+[field=value]:str:' \
        '--ch-add=+[name]:str:' \
        '--ch-del[delete current channel]' \
        '--ch-enable[enable channel]' \
        '--ch-disable[disable channel]' \
        '--ch-vlongslow[preset]' \
        '--ch-longslow[preset]' \
        '--ch-longfast[preset]' \
        '--ch-medslow[preset]' \
        '--ch-medfast[preset]' \
        '--ch-shortslow[preset]' \
        '--ch-shortfast[preset]' \
        '--export-config[export config]' \
        '--configure=+[yaml file]:file:_files -g "*.yaml *.yml"' \
        '--listen[listen mode]' \
        '--no-time[do not sync time]' \
        '--no-nodes[skip nodes on info]'
}

_meshtastic "$@"
