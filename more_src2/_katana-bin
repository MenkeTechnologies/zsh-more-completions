#compdef katana
# _katana-bin — ProjectDiscovery katana web crawler (Go); modern headless crawler for authorized recon
# upstream: https://github.com/projectdiscovery/katana

_katana-bin() {
    _arguments \
        '-h[show help]' \
        '-version[show version]' \
        '-u+[target URL]:url:_urls' \
        '-list+[input list file]:file:_files' \
        '-resume+[resume scan]:file:_files' \
        '-headless[headless browser]' \
        '-system-chrome[use system chrome]' \
        '-show-browser[show browser]' \
        '-no-sandbox[no sandbox]' \
        '-d+[crawl depth]:n:' \
        '-jc[crawl JS code]' \
        '-jsl[JS link extraction]' \
        '-ct+[crawl duration]:duration:' \
        '-kf+[known files]:list:(robotstxt sitemapxml all)' \
        '-mrs+[max response size]:n:' \
        '-timeout+[request timeout sec]:n:' \
        '-retry+[retries]:n:' \
        '-c+[concurrency]:n:' \
        '-p+[parallelism]:n:' \
        '-rd+[request delay]:duration:' \
        '-rl+[rate limit]:n:' \
        '-rlm+[rate per minute]:n:' \
        '-H+[header]:str:' \
        '-cookie+[cookie]:str:' \
        '-fs+[field scope]:scope:(rdn fqdn dn)' \
        '-cs+[crawl scope]:scope:' \
        '-cos+[crawl out scope]:scope:' \
        '-do[display out-of-scope]' \
        '-f+[field filter]:fields:(url path fqdn rdn rurl qurl qpath file ufile key value kv dir udir)' \
        '-sf+[store field]:fields:' \
        '-em+[extension match]:exts:' \
        '-ef+[extension filter]:exts:' \
        '-mr+[match regex]:regex:' \
        '-fr+[filter regex]:regex:' \
        '-no-color[no color]' \
        '-silent[silent]' \
        '-v[verbose]' \
        '-o+[output file]:file:_files' \
        '-j[json output]' \
        '-or[omit raw response]' \
        '-ob[omit body]' \
        '-stats[show stats]' \
        '-store-response[store response]' \
        '-store-response-dir+[response dir]:dir:_files -/' \
        '-proxy+[proxy URL]:url:_urls' \
        '*:target:'
}

_katana-bin "$@"
