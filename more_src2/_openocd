#compdef openocd
# Documentation: https://openocd.org/doc/html/Running.html
# Reference accessed: 2026-05-20
# Verified: OpenOCD Running chapter - option set matches upstream user guide.

# Zsh completion for openocd (Open On-Chip Debugger)

_arguments -s -S \
  '-h[Display help]' \
  '--help[Display help]' \
  '-v[Display version]' \
  '--version[Display version]' \
  '*-f+[Use configuration file]:config file:_files -g "*.cfg"' \
  '*--file=[Use configuration file]:config file:_files -g "*.cfg"' \
  '*-s+[Add directory to search path]:search dir:_directories' \
  '*--search=[Add directory to search path]:search dir:_directories' \
  '-d+[Set debug level (0-4)]:debug level:(0 1 2 3 4)' \
  '--debug=[Set debug level (0-4)]:debug level:(0 1 2 3 4)' \
  '-l+[Redirect log output to file]:log file:_files' \
  '--log_output=[Redirect log output to file]:log file:_files' \
  '*-c+[Run command on startup]:command:' \
  '*--command=[Run command on startup]:command:' \
  '-p[Set GDB pipe mode]' \
  '--pipe[Set GDB pipe mode]' && return 0
