#compdef drget
# Documentation: https://emboss.sourceforge.net/apps/cvs/emboss/apps/drget.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS drget: retrieve a single DRCAT data resource entry
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-resource=[input data resource USA]:USA:' \
  '-outresource=[output data resource file]:file:_files' \
  '-orformat=[output format]:format:(drcat list text excel xml tagseq)' \
  '*:resource USA:' && ret=0
return ret
