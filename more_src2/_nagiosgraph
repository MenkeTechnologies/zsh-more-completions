local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-v[verbose]' \
  '-l+[log file]:file:_files' && ret=0

return ret
