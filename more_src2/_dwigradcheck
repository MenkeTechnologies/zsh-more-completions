#compdef dwigradcheck
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwigradcheck.html
# Source: MRtrix3/mrtrix3 bin/dwigradcheck — check orientation of DWI gradient table (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[brain mask image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-number+[tracks generated per test]:n:_default' \
    '-grad+[input MRtrix-format gradient table]:file:_files' \
    '-fslgrad+[input FSL bvecs bvals pair]:files:_files' \
    '-export_grad_mrtrix+[export MRtrix-format gradient table]:file:_files' \
    '-export_grad_fsl+[export FSL bvecs bvals pair]:files:_files' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:input (DWI series):_files -g "*.{nii,nii.gz,mif}"' \
    && ret=0

return ret
