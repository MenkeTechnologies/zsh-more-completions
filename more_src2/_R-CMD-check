#compdef R-CMD-check
# _R-CMD-check — R Core Team R CMD check check an R package for common problems and CRAN policy violations (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-check() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-l+[library path]:dir:_files -/' \
        '--library=+[library path]:dir:_files -/' \
        '-o+[output dir]:dir:_files -/' \
        '--output=+[output dir]:dir:_files -/' \
        '-c[clean]' \
        '--clean[clean]' \
        '--preclean[preclean]' \
        '--no-clean-on-error[no clean on error]' \
        '--no-tests[no tests]' \
        '--no-vignettes[no vignettes]' \
        '--no-build-vignettes[no build vignettes]' \
        '--no-rebuild-vignettes[no rebuild vignettes]' \
        '--no-vignette-encodings[no vignette encodings]' \
        '--no-multiarch[no multiarch]' \
        '--no-examples[no examples]' \
        '--no-stop-on-test-error[no stop on test error]' \
        '--as-cran[as CRAN]' \
        '--no-codoc[no code-doc check]' \
        '--no-install[no install]' \
        '--no-tests[no tests]' \
        '--no-manual[no manual]' \
        '--use-gct[use gctorture]' \
        '--no-use-valgrind[no use valgrind]' \
        '--use-valgrind[use valgrind]' \
        '--check-subdirs=+[mode]:m:(no yes default)' \
        '--timings[show timings]' \
        '--check-renviron[check Renviron]' \
        '--ignore-vignettes[ignore vignettes]' \
        '--install-args=+[args]:str:' \
        '--build-args=+[args]:str:' \
        '--enable-remote-services[enable remote services]' \
        '--disable-remote-services[disable remote services]' \
        '--force-multiarch[force multiarch]' \
        '--keep-output[keep output]' \
        '--md5[md5 checksums]' \
        '--no-rebuild-vignettes[no rebuild vignettes]' \
        '*:package:_files -g "*.tar.gz *.tgz"'
}

_R-CMD-check "$@"
