#compdef rootslimtree
# Documentation: https://github.com/root-project/root/blob/master/main/python/rootslimtree.py
# Source: root-project/root main/python/rootslimtree.py — copy ROOT tree with only a subset of branches.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-c --compress)'{-c+,--compress=}'[compression factor for destination]:factor:_default' \
    '--recreate[recreate the destination file]' \
    '*'{-i+,--branchinclude=}'[branch name patterns to include]:pattern:_default' \
    '*'{-e+,--branchexclude=}'[branch name patterns to exclude]:pattern:_default' \
    '1:source file:tree:_default' \
    '2:destination file:_files -g "*.root(-.)"' \
    && ret=0

return ret
