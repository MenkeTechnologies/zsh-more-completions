#compdef manila-manage
# Documentation: https://docs.openstack.org/manila/latest/cli/manila-manage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# manila-manage: DB / admin commands
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a categories=(
  'db:database operations'
  'logs:log file operations'
  'shell:interactive shell access'
  'host:host management'
  'config:configuration display'
  'service:service management'
  'version:version information'
  'share:share operations'
  'share_server:share server management'
)
_arguments -C \
\
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "--debug[set log level to debug]" \
  "-d[set log level to debug]" \
  "--log-config-append=[log config file]:file:_files" \
  "--log-date-format=[log date format]:fmt:" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--nodebug[do not set log level to debug]" \
  "--rate-limit-burst=[log rate limit burst]:n:" \
  "--rate-limit-except=[log rate limit except]:list:" \
  "--rate-limit-interval=[log rate limit interval]:n:" \
  "--rpc-conn-pool-size=[RPC conn pool size]:n:" \
  "--rpc-response-timeout=[RPC response timeout]:n:" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "--transport-url=[transport URL]:url:" \
  "--use-journal[log to systemd journal]" \
  "--use-json[log as JSON]" \
  "--use-syslog[log via syslog]" \
  "--watch-log-file[watch log file]" \
  '1:category:->cat' \
  '*::arg:->args' && ret=0
case $state in
  cat) _describe -t categories 'manila-manage category' categories && ret=0 ;;
  args)
    case $line[1] in
      db)
        local -a db_cmds=(
          'version:show DB version'
          'sync:sync schema to latest'
          'downgrade:downgrade DB schema'
          'stamp:stamp DB with revision'
          'revision:create migration'
          'purge:purge deleted rows'
        )
        _describe -t db_cmds 'db subcommand' db_cmds && ret=0
        ;;
      logs)
        local -a logs_cmds=(
          'errors:show errors'
          'syslog:show syslog'
        )
        _describe -t logs_cmds 'logs subcommand' logs_cmds && ret=0
        ;;
      shell)
        local -a shell_cmds=(
          'bpython:bpython shell'
          'ipython:ipython shell'
          'python:python shell'
          'run:run command'
          'script:run script'
        )
        _describe -t shell_cmds 'shell subcommand' shell_cmds && ret=0
        ;;
      host)
        _arguments '1:subcommand:(list)' && ret=0
        ;;
      config)
        _arguments '1:subcommand:(list)' && ret=0
        ;;
      service)
        _arguments '1:subcommand:(list)' && ret=0
        ;;
      version)
        _arguments '1:subcommand:(list)' && ret=0
        ;;
      share)
        _arguments '1:subcommand:(delete update_host)' && ret=0
        ;;
      share_server)
        _arguments '1:subcommand:(update_share_server_capabilities)' && ret=0
        ;;
    esac ;;
esac
return ret
