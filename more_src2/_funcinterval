#compdef funcinterval funcinterval-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/funcinterval.py argparse)
# Reference accessed: 2026-05-29
# funcinterval — time interval between same kernel function as a histogram (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-i --interval)'{-i,--interval=}'[summary interval, in seconds]:sec:' \
  '(-d --duration)'{-d,--duration=}'[total duration of trace, in seconds]:sec:' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-u --microseconds -m --milliseconds)'{-u,--microseconds}'[microsecond histogram]' \
  '(-u --microseconds -m --milliseconds)'{-m,--milliseconds}'[millisecond histogram]' \
  '(-v --verbose)'{-v,--verbose}'[print the BPF program (for debugging purposes)]' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:pattern (function/tracepoint name e.g. "vfs_read" or "sched\:sched_switch"):' \
  && ret=0

return ret
