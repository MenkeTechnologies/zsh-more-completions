#compdef pmapper
# Documentation: https://github.com/nccgroup/PMapper
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'graph:graph commands (create/list/display)'
  'query:run a natural-language query'
  'argquery:run a parameterized query'
  'repl:interactive query REPL'
  'analysis:generate findings reports'
  'visualize:render a graph diagram'
  'orgs:Organizations commands (create/list/display/update)'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--profile=[AWS profile]:profile:' \
  '--account=[AWS account id]:id:' \
  '--debug[enable debug logging]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pmapper command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (graph)
        _arguments \
          '*::sub:(create list display)' \
          '--ignore-orgs[ignore Organizations data]' \
          '*--include-regions=[regions to include]:region:' \
          '*--exclude-regions=[regions to exclude]:region:' \
          '*--include-services=[services to include]:service:' \
          '*--exclude-services=[services to exclude]:service:' && ret=0 ;;
      (query)
        _arguments \
          '(-s --skip-admin)'{-s,--skip-admin}'[exclude admins from results]' \
          '(-u --include-unauthorized)'{-u,--include-unauthorized}'[also list principals that cannot perform action]' \
          '--with-resource-policy[load cached resource policies]' \
          '--resource-policy-text=[custom resource policy text]:policy:' \
          '--resource-owner=[resource owner account id]:id:' \
          '--session-policy=[session policy to apply]:policy:' \
          '--scps[include SCPs in evaluation]' \
          '*::query:' && ret=0 ;;
      (argquery)
        _arguments \
          '--principal=[IAM principal pattern]:principal:' \
          '--action=[AWS API action]:action:' \
          '--resource=[target resource ARN]:arn:' \
          '*--condition=[condition k=v]:condition:' \
          '--preset=[preset query]:preset:(privesc connected access)' \
          '(-s --skip-admin)'{-s,--skip-admin}'[exclude admins]' \
          '(-u --include-unauthorized)'{-u,--include-unauthorized}'[include unauthorized]' \
          '--with-resource-policy[include cached resource policies]' \
          '--resource-policy-text=[resource policy text]:policy:' \
          '--resource-owner=[resource owner account id]:id:' \
          '--session-policy=[session policy]:policy:' \
          '--scps[include SCPs]' && ret=0 ;;
      (analysis)
        _arguments \
          '--output-type=[output format]:format:(text json)' && ret=0 ;;
      (visualize)
        _arguments \
          '--filetype=[output type]:format:(svg png dot graphml)' \
          '--only-privesc[show only privilege escalation paths]' && ret=0 ;;
      (orgs)
        _arguments \
          '*::sub:(create list display update)' \
          '--org=[organization id]:id:' && ret=0 ;;
    esac ;;
esac

return ret
