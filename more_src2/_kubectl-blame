#compdef kubectl-blame
# Documentation: https://github.com/knight42/kubectl-blame
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (cmd/blame.go flag definitions).

# kubectl-blame (knight42/kubectl-blame). Own flags --time/--color/-f/-i
# plus the standard genericclioptions ConfigFlags set.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--time=[time format]:fmt:(full relative none)' \
  '--color=[color output]:mode:(auto always never)' \
  '(-f --filename)*'{-f+,--filename=}'[filename identifying the resource]:file:_files -g "*.yaml *.yml *.json"' \
  '(-i --input)'{-i+,--input=}'[read object from the given file (auto reads stdin if piped, - forces stdin)]:file:_files' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:ns:' \
  '--context=[kubeconfig context]:ctx:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '--insecure-skip-tls-verify[skip TLS certificate validation]' \
  '--request-timeout=[request timeout]:duration:' \
  '*:resource:' && ret=0

return ret
