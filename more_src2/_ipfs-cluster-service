#compdef ipfs-cluster-service
# _ipfs-cluster-service — IPFS Cluster daemon (ipfs-cluster/ipfs-cluster)
# upstream: https://github.com/ipfs-cluster/ipfs-cluster

_ipfs-cluster-service() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-c --config)'{-c+,--config=}'[path to the configuration and data directory]:dir:_files -/' \
        '(-f --force)'{-f,--force}'[forcefully proceed past warnings]' \
        '--debug[enable verbose / debug logging]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_ipfs-cluster-service_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)
                    _arguments \
                        '--consensus=[consensus algorithm]:algo:(crdt raft)' \
                        '--datastore=[datastore backend]:store:(badger3 leveldb pebble)' \
                        '--peers=[comma-separated bootstrap peer multiaddrs]:peers:' \
                        '--randomports[use random listening ports]' \
                        '--custom-secret[generate cluster.secret from terminal input]' && ret=0 ;;
                daemon)
                    _arguments \
                        '--upgrade[run state-version upgrades before starting]' \
                        '--bootstrap=[comma-separated bootstrap multiaddrs]:peers:' \
                        '--leave[leave the cluster on Ctrl-C]' \
                        '--stats[enable stats logging]' \
                        '--tracing[enable OpenCensus distributed tracing]' \
                        '--alloc=[allocation strategy]:strategy:(balanced freespace numpin tag-numpin tag-freespace)' && ret=0 ;;
                state)
                    _arguments \
                        '1: :(export import cleanup version migrate)' \
                        '*:state arg:_files' && ret=0 ;;
                version|help) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ipfs-cluster-service_commands] )) ||
_ipfs-cluster-service_commands() {
    local -a commands
    commands=(
        'init:create a default configuration directory'
        'daemon:run the ipfs-cluster daemon'
        'state:manage the cluster state (export/import/cleanup/migrate)'
        'version:print version information'
        'help:show online help'
    )
    _describe -t commands 'ipfs-cluster-service command' commands
}

_ipfs-cluster-service "$@"
