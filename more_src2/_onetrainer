#compdef onetrainer onetrainer-cli ot
# _onetrainer — Nerogar OneTrainer Stable Diffusion training all-in-one CLI alias (Nerogar, Python); custom argparse
# upstream: https://github.com/Nerogar/OneTrainer

_onetrainer() {
    local -a sub=(
        'train:train a model'
        'ui:start GUI'
        'convert-model:convert model'
        'caption:caption images'
        'sample:generate samples'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-path=+[config json]:file:_files -g "*.json"' \
        '-c+[config json]:file:_files -g "*.json"' \
        '--secrets-path=+[secrets json]:file:_files -g "*.json"' \
        '-s+[secrets json]:file:_files -g "*.json"' \
        '--callback-path=+[callback path]:file:_files' \
        '--command-path=+[command path]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'onetrainer subcommand' sub ;;
        args)
            case $words[1] in
                train) _arguments \
                    '--training-method=+[training method]:m:(LORA EMBEDDING FULL DREAMBOOTH FINE_TUNE)' \
                    '--model-type=+[model type]:t:(STABLE_DIFFUSION_15 STABLE_DIFFUSION_2 STABLE_DIFFUSION_3 STABLE_DIFFUSION_XL_10_BASE STABLE_DIFFUSION_XL_10_REFINER WURSTCHEN_2 PIXART_ALPHA FLUX_DEV_1)' \
                    '--base-model-name=+[base model name]:str:' \
                    '--cache-path=+[cache path]:dir:_files -/' \
                    '--workspace-dir=+[workspace dir]:dir:_files -/' \
                    '--debug-mode[debug mode]' \
                    '--debug-dir=+[debug dir]:dir:_files -/' \
                    '--continue-last-backup[continue from last backup]' ;;
                caption) _arguments \
                    '--mode=+[mode]:m:(blip blip2 wd14)' \
                    '--input-dir=+[input dir]:dir:_files -/' \
                    '*:arg:' ;;
                convert-model) _arguments \
                    '--input=+[input]:file:_files' \
                    '--output=+[output]:file:_files' \
                    '--target-format=+[target format]:fmt:(SAFETENSORS CKPT DIFFUSERS)' ;;
                sample) _arguments \
                    '--model-path=+[model path]:file:_files' \
                    '--prompt=+[prompt]:str:' \
                    '--output-dir=+[output dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_onetrainer "$@"
