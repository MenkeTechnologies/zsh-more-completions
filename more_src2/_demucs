#compdef demucs
# Documentation: https://github.com/facebookresearch/demucs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# facebookresearch/demucs — CLI `demucs` / `python -m demucs.separate`
local ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-n=[model name]:model:(htdemucs htdemucs_ft mdx_extra mdx_extra_q hdemucs_mmi mdx_q)' \
  '(-s --shifts)'{-s,--shifts=}'[random shifts for quality]:int' \
  '(-o --out)'{-o,--out=}'[output directory]:dir:_files -/' \
  '--filename=[output naming template]:pattern' \
  '(-d --device)'{-d,--device=}'[torch device]:device:(cpu cuda)' \
  '-j=[parallel jobs]:n' \
  '--overlap=[overlap between prediction windows]:f' \
  '--segment=[segment length in seconds]:n' \
  '--two-stems=[separate one stem from accompaniment]:stem:(vocals drums bass other)' \
  '--float32[32-bit float output]' \
  '--int24[24-bit wav output]' \
  '--clip-mode=[clipping behavior]:mode:(rescale clamp)' \
  '--flac[FLAC instead of wav]' \
  '--mp3[MP3 instead of wav]' \
  '--mp3-bitrate=[kbps]:rate' \
  '--mp3-preset=[mp3 preset]:n' \
  '--verbose[verbose logging]' \
  '*:tracks or files:_files' && ret=0

return ret
