#compdef pamsummcol
# Documentation: man pamsummcol (Netpbm)
# Source: print per-column sum, mean, min, or max of samples in a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-sum -mean -min -max)-sum[per-column sum]' \
    '(-sum -mean -min -max)-mean[per-column mean]' \
    '(-sum -mean -min -max)-min[per-column minimum]' \
    '(-sum -mean -min -max)-max[per-column maximum]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
