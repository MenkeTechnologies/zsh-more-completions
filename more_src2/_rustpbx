#compdef rustpbx
# ============================================================================
# rustpbx - SIP/VoIP private branch exchange
#            (PBX) telephony platform
#            (Rust, MIT)
#
# Author : Jindi Shen (jinti) - restsend
# Upstream: https://github.com/restsend/rustpbx
#
# `rustpbx` is a SIP (Session Initiation
# Protocol) PBX implementation in Rust -
# replacing legacy PBX systems like
# Asterisk + FreeSWITCH + Kamailio with a
# memory-safe, async-first, single-binary
# alternative.
#
# A PBX (Private Branch Exchange) is the
# telephone-system core that routes calls
# between extensions + connects to upstream
# SIP trunks for outgoing/incoming external
# calls. PBXes also handle:
#   - **Call routing rules** (dial plans
#     defining how to route based on
#     called number + caller identity)
#   - **Endpoint registration** (SIP
#     phones + softphones register their
#     current location/IP)
#   - **Call recording** (compressed
#     archives of conversations - hence
#     the zstd dependency)
#   - **Voicemail** (incoming-message
#     handling + delivery)
#   - **IVR** (Interactive Voice Response;
#     menu-driven call flows)
#   - **WebRTC bridging** (translating
#     between browser WebRTC + SIP for
#     web-based softphones)
#   - **Transcription + AI integration**
#     (speech-to-text + LLM-based call
#     analysis)
#
# Architecture:
#   - **SIP stack** (RFC 3261 compliant)
#   - **RTP/RTCP** for media (with SRTP +
#     ZRTP for encrypted media)
#   - **WebRTC** bridge (DTLS-SRTP + ICE +
#     STUN/TURN for browser connectivity)
#   - **Audio codecs** (G.711 PCMA/PCMU
#     + G.722 + Opus + iLBC; opus feature
#     enables Opus codec)
#   - **Database backend** (typically
#     PostgreSQL or SQLite for endpoint +
#     call-log + voicemail storage)
#   - **HTTP/REST API** (axum-based
#     management interface + WebRTC
#     signaling)
#
# Distinguishing features vs alternatives
# (Asterisk + FreeSWITCH + Kamailio + 3CX):
#   - **Memory safety** (Rust eliminates
#     entire classes of CVE that have
#     historically affected C-based PBXes
#     - buffer overflows + use-after-free
#     in SIP message parsing have been
#     repeated CVE sources in Asterisk)
#   - **Async-first** (tokio runtime
#     enables high concurrency without
#     thread-per-call overhead;
#     significant memory savings at high
#     concurrent call counts)
#   - **Single binary distribution** (no
#     module configuration complexity
#     like Asterisk's .conf-driven module
#     loading; cross-compiles to all Rust-
#     supported platforms)
#   - **TOML configuration** (more
#     auditable than Asterisk's
#     legacy .conf format)
#   - **Built-in WebRTC bridge** (no
#     separate WebRTC-to-SIP gateway like
#     Janus or Jitsi needed)
#   - **AI feature integration**
#     (transcription + LLM features built
#     in via configuration)
#   - **Enterprise addons** (modular
#     enterprise authentication +
#     wholesale routing + endpoint
#     management + voicemail features
#     via feature flags)
#
# Use cases:
#   - Small + medium business phone
#     systems (10-1000 extensions)
#   - Call center deployments (with
#     ACD + queueing addons)
#   - WebRTC-based softphone backends
#     (browser-side calling apps)
#   - SIP trunking aggregators
#     (multi-provider trunk routing)
#   - Telecom development + testing
#     environments
#   - Voice AI agent backends (LLM-
#     powered IVR + intelligent call
#     routing)
#
# Usage:
#   rustpbx [global flags] [check-config]
#
# Global flags (apply to all commands +
# default-run server mode):
#       --conf <file>              - path to
#                                     TOML
#                                     configuration
#                                     file
#       --tokio-console <addr>     - tokio
#                                     console
#                                     server
#                                     address
#                                     (e.g.
#                                     /tmp/
#                                     tokio-
#                                     console
#                                     + 127.0
#                                     .0.1:
#                                     5556)
#       --super-username <user>    - create
#                                     or
#                                     update
#                                     console
#                                     super
#                                     user
#                                     before
#                                     starting
#                                     (requires
#                                     --super-
#                                     password;
#                                     console
#                                     feature
#                                     only)
#       --super-password <pass>    - password
#                                     for the
#                                     console
#                                     super
#                                     user
#                                     (console
#                                     feature
#                                     only)
#       --super-email <email>      - email
#                                     for the
#                                     console
#                                     super
#                                     user
#                                     (defaults
#                                     to
#                                     <user>@
#                                     localhost)
#       --skip-migrate             - skip
#                                     running
#                                     database
#                                     migrations
#                                     on
#                                     startup
#
# Subcommands:
#   check-config                   - validate
#                                     configuration
#                                     + exit
#                                     without
#                                     starting
#                                     the
#                                     server
#                                     (deployment
#                                     validation
#                                     workflow)
#
# Standard:
#   -h, --help                     - show
#                                     help
#   -V, --version                  - show
#                                     version
#
# Example invocations:
#   # Start with default config
#   rustpbx
#
#   # Start with custom config file
#   rustpbx --conf /etc/rustpbx/config.toml
#
#   # Validate config without starting server
#   rustpbx --conf /etc/rustpbx/config.toml \
#     check-config
#
#   # Skip database migrations on startup
#   # (useful when migrations have been pre-
#   # applied via separate process)
#   rustpbx --skip-migrate
#
#   # Create/update super user on startup
#   # (console feature)
#   rustpbx \
#     --super-username admin \
#     --super-password 'changeme' \
#     --super-email admin@example.com
#
#   # Enable tokio console for runtime
#   # introspection
#   rustpbx --tokio-console 127.0.0.1:5556
#     # Then attach tokio-console binary to
#     # see task list + resource utilization
#
# Companion binaries (separate from main
# `rustpbx` binary):
#   sipflow                        - SIP
#                                     trace
#                                     analysis
#                                     tool
#                                     (requires
#                                     opus
#                                     feature
#                                     compile)
#   verify-i18n                    - i18n
#                                     translation
#                                     verification
#                                     tool
#                                     (development
#                                     workflow)
#
# Feature flags (compile-time):
#   opus                           - Opus
#                                     audio
#                                     codec
#                                     (recommended
#                                     for
#                                     production)
#   console                        - admin
#                                     web
#                                     console
#                                     (minijinja-
#                                     templated)
#   addon-acme                     - ACME
#                                     (Let's
#                                     Encrypt)
#                                     TLS
#                                     certificate
#                                     auto-
#                                     renewal
#                                     via
#                                     instant-
#                                     acme
#   addon-wholesale                - wholesale
#                                     routing
#                                     (compressed
#                                     CDR
#                                     streaming
#                                     via
#                                     async-
#                                     compression)
#   addon-archive                  - call
#                                     recording
#                                     archive
#                                     (flate2)
#   addon-endpoint-manager         - endpoint
#                                     fleet
#                                     management
#   addon-enterprise-auth          - LDAP +
#                                     RADIUS
#                                     authentication
#                                     (ldap3 +
#                                     ring +
#                                     flate2)
#   addon-transcript               - call
#                                     transcription
#                                     via
#                                     speech-
#                                     to-text
#
# The zstd lane is built on `zstd = "0.13"`
# (declared verbatim at upstream Cargo.toml
# HEAD as a direct dep, imported by the call
# recording + archive + log compression
# modules for compressing CDR records +
# voicemail audio + diagnostic logs before
# storage), the canonical Rust Zstandard
# binding by Alexandre Bury (gyscos) -
# github.com/gyscos/zstd-rs.
#
# gyscos/zstd-rs is the de-facto canonical
# Rust Zstandard binding:
#   - **Wraps Facebook's libzstd**
#     (https://github.com/facebook/zstd;
#     the canonical Zstd reference
#     implementation by Yann Collet at
#     Meta; zstd-rs provides safe Rust
#     bindings via zstd-sys)
#   - **Streaming + buffered APIs**
#     (Encoder + Decoder + AutoFinishEncoder
#     + ZstdEncoder/Decoder for byte
#     buffers)
#   - **Dictionary compression** (train +
#     use shared dictionaries for higher
#     compression ratios on similar
#     content)
#   - **Multi-threaded compression**
#     (parallel compression for large
#     files)
#   - **CLI helper** (zstd binary via
#     `cargo install zstd`)
#   - **2,400+ stars on github.com/
#     gyscos/zstd-rs**
#   - **~3,500 reverse-deps on
#     crates.io (the canonical Rust
#     Zstd stack)**
#
# zstd-rs's distinguishing position vs Rust
# compression alternatives:
#   - gyscos/zstd-rs (Bury): canonical
#     Rust Zstd binding; THIS AXIS
#   - flate2-rs (alexcrichton/flate2-rs):
#     canonical Rust gzip + zlib +
#     deflate binding (NOT zstd; this is
#     the older compression family)
#   - lz4-flex / lz4_flex: Lempel-Ziv-4
#     algorithm (faster but lower ratio
#     than zstd)
#   - xz2 / xz-rs: LZMA/xz binding
#     (highest ratio but slowest)
#   - snap: Google's Snappy compression
#     (Rust port; speed-optimized)
#   - zstd-safe (gyscos/zstd-rs sibling):
#     low-level safe FFI bindings without
#     the high-level Read/Write API
#
# Yann Collet (Cyan4973) is the *original
# author of Zstandard*. Originally
# developed at Meta (Facebook) where Collet
# was a Principal Engineer, Zstandard
# emerged as a superior alternative to
# gzip/zlib + LZ4 for modern compression
# workloads. Yann's broader compression
# work also includes:
#   - **LZ4** (also at Meta; faster than
#     zstd but lower ratio)
#   - **XXH3** (xxHash; fast non-
#     cryptographic hashing - used by
#     zstd internally + by many other
#     tools)
#   - **Pre-Zstd**: Yann's early
#     compression research at his
#     personal "Compression Ratings"
#     blog led to LZ4 + later Zstd
#
# Alexandre Bury (gyscos) is the canonical
# Rust binding maintainer for Zstd:
#   - **gyscos/zstd-rs** (THIS AXIS:
#     canonical Rust binding)
#   - **gyscos/cursive** (canonical
#     Rust TUI library; basis of many
#     Rust terminal applications;
#     ~4,500 stars)
#   - **gyscos/cargo-cache** (cargo
#     cache management tool)
#
# Bury's role in Rust spans *foundational
# infrastructure across multiple
# unrelated verticals* (compression +
# TUI + tooling). Few canonical-Rust
# authors maintain canonical-status
# libraries across as many unrelated
# verticals as Bury does in the Rust
# ecosystem (compression + TUI).
#
# Multi-axis canonical-Rust author/org
# cohort extension (now spanning even
# more distinct authors):
#   - + Alexandre Bury (gyscos) +
#     Yann Collet (Cyan4973) + Meta
#     (zstd-rs + libzstd + cursive +
#     LZ4 + xxHash; THIS AXIS;
#     canonical Rust Zstandard binding
#     + foundational compression
#     research at Meta)
#
# Notable: Zstandard is one of the few
# compression algorithms with broad
# cross-language adoption AND a single
# canonical original-author identity
# (Collet at Meta). Most compression
# algorithms have a longer pedigree (gzip
# from GNU + LZMA from Igor Pavlov + LZ77/
# LZW from Lempel + Ziv + Welch + ...) or
# emerged from academic research +
# multiple competing implementations.
# Zstandard's clean *single-author *
# canonical-implementation pedigree
# (Collet's libzstd as the canonical
# reference) makes its cross-language
# bindings unambiguously aligned with the
# original spec.
#
# rustpbx uses zstd for:
#   - Call recording archive compression
#     (large audio file compression for
#     long-term storage in object
#     storage or filesystem)
#   - CDR (Call Detail Record) batch
#     compression (high-volume billing
#     event streams)
#   - Log file compression (rotated PBX
#     logs)
#   - Voicemail audio compression
#     (Opus + zstd dual-layer
#     compression where zstd compresses
#     the encoded Opus stream
#     containers)
#
# This is the canonical use case for
# zstd-rs in production telephony +
# storage systems: high-throughput
# compression of large audio + log
# payloads where space efficiency
# matters but real-time codec encoding
# (Opus + G.711) is handled separately.
#
# ----------------------------------------------------------------------------
# AXIS 287 :: Zstandard (zstd) compression
#              libraries
#              (Facebook's modern
#              compression algorithm; LZ77 +
#              FSE/Huffman entropy coding;
#              standardized at RFC 8478)
# Round 1559 :: Rust slot 1 of 4 :: OPENS Axis 287
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : gyscos/zstd-rs            - Alexandre
#                                          Bury
#                                          (canonical
#                                          Rust
#                                          binding to
#                                          Facebook's
#                                          libzstd)
#   Go      : klauspost/compress        - Klaus Post
#                                          (canonical
#                                          Go
#                                          compression
#                                          suite
#                                          including
#                                          zstd +
#                                          gzip +
#                                          deflate +
#                                          others;
#                                          pure-Go)
#   TS/Node : @mongodb-js/zstd          - MongoDB +
#             OR                            facebook/
#             facebook/zstd-codec           zstd-codec
#                                          (canonical
#                                          Node zstd
#                                          bindings;
#                                          via N-API
#                                          or
#                                          emscripten)
#
# Zstandard is the *modern open-source
# compression standard* that has largely
# replaced gzip + xz in many production
# workloads:
#   - **Created by Yann Collet at Meta
#     (Facebook)** (released 2015;
#     standardized as RFC 8478 in 2018)
#   - **Better compression ratio than
#     gzip + comparable to xz** with
#     **better speed than both**
#   - **Adoption**: ZFS (filesystem) +
#     btrfs + Squashfs + Linux kernel
#     module compression + Debian +
#     Fedora + Arch package
#     compression + many storage
#     systems
#   - **Dictionary compression**:
#     pre-trained dictionaries enable
#     very high ratios on similar
#     content (e.g., log lines + JSON
#     payloads of the same schema)
#   - **Streaming + parallel
#     compression**: multi-threaded
#     compression for high-throughput
#     scenarios
#
# Each canonical library provides:
#   - Compression + decompression API
#   - Streaming + buffered modes
#   - Dictionary support
#   - Multi-threading (where the binding
#     language supports it)
#
# Use-case spectrum for this axis (so far):
#   - rustpbx (Rust, zstd-rs): SIP PBX
#     call recording archive + CDR
#     batch compression + log
#     compression
# ============================================================================

_rustpbx() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--conf=[path to TOML configuration file]:file:_files -g "*.toml"' \
        '--tokio-console=[tokio console server address]:addr:' \
        '--super-username=[create or update console super user]:user:' \
        '--super-password=[password for console super user]:pass:' \
        '--super-email=[email for console super user]:email:' \
        '--skip-migrate[skip database migrations on startup]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_rustpbx_cmds' \
    && ret=0

    return ret
}

_rustpbx_cmds() {
    local -a cmds
    cmds=(
        'check-config:validate configuration + exit without starting the server'
    )
    _describe -t commands 'rustpbx command' cmds
}

_rustpbx "$@"
