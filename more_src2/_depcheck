#compdef depcheck
# Documentation: https://github.com/depcheck/depcheck
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_depcheck() {
  _arguments \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '--ignore-bin-package=[ignore packages with bin entry]:b:(true false)' \
    '--skip-missing=[skip missing dependency check]:b:(true false)' \
    '--json[output in JSON format]' \
    '--oneline[output on a single line]' \
    '--ignores=[comma-separated packages to ignore (glob ok)]:packages:' \
    '--ignore-patterns=[comma-separated file patterns to ignore]:patterns:' \
    '--ignore-path=[gitignore-spec file to exclude]:file:_files' \
    '--parsers=[glob-parser pairs]:parsers:' \
    '--detectors=[detectors to use]:detectors:' \
    '--specials=[special parsers]:specials:(babel bin eslint feross-standard gatsby gulp jest karma mocha prettier tslint ttypescript webpack rollup vue serverless react-scripts)' \
    '--config=[depcheck config file]:file:_files -g "*depcheckrc*"' \
    '--quiet[suppress output]' \
    '1:directory:_directories'
}

_depcheck "$@"
