#compdef pambackground
# Documentation: man pambackground (Netpbm)
# Source: extract the background color of a Netpbm image as a single-pixel PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
