#compdef foamInfo
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamInfo — look up tutorial usage and C++ source documentation for a class/model/BC.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-all -a)'{-all,-a}'[list all tutorials/models (default cap: 10 tutorials, 25 models)]' \
    '(-browser -b)'{-browser,-b}'[open C++ source guide web page in given browser]:browser:(firefox chromium google-chrome safari open xdg-open)' \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-keyword -k)'{-keyword,-k}'[treat <name> as keyword instead of exact match]' \
    '(-web -w)'{-web,-w}'[open C++ source guide web page in controlDict-configured browser]' \
    '*:class/model/BC name:' \
    && ret=0

return ret
