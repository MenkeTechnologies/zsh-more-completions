#compdef gns3
# _gns3 — GNS3 (Cisco-focused network emulator GUI; --debug enables debug logging, --console URI overrides GNS3 server, --project opens a .gns3 project file, --no-ssl skip remote TLS, --no-help skip help dialog, --version print version)
# upstream: https://github.com/GNS3/gns3-gui
# Flags from gns3-gui gns3/main.py on tip.

_gns3() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug logging]' \
        '--console+[server URI]:uri:' \
        '--project+[project file]:file:_files -g "*.(gns3|gns3project)"' \
        '--no-ssl[disable TLS to remote server]' \
        '--no-help[skip help dialog]' \
        '--no-confirm-exit[skip exit confirmation]' \
        '--reset-prompts[reset hidden prompts]' \
        '--language+[ui language]:lang:'
}

_gns3 "$@"
