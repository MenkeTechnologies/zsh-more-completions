#compdef rpmdev-extract
# Documentation: https://github.com/rsrchboy/rpmdevtools/blob/master/rpmdev-extract
# Reference accessed: 2026-05-21
# Verified: upstream rsrchboy/rpmdevtools rpmdev-extract source.

# rpmdev-extract: extract source archive (.tar.gz/.zip/etc)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-q[suppress output]' \
  '-f[force overwrite existing files]' \
  '-C[change to directory before extracting]:dir:_files -/' \
  '*:archive:_files' && ret=0
return ret
