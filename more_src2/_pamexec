#compdef pamexec
# Documentation: man pamexec (Netpbm)
# Source: run a shell command on each image in a Netpbm multi-image stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-check[verify exit status of command]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:command:' \
    '2:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
