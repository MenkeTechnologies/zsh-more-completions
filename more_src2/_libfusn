#compdef fusninfo fusndump
# _libfusn — libfusn tools (libyal Windows USN journal parser; fusninfo prints metadata for the $UsnJrnl:$J alternate data stream of NTFS, fusndump walks every USN record and prints filename, reason flags and timestamps; -h help, -V version, -v verbose, -o image offset, -X exclusive; positional argument is the $UsnJrnl:$J stream file)
# upstream: https://github.com/libyal/libfusn
# Flags from libyal/libfusn fusntools/fusninfo.c on tip.

_libfusn() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-X[exclusive]' \
        '*:USN journal file:_files'
}

_libfusn "$@"
