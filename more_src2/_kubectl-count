#compdef kubectl-count
# Documentation: https://github.com/chenjiandongx/kubectl-count
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[aggregate resources across all namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:namespace:' \
  '(-o --output-format)'{-o+,--output-format=}'[output format]:format:(json table yaml j t y)' \
  '(-O --order)'{-O+,--order=}'[sort counts ascending or descending]:order:(asc desc a d)' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[kubeconfig context name]:context:' \
  '--cluster=[kubeconfig cluster name]:cluster:' \
  '--user=[kubeconfig user name]:user:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token for authentication]:token:' \
  '--request-timeout=[server request timeout]:timeout:' \
  '*:kinds:_default'
