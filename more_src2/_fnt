#compdef fnt
# Documentation: https://github.com/alexmyczko/fnt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# alexmyczko/fnt — apt for fonts

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '-u[update font index]' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'fnt command' compadd -- search install remove list update preview info
  ;;
rest)
  _normal && ret=0
  ;;
esac

return ret
