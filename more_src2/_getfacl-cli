#compdef getfacl-cli
# _getfacl-cli — Andreas Grünbacher acl getfacl get file access control lists CLI alias (acl team, C); custom argparse
# upstream: https://savannah.nongnu.org/projects/acl

_getfacl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-a[display access ACL]' \
        '--access[display access ACL]' \
        '-d[display default ACL]' \
        '--default[display default ACL]' \
        '-c[do not display comment header]' \
        '--omit-header[do not display comment header]' \
        '-e[show all effective rights]' \
        '--all-effective[show all effective rights]' \
        '-E[no show effective rights]' \
        '--no-effective[no show effective rights]' \
        '-n[show numeric ids]' \
        '--numeric[show numeric ids]' \
        '-p[do not strip leading slash]' \
        '--absolute-names[do not strip leading slash]' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-L[follow symlinks]' \
        '--logical[follow symlinks]' \
        '-P[no follow symlinks]' \
        '--physical[no follow symlinks]' \
        '-s[skip files with default acl]' \
        '--skip-base[skip files with default acl]' \
        '-t[tabular format]' \
        '--tabular[tabular format]' \
        '*:files:_files'
}

_getfacl-cli "$@"
