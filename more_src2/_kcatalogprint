#compdef kcatalogprint kzonesign
# Documentation: upstream knot-dns.cz man pages
# Reference accessed: 2026-05-30 via WebFetch of
# www.knot-dns.cz/docs/latest/html/man_{kcatalogprint,kzonesign}.html.
# Knot DNS R86 — 2-stem multi-binary harvest covering two Knot DNS
# utilities not previously covered (existing _keymgr, _kdig, _khost,
# _kjournalprint, _knot from earlier rounds). Both share the
# `-c/--config`/`-C/--confdb` Knot conf-source flag pair.

local -a _common_conf
_common_conf=(
  '(-c --config)'{-c,--config}'=[use a textual configuration file (default knot.conf)]:file:_files'
  '(-C --confdb)'{-C,--confdb}'=[use a binary configuration database directory]:dir:_directories'
)

case $service in

  kcatalogprint)
    # Print zone catalog stored in a catalog database.
    _arguments -s -S \
      $_common_conf \
      '(-D --dir)'{-D,--dir}'=[catalog database path (uses default config)]:path:_directories' \
      '(-a --catalog)'{-a,--catalog}'=[filter by catalog zone name]:zone:' \
      '(-m --member)'{-m,--member}'=[filter by member zone name]:zone:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version (-VV for compile-time config)]'
    ;;

  kzonesign)
    # DNSSEC signing utility — sign zone files, or verify existing
    # signatures, against the keymgr KASP database / Knot config.
    _arguments -s -S \
      $_common_conf \
      '(-o --outdir)'{-o,--outdir}'=[output directory for signed zone files]:dir:_directories' \
      '(-r --rollover)'{-r,--rollover}'[allow key roll-overs and NSEC3 re-salt]' \
      '(-v --verify)'{-v,--verify}'[validate zone signing instead of signing]' \
      '(-t --time)'{-t,--time}'=[sign/verify as if at this Unix timestamp]:timestamp:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-V,--version}'[show version]' \
      '*:zone name:'
    ;;

esac
