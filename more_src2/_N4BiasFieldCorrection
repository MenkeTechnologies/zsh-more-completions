#compdef N4BiasFieldCorrection
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/N4BiasFieldCorrection.cxx — N4 inhomogeneity correction (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-i --input-image)'{-i+,--input-image=}'[input image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-x --mask-image)'{-x+,--mask-image=}'[mask image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-r --rescale-intensities)'{-r+,--rescale-intensities=}'[rescale intensities after correction (0/1)]:n:(0 1)' \
    '(-w --weight-image)'{-w+,--weight-image=}'[weight image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-s --shrink-factor)'{-s+,--shrink-factor=}'[shrink factor (default 4)]:n:_default' \
    '(-c --convergence)'{-c+,--convergence=}'[convergence spec [iters,threshold]]:spec:_default' \
    '(-b --bspline-fitting)'{-b+,--bspline-fitting=}'[B-spline fitting [order,distance]]:spec:_default' \
    '(-t --histogram-sharpening)'{-t+,--histogram-sharpening=}'[histogram sharpening [bias-fwhm,wiener-noise,bins]]:spec:_default' \
    '(-o --output)'{-o+,--output=}'[output image]:file:_files' \
    '(- *)'{-v,--version}'[print version]' \
    '--verbose=[verbosity level]:n:(0 1 2)' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
