#compdef kx
# Documentation: https://github.com/saiya/kx
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kx: kubeconfig context switcher (saiya/kx). Flags taken from the
# upstream README usage section.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --current)'{-c,--current}'[show current context]' \
  '(-u --unset)'{-u,--unset}'[unset current context]' \
  '*:context name:' && ret=0

return ret
