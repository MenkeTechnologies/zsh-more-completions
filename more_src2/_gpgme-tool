#compdef gpgme-tool
# Documentation: gpgme-tool --help (gpgme)
# Source: GnuPG GPGME gpgme-tool — Assuan server exposing GPGME operations.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-s --server)'{-s,--server}'[server mode]' \
    '--gpg-binary=[FILE for the GPG backend]:file:_files' \
    '(- *)--lib-version[show GPGME library version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:command:' \
    && ret=0

return ret
