#compdef plutil
# Documentation: https://www.unix.com/man-page/osx/1/plutil/
# Source: Apple macOS — property-list utility (lint / convert / print).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show usage]' \
    '-p[print plist in human-readable form]' \
    '-lint[check files for syntax errors]' \
    '-convert[convert file to format]:format:(xml1 binary1 json swift objc)' \
    '-s[do not print anything on success]' \
    '-r[for JSON, add whitespace+indentation]' \
    '-o[alternate output path]:path:_files' \
    '-e[alternate output extension]:ext:' \
    '*:plist file:_files -g "*.plist"' \
    && ret=0

return ret
