#compdef fabio
# Documentation: https://github.com/fabiolb/fabio/blob/master/config/load.go
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fabio uses Go-style single-dash long flags (parsed by flag package).

_arguments -s -S \
  '-h[show help]' \
  '-v[show version]' \
  '-cfg=[config file path or URL]:file:_files' \
  '-insecure[allow fabio to run as root]' \
  '-proxy.addr=[listener config]:addr:' \
  '-proxy.strategy=[load balancing strategy]:strategy:(rnd rr)' \
  '-proxy.matcher=[path matching algorithm]:matcher:(prefix glob iprefix)' \
  '-proxy.maxconn=[max cached connections]:n:' \
  '-proxy.noroutestatus=[status code for invalid route]:code:' \
  '-proxy.shutdownwait=[graceful shutdown duration]:duration:' \
  '-proxy.dialtimeout=[backend dial timeout]:duration:' \
  '-proxy.responseheadertimeout=[response header timeout]:duration:' \
  '-proxy.keepalivetimeout=[keep-alive timeout]:duration:' \
  '-proxy.idleconntimeout=[idle conn timeout]:duration:' \
  '-proxy.readtimeout=[read timeout]:duration:' \
  '-proxy.writetimeout=[write timeout]:duration:' \
  '-proxy.flushinterval=[flush interval for streaming]:duration:' \
  '-proxy.cs=[certificate sources]:value:' \
  '-proxy.auth=[auth schemes]:value:' \
  '-proxy.localip=[fabio address in Forward headers]:ip:' \
  '-proxy.gzip.contenttype=[regexp of content types to compress]:regexp:' \
  '-log.level=[log level]:level:(TRACE DEBUG INFO WARN ERROR FATAL)' \
  '-log.access.format=[access log format]:format:' \
  '-log.access.target=[access log target]:target:' \
  '-log.routes.format=[routing table update log format]:format:' \
  '-metrics.target=[metrics backend]:target:(stdout graphite statsd dogstatsd circonus prometheus)' \
  '-metrics.prefix=[metric name prefix]:prefix:' \
  '-metrics.interval=[reporting interval]:duration:' \
  '-registry.backend=[service registry backend]:backend:(consul static file custom)' \
  '-registry.file.path=[static routes file]:file:_files' \
  '-registry.consul.addr=[consul agent address]:addr:' \
  '-registry.static.routes=[static routes]:routes:' \
  '-ui.addr=[admin UI listen address]:addr:' \
  '-ui.color=[admin UI color]:color:' \
  '-ui.title=[admin UI title]:title:' \
  '-ui.access=[admin UI access mode]:mode:(ro rw)' \
  '-profile.mode=[profiling mode]:mode:(cpu mem block mutex)' \
  '-profile.path=[profile output path]:path:_files -/' \
  '*::args: _default'
