#compdef mistral-cli mi
# Documentation: https://www.npmjs.com/package/mistral-cli
# Reference accessed: 2026-05-23
# Verified: npx mistral-cli --help.

# Zsh completion for mistral-cli - Mistral AI terminal chat CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-k --api-key)'{-k+,--api-key=}'[Mistral API key]:key:' \
  '(-m --model)'{-m+,--model=}'[model to use]:model:' \
  '(-t --temperature)'{-t+,--temperature=}'[temperature]:value:' \
  '(-s --single-message)'{-s,--single-message}'[single message and exit]' \
  '--no-history[do not include chat history]' \
  '--max-tokens[maximum response tokens]:count:' && ret=0

return ret
