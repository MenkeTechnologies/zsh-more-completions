#compdef faillock
# Documentation: man faillock(8)
# Source: linux-pam/linux-pam modules/pam_faillock/main.c (master) — view/reset auth fail counters (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--conf=[pam_faillock.conf path]:file:_files' \
    '--dir=[tally directory]:dir:_files -/' \
    '--user=[restrict to user]:user:_users' \
    '--reset[reset tally for user (or all)]' \
    '--legacy-output[use legacy tally output format]' \
    && ret=0

return ret
