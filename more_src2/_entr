#compdef entr
# Documentation: https://eradman.com/entrproject/entr.1.html
# Source: eradman/entr — run arbitrary commands when files change (BSD/Linux/macOS).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[respond to all events while utility is running]' \
    '-c[clear screen before invoking utility]' \
    '-d[track directories of input files; exit on new file]' \
    '-n[non-interactive mode]' \
    '-p[postpone first execution until a file is modified]' \
    '-r[reload a persistent child process]' \
    '-s[evaluate first argument with $SHELL]' \
    '-x[format custom exit-status messages via awk]' \
    '-z[exit after the utility completes]' \
    '*:utility:_command_names -e' \
    && ret=0

return ret
