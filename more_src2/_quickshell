#compdef quickshell qs
# _quickshell — outfoxxed quickshell QtQuick-based Wayland desktop shell scriptable in QML (quickshell team, C++); custom argparse
# upstream: https://git.outfoxxed.me/outfoxxed/quickshell

_quickshell() {
    local -a sub=(
        'kill:kill running instance'
        'list:list running instances'
        'log:show logs'
        'msg:send IPC message'
        'replace:replace running instance'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--path=+[shell path]:file:_files -g "*.qml"' \
        '-p+[shell path]:file:_files -g "*.qml"' \
        '--config=+[config file]:file:_files -g "*.qml"' \
        '-c+[config file]:file:_files -g "*.qml"' \
        '--manifest=+[manifest file]:file:_files' \
        '-m+[manifest file]:file:_files' \
        '--current[use current shell]' \
        '--instance=+[instance id]:str:' \
        '-i+[instance id]:str:' \
        '--id=+[shell id]:str:' \
        '--no-detach[do not detach]' \
        '--no-color[disable color]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quickshell subcommand' sub ;;
        args)
            case $words[1] in
                msg) _arguments \
                    '--instance=+[instance id]:str:' \
                    '*:target.method args:' ;;
                log) _arguments \
                    '--follow[follow]' \
                    '-f[follow]' \
                    '--tail=+[lines]:n:' \
                    '--instance=+[instance id]:str:' ;;
                kill|replace) _arguments '--instance=+[instance id]:str:' ;;
            esac
            ;;
    esac
}

_quickshell "$@"
