#compdef koka
# Documentation: https://raw.githubusercontent.com/koka-lang/koka/master/src/Compile/Options.hs
# Reference accessed: 2026-05-19
# Verified: upstream koka GetOpt option table in src/Compile/Options.hs.

# Zsh completion for koka (effect-typed functional language compiler)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-? -h --help)'{'-?',-h,--help}'[show this information]' \
  '--version[show the compiler version]' \
  '(-p --prompt)'{-p,--prompt}'[interactive mode]' \
  '--language-server[language server mode]' \
  '(-j --jobs)'{-j+,--jobs=}'[maximum concurrency (16)]:n:' \
  '(-i --include)'{-i,--include=}'[add dirs to module search path]:dir:_files -/' \
  '(-o --output)'{-o,--output=}'[write executable to file]:file:_files' \
  '(-O --optimize)'{-O+,--optimize=}'[optimize (0=default,1=space,2=full,3=aggressive)]:level:(0 1 2 3)' \
  '(-e --execute)'{-e,--execute}'[compile and execute]' \
  '(-c --compile)'{-c,--compile}'[only compile, do not execute (default)]' \
  '(-v --verbose)'{-v+,--verbose=}'[verbosity n (0=quiet,1=default,2=trace)]:n:(0 1 2)' \
  '(-l --library)'{-l,--library}'[generate a library]' \
  '--target=[compilation target]:target:(c c64 c32 c64c js jsnode jsweb wasm wasm32 wasm64 wasmjs wasmweb cs)' \
  '--buildtag=[set build variant tag]:tag:' \
  '--builddir=[build under dir]:dir:_files -/' \
  '--buildname=[base name of the final output]:name:' \
  '--buildhash[use hash in build directory name]' \
  '--outputdir=[write intermediate files in dir]:dir:_files -/' \
  '--libdir=[object library dir]:dir:_files -/' \
  '--sharedir=[source library dir]:dir:_files -/' \
  '--cc=[use cmd as the C backend compiler]:cmd:_command_names' \
  '--ccincdir=[search dirs for headers]:dirs:' \
  '--cclibdir=[search dirs for libraries]:dirs:' \
  '--cclib=[link with system libs]:libs:' \
  '--ccopts=[pass opts to C backend compiler]:opts:' \
  '--cclinkopts=[pass opts to C backend linker]:opts:' \
  '--cclibpath=[link with libraries lpath]:lpath:' \
  '--vcpkg=[vcpkg root directory]:dir:_files -/' \
  '--vcpkgtriplet=[vcpkg target triplet]:triplet:' \
  '--conan=[conan command]:cmd:_command_names' \
  '--csc=[use cmd as the csharp backend compiler]:cmd:_command_names' \
  '--node=[use cmd to execute node]:cmd:_command_names' \
  '--wasmrun=[use cmd to execute wasm]:cmd:_command_names' \
  '--editor=[use cmd as editor]:cmd:_command_names' \
  '--stack=[set stack size]:size:' \
  '--heap=[set reserved heap size]:size:' \
  '--output-entry=[name of the generated main entrypoint]:name:' \
  '--main-entry=[name of the main entrypoint function]:name:' \
  '--color=[set colors or a theme]:colors:(light dark)' \
  '--redirect=[redirect output to file]:file:_files' \
  '--console=[console output format]:fmt:(ansi html raw)' \
  '--lsport=[language server localhost port]:port:' \
  '--lsstdio[use language server over stdio]' \
  '--html[generate documentation]' \
  '--htmlbases=[set link prefixes for documentation]:bases:' \
  '--htmlcss=[set link to the css documentation style]:link:' \
  '--showtime[show elapsed time and rss after evaluation]' \
  '--showspan[show ending row/column too on errors]' \
  '--showkindsigs[show kind signatures of type definitions]' \
  '--showtypesigs[show type signatures of definitions]' \
  '--showhiddentypesigs[show hidden type signatures of definitions]' \
  '--showsynonyms[show expanded type synonyms in types]' \
  '--showcore[show core]' \
  '--showicore[show initial core]' \
  '--showfcore[show final core]' \
  '--showcoretypes[show full types in core]' \
  '--showtypeids[show numeric type variable ids]' \
  '--showcs[show generated c#]' \
  '--showjs[show generated javascript]' \
  '--showc[show generated C]' \
  '--core[generate a core file]' \
  '--checkcore[check generated core]' \
  '*:source file:_files -g "*.kk(N)"' && ret=0

return ret
