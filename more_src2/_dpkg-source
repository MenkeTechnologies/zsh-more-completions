#compdef dpkg-source
# Documentation: https://manpages.debian.org/dpkg-source
# Source: guillemj/dpkg scripts/dpkg-source.pl — Debian source package builder/extractor (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-x --extract)'{-x,--extract}'[extract source package]' \
    '(-b --build)'{-b,--build}'[build source package]' \
    '--print-format[print source package format]' \
    '--before-build[run before build]' \
    '--after-build[run after build]' \
    '--commit[commit changes]' \
    '(-? --help)'{-\?,--help}'[show help]' \
    '--version[show version]' \
    '--format=-[source package format]:format:(1.0 2.0 3.0 (native) (quilt) (git))' \
    '(-Z --compression)'{-Z+,--compression=}'[compression]:method:(gzip bzip2 xz lzma zstd)' \
    '(-z --compression-level)'{-z+,--compression-level=}'[compression level]:level:_default' \
    '--threads-max=-[max compression threads]:n:_default' \
    '-c+[control file]:file:_files' \
    '-l+[changelog file]:file:_files' \
    '-F+[changelog format]:format:_default' \
    '*-D-[override field]:field:_default' \
    '*-U-[remove field]:field:_default' \
    '(-i --diff-ignore)'{-i-,--diff-ignore=-}'[ignore diff regex]::regex:_default' \
    '--extend-diff-ignore=-[extend diff ignore regex]:regex:_default' \
    '*'{-I-,--tar-ignore=-}'[tar ignore pattern]::pattern:_default' \
    '--no-copy[do not copy upstream tarballs]' \
    '--no-check[do not check signatures and checksums]' \
    '--no-overwrite-dir[do not overwrite existing dir]' \
    '--no-vendor-certs[do not use vendor certs]' \
    '*--signer-certs=-[add cert to chain]:file:_files' \
    '--require-valid-signature[require valid signature]' \
    '--require-strong-checksums[require strong checksums]' \
    '*-V-[substvar]:name=value:_default' \
    '-T+[load substvars file]:file:_files' \
    '-q[quiet warnings]' \
    '1::source package or directory:_files' \
    && ret=0

return ret
