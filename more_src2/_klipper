#compdef klipper
# Documentation: https://github.com/KDE/plasma-workspace/blob/master/klipper/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream plasma-workspace klipper uses KAboutData +
# QApplication standard command line only; no klipper-specific flags.
# Corrected from prior file: this is KDE Plasma's clipboard manager,
# NOT the Klipper3d 3D-printer host (that is klippy).
# STUB: KDE/Qt standard options only.

# klipper: KDE Plasma clipboard manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including Qt]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' && ret=0
return ret
