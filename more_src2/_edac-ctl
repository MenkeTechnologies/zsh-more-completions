#compdef edac-ctl
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man8/edac-ctl.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show usage information]' \
  '--mainboard[display mainboard vendor and model]' \
  '--status[show whether EDAC drivers are loaded]' \
  '--register-labels[register motherboard DIMM labels into EDAC sysfs]' \
  '--print-labels[print configured labels and labels registered with EDAC]' \
  '--labeldb=[alternate location for the labels database]:file:_files' && ret=0

return ret
