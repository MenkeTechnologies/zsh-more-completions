#compdef esrally
# Documentation: https://esrally.readthedocs.io/en/latest/command_line_reference.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'race:run a benchmark'
  'compare:compare two race results (tournament mode)'
  'list:list configurations (tracks/cars/pipelines/races/telemetry)'
  'info:show information about a track or challenge'
  'render-track:render a track Jinja2 template to JSON'
  'create-track:scaffold a new track from data in a cluster'
  'install:install Elasticsearch from a binary or build'
  'start:start an installed Elasticsearch node'
  'stop:stop a running Elasticsearch node'
  'download:download an Elasticsearch distribution'
  'build:build Elasticsearch (and plugins) from source'
  'delete:delete a race and metrics records'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--quiet[suppress output]' \
  '--target-os=[target OS]:os:(linux darwin windows)' \
  '--target-arch=[target architecture]:arch:(x86_64 aarch64)' \
  '--distribution-version=[Elasticsearch distribution version]:version' \
  '--runtime-jdk=[major JDK version]:n' \
  '--offline[run offline]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'esrally command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (race)
        _arguments \
          '--track=[track name]:track' \
          '--track-repository=[track repository]:repo' \
          '--track-revision=[track revision]:revision' \
          '--track-path=[local track path]:path:_files -/' \
          '--challenge=[challenge name]:challenge' \
          '--include-tasks=[task subset]:tasks' \
          '--exclude-tasks=[exclude tasks]:tasks' \
          '*--car=[Elasticsearch config car]:car' \
          '--car-params=[car parameters]:params' \
          '*--telemetry=[telemetry devices]:devices' \
          '--telemetry-params=[telemetry params]:params' \
          '--pipeline=[Rally pipeline]:pipeline:(from-distribution from-sources benchmark-only)' \
          '*--target-hosts=[target ES hosts]:hosts' \
          '*--client-options=[client options]:options' \
          '--user-tags=[user tags for race]:tags' \
          '--report-file=[report output file]:file:_files' \
          '--report-format=[report format]:format:(markdown csv)' \
          '--track-params=[track parameters]:params' \
          '--load-driver-hosts=[load driver hosts]:hosts' \
          '--on-error=[error mode]:mode:(continue abort)' \
          '--kill-running-processes[kill leftover processes]' \
          '--test-mode[short test run]' \
          '--enable-driver-profiling[enable load driver profiling]' \
          '--enable-assertions[enable assertions]' \
          '--race-id=[race id]:id' && ret=0 ;;
      (compare)
        _arguments \
          '--baseline=[baseline race id]:id' \
          '--contender=[contender race id]:id' \
          '--report-file=[report file]:file:_files' \
          '--report-format=[report format]:format:(markdown csv)' && ret=0 ;;
      (list)
        _arguments \
          '*::category:(telemetry tracks pipelines races cars elasticsearch-plugins annotations)' \
          '--limit=[max records]:n' && ret=0 ;;
      (info)
        _arguments \
          '--track=[track name]:track' \
          '--track-path=[local track path]:path:_files -/' \
          '--challenge=[challenge name]:challenge' && ret=0 ;;
      (download)
        _arguments \
          '--distribution-version=[ES version]:version' \
          '--target-arch=[architecture]:arch:(x86_64 aarch64)' \
          '--target-os=[OS]:os:(linux darwin windows)' && ret=0 ;;
      (install)
        _arguments \
          '--distribution-version=[ES version]:version' \
          '--node-name=[node name]:name' \
          '--network-host=[network host]:host' \
          '--master-nodes=[master nodes]:list' \
          '--seed-hosts=[seed hosts]:list' \
          '--http-port=[HTTP port]:port' && ret=0 ;;
      (start|stop)
        _arguments \
          '--installation-id=[installation id]:id' \
          '--race-id=[race id]:id' && ret=0 ;;
      (build)
        _arguments \
          '--revision=[ES revision]:revision' \
          '--elasticsearch-plugins=[plugin list]:plugins' \
          '--target-arch=[architecture]:arch' \
          '--target-os=[OS]:os' && ret=0 ;;
      (delete)
        _arguments \
          '--race-id=[race id]:id' && ret=0 ;;
      (render-track)
        _arguments \
          '--track=[track name]:track' \
          '--track-path=[local track path]:path:_files -/' \
          '--track-params=[track parameters]:params' \
          '--output-path=[output path]:path:_files -/' && ret=0 ;;
      (create-track)
        _arguments \
          '--track=[track name]:track' \
          '--output-path=[output path]:path:_files -/' \
          '--indices=[indices]:list' \
          '--data-streams=[data streams]:list' \
          '--batch-size=[batch size]:n' \
          '--target-hosts=[target hosts]:hosts' \
          '--client-options=[client options]:options' && ret=0 ;;
    esac ;;
esac

return ret
