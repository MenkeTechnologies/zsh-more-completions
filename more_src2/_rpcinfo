#compdef rpcinfo
# _rpcinfo — OpenBSD rpcinfo (interrogate a portmapper/RPC service; -p dumps the registered programs on a host, -t/-u send a TCP/UDP RPC null call, -b broadcasts, -d deletes a registration)
# upstream: https://github.com/openbsd/src (usr.bin/rpcinfo)
# Flags from usr.bin/rpcinfo/rpcinfo.8 on tip.

_rpcinfo() {
    _arguments \
        '-b+[broadcast call: program version]:program version:' \
        '-d+[delete program version]:program version:' \
        '-p[show registered programs on host]' \
        '-s+[show services: program version port]:program version port:' \
        '-n+[port number for -t/-u]:port:' \
        '-t+[TCP RPC null call to host program]:host program:' \
        '-u+[UDP RPC null call to host program]:host program:' \
        '*:host:_hosts'
}

_rpcinfo "$@"
