#compdef grails-shell-cli
# Documentation: https://docs.grails.org/latest/guide/commandLine.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-v,--verbose}'[verbose output]' \
  '--config=[config file]:file:_files' && ret=0

return ret
