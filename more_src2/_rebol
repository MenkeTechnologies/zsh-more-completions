#compdef rebol rebol3 r3
# =============================================================================
# rebol — the REBOL [R3] Language Interpreter and Run-time Environment.
#         REBOL (Relative Expression Based Object Language) is a domain-
#         specific language for network messaging and distributed computing
#         created by Carl Sassenrath in 1997 (the same Carl Sassenrath who
#         designed the original Amiga operating system kernel exec.library
#         in 1985 and later worked on BeOS at Be, Inc.).  REBOL pioneered
#         the "data IS code, code IS data" philosophy that influenced
#         later languages including Red, Boron, Topaz, Arturo, and Rye.
#         REBOL [R3] is the third-generation reference implementation
#         open-sourced under Apache-2.0 in 2012 after the REBOL Technologies
#         company decided to publish the source.
#
# Author:  Carl Sassenrath (REBOL Technologies)
# Source:  https://github.com/rebol/rebol
# CLI:     src/os/host-args.c (Parse_Args entry point)
# Library: hand-rolled C with bitfield options + tri-prefix - / -- / + flags
# License: Apache-2.0
# Status:  Original REBOL [R3] is in maintenance mode; active forks include
#          Red (R/S compiler at github.com/red/red), Ren-C (Atronix Engineering
#          fork at github.com/metaeducation/ren-c), and Rebol3 community
#          builds at github.com/Oldes/Rebol3 — 885+ stars on the original.
#          REBOL remains widely cited as an influence on dialect-driven and
#          data-as-code language design.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — REBOL IS NOW LANGUAGE 46
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 45 to 46 documented languages.  REBOL joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, F#, Jakt,
# Ur/Web, Beluga, and now REBOL.  rebol is documented as the FIRST REBOL CLI
# library variant in the taxonomy (hand-rolled C with bitfield-OR'd flags +
# tri-prefix - / -- / + convention) — bringing the total to 201 cross-language
# CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS REBOL AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# REBOL is a language designed for "exchanging data and code over the network"
# (Carl Sassenrath's original framing).  REBOL programs are sequences of
# VALUES that are EVALUATED LEFT-TO-RIGHT against a CONTEXT.  Values can be
# literals (numbers, strings, dates, money, URLs, emails, IP addresses,
# tuples) or BLOCKS (`[ ... ]` syntax) of more values.  Functions, when
# invoked, consume subsequent values as arguments.  This gives REBOL a
# uniformly polymorphic syntax where the same parser handles "data" and
# "program" because there is no distinction.
#
# REBOL is distinct from every other language documented in the corpus
# because:
#
#   * It is the FIRST documented language with NATIVE FIRST-CLASS LITERALS
#     for non-string structured data types in the SOURCE LANGUAGE.  REBOL
#     source code can contain `1.2.3.4` (IP address literal), `1-Jan-2026`
#     (date literal), `$3.50` (money literal), `12:34:56` (time literal),
#     `1.2.3` (tuple/version literal), `user@example.com` (email literal),
#     `https://example.com` (URL literal), `#"a"` (char literal),
#     `#{DEADBEEF}` (binary literal), `%file.txt` (file path literal) — all
#     parsed as distinct typed values in the source grammar, not as strings
#     to be parsed later.  No other documented language has this many
#     first-class literal forms baked into the lexer.
#   * It is the FIRST documented language whose CORE DATATYPE COUNT exceeds
#     50 distinct types in the runtime, including the literal types above
#     plus REBOL-specific types like `port!` (I/O abstraction), `function!`,
#     `native!`, `op!` (binary operator), `routine!` (foreign function),
#     `error!`, `event!`, `image!`, `vector!`, `bitset!`, `pair!`
#     (x,y coordinate), `tag!` (HTML/XML-like tag), `refinement!`
#     (`/option`-style function modifier), `set-word!` / `get-word!` /
#     `lit-word!` (semantic distinctions on word references).
#   * It has DIALECTS — REBOL provides a mechanism for defining DOMAIN-
#     SPECIFIC SUB-LANGUAGES within the host syntax.  Built-in dialects
#     include PARSE (PEG-style grammar parsing), VID (Visual Interface
#     Dialect for GUIs), DRAW (vector graphics), and MAKE-DOC (markup).
#     User-defined dialects use the same source syntax but apply
#     domain-specific evaluation rules.
#   * It compiles to NO MACHINE CODE — REBOL is a tree-walking interpreter.
#     The R3 codebase is small (under 30k LOC of C) and embeddable.
#   * It uses REFINEMENTS for function options — `find/case/last block "x"`
#     applies `find` with `/case` (case-sensitive) and `/last` (search from
#     end) refinements.  Refinements are syntactically distinct from
#     positional arguments at the call site, which makes REBOL function
#     calls self-documenting in a way that positional/keyword-argument
#     languages cannot match.
#
# -----------------------------------------------------------------------------
# REBOL'S CLI LIBRARY — HAND-ROLLED C WITH BITFIELD OPTIONS + TRI-PREFIX FLAGS
# -----------------------------------------------------------------------------
#
# REBOL's command-line argument parser is a hand-rolled C implementation in
# src/os/host-args.c written by Carl Sassenrath himself.  The header comment
# states the house style: "Keep code clear and simple. Document unusual code,
# reasoning, or gotchas. Use same style for code, vars, indent(4), comments,
# etc. Keep in mind Linux, OS X, BSD, big/little endian CPUs. Test
# everything, then test it again."
#
# Defining characteristics:
#
#   1. THREE SEPARATE FLAG TABLES — REBOL parses argv with three distinct
#      string-or-character lookup tables:
#
#        arg_words[]   — "--longname" flags in ALPHA SORTED order
#        arg_chars[]   — "-x" short flags in ALPHA SORTED order
#        arg_chars2[]  — "+x" short flags in ALPHA SORTED order
#
#      Each table entry is { name/char, flag-bitmask }.  Tables MUST stay
#      alpha-sorted because lookup uses early-out on strncmp negative.
#
#   2. BITFIELD-OR'd OPTIONS — every flag has a `RO_*` integer constant
#      that is BIT-OR'd into a single `int options` field in REBARGS.
#      The runtime can then check `if (options & RO_QUIET) { ... }` to
#      dispatch on configuration.  This is the CLASSIC C BITFIELD OPTIONS
#      pattern used by Unix programs since the 1970s.
#
#   3. EXTENDED-ARG FLAG (RO_EXT) — some flags need a following value
#      (--script FILE, --do CODE, --boot PATH).  Their RO_* constant has
#      the RO_EXT bit set; the parser strips RO_EXT, dispatches on the
#      remaining bits via `Get_Ext_Arg`, and stores the value into the
#      appropriate REBARGS field (rargs->script, rargs->do_arg, etc.).
#      The trick: if the next argv slot starts with `-`, the value is
#      MISSING and the parser falls through to treating the flag as
#      RO_HELP (showing usage).
#
#   4. TRI-PREFIX CONVENTION — the parser accepts THREE distinct prefix
#      characters:
#
#        --word      Long-form flag (looked up in arg_words[])
#        -x          Short-form flag (looked up in arg_chars[])
#        +x          Plus-form flag (looked up in arg_chars2[])
#
#      The "+x" prefix exists almost solely to allow `+s` (RO_SECURE_MAX)
#      as a counterpart to `-s` (RO_SECURE_MIN).  This is similar to but
#      DISTINCT FROM Beluga's tri-prefix convention (R460) where `+flag`
#      means "turn ON" and `-flag` means "turn OFF" of the same toggle.
#      REBOL's convention is more specific: `-` and `+` indicate the LEVEL
#      of a single concept (security minimum vs maximum), not the
#      direction of a toggle.
#
#   5. CHAR-BY-CHAR SHORT FLAG PARSING — `-qcv` is parsed as three separate
#      short flags `-q`, `-c`, `-v` in sequence, each looked up in
#      arg_chars[].  This matches POSIX getopt behavior for short flag
#      bundling.
#
#   6. POSITIONAL FALLBACK — any argv element that does NOT start with `-`
#      or `+` is treated as the SCRIPT FILE NAME (first positional) or
#      appended to the SCRIPT ARGS string (subsequent positionals).
#      Positional args go into rargs->args as a single space-joined string
#      passed to the REBOL script via `system/script/args`.
#
#   7. NULL-TERMINATED TABLE — both flag tables end with a sentinel entry
#      `{"", 0}` or `{'\0', 0}`; the parser iterates while flag != 0.
#
#   8. SHELL-INPUT TOLERANCE — special handling for `\r` and `\n` at the
#      START of an arg returns RO_IGNORE.  Comment notes "Some shells will
#      pass us the line terminator. Ignore it." — defensive coding from
#      Sassenrath's Amiga-era experience with weird shell behavior.
#
# CONTRAST WITH OTHER HAND-ROLLED C CLI PARSERS DOCUMENTED IN THE CORPUS
#
#   * GNU getopt / getopt_long              — single-table state-machine
#                                              (POSIX/GNU canonical)
#   * gcc / clang driver                     — hand-rolled spec file driver
#                                              with response files
#   * mold / wild / GNU ld (R454)            — linker-convention parser
#                                              with state stack semantics
#   * Beluga main.ml (R460, OCaml)           — tri-prefix +/- match dispatch
#   * REBOL host-args.c (THIS, C)            — tri-prefix - / -- / + with
#                                              bitfield OR'd options +
#                                              three separate flag tables
#   * SQLite sqlite3 main.c                  — single-table strcmp dispatch
#   * Lua command-line (lua.c)               — single-pass switch loop
#   * Tcl interpreter (tclMain.c)            — single-pass strcmp dispatch
#
# REBOL's parser is unique among documented C parsers in combining ALL of:
# (a) three separate flag tables (long, short-minus, short-plus),
# (b) bitfield-OR'd flag accumulation,
# (c) extended-arg flag bit (RO_EXT) with magic value extraction,
# (d) char-by-char short flag bundling,
# (e) positional fallback into a space-joined args string.
#
# -----------------------------------------------------------------------------
# REBOL'S CLI SURFACE (verbatim from src/os/host-args.c flag tables)
# -----------------------------------------------------------------------------
#
# USAGE:
#   rebol [options] [script-file] [script-args...]
#
# Long-form options (--word):
#   --args VAL          Pass arguments to the script (EXT, takes value)
#   --boot PATH         Specify alternate boot script (EXT)
#   --cgi               CGI mode (implies --quiet)
#   --debug LEVEL       Set debug level (EXT)
#   --do CODE           Evaluate CODE as a REBOL expression (EXT)
#   --halt              Halt on errors (do not continue past first error)
#   --help              Show help and exit
#   --import LIB        Import a module before running script (EXT)
#   --quiet             Suppress banner and prompt
#   --script FILE       Run FILE as a REBOL script (EXT)
#   --secure LEVEL      Set security level (EXT)
#   --trace             Enable trace output
#   --verbose           Enable verbose output
#   --version VER       Specify required REBOL version (EXT)
#
# Short-form options (-c):
#   -?                  Show help and exit
#   -V                  Show version and exit
#   -b                  Boot script (EXT, same as --boot)
#   -c                  CGI mode (implies -q)
#   -h                  Halt on errors
#   -q                  Quiet (no banner)
#   -s                  Security minimum
#   -t                  Trace mode
#   -v                  Show version (alias for -V)
#   -w                  No-window mode (suppress GUI on REBOL/View builds)
#
# Plus-form options (+c):
#   +s                  Security maximum (counterpart to -s)
#
# Positional:
#   script-file         First non-flag argv is the REBOL script path
#   script-args...      Remaining argv joined into system/script/args
#
# =============================================================================

_rebol() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a long_flags short_flags plus_flags secure_levels

    secure_levels=(
        'none:disable all security checks'
        'low:permissive (default for interactive)'
        'med:moderate restrictions'
        'high:strict (default for cgi)'
        'throw:throw error on security violation'
        'quit:exit on security violation'
    )

    _arguments -s \
        '--args[pass arguments to script]:script args:' \
        '--boot[alternate boot script]:boot path:_files' \
        '--cgi[CGI mode (implies --quiet)]' \
        '--debug[set debug level]:debug level:' \
        '--do[evaluate REBOL expression]:expression:' \
        '--halt[halt on errors]' \
        '--help[show help and exit]' \
        '--import[import module before running]:module:_files -g "*.r"' \
        '--quiet[suppress banner and prompt]' \
        '--script[run file as REBOL script]:script:_files -g "*.(r|reb|r3)"' \
        '--secure[set security level]:level:->secure' \
        '--trace[enable trace output]' \
        '--verbose[enable verbose output]' \
        '--version[require specific REBOL version]:version:' \
        '-\?[show help and exit]' \
        '-V[show version and exit]' \
        '-b[boot script (== --boot)]:boot path:_files' \
        '-c[CGI mode]' \
        '-h[halt on errors]' \
        '-q[quiet mode]' \
        '-s[security minimum (paired with +s for max)]' \
        '-t[trace mode]' \
        '-v[show version (== -V)]' \
        '-w[no-window mode (REBOL/View)]' \
        '+s[security maximum (paired with -s for min)]' \
        '*:script file or args:_files -g "*.(r|reb|r3)"' \
        && ret=0

    case $state in
        (secure)
            _describe -t secure 'security level' secure_levels && ret=0
            ;;
    esac

    return ret
}

_rebol "$@"
