#compdef jwm
# Documentation: https://man.archlinux.org/man/jwm.1
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Corrected from prior file: JWM uses single-dash options ONLY.
# Removed fabricated GNU double-dash forms (--help, --version,
# --reload, --config, --parse, --restart) and the invented -c flag.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[display a help message and exit]' \
  '(- *)-v[display version information and exit]' \
  '-display[specify the display to use]:display:' \
  '-exit[exit JWM by sending _JWM_EXIT to the root window]' \
  '-f[specify an alternate configuration file to use]:file:_files' \
  '-p[parse the configuration file and exit]' \
  '-restart[restart JWM by sending _JWM_RESTART to the root window]' \
  '-reload[reload menus by sending _JWM_RELOAD to the root window]' && ret=0

return ret
