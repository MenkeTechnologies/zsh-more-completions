#compdef gen-graphql
# _gen-graphql — generate GraphQL schema from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/graphqlgen.py (click).

_gen-graphql() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.graphql"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(graphql)'
        '--strict-naming[enforce strict GraphQL naming rules]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '--useuris[use URI references for terms]'
        '--metauris[use meta URI references]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-graphql "$@"
