#compdef erl
# Documentation: erlang.org/doc/man/erl.html
# Source: Erlang/OTP runtime launcher.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-name -sname)-name+[fully-qualified distributed node name]:name@host:' \
    '(-name -sname)-sname+[short distributed node name]:name:' \
    '-setcookie+[magic cookie for node authentication]:cookie:' \
    '-hidden[start as a hidden node]' \
    '-boot+[boot script (default start.boot)]:file:_files -g "*.boot"' \
    '*-boot_var+[expand path variable in boot scripts]:var dir:' \
    '*-config+[load config file]:file:_files -g "*.config"' \
    '-mode+[code loading mode]:mode:(interactive embedded)' \
    '*-pa+[prepend dir to code path]:dir:_files -/' \
    '*-pz+[append dir to code path]:dir:_files -/' \
    '-hosts+[IPs for boot servers]:hosts:' \
    '-noshell[start without shell]' \
    '-noinput[no input (implies -noshell)]' \
    '-detached[detach from console (daemon, implies -noinput)]' \
    '-extra[all following args are plain]' \
    '*-s+[call M F A after init]:M F A:' \
    '*-run+[call M F A (string args)]:M F A:' \
    '*-eval+[evaluate expression]:expr:' \
    '*-env+[set OS env variable]:VAR VALUE:' \
    '-shutdown_time+[app shutdown ms]:milliseconds:' \
    '-compile=[compile modules and exit]:modules:' \
    '-man+[show man page (Unix only)]:module:' \
    '+A+[async thread pool size 1..1024]:n:' \
    '+K+[kernel poll]:bool:(true false)' \
    '+S+[schedulers\:online]:S\:Online:' \
    '+SDcpu+[dirty CPU schedulers\:online]:S\:Online:' \
    '+SDio+[dirty I/O schedulers 1..1024]:n:' \
    '+zdbbl+[dist buffer busy limit (KB)]:size:' \
    '+c+[time correction]:bool:(true false)' \
    '+d[core dump only on internal errors]' \
    '+sbt+[scheduler bind type]:type:(u ns ts ps s nnts nnps tnnps db)' \
    '+pc+[printable char range]:range:(latin1 unicode)' \
    '+V[print emulator version]' \
    '+W+[map warning messages]:mode:(w i e)' \
    '+B+[break handler]:mode:(c d i)' \
    '*:Erlang source file:_files -g "*.{erl,beam,boot}"' \
    && ret=0

return ret
