#compdef mysqldump
# Documentation: https://dev.mysql.com/doc/refman/en/mysqldump.html
# Source: mysql/mysql-server client/mysqldump.cc — dump MySQL databases/tables (C++, my_getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-A,--all-databases}'[dump all databases]' \
    {-Y,--all-tablespaces}'[dump all tablespaces]' \
    {-y,--no-tablespaces}'[do not dump tablespaces]' \
    '--add-drop-database[add DROP DATABASE before CREATE DATABASE]' \
    '--add-drop-table[add DROP TABLE before CREATE TABLE]' \
    '--add-drop-trigger[add DROP TRIGGER before CREATE TRIGGER]' \
    '--add-drop-user[add DROP USER before CREATE USER]' \
    '--add-locks[surround INSERTs with LOCK/UNLOCK]' \
    '--allow-keywords[allow column names that are SQL keywords]' \
    '--apply-replica-statements[wrap with STOP/START REPLICA]' \
    '--apply-slave-statements[wrap with STOP/START SLAVE (deprecated)]' \
    '--bind-address=-[interface IP]:ip:_default' \
    '--character-sets-dir=-[character sets dir]:dir:_files -/' \
    '--column-statistics[include ANALYZE TABLE statements]' \
    {-i,--comments}'[add comments]' \
    '--compatible=-[output compatible with named mode]:mode:(ansi mysql323 mysql40 postgresql oracle mssql db2 maxdb no_key_options no_table_options no_field_options)' \
    '--compact[give less verbose output]' \
    {-c,--complete-insert}'[use column-named INSERTs]' \
    {-C,--compress}'[use compression]' \
    {-a,--create-options}'[include all MySQL-specific create options]' \
    {-B,--databases}'[dump several databases]' \
    '--debug=-[debug log spec]:spec:_default' \
    '--debug-check[check at exit]' \
    '--debug-info[print debug info on exit]' \
    '--default-character-set=-[charset]:charset:_default' \
    '--delete-source-logs[delete master logs after dump]' \
    '--delete-master-logs[deprecated alias]' \
    {-K,--disable-keys}'[disable keys for faster load]' \
    '--dump-replica=-[dump replica info]:n:(0 1 2)' \
    '--dump-slave=-[deprecated alias]:n:(0 1 2)' \
    {-E,--events}'[dump events]' \
    {-e,--extended-insert}'[use multiple-row INSERTs]' \
    '--fields-terminated-by=-[field terminator]:str:_default' \
    '--fields-enclosed-by=-[field enclosure]:str:_default' \
    '--fields-optionally-enclosed-by=-[optional enclosure]:str:_default' \
    '--fields-escaped-by=-[escape char]:str:_default' \
    {-F,--flush-logs}'[flush logs before starting]' \
    '--flush-privileges[FLUSH PRIVILEGES after dump]' \
    {-f,--force}'[continue even on SQL error]' \
    {-\?,--help}'[show help]' \
    '--hex-blob[dump binary as hex]' \
    {-h+,--host=}'[server host]:host:_hosts' \
    '*--ignore-error=-[errors to ignore]:err:_default' \
    '*--ignore-table=-[ignore named table]:tbl:_default' \
    '--exclude-user=-[exclude user from dump]:user:_default' \
    '--include-user=-[only dump named users]:user:_default' \
    '--insert-ignore[INSERT IGNORE instead of INSERT]' \
    '--lines-terminated-by=-[line terminator]:str:_default' \
    {-x,--lock-all-tables}'[lock ALL tables]' \
    {-l,--lock-tables}'[lock tables before dumping]' \
    {-n,--no-create-db}'[suppress CREATE DATABASE]' \
    {-t,--no-create-info}'[suppress CREATE TABLE]' \
    {-d,--no-data}'[no row data]' \
    {-N,--no-set-names}'[suppress SET NAMES]' \
    {-W,--pipe}'[use named pipes]' \
    {-P+,--port=}'[port]:port:_default' \
    '--protocol=-[connection protocol]:proto:(TCP SOCKET PIPE MEMORY)' \
    {-q,--quick}'[stream out without buffering]' \
    {-Q,--quote-names}'[quote identifiers]' \
    {-r+,--result-file=}'[output file]:file:_files' \
    {-R,--routines}'[dump routines (procedures/functions)]' \
    {-S+,--socket=}'[socket file]:file:_files' \
    {-T+,--tab=}'[separate SQL+data files per table]:dir:_files -/' \
    '--triggers[dump triggers]' \
    {-u+,--user=}'[login user]:user:_users' \
    {-v,--verbose}'[verbose mode]' \
    {-V,--version}'[show version]' \
    '--where=-[WHERE clause]:where:_default' \
    {-X,--xml}'[XML output]' \
    {-p-,--password=-}'[password]::pass:_default' \
    '*:db[.tbl ...]:_default' \
    && ret=0

return ret
