#compdef gobetween
# Documentation: https://github.com/yyyar/gobetween
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'from-file:run with config from file'
  'from-url:run with config from URL'
  'from-consul:run with config from Consul'
  'from-env:run with config from env'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.toml *.yaml *.yml *.json"' \
  '(-f --format)'{-f+,--format=}'[config format]:fmt:(toml json yaml)' \
  '--logformat=[log format]:fmt:(text json)' \
  '--loglevel=[log level]:lvl:(debug info warn error fatal)' \
  '--profiler=[profiler bind]:addr:' \
  '--api-bind=[API bind addr]:addr:' \
  '--api-cors=[CORS origins]:list:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gobetween command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (from-file)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file path]:file:_files' \
          '(-f --format)'{-f+,--format=}'[format]:fmt:(toml json yaml)' && ret=0 ;;
      (from-url)
        _arguments \
          '1:URL:' \
          '(-f --format)'{-f+,--format=}'[format]:fmt:(toml json yaml)' && ret=0 ;;
      (from-consul)
        _arguments \
          '1:consul URL:' \
          '(-f --format)'{-f+,--format=}'[format]:fmt:(toml json yaml)' \
          '(-k --key)'{-k+,--key=}'[KV key path]:key:' && ret=0 ;;
    esac ;;
esac

return ret
