#compdef nntpsend
# Documentation: man nntpsend(8)
# Source: InterNetNews/inn backends/nntpsend.in — send INN spool to remote NNTP sites (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[always rewrite (pass -a to innxmit)]' \
    '-d[debug mode, suppress log]' \
    '-D[suppress log only]' \
    '-l[log rejects (pass -l to innxmit)]' \
    '-p[purge mode (pass -p to innxmit)]' \
    '-r[skip requeue (pass -r to innxmit)]' \
    '-N[disable streaming (pass -s to innxmit)]' \
    '-c[skip CHECK (pass -c to innxmit)]' \
    '-s+[truncate size]:size:_default' \
    '-t+[connect timeout]:secs:_default' \
    '-P+[port number]:port:_default' \
    '-T+[total time limit]:secs:_default' \
    '-n[do not lock]' \
    '-w+[wait seconds]:secs:_default' \
    '*:host file pairs:_default' \
    && ret=0

return ret
