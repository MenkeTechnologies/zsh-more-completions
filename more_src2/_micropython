#compdef micropython
# Documentation: https://docs.micropython.org/en/latest/unix/quickref.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for MicroPython (unix port binary)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[show help]' \
  '-i[inspect interactively after running script]' \
  '-c+[program passed in as string]:code:' \
  '-m+[run library module as script]:module:' \
  '-O[set optimization level (stackable)]' \
  '-v[verbose output (stackable, trace imports)]' \
  '*-X+[implementation-specific option (compile-only, emit=, heapsize=, realtime)]:option:(compile-only emit=bytecode emit=native emit=viper heapsize= realtime)' \
  '*:script file:_files -g "*.py"' && ret=0

return ret
