#compdef jpegrescan
# Documentation: https://raw.githubusercontent.com/kud/jpegrescan/master/jpegrescan
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# jpegrescan in.jpg out.jpg — perl -s switch parsing: -s -i -t -a -v -q

local ret=1

_arguments \
  '-s[strip all extra markers (jpegtran -copy none)]' \
  '-i[allow optimizations incompatible with some software (implies -s)]' \
  '-t[use multiple threads (usually 3)]' \
  '-a[use arithmetic coding (unsupported by most software)]' \
  '-v[verbose output]' \
  '-q[suppress all output]' \
  '1:input jpeg:_files -g "*.(jpg|jpeg|JPG|JPEG)"' \
  '2:output jpeg:_files' && ret=0

return ret
