#compdef grsync
# Documentation: https://manpages.debian.org/bookworm/grsync/grsync.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm grsync(1) manpage OPTIONS.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# grsync: GTK GUI front-end for rsync
local curcontext="$curcontext" ret=1
_arguments -C \
  '-e[execute session and close on success]' \
  '-s[allow window to remain open after success]' \
  '-i[open import session dialog for file]:file:_files' \
  '*:session name:' && ret=0
return ret
