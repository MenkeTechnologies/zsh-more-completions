#compdef pgmtexture
# Documentation: man pgmtexture (Netpbm)
# Source: compute textural features (Haralick) from a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-d+[pixel distance for co-occurrence matrix]:d:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
