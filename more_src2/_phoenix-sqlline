#compdef sqlline phoenix-sqlline
# _phoenix-sqlline — Apache Phoenix sqlline (interactive SQL shell for HBase via Phoenix; -u JDBC URL, -n user, -p password, -d driver class, --verbose, --color, --output-format CSV|TSV|XML|JSON|table|vertical, --maxWidth, --silent, -e single statement, -f script file, --headerInterval; positional zk-quorum/conn string also accepted)
# upstream: https://github.com/apache/phoenix
# Flags from Apache Phoenix bin/sqlline on tip.

_phoenix-sqlline() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-u+[JDBC URL]:url:' \
        '-n+[user]:user:_users' \
        '-p+[password]:password:' \
        '-d+[driver class]:class:' \
        '--verbose[verbose]' \
        '--color[color]' \
        '--silent[silent]' \
        '-e+[statement]:statement:' \
        '-f+[script file]:file:_files -g "*.sql"' \
        '--output-format+[output format]:format:(CSV TSV XML JSON table vertical)' \
        '--maxWidth+[max col width]:n:' \
        '--headerInterval+[N rows]:n:' \
        '--isolation+[isolation level]:level:' \
        '*:zk-quorum or url:'
}

_phoenix-sqlline "$@"
