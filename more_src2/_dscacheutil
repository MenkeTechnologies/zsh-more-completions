#compdef dscacheutil
# Documentation: https://www.unix.com/man-page/osx/1/dscacheutil/
# Source: Apple macOS — DirectoryServices cache inspector + flush.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[list dscacheutil options]' \
    '(-cachedump -configuration -flushcache -statistics)-q[query (uses cache; falls back to live)]:category:(host user group service protocol rpc network mount printer alias bootp ethernet)' \
    '-a[query key + value (with -q)]:key:' \
    '(-q -configuration -flushcache -statistics)-cachedump[dump cache overview]' \
    '-buckets[print hash bucket usage (with -cachedump)]' \
    '-entries=-[detailed cache-entry dump (with -cachedump; optional category)]:category:(host user group service protocol rpc network mount printer alias bootp ethernet)' \
    '(-q -cachedump -flushcache -statistics)-configuration[print search policy + cache parameters]' \
    '(-q -cachedump -configuration -statistics)-flushcache[flush the entire cache (use sparingly)]' \
    '(-q -cachedump -configuration -flushcache)-statistics[print cache statistics]' \
    && ret=0

return ret
