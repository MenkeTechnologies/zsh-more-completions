#compdef mirai cargo-mirai
# _mirai — MIRAI: Rust mid-level IR abstract interpreter (facebookexperimental/MIRAI)
# upstream: https://github.com/facebookexperimental/MIRAI
# Flags from checker/src/options.rs (clap builder).

_mirai() {
    local -a args
    args=(
        '--single_func=[focus analysis on the named function (or summary key)]:name:'
        '--diag=[diagnostic verbosity]:level:(default verify library paranoid)'
        '--constant_time=[enable constant-time-security verification for the given type]:type:'
        '--body_analysis_timeout=[seconds spent analyzing a single function body (default 30)]:seconds:'
        '--crate_analysis_timeout=[seconds spent analyzing a whole crate (default 240)]:seconds:'
        '--statistics[print analysis stats and exit]'
        '--call_graph_config=[path to call-graph JSON config]:file:_files -g "*.json"'
        '--print_function_names[print function signatures and exit]'
        '--test_only[focus analysis on #\[test\] methods only]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '*:source file:_files -g "*.rs"'
    )
    _arguments -s -S $args
}

_mirai "$@"
