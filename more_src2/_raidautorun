#compdef raidautorun
# Documentation: https://github.com/brgl/busybox/blob/master/miscutils/raidautorun.c
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# raidautorun: BusyBox applet that issues RAID_AUTORUN ioctl on one DEVICE
# (no command-line flags upstream; takes a single device argument).
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:raid device:_files -g "/dev/md*"' && ret=0
return ret
