#compdef gnoclient
# _gnoclient — Emacs gnoclient (legacy / Gnu-Emacs companion to gnuserv; sends a sexp evaluation request to a running emacs (gnuserv) via the socket /tmp/gsrvdir1000/gsrv; -e expression to evaluate, -f file to open, -n do not wait, -q quiet, -d display, -t TTY mode, -h help, -V version; positional argument is a file/buffer to open in the running emacs)
# upstream: https://github.com/davidswelt/gnuserv (legacy)
# Flags from gnuserv gnoclient.c on tip.

_gnoclient() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-e+[expr]:expr:' \
        '-f+[file to open]:file:_files' \
        '-n[no wait]' \
        '-q[quiet]' \
        '-d+[display]:display:' \
        '-t[tty mode]' \
        '*:file:_files'
}

_gnoclient "$@"
