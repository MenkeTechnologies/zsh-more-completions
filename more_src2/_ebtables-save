#compdef ebtables-save
# _ebtables-save — netfilter ebtables-save (dump the bridge-firewall (ebtables) ruleset in ebtables-restore-friendly text; -t TABLE limit (filter|nat|broute), -c include counters, -h help, -V version, -L list per-chain rather than save format; reads from kernel via ebtables ABI)
# upstream: https://git.netfilter.org/ebtables
# Flags from netfilter/ebtables src/ebtables-save.c on tip.

_ebtables-save() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-t+[table]:table:(filter nat broute)' \
        '-c[include counters]' \
        '-L[list format]'
}

_ebtables-save "$@"
