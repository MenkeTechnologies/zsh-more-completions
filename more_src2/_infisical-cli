#compdef infisical-cli infisicalctl
# _infisical-cli — Infisical infisical-cli infisicalctl CLI command-line frontend wrapping the Infisical open-source secrets management platform providing projects users teams workspaces secret folders dynamic-secrets-rotation auditing-Kubernetes-Helm-Terraform-Docker-Compose-CICD-integrations-injection-snapshot-vault-secrets-handover (Infisical team, Go); cobra
# upstream: https://infisical.com/

_infisical-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'init:initialize a project'
        'secrets:secret operations'
        'export:export secrets'
        'run:run command with injected env'
        'service-token:service-token management'
        'user:user management'
        'workspace:workspace management'
        'folders:folder management'
        'sync:sync secrets to remote'
        'snapshot:snapshot operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--domain=+[domain]:str:' \
        '--token=+[token]:str:' \
        '--type=+[t]:t:(personal service)' \
        '--env=+[env]:str:' \
        '--projectId=+[id]:str:' \
        '--path=+[path]:str:' \
        '--silent[silent]' \
        '--debug[debug]' \
        '-f+[format]:f:(json yaml dotenv csv table)' \
        '--format=+[format]:f:(json yaml dotenv csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'infisical-cli subcommand' sub ;;
        args)
            case $words[1] in
                secrets|folders|service-token|user|workspace) _arguments '1:op:(list get set delete create update)' '*:key:' ;;
                run) _arguments '*:command:_command_names' ;;
            esac
            ;;
    esac
}

_infisical-cli "$@"
