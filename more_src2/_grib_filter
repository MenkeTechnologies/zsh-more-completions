#compdef grib_filter
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_filter
# Source: ecmwf/eccodes tools/grib_filter.dox — apply a filter file to GRIB messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-o+[output file]:file:_files' \
    '-M[turn off multi-field support]' \
    '(- *)-V[show version]' \
    '-g[copy GTS header]' \
    '-G[GRIBEX compatibility mode]' \
    '-T+[message type]:type:(T B M A)' \
    '-7[do not fail on wrong message length]' \
    '-v[verbose]' \
    '1:filter file:_files' \
    '*:grib file:_files' \
    && ret=0

return ret
