#compdef pg_back
# _pg_back — simple backup tool for PostgreSQL (orgrim/pg_back)
# upstream: https://github.com/orgrim/pg_back
# Flags from internal/config/config.go (pflag).

_pg_back() {
    local -a args
    args=(
        '(-c --config)'{-c+,--config=}'[alternate config file (default /etc/pg_back/pg_back.conf)]:file:_files -g "*.conf"'
        '--no-config-file[skip reading the config file]'
        '(-b --backup-directory)'{-b+,--backup-directory=}'[backup directory]:dir:_files -/'
        '(-m --backup-file-mode)'{-m+,--backup-file-mode=}'[mode applied to dump files (octal)]:mode:'
        '(-t --with-templates)'{-t,--with-templates}'[include template databases]'
        '--without-templates[force exclude template databases]'
        '--dump-role-passwords[dump role passwords]'
        '--without-role-passwords[do not dump role passwords]'
        '--dump-only[skip globals; dump databases only]'
        '(-d --dbname)'{-d+,--dbname=}'[database to connect to for queries]:dbname:'
        '(-h --host)'{-h+,--host=}'[PostgreSQL host]:host:'
        '(-p --port)'{-p+,--port=}'[PostgreSQL port]:port:'
        '(-U --user)'{-U+,--user=}'[PostgreSQL user]:user:'
        '(-j --jobs)'{-j+,--jobs=}'[max databases dumped concurrently]:n:'
        '--parallel-backup-jobs=[parallel jobs for the directory pg_dump format]:n:'
        '--format=[pg_dump format]:format:(plain custom directory tar)'
        '--compress-level=[pg_dump compression level (-1=default)]:level:'
        '--purge-older-than=[purge dumps older than this many days]:days:'
        '--purge-min-keep=[minimum number of dumps to keep when purging]:n:'
        '--checksum-algorithm=[checksum algorithm]:algo:(none md5 sha1 sha224 sha256 sha384 sha512)'
        '--pre-backup-hook=[command to run before taking dumps]:cmd:'
        '--post-backup-hook=[command to run after taking dumps]:cmd:'
        '--encrypt[encrypt the dumps]'
        '--no-encrypt[do not encrypt the dumps]'
        '--cipher-pass=[encryption passphrase]:pass:'
        '--cipher-public-key=[AGE public key for encryption (age1...)]:key:'
        '--cipher-private-key=[AGE private key for decryption]:key:'
        '--encrypt-keep-source[keep the unencrypted source after encrypting]'
        '--uniform-timestamp[use a uniform timestamp across all dumps in a run]'
        '--upload=[upload backend]:backend:(none b2 s3 gcs azure sftp)'
        '--upload-prefix=[remote prefix / key path for uploads]:prefix:'
        '--delete-uploaded=[delete local file after upload]:mode:(yes no)'
        '--purge-remote=[purge old uploaded files in the remote backend]:mode:(yes no)'
        '--b2-bucket=[Backblaze B2 bucket]:bucket:'
        '--b2-key-id=[Backblaze B2 access key id]:id:'
        '--b2-app-key=[Backblaze B2 application key]:key:'
        '--b2-concurrent-connections=[B2 concurrent connections]:n:'
        '--s3-region=[S3 region]:region:'
        '--s3-bucket=[S3 bucket]:bucket:'
        '--s3-profile=[AWS profile name]:profile:'
        '--s3-key-id=[AWS access key id]:id:'
        '--s3-secret=[AWS secret access key]:secret:'
        '--s3-endpoint=[S3 endpoint URI]:url:'
        '--s3-tls=[use TLS for S3]:mode:(yes no)'
        '--sftp-host=[remote SFTP host]:host:'
        '--sftp-port=[remote SFTP port]:port:'
        '--sftp-identity=[path to a private key]:file:_files'
        '--gcs-bucket=[Google Cloud Storage bucket]:bucket:'
        '(- *)--version[show version]'
        '(- *)--help[show help]'
        '*:database name:'
    )
    _arguments -s -S $args
}

_pg_back "$@"
