#compdef llama-index llamaindex llamaindex-cli llamaindex-experimental
# _llama-index — Jerry Liu LlamaIndex framework CLI for retrieval-augmented LLM applications data ingestion and query (run-llama team, Python); typer
# upstream: https://github.com/run-llama/llama_index

_llama-index() {
    local -a sub=(
        'rag:run RAG query'
        'new-package:scaffold a new package'
        'init:initialize llama-index project'
        'add:add a llama-pack'
        'serve:serve query engine'
        'upgrade:upgrade installed packs'
        'upgrade-package:upgrade specific package'
        'unfreeze:unfreeze dependency'
        'download-llamapack:download a llama pack'
        'download-llamadataset:download a llama dataset'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--install-completion=+[shell]:s:(bash zsh fish)' \
        '--show-completion=+[shell]:s:(bash zsh fish)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llama-index subcommand' sub ;;
        args)
            case $words[1] in
                rag) _arguments \
                    '--question=+[question]:str:' \
                    '-q+[question]:str:' \
                    '--files=+[input files glob]:str:' \
                    '-f+[input files glob]:str:' \
                    '--persist-dir=+[index dir]:dir:_files -/' \
                    '-p+[index dir]:dir:_files -/' \
                    '--chat[chat mode]' \
                    '-c[chat mode]' \
                    '--clear[clear persisted index]' \
                    '--create-llama=+[bool]:b:(true false)' \
                    '--verbose[verbose]' ;;
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--persist-dir=+[index dir]:dir:_files -/' ;;
                download-llamapack|add) _arguments '*:pack name:' ;;
                download-llamadataset) _arguments '*:dataset name:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_llama-index "$@"
