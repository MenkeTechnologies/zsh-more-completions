#compdef rewrk
# Documentation: https://github.com/lnx-search/rewrk
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --connections)'{-c+,--connections=}'[concurrent connections]:n:' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-d --duration)'{-d+,--duration=}'[benchmark duration]:duration:' \
  '(-h --host)'{-h+,--host=}'[target URL to benchmark]:url:' \
  '--pct[display percentile table]' \
  '--http2[use HTTP/2 only]' && ret=0

return ret
