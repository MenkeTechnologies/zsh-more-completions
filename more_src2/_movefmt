#compdef movefmt
# Documentation: https://github.com/movebit/movefmt/blob/develop/src/bin/main.rs
# Documentation: https://github.com/aptos-labs/movefmt (downstream fork)
# Reference accessed: 2026-05-27
# Verified: upstream movebit/movefmt src/bin/main.rs make_opts() getopts options

# Zsh completion for movefmt (Move language formatter)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--emit=[what data to emit and how]:mode:(overwrite new_file stdout diff)' \
  '--config-path=[recursively search the given path for the movefmt.toml config file]:path:_files -/' \
  '--print-config=[dump default or current config to PATH]:topic:(default current)' \
  '*--config=[set options from command line (key1=val1,key2=val2)]:settings:' \
  '--file-path=[format the full path of the specified Move file]:file:_files -g "*.move"' \
  '--dir-path=[format all Move files in the specified directory]:dir:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[print verbose output]' \
  '(-q --quiet)'{-q,--quiet}'[print less output]' \
  '(-V --version)'{-V,--version}'[show version information]' \
  '(- *)'{-h,--help=}'[show help for given topic]:topic:(config)' \
  '(-i --stdin)'{-i,--stdin}'[receive code text from stdin]' \
  '(-f --functional)'{-f,--functional}'[use experimental functional formatter]' \
  '*:move file:_files -g "*.move"' && ret=0

return ret
