#compdef grib_index_build
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_index_build
# Source: ecmwf/eccodes tools/grib_index_build.cc — build a GRIB index file (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[force, do not fail on error]' \
    '-o+[output index file (default gribidx)]:file:_files' \
    '-k+[keys to index]:keys:_default' \
    '-M[turn off multi-field support]' \
    '-N[do not compress index]' \
    '-T+[message type]:type:(T B M A)' \
    '(- *)-V[show version]' \
    '*:grib file:_files' \
    && ret=0

return ret
