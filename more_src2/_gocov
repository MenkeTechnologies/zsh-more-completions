#compdef gocov
# Documentation: https://github.com/axw/gocov
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    local -a commands=(
      'test:run go test with coverage and output gocov JSON'
      'convert:convert go coverage profile to gocov JSON'
      'report:generate coverage report from gocov JSON'
      'annotate:annotate source files with coverage from gocov JSON'
    )
    _describe -t commands 'gocov command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      test)
        _arguments \
          '*:go test arguments' && ret=0
        ;;
      convert)
        _arguments \
          '1:coverage profile:_files' && ret=0
        ;;
      report)
        _arguments \
          '1:gocov JSON file:_files' && ret=0
        ;;
      annotate)
        _arguments \
          '1:gocov JSON file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
