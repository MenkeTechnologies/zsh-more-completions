#compdef nvidia-detector
# Documentation: https://salsa.debian.org/nvidia-team/nvidia-support
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Script takes no arguments;
# outputs recommended driver name. STUB.

# nvidia-detector: Debian/Ubuntu helper that prints recommended driver
local curcontext="$curcontext" ret=1
_arguments -C \
  '*::nvidia-detector args:_files' && ret=0
return ret
