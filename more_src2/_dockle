#compdef dockle
# Documentation: https://github.com/goodwithtech/dockle
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output)'{-o,--output}'=[output file]:output file:_files' \
  '(-f --format)'{-f,--format}'=[output format]:format:(list json sarif)' \
  '(-c --exit-code)'{-c,--exit-code}'=[exit code when alerts found]:code' \
  '(-l --exit-level)'{-l,--exit-level}'=[set minimum alert level for exit]:level:(info warn fatal)' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '--debug[debug mode]' \
  '--timeout=[timeout]:duration' \
  '--input=[input tarball]:tarball:_files -g "*.tar"' \
  '--host=[Docker host]:host' \
  '--username=[username for registry]:username' \
  '--password=[password for registry]:password' \
  '--insecure[skip TLS verification]' \
  '--non-ssl[use HTTP instead of HTTPS]' \
  '(-i --ignore)'{-i,--ignore}'=[ignore checkpoint]:checkpoint' \
  '--ak=[accept key]:key' \
  '--accept-key=[accept key]:key' \
  '--af=[accept file]:file' \
  '--accept-file=[accept file]:file' \
  '--ae=[accept file extension]:ext' \
  '--accept-file-extension=[accept file extension]:ext' \
  '--sw=[sensitive word]:word' \
  '--sensitive-word=[sensitive word]:word' \
  '--sf=[sensitive file]:file' \
  '--sensitive-file=[sensitive file]:file' \
  '--se=[sensitive file extension]:ext' \
  '--sensitive-file-extension=[sensitive file extension]:ext' \
  '1:image:' && ret=0

return ret
