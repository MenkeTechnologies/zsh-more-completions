#compdef dioxionary
# Documentation: https://github.com/vaaandark/dioxionary
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# vaaandark/dioxionary — StarDict CLI dictionary in Rust.

autoload -U is-at-least

_dioxionary() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_dioxionary_commands" \
"*::: :->dioxionary" \
&& ret=0
    case $state in
    (dioxionary)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:dioxionary-command-$line[1]:"
        case $line[1] in
            (lookup|l)
_arguments "${_arguments_options[@]}" : \
'-l+[Specify local dictionary]:local:_files' \
'--local-dicts=[Specify local dictionary]:local:_files' \
'-x[Use online dictionary]' \
'--use-online[Use online dictionary]' \
'-m[Use LLM dictionary]' \
'--use-llm[Use LLM dictionary]' \
'-L[Try offline dictionary first, then the online]' \
'--local-first[Try offline dictionary first, then the online]' \
'-e[Disable fuzzy search, only use exact search]' \
'--exact-search[Disable fuzzy search, only use exact search]' \
'-h[Print help]' \
'--help[Print help]' \
'*::word -- The word being looked up:_default' \
&& ret=0
;;
            (list|ls)
_arguments "${_arguments_options[@]}" : \
'-m+[The number of columns in the table]:column:_default' \
'--max-column=[The number of columns in the table]:column:_default' \
'-s[Sort lexicographically]' \
'--sort-alphabetically[Sort lexicographically]' \
'-f[Output to a table]' \
'--format-as-table[Output to a table]' \
'-h[Print help]' \
'--help[Print help]' \
'::difficulty_level -- The difficulty level of the word:_default' \
&& ret=0
;;
            (count|c)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
            (dicts)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
            (completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell:(bash elvish fish powershell zsh)' \
&& ret=0
;;
            (help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
}

(( $+functions[_dioxionary_commands] )) ||
_dioxionary_commands() {
    local commands; commands=(
'lookup:Look up a word, default offline dictionary' \
'l:Look up a word (alias of lookup)' \
'list:List records by difficulty level' \
'ls:List records by difficulty level (alias of list)' \
'count:Count number of records per difficulty level' \
'c:Count (alias of count)' \
'dicts:Display available dictionaries' \
'completion:Generate shell completion scripts' \
'help:Print help message or help of the given subcommand' \
    )
    _describe -t commands 'dioxionary commands' commands "$@"
}

if [ "$funcstack[1]" = "_dioxionary" ]; then
    _dioxionary "$@"
else
    compdef _dioxionary dioxionary
fi
