#compdef n8n-cli
# Documentation: https://www.npmjs.com/package/n8n-cli
# Reference accessed: 2026-05-23
# Verified: n8n-cli --help (REST API client; see also _n8n server CLI).

# Zsh completion for n8n-cli - n8n instance REST API CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--format[output format]:format:(json table)' \
  '--no-color[disable colored output]' \
  '--debug[show stack traces on errors]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'n8n-cli command' \
      'configure[configure instance credentials]' \
      'workflows[list workflows]' \
      'workflow[get workflow details]' \
      'create[create workflow from JSON]' \
      'update[update workflow]' \
      'update-node[update node parameter]' \
      'delete[delete workflow]' \
      'enable[enable workflow]' \
      'disable[disable workflow]' \
      'trigger[trigger workflow execution]' \
      'executions[list executions]' \
      'execution[get execution details]' && ret=0
    ;;
  args)
    case $line[1] in
      workflow|update|delete|enable|disable|trigger|execution)
        _arguments ':workflow ID:' && ret=0
        ;;
      create)
        _arguments ':JSON definition file:_files' && ret=0
        ;;
      update-node)
        _arguments ':workflow ID:' ':node:' ':parameter:' ':value:' && ret=0
        ;;
    esac
    ;;
esac

return ret
