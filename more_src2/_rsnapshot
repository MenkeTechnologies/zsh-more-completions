#compdef rsnapshot
# Documentation: https://github.com/rsnapshot/rsnapshot (rsnapshot-program.pl getopts 'vtxqVDc:')
# Reference accessed: 2026-05-21
# Verified: upstream source at https://raw.githubusercontent.com/rsnapshot/rsnapshot/master/rsnapshot-program.pl

# rsnapshot uses single-dash short options only (Getopt::Std)

_arguments \
  '-v[verbose, show shell commands being executed]' \
  '-t[test, show shell commands that would be executed]' \
  '-x[one filesystem, do not cross partitions within each backup point]' \
  '-q[quiet, suppress non-fatal warnings]' \
  '-V[same as -v but with more detail]' \
  '-D[firehose of diagnostic information]' \
  '-c+[path to alternate config file]:file:_files' \
  '1:command:(configtest help version version-only check-config-version upgrade-config-file du diff sync hourly daily weekly monthly yearly get-latest-snapshot)'
