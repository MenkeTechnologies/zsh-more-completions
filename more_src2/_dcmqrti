#compdef dcmqrti
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmqrti.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmqrdb/apps/dcmqrti.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmqrdb/apps/dcmqrti.cc OFCommandLine setup + docs/man/dcmqrti.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[use specific configuration file]:file:_files' \
  '(-to --timeout)'{-to+,--timeout=}'[timeout for connection requests (seconds)]:seconds:' \
  '(-ta --acse-timeout)'{-ta+,--acse-timeout=}'[timeout for ACSE messages (default: 30)]:seconds:' \
  '(-td --dimse-timeout)'{-td+,--dimse-timeout=}'[timeout for DIMSE messages]:seconds:' \
  '(-xi --propose-implicit)'{-xi,--propose-implicit}'[propose implicit VR little endian TS only]' \
  '(-aet --aetitle)'{-aet+,--aetitle=}'[set my AE title]:aetitle:' \
  '(-pdu --max-pdu)'{-pdu+,--max-pdu=}'[set max receive pdu to n bytes]:bytes:' \
  '(-u --disable-new-vr)'{-u,--disable-new-vr}'[disable support for new VRs, convert to OB]' \
  '(-rmt --remote)'{-rmt+,--remote=}'[connect to remote database defined in cfg file]:title:' \
  '*:peer:'
