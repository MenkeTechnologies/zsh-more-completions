#compdef grub-mkimage
# _grub-mkimage — GRUB grub-mkimage (assemble a bootable GRUB image from a list of modules and a target platform; -O target format (i386-pc|x86_64-efi|powerpc-ieee1275|arm64-efi|riscv64-efi|sparc64-ieee1275|...), -o output file, -d directory containing modules, -p prefix path, -c config snippet, -C compression (no|xz|gz|lzo), -k pubkey for sig check, -m memdisk, -f format-id; positional module list)
# upstream: https://git.savannah.gnu.org/cgit/grub.git
# Flags from grub util/grub-mkimage.c on tip.

_grub-mkimage() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-O+[target format]:fmt:(i386-pc i386-pc-eltorito i386-pc-pxe i386-efi x86_64-efi arm-uboot arm-efi arm64-efi powerpc-ieee1275 ia64-efi mips-arc mips-qemu_mips mips-yeeloong mipsel-arc mipsel-fuloong mipsel-loongson mipsel-qemu_mips mipsel-yeeloong riscv32-efi riscv64-efi sparc64-aout sparc64-ieee1275 sparc64-ieee1275-raw)' \
        '-o+[output file]:file:_files' \
        '-d+[modules directory]:dir:_files -/' \
        '-p+[prefix path]:prefix:' \
        '-c+[embed config snippet]:file:_files' \
        '-C+[compression]:comp:(no xz gz lzo)' \
        '-k+[pubkey for sig check]:file:_files' \
        '-m+[memdisk image]:file:_files' \
        '-f+[format-id]:format:' \
        '-n+[note]:note:' \
        '*:module:'
}

_grub-mkimage "$@"
