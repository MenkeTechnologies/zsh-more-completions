#compdef octosql
# Documentation: https://github.com/cube2222/octosql
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--config[path to config file]:config file:_files' \
  '--output=[output format]:format:(live_table batch_table csv stream_native)' \
  '--describe[describe schema of a data source]' \
  '--explain=[show query plan]:level:(1 2)' \
  '--optimize[optimize the query plan]' \
  '--profile[enable profiling]' \
  '*:SQL query:' \
  && ret=0

return ret
