#compdef esl-shuffle
# Documentation: https://manpages.debian.org/bookworm/hmmer/esl-shuffle.1.en.html
# Reference accessed: 2026-05-17
# Verified: HMMER Easel esl-shuffle upstream — sequence shuffling
# (shuffle, reverse, generate random sequences). Real flags: -h,
# -o, -N, -L, --seed, -m (mono), -d (di), -k (k-mer), -0 (0th
# Markov), -1 (1st Markov), -w (window), -r (reverse), -G (iid),
# -Q (QRNA-like), --rna/--dna/--amino, --informat.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --mono/--markov0/--markov1/--reverse/--iid duplicates
# of single-letter flags (Easel uses only one form, the letters).

local ret=1
_arguments -s -S \
  '(- *)-h[show help]' \
  '-o+[output file]:file:_files' \
  '-N+[number of output sequences]:n:' \
  '-L+[length (for random generation)]:n:' \
  '--seed=[RNG seed]:n:' \
  '-m[monoshuffle (default)]' \
  '-d[dinucleotide shuffle]' \
  '-k+[k-mer shuffle (k>1)]:k:' \
  '-0[0th-order Markov]' \
  '-1[1st-order Markov]' \
  '-w+[window shuffle]:size:' \
  '-r[reverse]' \
  '-G[generate random sequences (iid)]' \
  '-Q[generate QRNA-like alignments]' \
  '--rna[RNA alphabet]' \
  '--dna[DNA alphabet]' \
  '--amino[amino acid alphabet]' \
  '--informat=[input format]:fmt:(fasta embl genbank uniprot)' \
  '*:sequence file:_files' && ret=0
return ret
