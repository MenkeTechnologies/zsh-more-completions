#compdef llamafile
# Documentation: https://github.com/Mozilla-Ocho/llamafile
# Reference accessed: 2026-05-27
# Verified: upstream llamafile/main.cpp, llamafile/args.cpp, llamafile/args.h
# Forwarded flags verified against ggml-org/llama.cpp common/arg.cpp (server/CLI args)

# Zsh completion for llamafile - single-file LLM executable (Mozilla.ai)
# Top-level modes: --server, --chat, --cli, default (combined chat + server)
# Mode-specific flags forwarded to llama.cpp common args.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show llamafile version]' \
  '--server[run HTTP server only (OpenAI-compatible API)]' \
  '--chat[run TUI chat only (no server)]' \
  '--cli[single prompt/response then exit]' \
  '--gpu=[GPU backend]:mode:(auto nvidia amd apple disable)' \
  '--nologo[suppress startup logo]' \
  '--ascii[use ASCII art instead of Unicode for logo]' \
  '--nothink[suppress <think>...</think> reasoning output (--cli)]' \
  '--verbose[enable verbose logging]' \
  '(-m --model)'{-m+,--model=}'[path to GGUF model file]:model:_files' \
  '-mu+[model URL]:url:' \
  '-hf+[HuggingFace repo (<user>/<model>[:quant])]:repo:' \
  '-hff+[HuggingFace file]:file:' \
  '-hft+[HuggingFace token]:token:' \
  '(-p --prompt)'{-p+,--prompt=}'[prompt text (in --cli: user prompt)]:prompt:' \
  '(-sys --system-prompt)'{-sys+,--system-prompt=}'[system prompt]:prompt:' \
  '(-f --file)'{-f+,--file=}'[prompt from file]:file:_files' \
  '-sysf+[system prompt from file]:file:_files' \
  '--in-file=[input file]:file:_files' \
  '-bf+[binary input file]:file:_files' \
  '(-e --escape)'{-e,--escape}'[process prompt escape sequences]' \
  '--no-escape[do not process escapes]' \
  '(-r --reverse-prompt)'{-r+,--reverse-prompt=}'[stop at this prompt]:prompt:' \
  '(-i --interactive)'{-i,--interactive}'[run in interactive mode]' \
  '-if[interactive first]' \
  '-mli[multiline input]' \
  '--in-prefix=[input prefix string]:prefix:' \
  '--in-prefix-bos[insert BOS before in-prefix]' \
  '--in-suffix=[input suffix string]:suffix:' \
  '(-cnv --conversation)'{-cnv,--conversation}'[run in conversation mode]' \
  '-no-cnv[disable conversation mode]' \
  '-st[single-turn mode]' \
  '--keep=[tokens to keep from initial prompt]:n:' \
  '(-c --ctx-size)'{-c+,--ctx-size=}'[context size]:n:' \
  '(-n --predict)'{-n+,--predict=,--n-predict=}'[max tokens to predict]:n:' \
  '(-b --batch-size)'{-b+,--batch-size=}'[logical batch size]:n:' \
  '(-ub --ubatch-size)'{-ub+,--ubatch-size=}'[physical batch size]:n:' \
  '--chunks=[max chunks to process]:n:' \
  '(-t --threads)'{-t+,--threads=}'[number of threads]:n:' \
  '(-tb --threads-batch)'{-tb+,--threads-batch=}'[number of batch threads]:n:' \
  '(-C --cpu-mask)'{-C+,--cpu-mask=}'[CPU affinity mask]:mask:' \
  '(-Cr --cpu-range)'{-Cr+,--cpu-range=}'[CPU range lo-hi]:range:' \
  '--cpu-strict=[strict CPU placement]:value:(0 1)' \
  '--prio=[scheduling priority]:n:' \
  '--poll=[busy-poll percentage]:n:' \
  '(-ngl --gpu-layers --n-gpu-layers)'{-ngl+,--gpu-layers=,--n-gpu-layers=}'[layers to offload to GPU]:n:' \
  '(-sm --split-mode)'{-sm+,--split-mode=}'[multi-GPU split mode]:mode:(none layer row tensor)' \
  '(-ts --tensor-split)'{-ts+,--tensor-split=}'[GPU split ratios N0,N1,...]:split:' \
  '(-mg --main-gpu)'{-mg+,--main-gpu=}'[main GPU index]:index:' \
  '(-dev --device)'{-dev+,--device=}'[devices list]:devices:' \
  '--list-devices[list available devices]' \
  '--mlock[lock model in RAM]' \
  '--mmap[use mmap for model files]' \
  '--no-mmap[do not use mmap]' \
  '--numa=[NUMA strategy]:type:(distribute isolate numactl)' \
  '(-s --seed)'{-s+,--seed=}'[RNG seed]:seed:' \
  '--samplers=[samplers chain]:samplers:' \
  '--sampling-seq=[sampling sequence]:seq:' \
  '--ignore-eos[ignore end-of-stream token]' \
  '(--temp --temperature)'{--temp=,--temperature=}'[sampling temperature]:t:' \
  '--top-k=[top-k sampling]:k:' \
  '--top-p=[top-p (nucleus) sampling]:p:' \
  '--min-p=[min-p sampling]:p:' \
  '(--typical --typical-p)'{--typical=,--typical-p=}'[typical sampling]:p:' \
  '--repeat-last-n=[repeat penalty window]:n:' \
  '--repeat-penalty=[repeat penalty]:p:' \
  '--presence-penalty=[presence penalty]:p:' \
  '--frequency-penalty=[frequency penalty]:p:' \
  '--mirostat=[Mirostat sampling]:mode:(0 1 2)' \
  '--mirostat-lr=[Mirostat learning rate]:lr:' \
  '--mirostat-ent=[Mirostat target entropy]:ent:' \
  '--dynatemp-range=[dynamic temperature range]:r:' \
  '--dynatemp-exp=[dynamic temperature exponent]:e:' \
  '--xtc-probability=[XTC sampler probability]:p:' \
  '--xtc-threshold=[XTC sampler threshold]:t:' \
  '(-l --logit-bias)'{-l+,--logit-bias=}'[logit bias TOKEN_ID(+/-)BIAS]:bias:' \
  '--grammar=[BNF grammar constraint]:grammar:' \
  '--grammar-file=[grammar file]:file:_files' \
  '(-j --json-schema)'{-j+,--json-schema=}'[JSON schema constraint]:schema:' \
  '-jf+[JSON schema file]:file:_files' \
  '--rope-scaling=[RoPE scaling type]:type:(none linear yarn)' \
  '--rope-scale=[RoPE scale factor]:n:' \
  '--rope-freq-base=[RoPE base frequency]:n:' \
  '--rope-freq-scale=[RoPE frequency scale]:n:' \
  '--yarn-orig-ctx=[YaRN original context length]:n:' \
  '--yarn-ext-factor=[YaRN extension factor]:n:' \
  '--yarn-attn-factor=[YaRN attention factor]:n:' \
  '(-mm --mmproj)'{-mm+,--mmproj=}'[multimodal projector file]:file:_files' \
  '-mmu+[multimodal projector URL]:url:' \
  '--no-mmproj[disable multimodal projector]' \
  '(--image --audio)'{--image=,--audio=}'[image or audio input file]:file:_files' \
  '--lora=[LoRA adapter file]:file:_files' \
  '--lora-scaled=[LoRA adapter with scale FNAME:SCALE]:lora:' \
  '--control-vector=[control vector file]:file:_files' \
  '--control-vector-scaled=[control vector with scale]:vec:' \
  '(-a --alias)'{-a+,--alias=}'[model alias name]:alias:' \
  '--tags=[model tags]:tags:' \
  '(-ctk --cache-type-k)'{-ctk+,--cache-type-k=}'[KV cache K type]:type:' \
  '(-ctv --cache-type-v)'{-ctv+,--cache-type-v=}'[KV cache V type]:type:' \
  '-kvu[unified KV cache]' \
  '-no-kvu[separate KV cache]' \
  '(-fa --flash-attn)'{-fa,--flash-attn}'[enable Flash Attention]' \
  '--pooling=[pooling type]:type:(none mean cls last rank)' \
  '--port=[server port]:port:' \
  '--host=[server host/bind address]:host:' \
  '--api-key=[require API key]:key:' \
  '--api-key-file=[API keys file]:file:_files' \
  '--chat-template=[chat template name or string]:template:' \
  '--chat-template-file=[chat template file]:file:_files' \
  '--ssl-cert-file=[SSL cert file]:file:_files' \
  '--ssl-key-file=[SSL key file]:file:_files' \
  '--threads-http=[HTTP threads]:n:' \
  '--path=[serve static files from path]:path:_directories' \
  '--metrics[expose Prometheus metrics endpoint]' \
  '--slots[enable /slots endpoint]' \
  '--props[enable /props endpoint]' \
  '--jinja[enable Jinja template support]' \
  '--log-disable[disable logging]' \
  '--log-file=[log to file]:file:_files' \
  '--log-verbosity=[log verbosity]:level:' \
  '--log-prefix[prefix log messages]' \
  '--log-timestamps[timestamp log messages]' \
  '--color=[colorized output]:mode:(on off auto)' \
  '--no-display-prompt[do not echo the prompt]' \
  '--display-prompt[echo the prompt]' \
  '(-np --parallel)'{-np+,--parallel=}'[number of parallel sequences]:n:' \
  '(-cb --cont-batching)'{-cb,--cont-batching}'[enable continuous batching]' \
  '-nocb[disable continuous batching]' \
  '--prompt-cache=[prompt cache file]:file:_files' \
  '--prompt-cache-all[also cache user prompt]' \
  '--prompt-cache-ro[read-only prompt cache]' \
  '*:model file:_files -g "*.(gguf|llamafile)"' && ret=0

return ret
