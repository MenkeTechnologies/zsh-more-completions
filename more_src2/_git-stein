#compdef git-stein
# Documentation: https://github.com/sh5i/git-stein
# Reference accessed: 2026-05-30
# git-stein — Java-based Git history-rewriting framework with 3 modes:
#   Overwrite:  git stein <source>
#   Transform:  git stein <source> -o <target>
#   Duplicate:  git stein <source> -o <target> -d

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help message]' \
  '(- *)--version[show version]' \
  '(-o --output)-o+[destination repository path]:dir:_files -/' \
  '(-o --output)--output=[destination repository path]:dir:_files -/' \
  '(-d --duplicate)-d[copy source repo and overwrite]' \
  '(-d --duplicate)--duplicate[copy source repo and overwrite]' \
  '--clean[delete target before transforming]' \
  '--bare[treat repositories as bare]' \
  '(-j --jobs)-j+[parallel rewrite threads]:N:' \
  '(-j --jobs)--jobs=[parallel rewrite threads]:N:' \
  '(-n --dry-run)-n[preview changes without modifying]' \
  '(-n --dry-run)--dry-run[preview changes without modifying]' \
  '--stream-size-limit=[increase stream size limit]:N:' \
  '--no-notes[skip recording source commit IDs]' \
  '--no-pack[skip packing objects after transformation]' \
  '--alternates[share source objects via Git alternates]' \
  '--no-composite[disable blob translator composition]' \
  '--extra-attributes[rewrite encoding and signature fields]' \
  '--cache[enable persistent entry caching]' \
  '--mapping-mem=[max memory for entry mapping cache]:N:' \
  '*--cmdpath=[add package search paths]:path:_files -/' \
  '--log=[log level (default INFO)]:level:(OFF SEVERE WARNING INFO CONFIG FINE FINER FINEST ALL)' \
  '(-q --quiet -v --verbose)-q[quiet mode]' \
  '(-q --quiet -v --verbose)--quiet[quiet mode]' \
  '(-q --quiet -v --verbose)-v[verbose mode]' \
  '(-q --quiet -v --verbose)--verbose[verbose mode]' \
  '1:source repository:_files -/' \
  && ret=0

return ret
