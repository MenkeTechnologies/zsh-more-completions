#compdef ElmerGUI elmergui
# Documentation: https://github.com/ElmerCSC/elmerfem
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ElmerGUI: Qt-based GUI front end to ElmerSolver
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-version[show version]' \
  '--qt-help[Qt help options]' \
  '*:Elmer project/.egproject file:_files -g "*.(egproject|sif|msh)"' && ret=0
return ret
