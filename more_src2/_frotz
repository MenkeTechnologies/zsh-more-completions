#compdef frotz dfrotz sfrotz nfrotz
# Documentation: https://manpages.debian.org/bookworm/frotz/frotz.6.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-v[show version]' \
  '-a[watch attribute setting]' \
  '-A[watch attribute testing]' \
  '-o[watch object movement]' \
  '-O[watch object location]' \
  '-b+[background color]:c:(black red green yellow blue magenta cyan white)' \
  '-f+[foreground color]:c:(black red green yellow blue magenta cyan white)' \
  '-c+[context lines after MORE prompt]:n:' \
  '-d[disable color]' \
  '-e[enable sound]' \
  '-q[quiet, disable sound]' \
  '-i[ignore fatal errors]' \
  '-p[plain ASCII output]' \
  '-P[alter piracy opcode]' \
  '-r+[right margin]:n:' \
  '-l+[left margin]:n:' \
  '-w+[text width]:n:' \
  '-h+[text height]:n:' \
  '-s+[random seed]:n:' \
  '-S+[transcript width]:n:' \
  '-x[expand abbreviations]' \
  '-u+[undo slots]:n:' \
  '-I+[interpreter number]:n:' \
  '-Z+[error checking level]:lvl:(0 1 2 3)' \
  '-L+[load save file]:file:_files' \
  '-t[set Tandy bit]' \
  '-F[force color mode]' \
  '-m[mouse support]' \
  '-R+[restricted read/write]:path:' \
  '-E+[emphasis style]:style:(0 1 2 3)' \
  '*:Z-machine game:_files -g "*.(z[1-8]|dat|zblorb|zlb)"' && ret=0

return ret
