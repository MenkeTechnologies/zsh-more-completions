#compdef modiinfo modimount
# _libmodi — libmodi tools (libyal macOS sparse / sparsebundle / dmg disk-image parser; modiinfo prints metadata for sparse and bundled (.sparsebundle) images, modimount FUSE-mounts the image read-only; -h help, -V version, -v verbose, -o image offset, -p password, -X exclusive; positional argument is the .dmg / .sparseimage / .sparsebundle file)
# upstream: https://github.com/libyal/libmodi
# Flags from libyal/libmodi moditools/modiinfo.c on tip.

_libmodi() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-o+[image offset]:bytes:' \
        '-p+[password]:password:' \
        '-X[exclusive]' \
        '*:macOS image:_files'
}

_libmodi "$@"
