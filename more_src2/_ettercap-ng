#compdef ettercap-ng
# _ettercap-ng — Ettercap NG alias (modern ettercap binary; -T text mode, -C curses, -G GTK GUI, -D daemon, -M MITM method, -i interface, -F filter file, -w/-r pcap, -L log basename, -P plugin, -q quiet, -p only-sniff, -l only-passive, -z no host discovery, -Z restrict; positional argument is the comma-separated targets list)
# upstream: https://github.com/Ettercap/ettercap
# Flags from Ettercap/ettercap src/ec_main.c on tip.

_ettercap-ng() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-T[text mode]' \
        '-C[curses mode]' \
        '-G[GTK GUI]' \
        '-D[daemon mode]' \
        '-M+[MITM]:method:(arp arp:remote arp:oneway dhcp:remote icmp port port:remote ndp:remote)' \
        '-i+[interface]:interface:_net_interfaces' \
        '-F+[filter file]:file:_files -g "*.ef"' \
        '-w+[pcap write]:file:_files -g "*.(pcap|pcapng)"' \
        '-r+[pcap read]:file:_files -g "*.(pcap|pcapng)"' \
        '-L+[log basename]:basename:' \
        '*-P+[plugin]:plugin:' \
        '-q[quiet]' \
        '-p[only sniff]' \
        '-l[only passive]' \
        '-z[no host discovery]' \
        '-Z[restrict to discovered]' \
        '*:targets:'
}

_ettercap-ng "$@"
