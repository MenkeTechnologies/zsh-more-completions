#compdef gargoyle
# Documentation: https://manpages.ubuntu.com/manpages/noble/en/man6/gargoyle-free.6.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Gargoyle: cross-platform interactive fiction player (garglk/garglk).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-d,--dump-config}'[dump default config to stdout]' \
  '(- *)'{-e,--edit-config}'[open config file in editor (creating if needed)]' \
  '(- *)'{-m,--migrate-config}'[migrate legacy config to preferred location]' \
  '(- *)'{-p,--paths}'[show config and theme paths used at runtime]' \
  '(- *)'{-t,--themes}'[list available color themes]' \
  '*:story file:_files -g "*.(z3|z4|z5|z6|z7|z8|zblorb|blorb|blb|ulx|gblorb|hex|t3)"' && ret=0
return ret
