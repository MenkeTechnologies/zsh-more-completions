#compdef dcut
# Documentation: https://manpages.debian.org/dcut
# Source: Debian/dput-ng bin/dcut — Debian command-file upload tool (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(- *)'{-h,--help}'[show help]' \
    '*'{-d,--debug}'[enable debug (stackable)]' \
    {-f,--force}'[force action]' \
    {-c+,--config=}'[configuration file]:file:_files' \
    {-m+,--maintainer=}'[maintainer email]:maintainer:_default' \
    {-k+,--keyid=}'[GPG key ID]:key:_default' \
    {-S,--save}'[save command file without uploading]' \
    {-O+,--output=}'[output filename]:file:_files' \
    {-P,--passive}'[use FTP passive mode]' \
    '*'{-s,--simulate}'[simulate (stackable)]' \
    {-v,--version}'[show version]' \
    '1::host:_default' \
    '*::command:->cmd' \
    && ret=0

return ret
