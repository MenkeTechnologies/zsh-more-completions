#compdef LabelGeometryMeasures
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/LabelGeometryMeasures.cxx — per-label geometric / intensity stats (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:imageDimension:(2 3 4)' \
    '2:labelImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3::intensityImage:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4::outputCSV:_files -g "*.csv"' \
    && ret=0

return ret
