#compdef ldapvi
# _ldapvi CLI — David Lichteblau ldapvi CLI interactive LDAP directory editor displaying entries in editor of choice supporting bind URL filter base scope add delete modify rename schema-aware vi-like operations applying changes through standard LDAP add modify delete delrequest renaming for OpenLDAP 389-DS schemata (David Lichteblau team, C); getopt
# upstream: http://www.lichteblau.com/ldapvi/

_ldapvi() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-h+[host:port]:str:' \
        '--host=+[host:port]:str:' \
        '-D+[bind dn]:str:' \
        '--bind=+[dn]:str:' \
        '-W[prompt for password]' \
        '--password-prompt[prompt for password]' \
        '-w+[password]:str:' \
        '--password=+[password]:str:' \
        '-y+[password file]:file:_files' \
        '--password-file=+[file]:file:_files' \
        '-b+[base dn]:str:' \
        '--base=+[dn]:str:' \
        '-s+[scope]:s:(base one sub subtree)' \
        '--scope=+[scope]:s:(base one sub subtree)' \
        '-f+[filter]:str:' \
        '--filter=+[filter]:str:' \
        '-a+[attributes]:str:' \
        '--attrs=+[list]:str:' \
        '-A[show all attributes]' \
        '--all[show all attributes]' \
        '-o[show operational attributes]' \
        '--operational[show operational attributes]' \
        '-O+[options]:str:' \
        '--objectclass=+[class]:str:' \
        '--add[add mode]' \
        '--delete[delete mode]' \
        '--rename[rename mode]' \
        '--config=+[file]:file:_files' \
        '--in=+[file]:file:_files -g "*.ldif"' \
        '--out=+[file]:file:_files -g "*.ldif"' \
        '--ldap-cnf=+[file]:file:_files' \
        '--starttls[start TLS]' \
        '--tls[force TLS]' \
        '--no-input[no editor input]' \
        '--no-question[no questions]' \
        '--show-prompt[show prompt]' \
        '--continuous[continuous mode]' \
        '--scopes-all[scope all]' \
        '*:base dn:'
}

_ldapvi "$@"
