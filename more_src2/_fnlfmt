#compdef fnlfmt
# Documentation: https://github.com/rf-/fnlfmt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fnlfmt (Fennel source formatter).

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--fix[update file in-place]' \
  '--check[exit non-zero if file is unformatted]' \
  '--no-comments[disable comment preservation]' \
  '--fn-forms=[custom function forms]:forms (comma-separated):' \
  '--body-forms=[custom body forms]:forms (comma-separated):' \
  '*:Fennel file:_files -g "*.fnl"'
