#compdef geoiplookup geoiplookup6
# Documentation: man geoiplookup(1)
# Source: MaxMind GeoIP — look up country for an IP or hostname.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[custom GeoIP datafile]:file:_files' \
    '-d+[custom GeoIP datafile directory]:dir:_files -/' \
    '(- *)-v[list date and build of GeoIP datafile(s)]' \
    '*:IP address or hostname:_hosts' \
    && ret=0

return ret
