#compdef dicebear
# Documentation: https://www.dicebear.com/how-to-use/cli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# DiceBear avatar CLI (Node, dicebear/dicebear)

local -a styles=(
  adventurer adventurer-neutral avataaars avataaars-neutral big-ears big-ears-neutral
  big-smile bottts bottts-neutral croodles croodles-neutral dylan fun-emoji glass
  icons identicon initials lorelei lorelei-neutral micah miniavs notionists notionists-neutral
  open-peeps personas pixel-art pixel-art-neutral rings shapes thumbs
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--format=[output format]:format:(svg png jpg webp avif json)' \
  '--size=[image size in pixels]:px:' \
  '--count=[number of avatars]:n:' \
  '--seed=[seed string]:seed:' \
  '--backgroundColor=[background color(s)]:color:' \
  '--exif[include EXIF metadata]' \
  '--json[also write JSON metadata]' \
  '1:style:($styles)' \
  '2::output path:_files -/'
