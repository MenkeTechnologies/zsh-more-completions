#compdef jello
# Documentation: https://github.com/kellyjonbrazil/jello
# Reference accessed: 2026-05-19
# Verified: kellyjonbrazil/jello upstream README options table.
# jello uses only single-dash options (no long forms). Removed
# invented --long variants from prior file.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[help information]' \
  '(- *)-v[version information]' \
  '-c[compact print JSON output instead of pretty printing]' \
  '-C[force color output even when using pipes (overrides -m and NO_COLOR)]' \
  '-e[empty data (do not process data from STDIN or file)]' \
  '-f+[load input data from JSON file or JSON Lines files]:file:_files' \
  '-i+[initialize environment with a custom config file]:file:_files' \
  '-l[lines output (suitable for bash array assignment)]' \
  '-m[monochrome output]' \
  '-n[print selected null values]' \
  '-q+[load query from a file]:file:_files' \
  '-r[raw output of selected strings (no quotes)]' \
  '-R[raw string input (do not auto convert input to dict/list)]' \
  '-s[print the JSON schema in grep-able format]' \
  '-t[print type annotations in schema view]' \
  '*:query:' && ret=0

return ret
