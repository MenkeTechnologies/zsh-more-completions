#compdef pdfposter
# Documentation: https://manpages.debian.org/testing/pdfposter/pdfposter.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-media-names[list available media and distance names]' \
  '(- *)--help-box-definitions[help about specifying BOX parameters]' \
  '(- *)--version[show version]' \
  '*'{-v,--verbose}'[verbose output (repeatable)]' \
  {-n,--dry-run}'[preview operations without generating files]' \
  '(-f --first)'{-f+,--first=}'[first page to convert]:page:' \
  '(-l --last)'{-l+,--last=}'[last page to convert]:page:' \
  '(-A --art-box)'{-A,--art-box}'[use ArtBox instead of TrimBox]' \
  '(-m --media-size)'{-m+,--media-size=}'[input/print media size]:size:' \
  '(-p --poster-size)'{-p+,--poster-size=}'[poster size]:size:' \
  '-s+[linear scaling factor]:factor:' \
  '*:PDF file:_files -g "*.pdf"' && ret=0

return ret
