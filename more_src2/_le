#compdef le
# Documentation: https://github.com/lavv17/le/blob/master/src/edit.cc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (getopt_long in main()).

local ret=1
_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '(-r --read-only)'{-r,--read-only}'[open in read-only/view mode]' \
  '(-h --hex-mode)'{-h,--hex-mode}'[open in hex mode]' \
  '(-b --black-white)'{-b,--black-white}'[disable color]' \
  '(-c --color)'{-c,--color}'[enable color]' \
  '--config=[explicit config file]:file:_files' \
  '--dump-keymap[dump default keymap and exit]' \
  '--dump-colors[dump default colors and exit]' \
  '--multibyte[enable multibyte mode]' \
  '--no-multibyte[disable multibyte mode]' \
  '--mmap[open file in mmap (read-only hex) mode]' \
  '--mmap-rw[open file in mmap read-write hex mode]' \
  '*:file:_files' && ret=0
return ret
