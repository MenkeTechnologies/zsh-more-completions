#compdef kafka-metadata
# Documentation: https://github.com/apache/kafka
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--snapshot=[path to metadata snapshot file]:file:_files' \
  '--cluster-id=[cluster ID to verify]:id:' && ret=0

return ret
