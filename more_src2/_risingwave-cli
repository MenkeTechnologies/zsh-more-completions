#compdef risingwave-cli risingwave2
# _risingwave-cli — RisingWave Labs risingwave-cli CLI command-line frontend wrapping the RisingWave open-source distributed SQL streaming database providing single-node-mode standalone-mode playground compute frontend meta compactor risectl ctl table source sink materialized-view scaling-pause-resume-meta-fragment-actor-list cluster-health Kafka-Pulsar-Kinesis-Iceberg-Postgres-CDC connectors (RisingWave Labs team, Rust); custom argparse
# upstream: https://risingwave.com/

_risingwave-cli() {
    local -a sub=(
        'single-node:run single-node'
        'standalone:run standalone'
        'playground:run playground'
        'meta:run meta node'
        'compute:run compute node'
        'frontend:run frontend node'
        'compactor:run compactor'
        'ctl:risectl operations'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-path=+[file]:file:_files -g "*.toml"' \
        '-c+[file]:file:_files -g "*.toml"' \
        '--listen-addr=+[host:port]:_hosts' \
        '--host=+[host:port]:_hosts' \
        '--advertise-addr=+[host:port]:_hosts' \
        '--meta-address=+[host:port]:_hosts' \
        '--state-store=+[uri]:str:' \
        '--data-directory=+[dir]:dir:_files -/' \
        '--backend=+[b]:b:(mem etcd sql)' \
        '--etcd-endpoints=+[hosts]:_hosts' \
        '--sql-endpoint=+[uri]:str:' \
        '--prometheus-listener-addr=+[host:port]:_hosts' \
        '--enable-tls[enable TLS]' \
        '--total-memory-bytes=+[N]:n:' \
        '--parallelism=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'risingwave subcommand' sub ;;
        args)
            case $words[1] in
                ctl) _arguments '1:op:(meta hummock table compute trace bench profile scale debug)' '*:arg:' ;;
            esac
            ;;
    esac
}

_risingwave-cli "$@"
