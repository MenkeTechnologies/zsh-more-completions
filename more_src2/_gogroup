#compdef gogroup

local curcontext="$curcontext" state line ret=1

_arguments \
  '--order[Import group order (comma-separated)]:order:(std prefix other)' \
  '--rewrite[Rewrite files in place]' \
  '--diff[Display diffs instead of rewriting]' \
  '--list[List files whose grouping differs]' \
  '*:file or directory:_files' \
  && ret=0

return ret
