#compdef fastboot
# Documentation: https://manpages.debian.org/fastboot.1
# Source: Android Fastboot — bootloader-mode flash/erase/getvar protocol CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '-w[erase userdata and cache (format if supported)]' \
    '-u[do not erase partition before formatting]' \
    '-s[device serial or port path]:serial:' \
    '-l[list device paths (with devices command)]' \
    '-p[product name]:product:' \
    '-c[override kernel cmdline]:cmdline:' \
    '-i[custom USB vendor ID]:vendor id:' \
    '(-b --base)'{-b+,--base=}'[custom kernel base address (default 0x10000000)]:addr:' \
    '--kernel-offset=[custom kernel offset (default 0x00008000)]:offset:' \
    '--ramdisk-offset=[custom ramdisk offset (default 0x01000000)]:offset:' \
    '--tags-offset=[custom tags offset (default 0x00000100)]:offset:' \
    '(-n --page-size)'{-n+,--page-size=}'[NAND page size (default 2048)]:size:' \
    '-S[auto-sparse files greater than size (K/M/G)]:size:' \
    '--slot=[slot suffix for slotted devices]:slot:(a b)' \
    '(-a --set-active)'{-a,--set-active}'[set the active slot]' \
    '--wipe-and-use-fbe[erase userdata+cache and enable file-based encryption]' \
    '--unbuffered[do not buffer stdin/stdout]' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'update:reflash device from update.zip'
            'flashall:flash boot, system, vendor (and recovery if present)'
            'flash:write a file to a flash partition'
            'flashing:lock / unlock / lock_critical / unlock_critical / get_unlock_ability'
            'erase:erase a flash partition'
            'format:format a flash partition (fs type / size)'
            'getvar:print a bootloader variable'
            'set_active:set the active slot'
            'boot:download and boot kernel'
            'devices:list connected fastboot devices'
            'continue:continue with autoboot'
            'reboot:reboot device (optionally into bootloader)'
            'reboot-bootloader:reboot device into bootloader'
            'help:show help'
        )
        _describe -t subcmds 'fastboot command' subcmds && ret=0
        ;;
    args)
        _files && ret=0
        ;;
esac

return ret
