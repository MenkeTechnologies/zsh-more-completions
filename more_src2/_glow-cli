#compdef glow-cli
# _glow-cli — Charm glow render markdown in terminal CLI alias (Charm / charmbracelet, Go); spf13/cobra
# upstream: https://github.com/charmbracelet/glow

_glow-cli() {
    local -a sub=(
        'completion:generate shell completion'
        'config:edit config'
        'help:show help'
        'version:show version'
        'stash:stash a markdown file'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--all[show all files]' \
        '-a[show all files]' \
        '--config=+[config file]:file:_files -g "glow.yml"' \
        '-c+[config file]:file:_files -g "glow.yml"' \
        '--gopath=+[gopath]:dir:_files -/' \
        '--local[only show local files]' \
        '-l[only show local files]' \
        '--mouse[enable mouse]' \
        '-m[enable mouse]' \
        '--no-cache[disable cache]' \
        '--page[pager mode]' \
        '-p[pager mode]' \
        '--pager[pager mode]' \
        '--show-line-numbers[show line numbers]' \
        '--style=+[style]:s:(auto ascii dark dracula light notty pink tokyo-night)' \
        '-s+[style]:s:(auto ascii dark dracula light notty pink tokyo-night)' \
        '--tui[start TUI]' \
        '-t[start TUI]' \
        '--width=+[word wrap at width]:n:' \
        '-w+[word wrap at width]:n:' \
        '1:subcommand-or-file:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glow subcommand' sub
            _files -g "*.md *.markdown" ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                stash) _arguments \
                    '--description=+[description]:str:' \
                    '*:file:_files -g "*.md *.markdown"' ;;
            esac
            ;;
    esac
}

_glow-cli "$@"
