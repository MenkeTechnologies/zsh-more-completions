#compdef ecctl
# Documentation: https://www.elastic.co/guide/en/ecctl/current/ecctl.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'auth:handle authentication configuration'
  'comment:manage resource comments (ECE only)'
  'deployment:manage deployments'
  'generate:produce completions and documentation'
  'help:show help'
  'init:set up an initial configuration file'
  'platform:manage platform operations (ECE only)'
  'stack:manage Elastic StackPacks'
  'user:manage platform users (ECE only)'
  'version:display the ecctl version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--api-key=[API key]:key:' \
  '--config=[config name]:name:' \
  '--force[skip confirmations]' \
  '--format=[output format text/json]:fmt:(text json)' \
  '-o+[output format]:fmt:(text json)' \
  '--host=[host URL]:url:' \
  '--insecure[skip TLS verify]' \
  '--message=[deployment plan message]:msg:' \
  '--output=[output format]:fmt:(text json)' \
  '--pass=[password]:pw:' \
  '--pprof[enable pprof]' \
  '--quiet[suppress config output]' \
  '--region=[region]:region:' \
  '--timeout=[HTTP timeout (default 30s)]:dur:' \
  '--trace[enable HTTP trace]' \
  '--user=[username]:user:' \
  '--verbose[verbose output]' \
  '--verbose-file=[verbose log file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ecctl command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (deployment) _values 'subcommand' 'create' 'delete' 'extension' 'list' 'note' 'plan' 'resync' 'restore' 'show' 'shutdown' 'template' 'update' 'search' 'reapply' 'resource' && ret=0 ;;
      (platform) _values 'subcommand' 'allocator' 'constructor' 'enrollment-token' 'instance-config' 'proxy' 'repository' 'role' 'runner' 'stack' && ret=0 ;;
      (auth) _values 'subcommand' 'login' 'logout' 'list' && ret=0 ;;
      (user) _values 'subcommand' 'create' 'delete' 'disable' 'enable' 'key' 'list' 'show' 'update' && ret=0 ;;
      (stack) _values 'subcommand' 'list' 'show' 'upload' 'delete' 'update' && ret=0 ;;
      (generate) _values 'subcommand' 'completions' 'docs' && ret=0 ;;
    esac ;;
esac

return ret
