#compdef policyd-weight
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man8/policyd-weight.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. policyd-weight only
# supports short flags -d/-f/-h/-k/-s/-v plus daemon-mode positional
# commands (start, stop, restart, reload, defaults). Removed from
# prior file: fabricated long options --defaults/--config/--foreground/
# --re-read/--stop/--debug and -D flag.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-v[show version]' \
  '-d[debug mode (reports to STDOUT, spawns own cache daemon)]' \
  '-f+[configuration file]:file:_files' \
  '-k[kill cache daemon]' \
  '-s[show cache entries]' \
  '*:command:(start stop restart reload defaults)' && ret=0

return ret
