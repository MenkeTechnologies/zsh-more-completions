#compdef rpict
# Documentation: https://floyd.lbl.gov/radiance/man_html/rpict.1.html
# Reference accessed: 2026-05-21
# Verified: upstream LBNL Radiance rpict(1) manpage.

# Radiance rpict: image rendering tool
local curcontext="$curcontext" ret=1
_arguments -C \
  '-vf[view file]:file:_files' \
  '-vp[view point x y z]:x y z:' \
  '-vd[view direction]:x y z:' \
  '-vu[view up]:x y z:' \
  '-vh[view horizontal angle]:angle:' \
  '-vv[view vertical angle]:angle:' \
  '-vs[view shift]:val:' \
  '-vl[view lift]:val:' \
  '-vo[view fore clip]:val:' \
  '-va[view aft clip]:val:' \
  '-vt[view type]:type:(v l a h s c)' \
  '-x[horizontal pixel count]:n:' \
  '-y[vertical pixel count]:n:' \
  '-ps[pixel sampling rate]:n:' \
  '-pt[pixel sampling threshold]:val:' \
  '-pj[pixel jitter]:val:' \
  '-dj[direct jitter]:val:' \
  '-dt[direct threshold]:val:' \
  '-dc[direct certainty]:val:' \
  '-dr[direct relays]:n:' \
  '-dp[direct pretest density]:n:' \
  '-ds[direct sampling]:val:' \
  '-dv[show direct sources]' \
  '-st[specular threshold]:val:' \
  '-ab[ambient bounces]:n:' \
  '-aa[ambient accuracy]:val:' \
  '-ar[ambient resolution]:n:' \
  '-ad[ambient divisions]:n:' \
  '-as[ambient super-samples]:n:' \
  '-av[ambient value R G B]:r g b:' \
  '-aw[ambient weight]:n:' \
  '-af[ambient file]:file:_files' \
  '-ap[ambient cache]:file:_files' \
  '-lr[light reflection limit]:n:' \
  '-lw[light weight minimum]:val:' \
  '-i[irradiance mode]' \
  '-bv[backface visibility]' \
  '-o[output picture file (sequence template ok)]:file:_files' \
  '-S[sequence start frame number]:n:' \
  '-r[recover from interrupted run]:file:_files' \
  '-z[output depth buffer file]:file:_files' \
  '*:scene .oct file:_files -g "*.oct"' && ret=0
return ret
