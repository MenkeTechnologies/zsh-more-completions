#compdef networksetup
# Documentation: https://www.unix.com/man-page/osx/8/networksetup/
# Source: Apple macOS — Network preference pane CLI (services / DNS / Wi-Fi / proxies).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-listnetworkserviceorder[list services in connect-order]' \
    '-listallnetworkservices[list all services]' \
    '-listallhardwareports[list hardware ports + device + MAC]' \
    '-detectnewhardware[detect new hardware; create default services]' \
    '-getinfo[show IP/subnet/router/MAC for <service>]:service:' \
    '-setmanual[configure static IP (service ip subnet router)]:service:' \
    '-setdhcp[set service to DHCP]:service:' \
    '-getdhcpinfopacket[show last DHCP packet for service]:service:' \
    '-setdnsservers[set DNS servers]:service:' \
    '-getdnsservers[show DNS servers]:service:' \
    '-setsearchdomains[set search domains]:service:' \
    '-getsearchdomains[show search domains]:service:' \
    '-getairportnetwork[show current Wi-Fi network]:device:' \
    '-setairportnetwork[join Wi-Fi network (device ssid [password])]:device:' \
    '-getairportpower[Wi-Fi radio power state]:device:' \
    '-setairportpower[set Wi-Fi radio (device on/off)]:device:' \
    '-getwebproxy[HTTP proxy settings]:service:' \
    '-setwebproxy[set HTTP proxy (service host port)]:service:' \
    '-getsecurewebproxy[HTTPS proxy settings]:service:' \
    '-setsecurewebproxy[set HTTPS proxy]:service:' \
    '-getftpproxy[FTP proxy settings]:service:' \
    '-setftpproxy[set FTP proxy]:service:' \
    '-getcomputername[show computer name]' \
    '-setcomputername[set computer name]:name:' \
    '-getmacaddress[ethernet/Wi-Fi MAC for hardware port]:port:' \
    '-version[show version]' \
    '-help[show help]' \
    '*:args:' \
    && ret=0

return ret
