#compdef flash-kernel
# Documentation: man flash-kernel(8)
# Source: Debian flash-kernel (tobetter/flash-kernel mirror) functions — boot loader writer for embedded systems (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--force[skip safety checks]' \
    '--machine[override detected machine]:machine name:_default' \
    '--supported[check if current machine is supported and exit]' \
    '1::kernel version:_default' \
    && ret=0

return ret
