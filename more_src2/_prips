#compdef prips
# Documentation: https://manpages.debian.org/bookworm/prips/prips.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-c[print the range in CIDR notation]' \
  '-d[set delimiter ASCII code (0-255)]:delim' \
  '-e[exclude ranges from the output]:exclude pattern' \
  '-f[set address format]:format:(hex dec dot)' \
  '-h[show summary of options]' \
  '-i[set increment]:incr' \
  '1:start IP or CIDR' \
  '2::end IP' && ret=0

return ret
