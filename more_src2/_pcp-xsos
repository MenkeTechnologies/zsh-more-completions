#compdef pcp-xsos
# _pcp-xsos — PCP-based xsos-style system overview (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pcp/xsos/pcp-xsos.1 SYNOPSIS.

_pcp-xsos() {
    _arguments \
        '--all[show all sections]' \
        '-d[show disk info]' \
        '-m[show memory info]' \
        '-n[show network info]' \
        '-N[show NUMA info]' \
        '-o[show OS info]' \
        '-p[show process info]' \
        '-x[show extra info]' \
        '-u+[output units]:units:(B K M G T)'
}

_pcp-xsos "$@"
