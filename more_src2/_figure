# Documentation: https://docs.generic-mapping-tools.org/latest/figure.html
# Source: GenericMappingTools/gmt src/figure.c — register a figure in a modern-mode session (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*-V[verbose (stackable)]' \
    '1:prefix:_default' \
    '2::format(s):_values -s , format bmp eps jpg pdf png PNG ppm ps tif' \
    '*:psconvert options:_default' \
    && ret=0

return ret
