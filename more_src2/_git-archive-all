#compdef git-archive-all
# Documentation: https://github.com/Kentzo/git-archive-all
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-archive-all - archive a git repo with submodules

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
  '--prefix=[prepend prefix to each filename in archive]:prefix' \
  '-C+[base repo to archive]:repo:_directories' \
  '--no-export-ignore[ignore export-ignore in .gitattributes]' \
  '--force-submodules[force submodule init/update at each level]' \
  '--include=[additional files to include in archive]:file:_files' \
  '--dry-run[show files without creating archive]' \
  '-0[no compression]' \
  '-1[fastest compression]' \
  '-9[best compression]' \
  '*:output file:_files'
