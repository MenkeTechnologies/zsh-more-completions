#compdef ensembl-cli ensembl
# _ensembl-cli — Ensembl ensembl-cli CLI client to the Ensembl REST API querying genome assemblies sequences exons variants regulation comparative-genomics homology cross-references mapping VEP variant-effect-prediction for vertebrate non-vertebrate species GRCh38 GRCh37 mm10 hg38 (Ensembl team, Python); custom argparse
# upstream: https://rest.ensembl.org/

_ensembl-cli() {
    local -a sub=(
        'sequence:fetch genomic sequence'
        'lookup:lookup feature by id'
        'xrefs:cross-references for a feature'
        'overlap:features overlapping a region'
        'variation:variant data by id or rsid'
        'vep:run variant-effect prediction'
        'homology:homology data'
        'compara:comparative genomics'
        'regulation:regulatory features'
        'species:list species'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--species=+[species]:s:(homo_sapiens mus_musculus rattus_norvegicus danio_rerio drosophila_melanogaster saccharomyces_cerevisiae caenorhabditis_elegans gallus_gallus bos_taurus sus_scrofa canis_familiaris pan_troglodytes macaca_mulatta felis_catus equus_caballus oryctolagus_cuniculus xenopus_tropicalis takifugu_rubripes anopheles_gambiae plasmodium_falciparum)' \
        '--assembly=+[assembly]:a:(GRCh38 GRCh37 GRCm39 GRCm38 mRatBN7.2 ARS-UCD1.2 BDGP6 R64-1-1)' \
        '--region=+[chr:start-end]:str:' \
        '--coord-system=+[c]:c:(chromosome scaffold contig clone supercontig)' \
        '--object-type=+[t]:t:(gene transcript exon translation cds variation regulatoryfeature)' \
        '--feature=+[f]:f:(gene transcript exon cds intron regulatory variation motif)' \
        '--type=+[t]:t:(genomic cds cdna protein)' \
        '--mask=+[m]:m:(soft hard)' \
        '--canonical[only canonical]' \
        '--expand[expand to include children]' \
        '-f+[format]:f:(json xml gff3 bed fasta yaml table)' \
        '--format=+[format]:f:(json xml gff3 bed fasta yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ensembl-cli subcommand' sub ;;
    esac
}

_ensembl-cli "$@"
