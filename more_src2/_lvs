#compdef lvs
# _lvs — LVM2 lvs report Logical Volumes CLI (Red Hat / LVM2 team, C); custom argparse
# upstream: https://github.com/lvmteam/lvm2

_lvs() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a[all]' \
        '--all[all]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--ignorelockingfailure[ignore locking failure]' \
        '--ignoreskippedcluster[ignore skipped cluster]' \
        '--noheadings[no headings]' \
        '--nosuffix[no unit suffix]' \
        '--separator=+[field separator]:str:' \
        '--units=+[units]:u:(h H b s k K m M g G t T p P e E)' \
        '-o+[output columns]:list:' \
        '-O+[order by columns]:list:' \
        '--sort=+[sort columns]:list:' \
        '--reportformat=+[report format]:fmt:(basic json json_std)' \
        '--rows[transpose rows/columns]' \
        '--unbuffered[unbuffered]' \
        '--unquoted[no quotes]' \
        '--aligned[aligned]' \
        '--binary[binary 0/1]' \
        '--logonly[log only]' \
        '--readonly[readonly]' \
        '--shared[shared mode]' \
        '--config=+[config string]:str:' \
        '--devices=+[devices]:list:' \
        '--devicesfile=+[devices file]:file:_files' \
        '--select=+[select expr]:str:' \
        '--segments[report segments]' \
        '--logical-volumes[report LVs]' \
        '--history[include historical LVs]' \
        '*:vg-or-lv:'
}

_lvs "$@"
