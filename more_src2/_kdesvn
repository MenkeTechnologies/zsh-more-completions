#compdef kdesvn
# Documentation: https://man.archlinux.org/man/kdesvn.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kdesvn: KDE Subversion client
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including Qt-specific options]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '-r+[execute single command on specific revision(-range)]:startrev[:endrev]:' \
  '-R[ask for revision when executing single command]' \
  '-f[force operation]' \
  '-o+[save output of subversion command into file]:file:_files' \
  '-l+[limit log output to <number>]:number:' \
  '1:command:(exec)' \
  '*:repo URL / working copy:_files' && ret=0
return ret
