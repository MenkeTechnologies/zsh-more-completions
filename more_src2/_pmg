#compdef pmg
# Documentation: source-direct extraction from upstream
# materialsproject/pymatgen src/pymatgen/cli/pmg.py argparse
# `subparsers.add_parser(...)` declarations -> 8 subcommands
# (config, analyze, query, plot, structure, view, diff,
# potcar).  Per-subcommand `add_argument()` declarations
# decoded source-direct + per-subcommand
# `add_mutually_exclusive_group(required=True)` mutex groups
# decoded source-direct (config -p/-i/-a/--cp2k, query
# -s/-e/-d, plot -d/-c/-x, structure -c/-s/-g/-l, potcar
# -s/-r).  Enum autocompletes decoded source-direct from
# `choices=[...]` keyword args.
# Reference accessed: 2026-05-30 via gh api.
# materialsproject pymatgen R184 — pivot to computational
# materials science / DFT post-processing tooling.  pmg is the
# Python Materials Genomics CLI that powers Materials Project
# workflows: POTCAR setup, VASP calculation post-processing
# (analyze), Materials Project structure database queries
# (query), DOS/CHGCAR/XRD plotting, structure conversion +
# spacegroup determination + local-environment analysis
# (structure), structure visualisation (view), INCAR diffing
# (diff), and POTCAR generation (potcar).  Sister tool to the
# heavily-covered computational chemistry family (psi4, nwchem,
# vasp, quantum-espresso, gmx, mdtraj, antechamber, amber,
# cpptraj, vmd, pymol, ovito, pyscf, gabedit) already in the
# corpus.

local -a subcmds=(
  'config:configure pymatgen (POTCAR setup, .pmgrc.yaml)'
  'analyze:VASP calculation analysis tools'
  'query:search for structures and data from the Materials Project'
  'plot:plot DOS, CHGCAR, XRD, etc.'
  'structure:structure conversion and analysis tools'
  'view:visualise structures'
  'diff:diffing tool (INCAR only for now)'
  'potcar:generate POTCARs'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[print help and exit]' \
  '1: :->cmd' \
  '*:: :->sub'

case $state in
  cmd)
    _describe -t commands 'pmg subcommand' subcmds
    ;;
  sub)
    case $words[1] in
      config)
        # Mutex group (-p XOR -i XOR -a XOR --cp2k) decoded
        # source-direct from add_mutually_exclusive_group
        # (required=True).
        _arguments -s -S \
          '(-p --potcar -i --install -a --add --cp2k)'{-p,--potcar}'[POTCAR setup: extract-dir output-dir]:extract-dir:_files -/:output-dir:_files -/' \
          '(-p --potcar -i --install -a --add --cp2k)'{-i+,--install=}'[install optional CLI tool]:tool:(enumlib bader)' \
          '(-p --potcar -i --install -a --add --cp2k)'{-a,--add}'[add space-separated key value pairs (e.g. PMG_VASP_PSP_DIR ~/PSPs)]:vars:' \
          '(-p --potcar -i --install -a --add --cp2k)--cp2k[CP2K data setup: data-dir output-dir]:data-dir:_files -/:output-dir:_files -/' \
          '(-b --backup)'{-b+,--backup=}'[suffix for .pmgrc.yaml backup (default .bak; "" disables)]:suffix:'
        ;;
      analyze)
        _arguments -s -S \
          '(-e --energies)'{-e,--energies}'[print energies]' \
          '(-m --mag)'{-m+,--mag=}'[print magmoms (ion list "1-2" or "All")]:ion-list:' \
          '(-r --reanalyze)'{-r,--reanalyze}'[force reanalysis (do not reuse vasp_analyzer_data.gz)]' \
          '(-f --format)'{-f+,--format=}'[output table format]:fmt:(simple plain grid pipe orgtbl rst mediawiki html latex latex_raw latex_booktabs tsv presto pretty psql)' \
          '(-v --verbose)'{-v,--verbose}'[verbose]' \
          '(-q --quick)'{-q,--quick}'[faster but less detailed; parses individual VASP files]' \
          '(-s --sort)'{-s+,--sort=}'[sort criterion]:sort:(energy_per_atom filename)' \
          '*:VASP run directory:_files -/'
        ;;
      query)
        _arguments -s -S \
          '(-s --structure -e --entries -d --data)'{-s+,--structure=}'[get structures from MP, output format]:fmt:(poscar cif cssr)' \
          '(-s --structure -e --entries -d --data)'{-e+,--entries=}'[get entries from MP and serialise to file]:file:_files -g "*.(json|yaml|yml)"' \
          '(-s --structure -e --entries -d --data)'{-d,--data}'[print MP summary table with extra fields]' \
          ':criteria (formula / chemical system / mp-id):'
        ;;
      plot)
        _arguments -s -S \
          '(-d --dos -c --chgint -x --xrd)'{-d+,--dos=}'[plot DOS from vasprun.xml]:file:_files -g "vasprun*.xml"' \
          '(-d --dos -c --chgint -x --xrd)'{-c+,--chgint=}'[charge integration plot from CHGCAR]:file:_files -g "CHGCAR*"' \
          '(-d --dos -c --chgint -x --xrd)'{-x+,--xrd=}'[XRD plot from a supported structure file]:file:_files' \
          '(-s --site)'{-s,--site}'[plot site projected DOS]' \
          '(-e --element)'{-e+,--element=}'[comma-separated element list (e.g. Fe,Mn)]:elements:' \
          '(-o --orbital)'{-o,--orbital}'[plot orbital projected DOS]' \
          '(-i --indices)'{-i+,--indices=}'[comma-separated atom indices for CHGCAR plot]:indices:' \
          '(-r --radius)'{-r+,--radius=}'[integration radius for charge integration (default 3)]:angstrom:' \
          '--out_file=[save plot to file]:file:_files'
        ;;
      structure)
        _arguments -s -S \
          '(-f --filenames)'{-f+,--filenames=}'[list of structure files]:files:_files' \
          '(-c --convert -s --symmetry -g --group -l --localenv)'{-c,--convert}'[convert from structure file 1 to structure file 2 (format from filename)]' \
          '(-c --convert -s --symmetry -g --group -l --localenv)'{-s+,--symmetry=}'[determine spacegroup with given tolerance (0.1 typical for DFT)]:tol:' \
          '(-c --convert -s --symmetry -g --group -l --localenv)'{-g+,--group=}'[compare structures for similarity]:mode:(element species)' \
          '(-c --convert -s --symmetry -g --group -l --localenv)'{-l+,--localenv=}'[local env analysis (e.g. H-O=0.5)]:bonds:'
        ;;
      view)
        _arguments -s -S \
          '(-e --exclude_bonding)'{-e+,--exclude_bonding=}'[exclude elements from bonding analysis (e.g. Li,Na)]:elements:' \
          ':structure file:_files'
        ;;
      diff)
        _arguments -s -S \
          '(-i --incar)'{-i+,--incar=}'[2 INCARs to compare]:incar1:_files -g "INCAR*":incar2:_files -g "INCAR*"'
        ;;
      potcar)
        _arguments -s -S \
          '(-f --functional)'{-f+,--functional=}'[functional to use (PAW pseudopotential)]:functional:(PBE LDA PW91 PBE_52 PBE_54 LDA_52 LDA_54)' \
          '(-s --symbols -r --recursive)'{-s+,--symbols=}'[list of POTCAR symbols]:symbols:' \
          '(-s --symbols -r --recursive)'{-r+,--recursive=}'[recurse from dirname using POTCAR.spec]:dirname:_files -/'
        ;;
    esac
    ;;
esac
