#compdef drvctl
# Documentation: man drvctl(8)
# Source: netbsd/src sbin/drvctl — rescan busses and detach devices (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[interface attribute for device attachment]:attribute:_default' \
    '-d[detach driver from device]' \
    '-l[list child devices]' \
    '-n[suppress first column (-l) / headers (-p)]' \
    '-p[get device properties as XML]' \
    '-Q[resume ancestors, device, and descendants]' \
    '-R[resume ancestors and device itself]' \
    '-r[rescan specified bus]' \
    '-S[suspend descendants and device itself]' \
    '-t[print device tree (-l)]' \
    '1::device:_default' \
    '*::locator or property:_default' \
    && ret=0

return ret
