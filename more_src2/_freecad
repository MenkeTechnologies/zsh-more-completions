#compdef freecad FreeCAD FreeCADCmd
# Documentation: https://github.com/FreeCAD/FreeCAD-documentation/blob/main/wiki/Start_up_and_Configuration.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--verbose[print verbose version string]' \
  '(-c --console)'{-c,--console}'[run in console mode]' \
  '(-l --write-log)'{-l,--write-log}'[write FreeCAD.log to user directory]' \
  '--log-file=[log to file]:file:_files' \
  '(-u --user-cfg)'{-u+,--user-cfg=}'[user config file]:file:_files' \
  '(-s --system-cfg)'{-s+,--system-cfg=}'[system config file]:file:_files' \
  '(-t --run-test)'{-t+,--run-test=}'[run a test case (or 0 for all)]:test' \
  '(-r --run-open)'{-r+,--run-open=}'[run a test while keeping UI open]:test' \
  '(-M --module-path)'{-M+,--module-path=}'[additional module path]:dir:_files -/' \
  '(-P --python-path)'{-P+,--python-path=}'[additional Python path]:dir:_files -/' \
  '--response-file=[response file]:file:_files' \
  '--dump-config[dump configuration]' \
  '--get-config=[print value of a configuration key]:key' \
  '--set-config=[set the value of a configuration key]:key=value' \
  '--keep-deprecated-paths[maintain config files in legacy locations]' \
  '--single-instance[restrict to one application instance]' \
  '--safe-mode[force enable safe mode]' \
  '--pass[pass remaining args to scripts]' \
  '*:file:_files' && ret=0

return ret
