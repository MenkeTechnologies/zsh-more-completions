#compdef kubectl-ingress_nginx
# Documentation: https://kubernetes.github.io/ingress-nginx/kubectl-plugin/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
  '--all-namespaces[inspect resources in every namespace]' \
  '--deployment=[ingress-nginx deployment name]:deployment:' \
  '--pod=[ingress-nginx pod name]:pod:' \
  '--container=[container name]:container:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '--context=[kube context]:context:' \
  '--cluster=[kube cluster]:cluster:' \
  '(-s --server)'{-s+,--server=}'[Kubernetes API server address]:server:' \
  '--token=[bearer token]:token:' \
  '--client-certificate=[client cert]:file:_files' \
  '--client-key=[client key]:file:_files' \
  '--certificate-authority=[CA bundle]:file:_files' \
  '--insecure-skip-tls-verify[skip TLS verification]' \
  '--request-timeout=[request timeout]:duration:' \
  '--cache-dir=[cache directory]:dir:_files -/' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'backends:inspect the dynamic backend information'
      'certs:output the certificate data stored in a pod'
      'conf:inspect the generated nginx.conf'
      'exec:execute a command inside an ingress-nginx pod'
      'general:inspect other dynamic ingress-nginx information'
      'info:show information about the ingress-nginx service'
      'ingresses:short summary of all ingress definitions'
      'lint:inspect kubernetes resources for possible issues'
      'logs:get the logs for an ingress-nginx pod'
      'ssh:ssh into a running ingress-nginx pod'
    )
    _describe -t commands 'kubectl-ingress_nginx command' cmds && ret=0
    ;;
  args)
    _arguments -s -S '*: : _default' && ret=0
    ;;
esac

return ret
