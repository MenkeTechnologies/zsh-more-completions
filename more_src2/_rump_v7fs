#compdef rump_v7fs
# Documentation: man rump_v7fs(8)
# Source: netbsd/src usr.sbin/puffs/rump_v7fs — mount 7th Edition FS images via userspace rump server (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (see mount_v7fs(8))]:options:_default' \
    '1:image (supports %DISKLABEL\:p% suffix):_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
