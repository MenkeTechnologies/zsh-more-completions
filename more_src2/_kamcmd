#compdef kamcmd
# Documentation: https://www.kamailio.org/docs/tools/sr-tools.html
# Source: kamailio/kamailio utils/kamcmd/kamcmd.c — Kamailio binrpc/jsonrpc admin CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s+[unix socket name or hostname]:address:_default' \
    '-R+[force reply socket name (unix datagram)]:name:_default' \
    '-D+[directory for reply socket]:dir:_directories' \
    '-f+[print result using format (%v for values)]:format:_default' \
    '-b[use binrpc protocol]' \
    '-j[use jsonrpc protocol]' \
    '-t+[jsonrpc response timeout (seconds)]:seconds:_default' \
    '-z+[jsonrpc response buffer size (KB)]:kb:_default' \
    '-v[verbose]' \
    '(- *)-V[show version]' \
    '(- *)-h[show help]' \
    '*:rpc command and args:_default' \
    && ret=0

return ret
