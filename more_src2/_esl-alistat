#compdef esl-alistat
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-alistat.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-alistat: summary statistics of an MSA
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-1[tabular output, one line per MSA]' \
  '--informat=[input alignment format]:fmt:(stockholm pfam a2m afa psiblast clustal phylip phylips)' \
  '--amino[assume protein]' \
  '--dna[assume DNA]' \
  '--rna[assume RNA]' \
  '--small[memory-saving mode (Pfam format only)]' \
  '--list=[write all sequence names to file]:file:_files' \
  '--icinfo=[per-column information content]:file:_files' \
  '--rinfo=[per-column gap vs nongap residue frequency]:file:_files' \
  '--pcinfo=[per-column posterior probability info]:file:_files' \
  '--psinfo=[per-sequence posterior probability info]:file:_files' \
  '--iinfo=[insert residue info]:file:_files' \
  '--cinfo=[per-column residue counts]:file:_files' \
  '--noambig[exclude ambiguous residues from --cinfo counts]' \
  '--bpinfo=[per-column basepair counts]:file:_files' \
  '--weight[weight counts by sequence weights]' \
  '*:alignment file:_files' && ret=0
return ret
