#compdef magick-cli convert-cli
# _magick-cli — ImageMagick magick / convert image processing CLI alias (ImageMagick Studio LLC, C); custom argparse
# upstream: https://github.com/ImageMagick/ImageMagick

_magick-cli() {
    _arguments \
        '--help[show help]' \
        '-help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-V[show version]' \
        '-list+[list categories]:c:(Align Alpha Boolean Cache Channel Class CLI Color Colorspace Command Complex Compose Compress Configure DataType Debug Decoration Delegate Direction Dispose Distort Dither Endian Evaluate FillRule Filter Font Format Function Gradient Gravity Intent Interlace Interpolate Kernel Layers LineCap LineJoin List Locale LogEvent Log Magic Method Metric Mime Mode Module Morphology Noise Orientation PixelChannel PixelIntensity PixelMask PixelTrait Policy Preview Primitive QuantumFormat Resource SparseColor Statistic Storage Stretch Style Threshold Tool Type Units Validate VirtualPixel)' \
        '-quiet[quiet]' \
        '-verbose[verbose]' \
        '-debug+[debug events]:str:' \
        '-define+[define key=value]:list:' \
        '-density+[density]:str:' \
        '-depth+[depth]:n:' \
        '-monitor[monitor progress]' \
        '-format+[format]:str:' \
        '-quality+[quality]:n:' \
        '-strip[strip metadata]' \
        '-resize+[resize geometry]:str:' \
        '-rotate+[rotate degrees]:n:' \
        '-flip[flip vertically]' \
        '-flop[flop horizontally]' \
        '-crop+[crop geometry]:str:' \
        '-extent+[extent geometry]:str:' \
        '-gravity+[gravity]:g:(NorthWest North NorthEast West Center East SouthWest South SouthEast None)' \
        '-trim[trim edges]' \
        '-fuzz+[fuzz]:str:' \
        '-blur+[blur radius]:str:' \
        '-sharpen+[sharpen radius]:str:' \
        '-unsharp+[unsharp mask]:str:' \
        '-contrast[contrast]' \
        '-modulate+[modulate brightness,saturation,hue]:str:' \
        '-normalize[normalize]' \
        '-auto-level[auto level]' \
        '-auto-orient[auto orient]' \
        '-auto-gamma[auto gamma]' \
        '-colorspace+[colorspace]:c:(CIELab CMY CMYK Gray HCL HSB HSL HSI HWB Lab LCHab LCHuv LMS Log Luv OHTA Rec601Luma Rec601YCbCr Rec709Luma Rec709YCbCr RGB sRGB Transparent XYZ YCbCr YCC YDbDr YIQ YPbPr YUV)' \
        '-background+[background color]:str:' \
        '-bordercolor+[border color]:str:' \
        '-border+[border]:str:' \
        '-shadow+[shadow]:str:' \
        '-frame+[frame]:str:' \
        '-channel+[channel]:str:' \
        '-alpha+[alpha mode]:a:(Activate Associate Background Copy Deactivate Discrete Disassociate Extract Off On Opaque Remove Set Shape Transparent)' \
        '-transparent+[make color transparent]:str:' \
        '-thumbnail+[thumbnail geometry]:str:' \
        '-mosaic[create mosaic]' \
        '-montage+[montage]:str:' \
        '-tile+[tile geometry]:str:' \
        '-append[append vertically]' \
        '+append[append horizontally]' \
        '-composite[composite images]' \
        '-clone+[clone images]:str:' \
        '-delete+[delete images]:str:' \
        '-distort+[distort]:str:' \
        '-stretch+[font stretch]:str:' \
        '-style+[font style]:s:(Normal Italic Oblique Any)' \
        '-pointsize+[font pointsize]:n:' \
        '-font+[font]:str:' \
        '-fill+[fill color]:str:' \
        '-stroke+[stroke color]:str:' \
        '-strokewidth+[stroke width]:n:' \
        '-draw+[draw primitive]:str:' \
        '-annotate+[annotate geometry text]:str:' \
        '-write+[write file]:file:_files' \
        '-write-mask+[write mask file]:file:_files' \
        '*:file:_files'
}

_magick-cli "$@"
