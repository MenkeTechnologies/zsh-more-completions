#compdef darktable-generate-cache
# Documentation: https://docs.darktable.org/usermanual/development/en/special-topics/program-invocation/darktable-generate-cache/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# darktable-generate-cache: pre-build mipmap cache for the library
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)-h[show help]' \
  '--version[show version]' \
  '--min-mip=[minimum mipmap level (0..7)]:level:(0 1 2 3 4 5 6 7)' \
  '--max-mip=[maximum mipmap level (0..7)]:level:(0 1 2 3 4 5 6 7)' \
  '-m[set mipmap level (shortcut)]:level:(0 1 2 3 4 5 6 7)' \
  '--core[pass remaining args to darktable core]:args:' \
  '--library=[alternate library .db]:file:_files -g "*.db"' \
  '--configdir=[user config directory]:dir:_files -/' \
  '--cachedir=[user cache directory]:dir:_files -/' \
  '--tmpdir=[temporary directory]:dir:_files -/' \
  '--datadir=[install data directory]:dir:_files -/' \
  '--moduledir=[install module directory]:dir:_files -/' \
  '-d[debug filter]:filter:(all cache control dev opencl perf pwstorage sql memory nan masks lua print camsupport ioporder undo signal tiling lighttable verbose)' \
  '--disable-opencl[disable OpenCL]' \
  '--conf[set a config parameter]:key=value:' \
  '*::generate-cache extra args:_files' && ret=0
return ret
