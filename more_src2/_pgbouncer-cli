#compdef pgbouncer-cli
# Documentation: https://www.pgbouncer.org/usage.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[run in background as daemon]' \
  '(-q --quiet)'{-q,--quiet}'[quiet, no log to stderr]' \
  '(-R --reboot)'{-R,--reboot}'[do an online restart (deprecated)]' \
  '(-u --user)'{-u+,--user=}'[switch to user on startup]:user:_users' \
  '*'{-v,--verbose}'[increase verbosity]' \
  '--regservice[register Windows service]' \
  '--unregservice[unregister Windows service]' \
  '*:config file:_files -g "*.ini"' && ret=0

return ret
