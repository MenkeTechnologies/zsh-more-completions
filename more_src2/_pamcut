#compdef pamcut pnmcut
# Documentation: man pamcut (Netpbm)
# Source: extract a rectangular subregion from a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-left=[left edge column]:colnum:' \
    '-right=[right edge column]:colnum:' \
    '-top=[top edge row]:rownum:' \
    '-bottom=[bottom edge row]:rownum:' \
    '-width=[cropped width]:cols:' \
    '-height=[cropped height]:rows:' \
    '-pad[pad missing rows/columns with black]' \
    '-cropleft=[crop N columns from left]:cols:' \
    '-cropright=[crop N columns from right]:cols:' \
    '-croptop=[crop N rows from top]:rows:' \
    '-cropbottom=[crop N rows from bottom]:rows:' \
    '-reportonly[print resulting rectangle, do not cut]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:left top width height or pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
