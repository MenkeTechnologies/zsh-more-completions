#compdef kustomize-controller
# _kustomize-controller — FluxCD GitOps kustomize-controller (fluxcd/kustomize-controller)
# upstream: https://github.com/fluxcd/kustomize-controller
# Flags from main.go + fluxcd/pkg/runtime BindFlags.

_kustomize-controller() {
    _arguments \
        '--metrics-addr=[metrics bind address]:host\:port:' \
        '--events-addr=[events receiver address]:url:_urls' \
        '--health-addr=[healthz/readyz bind address]:host\:port:' \
        '--concurrent=[concurrent Kustomization reconciles]:n:' \
        '--concurrent-ssa=[concurrent server-side apply ops]:n:' \
        '--requeue-dependency=[failing dependency requeue interval]:dur:' \
        '--no-remote-bases[disallow remote bases in Kustomize builds]' \
        '--http-retry=[max retries for HTTP artifact fetches]:n:' \
        '--default-service-account=[default impersonation service account]:sa:' \
        '--default-decryption-service-account=[default decryption service account]:sa:' \
        '--default-kubeconfig-service-account=[default kubeconfig service account]:sa:' \
        '--sops-age-secret=[secret name with SOPS age fallback key]:name:' \
        '*--override-manager=[disallowed field manager]:fm:' \
        '--custom-apply-stage-kinds=[custom apply-stage GroupKinds (comma-sep)]:list:' \
        '--kube-api-qps=[Kubernetes API QPS]:f:' \
        '--kube-api-burst=[Kubernetes API burst]:n:' \
        '--log-encoding=[log encoding]:fmt:(json console)' \
        '--log-level=[log level]:level:(info debug error)' \
        '--enable-leader-election[enable leader election]' \
        '--leader-election-release-on-cancel=[release leader lock on cancel]:bool:(true false)' \
        '--leader-election-lease-duration=[leader lease duration]:dur:' \
        '--leader-election-renew-deadline=[leader renew deadline]:dur:' \
        '--leader-election-retry-period=[leader retry period]:dur:' \
        '--watch-all-namespaces=[watch all namespaces]:bool:(true false)' \
        '--watch-label-selector=[watched object label selector]:sel:' \
        '--watch-configs-label-selector=[watched configmaps/secrets label selector]:sel:' \
        '--min-retry-delay=[rate limiter min retry delay]:dur:' \
        '--max-retry-delay=[rate limiter max retry delay]:dur:' \
        '--no-cross-namespace-refs[disallow cross-namespace references]' \
        '--feature-gates=[feature-gate map (key=bool,...)]:gates:' \
        '--interval-jitter-percentage=[reconcile interval jitter %]:pct:'
}

_kustomize-controller "$@"
