#compdef lookout
# _lookout — Armada Lookout (web UI + REST/GraphQL API on top of the job-event Postgres store)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/lookout/main.go on tip; --migrateDatabase / --pruneDatabase are one-shot modes; everything else lives in the YAML config (./config/lookout or --config).

_lookout() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"' \
        '--migrateDatabase[run database migration then exit]' \
        '--pruneDatabase[prune old jobs then exit]'
}

_lookout "$@"
