#compdef rr
# Documentation: https://github.com/rr-debugger/rr/wiki/Usage
# Reference accessed: 2026-05-21
# Verified: upstream rr-debugger/rr src/*Command.cc list + manpage.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'record:record an execution'
  'replay:replay a recorded execution'
  'pack:pack a recording for distribution'
  'rerun:re-run replay deterministically'
  'ps:list traces in trace dir'
  'sources:list source files referenced by trace'
  'dump:dump events in trace'
  'trace-info:print trace metadata'
  'buildid:print build id of a trace'
  'cpufeatures:show CPU features used by recording'
  'ls:list traces'
  'mv:rename a trace'
  'rm:delete a trace'
  'filename:print full path of a trace file'
  'gdbinit:print gdb init lines'
  'lldbinit:print lldb init lines'
  'help:show help on a command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*--check-cached-mmaps[check cached mmaps]' \
  '*--cpu-unbound[no CPU binding]' \
  '*--disable-cpuid-features=[disable cpuid features]:f:' \
  '*--dump-syscalls=[dump syscalls]:f:_files' \
  '*--mark-stdio[mark stdio writes with metadata]' \
  '*--microarch=[CPU microarchitecture]:m:' \
  '*--non-interactive[non-interactive]' \
  '*--pid-namespace[use pid namespace]' \
  '*--resource-path=[resource path]:dir:_files -/' \
  '*--suppress-environment-warnings[suppress env warnings]' \
  '*--syscall-buffer-size=[syscall buffer MB]:mb:' \
  '*--ttl-mb=[ttl mb]:mb:' \
  '*-A[bind to one CPU]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'rr command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (record)
        _arguments \
          '(-h --help)'{-h,--help}'[help]' \
          '(-b --force-syscall-buffer)'{-b,--force-syscall-buffer}'[force syscall buffer]' \
          '(-n --no-syscall-buffer)'{-n,--no-syscall-buffer}'[disable syscall buffer]' \
          '(-c --num-cpu-ticks)'{-c+,--num-cpu-ticks=}'[CPU ticks per buffer]:n:' \
          '(-e --num-events)'{-e+,--num-events=}'[event limit before descheduling]:n:' \
          '*'{-i+,--ignore-signal=}'[block signal]:sig:' \
          '*'{-v+,--env=}'[add environment variable]:env:' \
          '(-u --cpu-unbound)'{-u,--cpu-unbound}'[run unbound to a CPU]' \
          '--scarce-fds[scarce fds]' \
          '(-w --wait)'{-w,--wait}'[wait for child to exit]' \
          '(-S --setuid-sudo)'{-S,--setuid-sudo}'[setuid via sudo]' \
          '*--continue-through-signal=[continue through signal]:sig:' \
          '--print-trace-dir=[print trace dir]:n:(0 1 2)' \
          '(-o --output-trace-dir)'{-o+,--output-trace-dir=}'[trace dir]:dir:_files -/' \
          '--chaos[chaos mode]' \
          '*: :_command_names -e' && ret=0 ;;
      (replay)
        _arguments \
          '(-h --help)'{-h,--help}'[help]' \
          '(-a --autopilot)'{-a,--autopilot}'[replay without debug server]' \
          '(-d --debugger)'{-d+,--debugger=}'[debugger command]:cmd:_command_names -e' \
          '(-g --goto)'{-g+,--goto=}'[goto event number]:n:' \
          '(-p --onprocess)'{-p+,--onprocess=}'[on process name or pid]:p:' \
          '(-x --gdb-x)'{-x+,--gdb-x=}'[gdb command file]:file:_files' \
          '(-q --no-redirect-output)'{-q,--no-redirect-output}'[skip stdout/stderr replay]' \
          '(-s --dbgport)'{-s+,--dbgport=}'[debug server port]:port:' \
          '(-t --trace)'{-t,--trace}'[singlestep + register dumps]' \
          '(-f --onfork)'{-f+,--onfork=}'[on fork]:p:' \
          '--stats=[print stats]:n:' \
          '--share-private-mappings[share private mappings]' \
          '--keep-listening[keep listening after disconnect]' \
          '--cpu-unbound[allow replay on any CPU]' \
          '--fullname[print full file names]' \
          '--interpreter=[debugger interpreter]:interp:' \
          '--serve-files[serve source files to debugger]' \
          '*: :_files -/' && ret=0 ;;
      (dump)
        _arguments \
          '(-b --syscallbuf)'{-b,--syscallbuf}'[display syscallbuf contents]' \
          '(-m --recorded-metadata)'{-m,--recorded-metadata}'[display recorded metadata]' \
          '(-p --mmaps)'{-p,--mmaps}'[display mmap data]' \
          '(-r --raw)'{-r,--raw}'[machine-parseable output]' \
          '(-s --statistics)'{-s,--statistics}'[trace statistics]' \
          '*: :_files -/' && ret=0 ;;
      (pack|rerun|ps|sources|trace-info|buildid|cpufeatures|ls|mv|rm|filename|gdbinit|lldbinit|help)
        _arguments \
          '*: :_files -/' && ret=0 ;;
      (*) _files ;;
    esac ;;
esac

return ret
