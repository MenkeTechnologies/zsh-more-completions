#compdef processhacker systeminformer
# _processhacker — Wen Jia Liu Process Hacker / System Informer task manager CLI alias (winsiderss, C); custom argparse
# upstream: https://github.com/winsiderss/systeminformer

_processhacker() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-s[selectpid]' \
        '-priority=+[set priority]:p:(realtime high abovenormal normal belownormal idle)' \
        '-iopriority=+[set io priority]:p:(verylow low normal high critical)' \
        '-pagepriority=+[set page priority]:n:' \
        '-elevate[elevate]' \
        '-noelevate[no elevate]' \
        '-newinstance[new instance]' \
        '-nosettings[no settings]' \
        '-settings+[settings file]:file:_files' \
        '-nokph[no kprocesshacker]' \
        '-installkph[install kprocesshacker]' \
        '-uninstallkph[uninstall kprocesshacker]' \
        '-startkph[start kprocesshacker]' \
        '-stopkph[stop kprocesshacker]' \
        '-debug[debug]' \
        '-hide[hide]' \
        '-showhidden[show hidden]' \
        '-shutdownsystem[shutdown system]' \
        '-restartsystem[restart system]' \
        '-lockworkstation[lock workstation]' \
        '-rundlginteg+[run dialog as user]:str:' \
        '-runas+[run as user]:str:_users' \
        '-systray+[show systray]:b:(1 0)' \
        '*:arg:'
}

_processhacker "$@"
