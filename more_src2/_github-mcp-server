#compdef github-mcp-server
# Documentation: https://github.com/github/github-mcp-server
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'stdio:run server in standard I/O mode'
  'tool-search:search available tools'
  'help:show help'
)

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--toolsets=[enable tool groups]:list' \
  '--tools=[enable individual tools]:list' \
  '--read-only[disable write operations]' \
  '--lockdown-mode[restrict public repo content access]' \
  '--insiders[enable experimental features]' \
  '--dynamic-toolsets[enable dynamic tool discovery]' \
  '--gh-host=[GitHub Enterprise/Cloud hostname]:host' \
  '--export-translations[export tool descriptions]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  command)
    _describe -t commands 'github-mcp-server command' commands && ret=0
    ;;
  args)
    case $words[1] in
      tool-search)
        _arguments -s -S \
          '--max-results=[max results]:n' \
          '*:query' && ret=0
        ;;
    esac
    ;;
esac

return ret
