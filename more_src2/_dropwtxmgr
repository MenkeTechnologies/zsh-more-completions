_dropwtxmgr() {
    case "${service:-${words[1]}}" in
        sweepaccount)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '--testnet[use the test bitcoin network]' \
                '--simnet[use the simulation bitcoin network]' \
                '--regtest[use the regression bitcoin network]' \
                '(-c --connect)'{-c,--connect}'=[hostname[:port] of wallet RPC server (default localhost)]:host:' \
                '(-u --rpcuser)'{-u,--rpcuser}'=[wallet RPC username]:user:' \
                '--cafile=[wallet RPC TLS certificate]:cert:_files -g "*.cert *.pem *.crt"' \
                '--feerate=[transaction fee per kilobyte (BTC)]:amount:' \
                '--sourceacct=[account to sweep outputs from (default imported)]:account:' \
                '--destacct=[account to send sweeped outputs to (default default)]:account:' \
                '--minconf=[required confirmations to include an output (default 1)]:n:' ;;
        dropwtxmgr|*)
            _arguments -s \
                '(- *)'{-h,--help}'[show help]' \
                '(-f --force)'{-f,--force}'[force removal without interactive prompt]' \
                '--db=[path to wallet database file]:db:_files -g "*.db"' \
                '--droplabels[also drop user-applied transaction labels]' \
                '--timeout=[timeout when opening the wallet database]:duration:' ;;
    esac
}

_dropwtxmgr "$@"
