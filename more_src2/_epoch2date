#compdef epoch2date
# Documentation: https://github.com/dmytro/zsh-compdef/blob/master/_epoch2date
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Repository: dmytro/zsh-compdef (_epoch2date)

local ret=1

_arguments \
  '-f+[output strftime format]:strftime:' \
  '(-g)-l[localtime]' \
  '(-l)-g[gmtime]' \
  '-r+[epoch regex kluge]:epochregex:' \
  '*:epoch:' \
  && ret=0

return $ret
