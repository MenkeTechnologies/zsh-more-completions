#compdef ppmtosixel
# Documentation: man ppmtosixel (Netpbm)
# Source: convert a PPM image to DEC sixel graphics.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-raw[raw output (no escape header)]' \
    '-margin[add page margin]' \
    '-7bit[restrict to 7-bit ASCII]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
