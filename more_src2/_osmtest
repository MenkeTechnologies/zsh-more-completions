#compdef osmtest
# Documentation: https://manpages.debian.org/bookworm/opensm/osmtest.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# osmtest: OpenSM regression tester
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-f[flow code (c create / v validate / s service / e events / f stress / m multicast / q qos / t trap / a all)]:flow:(c v s e f m q t a)' \
  '-w[wait time for traps 64/65 (seconds)]:seconds:' \
  '-d[debug option]:level:(0 1 2 3 4)' \
  '-m[max LID searched during inventory build]:lid:' \
  '-g[local port GUID]:guid:' \
  '-p[partition key]:pkey:' \
  '-i[inventory file]:file:_files' \
  '-s[stress test mode]:mode:' \
  '-M[multicast mode]:mode:' \
  '-l[log file]:file:_files' \
  '-vf[log flags]:flags:' \
  '-V[set max verbosity and force log flush]' \
  '*::osmtest args:_files' && ret=0
return ret
