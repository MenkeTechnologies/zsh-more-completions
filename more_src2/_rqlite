#compdef rqlite
# Documentation: https://rqlite.io/docs/cli/
# Reference accessed: 2026-05-21
# Verified: upstream rqlite/rqlite cmd/rqlite/main.go argT struct.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  '(- *)'{-v,--version}'[display CLI version]' \
  '(-a --alternatives)'{-a+,--alternatives=}'[fallback host:port list (comma separated)]:list:' \
  '(-s --scheme)'{-s+,--scheme=}'[protocol scheme]:scheme:(http https)' \
  '(-H --host)'{-H+,--host=}'[rqlited host address]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[rqlited host port]:port:' \
  '(-P --prefix)'{-P+,--prefix=}'[rqlited HTTP URL prefix]:prefix:' \
  '(-i --insecure)'{-i,--insecure}'[do not verify rqlited HTTPS certificate]' \
  '(-c --ca-cert)'{-c+,--ca-cert=}'[path to trusted X.509 root CA certificate]:file:_files' \
  '(-d --client-cert)'{-d+,--client-cert=}'[client X.509 certificate for mutual TLS]:file:_files' \
  '(-k --client-key)'{-k+,--client-key=}'[client X.509 key for mutual TLS]:file:_files' \
  '(-u --user)'{-u+,--user=}'[basic auth credentials user:pass]:creds:' \
  '(-t --http-timeout)'{-t+,--http-timeout=}'[HTTP request timeout (e.g. 30s)]:duration:' && ret=0

return ret
