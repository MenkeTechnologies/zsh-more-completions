#compdef gdcmxml
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmxml.cxx — DICOM ↔ XML converter (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input file]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(-V --verbose)'{-V,--verbose}'[verbose]' \
    '(-W --warning)'{-W,--warning}'[print warnings]' \
    '(-D --debug)'{-D,--debug}'[print debug info]' \
    '(-E --error)'{-E,--error}'[print errors]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '(-B --loadBulkData)'{-B,--loadBulkData}'[load bulk data from/to UUID files]' \
    '(-T --TransferSyntax)'{-T+,--TransferSyntax=}'[transfer syntax (default LittleEndianImplicit)]:syntax:_default' \
    '*:DICOM or XML file:_files' \
    && ret=0

return ret
