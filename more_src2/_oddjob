#compdef oddjobd oddjob
# Documentation: https://github.com/nalin-rec/oddjob
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-c+[config file]:file:_files' \
  '-d[debug mode]' \
  '-n[no fork]' \
  '-p+[pid file]:file:_files' \
  '-S[disable systemd integration]' && ret=0

return ret
