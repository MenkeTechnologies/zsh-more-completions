#compdef nthseqset
# Documentation: https://emboss.bioinformatics.nl/cgi-bin/emboss/help/nthseqset
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# EMBOSS nthseqset: extract the Nth alignment/set from multi-set input
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[input sequence sets]:sequence USA:_files' \
  '-number=[index of set to extract (1-based)]:n:' \
  '-outseq=[output sequence file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
