#compdef incusbox
# Documentation: https://github.com/MenkeTechnologies/zsh-more-completions
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: https://github.com/Interested-Deving-1896/incusbox/blob/6a14d5a35ec01f22b4eb2cb9614b2cb094caa083/incusbox/incusbox-completion
# Repository: Interested-Deving-1896/incusbox (incusbox/incusbox-completion)
#!/bin/bash
# SPDX-License-Identifier: GPL-3.0-only
# incusbox-completion: generate shell completion scripts for incusbox

set -e

version="0.1.0"

show_help() {
    cat <<EOF
incusbox-completion — generate shell completion scripts

Usage:
  incusbox completion bash
  incusbox completion zsh
  incusbox completion fish

Shells:
  bash    Bash completion (source in ~/.bashrc or /etc/bash_completion.d/)
  zsh     Zsh completion  (place in a \$fpath directory)
  fish    Fish completion (place in ~/.config/fish/completions/)

Examples:
  incusbox completion bash >> ~/.bashrc
  incusbox completion zsh  > ~/.zsh/completions/_incusbox
  incusbox completion fish > ~/.config/fish/completions/incusbox.fish
EOF
}

_top_cmds="assemble backup build cloud-sync completion config console create dashboard demo disk doctor enter export fleet gpu host-exec import monitor net profiles publish restore setup-rootless snapshot start status stop talos template tui update upgrade usb winesapos"

case "${1:-help}" in
    bash)
        cat <<BASH_COMPLETION
# incusbox bash completion  (auto-generated by: incusbox completion bash)
_incusbox_completion() {
    local cur prev
    cur="\${COMP_WORDS[COMP_CWORD]}"
    prev="\${COMP_WORDS[COMP_CWORD-1]}"

    local top_cmds="${_top_cmds}"

    if [[ \$COMP_CWORD -eq 1 ]]; then
        COMPREPLY=( \$(compgen -W "\$top_cmds" -- "\$cur") )
        return
    fi

    case "\$prev" in
        backup)
            COMPREPLY=( \$(compgen -W "create list delete help" -- "\$cur") ) ;;
        publish)
            COMPREPLY=( \$(compgen -W "create list delete help" -- "\$cur") ) ;;
        net)
            COMPREPLY=( \$(compgen -W "forward unforward list status nic help" -- "\$cur") ) ;;
        nic)
            COMPREPLY=( \$(compgen -W "add remove list help" -- "\$cur") ) ;;
        profiles)
            COMPREPLY=( \$(compgen -W "list show install diff apply remove help" -- "\$cur") ) ;;
        config)
            COMPREPLY=( \$(compgen -W "show init edit path" -- "\$cur") ) ;;
        upgrade)
            COMPREPLY=( \$(compgen -W "--check --no-snapshot --all --help" -- "\$cur") ) ;;
        snapshot)
            COMPREPLY=( \$(compgen -W "create list restore delete auto help" -- "\$cur") ) ;;
        completion)
            COMPREPLY=( \$(compgen -W "bash zsh fish" -- "\$cur") ) ;;
        usb)
            COMPREPLY=( \$(compgen -W "attach detach list list-host help" -- "\$cur") ) ;;
        disk)
            COMPREPLY=( \$(compgen -W "resize info help" -- "\$cur") ) ;;
        fleet)
            COMPREPLY=( \$(compgen -W "list status start-all stop-all backup-all help" -- "\$cur") ) ;;
        update)
            COMPREPLY=( \$(compgen -W "check install" -- "\$cur") ) ;;
    esac
}
complete -F _incusbox_completion incusbox
BASH_COMPLETION
        ;;
    zsh)
        cat <<'ZSH_COMPLETION'
# incusbox zsh completion  (auto-generated by: incusbox completion zsh)
_incusbox() {
    local state
    _arguments '1: :->cmd' '*: :->args'
    case $state in
        cmd)
            _values 'command' \
                'assemble[Create/update containers from a YAML file]' \
                'backup[Export/list/delete container backups]' \
                'build[Build a custom Incus image]' \
                'cloud-sync[Sync backups to cloud storage]' \
                'completion[Generate shell completion]' \
                'config[Manage configuration]' \
                'console[Attach to container console]' \
                'create[Create a new container]' \
                'dashboard[Launch web dashboard]' \
                'demo[Manage incus-demo-server]' \
                'disk[Live disk resize]' \
                'doctor[Check prerequisites]' \
                'enter[Enter a container]' \
                'export[Export a container]' \
                'fleet[Multi-container orchestration]' \
                'gpu[Manage GPU passthrough]' \
                'host-exec[Run a host command from inside a container]' \
                'import[Import a container]' \
                'monitor[Show container resource usage]' \
                'net[Manage networking]' \
                'profiles[Manage Incus profiles]' \
                'publish[Create and manage Incus images]' \
                'restore[Restore a container from backup]' \
                'setup-rootless[Configure rootless operation]' \
                'snapshot[Manage snapshots]' \
                'start[Start containers]' \
                'status[Show container status]' \
                'stop[Stop containers]' \
                'talos[Manage Talos Linux VMs]' \
                'template[Manage templates]' \
                'tui[Launch terminal UI]' \
                'update[Check for and install updates]' \
                'upgrade[Upgrade packages inside containers]' \
                'usb[Manage USB passthrough]' \
                'winesapos[Manage winesapOS containers]'
            ;;
        args)
            case ${words[2]} in
                backup)   _values 'subcommand' create list delete help ;;
                publish)  _values 'subcommand' create list delete help ;;
                net)      _values 'subcommand' forward unforward list status nic help ;;
                profiles) _values 'subcommand' list show install diff apply remove help ;;
                config)   _values 'subcommand' show init edit path ;;
                snapshot) _values 'subcommand' create list restore delete auto help ;;
                completion) _values 'shell' bash zsh fish ;;
                usb)      _values 'subcommand' attach detach list list-host help ;;
                disk)     _values 'subcommand' resize info help ;;
                fleet)    _values 'subcommand' list status start-all stop-all backup-all help ;;
                update)   _values 'subcommand' check install ;;
            esac
            ;;
    esac
}
_incusbox
ZSH_COMPLETION
        ;;
    fish)
        cat <<FISH_COMPLETION
# incusbox fish completion  (auto-generated by: incusbox completion fish)
set -l top_cmds ${_top_cmds}
complete -c incusbox -f -n 'not __fish_seen_subcommand_from \$top_cmds' -a "\$top_cmds"
complete -c incusbox -f -n '__fish_seen_subcommand_from backup'     -a 'create list delete help'
complete -c incusbox -f -n '__fish_seen_subcommand_from publish'    -a 'create list delete help'
complete -c incusbox -f -n '__fish_seen_subcommand_from net'        -a 'forward unforward list status nic help'
complete -c incusbox -f -n '__fish_seen_subcommand_from profiles'   -a 'list show install diff apply remove help'
complete -c incusbox -f -n '__fish_seen_subcommand_from config'     -a 'show init edit path'
complete -c incusbox -f -n '__fish_seen_subcommand_from snapshot'   -a 'create list restore delete auto help'
complete -c incusbox -f -n '__fish_seen_subcommand_from completion' -a 'bash zsh fish'
complete -c incusbox -f -n '__fish_seen_subcommand_from usb'        -a 'attach detach list list-host help'
complete -c incusbox -f -n '__fish_seen_subcommand_from disk'       -a 'resize info help'
complete -c incusbox -f -n '__fish_seen_subcommand_from fleet'      -a 'list status start-all stop-all backup-all help'
complete -c incusbox -f -n '__fish_seen_subcommand_from update'     -a 'check install'
FISH_COMPLETION
        ;;
    help|--help|-h)
        show_help ;;
    -V|--version)
        printf '%s\n' "${version}" ;;
    *)
        printf >&2 "incusbox-completion: unknown shell '%s'\n" "$1"
        printf >&2 "Supported: bash, zsh, fish\n"
        exit 1 ;;
esac
