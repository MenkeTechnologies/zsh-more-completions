#compdef pamtoqoi
# Documentation: https://manpages.debian.org/trixie/netpbm/pamtoqoi.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. Only Netpbm common option -quiet.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--quiet[suppress informational messages]' \
  '*:pnm file:_files -g "*.(pnm|pam|ppm|pgm|pbm)"' && ret=0

return ret
