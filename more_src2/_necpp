#compdef necpp nec2cpp nec2++
# Documentation: https://github.com/tmolteno/necpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nec2++ - C++ port of the Numerical Electromagnetics Code (NEC2).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[print usage information]' \
  '(- *)-v[print version and compiler information]' \
  '-i+[input file (required; use - for stdin)]:file:_files -g "*.nec"' \
  '-o+[output file]:file:_files' \
  '-g[return only the maximum gain to stdout]' \
  '-s[return output to stdout]' \
  '-c[use CSV result data format]' \
  '-x[use XML result data format]' \
  '-b[run benchmark mode]' \
  '*:file:_files' && ret=0

return ret
