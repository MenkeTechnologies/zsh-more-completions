#compdef exiwhat
# Documentation: https://manpages.debian.org/bookworm/exim4-base/exiwhat.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm exiwhat(8) manpage. Bare command that sends
# SIGUSR1 to all running Exim daemons and prints the resulting status
# lines. No CLI flags.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# exiwhat: show what Exim processes are currently doing
local curcontext="$curcontext" ret=1
_arguments -C && ret=0
return ret
