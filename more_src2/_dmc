#compdef dmc
# Documentation: https://www.manpagez.com/man/1/dmc/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Note: macOS Disk Mount Conditioner; degrades disk I/O on a mount point to
# simulate a slower device. Not the DigitalMars C++ compiler.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'start:start a DMC profile on a mount'
  'stop:stop DMC on a mount'
  'status:show status of DMC on a mount'
  'show:show a profile by name or index'
  'list:list profiles'
  'select:select a profile for a mount'
  'configure:configure a custom profile for a mount'
  'help:show help'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'dmc command' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (start)
        _arguments \
          '1:mount:_files -/' \
          '2:profile (name or index):' \
          '-boot[mark profile to apply at boot]' && ret=0
        ;;
      (stop|status|select|configure)
        _files -/ && ret=0
        ;;
      (status)
        _arguments \
          '1:mount:_files -/' \
          '-json[output JSON]' && ret=0
        ;;
    esac
    ;;
esac

return ret
