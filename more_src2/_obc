#compdef obc obr
# ============================================================================
# _obc — zsh completion for the Objeck programming language toolchain
#         (`obc` compiler + `obr` runtime).  Objeck is "an object-oriented,
#         JIT-compiled, AI-native programming language" — 168th
#         programming language entry
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/objeck/objeck-lang
#   Website    : https://www.objeck.org
#   Maintainer : Randy Hollines
#   License    : 3-clause BSD style (despite "All rights reserved"
#                 preamble, the body grants redistribution rights
#                 under standard BSD terms)
#   Stars      : 166
#   Language   : C++ (compiler) + C++ (JIT VM)
#   Project    : Objeck v2026.5.4
#   Binaries   : obc  (compiler — core/compiler/posix_main.cpp +
#                       win_main.cpp;  Usage: obc [options]
#                       <source files>)
#                obr  (runtime — core/vm/posix_main.cpp +
#                       win_main.cpp;  Usage: obr [options]
#                       <program>)
#   Source ext : .obs
#   Output ext : .obe  (compiled bytecode for `exe` target)
#   Last push  : 2026-05-31
#
# WHAT IT IS
#   Objeck is "a lightweight object-oriented and functional
#   programming language designed to be intuitive, JIT-compiled,
#   and AI-native".  It ships a `.obs` → `.obe` compiler with
#   four optimization levels (s0–s3), JIT support on ARM64 and
#   AMD64, an interactive REPL shell, an LSP server with VSCode/
#   Sublime/Kate plugins, a DAP debugger, and a stdlib that
#   covers HTTP/1.1, HTTP/2, HTTP/3/QUIC, WebSocket, DTLS,
#   threads, generics, closures, reflection, serialization, and
#   direct bindings to OpenAI, Gemini, Ollama, ONNX, and OpenCV
#   without third-party packages.  Source files use the `.obs`
#   extension;  `obc` compiles `.obs` → `.obe`, and `obr`
#   executes the resulting `.obe` bytecode through the Objeck
#   VM.
#
# CLI ARGUMENT GRAMMAR — obc  (verbatim from core/compiler/
#                               posix_main.cpp `usage += L"..."`
#                               help text)
#   obc [OPTIONS] <SOURCE FILES>
#
#   Options:
#     --source, -src, -s <FILES>     Source files (comma-
#                                    separated)
#     --destination, -dest, -d <F>   Output file name
#     --library, -lib, -l <LIBS>     Linked libraries (comma-
#                                    separated)
#     --target, -tar, -t <TYPE>      Target: 'lib' or 'exe'
#                                    [default: exe]
#     --optimize, -opt, -o <LEVEL>   Optimization: s0|s1|s2|s3
#                                    [default: s3]
#     --inline, -in, -i <CODE>       Inline code statements
#     --debug, -D                    Include debug symbols
#     --alt-syntax, -alt             Alternative C-like syntax
#     --assembly, -asm, -a           Emit assembly file
#     --strict                       Exclude default libraries
#     --version, -ver, -v            Show version
#
#   Examples:
#     obc hello.obs
#     obc --source hello.obs --destination hello.obe
#     obc -s hello.obs -d hello.obe -o s3 -D
#     obc -src file1.obs,file2.obs --debug
#
# CLI ARGUMENT GRAMMAR — obr  (verbatim from core/vm/
#                               posix_main.cpp `usage += L"..."`
#                               help text)
#   obr [OPTIONS] <PROGRAM>
#
#   Options:
#     --gc-threshold=<SIZE>          Initial garbage collection
#                                    threshold (number + k|m|g)
#     --GC_THRESHOLD=<SIZE>          Legacy alias for
#                                    --gc-threshold
#
#   Examples:
#     obr hello.obe
#     obr --gc-threshold=2m hello.obe
#
# LANGUAGE-CORPUS POSITION
#   Objeck is the 168th programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R941 (_openab / openabdev Rust=143 OPENS Axis 88 Discord
#   SDK / serenity) and continued through R942 (_bulkai /
#   igolaizola Go=143) and R943 (_commandkit / neplextech
#   TS-Node=143 CLOSES Axis 88 at 1/1/1 three-language
#   symmetry — triple-143 landmark and 81st axis closed).
#   Objeck joins Feral (R940 167th — R940 round-number commit
#   landmark), Biscuit/BL (R936 166th), Rux (R932 165th), Jule
#   (R928 164th), Nevalang (R924 163rd), Corvid (R920 162nd —
#   round-number R920 commit landmark), Soppo (R916 161st),
#   Cyrus (R912 160th — round-number language milestone),
#   Lumina (R908 159th), Penne (R904 158th), EndBASIC (R900
#   157th — R900 TRIPLE-9 commit landmark), goboscript (R896
#   156th), Alan (R892 155th), Mech (R888 154th — triple-8
#   landmark), Lisette (R884 153rd), Bril (R880 152nd), Vyxal
#   (R876 151st), EYG (R872 150th — round-number language
#   milestone), Roto (R868 149th), Pipefish (R864 148th),
#   Mochi (R860 147th), Oden (R856 146th), Hop (R852 145th),
#   Lustre via Kind 2 (R848 144th), Ravi (R844 143rd), ZetZ
#   (R840 142nd), Granule (R836 141st), Sixten (R832 140th),
#   Imba (R828 139th), Tao (R824 138th), Dada (R820 137th),
#   Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `obc` or `obr` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_obc() {
    case "${service:-${words[1]}}" in
        obr)
            _arguments -s \
                '--gc-threshold=[initial GC threshold (e.g. 2m)]:size:' \
                '--GC_THRESHOLD=[legacy alias for --gc-threshold]:size:' \
                ':Objeck bytecode program:_files -g "*.obe"' ;;
        obc|*)
            _arguments -s \
                '(--version -ver -v)'{--version,-ver,-v}'[show version]' \
                '(--source -src -s)'{--source,-src,-s}'=[source files (comma-separated)]:files:_files -g "*.obs"' \
                '(--destination -dest -d)'{--destination,-dest,-d}'=[output file name]:file:_files' \
                '(--library -lib -l)'{--library,-lib,-l}'=[linked libraries (comma-separated)]:libs:' \
                '(--target -tar -t)'{--target,-tar,-t}'=[target type]:type:(lib exe)' \
                '(--optimize -opt -o)'{--optimize,-opt,-o}'=[optimization level]:level:(s0 s1 s2 s3)' \
                '(--inline -in -i)'{--inline,-in,-i}'=[inline code statements]:code:' \
                '(--debug -D)'{--debug,-D}'[include debug symbols]' \
                '(--alt-syntax -alt)'{--alt-syntax,-alt}'[use alternative C-like syntax]' \
                '(--assembly -asm -a)'{--assembly,-asm,-a}'[emit assembly file]' \
                '--strict[exclude default libraries]' \
                '*:Objeck source file:_files -g "*.obs"' ;;
    esac
}

_obc "$@"
