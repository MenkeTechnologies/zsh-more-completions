#compdef onefetch
# Documentation: https://github.com/o2sh/onefetch/wiki/command-line-options
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for onefetch - Git repository info

local -a image_protocols=(
  'kitty:Kitty terminal graphics protocol'
  'sixel:Sixel graphics'
  'iterm:iTerm2 image protocol'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-a --ascii-language)'{-a,--ascii-language}'[which language to show ASCII art for]:language:' \
  '--ascii-input[take custom ASCII art from file or string]:input:' \
  '(-c --ascii-colors)'{-c,--ascii-colors}'[colors for ASCII art]:colors:' \
  '(-d --disabled-fields)'{-d,--disabled-fields}'[disable fields]:field:' \
  '(-E --email)'{-E,--email}'[show author email addresses]' \
  '(-e --exclude)'{-e,--exclude}'[exclude files/directories from analysis]:pattern:' \
  '--http-url[show repository URL in HTTP format]' \
  '--hide-token[obscure tokens in URLs]' \
  '(-i --image)'{-i,--image}'[path to image for the logo]:file:_files -g "*.{png,jpg,jpeg,gif,bmp,svg}"' \
  '--image-protocol[which image protocol to use]:protocol:((${(j: :)image_protocols}))' \
  '--color-resolution[set SIXEL color depth]:depth:' \
  '--include-hidden[include hidden files and directories]' \
  '--no-bold[do not bold fields]' \
  '--no-color-palette[hide color palette]' \
  '--no-art[hide ASCII art or image]' \
  '--no-merges[ignore merge commits]' \
  '--no-bots[exclude bot commits]:regex:' \
  '--no-title[hide the title]' \
  '--nerd-fonts[enable Nerd Font icons]' \
  '--number-of-authors[number of authors to display]:number:' \
  '--number-of-file-churns[number of file churns to display]:number:' \
  '--number-of-languages[number of languages to display]:number:' \
  '--number-separator[thousands separator style]:style:' \
  '(-o --output)'{-o,--output}'[define output format]:format:(json yaml)' \
  '(-t --text-colors)'{-t,--text-colors}'[set custom text colors]:colors:' \
  '--true-color[set true color terminal]:when:(auto always never)' \
  '(-T --type)'{-T,--type}'[filter by language type]:type:(programming markup prose data)' \
  '(-z --iso-time)'{-z,--iso-time}'[use ISO 8601 timestamps]' \
  '--churn-pool-size[minimum commits for file churn]:size:' \
  '--generate[generate shell completion]:shell:(bash fish zsh powershell elvish)' \
  '(-l --languages)'{-l,--languages}'[list supported languages]' \
  '(-p --package-managers)'{-p,--package-managers}'[list supported package managers]' \
  '*:repository:_directories' \
  && return 0
