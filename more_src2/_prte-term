#compdef prte-term
# Documentation: https://docs.prrte.org/en/latest/man/man1/prte-term.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable typical debug options]' \
  '--pmixmca[pass PMIx MCA parameters]:key value:' \
  '--dvm-uri[URI of the DVM master or file:filename]:uri:' \
  '--num-connect-retries[max number of times to try to connect]:n:' \
  '--pid[PID of the daemon to connect to]:pid:_pids' \
  '--namespace[namespace of the daemon to connect to]:name:' \
  '--system-server-first[look for system server first]' \
  '--system-server-only[connect only to system-level server]' \
  '--wait-to-connect[delay seconds before trying to connect]:seconds:' && ret=0

return ret
