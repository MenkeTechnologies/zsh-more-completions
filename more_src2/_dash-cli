#compdef dash-cli
# _dash-cli — Dash Core dash-cli JSON-RPC client CLI for the X11 PrivateSend InstantSend masternode-governance daemon issuing wallet getbalance sendtoaddress privatesend instantsend masternode protx llmq quorum gobject (dashpay team, C++); custom argparse
# upstream: https://github.com/dashpay/dash

_dash-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf dash.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-devnet=+[name]:str:' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblock getbalance listunspent sendtoaddress getnewaddress dumpprivkey importprivkey generate getrawtransaction sendrawtransaction signrawtransactionwithwallet privatesend instantsendlock submitblock masternodelist masternode protx quorum gobject voteraw mnsync sporkupdate spork chainlocks bls listlocks getgovernanceinfo)'
}

_dash-cli "$@"
