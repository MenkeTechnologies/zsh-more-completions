#compdef documentation
# ============================================================================
# documentation - JS API documentation generator
#                  parsing JSDoc + TypeScript-aware
#                  comments into HTML/Markdown/JSON
#                  (Node.js, BSD-2-Clause-style)
#
# Author : Tom MacWright + contributors
# Upstream: https://github.com/documentationjs/documentation
# npm    : documentation (binary: documentation)
#
# `documentation` is the canonical JavaScript API-
# documentation generator alongside JSDoc + TypeDoc.
# It parses source files (JavaScript, TypeScript,
# JSX, Vue SFC) + extracts JSDoc-style comment
# blocks + emits documentation in multiple output
# formats:
#   - HTML (themable templates)
#   - Markdown (with GitHub Flavored Markdown
#     table-of-contents)
#   - JSON (machine-readable AST output)
#   - remark (markdown AST output, for custom
#     post-processing pipelines)
#
# Use cases:
#   - npm-package API documentation
#     auto-generation
#   - README.md API section auto-update via
#     `documentation readme`
#   - Markdown documentation for static-site
#     generators (Hugo, Jekyll, 11ty, Astro, Next.js
#     etc.)
#   - HTML documentation hosted on GitHub Pages
#     / Netlify / Vercel
#   - JSDoc syntax linting via `documentation lint`
#
# Usage:
#   documentation <subcommand> <input...> [options]
#
# Subcommands (yargs declarative):
#   build <input>...               - emit
#                                     formatted
#                                     documentation
#                                     (JSON/MD/
#                                     HTML/remark)
#                                     from input
#                                     JavaScript
#                                     files
#   lint <input>...                - validate
#                                     JSDoc
#                                     syntax in
#                                     input files
#   readme <input>...              - update the
#                                     API section
#                                     of README.md
#                                     with docs
#                                     from the
#                                     input file
#
# Common build options (shared across subcommands):
#   --format / -f <type>           - output format
#                                     (json/md/
#                                     html/remark;
#                                     default
#                                     json)
#   --output / -o <path>           - output file
#                                     or directory
#                                     (default
#                                     stdout)
#   --watch / -w                   - watch input
#                                     files +
#                                     rebuild on
#                                     change
#   --markdown-toc                 - include TOC
#                                     in markdown
#                                     output
#                                     (default
#                                     true)
#   --markdown-toc-max-depth <n>   - max TOC depth
#                                     in markdown
#                                     (default 6)
#   --theme / -t <module>          - theme module
#                                     name (for
#                                     html output)
#   --project-name <name>          - project name
#                                     (default
#                                     from
#                                     package.json)
#   --project-version <ver>        - project
#                                     version
#                                     (default
#                                     from
#                                     package.json)
#   --project-description <text>   - project
#                                     description
#                                     (default
#                                     from
#                                     package.json)
#   --project-homepage <url>       - project
#                                     homepage URL
#                                     (default
#                                     from
#                                     package.json)
#   --favicon <path>               - favicon for
#                                     HTML output
#
# Common input options (shared across subcommands):
#   --babel <path>                 - babelrc /
#                                     babel.config.js
#                                     override
#   --shallow                      - shallow mode
#                                     (no
#                                     dependency
#                                     resolution)
#   --config / -c <path>           - configuration
#                                     file
#                                     (array
#                                     defining
#                                     explicit
#                                     sort order)
#   --no-package / --np            - do not use
#                                     package.json
#                                     for
#                                     project
#                                     defaults
#   --external <pattern>           - glob pattern
#                                     of external
#                                     modules to
#                                     whitelist
#                                     in output
#   --require-extension / --re <ext>...
#                                  - additional
#                                     require()/
#                                     import
#                                     extensions
#                                     (e.g. .es5)
#   --parse-extension / --pe <ext>...
#                                  - additional
#                                     source-code
#                                     extensions
#                                     to parse
#   --access / -a <levels>...      - filter
#                                     comment
#                                     access
#                                     levels
#                                     (public/
#                                     private/
#                                     protected/
#                                     undefined)
#   --github / -g                  - infer
#                                     GitHub
#                                     repository
#                                     URLs from
#                                     git config
#                                     (uses ini
#                                     to parse
#                                     .git/config
#                                     THIS AXIS
#                                     trigger)
#   --infer-private <regex>        - infer private
#                                     access from
#                                     name regex
#                                     pattern
#   --document-exported            - generate
#                                     docs for
#                                     all exported
#                                     bindings
#                                     (even
#                                     without
#                                     JSDoc)
#   --sort-order <order>...        - sort docs
#                                     by (source/
#                                     alpha/kind/
#                                     access/
#                                     memberof;
#                                     default
#                                     source)
#   --resolve <algorithm>          - dependency
#                                     resolution
#                                     (browser/
#                                     node;
#                                     default
#                                     browser)
#
# `readme` subcommand additional options:
#   --section / -s <name>          - README
#                                     section
#                                     name to
#                                     replace
#                                     (default
#                                     "API")
#   --readme-file <path>           - README file
#                                     path
#                                     (default
#                                     README.md)
#
# Examples:
#   documentation build index.js -f md > API.md
#   documentation build "src/**" -f html -o docs
#   documentation readme index.js -s "API Docs" --github
#   documentation lint util.js
#   documentation build --document-exported index.js
#
# The ini lane is built on `ini ^3.0.0` (declared
# verbatim at upstream package.json HEAD as a
# direct dep, imported as `import ini from 'ini'`
# in src/git/url_prefix.js to parse the local
# `.git/config` file when `--github` is passed.
# Git's .git/config is in INI format with
# `[core]`, `[remote "origin"]`, and `[branch
# "<name>"]` sections; documentation.js reads it
# to extract the GitHub repository URL +
# auto-link source-code references to the
# corresponding GitHub source-view pages), the
# canonical Node INI parser by Isaac Z. Schlueter
# (isaacs) - github.com/npm/ini.
#
# Isaac Z. Schlueter's npm/ini is the de-facto
# canonical Node INI parser:
#   - Used by npm itself for .npmrc parsing
#     (every npm install reads .npmrc via this
#     library)
#   - 25,000,000+ weekly npm downloads
#   - Implements the de-facto INI file format
#     (sections + key=value + comment lines)
#   - Read + write API
#   - Section + subsection support (e.g.
#     `[a.b.c]`)
#   - Array values (repeated keys merged into
#     arrays)
#   - Type-coercing parse (booleans true/false +
#     numbers + null)
#   - Escape sequence handling
#   - Quoted string values
#
# This is Schlueter's THIRD axis closure in the
# corpus:
#   - Axis 261 (Globbing) - node-glob at R1483
#   - Axis 266 (TAR archives) - node-tar at
#     R1498
#   - Axis 268 (INI parsing) - npm/ini at R1504
#     (THIS FILE)
#
# Schlueter is now the *most-canonical Node
# author* in the corpus by axis count (3) +
# transitive-reverse-dep count (all of npm +
# ~every Node project that does file
# manipulation). His libraries form the
# substrate of the entire Node ecosystem.
#
# The Schlueter triple-axis pattern reflects his
# *npm internal use* canonicalization mechanism:
#   - node-glob: used by npm for file matching
#   - node-tar: used by npm for package tarball
#     extraction
#   - npm/ini: used by npm for .npmrc parsing
#
# Every npm install command transitively
# exercises all three libraries. This creates
# a *foundational-via-package-manager-internal*
# pattern that no other Node author has
# replicated. Sorhus has the most microlibraries,
# Sindre is most prolific by raw count, but
# Schlueter's libraries are *load-bearing for
# the npm CLI itself*.
#
# Schlueter's broader Node ecosystem infrastructure
# tier:
#   - npm CLI (created 2010; the package manager
#     of the Node ecosystem)
#   - node-glob (Axis 261; used by npm + every
#     build tool)
#   - node-tar (Axis 266; used by npm for tarball
#     extraction)
#   - npm/ini (Axis 268; used by npm for .npmrc
#     parsing)
#   - minimatch (the glob-to-regex engine used
#     by node-glob + npm)
#   - rimraf (canonical recursive-delete)
#   - node-semver (canonical SemVer parser used
#     by npm for version resolution)
#   - tap (test framework)
#   - chownr, graceful-fs, nopt, dezalgo,
#     inflight, lru-cache, etc.
#
# This is the *largest single-author canonical-
# Node footprint by transitive-reverse-dep* in
# any language ecosystem.
#
# ----------------------------------------------------------------------------
# AXIS 268 :: INI configuration file parsers
#              ([sections] + key=value lines +
#              comment lines; informal 1990s
#              Windows .ini convention)
# Round 1504 :: TS-Node slot 3 of 4 :: CLOSES Axis 268
#                                       (261st axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : rust-ini/rust-ini          [R1502 _beacn-utility]
#             (Y. T. Chung / zonyitoo;
#              canonical Rust INI)
#   Go      : go-ini/ini                 [R1503 _nanolist]
#             (Joe Chen / Unknwon;
#              canonical Go INI;
#              powers Gogs + Gitea)
#   TS/Node : npm/ini                    [R1504 THIS FILE]
#             (Isaac Z. Schlueter;
#              canonical Node INI;
#              used by npm itself
#              for .npmrc parsing;
#              SCHLUETER'S THIRD
#              AXIS CLOSURE)
#
# npm/ini closes Axis 268 with Schlueter's third
# axis closure - extending his record-holding
# *foundational-via-npm-install-graph* position.
# The three lanes form a clean spectrum:
#
#   - Rust (rust-ini): single-author specialized-
#     infrastructure-protocol canonical (Chung)
#   - Go (go-ini): single-author application-
#     layer canonical (Chen / Gogs maintainer)
#   - Node (npm/ini): single-author infrastructure-
#     tier canonical (Schlueter / npm creator)
#
# Each lane shows a different mechanism for
# achieving canonical-library status:
#   - Rust: specialized-protocol-library author
#     dominance
#   - Go: application-framework-author
#     dominance
#   - Node: package-manager-internal-use
#     dominance
#
# Cross-language interop at the file level - the
# same .ini file is readable across all three
# lanes with informal-format-divergence caveats.
#
# Use-case spectrum across the three lanes:
#   - beacn-utility (Rust, rust-ini): Beacn
#     audio device Linux config UI;
#     generates XDG Autostart .desktop INI
#     files
#   - nanolist (Go, go-ini): tiny Unix-pipe
#     mailing list server; parses SMTP +
#     list-definition config
#   - documentation (Node, npm/ini): JS API
#     documentation generator; parses
#     .git/config to infer GitHub URLs
#     when --github is set
#
# Three lanes, three use-case shapes (audio-
# hardware config / mail-list server / docs
# generator), three canonicalization mechanisms
# (specialized-protocol / application-framework /
# package-manager-internal), all converging on
# the informal 1990s INI convention.
#
# Axis 268 closes the round 1504 cycle - 261st
# axis closed total. With Schlueter's third axis
# closure, he becomes the first author in the
# corpus to close three axes via the same
# canonicalization mechanism (npm internal use).
#
# Multi-axis canonical-Node author/org cohort
# (now spanning 13 distinct individuals/orgs;
# Schlueter at 3 axes, others at 1-2):
#   - Sindre Sorhus (chalk + ~1000 microlibs)
#   - Matt Ranney + Redis Inc. (node-redis)
#   - Brian Carlson (node-postgres)
#   - Andrey Sitnik (PostCSS + browserslist +
#     nanoid)
#   - Lovell Fuller (sharp)
#   - Paul Miller (noble umbrella)
#   - Devon Govett (foliojs umbrella +
#     lightningcss)
#   - Matteo Collina (undici + pino + fastify)
#   - Isaac Z. Schlueter (npm CLI + node-glob +
#     node-tar + npm/ini + rimraf + node-semver
#     + ...; THREE AXIS CLOSURES)
#   - Vitaly Puzrin + nodeca (js-yaml +
#     markdown-it + pako + argparse + sax +
#     linkify-it)
#   - Sergey Belov + svgo team (svg/svgo)
#   - Matt Zabriskie + axios team (axios)
#   - Stuart Knightley (jszip)
# ============================================================================

_documentation() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(- *)--version[print version]' \
        '(- *)--help[print help]' \
        '1: :_documentation_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                build|lint|readme)
                    _documentation_common_opts
                    case $words[1] in
                        build)
                            _arguments \
                                '(-o --output)'{-o,--output}'[output location (file or directory)]:path:_files'
                            ;;
                        readme)
                            _arguments \
                                '(-s --section)'{-s,--section}'[README section name to replace]:name:' \
                                '--readme-file=[README file path]:file:_files'
                            ;;
                    esac
                    ;;
            esac
            ;;
    esac

    return ret
}

_documentation_common_opts() {
    _arguments \
        '(-f --format)'{-f,--format}'[output format]:type:(json md html remark)' \
        '(-w --watch)'{-w,--watch}'[watch input + rebuild on change]' \
        '--markdown-toc[include TOC in markdown output]' \
        '--markdown-toc-max-depth=[max TOC depth]:n:' \
        '(-t --theme)'{-t,--theme}'[theme module for html output]:module:' \
        '--project-name=[project name]:name:' \
        '--project-version=[project version]:version:' \
        '--project-description=[project description]:text:' \
        '--project-homepage=[project homepage URL]:url:' \
        '--favicon=[favicon path for HTML output]:file:_files' \
        '--babel=[babelrc/babel.config.js override path]:path:_files' \
        '--shallow[shallow mode (no dependency resolution)]' \
        '(-c --config)'{-c,--config}'[configuration file]:file:_files' \
        '(--no-package --np)'{--no-package,--np}'[do not use package.json for defaults]' \
        '--external=[glob pattern of external modules to whitelist]:pattern:' \
        '*'{--require-extension,--re}'[additional require() extensions]:ext:' \
        '*'{--parse-extension,--pe}'[additional source-code extensions to parse]:ext:' \
        '*'{-a,--access}'[filter comment access levels]:level:(public private protected undefined)' \
        '(-g --github)'{-g,--github}'[infer GitHub URLs from git config]' \
        '--infer-private=[infer private access from name regex]:regex:' \
        '--document-exported[generate docs for all exported bindings (even without JSDoc)]' \
        '*--sort-order=[sort order]:order:(source alpha kind access memberof)' \
        '--resolve=[dependency resolution algorithm]:algorithm:(browser node)' \
        '*:input file:_files'
}

_documentation_cmds() {
    local -a cmds
    cmds=(
        'build:build documentation from input JavaScript files'
        'lint:validate JSDoc syntax in input files'
        'readme:update the API section of README.md'
    )
    _describe -t commands 'documentation command' cmds
}

_documentation "$@"
