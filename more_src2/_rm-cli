#compdef rm-cli
# _rm-cli — GNU coreutils rm remove files or directories CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_rm-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-f[force]' \
        '--force[force]' \
        '-i[interactive (before every)]' \
        '-I[interactive (before more than 3)]' \
        '--interactive=+[when]:w:(never once always)' \
        '--one-file-system[stay on file system]' \
        '--no-preserve-root[no preserve root]' \
        '--preserve-root[preserve root]' \
        '--preserve-root=+[mode]:m:(all)' \
        '-r[recursive]' \
        '-R[recursive]' \
        '--recursive[recursive]' \
        '-d[remove empty dirs]' \
        '--dir[remove empty dirs]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '*:files:_files'
}

_rm-cli "$@"
