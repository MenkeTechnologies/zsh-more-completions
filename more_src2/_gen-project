#compdef gen-project
# _gen-project — generate a multi-artifact project from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/projectgen.py (click).

_gen-project() {
    local -a args
    args=(
        '--dir=[output project directory]:dir:_files -/'
        '(-A --generator-arguments)'{-A+,--generator-arguments=}'[YAML config for per-generator arguments]:yaml:'
        '(-C --config-file)'{-C+,--config-file=}'[path to a YAML config file]:file:_files -g "*.(yaml|yml)"'
        '*'{-X+,--exclude=}'[artifact to exclude (repeatable)]:artifact:(jsonschema owl shex shacl python pydantic typescript java golang rust graphql sqla sqlddl prefixmap markdown excel csv doc plantuml erdiagram)'
        '*--include=[artifact to include (repeatable)]:artifact:(jsonschema owl shex shacl python pydantic typescript java golang rust graphql sqla sqlddl prefixmap markdown excel csv doc plantuml erdiagram)'
        '--mergeimports[merge imports into generated output]'
        '--no-mergeimports[do not merge imports]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-project "$@"
