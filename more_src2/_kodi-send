#compdef kodi-send
# Documentation: https://raw.githubusercontent.com/xbmc/xbmc/master/tools/EventClients/Clients/KodiSend/kodi-send.py
# Reference accessed: 2026-05-19
# Verified: upstream kodi-send.py usage() in the XBMC/Kodi source.

# Zsh completion for kodi-send - Kodi EventServer remote control CLI

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-?,--help}'[bring up usage message]' \
  '--host=[host to connect to (default localhost)]:host:_hosts' \
  '--port=[port to connect to (default 9777)]:port:' \
  '--keymap=[keymap to use for key presses (default KB)]:keymap:' \
  '*--button=[send a key press event (repeatable for a macro)]:button:' \
  '--mouse=[send the mouse position to Kodi]:X,Y:' \
  '--log=[send a log message to Kodi]:message:' \
  '--loglevel=[log level for --log (default LOGDEBUG)]:level:' \
  '--notification=[send a notification to Kodi]:message:' \
  '*'{-a,--action=}'[send an action (repeatable for a macro)]:action:' \
  '*'{-d,--delay=}'[wait for T ms (repeatable for a macro)]:ms:' \
  && ret=0

return ret
