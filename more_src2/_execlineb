#compdef execlineb
# Documentation: https://skarnet.org/software/execline/execlineb.html
# Reference accessed: 2026-05-30
# execlineb — script interpreter for the execline language (skarnet). Designed for run scripts in s6/s6-rc.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c)-c[execute SCRIPT directly (do not read from file)]:script:' \
  '-e[ignored (provided for `$SHELL -ec script` compatibility)]' \
  '(-q -w -W)-q[silent mode (force EXECLINE_STRICT unset)]' \
  '(-q -w -W)-w[warning mode (set EXECLINE_STRICT=1)]' \
  '(-q -w -W)-W[error/exit mode (set EXECLINE_STRICT=2)]' \
  '(-p -P)-p[bypass push phase (positional parameters overwritten)]' \
  '(-p -P)-P[bypass positional parameter handling completely (no env push)]' \
  '(-s -S)-S+[substitute positional parameters up to NMIN (no push, no env)]:nmin:' \
  '(-s -S)-s+[like -S but define $@ as remaining cmdline after NMIN args]:nmin:' \
  '1:script file (when -c not used):_files' \
  '*:arguments:' \
  && ret=0

return ret
