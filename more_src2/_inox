#compdef inox
# Documentation: https://github.com/inoxlang/inox
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Inox: privacy-fork of Chromium
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--incognito[start incognito]' \
  '--user-data-dir=[user data dir]:dir:_files -/' \
  '--proxy-server=[proxy server URL]:url:' \
  '--proxy-bypass-list=[proxy bypass list]:list:' \
  '--app=[app URL/path]:app:' \
  '--no-sandbox[disable sandbox]' \
  '--disable-gpu[disable GPU]' \
  '--lang=[locale]:lang:' \
  '--allow-running-insecure-content[allow http resources on https pages]' \
  '*:URL:' && ret=0
return ret
