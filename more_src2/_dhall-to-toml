#compdef dhall-to-toml
# Documentation: https://github.com/dhall-lang/dhall-haskell/tree/main/dhall-toml
# Source: dhall-lang/dhall-haskell dhall-toml/src/Dhall/DhallToToml.hs — compile Dhall to TOML.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--file=[read Dhall expression from FILE instead of stdin]:file:_files' \
    '--output=[write TOML to FILE instead of stdout]:file:_files' \
    '(- *)--version[display version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
