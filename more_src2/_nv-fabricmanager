#compdef nv-fabricmanager
# Documentation: https://docs.nvidia.com/datacenter/tesla/fabric-manager-user-guide/index.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nv-fabricmanager: NVIDIA Fabric Manager service (NVSwitch)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '-c[Fabric Manager config file path]:file:_files' \
  '--config=[Fabric Manager config file path]:file:_files' \
  '-r[restart Fabric Manager after exit (Shared NVSwitch/vGPU modes)]' \
  '--restart[restart Fabric Manager after exit]' \
  '-g[Fabric Manager and NVLink Subnet Manager management port GUID]:guid:' \
  '--fm-sm-mgmt-port-guid=[Fabric Manager and NVLink Subnet Manager management port GUID]:guid:' \
  '-d[Fabric Manager database engine]:engine:' \
  '--database=[Fabric Manager database engine]:engine:' && ret=0
return ret
