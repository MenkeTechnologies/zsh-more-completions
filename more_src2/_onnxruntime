#compdef onnxruntime onnxruntime_perf_test onnxruntime_test_all onnx_test_runner
# _onnxruntime — Microsoft onnxruntime cross-platform inference engine for ONNX models perf-test runner and benchmark binary (microsoft team, C++); custom argparse
# upstream: https://github.com/microsoft/onnxruntime

_onnxruntime() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-m+[memory pattern]:b:(0 1)' \
        '-c+[parallel threads]:n:' \
        '-r+[repeats]:n:' \
        '-t+[duration sec]:n:' \
        '-p+[parallel sessions]:n:' \
        '-s+[sequence length]:n:' \
        '-v[verbose]' \
        '-x[xnnpack]' \
        '-e+[execution provider]:p:(cpu cuda dnnl tensorrt openvino dml rocm migraphx coreml nnapi qnn vsinpu armnn webnn)' \
        '-A+[arena allocator]:b:(0 1)' \
        '-C+[cuda graph]:b:(0 1)' \
        '-d+[device id]:n:' \
        '-D+[disable thread spinning]:b:(0 1)' \
        '-i+[provider options]:str:' \
        '-I[input only inference]' \
        '-l+[log severity]:l:(0 1 2 3 4)' \
        '-M+[memory limit MB]:n:' \
        '-n+[disable mlas/onnxruntime nn fusion]:b:(0 1)' \
        '-o+[graph optimization level]:l:(0 1 2 3 99)' \
        '-P+[deterministic]:b:(0 1)' \
        '-q[query stats]' \
        '-R+[shared lib path]:file:_files' \
        '-S+[seed]:n:' \
        '-T+[trace file]:file:_files' \
        '-u+[optimized model output]:file:_files' \
        '-w+[warmup iterations]:n:' \
        '-y[use sync mode]' \
        '-Y[use async mode]' \
        '-Z[force single thread]' \
        '-z[force multi thread]' \
        '-f+[free dimension override]:str:' \
        '-F+[free dimension by name override]:str:' \
        '*:model:_files -g "*.onnx *.ort"'
}

_onnxruntime "$@"
