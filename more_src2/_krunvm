#compdef krunvm
# Documentation: https://github.com/slp/krunvm/blob/main/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (src/main.rs clap defs + docs/*.1.txt).

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'create:create a new microVM'
  'start:start a microVM'
  'list:list microVMs'
  'delete:delete a microVM'
  'changevm:change microVM config'
  'config:configure global default values'
)

_arguments -C \
  '*-v[verbosity level 0-5]' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'krunvm subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '--cpus=[number of vCPUs]:n:' \
          '--mem=[memory MiB]:n:' \
          '--dns=[DNS server IP]:addr:' \
          '--name=[VM name]:name:' \
          '(-w --workdir)'{-w,--workdir}'=[guest working dir]:dir:' \
          '*'{-v,--volume}'=[HOST_PATH:GUEST_PATH volume mapping]:mapping:' \
          '*'{-p,--port}'=[HOST_PORT:GUEST_PORT port mapping]:mapping:' \
          '*:image: ' && ret=0
        ;;
      (changevm)
        _arguments \
          '--cpus=[number of vCPUs]:n:' \
          '--mem=[memory MiB]:n:' \
          '--name=[new VM name]:name:' \
          '(-w --workdir)'{-w,--workdir}'=[guest working dir]:dir:' \
          '--remove-volumes[remove all volume mappings]' \
          '*'{-v,--volume}'=[HOST_PATH:GUEST_PATH volume mapping]:mapping:' \
          '--remove-ports[remove all port mappings]' \
          '*'{-p,--port}'=[HOST_PORT:GUEST_PORT port mapping]:mapping:' \
          '*:microVM: ' && ret=0
        ;;
      (config)
        _arguments \
          '--cpus=[default number of vCPUs]:n:' \
          '--mem=[default memory MiB]:n:' \
          '--dns=[default DNS server IP]:addr:' && ret=0
        ;;
      (start)
        _arguments \
          '--cpus=[override number of vCPUs]:n:' \
          '--mem=[override memory MiB]:n:' \
          '*:microVM: ' && ret=0
        ;;
      (list)
        _arguments '-d[debug output]' && ret=0
        ;;
      (delete)
        _arguments '*:microVM: ' && ret=0
        ;;
    esac
    ;;
esac

return ret
