#compdef pbmtolj
# Documentation: man pbmtolj (Netpbm)
# Source: convert a PBM image to an HP LaserJet PCL command stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-resolution+[output resolution dpi]:n:(75 100 150 300 600)' \
    '-float[do not move to top-left corner]' \
    '-noreset[do not reset printer at end]' \
    '-packbits[use PackBits compression]' \
    '-delta[use Delta-row compression]' \
    '-compress[use generic compression]' \
    '-copies+[number of copies]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
