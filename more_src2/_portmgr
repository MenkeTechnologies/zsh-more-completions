#compdef portmgr
# _portmgr — FreeBSD Ports portmgr CLI port-management dispatcher for the FreeBSD Ports Collection performing port build install deinstall upgrade reinstall search list outdated which fetch makesum mtree-check distfile-check ports-tree-status quarterly-tier audit options dependencies pkg-fallback management (FreeBSD team, shell); getopt
# upstream: https://www.freebsd.org/ports/

_portmgr() {
    local -a sub=(
        'install:install a port'
        'deinstall:deinstall a port'
        'upgrade:upgrade installed ports'
        'reinstall:reinstall a port'
        'remove:remove a port from index'
        'list:list installed ports'
        'list-outdated:list outdated ports'
        'search:search ports tree'
        'which:locate installed port'
        'fetch:fetch port distfile'
        'makesum:make port checksums'
        'distclean:clean distfiles'
        'clean:clean port work dir'
        'index:rebuild ports index'
        'pkg:pkg fallback management'
        'audit:audit installed ports for vulnerabilities'
        'options:edit port options'
        'check:check ports tree status'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-y[assume yes]' \
        '-n[dry run]' \
        '--portsdir=+[dir]:dir:_files -/' \
        '--builddir=+[dir]:dir:_files -/' \
        '--distdir=+[dir]:dir:_files -/' \
        '--make-flags=+[flags]:str:' \
        '--jobs=+[N]:n:' \
        '--keep-build-logs[keep build logs]' \
        '--ignore-osversion[ignore os version]' \
        '--fetch-only[fetch only]' \
        '--no-clean[no clean]' \
        '--checkflavors[check flavors]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'portmgr subcommand' sub ;;
        args)
            _arguments '*:port:'
            ;;
    esac
}

_portmgr "$@"
