#compdef evcxr
# Documentation: https://github.com/evcxr/evcxr
# Source: https://github.com/evcxr/evcxr/blob/main/evcxr_repl/src/bin/evcxr.rs
# Reference accessed: 2026-06-02
# Rust REPL. Use `:help` inside the REPL for `:`-prefixed commands.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--disable-readline[disable readline editing]' \
    '--ide-mode[run in IDE-friendly mode]' \
    '--opt=[optimization level]:level:(0 1 2)' \
    '--edit-mode=[edit mode]:mode:(emacs vi)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    && ret=0

return ret
