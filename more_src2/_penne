#compdef penne
# ============================================================================
# _penne — zsh completion for Sander in 't Veld's Penne, the
#           pasta-oriented programming language that compiles via LLVM
#           (158th language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/SLiV9/penne
#   Author     : Sander in 't Veld  <sanderintveld@hotmail.com>
#   License    : MIT
#   Stars      : 53
#   Language   : Rust (compiler) / Penne (.pn source files)
#   Crate      : penne v0.4.0
#   Binary     : penne  (Cargo.toml [package] name = "penne",
#                        built from src/main.rs)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Penne is "a pasta-oriented programming language that favors the
#   goto-statement for flow control" — Sander in 't Veld's
#   deliberately retro systems language whose primary control-flow
#   primitive is the labelled `goto`, in the tradition of early FORTRAN
#   and BASIC.  The compiler is a Rust front-end that lowers `.pn`
#   source files to LLVM IR and then shells out to a configurable
#   LLVM backend (`clang` for native builds, `lli` for JIT execution,
#   or a user-supplied alternative for custom toolchains).  WebAssembly
#   targeting is built in via `-w/--wasm` (which sets the target
#   triple to `wasm32-unknown-wasi`).  A built-in fuzzer generates
#   random source files using a selected fuzzing strategy.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/main.rs clap-derive
#                       Cli / Subcommand enum + per-subcommand Args
#                       structs;  `args_conflicts_with_subcommands`
#                       lets the bare-build form act as the default)
#   penne [<BUILD_ARGS>] [<filepaths>...]
#   penne <SUBCOMMAND> [args...]
#
#   Subcommands (the bare invocation defaults to `build`):
#     build  Compile one or more Penne source files into an
#            executable (default — `penne foo.pn bar.pn` is
#            equivalent to `penne build foo.pn bar.pn`).
#
#       -b, --backend <PATH>        LLVM executable to pipe the
#                                   generated IR into
#                                   [default: `clang`;
#                                    overridable via $PENNE_BACKEND
#                                    env var or `--config` TOML]
#       --backend-args <ARGS>       Space-separated arguments
#                                   forwarded to the backend
#       --config <FILE>             Load additional build options
#                                   from a TOML file
#       --link-args <ARGS>          Space-separated linker arguments
#       -o <PATH>                   Write the final binary to <PATH>
#       --out-dir <DIR>             Write the binary + emitted IR
#                                   into <DIR>
#       -w, --wasm                  Target `wasm32-unknown-wasi`
#       <filepaths>...              One or more `.pn` source files
#                                   (required)
#       (stdout::Options flattened — color / verbosity / quiet flags)
#
#     run    Generate LLVM IR from a Penne source file and execute
#            it directly via `lli`.
#
#       -b, --backend <PATH>        LLVM executable
#                                   [default: `lli`;
#                                    overridable via $PENNE_LLI]
#       --backend-args <ARGS>       Backend arguments
#       --out-dir <DIR>             Where to write IR
#       -w, --wasm                  Target wasm32-unknown-wasi
#       <filepaths>...              One or more `.pn` source files
#
#     emit   Generate LLVM IR from Penne source files (without
#            running the backend).
#
#       --out-dir <DIR>             Output directory for the IR
#       -w, --wasm                  Target wasm32-unknown-wasi
#       <filepaths>...              One or more `.pn` source files
#
#     fuzz   Generate random Penne source files for fuzzing the
#            compiler itself.
#
#       <strategy>                  Fuzzing strategy
#                                   (from
#                                    penne::delta::fuzzer::
#                                    FuzzingStrategy enum)
#       --kb <N>                    Kilobytes of random source to
#                                   generate (required)
#       --mistakes <N>              Inject this many random mistakes
#                                   into the generated source
#       --out-dir <DIR>             Where to write generated files
#
#   Standard clap auto-flags (with `propagate_version`):
#     -h, --help                   Show help
#     -V, --version                Show version
#
#   Environment variables:
#     PENNE_BACKEND                 Default `--backend` for `build`
#     PENNE_LLI                     Default `--backend` for `run`
#
# LANGUAGE-CORPUS POSITION
#   Penne is the 158th programming language entry in this completion
#   corpus, closing the 3+1 micro-cycle that began at R901 (_nostcat
#   / tungstenite 0.18.0 Rust=133 OPENS Axis 78 WebSocket Protocol
#   Library) and continued through R902 (_burst / gorilla/websocket
#   v1.5.0 Go=133) and R903 (_wscli / ws ^7.2.0 TS-Node=133 CLOSES
#   Axis 78 at 1/1/1 three-language symmetry — triple-133 landmark
#   and 71st axis closed).  Penne joins EndBASIC (R900 157th —
#   R900 TRIPLE-9 commit landmark), goboscript (R896 156th), Alan
#   (R892 155th), Mech (R888 154th — triple-8 landmark), Lisette
#   (R884 153rd), Bril (R880 152nd), Vyxal (R876 151st), EYG (R872
#   150th — round-number language milestone), Roto (R868 149th),
#   Pipefish (R864 148th), Mochi (R860 147th), Oden (R856 146th),
#   Hop (R852 145th), Lustre via Kind 2 (R848 144th), Ravi (R844
#   143rd), ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832
#   140th), Imba (R828 139th), Tao (R824 138th), Dada (R820 137th),
#   Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `penne` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_penne() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-b --backend)'{-b+,--backend=}'[LLVM backend executable (default clang for build)]:backend:_command_names -e' \
        '--backend-args=[space-separated arguments forwarded to backend]:backend args:' \
        '--config=[load additional build options from TOML file]:config file:_files -g "*.toml"' \
        '--link-args=[space-separated linker arguments]:linker args:' \
        '-o+[write binary output to file]:output file:_files' \
        '--out-dir=[write binary and IR to directory]:dir:_files -/' \
        '(-w --wasm)'{-w,--wasm}'[target wasm32-unknown-wasi]' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_penne_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build)
                    _arguments \
                        '(-b --backend)'{-b+,--backend=}'[LLVM backend (default clang)]:backend:_command_names -e' \
                        '--backend-args=[backend args (space-separated)]:args:' \
                        '--config=[TOML config file]:config file:_files -g "*.toml"' \
                        '--link-args=[linker args]:args:' \
                        '-o+[output file]:output file:_files' \
                        '--out-dir=[output dir]:dir:_files -/' \
                        '(-w --wasm)'{-w,--wasm}'[target wasm32-unknown-wasi]' \
                        '*:Penne source file:_files -g "*.pn"' && ret=0 ;;
                run)
                    _arguments \
                        '(-b --backend)'{-b+,--backend=}'[LLVM backend (default lli)]:backend:_command_names -e' \
                        '--backend-args=[backend args]:args:' \
                        '--out-dir=[output dir]:dir:_files -/' \
                        '(-w --wasm)'{-w,--wasm}'[target wasm32-unknown-wasi]' \
                        '*:Penne source file:_files -g "*.pn"' && ret=0 ;;
                emit)
                    _arguments \
                        '--out-dir=[output dir]:dir:_files -/' \
                        '(-w --wasm)'{-w,--wasm}'[target wasm32-unknown-wasi]' \
                        '*:Penne source file:_files -g "*.pn"' && ret=0 ;;
                fuzz)
                    _arguments \
                        ':fuzzing strategy:' \
                        '--kb=[KB of random source to generate (required)]:KB:' \
                        '--mistakes=[number of random mistakes to inject]:N:' \
                        '--out-dir=[output dir]:dir:_files -/' && ret=0 ;;
                *)
                    _files -g "*.pn" && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_penne_commands] )) ||
_penne_commands() {
    local -a commands
    commands=(
        'build:compile Penne source files to an executable (default)'
        'run:generate LLVM IR and execute via lli'
        'emit:generate LLVM IR only (no backend execution)'
        'fuzz:generate random Penne source files for fuzzing'
    )
    _describe -t commands 'penne command' commands
}

_penne "$@"
