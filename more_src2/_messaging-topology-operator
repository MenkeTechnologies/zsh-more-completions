#compdef messaging-topology-operator
# _messaging-topology-operator — RabbitMQ Messaging Topology Operator (reconciles Vhost/Queue/Exchange/Binding/User/Policy/Permission/Federation/Shovel/SchemaReplication CRs into a running RabbitmqCluster via the management API)
# upstream: https://github.com/rabbitmq/messaging-topology-operator
# Flags from cmd/main.go on tip + controller-runtime/zap.Options.

_messaging-topology-operator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--metrics-bind-address=[metrics endpoint bind address]:addr:' \
        '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
        '--leader-elect[enable leader election]' \
        '--metrics-secure=[serve metrics over HTTPS]:bool:(true false)' \
        '--webhook-cert-path=[directory containing the webhook certificate]:dir:_files -/' \
        '--webhook-cert-name=[webhook certificate filename]:name:' \
        '--webhook-cert-key=[webhook key filename]:name:' \
        '--metrics-cert-path=[directory containing the metrics server cert]:dir:_files -/' \
        '--metrics-cert-name=[metrics server certificate filename]:name:' \
        '--metrics-cert-key=[metrics server key filename]:name:' \
        '--enable-http2[enable HTTP/2 for the webhook + metrics servers]' \
        '--zap-devel[zap development-mode encoder]' \
        '--zap-encoder=[zap log encoder]:enc:(json console)' \
        '--zap-log-level=[zap log level]:level:(debug info warn error dpanic panic fatal)' \
        '--zap-stacktrace-level=[zap log level that triggers a stacktrace]:level:(info error panic)' \
        '--zap-time-encoding=[zap time encoding]:enc:(epoch millis nano iso8601 rfc3339 rfc3339nano)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_messaging-topology-operator "$@"
