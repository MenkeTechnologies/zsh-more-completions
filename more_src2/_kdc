#compdef kdc krb5kdc
# _kdc — Heimdal kdc / MIT krb5kdc (Kerberos Key Distribution Center daemon; --config-file picks krb5.conf, --realm scopes to one realm, --addresses list, --enable-http enables HTTP transport, -P pidfile, --detach forks, -p ports listen list)
# upstream: https://github.com/heimdal/heimdal (kdc) ; https://github.com/krb5/krb5 (krb5kdc)
# Flags from heimdal kdc/main.c on tip.

_kdc() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--config-file+[config file]:file:_files' \
        '--no-config-file[skip config file]' \
        '--realm+[realm]:realm:' \
        '--addresses+[listen addresses]:addresses:' \
        '--max-request+[max request bytes]:bytes:' \
        '--enable-http[enable HTTP transport]' \
        '-P[do not detach]' \
        '--detach[detach to background]' \
        '-p+[listen ports]:ports:' \
        '--port+[listen ports]:ports:' \
        '--key-file+[key file]:file:_files' \
        '--hdb+[HDB URL]:url:' \
        '--no-fork[do not fork]' \
        '*-l[log level]:level:'
}

_kdc "$@"
