#compdef pnmtotiffcmyk
# Documentation: man pnmtotiffcmyk (Netpbm)
# Source: convert a Netpbm image to a CMYK TIFF file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-none -packbits -lzw)-none[no compression]' \
    '(-none -packbits -lzw)-packbits[PackBits compression]' \
    '(-none -packbits -lzw)-lzw[LZW compression (default)]' \
    '-predictor=[LZW predictor]:n:' \
    '(-msb2lsb -lsb2msb)-msb2lsb[fill MSB to LSB]' \
    '(-msb2lsb -lsb2msb)-lsb2msb[fill LSB to MSB]' \
    '-rowsperstrip=[rows per strip]:n:' \
    '-lowdotrange=[low dot range]:n:' \
    '-highdotrange=[high dot range]:n:' \
    '(-knormal -konly -kremove)-knormal[normal K (black) channel]' \
    '(-knormal -konly -kremove)-konly[output only K channel]' \
    '(-knormal -konly -kremove)-kremove[remove K from CMY]' \
    '(-default -negative)-default[default algorithm]' \
    '(-default -negative)-negative[negative algorithm]' \
    '-theta=[hue rotation degrees]:deg:' \
    '-gamma=[gamma value]:n:' \
    '-gammap=[gamma p value]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
