#compdef grdctl
# _grdctl — GNOME Remote Desktop grdctl (manage gnome-remote-desktop daemon's RDP/VNC backends; rdp/vnc subcommand stems each take enable/disable/status/set-credentials/clear-credentials/set-port/set-tls-cert/clear-tls-cert)
# upstream: https://gitlab.gnome.org/GNOME/gnome-remote-desktop
# Subcommands from gnome-remote-desktop src/grdctl.c on tip.

_grdctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--headless[headless backend]' \
        '--system[system backend]' \
        '--user[user backend]' \
        '1: :->backend' \
        '*::arg:->args'
    case $state in
        backend) _describe -t commands 'backend' '(rdp vnc status)' ;;
        args)
            case $line[1] in
                rdp|vnc) _describe -t commands 'subcommand' '(enable disable status set-credentials clear-credentials set-port clear-port set-tls-cert clear-tls-cert set-tls-key clear-tls-key)' ;;
            esac
            ;;
    esac
}

_grdctl "$@"
