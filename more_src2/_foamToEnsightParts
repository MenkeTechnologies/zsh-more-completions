#compdef foamToEnsightParts
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/postProcessing/dataConversion/foamToEnsightParts — convert OpenFOAM case to EnSight Parts format (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-time+[restrict to selected times]:times:_default' \
    '-latestTime[use latest time]' \
    '-newTimes[only new times]' \
    '-ascii[write EnSight files in ASCII]' \
    '-index+[starting index]:start:_default' \
    '-noMesh+[do not write mesh (name)]:name:_default' \
    '-subdir+[output sub-directory]:subdir:_default' \
    '-width+[zero-padding width]:n:_default' \
    '-region+[region name]:region:_default' \
    && ret=0

return ret
