#compdef konveyor-analyzer
# _konveyor-analyzer — Konveyor analyzer-lsp rule-based source code analyzer
# upstream: https://github.com/konveyor/analyzer-lsp
# Flags from cmd/analyzer/main.go on tip.

_konveyor-analyzer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-file=[violations output file]:file:_files' \
        '--error-on-violation=[exit 3 if any violation found]:bool:(true false)' \
        '--verbose=[log verbosity level]:n:' \
        '--enable-jaeger=[enable Jaeger tracing exports]:bool:(true false)' \
        '--jaeger-endpoint=[Jaeger collector endpoint]:url:_urls' \
        '--get-openapi-spec=[write OpenAPI spec for rulesets to file]:file:_files' \
        '--tree=[print dependencies as a tree]:bool:(true false)' \
        '--dep-output-file=[dependency output file]:file:_files' \
        '--progress-output=[progress event sink (stderr/stdout/file)]:dest:' \
        '--progress-format=[progress output format]:fmt:(bar text json)' \
        '--rules=[rules file or directory]:path:_files' \
        '--provider-settings=[provider settings file]:file:_files' \
        '--source-location=[source code location]:dir:_files -/' \
        '-v[verbosity level]:n:'
}

_konveyor-analyzer "$@"
