#compdef lxd-cli
# _lxd-cli — Canonical LXD container/virt admin CLI alias (Canonical, Go); custom argparse
# upstream: https://github.com/canonical/lxd

_lxd-cli() {
    local -a sub=(
        'activateifneeded:activate LXD if needed'
        'cluster:cluster commands'
        'callhook:internal callhook'
        'forkconsole:internal forkconsole'
        'forkdns:internal forkdns'
        'forkexec:internal forkexec'
        'forkfile:internal forkfile'
        'forknet:internal forknet'
        'forkproxy:internal forkproxy'
        'forkstart:internal forkstart'
        'forksyscall:internal forksyscall'
        'forkuevent:internal forkuevent'
        'forkzfs:internal forkzfs'
        'import:import container/VM backup'
        'init:initialize LXD'
        'manpage:generate man pages'
        'migratedumpsuccess:internal migrate dump success'
        'netcat:internal netcat'
        'recover:recover from broken state'
        'shutdown:shutdown LXD'
        'sql:execute SQL'
        'version:show version'
        'waitready:wait until LXD is ready'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--logfile=+[log file]:file:_files' \
        '--debug[debug]' \
        '-d[debug]' \
        '--trace=+[trace logging targets]:list:(dqlite raft storage db api network)' \
        '--syslog[log to syslog]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--group=+[group]:str:_groups' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lxd subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--auto[auto config]' \
                    '--dump[dump current config]' \
                    '--minimal[minimal config]' \
                    '--preseed[read yaml from stdin]' \
                    '--network-address=+[network address]:str:' \
                    '--network-port=+[network port]:port:' \
                    '--storage-backend=+[storage backend]:b:(dir btrfs ceph cephobject lvm lvmcluster zfs powerflex pure)' \
                    '--storage-create-loop=+[loop size]:str:' \
                    '--storage-create-device=+[storage device]:file:_files' \
                    '--storage-pool=+[storage pool name]:str:' \
                    '--trust-password=+[trust password]:str:' ;;
                cluster) _arguments \
                    '1:cmd:(add edit list list-database recover-from-quorum-loss remove-raft-node show)' \
                    '*:arg:' ;;
                import) _arguments \
                    '--force-local[force local]' \
                    '*:tarball:_files -g "*.tar.gz *.tar.xz *.tgz *.txz"' ;;
                shutdown) _arguments \
                    '--timeout=+[timeout]:n:' \
                    '-t+[timeout]:n:' ;;
                recover|waitready|sql|activateifneeded|version) _arguments '*:arg:' ;;
                manpage) _arguments \
                    '1:directory:_files -/' ;;
            esac
            ;;
    esac
}

_lxd-cli "$@"
