#compdef git-codereview
# Documentation: https://pkg.go.dev/golang.org/x/review/git-codereview
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for git-codereview - Gerrit code review workflow (Go)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-n[print commands without executing]' \
  '*-v[increase verbosity]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'branchpoint:print shared commit with Gerrit server'
      'change:create or amend a Gerrit change'
      'gofmt:run gofmt on staged files'
      'help:show help'
      'hooks:install Git hooks for code review'
      'hook-invoke:invoke a named hook (internal)'
      'mail:send change for review to Gerrit'
      'pending:show pending changes'
      'rebase-work:interactive rebase over pending changes'
      'reword:edit pending commit messages'
      'submit:submit the current change'
      'sync:update local repo and rebase pending changes'
      'sync-branch:sync with the parent branch'
    )
    _describe -t commands 'git-codereview command' commands && ret=0
    ;;
  args)
    case $line[1] in
      change)
        _arguments -s -S \
          '-a[add unstaged edits in tracked files]' \
          '-q[skip editing commit message]' \
          '-m+[commit message]:message' \
          '-s[add Signed-off-by trailer]' \
          '1:branch:' && ret=0
        ;;
      gofmt)
        _arguments -s -S \
          '-l[list files needing reformatting]' && ret=0
        ;;
      mail)
        _arguments -s -S \
          '-r+[reviewers]:emails' \
          '-cc+[cc recipients]:emails' \
          '-autosubmit[set Auto-Submit+1 vote]' \
          '-diff[show diff against upstream]' \
          '-f[force despite staged changes]' \
          '-hashtag+[hashtags]:tags' \
          '-nokeycheck[disable public key check]' \
          '-topic+[topic]:topic' \
          '-trybot[set Commit-Queue+1 vote]' \
          '-wip[mark as work-in-progress]' \
          '1:revision:' && ret=0
        ;;
      pending)
        _arguments -s -S \
          '-c[only current branch]' \
          '-g[print Gerrit CL numbers]' \
          '-l[local information only]' \
          '-s[short output]' && ret=0
        ;;
      submit)
        _arguments -s -S \
          '-i[open editor to select commits]' \
          '*:revision:' && ret=0
        ;;
      sync-branch)
        _arguments -s -S \
          '-continue[continue after resolving conflicts]' \
          '-merge-back-to-parent[merge in reverse direction]' && ret=0
        ;;
    esac
    ;;
esac

return ret
