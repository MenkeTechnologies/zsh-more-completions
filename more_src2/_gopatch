#compdef gopatch
# Documentation: https://github.com/uber-go/gopatch
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-p,--patch}'=[patch file]:file:_files' \
  '(-d --diff)'{-d,--diff}'[write diff to stdout instead of modifying files]' \
  '--print-only[write changed code to stdout without modifying files]' \
  '--skip-import-processing[disable import formatting for non-patch changes]' \
  '--skip-generated[skip files marked as generated]' \
  '*:Go packages or files:_files -g "*.go"'
