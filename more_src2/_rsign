#compdef rsign rsign2
# Documentation: https://github.com/jedisct1/rsign2 (Rust Minisign — README + src/main.rs)
# Reference accessed: 2026-05-30
# rsign / rsign2 — Rust implementation of Minisign. Public/private key signing and verification.
# Pure Rust, minimal dependencies. Multi-stem: ships as both `rsign` and `rsign2` upstream.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'generate:create a new public/private key pair'
  'sign:sign a file with your secret key'
  'verify:verify a signed file against a public key'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'rsign subcommand' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments \
          '(-p)-p[public key path (default rsign.pub)]:file:_files' \
          '(-s)-s[secret key path (default ~/.rsign/rsign.key)]:file:_files' \
          '(-W --unencrypted)-W[do not require a password for the secret key]' \
          '(-W --unencrypted)--unencrypted[do not encrypt the secret key]' \
          '-f[force overwrite of existing keys]' \
          && ret=0
        ;;
      sign)
        _arguments \
          '(-s)-s[secret key path]:file:_files' \
          '(-x)-x[output signature file (default: <input>.minisig)]:file:_files' \
          '(-t)-t[trusted comment (signed)]:comment:' \
          '(-c)-c[untrusted comment]:comment:' \
          '(-W)-W[secret key has no password]' \
          '*:file to sign:_files' \
          && ret=0
        ;;
      verify)
        _arguments \
          '(-p -P)-p[public key file (default rsign.pub)]:file:_files' \
          '(-p -P)-P[public key string (alternative to -p)]:pubkey:' \
          '(-x)-x[signature file (default: <input>.minisig)]:file:_files' \
          '(-q)-q[quiet mode]' \
          '(-o)-o[output file content if verification succeeds]' \
          '*:file to verify:_files' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
