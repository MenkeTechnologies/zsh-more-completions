#compdef mythpreviewgen
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythpreviewgen/mythpreviewgen_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythpreviewgen: MythTV preview image generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '--chanid=[channel ID]:id:' \
  '--starttime=[start time]:time:' \
  '--seconds=[seconds into video for preview]:seconds:' \
  '--frame=[frames into video for preview]:n:' \
  '--size=[preview image size WxH]:size:' \
  '--infile=[input video file]:file:_files' \
  '--outfile=[output preview file]:file:_files' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
