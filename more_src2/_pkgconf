#compdef pkgconf
# Documentation: pkgconf --help
# Source: drop-in replacement for pkg-config (pkg-config-compatible CLI).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--about[print version and license]' \
    '--version[print supported pkg-config version]' \
    '--verbose[print additional information]' \
    '--atleast-pkgconfig-version=[check pkg-config compatibility]:version:' \
    '--errors-to-stdout[print errors on stdout]' \
    '--print-errors[ensure all errors are printed]' \
    '--short-errors[short error messages]' \
    '--silence-errors[silent about errors]' \
    '--list-all[list all known packages]' \
    '--list-package-names[list all known package names]' \
    '--simulate[simulate walking the dependency graph]' \
    '--no-cache[do not cache seen packages]' \
    '--log-file=[write audit log]:file:_files' \
    '--with-path=[add directory to search path]:path:_files -/' \
    '--define-prefix[override prefix variable]' \
    '--dont-define-prefix[never override prefix]' \
    '--prefix-variable=[name of package-prefix variable]:varname:' \
    '--relocate=[relocate path and exit]:path:_files -/' \
    '--dont-relocate-paths[disable path relocation]' \
    '--personality=[set personality triplet or file]:personality:' \
    '--dump-personality[dump selected personality]' \
    '--atleast-version=[require at-least version]:version:' \
    '--exact-version=[require exact version]:version:' \
    '--max-version=[require maximum version]:version:' \
    '--exists[check whether modules exist]' \
    '--uninstalled[check whether uninstalled module will be used]' \
    '--no-uninstalled[never use uninstalled modules]' \
    '--no-provides[ignore provides rules]' \
    '--maximum-traverse-depth=[max graph depth]:n:' \
    '(--shared)--static[aggressive graph (static linking)]' \
    '(--static)--shared[simplified graph (default)]' \
    '--pure[optimize static graph as normal]' \
    '--env-only[only entries in PKG_CONFIG_PATH]' \
    '--ignore-conflicts[ignore conflicts rules]' \
    '--validate[validate .pc files]' \
    '*--define-variable=[define variable name=value]:assignment:' \
    '--variable=[print variable value]:varname:' \
    '--cflags[print required CFLAGS]' \
    '--cflags-only-I[print include-dir CFLAGS]' \
    '--cflags-only-other[print non-include-dir CFLAGS]' \
    '--libs[print linker flags]' \
    '--libs-only-L[print -L linker flags]' \
    '--libs-only-l[print -l linker flags]' \
    '--libs-only-other[print other linker flags]' \
    '--print-requires[print required dependencies]' \
    '--print-requires-private[print static-link required dependencies]' \
    '--print-provides[print provided dependencies]' \
    '--print-variables[print all known variables]' \
    '--digraph[print dependency graph as graphviz dot]' \
    '--solution[print dependency graph solution]' \
    '--keep-system-cflags[keep system include cflags]' \
    '--keep-system-libs[keep system lib flags]' \
    '--path[show .pc filenames]' \
    '--modversion[print module version]' \
    '--internal-cflags[do not filter internal cflags]' \
    '--license[print module license]' \
    '--exists-cflags[add -DHAVE_FOO cflag fragments]' \
    '--msvc-syntax[output in MSVC syntax]' \
    '--fragment-filter=[filter output fragments]:types:' \
    '--env=[output as shell env vars]:prefix:' \
    '--fragment-tree[visualize fragments as tree]' \
    '*:library:' \
    && ret=0

return ret
