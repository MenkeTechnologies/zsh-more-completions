#compdef fixpix
# _fixpix — fix specified bad pixels in a FITS image (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from fixpix.c (single-letter getopt-style).

_fixpix() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-c[interpolate along columns]' \
        '-r[interpolate along rows]' \
        '-n[output new file]' \
        '-@+[file listing input filenames]:file:_files' \
        '1:FITS file:_files -g "*.(fits|fit|fts|imh)"' \
        '*:x y region:'
}

_fixpix "$@"
