#compdef nova-manage
# Documentation: https://docs.openstack.org/nova/latest/cli/nova-manage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nova-manage: DB / cell / placement / libvirt admin commands
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'db:database management'
  'api_db:API DB management'
  'cell_v2:Cells v2 configuration'
  'placement:placement service commands'
  'volume_attachment:volume attachment management'
  'libvirt:libvirt-specific operations'
  'image_property:instance image property management'
  'limits:quota and limits migration'
)
_arguments -C \
  "(- *)"{-h,--help}"[show help]" \
  "--version[show version]" \
  "--config-file=[config file]:file:_files" \
  "--config-dir=[config dir]:dir:_files -/" \
  "(--nodebug)"{-d,--debug}"[set log level to debug]" \
  "(-d --debug)--nodebug[do not set log level to debug]" \
  "--log-config-append=[log config file]:file:_files" \
  "--log-date-format=[log date format]:fmt:" \
  "--log-dir=[log directory]:dir:_files -/" \
  "--log-file=[log file]:file:_files" \
  "--syslog-log-facility=[syslog facility]:facility:" \
  "(--nouse-journal)--use-journal[log to systemd journal]" \
  "(--use-journal)--nouse-journal[do not log to systemd journal]" \
  "(--nouse-json)--use-json[log as JSON]" \
  "(--use-json)--nouse-json[do not log as JSON]" \
  "(--nouse-syslog)--use-syslog[log via syslog]" \
  "(--use-syslog)--nouse-syslog[do not log via syslog]" \
  "(--nowatch-log-file)--watch-log-file[watch log file]" \
  "(--watch-log-file)--nowatch-log-file[do not watch log file]" \
  "(--nopost-mortem)--post-mortem[drop into pdb on uncaught exception]" \
  "(--post-mortem)--nopost-mortem[do not drop into pdb on uncaught exception]" \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nova-manage command' commands && ret=0 ;;
esac
return ret
