#compdef nginx-prometheus-exporter
# Documentation: https://github.com/nginxinc/nginx-prometheus-exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'-help'[show help]' \
  '-nginx.scrape-uri=[URI for scraping NGINX metrics]:uri:' \
  '-nginx.retries=[number of retries for scraping]:count:' \
  '-nginx.retry-interval=[interval between retries]:duration:' \
  '-nginx.ssl-verify[verify SSL certificates]' \
  '-nginx.ssl-ca-cert=[path to CA certificate]:file:_files' \
  '-nginx.ssl-client-cert=[path to client certificate]:file:_files' \
  '-nginx.ssl-client-key=[path to client key]:file:_files' \
  '-nginx.timeout=[timeout for scraping]:duration:' \
  '-nginx.plus[use NGINX Plus API]' \
  '-web.listen-address=[address to listen on]:address:' \
  '-web.telemetry-path=[path for metrics]:path:' \
  '-web.secured-metrics[require authentication for metrics]' \
  '-prometheus.const-labels=[constant labels for metrics]:labels:' && ret=0

return ret
