#compdef git-cvsserver
# Documentation: https://git-scm.com/docs/git-cvsserver
# Source: git/git git-cvsserver.perl — CVS pserver emulation against a Git repository (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h -H)'{-h,-H}'[show usage]' \
    {-V,--version}'[print version and exit]' \
    '--base-path+[prepend to requested CVSROOT]:path:_files -/' \
    '--strict-paths[do not allow recursing into subdirectories]' \
    '--export-all[do not check gitcvs.enabled in config]' \
    '1::mode:(pserver server)' \
    '*:repository directory:_files -/' \
    && ret=0

return ret
