#compdef phive
# Documentation: https://github.com/phar-io/phive/blob/master/src/commands/help/help.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--no-progress[suppress progress output]' \
  '1: :->cmds' \
  '*:: :->rest' && ret=0

case $state in
  (cmds)
    local -a cmds=(
      help:'show help output and exit'
      version:'show release version and exit'
      list:'list known PHAR aliases'
      install:'install a phar distributed application or library'
      composer:'parse composer.json and suggest installation'
      purge:'delete unused PHARs'
      remove:'remove installed PHAR from project'
      reset:'reset symlinks to PHARs used in the project'
      selfupdate:'update PHIVE to the latest version'
      skel:'create a default configuration file'
      status:'list configured PHARs for the current directory'
      outdated:'list outdated PHARs'
      migrate:'run Phive migration'
      update:'update PHARs to newest applicable version'
      update-repository-list:'update the alias list'
    )
    _describe -t commands command cmds && ret=0
    ;;
  (rest)
    case $line[1] in
      install)
        _arguments \
          '--copy[copy phar instead of symlink]' \
          '--temporary[install temporarily]' \
          '--force-accept-unsigned[install unsigned phars]' \
          '--trust-gpg-keys=[trusted GPG key IDs]:keys:' \
          '--target=[target directory]:dir:_directories' \
          '*:phar:' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
