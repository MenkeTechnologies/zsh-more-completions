#compdef newuidmap
# Documentation: https://man7.org/linux/man-pages/man1/newuidmap.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '1:pid:_pids' \
  '*:uid mapping (innerUID outerUID count):' && ret=0

return ret
