#compdef pamlevels
# Documentation: man pamlevels (Netpbm)
# Source: adjust tonal levels of a PAM image with up to three linear segments per channel.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-from1+[start input level 1]:from1:' \
    '-to1+[start output level 1]:to1:' \
    '-from2+[input level 2]:from2:' \
    '-to2+[output level 2]:to2:' \
    '-from3+[input level 3 (optional)]:from3:' \
    '-to3+[output level 3 (optional)]:to3:' \
    '-linear[treat samples as linear, not gamma]' \
    '-fitbrightness[normalise overall brightness]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
