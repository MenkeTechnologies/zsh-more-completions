#compdef innoextract
# Documentation: https://manpages.debian.org/bookworm/innoextract/innoextract.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm innoextract(1) manpage OPTIONS.
# Removed from prior file: fabricated -V/--version (real is -v) and
# bogus man.archlinux.org search URL.

# innoextract: extract Inno Setup installers
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--license[show license info]' \
  '(-t --test)'{-t,--test}'[verify checksums, do not write]' \
  '(-e --extract)'{-e,--extract}'[extract files (default)]' \
  '(-l --list)'{-l,--list}'[only list files]' \
  '--list-sizes[list file sizes]' \
  '--list-checksums[list file checksums]' \
  '(-i --info)'{-i,--info}'[print installer info]' \
  '--list-languages[list languages supported]' \
  '--gog-game-id[determine GOG.com game ID]' \
  '--show-password[show password check info]' \
  '--check-password[abort if password incorrect]' \
  '(-V --data-version)'{-V,--data-version}'[only print data version]' \
  '--codepage=[encoding for ANSI strings]:codepage:' \
  '--collisions=[duplicate file handling]:action:(overwrite rename rename-all error)' \
  '--default-language=[default language for renaming]:lang:' \
  '--dump[dump contents without converting filenames]' \
  '(-L --lowercase)'{-L,--lowercase}'[lower-case extracted filenames]' \
  '(-T --timestamps)'{-T+,--timestamps=}'[timezone for file times]:tz:(local none)' \
  '(-d --output-dir)'{-d+,--output-dir=}'[extract into directory]:dir:_files -/' \
  '(-P --password)'{-P+,--password=}'[password for encrypted files]:password:' \
  '--password-file=[file to load password from]:file:_files' \
  '(-g --gog)'{-g,--gog}'[process additional GOG.com archives]' \
  '--no-gog-galaxy[do not re-assemble GOG Galaxy file parts]' \
  '(-n --no-extract-unknown)'{-n,--no-extract-unknown}'[skip unknown Inno Setup versions]' \
  '(-m --exclude-temp)'{-m,--exclude-temp}'[do not extract temporary files]' \
  '--language=[extract only files for language]:lang:' \
  '--language-only[only extract language-specific files]' \
  '(-I --include)'{-I+,--include=}'[extract only matching path]:expr:' \
  '(-q --quiet)'{-q,--quiet}'[less output]' \
  '(-s --silent)'{-s,--silent}'[only errors/warnings]' \
  '--no-warn-unused[suppress unused .bin file warnings]' \
  '(-c --color)'{-c,--color=-}'[color output]:enable:(yes no)' \
  '(-p --progress)'{-p,--progress=-}'[progress bar]:enable:(yes no)' \
  '*:installer file:_files -g "*.exe(-.)"' && ret=0
return ret
