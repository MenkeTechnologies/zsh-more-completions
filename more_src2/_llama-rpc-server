#compdef llama-rpc-server
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/tools/rpc/rpc-server.cpp
# Reference accessed: 2026-05-27
# Verified: upstream rpc_server_params_parse in tools/rpc/rpc-server.cpp (custom parser, not common_params)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-t --threads)'{-t+,--threads=}'[number of threads for the CPU device]:threads' \
  '(-d --device)'{-d+,--device=}'[comma-separated list of devices]:devices' \
  '(-H --host)'{-H+,--host=}'[host to bind to]:host' \
  '(-p --port)'{-p+,--port=}'[port to bind to]:port' \
  '(-c --cache)'{-c,--cache}'[enable local file cache]' && ret=0

return ret
