#compdef grdinterpolate
# Documentation: https://docs.generic-mapping-tools.org/latest/grdinterpolate.html
# Source: GenericMappingTools/gmt classic-mode grdinterpolate — interpolate 2-D grids or 3-D cubes onto new lattices / profiles / time series.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output 3-D cube or 2-D grid file]:file:_files' \
    '-D+[netCDF names/units metadata]:opts:_default' \
    '-E+[profile sampling spec]:opts:_default' \
    '-F+[interpolation method]:method:(l a c n)' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[time/spatial series at points]:opts:_default' \
    '-T+[evenly spaced levels/times]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-Z[read multiple 2-D grids as cube layers]' \
    '-:[swap first two columns]' \
    '-b+[binary I/O format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-n+[grid interpolation mode]:mode:_default' \
    '-q+[row selection]:opts:_default' \
    '-s+[NaN-record handling]:opts:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
