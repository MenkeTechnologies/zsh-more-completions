#compdef proxify
# Documentation: https://github.com/projectdiscovery/proxify
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for proxify - Swiss Army knife proxy tool for HTTP/HTTPS traffic capture

_arguments -s -S \
  '-ha[listening HTTP IP and port]:addr:' \
  '-http-addr[listening HTTP IP and port]:addr:' \
  '-sa[listening SOCKS IP and port]:addr:' \
  '-socks-addr[listening SOCKS IP and port]:addr:' \
  '-da[listening DNS IP and port]:addr:' \
  '-dns-addr[listening DNS IP and port]:addr:' \
  '-dm[domain to IP mapping]:mapping:' \
  '-dns-mapping[domain to IP mapping]:mapping:' \
  '-r[custom DNS resolvers]:resolver:' \
  '-resolver[custom DNS resolvers]:resolver:' \
  '-hp[upstream HTTP proxies]:proxy:' \
  '-http-proxy[upstream HTTP proxies]:proxy:' \
  '-sp[upstream SOCKS5 proxies]:proxy:' \
  '-socks5-proxy[upstream SOCKS5 proxies]:proxy:' \
  '-c[number of requests before switching upstream proxy]:n:' \
  '-sr[store raw request/response to output directory]' \
  '-store-response[store raw request/response to output directory]' \
  '-o[output file for proxify logs]:file:_files' \
  '-output[output file for proxify logs]:file:_files' \
  '-of[output format]:format:(jsonl yaml)' \
  '-output-format[output format]:format:(jsonl yaml)' \
  '-dump-req[dump only HTTP requests]' \
  '-dump-resp[dump only HTTP responses]' \
  '-oca[generate and save CA file]' \
  '-out-ca[generate and save CA file]' \
  '-req-fd[request filter DSL expression]:expr:' \
  '-request-dsl[request filter DSL expression]:expr:' \
  '-resp-fd[response filter DSL expression]:expr:' \
  '-response-dsl[response filter DSL expression]:expr:' \
  '-req-mrd[request match-replace DSL expression]:expr:' \
  '-request-match-replace-dsl[request match-replace DSL expression]:expr:' \
  '-resp-mrd[response match-replace DSL expression]:expr:' \
  '-response-match-replace-dsl[response match-replace DSL expression]:expr:' \
  '-config[proxify configuration file path]:file:_files' \
  '-ec[export module configuration file]:file:_files' \
  '-export-config[export module configuration file]:file:_files' \
  '-config-directory[override default config path]:dir:_files -/' \
  '-cert-cache-size[certificate cache size]:n:' \
  '-a[allowed IP/CIDR list]:cidr:' \
  '-allow[allowed IP/CIDR list]:cidr:' \
  '-d[denied IP/CIDR list]:cidr:' \
  '-deny[denied IP/CIDR list]:cidr:' \
  '-pt[passthrough domains]:domain:' \
  '-passthrough[passthrough domains]:domain:' \
  '-max-size[maximum export data size]:bytes:' \
  '-up[update proxify to latest version]' \
  '-update[update proxify to latest version]' \
  '-duc[disable automatic update check]' \
  '-disable-update-check[disable automatic update check]' \
  '-nc[disable color output]' \
  '-no-color[disable color output]' \
  '-version[show version]' \
  '-silent[silent mode]' \
  '-v[verbose output]' \
  '-verbose[verbose output]' \
  '-vv[very verbose output]' \
  '-very-verbose[very verbose output]' \
  '-h[show help]' \
  '-help[show help]'
