#compdef gnative2ascii
# Documentation: https://man.cx/native2ascii
# Reference accessed: 2026-05-16
# Verified: GNU Classpath implementation of Sun native2ascii(1).
# Removed from prior file: bogus man.archlinux.org search URL.

# gnative2ascii: GNU Classpath native-to-ASCII converter
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-version[show version]' \
  '-encoding[encoding name]:encoding:' \
  '-reverse[convert ASCII/Unicode back to native]' \
  '*-J[pass option to JVM]:option:' \
  '1:input file:_files' \
  '2:output file:_files' && ret=0
return ret
