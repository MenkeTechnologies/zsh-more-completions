#compdef milvus-server
# _milvus-server — Milvus open-source vector database server entrypoint (starts/stops per-role daemons: rootcoord, querycoord, datacoord, querynode, datanode, proxy, streamingnode, standalone, mixture)
# upstream: https://github.com/milvus-io/milvus
# Subcommands + flags from cmd/milvus/{run,stop,mck,help,util}.go on tip; distinct from the interactive _milvus completion which targets zilliztech/milvus_cli.

_milvus-server() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                'run:start a Milvus server (positional: server type)'
                'stop:stop a Milvus server'
                'mck:Milvus data consistency check (subcommands: run|cleanTrash)'
                'dry-run:no-op (placeholder)'
            )
            _describe -t commands 'milvus command' subs
            ;;
        args)
            local -a server_types=(rootcoord querycoord datacoord querynode datanode proxy streamingnode standalone mixture)
            case $line[1] in
                run)
                    _arguments \
                        '-alias=[server alias]:alias:' \
                        '-rootcoord[start the rootcoord server]' \
                        '-querycoord[start the querycoord server]' \
                        '-datacoord[start the datacoord server]' \
                        '-indexcoord[start the indexcoord server]' \
                        '-querynode[start the querynode server]' \
                        '-datanode[start the datanode server]' \
                        '-proxy[start the proxy server]' \
                        '-streamingnode[start the streamingnode server]' \
                        '1: :->run-type'
                    case $state in
                        run-type) _describe -t values 'server type' server_types ;;
                    esac
                    ;;
                stop)
                    _arguments \
                        '-alias=[server alias]:alias:' \
                        '1: :->stop-type'
                    case $state in
                        stop-type) _describe -t values 'server type' server_types ;;
                    esac
                    ;;
                mck)
                    _arguments \
                        '-etcdIp=[etcd endpoint]:endpoint:' \
                        '-etcdRootPath=[etcd root path]:path:' \
                        '-minioAddress=[minio endpoint]:endpoint:' \
                        '-minioUsername=[minio username]:user:' \
                        '-minioPassword=[minio password]:pwd:' \
                        '-minioUseSSL=[minio use SSL]:bool:(true false)' \
                        '-minioBucketName=[minio bucket]:bucket:' \
                        '1: :->mck-sub'
                    case $state in
                        mck-sub) _describe -t commands 'mck subcommand' '(run cleanTrash)' ;;
                    esac
                    ;;
            esac
            ;;
    esac
}

_milvus-server "$@"
