#compdef qlmanage
# Documentation: https://www.unix.com/man-page/osx/1/qlmanage/
# Source: Apple macOS — Quick Look server management + thumbnail/preview tester.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-r[reset Quick Look server + client generator cache]' \
    '(- *)-m[print Quick Look server info + detected generators]' \
    '(- *)-h[extensive help]' \
    '(-t -p)-t[show generated thumbnails for files]' \
    '(-t -p)-p[show generated previews for files]' \
    '-d[debug level (with -t or -p)]:level:' \
    '-x[no description (with -t or -p)]' \
    '-i[option available with -t]' \
    '-s[thumbnail size (with -t)]:size:' \
    '-f[scaling factor (with -t)]:factor:' \
    '-c[content type UTI (with -t or -p)]:uti:' \
    '-g[generator (with -c)]:generator:' \
    '*:file:_files' \
    && ret=0

return ret
