#compdef expo-cli
# _expo-cli — Expo SDK + dev tooling CLI alias (Expo, TypeScript); commander
# upstream: https://github.com/expo/expo

_expo-cli() {
    local -a sub=(
        'start:start dev server'
        'install:install matching package versions'
        'build:legacy classic build (deprecated)'
        'config:print resolved app.json'
        'doctor:diagnose project'
        'export:export production bundle'
        'login:login to expo'
        'logout:logout from expo'
        'register:register expo account'
        'whoami:show current user'
        'prebuild:generate native code'
        'run:android|ios native run helpers'
        'send:send link via email/SMS'
        'customize:customize web/metro/babel'
        'lint:run linter'
        'fetch:fetch credentials'
        'init:scaffold project'
        'eject:eject native code (deprecated, use prebuild)'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--non-interactive[non-interactive]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'expo subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '--web[start web]' \
                    '-w[start web]' \
                    '--ios[start ios]' \
                    '-i[start ios]' \
                    '--android[start android]' \
                    '-a[start android]' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--scheme=+[scheme]:str:' \
                    '--host=+[host type]:t:(localhost lan tunnel)' \
                    '--tunnel[use tunnel]' \
                    '--clear[clear cache]' \
                    '-c[clear cache]' \
                    '--max-workers=+[max workers]:n:' \
                    '--no-dev[no dev]' \
                    '--minify[minify]' \
                    '--https[https]' \
                    '--offline[offline]' \
                    '--reset-cache[reset cache]' \
                    '--dev-client[expo-dev-client]' \
                    '--go[use Expo Go]' \
                    '--lan[lan]' \
                    '--localhost[localhost]' ;;
                run) _arguments \
                    '1:platform:(android ios)' \
                    '--device=+[device]:str:' \
                    '-d+[device]:str:' \
                    '--variant=+[variant]:str:' \
                    '--scheme=+[scheme]:str:' \
                    '--port=+[port]:port:' \
                    '--no-build-cache[no build cache]' \
                    '--no-install[no install]' \
                    '--no-bundler[no bundler]' \
                    '--app-id=+[app id]:str:' \
                    '--binary=+[binary]:file:_files' \
                    '--archs=+[archs]:list:(armeabi-v7a arm64-v8a x86 x86_64 universal)' ;;
                install) _arguments \
                    '--check[check versions]' \
                    '--fix[fix versions]' \
                    '*:package:' ;;
                export) _arguments \
                    '--platform=+[platform]:p:(android ios web)' \
                    '-p+[platform]:p:(android ios web)' \
                    '--output-dir=+[output dir]:dir:_files -/' \
                    '--source-maps[source maps]' \
                    '-s[source maps]' \
                    '--clear[clear cache]' \
                    '-c[clear cache]' \
                    '--max-workers=+[max workers]:n:' \
                    '--dump-assetmap[dump asset map]' \
                    '--dump-sourcemap[dump source map]' \
                    '--bytecode[bundle as bytecode]' \
                    '--minify[minify]' \
                    '--no-minify[no minify]' \
                    '--dev[dev]' ;;
                prebuild) _arguments \
                    '--platform=+[platform]:p:(android ios all)' \
                    '-p+[platform]:p:(android ios all)' \
                    '--no-install[no install]' \
                    '--clean[clean]' \
                    '--skip-dependency-update=+[skip dependency update]:list:' \
                    '--template=+[template]:str:' ;;
                config) _arguments \
                    '--type=+[type]:t:(public prebuild introspect)' \
                    '--full[full]' \
                    '--json[json output]' ;;
                doctor) _arguments '*:arg:' ;;
                init) _arguments \
                    '1:name:' \
                    '--template=+[template]:str:' \
                    '-t+[template]:str:' \
                    '--no-install[no install]' \
                    '--yes[yes to all]' \
                    '-y[yes to all]' ;;
                customize) _arguments '*:arg:' ;;
                login|logout|register|whoami|fetch) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_expo-cli "$@"
