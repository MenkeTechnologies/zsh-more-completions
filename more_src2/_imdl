#compdef imdl
# Documentation: https://github.com/casey/intermodal
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.
# imdl - intermodal: a 40' shipping container for the Internet (BitTorrent CLI)

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[suppress normal output]' \
  '(-u --unstable)'{-u,--unstable}'[enable unstable features]' \
  '(-c --color)'{-c,--color=}'[colored output mode]:mode:(auto always never)' \
  '(-t --terminal)'{-t,--terminal}'[force terminal-style output]' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'torrent:BitTorrent operations'
      'completions:generate shell completion script'
    )
    _describe -t commands 'imdl command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      torrent)
        local -a sub=(
          'announce:announce a torrent to its trackers'
          'create:create a .torrent file'
          'dump:dump a torrent as YAML'
          'from-link:generate a torrent from a magnet link'
          'link:generate a magnet link'
          'piece-length:show recommended piece length'
          'show:display torrent information'
          'stats:print torrent statistics'
          'verify:verify torrent contents'
        )
        _describe -t torrent_sub 'torrent subcommand' sub && ret=0
        ;;
      completions)
        _arguments -s -S \
          '--shell=[target shell]:shell:(bash zsh fish powershell elvish)' \
          '--dir=[output directory]:dir:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
