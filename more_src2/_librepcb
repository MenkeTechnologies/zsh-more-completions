#compdef librepcb librepcb-cli
# Documentation: https://github.com/LibrePCB/LibrePCB
# Documentation: https://librepcb.org/docs/cli/
# Reference accessed: 2026-05-27
# Verified: upstream apps/librepcb-cli/commandlineinterface.cpp QCommandLineOption definitions
# and command map in LibrePCB master branch.

local curcontext="$curcontext" state line ret=1
local -a _lpcb_subcommands

_lpcb_subcommands=(
  'open-project:open a project to execute project-related tasks'
  'open-library:open a library to execute library-related tasks'
  'open-symbol:open a symbol to execute symbol-related tasks'
  'open-package:open a package to execute package-related tasks'
  'open-step:open a STEP model to execute STEP-related tasks'
)

case $service in
  librepcb-cli)
    _arguments -C \
      '(-h --help)'{-h,--help}'[print help message]' \
      '(-V --version)'{-V,--version}'[display version information]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '1: :->cmd' \
      '*:: :->args' && ret=0

    case $state in
      cmd)
        _describe -t commands 'librepcb-cli command' _lpcb_subcommands && ret=0
        ;;
      args)
        case $line[1] in
          open-project)
            _arguments \
              '--erc[run electrical rule check]' \
              '--drc[run design rule check]' \
              '--drc-settings=[override DRC settings file]:file:_files -g "*.lp"' \
              '*--run-job=[run a particular output job]:name:' \
              '--run-jobs[run all existing output jobs]' \
              '--jobs=[override output jobs with custom *.lp file]:file:_files -g "*.lp"' \
              '--outdir=[override output base directory]:path:_files -/' \
              '*--export-schematics=[export schematics to file]:file:_files' \
              '*--export-bom=[export generic BOM to file]:file:_files' \
              '*--export-board-bom=[export board-specific BOM to file]:file:_files' \
              '--bom-attributes=[additional BOM attributes (comma separated)]:attributes:' \
              '--export-pcb-fabrication-data[export Gerber/Excellon fabrication files]' \
              '--pcb-fabrication-settings=[override PCB fabrication settings file]:file:_files -g "*.lp"' \
              '*--export-pnp-top=[export top-side pick&place file]:file:_files' \
              '*--export-pnp-bottom=[export bottom-side pick&place file]:file:_files' \
              '*--export-netlist=[export netlist (D356) file]:file:_files' \
              '*--board=[name of board(s) to export]:name:' \
              '*--board-index=[specify board(s) by index]:index:' \
              '--remove-other-boards[remove boards not specified with --board]' \
              '*--variant=[name of assembly variant(s) to export]:name:' \
              '*--variant-index=[specify assembly variant(s) by index]:index:' \
              '--set-default-variant=[move assembly variant to top]:name:' \
              '--save[save project before closing]' \
              '--strict[fail if project files are not strictly canonical]' \
              '*:project:_files -g "*.lpp(|z)"' && ret=0
            ;;
          open-library)
            _arguments \
              '--all[perform action on all elements in the library]' \
              '--check[run library element check]' \
              '--minify-step[minify STEP models (requires --all)]' \
              '--save[save library and elements before closing]' \
              '--strict[fail if files are not strictly canonical]' \
              '*:library:_files -/' && ret=0
            ;;
          open-symbol)
            _arguments \
              '--check[run symbol check]' \
              '*--export=[export symbol to graphical file]:file:_files' \
              '*:symbol:_files -/' && ret=0
            ;;
          open-package)
            _arguments \
              '--check[run package check]' \
              '*--export=[export footprint(s) to graphical file]:file:_files' \
              '*:package:_files -/' && ret=0
            ;;
          open-step)
            _arguments \
              '--minify[minify the STEP model before validating it]' \
              '--tesselate[validate tesselation capability]' \
              '--save-to=[write modified STEP to output location]:file:_files -g "*.step"' \
              '*:file:_files -g "*.step"' && ret=0
            ;;
          *)
            _files && ret=0
            ;;
        esac
        ;;
    esac
    ;;
  librepcb|*)
    _arguments \
      '(-h --help)'{-h,--help}'[print help]' \
      '(-V --version)'{-V,--version}'[display version]' \
      '*:file:_files -g "*.(lpp|lppz|lplib)"' && ret=0
    ;;
esac

return ret
