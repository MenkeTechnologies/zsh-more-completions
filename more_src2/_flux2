#compdef flux flux2
# _flux2 — Fluxcd flux CLI (GitOps toolkit for K8s; subcommands: bootstrap/install/uninstall, create/get/delete/suspend/resume/reconcile per-kind (source git/oci/helm/chart, helmrelease, kustomization, alert, alertprovider, receiver, image-update-automation, image-policy, image-repository), check, completion, version, trace)
# upstream: https://github.com/fluxcd/flux2
# Subcommands from fluxcd/flux2 cmd/flux on tip.

_flux2() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--kubeconfig+[kubeconfig]:file:_files' \
        '--context+[kubecontext]:context:' \
        '-n+[namespace]:namespace:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'flux command' \
                '(bootstrap install uninstall check completion create delete diff events export get pull push reconcile resume stats suspend trace tree uninstall update version logs)'
            ;;
        args)
            _describe -t commands 'kind' '(source helmrelease kustomization image alert alertprovider receiver image-update-automation image-policy image-repository tenant secret)' ;;
    esac
}

_flux2 "$@"
