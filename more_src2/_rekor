#compdef rekor-server
# Documentation: https://github.com/sigstore/rekor
# Reference accessed: 2026-05-20
# Verified: upstream rekor/cmd/rekor-server source at the URL above.
# Reworked entirely: prior file mis-declared `#compdef rekor-cli`
# (already covered by sibling _rekor-cli) and used invented
# subcommands. rekor-server is a transparency-log server, not a CLI
# log client.

local -a _rekor_server_commands
_rekor_server_commands=(
  'serve:start the rekor transparency log HTTP server'
  'version:print version'
  'help:help about any command'
)

_arguments -C \
  '--config=[config file]:file:_files' \
  '--log_type=[logger type]:type:(dev prod)' \
  '--enable_pprof[enable pprof profiling on port 6060]' \
  '--port=[port to bind to]:port:' \
  '--rekor_server.hostname=[public hostname]:hostname:' \
  '--rekor_server.address=[bind address]:address:' \
  '--rekor_server.signer=[signer]:signer:(awskms azurekms gcpkms hashivault memory tink)' \
  '--rekor_server.signer-passwd=[signer password]:password:' \
  '--trillian_log_server.address=[Trillian server address]:address:' \
  '--trillian_log_server.port=[Trillian server port]:port:' \
  '--trillian_log_server.tlog_id=[Trillian tree ID]:id:' \
  '--trillian_log_server.tls[use TLS for Trillian connection]' \
  '--trillian_log_server.tls_ca_cert=[TLS CA certificate]:file:_files' \
  '--redis_server.address=[Redis address]:address:' \
  '--redis_server.port=[Redis port]:port:' \
  '--redis_server.password=[Redis password]:password:' \
  '--search_index.storage_provider=[search index storage]:provider:(redis mysql)' \
  '--attestation_storage_bucket=[attestation storage URL]:url:' \
  '--max_attestation_size=[max attestation size in bytes]:bytes:' \
  '--max_request_body_size=[max HTTP request body size]:bytes:' \
  '--publish_frequency=[checkpoint publishing interval minutes]:minutes:' \
  '--rekor_server.publish_events_protobuf[enable Protobuf event publishing]' \
  '--rekor_server.publish_events_json[enable CloudEvents JSON publishing]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*::arg:->args'

case "$state" in
  cmds)
    _describe -t commands 'rekor-server commands' _rekor_server_commands
    ;;
esac
