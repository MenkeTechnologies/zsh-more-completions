#compdef nimsuggest
# _nimsuggest — Nim Language nimsuggest CLI Nim language server tool for IDE editor integration providing suggestions go-to-definition documentation hints type info refactor rename around the Nim Lean compiler with stdin epc nimble project-aware mode for VSCode emacs vim helix editor LSP backend (Nim team, Nim); custom argparse
# upstream: https://nim-lang.org/

_nimsuggest() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--debug[debug]' \
        '--silent[silent]' \
        '--quiet[quiet]' \
        '--maxResults=+[N]:n:' \
        '--maxLoopIterationsVM=+[N]:n:' \
        '--cppCompileToNamespace=+[name]:str:' \
        '--colors=+[s]:s:(on off)' \
        '--unitsep=+[s]:s:(on off)' \
        '--listFullPaths=+[s]:s:(on off)' \
        '--processNote=+[note]:str:' \
        '--processFatalError=+[s]:s:(on off)' \
        '--define=+[symbol]:str:' \
        '-d+[symbol]:str:' \
        '--undef=+[symbol]:str:' \
        '-u+[symbol]:str:' \
        '--out=+[file]:file:_files -g "*.nim"' \
        '-o+[file]:file:_files -g "*.nim"' \
        '--outDir=+[dir]:dir:_files -/' \
        '--stdout=+[s]:s:(on off)' \
        '--path=+[dir]:dir:_files -/' \
        '-p+[dir]:dir:_files -/' \
        '--nimcache=+[dir]:dir:_files -/' \
        '--backend=+[b]:b:(c cpp objc js)' \
        '-b+[backend]:b:(c cpp objc js)' \
        '--cmd=+[cmd]:c:(suggestions con def def2 outline use known mod chk highlight inlayHints chkFile recompile typeDef refs project type expand declaration testPragma)' \
        '--engine[engine mode]' \
        '--epc[EPC mode]' \
        '--stdin[stdin mode]' \
        '--socket[socket mode]' \
        '--address=+[host]:_hosts' \
        '--port=+[port]:n:' \
        '*:nim source:_files -g "*.nim *.nims"'
}

_nimsuggest "$@"
