#compdef footclient foot-client
# Documentation: https://codeberg.org/dnkl/foot
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-t --term)'{-t,--term=}'[terminal type]:TERM:' \
  '(-T --title)'{-T,--title=}'[window title]:title:' \
  '(-a --app-id)'{-a,--app-id=}'[Wayland app-id]:app id:' \
  '(-w --window-size-pixels)'{-w,--window-size-pixels=}'[initial window size in pixels]:WxH:' \
  '(-W --window-size-chars)'{-W,--window-size-chars=}'[initial window size in chars]:WxH:' \
  '(-m --maximized)'{-m,--maximized}'[start maximized]' \
  '(-F --fullscreen)'{-F,--fullscreen}'[start fullscreen]' \
  '(-L --login-shell)'{-L,--login-shell}'[start as login shell]' \
  '(-D --working-directory)'{-D,--working-directory=}'[initial working directory]:directory:_files -/' \
  '(-s --server-socket)'{-s,--server-socket=}'[server socket path]:socket:_files' \
  '(-H --hold)'{-H,--hold}'[keep terminal open after exit]' \
  '(-N --no-wait)'{-N,--no-wait}'[detach client from running terminal]' \
  '(-o --override)'{-o,--override=}'[override config option]:[section.]key=value:' \
  '(-E --client-environment)'{-E,--client-environment}'[use client environment instead of server'\''s]' \
  '(-d --log-level)'{-d,--log-level=}'[log level]:level:(info warning error none)' \
  '(-l --log-colorize)'{-l,--log-colorize=}'[colorize log]:when:(never always auto)' \
  '-e[ignored (xterm compat)]' \
  '*::command:_command_names -e' && ret=0

return ret
