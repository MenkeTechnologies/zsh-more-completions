#compdef otelcontribcol
# _otelcontribcol — OpenTelemetry Collector Contrib (OpenTelemetry, Go); spf13/cobra wraps collector lifecycle
# upstream: https://github.com/open-telemetry/opentelemetry-collector-contrib

_otelcontribcol() {
    local -a sub=(
        'components:print components'
        'validate:validate config'
        'version:show version'
        'help:show help'
        'featuregate:list feature gates'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config=+[config file or yaml URI]:str:' \
        '--set=+[set property]:str:' \
        '--feature-gates=+[feature gates]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'otelcontribcol subcommand' sub ;;
        args)
            case $words[1] in
                validate) _arguments \
                    '--config=+[config file]:file:_files -g "*.yaml *.yml"' ;;
                featuregate) _arguments \
                    '1:cmd:(list)' \
                    '*:arg:' ;;
            esac
            ;;
    esac
}

_otelcontribcol "$@"
