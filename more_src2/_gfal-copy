#compdef gfal-copy
# Documentation: https://manpages.ubuntu.com/manpages/noble/man1/gfal-copy.1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gfal-copy: copy files via Grid File Access Library (gfal2-util).
local ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*'{-v,--verbose}'[verbose (repeatable up to 3)]' \
  '*'{-D+,--definition=}'[gfal2 property CONFIG_GROUP:KEY=VALUE]:def:' \
  '(-t --timeout)'{-t+,--timeout=}'[global timeout (s)]:sec:' \
  '(-E --cert)'{-E+,--cert=}'[user certificate]:file:_files' \
  '--key=[user private key]:file:_files' \
  '-4[force IPv4 (GridFTP)]' \
  '-6[force IPv6 (GridFTP)]' \
  '(-C --client-info)'{-C+,--client-info=}'[custom client info]:info:' \
  '--log-file=[gfal2 log file]:file:_files' \
  '(-f --force)'{-f,--force}'[delete and retry on overwrite failure]' \
  '(-p --parent)'{-p,--parent}'[create parent directories]' \
  '(-n --nbstreams)'{-n+,--nbstreams=}'[max parallel streams]:n:' \
  '--tcp-buffersize=[TCP buffer size]:bytes:' \
  '(-s --src-spacetoken)'{-s+,--src-spacetoken=}'[source space token]:token:' \
  '(-S --dst-spacetoken)'{-S+,--dst-spacetoken=}'[destination space token]:token:' \
  '(-T --transfer-timeout)'{-T+,--transfer-timeout=}'[transfer timeout (s)]:sec:' \
  '(-K --checksum)'{-K+,--checksum=}'[checksum spec ALGO[:VALUE]]:checksum:' \
  '--checksum-mode=[checksum mode]:mode:(none source target both)' \
  '--from-file=[source list file]:file:_files' \
  '--copy-mode=[copy mode]:mode:(streamed push pull)' \
  '--just-copy[skip checksum/staging]' \
  '--no-delegation[disable proxy delegation]' \
  '--evict[evict source after copy]' \
  '--scitag=[scitag value]:tag:' \
  '(-r --recursive)'{-r,--recursive}'[recursive copy]' \
  '--abort-on-failure[abort on first failure]' \
  '--dry-run[show what would happen]' \
  '*:src dst:_files' && ret=0
return ret
