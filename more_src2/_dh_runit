#compdef dh_runit
# _dh_runit — debhelper for runit service install (Debian/dh-runit)
# upstream: https://salsa.debian.org/debian/dh-runit
# Flags from dh_runit script (debhelper standard options).

_dh_runit() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '--no-act[dry-run]' \
        '*-p+[act on package]:package:' \
        '*-N+[skip package]:package:' \
        '-O+[option passed to the helper]:opt:' \
        '*:service script:_files'
}

_dh_runit "$@"
