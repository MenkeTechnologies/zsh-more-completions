(( $+functions[_lore_commands] )) ||
_lore_commands() {
    local commands; commands=(
'init:Initialize Lore with guided setup' \
'status:Show Lore status, database stats, and recent sessions' \
'current:Show the active session for the current directory' \
'context:Show recent sessions for quick orientation' \
'sessions:List and filter imported sessions' \
'show:Show session details or sessions linked to a commit' \
'link:Link sessions to git commits' \
'unlink:Remove session-to-commit links' \
'annotate:Add a bookmark or note to the current session' \
'tag:Add or remove tags from a session' \
'summarize:Add or view a session summary' \
'delete:Permanently delete a session and its data' \
'blame:Show which AI session led to a specific line of code' \
'export:Export a session in various formats' \
'search:Search session content using full-text search' \
'config:View and manage configuration settings' \
'import:Import sessions from AI coding tools' \
'insights:Show AI development insights and analytics' \
'hooks:Manage git hooks for automatic session linking' \
'daemon:Manage the background daemon for automatic session capture' \
'db:Manage the database (vacuum, prune, stats)' \
'login:Authenticate with the Lore cloud service' \
'logout:Log out from the Lore cloud service' \
'cloud:Sync sessions with Lore cloud' \
'doctor:Diagnose Lore installation and configuration issues' \
'mcp:Run the MCP server for AI tool integration' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'lore commands' commands "$@"
}
