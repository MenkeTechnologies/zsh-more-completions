#compdef news2mail
# Documentation: man news2mail(8)
# Source: InterNetNews/inn backends/news2mail.in — gateway news to mail via sm + sendmail (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

# news2mail is invoked as a channel backend; it reads @token@ list lines from stdin.
# No command-line options are accepted.
_arguments -s \
    && ret=0

return ret
