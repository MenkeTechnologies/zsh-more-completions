#compdef eclair eclair-node eclair-cli
# _eclair — ACINQ eclair-node CLI for the Scala Lightning Network implementation managing channels payments routes htlcs onchain wallet peers gossip relay fees liquidity ads policy updates (acinq team, Scala); custom argparse
# upstream: https://github.com/ACINQ/eclair

_eclair() {
    local -a sub=(
        'getinfo:show node info'
        'connect:connect to peer'
        'disconnect:disconnect peer'
        'peers:list peers'
        'open:open channel'
        'close:close channel'
        'forceclose:force-close channel'
        'channels:list channels'
        'channel:show channel'
        'createinvoice:create payment invoice'
        'parseinvoice:parse invoice'
        'payinvoice:pay invoice'
        'sendtoroute:send to specific route'
        'findroute:find route to node'
        'getreceivedinfo:show received info'
        'getsentinfo:show sent info'
        'allnodes:list known nodes'
        'allchannels:list known channels'
        'getbalance:show wallet balance'
        'onchainbalance:show onchain balance'
        'getnewaddress:generate new address'
        'send:send onchain payment'
        'sendtoonion:send to onion'
        'closedchannels:list closed channels'
        'cpfpbumpfees:CPFP bump fees'
        'rbf:RBF replace'
        'audit:show audit log'
        'forceClose:alias for forceclose'
        'updaterelayfee:update relay fee'
        'usablebalances:show usable balances'
        'channelstats:channel statistics'
        'networkstats:network statistics'
        'fees:show fee estimates'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.conf eclair.conf"' \
        '--config=+[config file]:file:_files -g "*.conf eclair.conf"' \
        '-a+[api host:port]:str:' \
        '--api=+[api host:port]:str:' \
        '-p+[api password]:str:' \
        '--password=+[api password]:str:' \
        '-d+[data dir]:dir:_files -/' \
        '--datadir=+[data dir]:dir:_files -/' \
        '-o+[output format]:f:(json text)' \
        '--output=+[output format]:f:(json text)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'eclair subcommand' sub ;;
        args)
            case $words[1] in
                open) _arguments \
                    '--nodeId=+[node id]:str:' \
                    '--fundingSatoshis=+[sat]:n:' \
                    '--pushMsat=+[msat]:n:' \
                    '--fundingFeerateSatByte=+[sat/B]:n:' \
                    '--channelType=+[t]:t:(STANDARD STATIC_REMOTEKEY ANCHOR ANCHOR_OUTPUTS_ZERO_FEE_HTLC_TX SIMPLE_TAPROOT)' \
                    '--announceChannel=+[b]:b:(true false)' ;;
                close|forceclose) _arguments \
                    '--channelId=+[hex]:str:' \
                    '--scriptPubKey=+[hex]:str:' \
                    '--feerateSatByte=+[sat/B]:n:' ;;
                createinvoice) _arguments \
                    '--description=+[text]:str:' \
                    '--amountMsat=+[msat]:n:' \
                    '--expireIn=+[seconds]:n:' \
                    '--fallbackAddress=+[addr]:str:' ;;
            esac
            ;;
    esac
}

_eclair "$@"
