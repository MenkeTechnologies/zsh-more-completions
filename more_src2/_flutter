#compdef flutter
# Documentation: https://docs.flutter.dev/reference/flutter-cli
# Reference accessed: 2026-05-30
# flutter — Google's cross-platform UI toolkit CLI. 25+ subcommands, full
# build-target dispatch (apk/appbundle/ios/ipa/web/macos/linux/windows), pub
# sub-dispatch, live device discovery via `flutter devices --machine`.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'analyze:analyze Dart source code'
  'assemble:assemble + build Flutter resources'
  'attach:attach to a running application'
  'bash-completion:emit shell-completion setup'
  'build:build a target-specific bundle (apk/appbundle/ios/ipa/web/macos/linux/windows)'
  'channel:list or switch Flutter release channels'
  'clean:delete build/ and .dart_tool/ directories'
  'config:configure persistent Flutter settings'
  'create:create a new project'
  'custom-devices:add, delete, list, reset custom devices'
  'daemon:run in long-running daemon mode (IDE protocol)'
  'debug-adapter:run a DAP-protocol debug adapter'
  'devices:list connected devices'
  'doctor:show installed-tooling diagnostics'
  'downgrade:downgrade to previously-active version'
  'drive:run Flutter Driver tests'
  'emulators:list, launch, create emulators'
  'gen-l10n:generate localizations'
  'generate:generate sources (build_runner alias)'
  'ide-config:configure IDE integration files'
  'install:install app on a device'
  'logs:stream log output of running apps'
  'packages:deprecated — use `flutter pub`'
  'precache:populate the Flutter tool cache'
  'pub:dart pub passthrough — package management'
  'run:run a Flutter app'
  'screenshot:capture screenshot from connected device'
  'symbolize:symbolize a stack trace'
  'test:run tests in the package'
  'upgrade:upgrade Flutter to latest in current channel'
)

# Shared global flags.
local -a _global
_global=(
  '(-v --verbose)'{-v,--verbose}'[verbose logging]'
  '--version[print Flutter SDK version]'
  '(-h --help)'{-h,--help}'[show help]'
  '(-d --device-id)'{-d,--device-id=}'[target device]:device:_flutter_devices'
  '--suppress-analytics[suppress analytics reporting for this run]'
  '--disable-analytics[disable analytics collection]'
  '--enable-analytics[enable analytics collection]'
  '--machine[machine-readable JSON output]'
  '(--color --no-color)--color[enable colored output]'
  '(--color --no-color)--no-color[disable colored output]'
  '--packages=[path to .packages or pubspec.lock]:file:_files'
  '--device-timeout=[device connection timeout (s)]:seconds:'
  '(--version-check --no-version-check)--version-check[check for updates (default)]'
  '(--version-check --no-version-check)--no-version-check[skip update check]'
)

# Helper: live-discover connected devices via `flutter devices --machine`.
_flutter_devices() {
  local -a ids
  ids=( ${(f)"$(flutter devices --machine 2>/dev/null | grep -oE '"id":"[^"]+"' | sed -E 's/^"id":"|"$//g')"} )
  _describe -t devices 'flutter device' ids
}

# Build sub-targets.
local -a _build_targets
_build_targets=(
  'apk:Android APK'
  'appbundle:Android App Bundle (AAB)'
  'aar:Android AAR archive'
  'ios:iOS app bundle'
  'ios-framework:iOS framework'
  'ipa:iOS archive (signed/unsigned)'
  'macos:macOS app bundle'
  'macos-framework:macOS framework'
  'linux:Linux desktop app'
  'windows:Windows desktop app'
  'web:web/PWA app'
  'bundle:generic asset bundle'
)

# Build shared flags.
local -a _build_common
_build_common=(
  '(--release --debug --profile)--release[optimized release build]'
  '(--release --debug --profile)--debug[debug build]'
  '(--release --debug --profile)--profile[profile-mode build]'
  '(-t --target)'{-t,--target=}'[entry-point Dart file]:file:_files -g "*.dart"'
  '--target-platform=[Android architecture]:plat:(android-arm android-arm64 android-x64)'
  '--build-name=[version name (e.g. 1.0.0)]:version:'
  '--build-number=[build version number]:N:'
  '--analyze-size[generate app-size analysis]'
  '--tree-shake-icons[remove unused Material icons]'
  '*--dart-define=[Dart compile-time variable name=value]:define:'
  '*--dart-define-from-file=[Dart defines from JSON file]:file:_files -g "*.json"'
  '--obfuscate[obfuscate Dart symbols]'
  '--split-debug-info=[directory for split debug-info symbols]:dir:_files -/'
  '--source-maps[generate source maps (web)]'
  '--no-pub[do not auto-run pub get]'
  '--web-renderer=[web renderer]:r:(auto html canvaskit skwasm)'
  '--csp[Content Security Policy mode (web)]'
  '--flavor=[Android/iOS flavor name]:flavor:'
)

# pub sub-dispatch.
local -a _pub_subs
_pub_subs=(
  'get:download project dependencies'
  'add:add a dependency to pubspec.yaml'
  'remove:remove a dependency from pubspec.yaml'
  'upgrade:upgrade dependencies to latest matching constraints'
  'downgrade:downgrade dependencies to lowest allowed'
  'outdated:show outdated dependencies'
  'deps:print dependency graph'
  'cache:manage the pub system cache'
  'publish:publish package to pub.dev'
  'run:run an executable from a dependency'
  'global:manage globally-activated packages'
  'token:manage pub.dev auth tokens'
  'login:authenticate with pub.dev'
  'logout:clear pub.dev credentials'
  'pub:nested passthrough to dart pub'
)

# custom-devices sub-dispatch.
local -a _customdev_subs
_customdev_subs=(
  'list:list configured custom devices'
  'add:add a new custom device'
  'delete:remove a custom device'
  'reset:reset config file to defaults'
)

_arguments -C \
  $_global \
  '1: :->subcmd' \
  '*:: :->args' && ret=0

case $state in
  subcmd)
    _describe -t commands 'flutter subcommand' _subcmds && ret=0
    ;;
  args)
    curcontext="${curcontext%:*:*}:flutter-$line[1]:"
    case $line[1] in
      build)
        _arguments -C $_global '1: :->t' '*:: :->bargs' && ret=0
        case $state in
          t) _describe -t targets 'build target' _build_targets && ret=0 ;;
          bargs) _arguments -s -S $_global $_build_common '*:dart file:_files -g "*.dart"' && ret=0 ;;
        esac
        ;;
      run)
        _arguments -s -S \
          $_global \
          '(--release --debug --profile)--release[release-mode run]' \
          '(--release --debug --profile)--debug[debug-mode run]' \
          '(--release --debug --profile)--profile[profile-mode run]' \
          '(-t --target)'{-t,--target=}'[entry-point Dart file]:file:_files -g "*.dart"' \
          '--flavor=[flavor]:flavor:' \
          '*--dart-define=[Dart compile-time name=value]:define:' \
          '*--dart-define-from-file=[Dart defines JSON]:file:_files -g "*.json"' \
          '--hot[enable hot reload (default)]' \
          '--no-hot[disable hot reload]' \
          '--enable-software-rendering[force software rendering]' \
          '--trace-skia[trace Skia engine]' \
          '--start-paused[pause Dart VM at startup]' \
          '--use-application-binary=[pre-built APK/AAB to install]:file:_files' \
          '--web-port=[web server port]:port:' \
          '--web-hostname=[web server hostname]:host:_hosts' \
          '*:dart file:_files -g "*.dart"' \
          && ret=0
        ;;
      test)
        _arguments -s -S \
          $_global \
          '--coverage[generate lcov.info coverage report]' \
          '--coverage-path=[explicit coverage file path]:file:_files' \
          '*--name=[run only tests matching name regex]:pattern:' \
          '*--plain-name=[run only tests whose name contains substring]:substring:' \
          '*--tags=[run only tests with tag]:tag:' \
          '*--exclude-tags=[exclude tests with tag]:tag:' \
          '--update-goldens[update golden files]' \
          '--reporter=[output reporter]:fmt:(compact expanded json silent github)' \
          '--concurrency=[concurrent test isolates]:N:' \
          '--start-paused[pause at startup]' \
          '*:test target:_files -g "*.dart"' \
          && ret=0
        ;;
      create)
        _arguments -s -S \
          $_global \
          '--org=[Reverse-DNS organization id (e.g. com.example)]:org:' \
          '(-t --template)'{-t,--template=}'[project type]:tmpl:(app module package plugin plugin_ffi)' \
          '--project-name=[explicit package name]:name:' \
          '--description=[pubspec.yaml description]:desc:' \
          '--ios-language=[iOS host language]:lang:(objc swift)' \
          '--android-language=[Android host language]:lang:(java kotlin)' \
          '*--platforms=[platforms to enable]:plat:(android ios linux macos web windows)' \
          '--overwrite[overwrite existing files]' \
          '--sample=[example fragment id]:id:' \
          '--empty[create empty app (no counter sample)]' \
          '1:project directory:_files -/' \
          && ret=0
        ;;
      pub)
        _arguments -C $_global '1: :->p' '*:: :->pargs' && ret=0
        case $state in
          p) _describe -t commands 'pub subcommand' _pub_subs && ret=0 ;;
          pargs)
            case $line[1] in
              get|upgrade|downgrade|outdated|publish|token|login|logout)
                _arguments $_global && ret=0 ;;
              add)
                _arguments $_global '--dev[add as dev dependency]' '*:package[:version]:' && ret=0 ;;
              remove)
                _arguments $_global '*:package:' && ret=0 ;;
              run)
                _arguments $_global '1:executable:' '*::script args:_files' && ret=0 ;;
              global)
                _arguments $_global '1:action:(activate deactivate list run)' '*::package:' && ret=0 ;;
              cache)
                _arguments $_global '1:action:(add clean repair preload list)' && ret=0 ;;
              deps)
                _arguments $_global '--style=[graph style]:s:(compact tree list)' && ret=0 ;;
              *) _arguments $_global '*:argument:' && ret=0 ;;
            esac
            ;;
        esac
        ;;
      custom-devices)
        _arguments -C $_global '1: :->c' '*:: :->cargs' && ret=0
        case $state in
          c) _describe -t commands 'custom-devices subcommand' _customdev_subs && ret=0 ;;
          cargs)
            case $line[1] in
              add) _arguments $_global '--json=[device config JSON]:file:_files' '--check[validate fields]' && ret=0 ;;
              delete) _arguments $_global '1:device-id:' && ret=0 ;;
              *) _arguments $_global && ret=0 ;;
            esac
            ;;
        esac
        ;;
      emulators)
        _arguments -s -S \
          $_global \
          '--launch=[launch an emulator by id]:emulator:' \
          '--cold[cold-boot the emulator]' \
          '--create[create a new Android emulator]' \
          '--name=[name for new emulator]:name:' \
          && ret=0
        ;;
      devices)
        _arguments -s -S $_global '--timeout=[device discovery timeout]:seconds:' && ret=0
        ;;
      doctor)
        _arguments -s -S \
          $_global \
          '--android-licenses[review + accept Android SDK licenses]' \
          '--check-for-remote-artifacts=[remote artifacts to check]:engine-rev:' \
          && ret=0
        ;;
      channel)
        _arguments -s -S \
          $_global \
          '1:channel:(stable beta dev master main)' \
          && ret=0
        ;;
      analyze)
        _arguments -s -S \
          $_global \
          '--write=[write analysis output to file]:file:_files' \
          '--congratulate[show success message]' \
          '--no-congratulate[suppress success message]' \
          '--preamble[skip Dart language preamble]' \
          '--no-preamble[show Dart language preamble]' \
          '*:dart file or directory:_files -g "*.dart"' \
          && ret=0
        ;;
      logs)
        _arguments -s -S $_global '--clear[clear log buffer before showing]' && ret=0
        ;;
      install)
        _arguments -s -S \
          $_global \
          '--use-application-binary=[pre-built binary to install]:file:_files' \
          && ret=0
        ;;
      attach)
        _arguments -s -S \
          $_global \
          '--debug-port=[Dart VM debug port]:port:' \
          '--debug-url=[Dart VM observatory URL]:url:' \
          '--isolate-filter=[filter isolates by name]:filter:' \
          && ret=0
        ;;
      screenshot)
        _arguments -s -S \
          $_global \
          '(-o --out)'{-o,--out=}'[output file]:file:_files' \
          '--type=[screenshot type]:t:(device rasterizer skia)' \
          '--vm-service-url=[Dart VM service URL]:url:' \
          && ret=0
        ;;
      symbolize)
        _arguments -s -S \
          $_global \
          '(-i --input)'{-i,--input=}'[input stack-trace file]:file:_files' \
          '(-o --output)'{-o,--output=}'[output file]:file:_files' \
          '(-d --debug-info)'{-d,--debug-info=}'[symbols file]:file:_files' \
          && ret=0
        ;;
      gen-l10n)
        _arguments -s -S \
          $_global \
          '--arb-dir=[ARB directory]:dir:_files -/' \
          '--template-arb-file=[template ARB file]:file:_files' \
          '--output-localization-file=[output localization file]:file:_files' \
          '--output-class=[generated Dart class name]:name:' \
          '--header-file=[header to prepend]:file:_files' \
          '--use-deferred-loading[defer-load translations (web)]' \
          && ret=0
        ;;
      precache)
        _arguments -s -S \
          $_global \
          '--all-platforms[populate cache for all platforms]' \
          '--android[Android artifacts]' \
          '--ios[iOS artifacts]' \
          '--web[web artifacts]' \
          '--linux[Linux artifacts]' \
          '--windows[Windows artifacts]' \
          '--macos[macOS artifacts]' \
          '--fuchsia[Fuchsia artifacts]' \
          '--force[force re-download]' \
          '--universal[universal artifacts]' \
          && ret=0
        ;;
      upgrade|downgrade)
        _arguments -s -S \
          $_global \
          '(-f --force)'{-f,--force}'[force upgrade even with dirty tree]' \
          '--continue[resume previously-interrupted upgrade]' \
          && ret=0
        ;;
      config)
        _arguments -s -S \
          $_global \
          '--build-dir=[default build output directory]:dir:_files -/' \
          '--no-analytics[disable analytics]' \
          '--analytics[enable analytics]' \
          '--enable-web[enable web support]' \
          '--no-enable-web[disable web support]' \
          '--enable-android[enable Android support]' \
          '--enable-ios[enable iOS support]' \
          '--enable-linux-desktop[enable Linux desktop]' \
          '--enable-macos-desktop[enable macOS desktop]' \
          '--enable-windows-desktop[enable Windows desktop]' \
          '--clear-features[clear all feature overrides]' \
          '--android-sdk=[path to Android SDK]:dir:_files -/' \
          '--android-studio-dir=[path to Android Studio]:dir:_files -/' \
          '--jdk-dir=[path to JDK]:dir:_files -/' \
          && ret=0
        ;;
      bash-completion|daemon|debug-adapter|generate|ide-config|clean|packages)
        _arguments -s -S $_global && ret=0
        ;;
      *)
        _arguments -s -S $_global '*:argument:' && ret=0
        ;;
    esac
    ;;
esac

return ret
