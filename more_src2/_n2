#
#  CLI library taxonomy update: 11th Rust CLI library — Jan Verbeek's
#  **lexopt** (blyxxyz/lexopt).  Rust ecosystem now has 11 documented
#  CLI libraries — TAKING THE SOLO LEAD as the MOST-DOCUMENTED CLI
#  LANGUAGE in the cross-language taxonomy ahead of Go (10) and
#  TypeScript-Node (10).  🎉 Rust BREAKS THE THREE-WAY TIE.
#
#  lexopt (blyxxyz/lexopt) is Jan Verbeek's MINIMAL iterator-based
#  Rust arg parser — designed for the BurntSushi (Andrew Gallant)
#  philosophy of TINY ZERO-DEPENDENCY caller-driven parsing.  Used
#  by nushell (THE Rust-written shell, IN CORPUS via _nushell — 33k
#  stars), RustPython (Python interpreter in Rust, 20k stars), the
#  OFFICIAL rust-lang/regex crate's regex-cli, BurntSushi/jiff
#  (Andrew Gallant's date/time library), winnow-rs/winnow (Rust
#  parser combinators), pomsky-lang/pomsky (1355 stars regex
#  language), rhysd/Shiba (799 stars Markdown browser), swyh-rs
#  (570 stars Stream What You Hear), n2 (459 stars Ninja-compatible
#  build system by Evan Martin), Pomsky regex compiler, rust-cli/
#  anstyle examples, radicle-tui (Radicle CRDT git layer), wado-cli
#  (Wado language), and many Rust internal tools that prefer
#  caller-driven iterator-style parsing over derive-based
#  alternatives.
#
#  lexopt API:
#    use lexopt::prelude::*;
#
#    let mut parser = lexopt::Parser::from_env();
#    let mut verbose = false;
#    let mut output: Option<String> = None;
#    let mut positionals: Vec<String> = vec![];
#
#    while let Some(arg) = parser.next()? {
#      match arg {
#        Short('h') | Long("help") => {
#          println!("Usage: mytool [options] files...");
#          std::process::exit(0);
#        }
#        Short('v') | Long("verbose") => {
#          verbose = true;
#        }
#        Short('o') | Long("output") => {
#          output = Some(parser.value()?.string()?);
#        }
#        Long("count") => {
#          let count: u32 = parser.value()?.parse()?;
#          // ...
#        }
#        Value(arg) => {
#          positionals.push(arg.string()?);
#        }
#        _ => return Err(arg.unexpected().into()),
#      }
#    }
#
#  lexopt distinctive features:
#    - MINIMAL ITERATOR-BASED — `lexopt::Parser` is a pull parser
#      yielding `Option<Arg>` from `next()?`; caller drives the
#      iteration with `while let Some(arg) = parser.next()?`
#    - ZERO ALLOCATIONS — no Vec/String creation in the hot path
#      (uses `OsString` references); ideal for no_std-adjacent and
#      embedded use cases where allocator pressure matters
#    - TINY (~600 LOC) pure Rust — no proc-macros, no derive, no
#      build dependencies
#    - `Parser::from_env()` — create parser from `std::env::args_os()`
#    - `Parser::from_args(args)` — create from explicit iterator
#      (useful for testing)
#    - `parser.next()? -> Option<Arg>` — pull next argument
#    - `Arg` ENUM variants:
#      * `Short(char)` — short flag like `-h`
#      * `Long(&str)` — long flag like `--help`
#      * `Value(OsString)` — positional or unconsumed value
#    - `parser.value()? -> OsString` — REQUIRED value following the
#      current flag (e.g. `--output FILE` — call `value()` after
#      matching `--output` to consume FILE); returns ERROR if no
#      value follows
#    - `parser.optional_value() -> Option<OsString>` — OPTIONAL value
#      (for `--flag[=value]` semantics)
#    - `parser.raw_args() -> impl Iterator<Item = OsString>` —
#      RAW ITERATOR over remaining args (for `--` separator pattern)
#    - `arg.unexpected()` — convenience method on `Arg` returning
#      formatted error for unhandled flag (used in catch-all `_ =>`
#      arm of match)
#    - `ValueExt` trait for OsString convenience: `.string()?` (UTF-8
#      conversion), `.parse()?` (FromStr coercion), `.parse_with(fn)?`
#      (custom parser)
#    - `lexopt::Error` — error type with variants for missing values,
#      invalid UTF-8, custom parse errors, etc.
#    - PROCESS EXIT model — caller controls via std::process::exit
#      or returning from main
#    - NO automatic --help (caller writes `Short('h') | Long("help")
#      => { print_usage(); exit(0); }` pattern)
#    - NO automatic --version (caller writes manually)
#    - NO subcommand support (caller hand-rolls subcommand dispatch
#      by checking first positional or first flag pattern)
#    - NO derive macros — caller writes the match arms manually
#      (this is INTENTIONAL — lexopt's design goal is ZERO MAGIC and
#      MAXIMAL CALLER CONTROL)
#    - SUPPORTS:
#      * `-fvalue` — short flag with concatenated value
#      * `-f value` — short flag with space-separated value
#      * `-f=value` — short flag with `=` separator
#      * `--flag=value` — long flag with `=` separator
#      * `--flag value` — long flag with space-separated value
#      * `-abc` — clustered short flags (each is a separate Short)
#      * `--` — separator (all subsequent args become Value(..))
#    - INSPIRED BY Python's getopt (similar low-level pull-parser
#      style)
#  Distinct from R275 Rust clap-derive (Salesforce-acquired Salesforce
#  framework... wait that's wrong, clap is by Kevin K., clap_derive
#  is `#[derive(Parser)]` proc-macro — much heavier with ~30MB build
#  cost), R330 Rust bpaf (functional applicative combinator style),
#  R344 Rust google/argh (derive-on-struct similar to clap_derive),
#  R347 Rust RazrFalcon/pico-args (LOW-LEVEL similar to lexopt but
#  with different iteration style — pico-args uses `args.value_from_str("--flag")?`
#  imperative-pull rather than lexopt's match-on-Arg-enum), R404
#  Rust matklad/xflags (DECLARATIVE MACRO BLOCK SYNTAX with `cmd
#  NAME { ... }` blocks — opposite philosophy from lexopt's caller-
#  driven match-loop), R275 (clap is also imperative builder but
#  much larger).  lexopt's approach: MINIMAL ITERATOR-BASED with
#  `lexopt::Parser::from_env()` + `parser.next()? -> Option<Arg>`
#  pull parser + `Arg::Short(char)`/`Long(&str)`/`Value(OsString)`
#  enum match + `parser.value()?` REQUIRED value + `parser.
#  optional_value()` OPTIONAL value + `parser.raw_args()` raw
#  iterator for `--` separator + `arg.unexpected()` catch-all error
#  + `ValueExt` trait `.string()?`/`.parse()?` + ZERO ALLOCATIONS +
#  TINY ~600 LOC + NO automatic --help/--version/subcommands
#  (caller writes match arms manually) — corpus's **first documented
#  minimal-iterator-based-pull-parser Rust CLI library**.  Brings
#  cross-language CLI library taxonomy variant count to 146; Rust
#  ecosystem now has 11 documented CLI libraries — TAKING THE SOLO
#  LEAD as the MOST-DOCUMENTED CLI LANGUAGE in the cross-language
#  taxonomy ahead of Go (10) and TypeScript-Node (10).
#
#  Surface (verbatim from `src/run.rs` lexopt match arms):
#
#  Options:
#    -h, --help                     Show help and exit
#        --version                  Show version (or fake "1.10.2"
#                                   when --fake-ninja-compat is set
#                                   for CMake compatibility)
#    -C DIR                         Change directory before running
#    -f FILE                        Input build file
#                                   (default: build.ninja)
#    -j N                           Parallelism (default: system
#                                   thread count)
#    -k N                           Keep going until N failures
#                                   (default: 1)
#    -v                             Print executed command lines
#    -t TOOL                        Tools (use `-t list` to list)
#                                   Subtools: list, deps, restat,
#                                   query, recompact, browse,
#                                   clean, graph, missingdeps
#    -d TOOL                        Debugging tools (use `-d list`)
#                                   Subtools: list, explain, keepdepfile,
#                                   keeprsp, lint, missingdeps, stats,
#                                   trace
#
#  Positional:
#    TARGETS...                     Targets to build (multiple values
#                                   accumulate); defaults to default
#                                   targets in build.ninja
#
#  Examples:
#    n2                                     # Build defaults
#    n2 -j 8 hello                          # Build "hello" target with 8 jobs
#    n2 -C build/                           # Change to build/ before running
#    n2 -f custom.ninja foo bar             # Use custom build file
#    n2 -t list                             # List available tools
#    n2 -d explain                          # Show explanation of build steps
#    n2 -k 0                                # Keep going forever on failures
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also lexopt users):
#    - nushell (IN CORPUS via _nushell — Rust-written shell 33k
#      stars; uses lexopt for `command.rs` CLI parsing; already
#      documented under different attribution; flagship lexopt use
#      case)
#    - rustpython (RustPython 20k stars — Python interpreter in
#      Rust; uses lexopt for settings.rs; FUTURE candidate)
#    - regex (rust-lang/regex official Rust regex crate — uses lexopt
#      in regex-cli; library not user-facing standalone CLI)
#    - jiff (BurntSushi/jiff — Andrew Gallant's date/time library;
#      uses lexopt in jiff-cli)
#    - pomsky (IN CORPUS via _pomsky — Pomsky regex language 1355
#      stars; uses lexopt)
#    - Shiba (rhysd/Shiba 799 stars — Markdown browser; uses lexopt
#      for CLI)
#    - swyh-rs (dheijl/swyh-rs 570 stars — Stream What You Hear in
#      Rust)
#    - cthulock / pass-rs / radicle-tui / wado-cli / blyxxyz/lexopt
#      examples (smaller community Rust tools using lexopt)
# ============================================================================

_n2() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '(-h --help)'{-h,--help}'[show help and exit]' \
    '--version[show version]' \
    '-C[change directory before running]:dir:_directories' \
    '-f[input build file (default build.ninja)]:file:_files -g "*.ninja"' \
    '-j[parallelism (default: system thread count)]:n' \
    '-k[keep going until N failures (default 1)]:n' \
    '-v[print executed command lines]' \
    '-t[tools (use `-t list` to list)]:tool:(list deps restat query recompact browse clean graph missingdeps)' \
    '-d[debugging tools (use `-d list` to list)]:tool:(list explain keepdepfile keeprsp lint missingdeps stats trace)' \
    '*:target:'
}

_n2 "$@"
