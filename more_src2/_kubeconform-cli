#compdef kubeconform-cli kubeconform
# _kubeconform-cli — yannh kubeconform-cli CLI command-line frontend wrapping the Kubeconform fast Kubernetes manifest validator with support for custom resources open-source written in Go inspired by Kubeval which is no longer maintained does not require access to a Kubernetes cluster validates JSON Yaml manifests against k8s OpenAPI schemas crd-schemas multi-doc-manifests-recursive-glob-pattern parallel-validation summary-output tap junit json text exit-on-error skip-kinds reject-kinds insecure-skip-tls-verify ignore-missing-schemas (yannh team Yann Hamon, Go); flag
# upstream: https://github.com/yannh/kubeconform

_kubeconform-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-cache+[cache dir]:dir:_files -/' \
        '-debug[debug]' \
        '-exit-on-error[exit on first error]' \
        '-h[show help]' \
        '-ignore-filename-pattern+[regex]:str:' \
        '*-ignore-filename-pattern+[regex]:str:' \
        '-ignore-missing-schemas[ignore missing schemas]' \
        '-insecure-skip-tls-verify[skip TLS verify]' \
        '-kubernetes-version+[v]:str:' \
        '-n+[parallel goroutines]:n:' \
        '-output+[fmt]:f:(text json tap junit)' \
        '-reject+[kinds]:str:' \
        '-schema-location+[locations]:str:' \
        '*-schema-location+[location]:str:' \
        '-skip+[kinds]:str:' \
        '-strict[strict validation]' \
        '-summary[only print summary]' \
        '*:files:_files'
}

_kubeconform-cli "$@"
