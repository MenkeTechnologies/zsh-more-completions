#compdef dendrite-monolith-server dendrite-polylith-multi create-account generate-config generate-keys
# _dendrite-cli — Dendrite Matrix homeserver (Go); monolith + polylith binaries plus admin helpers
# upstream: https://github.com/matrix-org/dendrite

_dendrite-cli() {
    _arguments \
        '-config+[YAML config file]:file:_files -g "*.yaml"' \
        '-version[show version]' \
        '-http-bind-address+[HTTP bind]:addr:' \
        '-https-bind-address+[HTTPS bind]:addr:' \
        '-tls-cert+[TLS cert]:file:_files' \
        '-tls-key+[TLS key]:file:_files' \
        '-api[enable API endpoints (monolith only)]' \
        '-stages-port+[stages port]:port:' \
        '-monitor+[Prometheus listen]:addr:' \
        '-trace-internal[enable internal tracing]' \
        '-really-enable-open-registration[allow open registration]' \
        '*:host:_hosts'
}

_dendrite-cli "$@"
