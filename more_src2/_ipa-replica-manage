#compdef ipa-replica-manage
# Documentation: https://manpages.debian.org/experimental/freeipa-server/ipa-replica-manage.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'list:list replicas'
  'list-ruv:list replication update vectors'
  'connect:connect to replica'
  'disconnect:disconnect from replica'
  'del:remove replica'
  're-initialize:re-initialize replica'
  'force-sync:force sync'
  'clean-ruv:clean obsolete RUVs'
  'abort-clean-ruv:abort RUV cleanup'
  'list-clean-ruv:show RUV cleanup tasks'
  'set-renewal-master:set CA renewal master'
  'dnarange-show:show DNA ranges'
  'dnarange-set:set DNA range'
  'dnanextrange-show:show DNA next range'
  'dnanextrange-set:set DNA next range'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(--force)--force[force]' \
  '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
  '(-w --password)'{-w,--password}'+[directory manager password]:pw:' \
  '(-p --principal)'{-p,--principal}'+[principal]:principal:' \
  '(--no-lookup)--no-lookup[do not lookup IPA server]' \
  '(--from)--from=+[from server]:host:_hosts' \
  '(--binddn)--binddn=+[bind DN]:dn:' \
  '(--bindpw)--bindpw=+[bind password]:pw:' \
  '(--cacert)--cacert=+[CA cert]:file:_files' \
  '(--winsync)--winsync[winsync mode]' \
  '(--passsync)--passsync=+[passsync password]:pw:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ipa-replica-manage command' commands && ret=0 ;;
esac

return ret
