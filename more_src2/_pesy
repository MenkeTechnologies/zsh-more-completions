#compdef pesy
# _pesy — Manas Jayanth pesy esy/dune project scaffolder CLI alias (jordwalke team, OCaml/Reason); commander
# upstream: https://github.com/esy/pesy

_pesy() {
    local -a sub=(
        'build:build the project'
        'install:install dependencies'
        'init:initialize project'
        'azure-init:init azure devops pipeline'
        'create:create new pesy project'
        'fmt:format source code'
        'test:run tests'
        'add:add dependency'
        'remove:remove dependency'
        'list:list packages'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--debug[debug]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pesy subcommand' sub ;;
        args)
            case $words[1] in
                create|init) _arguments \
                    '1:dir:_files -/' \
                    '--template=+[template]:t:(pesy-reason-template pesy-ocaml-template)' \
                    '--use-esy[use esy]' ;;
                add|remove) _arguments '*:package:' ;;
                build|test|fmt) _arguments '*:target:' ;;
            esac
            ;;
    esac
}

_pesy "$@"
