#compdef pbmtoescp2
# Documentation: man pbmtoescp2 (Netpbm)
# Source: convert a PBM image to an Epson ESC/P2 printer command stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-compress=[compression mode]:mode:(0 1 2)' \
    '-resolution=[resolution dpi]:dpi:(180 360 720)' \
    '-stripeheight=[stripe height in dots]:n:' \
    '-formfeed[issue form feed at end]' \
    '-raw[emit raw bitmap data]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
