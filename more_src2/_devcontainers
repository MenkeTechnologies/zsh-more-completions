#compdef devcontainers
# _devcontainers — Microsoft VS Code Dev Containers CLI reference implementation devcontainer-up/build/exec (microsoft team, Node.js); custom argparse
# upstream: https://github.com/devcontainers/cli

_devcontainers() {
    local -a sub=(
        'up:create and run dev container'
        'build:build a dev container image'
        'run-user-commands:run lifecycle commands'
        'read-configuration:read effective config'
        'outdated:show outdated features'
        'upgrade:upgrade features'
        'features:feature subcommands'
        'templates:template subcommands'
        'exec:execute command in container'
        'set-up:set up an existing container'
        'down:stop and remove container'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--workspace-folder=+[workspace dir]:dir:_files -/' \
        '--config=+[config file]:file:_files -g "devcontainer.json"' \
        '--override-config=+[override config]:file:_files' \
        '--docker-path=+[docker binary]:file:_command_names' \
        '--docker-compose-path=+[compose binary]:file:_command_names' \
        '--container-data-folder=+[data dir]:dir:_files -/' \
        '--container-system-data-folder=+[sys data dir]:dir:_files -/' \
        '--log-level=+[level]:l:(info debug trace)' \
        '--log-format=+[format]:f:(text json)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'devcontainers subcommand' sub ;;
        args)
            case $words[1] in
                up) _arguments \
                    '--id-label=+[label]:str:' \
                    '--remove-existing-container[remove existing]' \
                    '--build-no-cache[no cache]' \
                    '--expect-existing-container[require existing]' \
                    '--skip-post-create[skip postCreate]' \
                    '--skip-non-blocking-commands[skip non-blocking]' \
                    '--prebuild[prebuild]' \
                    '--user-data-folder=+[data dir]:dir:_files -/' \
                    '--mount-workspace-git-root[mount git root]' \
                    '--update-remote-user-uid-default=+[mode]:m:(never on off)' ;;
                build) _arguments \
                    '--image-name=+[image name]:str:' \
                    '--no-cache[no cache]' \
                    '--platform=+[platform]:p:(linux/amd64 linux/arm64)' \
                    '--push[push image]' \
                    '--output=+[output]:str:' ;;
                exec) _arguments \
                    '--id-label=+[label]:str:' \
                    '--container-id=+[container id]:str:' \
                    '--workspace-folder=+[dir]:dir:_files -/' \
                    '--remote-env=+[env=value]:str:' \
                    '*:command:_command_names' ;;
                features|templates) _arguments '1:cmd:(test publish package info generate-docs resolve-dependencies)' ;;
                read-configuration) _arguments \
                    '--include-features-configuration[include features]' \
                    '--include-merged-configuration[include merged]' ;;
            esac
            ;;
    esac
}

_devcontainers "$@"
