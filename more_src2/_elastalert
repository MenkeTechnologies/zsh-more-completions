#compdef elastalert
# _elastalert — Yelp ElastAlert: rule-based alerting for Elasticsearch (Yelp/elastalert)
# upstream: https://github.com/Yelp/elastalert
# Flags from elastalert/elastalert.py (argparse).

_elastalert() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[config file (default config.yaml)]:file:_files -g "*.{yml,yaml}"' \
        '(--verbose)--debug[suppress alerts, print info]' \
        '--rule=[run only this rule (filename in rules folder)]:rule:' \
        '--silence=[silence rule for time period (units=number)]:spec:' \
        '--start=[start timestamp (YYYY-MM-DDTHH:MM:SS or NOW)]:timestamp:' \
        '--end=[end timestamp (YYYY-MM-DDTHH:MM:SS)]:timestamp:' \
        '(--debug)--verbose[increase verbosity without suppressing alerts]' \
        '--patience=[patience timeout duration]:duration:' \
        '--pin_rules[do not auto-load new rules]' \
        '--es_debug[verbose ES query logging]' \
        '--es_debug_trace=[file to log ES debug trace]:file:_files'
}

_elastalert "$@"
