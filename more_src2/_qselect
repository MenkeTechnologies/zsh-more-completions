#compdef qselect
# Documentation: https://www.systutorials.com/docs/linux/man/1-qselect-torque/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# qselect: list job IDs matching criteria
local curcontext="$curcontext" ret=1
_arguments -C \
  '-a+[filter by submission/eligible date_time]:datetime:' \
  '-A+[account string]:account:' \
  '-c+[checkpoint interval]:val:' \
  '-e[restrict to jobs in execution queues]' \
  '-h+[hold types]:hold_list:(u o s n)' \
  '-l+[resource requirements]:resource:' \
  '-N+[job name]:name:' \
  '-p+[priority]:n:' \
  '-q+[queue destination]:queue:' \
  '-r+[rerunable]:val:(y n)' \
  '-s+[job state]:state:(E H Q R T W)' \
  '-u+[user list]:user:_users' \
  '*::qselect args:_files' && ret=0
return ret
