#compdef druid-cli druid2
# _druid-cli — Apache Druid druid-cli CLI command-line frontend wrapping the Apache Druid high-performance real-time analytics OLAP database providing server overlord coordinator broker historical middleManager router internal-discovery service tools start-batch-task ingestion-spec sql-rest task-statistics segment-management compaction kill-task purge-shutdown bundled-ZooKeeper-PostgreSQL-MySQL (ASF Druid team, Java); custom argparse
# upstream: https://druid.apache.org/

_druid-cli() {
    local -a sub=(
        'server:run server'
        'tools:tools'
        'index:run indexing task'
        'broker:run broker'
        'coordinator:run coordinator'
        'historical:run historical'
        'middleManager:run middleManager'
        'overlord:run overlord'
        'router:run router'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config dir]:dir:_files -/' \
        '--config=+[dir]:dir:_files -/' \
        '-p+[property]:str:' \
        '--property=+[k=v]:str:' \
        '--log-properties=+[file]:file:_files -g "log4j2.xml *.properties"' \
        '--jvm-config=+[file]:file:_files -g "jvm.config"' \
        '--main-config=+[file]:file:_files -g "main.config"' \
        '--task-spec=+[file]:file:_files -g "*.json"' \
        '--task-id=+[id]:str:' \
        '--segment-id=+[id]:str:' \
        '--data-source=+[name]:str:' \
        '--interval=+[ISO]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'druid subcommand' sub ;;
        args)
            case $words[1] in
                tools) _arguments '1:tool:(pull-deps coordinator-redis-init dump-segment validate-segments insert-segment-to-db purge-deep-storage compact-segments)' '*:arg:' ;;
                index) _arguments '*:spec:_files -g "*.json"' ;;
            esac
            ;;
    esac
}

_druid-cli "$@"
