#compdef dcmedit
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dcmedit.html
# Source: MRtrix3/mrtrix3 cmd/dcmedit.cpp — edit DICOM tags in-place (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-anonymise[remove identifiable information by overwriting standard tags]' \
    '-id+[replace all ID tags with given text]:text:_default' \
    '*-tag+[replace specific tag (group element newvalue)]:tag:_default' \
    '1:DICOM file:_files -g "*.{dcm,DCM,dicom,IMA}"' \
    && ret=0

return ret
