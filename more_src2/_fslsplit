#compdef fslsplit
# fslsplit — split a 4D image into separate volumes

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-x -y -z)-t[split along time dimension]' \
  '(-t -y -z)-x[split along x dimension]' \
  '(-t -x -z)-y[split along y dimension]' \
  '(-t -x -y)-z[split along z dimension]' \
  '1:input image:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '2:output basename:_files'
