#compdef powerline-shell
# _powerline-shell — b-ryan's powerline-style prompt generator (Python port that renders a segmented prompt from per-segment plugins; configured via ~/.powerline-shell.json)
# upstream: https://github.com/b-ryan/powerline-shell
# Flags from powerline_shell/__init__.py on tip (argparse).

_powerline-shell() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--generate-config[print the default JSON config to stdout and exit]' \
        '--shell=[target shell]:shell:(bash tcsh zsh bare)' \
        '1:prev-error-code:'
}

_powerline-shell "$@"
