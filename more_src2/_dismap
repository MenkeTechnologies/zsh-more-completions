#compdef dismap

local curcontext="$curcontext" state line ret=1

_arguments \
  '(-i --ip)'{-i,--ip}'[target IP or CIDR]:target IP/CIDR' \
  '(-f --file)'{-f,--file}'[target file]:target file:_files' \
  '(-p --port)'{-p,--port}'[port range]:port range' \
  '--np[disable probe]' \
  '--nc[disable color output]' \
  '(-t --thread)'{-t,--thread}'[number of threads]:threads' \
  '--timeout[request timeout in seconds]:timeout' \
  '--proxy[proxy URL]:proxy URL' \
  '--output[output file]:output file:_files' \
  '(-l --level)'{-l,--level}'[scan level (1-3)]:level:(1 2 3)' \
  '--type[protocol type]:protocol type:(tcp udp)' \
  && ret=0

return ret
