#compdef elm-cli
# _elm-cli — Evan Czaplicki Elm language compiler CLI alias (Evan Czaplicki / elm-lang, Haskell); custom argparse
# upstream: https://github.com/elm/compiler

_elm-cli() {
    local -a sub=(
        'bump:bump version after API change'
        'diff:diff API between versions'
        'init:scaffold elm.json'
        'install:install a package'
        'make:compile Elm code to JS/HTML'
        'publish:publish a package'
        'reactor:run dev reactor server'
        'repl:start REPL'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'elm subcommand' sub ;;
        args)
            case $words[1] in
                make) _arguments \
                    '--debug[debug mode]' \
                    '--optimize[optimize output]' \
                    '--output=+[output file]:file:_files' \
                    '--report=+[report format]:fmt:(json compact)' \
                    '--docs=+[docs file]:file:_files' \
                    '*:elm-file:_files -g "*.elm"' ;;
                install) _arguments '*:package:' ;;
                reactor) _arguments \
                    '--port=+[port]:port:' ;;
                init) _arguments '*:arg:' ;;
                repl) _arguments \
                    '--interpreter=+[interpreter]:str:' \
                    '--no-colors[no colors]' ;;
                diff) _arguments \
                    '*:package-and-versions:' ;;
                publish) _arguments '*:arg:' ;;
                bump) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_elm-cli "$@"
