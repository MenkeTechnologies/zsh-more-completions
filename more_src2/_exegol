#compdef exegol
# Documentation: https://docs.exegol.com/wrapper/cli/ (start, exec, etc.) + pypi.org/project/Exegol
# Reference accessed: 2026-05-29
# Exegol — Docker-based offensive-security environment.

local curcontext="$curcontext" state line ret=1

local -a _subcmds
_subcmds=(
  'install:install an Exegol image'
  'update:update Exegol images'
  'uninstall:uninstall Exegol images'
  'remove:remove containers'
  'start:start or create an Exegol container'
  'stop:stop running containers'
  'restart:restart containers'
  'exec:run a single command in a container'
  'info:list all containers and images'
  'build:build a custom Exegol image'
  'version:show Exegol version'
  'help:show help for an action'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose output (stackable)]' \
  '--debug[debug logging]' \
  '--accept-eula[accept the end-user license agreement]' \
  '1: :->subcmds' \
  '*:: :->args' && ret=0

case $state in
  subcmds)
    _describe -t commands 'exegol action' _subcmds && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments \
          '(-w --workspace)'{-w,--workspace=}'[link a host folder to /workspace]:dir:_directories' \
          '(-cwd --cwd-mount)'{-cwd,--cwd-mount}'[set /workspace to current working directory]' \
          '(-fs --update-fs)'{-fs,--update-fs}'[modify folder permissions for shared workspace]' \
          '*'{-V,--volume=}'[share volume between host and container (host\:cont\[\:mode\])]:volume:' \
          '*'{-p,--port=}'[expose network port (host\:cont/proto)]:port:' \
          '--hostname=[custom container hostname]:hostname:' \
          '--hosts-file=[import custom hosts entries]:file:_files' \
          '--disable-X11[disable GUI application support]' \
          '--disable-my-resources[do not mount shared resources]' \
          '--disable-exegol-resources[do not mount Exegol resources]' \
          '--network=[network mode]:mode:(host docker nat disable)' \
          '--disable-shared-timezones[do not share host timezone]' \
          '*'{-d,--device=}'[add host device to container]:device:_files' \
          '*--cap=[grant Linux capability]:cap:(SYS_ADMIN SYS_PTRACE SYS_TIME NET_ADMIN NET_RAW DAC_READ_SEARCH AUDIT_WRITE AUDIT_CONTROL SYS_MODULE SYS_NICE SYS_RAWIO IPC_LOCK)' \
          '--privileged[grant extended privileges (use cautiously)]' \
          '--desktop[enable graphical desktop environment]' \
          '--desktop-config=[desktop protocol\:host\:port]:config:' \
          '--vpn=[OpenVPN .ovpn or WireGuard config file]:file:_files -g "*.(ovpn|conf)"' \
          '--vpn-auth=[VPN credentials file]:file:_files' \
          '(-l --log)'{-l,--log}'[enable shell command/output logging]' \
          '--log-method=[shell logging method]:method:(asciinema script vt100)' \
          '--log-compress[auto-compress log files]' \
          '*'{-e,--env=}'[set environment variable]:var=value:' \
          '(-s --shell)'{-s,--shell=}'[shell type (default zsh)]:shell:(zsh bash fish)' \
          ':container name:' \
          ':image name:' && ret=0
        ;;
      exec)
        _arguments \
          '*'{-V,--volume=}'[share volume]:volume:' \
          '*'{-p,--port=}'[expose port]:port:' \
          '--privileged[grant extended privileges]' \
          '*'{-d,--device=}'[add host device]:device:_files' \
          '*--cap=[grant Linux capability]:cap:(SYS_ADMIN NET_ADMIN NET_RAW)' \
          ':container name:' \
          '*:command:' && ret=0
        ;;
      install|update|uninstall|remove|stop|restart|info)
        _arguments \
          '*:image or container:' && ret=0
        ;;
      build)
        _arguments \
          '--build-profile=[build profile]:profile:' \
          ':image tag:' && ret=0
        ;;
    esac
    ;;
esac

return ret
