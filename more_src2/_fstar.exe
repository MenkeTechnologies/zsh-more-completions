#compdef fstar.exe
# Documentation: https://github.com/FStarLang/FStar
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fstar.exe is an alias for the fstar binary; see _fstar for full options.
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '*:F* source file:_files -g "*.fst(|i)"' && ret=0

return ret
