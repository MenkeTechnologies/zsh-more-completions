#compdef perl-cleaner
# Documentation: https://github.com/gentoo-perl/perl-cleaner
# Reference accessed: 2026-05-20
# Verified: upstream perl-cleaner script (v2.30) at the URL above.

local arguments

arguments=(
  '(- :)'{--help,-h}'[show help]'
  '(- :)'{--version,-V}'[show version]'
  {'(--pretend --dry-run)-p','(-p --dry-run)--pretend','(-p --pretend)--dry-run'}"[pretend (don't actually do anything)]"
  '*'{-v,--verbose}'[increase verbosity (may be specified multiple times)]'
  '*'{-q,--quiet}'[decrease verbosity]'
  '--modules[rebuild perl modules for old installs of perl]'
  '--allmodules[rebuild all perl modules]'
  '--libperl[rebuild anything linked against libperl]'
  '--all[short for --modules --libperl]'
  '--reallyall[short for --allmodules --libperl]'
  '--leftovers[show files that were not rebuilt]'
  '--delete-leftovers[delete known leftover files]'
  '--dont-delete-leftovers[preserve leftover files]'
  '--force[force rebuilding]'
  '--reinstall-identical-versions[reinstall identical versions]'
  '--package-manager-command=[custom package manager command]:command:'
  '(- :)'{--package-manager,-P}'[use package manager]:package manager:((portage pkgcore paludis))'
)

_arguments $arguments

