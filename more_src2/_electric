#compdef electric
# Documentation: https://www.staticfreesoft.com/jmanual/mchap01-03.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Electric VLSI: IC design editor (schematics + layout)
local ret=1
_arguments \
  '-help[show help]' \
  '-version[show full version info]' \
  '-v[show abbreviated version]' \
  '-s[execute Bean Shell script (- for stdin)]:script:_files' \
  '-debug[enable developer menus and testing]' \
  '-batch[batch mode (no GUI)]' \
  '-mdi[multiple document interface (default on Windows)]' \
  '-sdi[single document interface (default on UNIX/Linux/Mac)]' \
  '-NOMINMEM[bypass minimum memory check]' \
  '*:Electric library (.elib/.delib/.jelib):_files -g "*.(elib|delib|jelib)"' && ret=0
return ret
