#compdef kondo
# Documentation: https://raw.githubusercontent.com/tbillington/kondo/master/kondo/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream clap definitions in kondo/src/main.rs.
# Zsh completion for kondo - Clean unneeded build artifacts
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-a --all)'{-a,--all}'[clean all found projects without confirmation]' \
  '(-o --older)'{-o,--older}'[filter by last modified time (e.g. 20d)]:age:' \
  '(-d --default)'{-d,--default}'[default to yes if no input provided]' \
  '*'{-I,--ignored-dirs}'[directories to ignore and skip during traversal]:dir:_directories' \
  '(-L --follow-symlinks)'{-L,--follow-symlinks}'[follow symbolic links]' \
  '--same-filesystem[restrict directory traversal to root filesystem]' \
  '*'{-q,--quiet}'[quiet mode (-qq prevents all output)]' \
  '(-n --dry-run)'{-n,--dry-run}'[list directories without cleaning]' \
  '--single-key[accept single-letter input without Enter key]' \
  '--completions=[generate shell completions]:shell:(bash elvish fish powershell zsh)' \
  '(- *)'{-h,--help}'[show help information]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:directory:_directories' && ret=0
return ret
