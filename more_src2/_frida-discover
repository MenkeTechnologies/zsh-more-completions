#compdef frida-discover
# _frida-discover — Frida discover utility (Ole André V. Ravnås); scans a running process to enumerate exported functions for hooking
# upstream: https://github.com/frida/frida

_frida-discover() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-D --device)'{-D,--device}'+[device id]:device:' \
        '(-U --usb)'{-U,--usb}'[USB device]' \
        '(-R --remote)'{-R,--remote}'[remote frida-server]' \
        '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
        '(-O --options)'{-O,--options}'+[option args]:opts:' \
        '(-f --file)'{-f,--file}'+[spawn target binary]:file:_files' \
        '(-F --attach-frontmost)'{-F,--attach-frontmost}'[attach to frontmost app]' \
        '(-n --attach-name)'{-n,--attach-name}'+[attach to name]:name:' \
        '(-p --attach-pid)'{-p,--attach-pid}'+[attach PID]:pid:_pids' \
        '--stdio+[stdio mode]:mode:(inherit pipe)' \
        '*:target:'
}

_frida-discover "$@"
