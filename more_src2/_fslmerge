#compdef fslmerge
# fslmerge — concatenate images in time, x, y, or z

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-x -y -z -a -tr)-t[concatenate in time (4th dimension)]' \
  '(-t -y -z -a -tr)-x[concatenate in x direction]' \
  '(-t -x -z -a -tr)-y[concatenate in y direction]' \
  '(-t -x -y -a -tr)-z[concatenate in z direction]' \
  '(-t -x -y -z -tr)-a[auto-choose concat dimension]' \
  '(-t -x -y -z -a)-tr[concatenate in time and set TR]:TR value' \
  '1:output file:_files -g "*.{nii,nii.gz,img,hdr}"' \
  '*:input files:_files -g "*.{nii,nii.gz,img,hdr}"'
