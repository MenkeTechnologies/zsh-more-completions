#compdef FoxDot foxdot
# Documentation: https://github.com/Qirky/FoxDot
# Reference accessed: 2026-05-27
# Verified: upstream FoxDot/__main__.py argparse parser (Qirky/FoxDot)

# Zsh completion for FoxDot, a Python live-coding environment for
# SuperCollider.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --pipe)'{-p,--pipe}'[run FoxDot from the command line interface]' \
  '(-d --dir)'{-d+,--dir=}'[use an alternate directory for looking up samples]:directory:_files -/' \
  '(-s --startup)'{-s+,--startup=}'[use an alternate startup file]:file:_files' \
  '(-S --simple)'{-S,--simple}'[run FoxDot in simple (accessible) mode]' \
  '(-n --no-startup)'{-n,--no-startup}'[do not load startup.py on boot]' \
  '(-b --boot)'{-b,--boot}'[boot SuperCollider from the command line]' \
  '(- *)'{-h,--help}'[show help message and exit]' && ret=0

return ret
