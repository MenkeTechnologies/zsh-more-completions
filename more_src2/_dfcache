#compdef dfcache
# _dfcache — Dragonfly P2P cache CLI (dragonflyoss/client)
# upstream: https://github.com/dragonflyoss/client
# Subcommands from dragonfly-client/src/bin/dfcache/main.rs (clap).

_dfcache() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'import:import a local file into the Dragonfly P2P network'
                'export:export a file from the P2P network by task ID'
                'stat:show task stats by ID'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                import) _arguments '1:local file:_files' ;;
                export) _arguments '1:task ID:' ;;
                stat) _arguments '1:task ID:' ;;
            esac
            ;;
    esac
}

_dfcache "$@"
