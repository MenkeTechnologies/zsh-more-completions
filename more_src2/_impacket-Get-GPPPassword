#compdef impacket-Get-GPPPassword
# Documentation: https://github.com/fortra/impacket/blob/master/examples/Get-GPPPassword.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-Get-GPPPassword: retrieve cleartext passwords from Group Policy Preferences XML.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-xmlfile[GPP XML file to parse]:file:_files' \
  '-share[SMB share to scan]:share:' \
  '-base-dir[directory to search in]:dir:' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target IP]:ip:' \
  '-port[destination port]:port:(139 445)' \
  '*::positional:_files' && ret=0
return ret
