# _llvm-config — LLVM Foundation llvm-config print LLVM build configuration for the LLVM compiler infrastructure (llvm team, C++); custom argparse
# upstream: https://github.com/llvm/llvm-project

_llvm-config() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--prefix[show install prefix]' \
        '--exec-prefix[show exec prefix]' \
        '--bindir[show binary dir]' \
        '--includedir[show include dir]' \
        '--libdir[show library dir]' \
        '--cmakedir[show cmake module dir]' \
        '--cppflags[show preprocessor flags]' \
        '--cflags[show C compiler flags]' \
        '--cxxflags[show C++ compiler flags]' \
        '--ldflags[show linker flags]' \
        '--system-libs[show system libraries]' \
        '--libs[show LLVM libraries]' \
        '--libnames[show LLVM library names]' \
        '--libfiles[show LLVM library files]' \
        '--components[list LLVM components]' \
        '--targets-built[show targets supported by this build]' \
        '--host-target[show host target triple]' \
        '--build-mode[show build mode]' \
        '--assertion-mode[show assertion mode]' \
        '--build-system[show build system]' \
        '--has-rtti[show rtti enabled]' \
        '--has-global-isel[show global isel enabled]' \
        '--shared-mode[show shared library mode]' \
        '--link-shared[link with shared LLVM]' \
        '--link-static[link with static LLVM]' \
        '--ignore-libllvm[do not link with libLLVM]' \
        '--obj-root[show obj root]' \
        '--src-root[show src root]' \
        '*:component:(all all-targets analysis aarch64 amdgpu arm armcommon asmparser asmprinter binaryformat bitreader bitstreamreader bitwriter cfguard codegen core coroutines coverage debuginfodwarf debuginfomsf debuginfopdb demangle dlltooldriver dwp engine executionengine extensions filecheck fuzzmutate fuzzmutate gimr gisel global-isel globalisel hexagon hidden hipstd-target instcombine instrumentation interpreter ipo irreader jitlink lanai libdriver linker lto m68k mc mcdisassembler mcjit mcparser mips msp430 native nativecodegen nvptx objcarcopts object objectyaml option orcjit orcshared orctargetprocess passes powerpc profiledata remarks riscv runtimedyld scalaropts selectiondag sparc support symbolize systemz tablegen target textapi transformutils ve vectorize webassembly windowsmanifest x86 xcore xray)'
}

_llvm-config "$@"
