#compdef i3status-rs
# Documentation: https://github.com/greshake/i3status-rust
# Reference accessed: 2026-05-17
# Verified: greshake/i3status-rust README. Minimal CLI (nearly all
# config is in TOML).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --threads flag (not in upstream).

# i3status-rs: i3status-rust status bar generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--never-stop[use SIGCONT instead of SIGSTOP for blocks]' \
  '1:config file:_files -g "*.toml(-.)"' && ret=0
return ret
