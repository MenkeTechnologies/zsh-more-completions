#compdef printf
# Documentation: man zshbuiltins (zsh)
# Source: zsh printf builtin — format and print arguments per C printf-style spec.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v+[store result in named variable instead of printing]:name:_parameters' \
    '1:format string:' \
    '*:argument:' \
    && ret=0

return ret
