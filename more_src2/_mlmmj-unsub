#compdef mlmmj-unsub
# Documentation: https://mlmmj.org/mlmmj-unsub.html
# Reference accessed: 2026-05-30
# mlmmj-unsub — unsubscribe an email address from an mlmmj mailing list.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-L+[full path to list directory (REQUIRED)]:dir:_directories' \
  '-a+[email address to unsubscribe (REQUIRED)]:email:' \
  '(-d -n -N)-d[target digest version only]' \
  '(-d -n -N)-n[target nomail version only]' \
  '(-d -n -N)-N[target normal version only]' \
  '(-c -C)-c[send goodbye message to unsubscribed address]' \
  '(-c -C)-C[request mail confirmation of the unsubscribe]' \
  '-q[suppress owner notification]' \
  '-s[do not send mail if address is not currently subscribed]' \
  '-r[simulate email-based request (internal use)]' \
  '-R[simulate confirmation arrival via email (internal use)]' \
  '-U[do not switch to list directory owner UID]' \
  && ret=0

return ret
