#compdef pitest pit-cli
# _pitest — PIT mutation testing for JVM (PIT project / Henry Coles, Java); custom argparse
# upstream: https://github.com/hcoles/pitest

_pitest() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '--targetClasses=+[target classes globs csv]:list:' \
        '--targetTests=+[target tests globs csv]:list:' \
        '--reportDir=+[report directory]:dir:_files -/' \
        '--sourceDirs=+[source dirs csv]:list:_files -/' \
        '--mutators=+[mutator groups csv]:list:(DEFAULTS STRONGER OLD_DEFAULTS RETURN_VALS INCREMENTS VOID_METHOD_CALLS NON_VOID_METHOD_CALLS CONDITIONALS_BOUNDARY CONSTRUCTOR_CALLS INLINE_CONSTS NEGATE_CONDITIONALS MATH INVERT_NEGS REMOVE_CONDITIONALS REMOVE_INCREMENTS EXPERIMENTAL_MEMBER_VARIABLE EXPERIMENTAL_NAKED_RECEIVER EXPERIMENTAL_RETURN_VALUES ABS AOD AOR CRCR OBBN ROR UOI)' \
        '--features=+[features]:list:' \
        '--threads=+[parallel threads]:n:' \
        '--mutationUnitSize=+[mutation unit size]:n:' \
        '--timeoutFactor=+[timeout factor]:f:' \
        '--timeoutConst=+[timeout const ms]:n:' \
        '--maxMutationsPerClass=+[max mutations per class]:n:' \
        '--maxSurviving=+[max surviving]:n:' \
        '--mutationThreshold=+[mutation threshold pct]:n:' \
        '--coverageThreshold=+[coverage threshold pct]:n:' \
        '--testStrengthThreshold=+[test strength threshold pct]:n:' \
        '--excludedMethods=+[excluded methods]:list:' \
        '--excludedClasses=+[excluded classes]:list:' \
        '--excludedTestClasses=+[excluded test classes]:list:' \
        '--avoidCallsTo=+[avoid calls to]:list:' \
        '--classPath=+[classpath csv]:list:_files' \
        '--classPathFile=+[classpath file]:file:_files' \
        '--reportSourceDirs=+[report source dirs csv]:list:_files -/' \
        '--historyInputLocation=+[history input file]:file:_files' \
        '--historyOutputLocation=+[history output file]:file:_files' \
        '--outputFormats=+[output formats csv]:list:(XML HTML CSV JUNIT)' \
        '--verbose[verbose]' \
        '--includeLaunchClasspath=+[include launch classpath]:b:(true false)' \
        '--jvmArgs=+[jvm args]:str:' \
        '--jvmPath=+[jvm path]:file:_files' \
        '--testPlugin=+[test plugin]:str:(junit5 junit testng)' \
        '--includedGroups=+[included groups csv]:list:' \
        '--excludedGroups=+[excluded groups csv]:list:' \
        '--exportLineCoverage[export line coverage]' \
        '--detectInlinedCode[detect inlined code]' \
        '--useClasspathJar[use classpath jar]' \
        '--inputEncoding=+[input encoding]:enc:' \
        '--outputEncoding=+[output encoding]:enc:' \
        '--skipFailingTests[skip failing tests]' \
        '*:arg:'
}

_pitest "$@"
