#compdef git-jump
# Documentation: https://github.com/git/git/blob/master/contrib/git-jump/README
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-jump: jump to interesting points in a git repo (diff/merge/grep/ws)

local curcontext="$curcontext" state line ret=1
local -a modes

modes=(
  'diff:jump to the beginning of any diff hunks'
  'merge:jump to the beginning of any merge conflict markers'
  'grep:jump to any grep matches, including the column of the first match'
  'ws:jump to whitespace errors detected by git diff --check'
)

_arguments -C \
  '--stdout[print listing instead of opening editor]' \
  '1: :->mode' \
  '*::arg:->args' && ret=0

case $state in
  (mode)
    _describe -t modes 'git-jump mode' modes && ret=0
    ;;
  (args)
    case $line[1] in
      (diff)
        _arguments \
          '--cached[show staged changes]' \
          '*:diff option:' && ret=0
        ;;
      (grep)
        _arguments \
          '-i[case-insensitive search]' \
          '*:grep option:' && ret=0
        ;;
    esac
    ;;
esac

return ret
