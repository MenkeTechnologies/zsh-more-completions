#compdef ripdrag
# Documentation: https://github.com/nik012003/ripdrag
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for ripdrag (drag-and-drop source/target from terminal)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose output]' \
  '(-t --target)'{-t,--target}'[operate as a drop target instead of drag source]' \
  '(-k --keep)'{-k,--keep}'[retain files for dragging when used with --target]' \
  '(-r --resizable)'{-r,--resizable}'[allow window resizing]' \
  '(-x --and-exit)'{-x,--and-exit}'[close after first successful drag or drop]' \
  '(-i --icons-only)'{-i,--icons-only}'[display only icons without text labels]' \
  '(-d --disable-thumbnails)'{-d,--disable-thumbnails}'[skip loading image thumbnails]' \
  '(-s --icon-size)'{-s,--icon-size}'+[set icon/thumbnail dimensions]:size' \
  '(-W --content-width)'{-W,--content-width}'+[minimum window width]:width' \
  '(-H --content-height)'{-H,--content-height}'+[default window height]:height' \
  '(-I --from-stdin)'{-I,--from-stdin}'[read file paths from standard input]' \
  '(-a --all)'{-a,--all}'[display a button to drag all items]' \
  '(-A --all-compact)'{-A,--all-compact}'[show item count and drag collectively]' \
  '(-n --no-click)'{-n,--no-click}'[disable file opening on click]' \
  '(-b --basename)'{-b,--basename}'[always display file basename]' \
  '*:file:_files'
