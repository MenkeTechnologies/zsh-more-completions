#compdef pglogical_create_subscriber
# Documentation: https://github.com/2ndQuadrant/pglogical
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--drop-slot-if-exists[drop conflicting replication slot automatically]' \
  '(-n --subscriber-name)'{-n+,--subscriber-name=}'[subscriber name]:name:' \
  '--provider-dsn=[provider DSN]:dsn:' \
  '--subscriber-dsn=[subscriber DSN]:dsn:' \
  '(-D --pgdata)'{-D+,--pgdata=}'[data directory for new node]:dir:_files -/' \
  '--replication-sets=[replication sets comma-separated]:sets:' \
  '--databases=[databases to replicate]:dbs:' \
  '--apply-delay=[apply delay seconds]:delay:' \
  '--recovery-conf=[recovery conf template]:file:_files' \
  '--postgresql-conf=[postgresql conf]:file:_files' \
  '--hba-conf=[hba conf]:file:_files' \
  '(-s --stop)'{-s,--stop}'[stop server after init]' \
  '--extra-basebackup-args=[extra pg_basebackup arguments]:args:' \
  '-v[verbose]' && ret=0

return ret
