#compdef patscc patsopt
# Documentation: https://manpages.debian.org/testing/ats2-lang/patscc.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

case $service in
  (patsopt)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '--depgen[generate dependency lists]' \
      '--taggen[generate tagging information on syntactic entities]' \
      '(-tc --typecheck)'{-tc,--typecheck}'[typecheck only, go no further]' \
      '--gline[generate line pragma information in target code]' \
      '(-d --dynamic)'{-d+,--dynamic=}'[dynamically load the filenames]:file:_files' \
      '(-s --static)'{-s+,--static=}'[statically load the filenames]:file:_files' \
      '(-o --output)'{-o+,--output=}'[specify output filename]:file:_files' \
      '*: :_files -g "*.(dats|sats|cats|hats)"' && ret=0 ;;
  (patscc)
    _arguments -C \
      '(- *)'{-h,--help}'[show help]' \
      '(--version -vats)'{--version,-vats}'[show version]' \
      '(-tcats --typecheck)'{-tcats,--typecheck}'[typecheck without compilation]' \
      '(-ccats --compile)'{-ccats,--compile}'[compile ATS to C files only]' \
      '-cleanaft[remove generated C files after compilation]' \
      '-o+[output file]:file:_files' \
      '*-IATS+[add path to search for ATS files]:dir:_files -/' \
      '*-IIATS+[add path passed to ATS and C compiler]:dir:_files -/' \
      '*-DATS+[define ATS macro]:name[=value]:' \
      '*-DDATS+[define macro for ATS and C]:name[=value]:' \
      '-fsats+[specify SATS file explicitly]:file:_files -g "*.sats"' \
      '-fdats+[specify DATS file explicitly]:file:_files -g "*.dats"' \
      '*-I+[C include]:dir:_files -/' \
      '*-L+[C lib path]:dir:_files -/' \
      '*-l+[C library]:lib:' \
      '*-D+[C define]:macro:' \
      '-O+[optimize level]:lvl:(0 1 2 3 s)' \
      '-g[debug info]' \
      '--gline[generate line pragma information]' \
      '-DATS_MEMALLOC_LIBC[use libc malloc]' \
      '-DATS_MEMALLOC_GCBDW[use Boehm GC]' \
      '-atsccomp+[name of C compiler]:cc:_command_names -e' \
      '*: :_files -g "*.(dats|sats|cats|c|o)"' && ret=0 ;;
esac

return ret
