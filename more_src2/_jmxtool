#compdef jmxtool
# Documentation: https://github.com/apache/cassandra/blob/trunk/src/java/org/apache/cassandra/tools/JMXTool.java
# Reference accessed: 2026-05-19
# Verified: upstream Cassandra JMXTool source at the URL above.

# Cassandra JMXTool. Corrected from prior file: removed the invented
# "help" subcommand (only dump and diff exist); added each
# subcommand's real options from the airline @Command definitions.
local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'dump:dump the Apache Cassandra JMX objects and metadata'
  'diff:diff two jmx dump files and report their differences'
)

_arguments -C \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'jmxtool subcommand' subcommands && ret=0
    ;;
  (args)
    case $words[1] in
      dump)
        _arguments \
          '(-u --url)'{-u,--url}'+[JMX service URL]:url:' \
          '(-f --format)'{-f,--format}'+[output format]:format:(console json yaml)' && ret=0
        ;;
      diff)
        _arguments \
          '(-f --format)'{-f,--format}'+[file format]:format:(json yaml)' \
          '--ignore-missing-on-left[exclude left-side missing results]' \
          '--ignore-missing-on-right[exclude right-side missing results]' \
          '*--exclude-object=[exclude objects matching pattern]:pattern:' \
          '*--exclude-attribute=[exclude attributes matching pattern]:pattern:' \
          '*--exclude-operation=[exclude operations matching pattern]:pattern:' \
          '*:dump file:_files' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
