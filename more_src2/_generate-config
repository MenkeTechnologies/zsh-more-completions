#compdef generate-config
# _generate-config — generate a Dendrite homeserver config (element-hq/dendrite)
# upstream: https://github.com/element-hq/dendrite
# Flags from cmd/generate-config/main.go.

_generate-config() {
    _arguments \
        '-ci[populate config with sane CI defaults]' \
        '-server=[server domain name (not localhost)]:name:' \
        '-db=[PostgreSQL DB URI for all components]:uri:' \
        '-dir=[folder for paths (SQLite DBs, media)]:dir:_files -/' \
        '-normalise=[normalise existing config file]:file:_files -g "*.{yml,yaml}"'
}

_generate-config "$@"
