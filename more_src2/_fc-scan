#compdef fc-scan
# Documentation: fc-scan --help (fontconfig)
# Source: fontconfig fc-scan — scan font files and directories, and print resulting pattern(s).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-b --brief)'{-b,--brief}'[display font pattern briefly]' \
    '(-f --format)'{-f,--format=}'[output format string]:format:' \
    '(-y --sysroot)'{-y,--sysroot=}'[prepend SYSROOT to all paths]:sysroot:_files -/' \
    '(- *)'{-V,--version}'[display fontconfig version and exit]' \
    '(- *)'{-h,--help}'[display help and exit]' \
    '*:font file or directory:_files' \
    && ret=0

return ret
