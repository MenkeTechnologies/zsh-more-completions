#compdef dupl
# Documentation: https://github.com/mibk/dupl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dupl - Go code clone detection tool

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-files[read file names from stdin (one per line)]' \
  '-html[output results as HTML including duplicate fragments]' \
  '-plumbing[easy-to-parse output for scripts/tools]' \
  '-t+[minimum token sequence size for clones (default 100)]:n:' \
  '-threshold+[minimum token sequence size for clones (default 100)]:n:' \
  '-vendor[check files in vendor directory]' \
  '-v[explain what is being done]' \
  '-verbose[explain what is being done]' \
  '*: :_files' && ret=0

return ret
