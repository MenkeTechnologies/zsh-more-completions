#compdef dirmerge
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dirmerge.html
# Source: MRtrix3/mrtrix3 cmd/dirmerge.cpp — merge directions per b-value into one set (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-unipolar_weight+[unipolar repulsion weighting]:value:_default' \
    '1:subsets (per b-value):_default' \
    '*:b-value followed by direction files; last arg is output:_files' \
    && ret=0

return ret
