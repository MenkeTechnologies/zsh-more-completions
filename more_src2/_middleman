#compdef middleman
# _middleman — Middleman Ruby static site generator; Sinatra-like routes that render to flat HTML
# upstream: https://github.com/middleman/middleman

_middleman() {
    local -a sub=(
        'init:create new project'
        'build:build site to ./build'
        'server:run dev server'
        'config:show resolved config'
        'console:open IRB with site loaded'
        'deploy:deploy site (with middleman-deploy)'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'middleman subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '(-c --clean)'{-c,--clean}'[remove orphaned files]' \
                    '(-g --glob)'{-g,--glob}'+[only build glob]:glob:' \
                    '(-V --verbose)'{-V,--verbose}'[verbose]' \
                    '(-p --parallel)'{-p,--parallel}'[parallel build]' \
                    '--no-parallel[disable parallel build]' \
                    '(-i --instrument)'{-i,--instrument}'+[instrument]:section:' \
                    '--bail[abort on first failure]' ;;
                server) _arguments \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-o --bind)'{-o,--bind}'+[bind address]:host:_hosts' \
                    '--https[serve over HTTPS]' \
                    '--ssl-certificate+[ssl cert]:file:_files' \
                    '--ssl-private-key+[ssl key]:file:_files' \
                    '--environment+[env]:env:' \
                    '(-d --daemon)'{-d,--daemon}'[run as daemon]' \
                    '--force-polling[use polling watcher]' \
                    '--latency+[poll latency]:n:' ;;
                init) _arguments \
                    '(-T --template)'{-T,--template}'+[template]:template:' \
                    '1:dir:_files -/' ;;
            esac
            ;;
    esac
}

_middleman "$@"
