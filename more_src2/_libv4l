#compdef libv4l libv4l-config libv4l-version
# _libv4l — Linux v4l-utils libv4l helper CLI for the v4l user-space library reporting build flags include paths supported format conversion encoder decoder plugin metadata supported devices (linuxtv team, C); getopt
# upstream: https://git.linuxtv.org/v4l-utils.git

_libv4l() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--prefix[show install prefix]' \
        '--libdir[show lib dir]' \
        '--includedir[show include dir]' \
        '--datarootdir[show data root dir]' \
        '--cflags[show CFLAGS]' \
        '--libs[show LIBS]' \
        '--libversion[library version]' \
        '--has-libv4l1[has libv4l1]' \
        '--has-libv4l2[has libv4l2]' \
        '--has-libv4lconvert[has libv4lconvert]' \
        '--list-plugins[list plugins]' \
        '--list-formats[list supported formats]' \
        '--plugin-path[show plugin path]'
}

_libv4l "$@"
