#compdef lldb-dap
# Documentation: https://lldb.llvm.org/use/lldb-dap.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (also verified locally via lldb-dap --help).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--connection=[communicate over the specified connection URI]:uri:' \
  '*-c+[command to run before initialization]:command:' \
  '*--pre-init-command=[command to run before initialization]:command:' \
  '--repl-mode=[REPL evaluation mode]:mode:(variable command auto)' \
  '--launch-target=[program to launch for launchInTerminal request]:program:_files' \
  '--comm-file=[fifo file for launch-target communication]:file:_files' \
  '--debugger-pid=[PID of lldb-dap that sent launchInTerminal]:pid:_pids' \
  '-g[pause the program at startup]' \
  '--wait-for-debugger[pause the program at startup]' && ret=0

return ret
