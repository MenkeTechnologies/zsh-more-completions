#compdef provider-helm crossplane-provider-helm
# _provider-helm — Crossplane Helm provider (manages Release CRs via the Helm client)
# upstream: https://github.com/crossplane-contrib/provider-helm
# Flags from cmd/provider/main.go on tip (alecthomas/kingpin/v2 + DefaultEnvars).

_provider-helm() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-d --debug)'{-d,--debug}'[run with debug logging]' \
        '(-l --leader-election)'{-l,--leader-election}'[enable leader election (LEADER_ELECTION env var)]' \
        '--timeout=[max duration a Helm command may run before being killed]:duration:' \
        '(-s --sync)'{-s,--sync}'=[drift-detection sync period]:duration:' \
        '--poll=[per-resource drift-check poll interval]:duration:' \
        '--poll-state-metric=[state-metric recording interval]:duration:' \
        '--max-reconcile-rate=[global max rate (per second) of drift checks]:n:' \
        '--enable-management-policies=[enable Management Policies (ENABLE_MANAGEMENT_POLICIES env var)]:bool:(true false)' \
        '--enable-changelogs=[capture change logs during reconciliation (ENABLE_CHANGE_LOGS env var)]:bool:(true false)'
}

_provider-helm "$@"
