#compdef phpmd-cli
# _phpmd-cli — Manuel Pichler PHPMD PHP mess detector CLI alias (phpmd team, PHP); custom argparse
# upstream: https://github.com/phpmd/phpmd

_phpmd-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--minimumpriority=+[priority]:n:(1 2 3 4 5)' \
        '--reportfile=+[report file]:file:_files' \
        '--reportfile-html=+[html report file]:file:_files' \
        '--reportfile-text=+[text report file]:file:_files' \
        '--reportfile-xml=+[xml report file]:file:_files' \
        '--reportfile-json=+[json report file]:file:_files' \
        '--reportfile-sarif=+[sarif report file]:file:_files' \
        '--reportfile-checkstyle=+[checkstyle report file]:file:_files' \
        '--reportfile-github=+[github report file]:file:_files' \
        '--reportfile-ansi=+[ansi report file]:file:_files' \
        '--reportfile-baseline=+[baseline file]:file:_files' \
        '--baseline-file=+[baseline file]:file:_files' \
        '--generate-baseline[generate baseline]' \
        '--update-baseline[update baseline]' \
        '--cache[enable cache]' \
        '--cache-file=+[cache file]:file:_files' \
        '--cache-strategy=+[strategy]:s:(content timestamp)' \
        '--suffixes=+[suffixes]:str:' \
        '--exclude=+[paths]:str:' \
        '--strict[strict mode]' \
        '--ignore-violations-on-exit[ignore violations on exit]' \
        '--ignore-errors-on-exit[ignore errors on exit]' \
        '--color[force color]' \
        '--extra-line-in-excerpt=+[lines]:n:' \
        '1:filename or directory:_files' \
        '2:report format:(xml html text json sarif checkstyle github ansi baseline)' \
        '3:ruleset:(codesize cleancode controversial design naming unusedcode)'
}

_phpmd-cli "$@"
