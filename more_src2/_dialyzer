#compdef dialyzer
# Documentation: dialyzer --help
# Source: Erlang/OTP Dialyzer — static analyzer for Erlang BEAM / source.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-c --com)*'{-c,--com=}'[files to analyze (legacy)]:files:_files' \
    '*-r+[recurse into directory]:dir:_files -/' \
    '--input_list_file=[file listing inputs (one per line)]:file:_files' \
    '*--apps[refer to OTP applications or files]:apps:' \
    '(-o --output)'{-o,--output=}'[output file (default stdout)]:file:_files' \
    '--raw[output raw Erlang terms]' \
    '--src[analyze Erlang source instead of BEAM]' \
    '*-D+[preprocessor define]:NAME[=VALUE]:' \
    '*-I+[include directory]:dir:_files -/' \
    '*-pa+[Erlang code path]:dir:_files -/' \
    '--output_plt=[store PLT to file]:file:_files' \
    '*--plt=[initial PLT]:file:_files' \
    '*--plts[merge several PLTs]:files:_files' \
    '*-W+[selectively enable warning]:warning:(no_return no_unused no_improper_lists no_fun_app no_match no_opaque no_fail_call no_contracts no_behaviours no_undefined_callbacks no_unknown unmatched_returns error_handling underspecs specdiffs overspecs extra_return missing_return unmatched_returns)' \
    '(- *)'{-v,--version}'[print version]' \
    '(- *)'{-h,--help}'[show help]' \
    '(-q --quiet --verbose)'{-q,--quiet}'[less output]' \
    '(-q --quiet --verbose)--verbose[more output]' \
    '--statistics[print statistics]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--build_plt[build a PLT]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--add_to_plt[append to existing PLT]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--remove_from_plt[remove from PLT]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--check_plt[verify PLT consistency]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--no_check_plt[skip PLT consistency check]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--incremental[incremental analysis]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--plt_info[show PLT information]' \
    '(--build_plt --add_to_plt --remove_from_plt --check_plt --no_check_plt --incremental --plt_info --get_warnings)--get_warnings[get warnings from PLT]' \
    '--dump_callgraph=[dump callgraph to file]:file:_files' \
    '--dump_full_dependencies_graph=[dump module-deps graph]:file:_files' \
    '--error_location=[error location format]:format:(line column)' \
    '--fullpath[show full path of source files]' \
    '--no_indentation[no indentation in output]' \
    '--metrics_file=[write metrics file]:file:_files' \
    '*--warning_apps[warn only for these apps]:apps:' \
    '-n[non-interactive mode]' \
    '*:Erlang file or directory:_files -g "*.{erl,beam}"' \
    && ret=0

return ret
