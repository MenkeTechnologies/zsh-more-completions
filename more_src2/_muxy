#compdef muxy
# ============================================================================
#  _muxy — Muxy: chaos engineering tool for simulating real-world
#          distributed system failures
#
#  Source-direct extraction from
#    https://github.com/mefellows/muxy/blob/master/main.go
#    https://github.com/mefellows/muxy/blob/master/command/{commands,proxy}.go
#    https://github.com/mitchellh/cli (the mitchellh/cli library)
#
#  Authored by Matt Fellows (mefellows/muxy).  829 GH stars.  Muxy
#  injects deterministic failures into HTTP/TCP traffic — latency,
#  bandwidth limits, packet loss, malformed responses, slow body
#  streaming, etc.  Used in chaos engineering pipelines to validate
#  distributed system resilience.  Sister tools: chaos-mesh
#  (Kubernetes chaos engineering, in corpus), pumba (Docker chaos,
#  in corpus), toxiproxy (Shopify TCP chaos proxy).
#
#  CLI library taxonomy update: 9th Go CLI library — mitchellh/cli.
#  Go ecosystem now has 9 documented CLI libraries (cobra/urfave-cli/
#  kingpin/spf13-pflag/alecthomas-kong/alexflint-go-arg/integrii-flaggy/
#  jessevdk-go-flags/mitchellh-cli) — extends Go's documented-CLI-
#  library lead to TIE with Rust 9.  mitchellh/cli is Mitchell Hashimoto's
#  (HashiCorp co-founder) Go CLI library — used by HashiCorp Consul,
#  Vault, Terraform, Packer, Boundary, Nomad, and many others.  ~1600
#  GH stars on mitchellh/cli.
#
#  mitchellh/cli is fundamentally different from cobra/kong/go-arg:
#    - INTERFACE-BASED — each subcommand is a STRUCT IMPLEMENTING
#      `cli.Command` interface with 3 methods:
#        Run(args []string) int       // handler returning exit code
#        Help() string                // detailed help text
#        Synopsis() string            // one-line synopsis
#    - SUBCOMMAND DISPATCH via `map[string]cli.CommandFactory` where
#      `CommandFactory` is `func() (cli.Command, error)` — caller maps
#      subcommand names to factory functions
#    - EACH COMMAND uses standard `flag` package internally — mitchellh/
#      cli does NOT provide its own flag parsing, only subcommand
#      dispatch + help system + UI abstraction
#    - UI ABSTRACTION via `cli.Ui` interface (BasicUi/ColoredUi/MockUi)
#      for output/error/info channels with color support
#    - HELP TEXT IS HAND-WRITTEN per command via `Help()` method —
#      mitchellh/cli does NOT auto-generate help from a spec; caller
#      writes the help text themselves
#  Distinct from R275 clap-derive (Rust struct + macro), R334 kong
#  (Go struct tags), R342 alexflint/go-arg (Go struct tags), R350
#  integrii/flaggy (pointer-based imperative builder), R354 jessevdk/
#  go-flags (Go struct tags), R341 yargs (TS fluent builder), R340
#  oclif (TS class-inheritance with static fields).  mitchellh/cli's
#  approach: INTERFACE-BASED with INTERFACE METHODS implementing
#  commands, leaving flag parsing to standard `flag` package — corpus's
#  **first documented interface-based-with-stdlib-flag-delegation CLI
#  pattern**.  Brings cross-language CLI library taxonomy variant
#  count to 96; Go ecosystem now has 9 documented CLI libraries.
#
#  Surface (verbatim from main.go + command/proxy.go):
#
#  Subcommands:
#    proxy                       Run the Muxy proxy
#      --config FILE             Path to a YAML configuration file
#    pki                         PKI utilities (from mefellows/pkigo)
#
#  Standard mitchellh/cli auto-added flags (handled by `cli.Run()`):
#    --help                      Show CLI usage / per-command help
#    --version                   Show muxy version
#
#  Configuration:
#    muxy.yml                    Default YAML config in working directory
#                                — declares middleware chain, protocol
#                                listeners, symptoms (chaos injections)
#
#  Dup-skipped neighbors during hunt (already in corpus or smaller):
#    - consul, vault, terraform, packer, boundary, nomad (all HashiCorp
#      tools — IN CORPUS, all use mitchellh/cli but already documented)
#    - spire-agent, spire-server (spiffe/spire — IN CORPUS)
#    - kite (koding/kite 3258 stars — uses mitchellh/cli, but `kite`
#      binary's surface is mostly micro-service framework registration
#      not user-facing CLI; HOLD for future round)
#    - krab (ohkrab/krab 21 stars Postgres migration tool — narrow)
# ============================================================================

_muxy() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '--help[show CLI usage]' \
    '--version[show muxy version]' \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'proxy:run the Muxy chaos-injection proxy'
        'pki:PKI utilities (from pkigo)'
      )
      _describe -t commands 'muxy subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        proxy)
          _arguments -s -S \
            '--config=[path to YAML configuration file]:config:_files -g "*.{yml,yaml}"'
          ;;
        pki)
          _message 'pki subcommand args'
          ;;
      esac
      ;;
  esac
}

_muxy "$@"
