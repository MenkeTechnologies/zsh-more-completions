#compdef phrase
# Documentation: https://github.com/phrase/phrase-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# phrase/phrase-cli (cobra) — persistent flags `cmd/root.go`; subcommands include REST groups + pull/push/init

local curcontext="$curcontext" ret=1 expl

_arguments -C \
  '(-h)'{-h,--help}'[help]' \
  '(-v)'{-v,--verbose}'[verbose API messages]' \
  '--host=[override API host]:host:' \
  '(-t)'{-t,--access_token=}'[API access token]:token:' \
  '(-u)'{-u,--username=}'[username]:username:' \
  '--tfa[two-factor authentication]' \
  '(-B)'{-B,--batch}'[batch: JSON only, no prompts]' \
  '--config=[config file]:config:_files' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
cmd)
  _wanted commands expl 'phrase command' compadd -- accounts authorizations automations blacklisted_keys branches \
    comment_reactions comment_replies comments completion custom_metadata distributions documents figma_attachments \
    formats glossaries glossary_term_translations glossary_terms icu info init invitations job_annotations \
    job_comments job_locales job_template_locales job_templates jobs keys keys_figma_attachments linked_keys \
    locale_downloads locales members notification_groups notifications orders organization_job_template_locales \
    organization_job_templates projects pull push quality_performance_score release_triggers releases \
    repo_sync_events repo_syncs reports screenshot_markers screenshots search spaces style_guides tags teams \
    translations upload_batches upload_cleanup uploads users variables version versions_history webhook_deliveries webhooks
  ;;
rest)
  case $line[1] in
    pull)
      _arguments \
        '(-b)'{-b+,--branch=}'[phrase branch]:branch:' \
        '--use-local-branch-name[use checked-out VCS branch name]' \
        '(-a)'{-a,--async}'[async locale downloads]' \
        '--cache[cache ETags (sync mode)]' \
        '(-p)'{-p,--parallel}'[parallel downloads (max 4)]' \
        '*:: :_default' && ret=0
      ;;
    push)
      _arguments \
        '(-w)'{-w,--wait}'[wait for processing]' \
        '(-c)'{-c,--cleanup}'[delete keys absent from uploads]' \
        '(-b)'{-b+,--branch=}'[branch]:branch:' \
        '--use-local-branch-name[use checked-out VCS branch name]' \
        '--tag=[tag uploaded keys]:tag:' \
        '*:: :_default' && ret=0
      ;;
    *)
      _normal && ret=0
      ;;
  esac
  ;;
esac

return ret
