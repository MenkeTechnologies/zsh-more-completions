#compdef git-ssh
# Documentation: https://github.com/lemarsu/git-ssh
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# git-ssh is a server-side proxy invoked from SSH authorized_keys; it is
# not a user-facing CLI, but completion handles its single -r flag.

_arguments -s -S \
  '-r[chroot repositories under directory]:directory:_files -/' \
  '*::args:_default' && return 0
