#compdef papermill
# Documentation: https://papermill.readthedocs.io/en/latest/reference/papermill-cli.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for papermill - Jupyter notebook execution

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--help-notebook[display parameters info for input notebook]' \
  '*'{-p,--parameters}'[set a parameter]:name:: :_files' \
  '*'{-r,--parameters_raw}'[set a raw string parameter]:name:: :_files' \
  '*'{-f,--parameters_file}'[path to parameters YAML file]:file:_files' \
  '*'{-y,--parameters_yaml}'[YAML string of parameters]:yaml:' \
  '*'{-b,--parameters_base64}'[base64-encoded YAML parameters]:base64:' \
  '--inject-input-path[insert input path as parameter]' \
  '--inject-output-path[insert output path as parameter]' \
  '--inject-paths[insert both input and output paths as parameters]' \
  '--engine=[execution engine]:engine:' \
  '--prepare-only[prepare notebook but do not execute]' \
  '--prepare-execute[prepare and execute notebook (default)]' \
  '(-k --kernel)'{-k+,--kernel=}'[kernel name]:kernel:' \
  '(-l --language)'{-l+,--language=}'[override cell language]:language:' \
  '--cwd=[working directory for notebook execution]:dir:_directories' \
  '--progress-bar[show progress bar]' \
  '--no-progress-bar[hide progress bar]' \
  '--log-output[log notebook output]' \
  '--no-log-output[do not log notebook output]' \
  '--stdout-file=[write stdout to file]:file:_files' \
  '--stderr-file=[write stderr to file]:file:_files' \
  '--log-level=[set log level]:level:(NOTSET DEBUG INFO WARNING ERROR CRITICAL)' \
  '--report-mode[hide parameters and injected-parameters cells]' \
  '--no-report-mode[disable hiding of parameters cell]' \
  '--start_timeout=[cell start timeout in seconds]:seconds:' \
  '--execution-timeout=[cell execution timeout in seconds]:seconds:' \
  '--request-save-on-cell-execute[save notebook on each cell execution]' \
  '--no-request-save-on-cell-execute[do not save notebook on each cell execution]' \
  '--autosave-cell-every=[autosave every N seconds]:seconds:' \
  '1:input notebook:_files -g "*.ipynb"' \
  '2:output notebook:_files -g "*.ipynb"' \
  && return 0
