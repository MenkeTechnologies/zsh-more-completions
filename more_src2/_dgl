#compdef dgl dgl-cli dgl-bench dgl-partition
# _dgl — Deep Graph Library DGL graph neural network framework for PyTorch TensorFlow JAX MXNet (dmlc team, Python); argparse
# upstream: https://github.com/dmlc/dgl

_dgl() {
    local -a sub=(
        'train:train a GNN model'
        'evaluate:evaluate a model'
        'predict:run inference'
        'partition:partition a graph for distributed'
        'serve:serve a GNN model'
        'preprocess:preprocess a dataset'
        'export:export model'
        'convert:convert graph formats'
        'sampler:sampler subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--backend=+[backend]:b:(pytorch tensorflow mxnet jax)' \
        '--device=+[device]:d:(cpu cuda mps auto)' \
        '--gpus=+[gpu ids csv]:str:' \
        '--num-workers=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '--debug[debug logging]' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dgl subcommand' sub ;;
        args)
            case $words[1] in
                train|evaluate|predict) _arguments \
                    '--config=+[config file]:file:_files -g "*.yaml *.yml *.json"' \
                    '--dataset=+[dataset]:d:(cora citeseer pubmed ogbn-arxiv ogbn-mag ogbn-papers100M ogbn-products ogbn-proteins reddit ppi karate amazon enwiki bgl)' \
                    '--model=+[model]:m:(GCN GAT SAGE GIN APPNP MoNet HGT RGCN PGNN PinSAGE)' \
                    '--num-epochs=+[N]:n:' \
                    '--batch-size=+[N]:n:' \
                    '--learning-rate=+[F]:f:' \
                    '--weight-decay=+[F]:f:' \
                    '--hidden-size=+[N]:n:' \
                    '--num-layers=+[N]:n:' \
                    '--dropout=+[F]:f:' \
                    '--checkpoint-dir=+[dir]:dir:_files -/' \
                    '--output=+[output file]:file:_files' ;;
                partition) _arguments \
                    '--dataset=+[dataset]:str:' \
                    '--num-parts=+[N]:n:' \
                    '--out-dir=+[output dir]:dir:_files -/' \
                    '--balance-train[balance train]' \
                    '--balance-edges[balance edges]' \
                    '--method=+[method]:m:(metis random)' ;;
                serve) _arguments \
                    '--model-path=+[path]:file:_files' \
                    '--port=+[port]:port:_ports' \
                    '--host=+[host]:host:_hosts' \
                    '--workers=+[N]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_dgl "$@"
