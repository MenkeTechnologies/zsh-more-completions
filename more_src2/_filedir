#compdef filedir
# _filedir — print the directory portion of a file path (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from filedir.c (single-letter getopt-style).

_filedir() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-z[drop trailing newline (for scripting)]' \
        '*:file path:_files'
}

_filedir "$@"
