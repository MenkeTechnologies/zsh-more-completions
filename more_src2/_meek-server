#compdef meek-server
# Documentation: https://gitlab.torproject.org/tpo/anti-censorship/pluggable-transports/meek
# Reference accessed: 2026-05-19
# Verified: upstream meek-server.go source. Flags defined in source: -cert,
# -key, -log, -port, -disable-tls. ACME and -state placeholders from the
# prior file are not in current upstream and were removed.

# meek-server: Tor pluggable transport server for meek
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-port=[listen port]:port:' \
  '-cert=[TLS certificate file]:file:_files' \
  '-key=[TLS private key file]:file:_files' \
  '-disable-tls[do not use HTTPS]' \
  '-log=[log file]:file:_files' \
  '*::meek-server args:_files' && ret=0
return ret
