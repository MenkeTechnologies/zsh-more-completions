#compdef mfsdeleattr
# Documentation: https://moosefs.com/manpages/mfsdeleattr
# Reference accessed: 2026-05-19
# Verified: upstream MooseFS man page at the URL above.
# mfsdeleattr: delete extra (MooseFS) attributes from objects.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-?[display short usage message]' \
  '-r[delete recursively]' \
  '(-h -H -k -m -g)-n[print exact numbers]' \
  '(-n -H -k -m -g)-h[use binary prefixes (Ki, Mi, Gi)]' \
  '(-n -h -k -m -g)-H[use SI prefixes (k, M, G)]' \
  '(-n -h -H -m -g)-k[print sizes in kibis]' \
  '(-n -h -H -k -g)-m[print sizes in mebis]' \
  '(-n -h -H -k -m)-g[print sizes in gibis]' \
  '(-f)-a[delete all extra attributes]' \
  '(-a)*-f+[attribute name to delete (repeatable)]:attribute:' \
  '*:object:_files' && ret=0
return ret
