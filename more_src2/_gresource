#compdef gresource
# _gresource — GLib gresource (introspect compiled GResource bundles (.gresource files or ELF binaries embedding them); list/sections/details/extract subcommands; positional file is a binary or .gresource)
# upstream: https://gitlab.gnome.org/GNOME/glib (gio/gresource-tool.c)
# Subcommands from glib gio/gresource-tool.c on tip.

_gresource() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'gresource command' '(help sections list details extract)' ;;
        args) _arguments '1:file:_files' '2:resource path:' ;;
    esac
}

_gresource "$@"
