#compdef ntpd
# _ntpd — ntp-project ntpd (NTPv4 daemon; full reference implementation of NTP for synchronizing system clocks, supports symmetric keys + Autokey + multicast + manycast)
# upstream: https://github.com/ntp-project/ntp
# Flags from ntpd/ntpd-opts.def + ntpdbase-opts.def on tip (AutoOpts); positional args are upstream server hostnames.

_ntpd() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(- *)--version[show version and exit]' \
        '(-4 --ipv4 -6 --ipv6)'{-4,--ipv4}'[force IPv4 DNS resolution]' \
        '(-4 --ipv4 -6 --ipv6)'{-6,--ipv6}'[force IPv6 DNS resolution]' \
        '(-a --authreq -A --authnoreq)'{-a,--authreq}'[require crypto authentication]' \
        '(-a --authreq -A --authnoreq)'{-A,--authnoreq}'[do not require crypto authentication]' \
        '(-b --bcastsync)'{-b,--bcastsync}'[sync to broadcast servers]' \
        '(-c --configfile)'{-c+,--configfile=}'[configuration file]:file:_files' \
        '(-d --debug-level)'{-d+,--debug-level=}'[increment debug level]:n:' \
        '(-D --set-debug-level)'{-D+,--set-debug-level=}'[set debug level]:n:' \
        '(-f --driftfile)'{-f+,--driftfile=}'[frequency drift file]:file:_files' \
        '(-g --panicgate)'{-g,--panicgate}'[allow first adjustment to be big]' \
        '(-G --force_step_once)'{-G,--force_step_once}'[step any initial offset]' \
        '(-i --jaildir)'{-i+,--jaildir=}'[jail/chroot directory]:dir:_files -/' \
        '*'{-I+,--interface=}'[listen on interface (repeatable)]:iface:_net_interfaces' \
        '(-k --keyfile)'{-k+,--keyfile=}'[symmetric key file]:file:_files' \
        '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
        '(-L --novirtualips)'{-L,--novirtualips}'[do not listen on virtual interfaces]' \
        '(-n --nofork)'{-n,--nofork}'[do not fork]' \
        '(-N --nice)'{-N,--nice}'[run at high priority]' \
        '(-p --pidfile)'{-p+,--pidfile=}'[PID file path]:file:_files' \
        '(-P --priority)'{-P+,--priority=}'[process priority]:n:' \
        '(-q --quit)'{-q,--quit}'[set the time and quit]' \
        '(-r --propagationdelay)'{-r+,--propagationdelay=}'[broadcast/propagation delay]:sec:' \
        '--saveconfigquit=[save parsed configuration and quit]:file:_files' \
        '(-s --statsdir)'{-s+,--statsdir=}'[statistics file directory]:dir:_files -/' \
        '*'{-t+,--trustedkey=}'[trusted key number (repeatable)]:n:' \
        '(-u --user)'{-u+,--user=}'[run as user[:group]]:user:_users' \
        '(-U --updateinterval)'{-U+,--updateinterval=}'[interface scan interval (sec)]:sec:' \
        '*--var=[RW NTP variable]:var:' \
        '*--dvar=[RW|DEF NTP variable]:var:' \
        '(-x --slew)'{-x,--slew}'[slew up to 600 seconds]' \
        '*--mdns[register with mDNS as an NTP server]' \
        '*:server:_hosts'
}

_ntpd "$@"
