#compdef frps-cli frpsctl
# _frps-cli — fatedier frps-cli CLI command-line frontend to the FRP fast reverse proxy server frps providing tunneling internal services to public hosts via TCP UDP HTTP HTTPS STCP XTCP WebSocket KCP-QUIC-protocol stcp-stcp-xtcp-tcpmux-multi-tunnel for the de-facto NAT traversal bidirectional-port-forwarding-publish (fatedier team, Go); pflag
# upstream: https://github.com/fatedier/frp

_frps-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "frps.ini frps.toml frps.yaml *.ini *.toml *.yaml"' \
        '--config=+[file]:file:_files -g "*.ini *.toml *.yaml"' \
        '--reload[reload config without exit]' \
        '--strict-config[strict config]' \
        '--bind-addr=+[host]:_hosts' \
        '--bind-port=+[port]:n:' \
        '--bind-udp-port=+[port]:n:' \
        '--kcp-bind-port=+[port]:n:' \
        '--quic-bind-port=+[port]:n:' \
        '--proxy-bind-addr=+[host]:_hosts' \
        '--vhost-http-port=+[port]:n:' \
        '--vhost-https-port=+[port]:n:' \
        '--vhost-http-timeout=+[sec]:n:' \
        '--dashboard-addr=+[host]:_hosts' \
        '--dashboard-port=+[port]:n:' \
        '--dashboard-user=+[user]:str:' \
        '--dashboard-pwd=+[password]:str:' \
        '--token=+[token]:str:' \
        '--subdomain-host=+[host]:_hosts' \
        '--log-file=+[file]:file:_files' \
        '--log-level=+[l]:l:(trace debug info warn error)' \
        '--log-max-days=+[N]:n:' \
        '--disable-log-color[disable log color]' \
        '--allow-ports=+[ports]:str:' \
        '--max-pool-count=+[N]:n:' \
        '--max-ports-per-client=+[N]:n:' \
        '--tls-only[require TLS]' \
        '--tls-cert-file=+[file]:file:_files' \
        '--tls-key-file=+[file]:file:_files' \
        '--tls-trusted-ca-file=+[file]:file:_files' \
        '--heartbeat-timeout=+[sec]:n:' \
        '--user-conn-timeout=+[sec]:n:' \
        '--enable-prometheus[enable prometheus]' \
        '*::'
}

_frps-cli "$@"
