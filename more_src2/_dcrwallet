#compdef dcrwallet
# _dcrwallet — Decred Project dcrwallet wallet daemon CLI for the hybrid PoW/PoS Decred reference daemon managing keys creating transactions ticket purchases vote choice live signing stakepool integration multi-account discovery rescan (decred team, Go); flag
# upstream: https://github.com/decred/dcrwallet

_dcrwallet() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-C+[config file]:file:_files -g "*.conf dcrwallet.conf"' \
        '--configfile=+[config file]:file:_files -g "*.conf dcrwallet.conf"' \
        '-A+[app data dir]:dir:_files -/' \
        '--appdata=+[app data dir]:dir:_files -/' \
        '--logdir=+[log dir]:dir:_files -/' \
        '--testnet[use testnet]' \
        '--simnet[use simnet]' \
        '--regnet[use regnet]' \
        '--noinitialload[no initial load]' \
        '--noseedback[no seed backup]' \
        '--nogrpc[disable gRPC]' \
        '--nolegacyrpc[disable legacy RPC]' \
        '--rpcconnect=+[host:port]:str:' \
        '-c+[host:port]:str:' \
        '--cafile=+[file]:file:_files -g "*.cert *.pem"' \
        '--username=+[user]:str:' \
        '-u+[user]:str:' \
        '--password=+[password]:str:' \
        '-P+[password]:str:' \
        '--grpclisten=+[host:port]:str:' \
        '--legacyrpclisten=+[host:port]:str:' \
        '--rpccert=+[file]:file:_files -g "*.cert *.pem"' \
        '--rpckey=+[file]:file:_files -g "*.key *.pem"' \
        '--enablevoting[enable voting]' \
        '--enableticketbuyer[enable ticket buyer]' \
        '--debuglevel=+[level]:l:(error warn info debug trace)' \
        '--reuseaddresses[reuse addresses]' \
        '--allowhighfees[allow high fees]' \
        '--purchaseaccount=+[account]:str:' \
        '--votingaccount=+[account]:str:' \
        '--stakepooladdrs=+[csv]:str:' \
        '--ticketsplit[ticket split]' \
        '--noratelimit[no rate limit]' \
        '--dbtimeout=+[d]:str:' \
        '--circuitbreaker[circuit breaker]' \
        '--manualtickets[manual tickets]' \
        '--mixingenabled[mixing enabled]' \
        '--csppserver=+[host:port]:str:' \
        '--mixedaccount=+[account]:str:' \
        '--changeaccount=+[account]:str:' \
        '--mixchange[mix change]'
}

_dcrwallet "$@"
