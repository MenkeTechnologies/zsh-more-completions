#compdef dbus-test-tool
# Documentation: man dbus-test-tool(1)
# Source: freedesktop/dbus tools/test-tool.c (master) — D-Bus traffic test utility (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a cmds=(
    'black-hole:receive messages and discard them'
    'echo:reply to method calls with the same payload'
    'spam:send messages as fast as possible'
)

_arguments -s -C \
    '1:subcommand:->cmd' \
    '*::cmd args:->cmdargs' \
    && ret=0

case $state in
    cmd) _describe -t commands 'dbus-test-tool subcommand' cmds && ret=0 ;;
    cmdargs)
        case $line[1] in
            black-hole|echo|spam)
                _arguments \
                    '(--session --system)--session[use session bus]' \
                    '(--session --system)--system[use system bus]' \
                    '(-h --help)'{-h,--help}'[show help]' \
                    '--name=[well-known name to claim]:name:_default' \
                    '--no-reply[do not reply to method calls]' \
                    '--ignore-errors[ignore errors]' \
                    '--seed=[random seed]:seed:_default' \
                    '--payload=[payload size in bytes]:bytes:_default' \
                    '--messages=[number of messages]:N:_default' \
                    '--queue=[outgoing queue size]:N:_default' ;;
        esac
        ;;
esac

return ret
