(( $+functions[_fxc__subcmd__init_commands] )) ||
_fxc__subcmd__init_commands() {
    local commands; commands=()
    _describe -t commands 'fxc init commands' commands "$@"
}
(( $+functions[_fxc__subcmd__status_commands] )) ||
_fxc__subcmd__status_commands() {
    local commands; commands=()
    _describe -t commands 'fxc status commands' commands "$@"
}
(( $+functions[_fxc__subcmd__sync_commands] )) ||
_fxc__subcmd__sync_commands() {
    local commands; commands=()
    _describe -t commands 'fxc sync commands' commands "$@"
}
(( $+functions[_fxc__subcmd__toolchain_commands] )) ||
_fxc__subcmd__toolchain_commands() {
