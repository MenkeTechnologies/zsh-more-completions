#compdef fxc
# Documentation: https://github.com/joelsa/fxc
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Source: cargo binstall fxc@0.1.0
# Probed via: completions zsh
# Note: there is also a Microsoft DirectX fxc.exe HLSL compiler with a different
# flag syntax (/T, /E, /Fo). This completion targets the Rust cross-compile tool.

autoload -U is-at-least

_fxc() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_fxc_commands" \
"*::: :->fxc" \
&& ret=0
    case $state in
    (fxc)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:fxc-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
'--target=[Sync only this target (default\: all targets)]:TARGET:_default' \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'--force[Rebuild even if sysroot is up-to-date]' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
'--target=[Clean only this target]:TARGET:_default' \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'--all[Remove all sysroots without confirmation]' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(toolchain)
_arguments "${_arguments_options[@]}" : \
'--target=[Target to get toolchain for (optional if only one target)]:TARGET:_default' \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'--config=[Path to fxc.toml (default\: search current and parent directories)]:CONFIG:_files' \
'--color=[Color output control]:COLOR:(auto always never)' \
'-q[Suppress progress output]' \
'--quiet[Suppress progress output]' \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Shell to generate completions for:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_fxc__subcmd__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:fxc-help-command-$line[1]:"
        case $line[1] in
            (init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(sync)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(clean)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(toolchain)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(status)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_fxc_commands] )) ||
_fxc_commands() {
    local commands; commands=(
'init:Create a new fxc.toml configuration file' \
'sync:Build or update sysroot(s) from fxc.toml' \
'clean:Remove sysroot(s) and generated files' \
'toolchain:Print path to CMake toolchain file' \
'status:Show state of all targets' \
'completions:Generate shell completions' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'fxc commands' commands "$@"
}
(( $+functions[_fxc__subcmd__clean_commands] )) ||
_fxc__subcmd__clean_commands() {
    local commands; commands=()
    _describe -t commands 'fxc clean commands' commands "$@"
}
(( $+functions[_fxc__subcmd__completions_commands] )) ||
_fxc__subcmd__completions_commands() {
