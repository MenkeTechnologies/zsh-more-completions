#compdef rspamd
# Documentation: https://github.com/rspamd/rspamd/blob/master/doc/rspamd.8.md
# Reference accessed: 2026-05-21
# Verified: source at https://raw.githubusercontent.com/rspamd/rspamd/master/src/rspamd.c

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f --no-fork)'{-f,--no-fork}'[do not daemonize main process]' \
  '(-c --config)'{-c+,--config=}'[config file(s)]:file:_files -g "*.conf"' \
  '(-u --user)'{-u+,--user=}'[user to run rspamd as]:user:_users' \
  '(-g --group)'{-g+,--group=}'[group to run rspamd as]:group:_groups' \
  '(-p --pid)'{-p+,--pid=}'[path to PID file]:file:_files' \
  '(-d --debug)'{-d,--debug}'[force debug output]' \
  '(-i --insecure)'{-i,--insecure}'[ignore running workers as privileged users]' \
  '--var=[override UCL variable]:var:' \
  '(-T --skip-template)'{-T,--skip-template}'[skip UCL templating]' \
  '*--lua-env=[lua environment file]:file:_files' \
  '*::extra:_files' && ret=0

return ret
