#compdef openobserve
# Documentation: https://openobserve.ai/docs/quickstart/
# Reference accessed: 2026-05-20
# Verified: `openobserve` is the server binary; configuration is via
# environment variables (ZO_ROOT_USER_EMAIL, ZO_ROOT_USER_PASSWORD, etc.),
# not CLI flags. The canonical OpenObserve CLI client is named `o2`, not
# `openobserve`.
# STUB: minimal completion retained per "do not delete files" directive.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*::passthrough:_command_names' && ret=0

return ret
