#compdef eu-elflint
# _eu-elflint-bin — elfutils ELF format checker (Ulrich Drepper, Red Hat); strict spec compliance for ELF files
# upstream: https://sourceware.org/elfutils

_eu-elflint-bin() {
    _arguments \
        '(-q --quiet)'{-q,--quiet}'[only diagnose]' \
        '(-d --debuginfo)'{-d,--debuginfo}'[debuginfo file]' \
        '--strict[strict spec checks]' \
        '--gnu-ld[GNU ld behavior accepted]' \
        '--gnu[same as --gnu-ld]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-elflint-bin "$@"
