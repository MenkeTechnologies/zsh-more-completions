#compdef iris
# Documentation: https://github.com/Moon9t/IRIS
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# IRIS language compiler / toolchain
local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help information]' \
  '(- *)'{-V,--version}'[display compiler version]' \
  '--emit=[control output format]:format:(ir llvm eval binary onnx cuda simd)' \
  '-o+[output file path]:output file:_files' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'build:compile to native binary'
      'run:compile and execute'
      'repl:launch interactive REPL'
      'lsp:start Language Server Protocol'
      'dap:start Debug Adapter Protocol'
      'pkg:package manager operations'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    case $line[1] in
      pkg)
        local -a pkgcmds=(
          'init:create project structure'
          'add:add dependency'
          'install:fetch dependencies'
          'build:build project'
          'run:build and run'
          'list:list dependencies'
        )
        _describe -t pkgcmds 'pkg command' pkgcmds && ret=0
        ;;
      *)
        _files -g '*.iris' && ret=0
        ;;
    esac
    ;;
esac

return ret
