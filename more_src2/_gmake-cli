#compdef gmake-cli
# _gmake-cli — GNU make rule-based build system CLI alias (GNU team, C); custom argparse
# upstream: https://savannah.gnu.org/projects/make/

_gmake-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-B[unconditionally make targets]' \
        '--always-make[unconditionally make targets]' \
        '-C+[directory]:dir:_files -/' \
        '--directory=+[directory]:dir:_files -/' \
        '-d[debug]' \
        '--debug[debug]' \
        '--debug=+[flags]:str:' \
        '-e[env overrides]' \
        '--environment-overrides[env overrides]' \
        '-E+[evaluate as makefile]:str:' \
        '--eval=+[evaluate as makefile]:str:' \
        '-f+[makefile]:file:_files -g "{Makefile,makefile,GNUmakefile,*.mk}"' \
        '--file=+[makefile]:file:_files -g "{Makefile,makefile,GNUmakefile,*.mk}"' \
        '--makefile=+[makefile]:file:_files -g "{Makefile,makefile,GNUmakefile,*.mk}"' \
        '-i[ignore errors]' \
        '--ignore-errors[ignore errors]' \
        '-I+[include dir]:dir:_files -/' \
        '--include-dir=+[include dir]:dir:_files -/' \
        '-j+[jobs]:n:' \
        '--jobs=+[jobs]:n:' \
        '-k[keep going]' \
        '--keep-going[keep going]' \
        '-l+[load average]:str:' \
        '--load-average=+[load average]:str:' \
        '--max-load=+[load average]:str:' \
        '-L[check symlink times]' \
        '--check-symlink-times[check symlink times]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '--recon[dry run]' \
        '--just-print[dry run]' \
        '-o+[old file]:file:_files' \
        '--old-file=+[old file]:file:_files' \
        '--assume-old=+[old file]:file:_files' \
        '-O+[output sync]:m:(none line target recurse)' \
        '--output-sync=+[output sync]:m:(none line target recurse)' \
        '-p[print database]' \
        '--print-data-base[print database]' \
        '-q[question mode]' \
        '--question[question mode]' \
        '-r[no builtin rules]' \
        '--no-builtin-rules[no builtin rules]' \
        '-R[no builtin variables]' \
        '--no-builtin-variables[no builtin variables]' \
        '-s[silent]' \
        '--silent[silent]' \
        '--quiet[silent]' \
        '-S[no keep going]' \
        '--no-keep-going[no keep going]' \
        '--stop[no keep going]' \
        '-t[touch]' \
        '--touch[touch]' \
        '--trace[trace]' \
        '-w[print working directory]' \
        '--print-directory[print working directory]' \
        '--no-print-directory[no print working directory]' \
        '-W+[new file]:file:_files' \
        '--what-if=+[new file]:file:_files' \
        '--new-file=+[new file]:file:_files' \
        '--assume-new=+[new file]:file:_files' \
        '--warn-undefined-variables[warn undefined vars]' \
        '*:targets:'
}

_gmake-cli "$@"
