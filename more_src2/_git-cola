#compdef git-cola
# _git-cola — Git Cola sleek Git GUI client CLI (David Aguilar / Git Cola team, Python); custom argparse
# upstream: https://github.com/git-cola/git-cola

_git-cola() {
    local -a sub=(
        'am:amend interactive'
        'archive:create archive'
        'branch:browse branches'
        'browse:browse repository'
        'classic:run classic Git Cola'
        'clone:clone repository'
        'config:edit configuration'
        'dag:show DAG visualizer'
        'diff:show diff GUI'
        'fetch:fetch GUI'
        'find:find file'
        'grep:grep GUI'
        'merge:merge GUI'
        'pull:pull GUI'
        'push:push GUI'
        'rebase:rebase GUI'
        'recent:open recent repository'
        'remote:edit remotes'
        'search:search GUI'
        'stash:stash GUI'
        'tag:tag GUI'
        'view:view a commit'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--repo=+[repo path]:dir:_files -/' \
        '-r+[repo path]:dir:_files -/' \
        '--prompt[prompt for repo]' \
        '-p[prompt for repo]' \
        '--icon-theme=+[icon theme]:t:(default dark light system)' \
        '--theme=+[theme]:str:' \
        '--style=+[style]:str:' \
        '--font-size=+[font size]:n:' \
        '--git=+[git binary]:file:_files' \
        '--config=+[config file]:file:_files' \
        '--cwd=+[change to dir]:dir:_files -/' \
        '--debug[debug]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'git-cola subcommand' sub ;;
        args)
            case $words[1] in
                clone) _arguments '*:url:_urls' ;;
                view|diff) _arguments '*:commit:' ;;
                browse|dag|find|grep|remote|search|stash|tag|merge|rebase|pull|push|fetch) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_git-cola "$@"
