#compdef gcli
# Documentation: https://herrhotzenplotz.de/gcli/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gcli: multi-forge Git CLI (github/gitlab/gitea/forgejo/bugzilla); herrhotzenplotz/gcli v2.11.x.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-t --target)'{-t+,--target=}'[forge target]:target:(github gitlab gitea bugzilla forgejo)' \
  '*::arguments:_default'
