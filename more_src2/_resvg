#compdef resvg
# Documentation: https://github.com/linebender/resvg
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for resvg (SVG rendering tool).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --width)'{-w+,--width=}'[output image width in pixels]:width:' \
  '(-h --height)'{-h+,--height=}'[output image height in pixels]:height:' \
  '(-z --zoom)'{-z+,--zoom=}'[zoom factor]:zoom:' \
  '--dpi=[output DPI]:DPI:(72 96 150 200 300)' \
  '--background=[background color]:color:' \
  '--stylesheet=[CSS stylesheet to inject]:file:_files -g "*.css"' \
  '--languages=[preferred languages]:csv:' \
  '--shape-rendering=[shape rendering mode]:mode:(optimizeSpeed crispEdges geometricPrecision)' \
  '--text-rendering=[text rendering mode]:mode:(optimizeSpeed optimizeLegibility geometricPrecision)' \
  '--image-rendering=[image rendering mode]:mode:(optimizeQuality optimizeSpeed)' \
  '--resources-dir=[directory for relative image paths]:directory:_files -/' \
  '--font-family=[default font family]:family:' \
  '--font-size=[default font size]:size:' \
  '--serif-family=[serif font family]:family:' \
  '--sans-serif-family=[sans-serif font family]:family:' \
  '--cursive-family=[cursive font family]:family:' \
  '--fantasy-family=[fantasy font family]:family:' \
  '--monospace-family=[monospace font family]:family:' \
  '*--use-font-file=[load a font file]:file:_files' \
  '*--use-fonts-dir=[load fonts from directory]:directory:_files -/' \
  '--skip-system-fonts[do not load system fonts]' \
  '--list-fonts[list loaded font faces]' \
  '--query-all[print bounding boxes of all elements with IDs]' \
  '--export-id=[render only element with given ID]:id:' \
  '--export-area-page[use page area for export-id]' \
  '--export-area-drawing[use drawing tight bounding box]' \
  '--perf[print rendering time]' \
  '--quiet[suppress warnings]' \
  '1:input SVG:_files -g "*.svg(|.gz)(|z)(N)"' \
  '2:output:_files -g "*.(png|pdf|svg)(N)"' && ret=0

return ret
