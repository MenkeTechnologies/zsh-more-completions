#compdef debrepro
# Documentation: https://manpages.debian.org/debrepro
# Source: debian/devscripts scripts/debrepro.sh — check reproducibility of a Debian package build (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '*'{-s+,--skip=}'[skip variation]:variation:(domain user umask timezone locale path captures filesystem fileordering build-path home shell aslr time)' \
    '(-b --before-second-build)'{-b+,--before-second-build=}'[run command before second build]:command:_command_names' \
    '(-B --build-command)'{-B+,--build-command=}'[build command]:command:_command_names' \
    '(-a --artifact-pattern)'{-a+,--artifact-pattern=}'[artifact glob pattern]:pattern:_default' \
    '(-n --no-copy)'{-n,--no-copy}'[do not copy source tree before build]' \
    '(-t --timeout)'{-t+,--timeout=}'[timeout for diffoscope]:seconds:_default' \
    '1::source directory or .dsc:_files' \
    && ret=0

return ret
