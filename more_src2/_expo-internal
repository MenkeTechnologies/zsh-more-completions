#compdef expo-internal
# Documentation: https://www.npmjs.com/package/@expo/cli
# Reference accessed: 2026-05-23
# Verified: npx @expo/cli --help.

# Zsh completion for expo-internal - Expo CLI internal entry (@expo/cli)

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start Expo dev server'
  'export:export static app'
  'run:ios:run on iOS'
  'run:android:run on Android'
  'prebuild:generate native projects'
  'install:install dependencies'
  'customize:customize native project'
  'config:show Expo config'
  'serve:serve production bundle'
  'login:log in to Expo'
  'logout:log out of Expo'
  'whoami:show current Expo user'
  'register:create Expo account'
)

_arguments -C   '(-h --help)'{-h,--help}'[show help]'   '(-v --version)'{-v,--version}'[show version]'   '1: :->cmd'   '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'expo command' commands && ret=0 ;;
  (args) _arguments '*::args:' && ret=0 ;;
esac

return ret
