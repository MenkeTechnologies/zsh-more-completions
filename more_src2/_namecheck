#compdef namecheck
# Documentation: https://manpages.debian.org/namecheck
# Source: debian/devscripts scripts/namecheck.pl — check whether a project name is taken (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:name to check:_default' \
    && ret=0

return ret
