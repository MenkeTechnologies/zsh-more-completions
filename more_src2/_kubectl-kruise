#compdef kubectl-kruise
# Documentation: https://github.com/openkruise/kruise-tools
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'expose:expose workloads/services/pods as Kubernetes Services'
  'scale:set the desired number of replicas'
  'scaledown:scale down a workload while choosing which pods to delete'
  'rollout:manage rollout resources'
  'set:configure workload fields (image/env/resources/selector/etc.)'
  'migrate:migrate Deployment to CloneSet'
  'exec:execute a command in a (sidecar) container'
  'completion:generate shell completion'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-n+[namespace]:namespace:' \
  '--namespace=[namespace]:namespace:' \
  '--context=[kube context]:context:' \
  '--cluster=[kube cluster]:cluster:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kubectl-kruise command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (rollout)
        local -a rollout_subs=(
          'approve:approve a paused rollout to next phase'
          'undo:rollback to a previous version'
          'history:show rollout history'
          'pause:pause a rollout'
          'resume:resume a paused rollout'
          'restart:restart a rollout'
          'status:show rollout status'
        )
        _describe -t rcmds 'rollout subcommand' rollout_subs && ret=0 ;;
      (set)
        _arguments '*::sub:(env image resources selector serviceaccount subject)' && ret=0 ;;
      (scale)
        _arguments \
          '--replicas=[number of replicas]:n:' && ret=0 ;;
      (scaledown)
        _arguments \
          '--replicas=[number of replicas]:n:' \
          '--pods=[pods to delete (comma-separated)]:pods:' && ret=0 ;;
      (expose)
        _arguments \
          '--port=[service port]:port:' \
          '--target-port=[target port]:port:' \
          '--type=[service type]:type:(ClusterIP NodePort LoadBalancer ExternalName)' && ret=0 ;;
      (migrate)
        _arguments \
          '--from=[source workload type]:type:' \
          '--src-name=[source resource name]:name:' \
          '--dst-name=[target resource name]:name:' \
          '--create[create an empty CloneSet]' \
          '--copy[create a CloneSet with the same replicas]' \
          '--replicas=[replicas to migrate]:n:' \
          '--max-surge=[max surge during migration]:n:' && ret=0 ;;
      (exec)
        _arguments \
          '(-i --stdin)'{-i,--stdin}'[stdin]' \
          '(-t --tty)'{-t,--tty}'[allocate TTY]' \
          '(-c --container)'{-c+,--container=}'[container name]:container:' \
          '(-S --sidecar-container)'{-S+,--sidecar-container=}'[sidecar container name]:container:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
