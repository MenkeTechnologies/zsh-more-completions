#compdef iMath
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/iMath.cxx — ImageMath in ANTsR style; dimension-aware image arithmetic (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:OutputImage.ext:_files' \
    '3:Operation:(GetLargestComponent FillHoles PadImage MakeImage MD ME GD GE Sharpen Laplacian Grad Normalize TruncateImageIntensity Translate ReflectionMatrix CreationMatrix Canny GC ReorientTensorByAxis SmoothImage Smooth)' \
    '*:input images and operator-specific args:_files' \
    && ret=0

return ret
