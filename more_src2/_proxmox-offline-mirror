#compdef proxmox-offline-mirror
# _proxmox-offline-mirror — Proxmox Server Solutions proxmox-offline-mirror CLI for creating air-gapped Debian/Proxmox mirrors with signed snapshots (proxmox team, Rust); clap-derive
# upstream: https://git.proxmox.com/?p=proxmox-offline-mirror.git

_proxmox-offline-mirror() {
    local -a sub=(
        'setup:initial interactive setup'
        'config:configuration subcommands'
        'create:create a mirror'
        'snapshot:snapshot subcommands'
        'sync:run mirror sync'
        'gc:run garbage collection'
        'medium:medium subcommands'
        'health:check mirror health'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[config file]:file:_files -g "*.cfg *.toml"' \
        '-c+[config file]:file:_files -g "*.cfg *.toml"' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'proxmox-offline-mirror subcommand' sub ;;
        args)
            case $words[1] in
                config) _arguments '1:config cmd:(show set unset get list mirror remove-mirror add-mirror subscription medium remove-medium add-medium)' ;;
                snapshot) _arguments '1:snapshot cmd:(list show prune diff)' ;;
                medium) _arguments '1:medium cmd:(list sync gc status)' ;;
                sync) _arguments \
                    '--id=+[mirror id]:str:' \
                    '--dry-run[dry run]' \
                    '--skip-config[skip config]' ;;
                gc) _arguments \
                    '--id=+[mirror id]:str:' \
                    '--dry-run[dry run]' \
                    '--keep-last=+[N]:n:' ;;
                create) _arguments \
                    '--id=+[mirror id]:str:' \
                    '--repository=+[apt source]:str:' \
                    '--key-path=+[gpg key]:file:_files' \
                    '--base-dir=+[base dir]:dir:_files -/' \
                    '--architectures=+[arches csv]:str:' \
                    '--ignore-errors[ignore errors]' \
                    '--sync[sync after create]' ;;
            esac
            ;;
    esac
}

_proxmox-offline-mirror "$@"
