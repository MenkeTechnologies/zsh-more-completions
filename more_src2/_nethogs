#compdef nethogs
# _nethogs — Arnout Engelen's NetHogs (per-process network bandwidth monitor; groups traffic by PID via /proc, libpcap-based)
# upstream: https://github.com/raboof/nethogs
# Flags from src/main.cpp getopt on tip.

_nethogs() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-V[show version and exit]' \
        '-x[bug-hunt mode (verbose trace)]' \
        '-t[trace mode (suitable for parsing/CSV)]' \
        '-p[enable promiscuous mode]' \
        '-s[sort by sent traffic instead of received]' \
        '-d+[refresh delay (sec)]:sec:' \
        '-v+[view mode]:mode:(0 1 2 3)' \
        '-c+[max refreshes before exit]:n:' \
        '-l[show full command-line for processes]' \
        '-a[also monitor loopback / not-up interfaces]' \
        '-f+[pcap filter expression]:filter:' \
        '-C[catch-all (group unknown traffic into "unknown")]' \
        '-b[show only basename of process command]' \
        '-g+[garbage collection period (sec)]:sec:' \
        '*-P+[restrict to this PID (repeatable)]:pid:_pids' \
        '*:interface:_net_interfaces'
}

_nethogs "$@"
