#compdef errno
# _errno — moreutils errno (look up errno codes by number, name (E*), or string description; -l lists all known errnos, -s searches names+text, -S searches text only)
# upstream: https://salsa.debian.org/built-using-team/moreutils (joeyh)
# Flags from moreutils errno.c on tip.

_errno() {
    _arguments \
        '-l[list all known errnos]' \
        '-s[search names/text matching args]' \
        '-S[search descriptions only]' \
        '*:errno name/number/text:(EPERM ENOENT ESRCH EINTR EIO ENXIO E2BIG ENOEXEC EBADF ECHILD EAGAIN ENOMEM EACCES EFAULT ENOTBLK EBUSY EEXIST EXDEV ENODEV ENOTDIR EISDIR EINVAL ENFILE EMFILE ENOTTY ETXTBSY EFBIG ENOSPC ESPIPE EROFS EMLINK EPIPE EDOM ERANGE ETIMEDOUT ECONNREFUSED ENOSYS)'
}

_errno "$@"
