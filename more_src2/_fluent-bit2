#compdef fluent-bit2
# _fluent-bit2 — Fluent fluent-bit2 CLI command-line frontend wrapping the Fluent Bit CNCF open-source lightweight log metric trace processor and forwarder C-based providing inputs filters outputs parsers multiline-rules streams stream-processor record-modifier-kubernetes-lua-grep-rewrite-tag tail forward-systemd-syslog-tcp-udp-http-elasticsearch-loki-prometheus-kafka-stdout-influxdb-opensearch-opentelemetry hot-reload (Fluent CNCF team Treasure Data, C); custom argparse
# upstream: https://fluentbit.io/

_fluent-bit2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "fluent-bit.conf *.conf *.yaml"' \
        '--config=+[file]:file:_files -g "fluent-bit.conf *.conf *.yaml"' \
        '-D[daemonize]' \
        '--daemon[daemonize]' \
        '-f+[flush sec]:n:' \
        '--flush=+[N]:n:' \
        '-i+[input plugin]:p:(tail forward syslog systemd tcp udp http kafka mqtt cpu mem disk netif proc dummy random docker_events docker_metrics elasticsearch kubernetes_events node_exporter_metrics opentelemetry serial stdin nginx_metrics statsd thermal winlog)' \
        '--input=+[plugin]:str:' \
        '-o+[output plugin]:p:(stdout file forward elasticsearch opensearch loki prometheus_exporter prometheus_remote_write kafka kafka-rest http syslog tcp counter datadog azure_blob azure_log_analytics azure_kusto bigquery cloudwatch_logs cloudwatch_metrics es flowcounter gelf influxdb kinesis_firehose kinesis_streams logdna nrlogs null opentelemetry plot s3 skywalking slack splunk stackdriver tcp tikv treasuredata websocket)' \
        '--output=+[plugin]:str:' \
        '-F+[filter plugin]:p:(grep record_modifier rewrite_tag stdout kubernetes lua parser modify multiline nest expect throttle aws geoip2 type_converter checklist nightfall ecs sysinfo)' \
        '--filter=+[plugin]:str:' \
        '-P+[property k=v]:str:' \
        '--prop=+[k=v]:str:' \
        '-p+[plugin property]:str:' \
        '-T+[tag]:str:' \
        '--tag=+[tag]:str:' \
        '-m+[match]:str:' \
        '--match=+[match]:str:' \
        '-e+[external plugin .so]:file:_files -g "*.so"' \
        '--plugin=+[file]:file:_files -g "*.so"' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-l+[log file]:file:_files' \
        '--log_file=+[file]:file:_files' \
        '-R+[parsers conf]:file:_files -g "*.conf"' \
        '--parser=+[file]:file:_files -g "*.conf"' \
        '-H+[http port]:n:' \
        '--http=+[port]:n:' \
        '-Y[enable hot reload]' \
        '--enable-hot-reload[hot reload]' \
        '-s+[storage path]:dir:_files -/' \
        '--storage_path=+[dir]:dir:_files -/' \
        '-S+[sosreport]:str:' \
        '--sosreport[sosreport]' \
        '-Q[quit on flush error]' \
        '*:args:'
}

_fluent-bit2 "$@"
