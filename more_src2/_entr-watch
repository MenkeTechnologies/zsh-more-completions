#compdef entr-watch
# _entr-watch — Eric Radman entr Event Notify Test Runner CLI alias (eradman team, C); custom argparse
# upstream: https://github.com/eradman/entr

_entr-watch() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-a[respond to all events]' \
        '-c[clear screen before command]' \
        '-cc[clear screen and run]' \
        '-d[track directories]' \
        '-n[non-interactive (no tty)]' \
        '-p[postpone first execution]' \
        '-r[restart child if it dies]' \
        '-s[evaluate via shell]' \
        '-z[do not exit at end of input]' \
        '*:command args:_command_names'
}

_entr-watch "$@"
