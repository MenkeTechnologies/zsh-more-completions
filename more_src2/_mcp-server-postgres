# Zsh completion for mcp-server-postgres - archived MCP server for PostgreSQL access
# Single required positional: postgres:// database connection URL.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '1:database url (postgres\://user\:pass@host\:5432/db):_urls' && ret=0

return ret
