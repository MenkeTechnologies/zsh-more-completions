#compdef gnt-cluster
# Documentation: https://docs.ganeti.org/docs/ganeti/3.0/html/man-gnt-cluster.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'activate-master-ip:activate master IP'
  'add-tags:add cluster tags'
  'command:run a command on all nodes'
  'copyfile:copy a file to all nodes'
  'deactivate-master-ip:deactivate master IP'
  'destroy:destroy the cluster'
  'epo:emergency power off'
  'getmaster:print the name of the master node'
  'info:show cluster info'
  'init:initialise the cluster'
  'list-tags:list cluster tags'
  'master-failover:fail-over the master role'
  'master-ping:ping the master node'
  'modify:modify cluster parameters'
  'queue:cluster queue management'
  'redist-conf:redistribute cluster configuration'
  'remove-tags:remove cluster tags'
  'rename:rename the cluster'
  'renew-crypto:renew cluster crypto material'
  'repair-disk-sizes:repair disk size mismatches'
  'search-tags:search for cluster tags by regex'
  'show-ispecs-cmd:show ipolicy spec command'
  'upgrade:upgrade the cluster'
  'verify:verify cluster state'
  'verify-disks:verify disk state'
  'version:show version'
  'watcher:control the cluster watcher'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gnt-cluster command' commands && ret=0 ;;
esac

return ret
