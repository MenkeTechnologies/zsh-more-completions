#compdef elasticsearch-service-tokens
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/service-tokens-command.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elasticsearch-service-tokens: manage tokens for service accounts
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'create:create a service account token'
  'list:list service tokens'
  'delete:delete a service token'
)
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-E[config setting key=value]:kv:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'elasticsearch-service-tokens command' commands && ret=0 ;;
esac
return ret
