#compdef redwood rw
# _redwoodjs — RedwoodJS full-stack JavaScript framework CLI (Tom Preston-Werner et al); React + GraphQL + Prisma starter
# upstream: https://github.com/redwoodjs/redwood

_redwoodjs() {
    local -a sub=(
        'build:build for production'
        'check:check for errors'
        'console:open REPL'
        'data-migrate:run data migrations'
        'deploy:deploy to a provider'
        'destroy:undo a generate'
        'dev:run dev server'
        'diagnostics:print diagnostics'
        'exec:execute a script'
        'experimental:experimental commands'
        'generate:scaffold code'
        'g:alias for generate'
        'info:print info'
        'lint:run ESLint'
        'prerender:prerender static pages'
        'prisma:proxy Prisma CLI'
        'record:record CI/build telemetry'
        'serve:start API + web prod server'
        'setup:setup integrations'
        'storybook:run Storybook'
        'sb:alias for storybook'
        'studio:open Redwood Studio'
        'test:run tests'
        'type-check:run type-check only'
        'tc:alias for type-check'
        'upgrade:upgrade redwood packages'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--cwd+[cwd]:dir:_files -/' \
        '--load-env-files+[env file]:file:_files' \
        '--telemetry[enable telemetry]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'redwood subcommand' sub ;;
        args)
            case $words[1] in
                generate|g) _arguments \
                    '1:scaffold:(cell component dataMigration directive function layout model page sdl scaffold script service types graphiql secret realtime job)' \
                    '*:name:' ;;
                setup) _arguments '1:integration:(auth cache custom-web-index db deploy generator graphql i18n jobs mailer monitoring package realtime tsconfig ui upgrade webpack)' '*:variant:' ;;
                dev) _arguments \
                    '--side+[side]:side:(api web)' \
                    '--forward+[passthrough args]:str:' \
                    '--apiDebugPort+[api debug port]:port:' \
                    '--watch-node-modules[watch node_modules]' \
                    '--generate[regenerate types]' ;;
                serve) _arguments \
                    '1:side:(api web both)' \
                    '--port+[port]:port:' \
                    '--apiPort+[api port]:port:' \
                    '--apiHost+[api host]:host:_hosts' \
                    '--apiRootPath+[api root]:str:' \
                    '--socket+[unix socket]:file:_files' ;;
                build) _arguments '1:side:(api web both)' '--verbose[verbose]' '--stats[print stats]' '--prerender[prerender pages]' ;;
                test) _arguments '1:side:(api web)' '--watch[watch]' '--collectCoverage[coverage]' '--clearCache[clear cache]' ;;
            esac
            ;;
    esac
}

_redwoodjs "$@"
