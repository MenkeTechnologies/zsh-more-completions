#compdef gnaural
# _gnaural — Bret Logan Gnaural binaural-beat brainwave audio entrainment program GTK GUI and CLI batch mode (gnaural team, C); custom argparse
# upstream: http://gnaural.sourceforge.net

_gnaural() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--batch[batch mode]' \
        '-b[batch mode]' \
        '--output=+[output file]:file:_files -g "*.wav *.gnaural"' \
        '-o+[output file]:file:_files -g "*.wav *.gnaural"' \
        '--sample-rate=+[Hz]:n:' \
        '-s+[Hz]:n:' \
        '--bits=+[bits per sample]:n:(8 16 24 32)' \
        '-B+[bits per sample]:n:(8 16 24 32)' \
        '--no-gui[no GUI]' \
        '-N[no GUI]' \
        '--play[autoplay on load]' \
        '-p[autoplay on load]' \
        '--no-fade[no fade]' \
        '--render[render to file]' \
        '-r[render to file]' \
        '*:gnaural file:_files -g "*.gnaural *.xml"'
}

_gnaural "$@"
