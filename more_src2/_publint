#compdef publint
# Documentation: https://publint.dev/docs/cli
# Reference accessed: 2026-05-20
# Verified: upstream publint.dev CLI reference at the URL above.

# publint: lint published npm package output
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--strict[report warnings as errors]' \
  '--level=[level of messages to log]:level:(suggestion warning error)' \
  '--pack=[package manager to use for packing]:pack:(auto npm yarn pnpm bun false)' \
  '*:package directory:_directories' && ret=0

return ret
