#compdef deadcode
# Documentation: https://pkg.go.dev/golang.org/x/tools/cmd/deadcode
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-filter=[restrict results to packages matching regex]:pattern' \
  '-generated[include dead functions in generated files]' \
  '-test[analyze test executables in addition to main packages]' \
  '-cpuprofile=[write CPU profile]:file:_files' \
  '-json[output in JSON format]' \
  '-line[line-oriented output format]' \
  '-tags=[build tags]:tags' \
  '-f=[output format template]:template' \
  '-whylive=[explain why a named function is not dead]:function' \
  '*:packages or directories:_files -/' && ret=0

return ret
