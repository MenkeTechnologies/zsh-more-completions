#compdef linkml-lint
# _linkml-lint — lint LinkML schema YAML files (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from src/linkml/linter/cli.py (click).

_linkml-lint() {
    local -a args
    args=(
        '(-a --all)'{-a,--all}'[also process files that start with "."]'
        '(-c --config)'{-c+,--config=}'[custom linter configuration file]:file:_files -g "*.(yaml|yml)"'
        '(-f --format)'{-f+,--format=}'[report format]:format:(terminal markdown json tsv)'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '(-o --output)'{-o+,--output=}'[report output file (default stdout)]:file:_files'
        '--ignore-warnings[exit 0 even when warnings are found]'
        '--max-warnings=[exit 0 if at most this many warnings (and no errors)]:n:'
        '--fix[apply auto-fixes to the schema in place]'
        '--no-fix[do not auto-fix (default)]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema file or directory:_files'
    )
    _arguments -s -S $args
}

_linkml-lint "$@"
