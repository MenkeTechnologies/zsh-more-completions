#compdef flake-checker
# _flake-checker — flake.lock checker for Nix projects (DeterminateSystems/flake-checker)
# upstream: https://github.com/DeterminateSystems/flake-checker
# Flags from src/main.rs (clap).

_flake-checker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--no-telemetry[do not send aggregate issue sums]' \
        '--check-outdated[check for outdated Nixpkgs inputs]' \
        '--check-owner[check Nixpkgs inputs have NixOS as GitHub owner]' \
        '--check-supported[check git refs are supported]' \
        '--ignore-missing-flake-lock[ignore a missing flake.lock]' \
        '(-f --fail-mode)'{-f,--fail-mode}'[exit 1 if any issues encountered]' \
        '(-n --nixpkgs-keys)'{-n+,--nixpkgs-keys=}'[Nixpkgs input keys (comma list)]:list:' \
        '(-m --markdown-summary)'{-m,--markdown-summary}'[print Markdown summary]' \
        '(-c --condition)'{-c+,--condition=}'[CEL policy to apply per input]:cel:' \
        '*:flake.lock path:_files -g "flake.lock"'
}

_flake-checker "$@"
