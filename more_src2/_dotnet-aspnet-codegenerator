#compdef dotnet-aspnet-codegenerator
# Documentation: https://github.com/dotnet/Scaffolding/tree/main/src/Scaffolding/dotnet-aspnet-codegenerator
# Reference accessed: 2026-05-27
# Verified: upstream ScaffoldingApp.cs + VS.Web.CG.Mvc generator [Option] attributes

local curcontext="$curcontext" state line ret=1
local -a generators

generators=(
  'area:scaffold an MVC Area'
  'controller:scaffold an MVC Controller'
  'identity:scaffold ASP.NET Core Identity'
  'minimalapi:scaffold a Minimal API endpoints class'
  'razorpage:scaffold a Razor Page'
  'view:scaffold an MVC View'
  'blazor:scaffold a Blazor component'
  'blazoridentity:scaffold Blazor Identity'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --project)'{-p+,--project=}'[path to project file]:project:_files -g "*.csproj"' \
  '(-n --nuget-package-dir)'{-n+,--nuget-package-dir=}'[NuGet packages directory]:directory:_files -/' \
  '(-c --configuration)'{-c+,--configuration=}'[build configuration]:config:(Debug Release)' \
  '(-tfm --target-framework)'{-tfm+,--target-framework=}'[target framework moniker]:tfm:' \
  '(-b --build-base-path)'{-b+,--build-base-path=}'[base path for build output]:path:_files -/' \
  '--no-build[skip building the project before scaffolding]' \
  '1: :->generator' \
  '*::arg:->args' && ret=0

case $state in
  (generator)
    _describe -t generators 'aspnet-codegenerator generator' generators && ret=0
    ;;
  (args)
    case $line[1] in
      (controller)
        _arguments \
          '(-name --controllerName)'{-name+,--controllerName=}'[name of the controller]:name:' \
          '(-async --useAsyncActions)'{-async,--useAsyncActions}'[generate async controller actions]' \
          '(-nv --noViews)'{-nv,--noViews}'[do not generate CRUD views]' \
          '(-api --restWithNoViews)'{-api,--restWithNoViews}'[generate REST-style API controller (noViews implied)]' \
          '(-actions --readWriteActions)'{-actions,--readWriteActions}'[generate read/write actions when no Model class]' \
          '(-b --bootstrapVersion)'{-b+,--bootstrapVersion=}'[bootstrap version]:version:(4 5)' \
          '(-m --model)'{-m+,--model=}'[model class to use]:model:' \
          '(-dc --dataContext)'{-dc+,--dataContext=}'[DbContext class to use]:context:' \
          '(-dbProvider --databaseProvider)'{-dbProvider+,--databaseProvider=}'[database provider]:provider:(sqlserver sqlite cosmos postgres)' \
          '(-scripts --referenceScriptLibraries)'{-scripts,--referenceScriptLibraries}'[reference script libraries in generated views]' \
          '(-l --layout)'{-l+,--layout=}'[custom layout page]:layout:_files' \
          '(-udl --useDefaultLayout)'{-udl,--useDefaultLayout}'[use the default layout for views]' \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '(-outDir --relativeFolderPath)'{-outDir+,--relativeFolderPath=}'[relative output folder path]:path:_files -/' \
          '(-namespace --controllerNamespace)'{-namespace+,--controllerNamespace=}'[namespace for the generated controller]:namespace:' && ret=0
        ;;
      (view|razorpage)
        _arguments \
          '(-partial --partialView)'{-partial,--partialView}'[generate a partial view (layout options ignored)]' \
          '(-npm --noPageModel)'{-npm,--noPageModel}'[do not generate a PageModel class for Empty template]' \
          '(-namespace --namespaceName)'{-namespace+,--namespaceName=}'[namespace for the generated PageModel]:namespace:' \
          '(-b --bootstrapVersion)'{-b+,--bootstrapVersion=}'[bootstrap version]:version:(4 5)' \
          '(-m --model)'{-m+,--model=}'[model class to use]:model:' \
          '(-dc --dataContext)'{-dc+,--dataContext=}'[DbContext class to use]:context:' \
          '(-dbProvider --databaseProvider)'{-dbProvider+,--databaseProvider=}'[database provider]:provider:(sqlserver sqlite cosmos postgres)' \
          '(-scripts --referenceScriptLibraries)'{-scripts,--referenceScriptLibraries}'[reference script libraries]' \
          '(-l --layout)'{-l+,--layout=}'[custom layout page]:layout:_files' \
          '(-udl --useDefaultLayout)'{-udl,--useDefaultLayout}'[use the default layout for views]' \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '(-outDir --relativeFolderPath)'{-outDir+,--relativeFolderPath=}'[relative output folder path]:path:_files -/' \
          '1:template:(Empty Create Edit Delete Details List)' && ret=0
        ;;
      (identity)
        _arguments \
          '(-rn --rootNamespace)'{-rn+,--rootNamespace=}'[root namespace for generated identity code]:namespace:' \
          '(-dbProvider --databaseProvider)'{-dbProvider+,--databaseProvider=}'[database provider]:provider:(sqlserver sqlite cosmos postgres)' \
          '(-dc --dbContext)'{-dc+,--dbContext=}'[name of DbContext to use or generate]:context:' \
          '(-u --userClass)'{-u+,--userClass=}'[name of the User class to generate]:class:' \
          '(-fi --files)'{-fi+,--files=}'[semicolon separated list of files to scaffold]:files:' \
          '(-lf --listFiles)'{-lf,--listFiles}'[list files that can be scaffolded via --files]' \
          '(-f --force)'{-f,--force}'[overwrite existing files]' \
          '(-udui --useDefaultUI)'{-udui,--useDefaultUI}'[set up identity with the default UI]' \
          '(-l --layout)'{-l+,--layout=}'[custom layout file]:layout:_files' \
          '(-gl --generateLayout)'{-gl,--generateLayout}'[generate a new _Layout.cshtml]' \
          '(-b --bootstrapVersion)'{-b+,--bootstrapVersion=}'[bootstrap version]:version:(4 5)' \
          '(-exf --excludeFiles)'{-exf+,--excludeFiles=}'[semicolon separated files to exclude when overwriting]:files:' && ret=0
        ;;
      (minimalapi)
        _arguments \
          '(-e --endpoints)'{-e+,--endpoints=}'[endpoints class to use (not file name)]:class:' \
          '(-m --model)'{-m+,--model=}'[model class to use]:model:' \
          '(-dc --dataContext)'{-dc+,--dataContext=}'[DbContext class to use]:context:' \
          '(-outDir --relativeFolderPath)'{-outDir+,--relativeFolderPath=}'[relative output folder path]:path:_files -/' \
          '(-o --open)'{-o,--open}'[enable OpenAPI]' \
          '(-namespace --endpointsNamespace)'{-namespace+,--endpointsNamespace=}'[namespace for generated endpoints]:namespace:' \
          '(-dbProvider --databaseProvider)'{-dbProvider+,--databaseProvider=}'[database provider]:provider:(sqlserver sqlite cosmos postgres)' \
          '(-ntr --noTypedResults)'{-ntr,--noTypedResults}'[do not use TypedResults for minimal apis]' && ret=0
        ;;
      (area)
        _arguments \
          '1:area name:' && ret=0
        ;;
      (*)
        _arguments '*:arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
