#compdef mqttcli
# Documentation: https://github.com/shirou/mqttcli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Only -t, -m, -s, --conf are
# documented in the README; other flags trimmed to avoid invention.

local curcontext="$curcontext" state line ret=1

_mqttcli_commands() {
  local -a commands=(
    'pub:publish a message'
    'sub:subscribe to a topic'
    'pubsub:bidirectional publish and subscribe (experimental)'
    'help:show help'
  )
  _describe -t commands 'mqttcli command' commands
}

_arguments -C \
  '--help[show help]' \
  '--conf[config file path]:file:_files' \
  '1: :_mqttcli_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      pub)
        _arguments \
          '(-t --topic)'{-t,--topic}'[MQTT topic]:topic:' \
          '(-m --message)'{-m,--message}'[message body]:message:' \
          '-s[send one stdin line per message]' \
          '--conf[config file]:file:_files' && ret=0
        ;;
      sub)
        _arguments \
          '(-t --topic)'{-t,--topic}'[MQTT topic]:topic:' \
          '--conf[config file]:file:_files' && ret=0
        ;;
      pubsub)
        _arguments \
          '(-t --topic)'{-t,--topic}'[MQTT topic]:topic:' \
          '--conf[config file]:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
