#compdef dfu-programmer
# Documentation: https://manpages.debian.org/bookworm/dfu-programmer/dfu-programmer.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm dfu-programmer(1) manpage.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated commands (getfuse/setfuse/read/start-app/version);
# fabricated --debug numeric level (real --debug takes LEVEL not 0-9).

# dfu-programmer: Atmel USB bootloader programmer
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'configure:configure REGISTER DATA'
  'dump:dump flash'
  'dump-eeprom:dump EEPROM'
  'dump-user:dump user page'
  'erase:erase flash'
  'flash:flash hex file'
  'flash-eeprom:flash EEPROM hex'
  'flash-user:flash user page'
  'setsecure:set security fuse'
  'get:get REGISTER'
  'reset:reset device'
  'launch:launch firmware'
  'start:start application'
)

_arguments -C \
  '--quiet[quiet output]' \
  '--debug=[debug level]:level:' \
  '--help[show help]' \
  '--targets[list known target devices]' \
  '--version[show version]' \
  '1:device:' \
  '2: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'dfu-programmer command' commands && ret=0 ;;
  (args)
    case $line[2] in
      (flash|flash-eeprom|flash-user)
        _arguments \
          '--suppress-validation[suppress validation]' \
          '--suppress-bootloader-mem[suppress bootloader memory]' \
          '--serial=[HEX:OFFSET]:hex\:offset:' \
          '*:hex file:_files -g "*.(hex|ihx)(-.)"' && ret=0
        ;;
      (erase|configure)
        _arguments '--suppress-validation[suppress validation]' && ret=0
        ;;
    esac
    ;;
esac
return ret
