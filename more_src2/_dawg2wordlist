#compdef dawg2wordlist
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/dawg2wordlist.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments \
  '(- *)'{-v,--version}'[show version]' \
  '1:unicharset file:_files' \
  '2:dawg file:_files' \
  '3:wordlist output file:_files' && ret=0

return ret
