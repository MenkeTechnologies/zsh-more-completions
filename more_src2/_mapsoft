#compdef mapsoft
# Documentation: http://slazav.github.io/mapsoft2
# Reference accessed: 2026-05-16
# Verified: upstream slazav/mapsoft2. mapsoft2 ships as a 12-binary
# suite (ms2conv, ms2geofig, ms2img, ms2mp, ms2nom, ms2proj, ms2render,
# ms2tiles, ms2view, ms2vmap, ms2vmapdb, ms2xyz); there is no single
# `mapsoft` binary. Per-binary flags are not enumerated upstream.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# mapsoft: GIS toolkit suite (use ms2* binaries directly)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:arg:_files' && ret=0
return ret
