#compdef dvdbackup
# Documentation: https://man.archlinux.org/man/dvdbackup.1.en
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# zsh completion for dvdbackup - DVD backup tool

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[display usage]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-I --info)'{-I,--info}'[print DVD information]' \
  '(-M --mirror)'{-M,--mirror}'[backup the whole DVD]' \
  '(-F --feature)'{-F,--feature}'[backup the main feature]' \
  '(-T --titleset)'{-T+,--titleset=}'[backup a specific title set]:title number:' \
  '(-t --title)'{-t+,--title=}'[backup specific title]:title number:' \
  '(-s --start)'{-s+,--start=}'[start chapter]:chapter:' \
  '(-e --end)'{-e+,--end=}'[end chapter]:chapter:' \
  '(-i --input)'{-i+,--input=}'[input DVD device]:device:_files' \
  '(-o --output)'{-o+,--output=}'[output directory]:directory:_files -/' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-n --name)'{-n+,--name=}'[name for output]:name:' \
  '(-a --aspect)'{-a+,--aspect=}'[force aspect ratio (0=4:3)]:aspect:(0)' \
  '(-r --error)'{-r+,--error=}'[read error recovery mode]:mode:(a b m)' \
  '(-p --progress)'{-p,--progress}'[show progress while copying]' && ret=0

return ret
