#compdef gnmmanage
# Documentation: https://gdal.org/en/stable/programs/gnmmanage.html
# Source: OSGeo/gdal apps/gnmmanage.cpp — Geographic Network management (create, connect, rule, autoconnect).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)--help[show help]' \
    '(-q -quiet)'{-q,-quiet}'[suppress progress output]' \
    '-f+[output file format]:format:_default' \
    '-t_srs+[spatial reference]:srs:_default' \
    '*-dsco+[network creation option NAME=VALUE]:option:_default' \
    '-l+[layer name]:layer:_default' \
    '-c+[edge cost/weight]:cost:_default' \
    '-ic+[inverse cost]:invcost:_default' \
    '-dir+[edge direction]:dir:_default' \
    '-bl+[block feature by gfid]:gfid:_default' \
    '-unbl+[unblock feature by gfid]:gfid:_default' \
    '-unblall[unblock all features]' \
    '1:subcommand:(info create import connect disconnect rule autoconnect delete change)' \
    '*::args:_files' \
    && ret=0

return ret
