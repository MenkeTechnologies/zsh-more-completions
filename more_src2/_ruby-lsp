#compdef ruby-lsp
# Documentation: https://github.com/Shopify/ruby-lsp/blob/main/exe/ruby-lsp
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

# Zsh completion for ruby-lsp - Ruby language server

_arguments -s -S \
  '--version[print ruby-lsp version]' \
  '--debug[launch the Ruby LSP with a debugger attached]' \
  '--time-index[measure the time it takes to index the project]' \
  '--doctor[run troubleshooting steps]' \
  '--use-launcher[use launcher mechanism to handle missing dependencies gracefully (experimental)]' \
  '--beta[use pre-release server gems]' \
  '(-h --help)'{-h,--help}'[print this help]'
