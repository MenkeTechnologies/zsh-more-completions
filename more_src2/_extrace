#compdef extrace
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-d[print current working directory of traced process]' \
  '-e[print environment of traced process]' \
  '-f[follow forks and vforks]' \
  '-l[print full command line]' \
  '-o[write output to file]:output file:_files' \
  '-p[trace specific PID tree]:pid:_pids' \
  '-t[print timestamps]' \
  '-u[filter by user]:user:_users' \
  '-Q[do not quote arguments]' \
  '-w[wider output]' && ret=0
return ret
