#compdef dbtell
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/dbtell.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS dbtell: display details of a configured EMBOSS database
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-database=[database name]:name:' \
  '-server=[server name]:server:' \
  '-full[print every database attribute]' \
  '-outfile=[output file]:file:_files' \
  '-odirectory=[output directory]:dir:_files -/' \
  '*:database name:' && ret=0
return ret
