#compdef japa
# _japa — JACK and ALSA perceptual analyser (Fons Adriaensen)
# upstream: https://kokkinizita.linuxaudio.org/linuxaudio/index.html
# Flags from japa(1) man page.

_japa() {
    _arguments \
        '(- *)-h[show help]' \
        '-J[use JACK backend]' \
        '-s[select JACK server]:server:' \
        '-A[use ALSA backend]' \
        '-C[ALSA capture device for split mode]:device:' \
        '-P[ALSA playback device for split mode]:device:' \
        '-d[ALSA device]:device:' \
        '-r[sample frequency]:rate:(22050 32000 44100 48000 88200 96000 192000)' \
        '-p[period size]:size:(64 128 256 512 1024 2048 4096)' \
        '-n[number of fragments]:n:'
}

_japa "$@"
