#compdef idme
# Documentation: https://github.com/verygreen/u-boot-amazon-jed/blob/master/common/cmd_idme.c
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# idme: read/write Amazon Fire / Kindle idme (HW info) partition. U-Boot/Android binary.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-p[device]:device:_files' \
  '-r[read mode]' \
  '-w[write mode]' \
  '-d[dump]' \
  '*:tag value:' && ret=0
return ret
