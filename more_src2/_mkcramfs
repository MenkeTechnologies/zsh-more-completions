#compdef mkcramfs mkfs.cramfs
# Documentation: https://man7.org/linux/man-pages/man8/mkfs.cramfs.8.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mkcramfs / mkfs.cramfs: build a CRAMFS image from a directory tree
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-v[verbose]' \
  '-E[treat warnings as errors]' \
  '-b[block size]:bytes' \
  '-e[edition number]:n' \
  '-i[insert blob file]:file:_files' \
  '-n[volume name]:name' \
  '-p[pad by 512 bytes for boot code]' \
  '-s[ignored (formerly enabled directory entry sorting)]' \
  '-z[make explicit holes]' \
  '-N[byte order]:order:(big little host)' \
  '-l[use exclusive BSD lock]::mode:(yes no nonblock)' \
  '1:source directory:_files -/' \
  '2:output image:_files' && ret=0
return ret
