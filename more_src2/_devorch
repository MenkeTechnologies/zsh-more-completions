#compdef devorch
# Documentation: https://github.com/guicheffer/devorch
# Reference accessed: 2026-05-22
# Verified: src/cli/lib/cli/help.ts and package.json bin devorch.

# Zsh completion for devorch - composable AI workflow automation for Claude Code

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--local[use local devorch repository]:directory:_directories' \
  '--agent[pre-select AI agent for install]:agent:' \
  '--ci[auto-confirm prompts for CI]' \
  '--debug[enable debug logging]' \
  '--verbose[verbose output]' \
  '--quiet[errors only]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'devorch command' \
      'install[setup and install devorch]' \
      'diagnose[installation health checks]' \
      'count-tokens[count tokens in directory]' \
      'update[update CLI and templates]' \
      'check-version[check CLI and template versions]' && ret=0
    ;;
  args)
    case $line[1] in
      count-tokens)
        _arguments '1:directory:_directories' && ret=0
        ;;
    esac
    ;;
esac

return ret
