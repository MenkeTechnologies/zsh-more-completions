#compdef pamtosvg
# Documentation: man pamtosvg (Netpbm)
# Source: trace a Netpbm raster image into an SVG vector image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-background-color=[background color]:colorname:' \
    '-centerline[trace center line]' \
    '-corner-threshold=[corner detection angle threshold]:angle:' \
    '-corner-always-threshold=[corner-always angle threshold]:angle:' \
    '-corner-surround=[neighbourhood size for corner detection]:integer:' \
    '-tangent-surround=[neighbourhood size for tangent estimation]:integer:' \
    '-error-threshold=[max fitting error]:float:' \
    '-filter-iterations=[smoothing filter passes]:count:' \
    '-line-reversion-threshold=[line reversion threshold]:float:' \
    '-line-threshold=[straight-line detection threshold]:float:' \
    '-width-weight-factor=[stroke-width weight factor]:float:' \
    '-preserve-width[preserve stroke widths]' \
    '-remove-adjacent-corners[merge adjacent corner segments]' \
    '-log[write log]' \
    '-report-progress[report progress]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
