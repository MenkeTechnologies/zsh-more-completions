#compdef quast quast.py metaquast metaquast.py
# _quast — Alexey Gurevich QUAST Quality Assessment Tool for Genome Assemblies and MetaQUAST for metagenome assemblies (ablab team, Python); argparse
# upstream: https://github.com/ablab/quast

_quast() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '-r+[reference genome]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
        '--reference=+[reference genome]:file:_files -g "*.fa *.fasta *.fna *.fa.gz"' \
        '-g+[gene file]:file:_files -g "*.gff *.gff3 *.gtf *.bed"' \
        '--features=+[gene file]:file:_files -g "*.gff *.gff3 *.gtf *.bed"' \
        '-t+[threads]:n:' \
        '--threads=+[threads]:n:' \
        '-m+[min contig]:n:' \
        '--min-contig=+[min contig]:n:' \
        '-l+[labels csv]:str:' \
        '--labels=+[labels csv]:str:' \
        '-L[label by parent dir]' \
        '--split-scaffolds[split scaffolds]' \
        '-s[scaffolds]' \
        '--scaffolds[scaffolds]' \
        '-k[K-mer based statistics]' \
        '--k-mer-stats[K-mer based statistics]' \
        '--circos[circos plot]' \
        '--glimmer[gene prediction with GlimmerHMM]' \
        '--gene-finding[gene prediction]' \
        '-f[gene prediction]' \
        '--mgm[MetaGeneMark]' \
        '--rna-finding[rna finding]' \
        '--conserved-genes-finding[BUSCO]' \
        '-b[BUSCO]' \
        '--operons=+[operons]:file:_files' \
        '--est-ref-size=+[N]:n:' \
        '--gene-thresholds=+[thresholds]:str:' \
        '--contig-thresholds=+[thresholds]:str:' \
        '--use-all-alignments[use all alignments]' \
        '--ambiguity-usage=+[mode]:m:(none one all)' \
        '-a+[ambiguity usage]:m:(none one all)' \
        '--ambiguity-score=+[F]:f:' \
        '--strict-NA[strict NA]' \
        '--extensive-mis-size=+[N]:n:' \
        '--scaffold-gap-max-size=+[N]:n:' \
        '--unaligned-part-size=+[N]:n:' \
        '--skip-unaligned-mis-contigs[skip unaligned mis]' \
        '--fragmented[fragmented assembly]' \
        '--fragmented-max-indent=+[N]:n:' \
        '--upper-bound-assembly[upper bound]' \
        '--upper-bound-min-con=+[N]:n:' \
        '--est-insert-size=+[N]:n:' \
        '--report-all-metrics[report all metrics]' \
        '--plots-format=+[format]:f:(png pdf svg ps eps)' \
        '--memory-efficient[memory efficient]' \
        '--space-efficient[space efficient]' \
        '--gzip[gzip output]' \
        '--silent[silent mode]' \
        '--debug[debug mode]' \
        '*:assembly fasta:_files -g "*.fa *.fasta *.fna *.fa.gz"'
}

_quast "$@"
