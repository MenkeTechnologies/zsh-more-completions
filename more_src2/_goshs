#compdef goshs
# Documentation: https://github.com/patrickhener/goshs
# Reference accessed: 2026-05-17
# Verified: patrickhener/goshs README + docs.goshs.de reference. The
# tool also supports SMB/LDAP/DNS/SMTP server modes.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -p (real flag is -P PORT not -p), -sk/-sc/-si/-wo/-P credentials
# style (real flags differ).

# goshs: Go HTTP/SMB/LDAP/DNS/SMTP server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-d[directory to serve]:dir:_files -/' \
  '-s[serve via HTTPS]' \
  '-ss[serve via HTTPS with self-signed cert]' \
  '-cert[TLS certificate]:file:_files' \
  '-key[TLS key]:file:_files' \
  '-b[basic auth user:pass]:user\:pass:' \
  '-smb[enable SMB server]' \
  '-smb-domain[SMB domain]:domain:' \
  '-ldap[enable LDAP server]' \
  '-ldap-wordlist[LDAP wordlist]:file:_files' \
  '-dns[enable DNS server]' \
  '-dns-ip[DNS response IP]:ip:' \
  '-smtp[enable SMTP server]' \
  '-smtp-domain[SMTP domain]:domain:' \
  '--completion=[generate shell completion]:shell:(bash fish zsh)' && ret=0
return ret
