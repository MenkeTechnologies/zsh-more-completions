#compdef osv-scanner
# Documentation: https://google.github.io/osv-scanner/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'scan:scan for vulnerabilities'
      'fix:guided remediation for vulnerabilities'
    )
    _describe -t commands 'osv-scanner command' cmds && ret=0
    ;;
  args)
    case "${words[1]}" in
      scan)
        local -a scan_sub=(
          'source:scan source code / lockfiles'
          'image:scan a container image'
        )
        _arguments -s -S \
          '1:subcommand:->scansub' \
          '*::scanarg:->scanargs' && ret=0
        case "$state" in
          (scansub) _describe -t scansub 'osv-scanner scan subcommand' scan_sub && ret=0 ;;
          (scanargs)
            _arguments -s -S \
              '--lockfile[path to lockfile]:lockfile:_files' \
              '--sbom[path to SBOM file]:sbom file:_files' \
              '(-r --recursive)'{-r,--recursive}'[scan directories recursively]' \
              '--skip-git[skip scanning git repositories]' \
              '--format[output format]:format:(table json markdown sarif gh-annotations cyclonedx-1-4 cyclonedx-1-5)' \
              '--output[output file]:file:_files' \
              '--config[config file]:file:_files' \
              '--offline-vulnerabilities[use cached local vulnerability DB]' \
              '--download-offline-databases[download offline DBs as needed]' \
              '--licenses[license scanning]' \
              '--no-ignore[do not respect ignore entries]' \
              '--verbosity[verbosity level]:level:(error warn info verbose debug)' \
              '*:path:_files' && ret=0
            ;;
        esac
        ;;
      fix)
        _arguments -s -S \
          '--strategy[remediation strategy]:strategy:(in-place relock override)' \
          '--max-depth[limit dependency depth]:n:' \
          '--min-severity[minimum severity]:sev:' \
          '--ignore-dev[exclude dev dependencies]' \
          '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac
return ret
