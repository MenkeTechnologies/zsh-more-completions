#compdef llvm-symbolizer
# _llvm-symbolizer — LLVM symbolizer (LLVM project, C++); convert addresses + offsets to source line:column for stack traces
# upstream: https://github.com/llvm/llvm-project

_llvm-symbolizer() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--obj=+[object file]:file:_files' \
        '-obj=+[object file]:file:_files' \
        '-e+[object file]:file:_files' \
        '--exe=+[object file]:file:_files' \
        '--demangle+[demangle]:bool:(true false)' \
        '-C[demangle]' \
        '--inlines+[show inline frames]:bool:(true false)' \
        '-i[show inline frames]' \
        '--functions=+[functions]:val:(none short linkage)' \
        '-f+[functions]:val:(none short linkage)' \
        '--use-symbol-table+[use symbol table]:bool:(true false)' \
        '--print-source-context-lines=+[source context]:n:' \
        '--basenames[print basenames only]' \
        '-s[print basenames only]' \
        '--relative-address[input is relative address]' \
        '--default-arch=+[default arch]:arch:' \
        '--dsym-hint=+[dsym hint]:file:_files' \
        '--output-style=+[output style]:style:(LLVM GNU JSON)' \
        '--print-address[print address]' \
        '-a[print address]' \
        '--pretty-print[pretty print]' \
        '-p[pretty print]' \
        '--verbose[verbose]' \
        '--debug-file-directory=+[debug file dir]:dir:_files -/' \
        '*:address:'
}

_llvm-symbolizer "$@"
