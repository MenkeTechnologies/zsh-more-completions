#compdef pgmoneta-mcp-admin
# _pgmoneta-mcp-admin — manage users for pgmoneta MCP server (pgmoneta/pgmoneta_mcp)
# upstream: https://github.com/pgmoneta/pgmoneta_mcp
# Flags from src/bin/admin/admin.rs (clap derive).

_pgmoneta-mcp-admin() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-f --file)'{-f+,--file=}'[user configuration file]:file:_files' \
        '(-U --user)'{-U+,--user=}'[username]:user:' \
        '(-P --password)'{-P+,--password=}'[password]:pass:' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            _describe -t commands command '(user:manage a user account)'
            ;;
        args)
            case $words[1] in
                user)
                    _arguments '1:action:(add del edit ls)'
                    ;;
            esac
            ;;
    esac
}

_pgmoneta-mcp-admin "$@"
