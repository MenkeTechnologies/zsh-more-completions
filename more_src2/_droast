#compdef droast
# Documentation: https://github.com/immanuwell/dockerfile-roast
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_droast() {
    _arguments \
        '--list-rules[List all rules]' \
        '--no-roast[Boring mode, no jokes]' \
        '--min-severity[Set minimum severity level]:severity:(info warning error)' \
        '--skip[Comma-separated list of rule IDs to ignore]:rules:' \
        '--format[Output format]:format:(terminal json github compact sarif)' \
        '--no-fail[Advisory mode, exit 0]' \
        '--version[Show version]' \
        '--help[Show help]' \
        '*:Dockerfile:_files'
}

_droast "$@"
