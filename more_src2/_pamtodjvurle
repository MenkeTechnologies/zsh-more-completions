#compdef pamtodjvurle
# Documentation: man pamtodjvurle (Netpbm)
# Source: convert a Netpbm image to a DJVU RLE encoded foreground stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-transparent+[transparent color]:color:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:djvu rle output:_files' \
    && ret=0

return ret
