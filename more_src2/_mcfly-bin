#compdef mcfly
# _mcfly-bin — McFly fly-through shell history search (Andrew Cantino, Rust); neural-network-ranked Ctrl-R replacement
# upstream: https://github.com/cantino/mcfly

_mcfly-bin() {
    local -a sub=(
        'init:print shell integration script'
        'add:add a command to history'
        'search:search for a command'
        'train:train the neural network'
        'move:rename a directory'
        'stats:print stats'
        'dump:dump history db'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --debug)'{-d,--debug}'[debug log]' \
        '--mcfly-history-format+[history format]:fmt:' \
        '--mcfly-history+[history file]:file:_files' \
        '--mcfly-results+[result count]:n:' \
        '--mcfly-fuzzy+[fuzzy distance]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mcfly subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments '1:shell:(bash zsh fish)' ;;
                add) _arguments \
                    '--exit+[exit code]:n:' \
                    '--directory+[cwd]:dir:_files -/' \
                    '--old-dir+[old dir]:dir:_files -/' \
                    '--append-to-histfile[also append to HISTFILE]' \
                    '*:command:' ;;
                search) _arguments \
                    '(-o --output_selection)'{-o,--output_selection}'+[output file]:file:_files' \
                    '--results+[result count]:n:' \
                    '--results-sort+[sort by]:by:(last_run rank)' \
                    '--delete-without-confirm[delete without confirm]' \
                    '*:query:' ;;
                move) _arguments '1:old dir:_files -/' '2:new dir:_files -/' ;;
            esac
            ;;
    esac
}

_mcfly-bin "$@"
