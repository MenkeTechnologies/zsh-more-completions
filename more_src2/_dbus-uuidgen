#compdef dbus-uuidgen
# Documentation: https://manpages.debian.org/dbus-uuidgen
# Source: freedesktop/dbus tools/dbus-uuidgen.c — generate or read the D-Bus machine ID (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--get)--ensure=-[ensure UUID exists; path argument optional]::file:_files' \
    '(--ensure)--get=-[read UUID from file; path argument optional]::file:_files' \
    && ret=0

return ret
