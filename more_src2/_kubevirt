#compdef kubevirt
# _kubevirt — KubeVirt Authors kubevirt CLI top-level dispatcher for the KubeVirt Kubernetes-native virtual-machine workload-management add-on bundling virtctl virt-controller virt-api virt-handler virt-launcher VirtualMachine VirtualMachineInstance launch console vnc migrate pause start stop restart for the de-facto k8s-VM platform (KubeVirt team, Go); cobra
# upstream: https://kubevirt.io/

_kubevirt() {
    local -a sub=(
        'console:open VM console'
        'vnc:open VM VNC connection'
        'start:start a VM'
        'stop:stop a VM'
        'restart:restart a VM'
        'pause:pause a VM'
        'unpause:unpause a VM'
        'migrate:trigger live migration'
        'migrate-cancel:cancel migration'
        'expose:create service'
        'image-upload:upload disk image'
        'guestfs:open guestfs shell'
        'soft-reboot:soft reboot a VM'
        'permitted-devices:list permitted devices'
        'memory-dump:trigger memory dump'
        'usbredir:USB redirection'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--kubeconfig=+[file]:file:_files' \
        '--context=+[ctx]:str:' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--all-namespaces[all namespaces]' \
        '-o+[output]:f:(json yaml table wide)' \
        '--output=+[format]:f:(json yaml table wide)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kubevirt subcommand' sub ;;
        args)
            case $words[1] in
                console|vnc|start|stop|restart|pause|unpause|migrate|migrate-cancel|soft-reboot|memory-dump|usbredir) _arguments '*:vm name:' ;;
                expose) _arguments \
                    '--name=+[name]:str:' \
                    '--port=+[port]:n:' \
                    '--target-port=+[port]:n:' \
                    '--protocol=+[p]:p:(TCP UDP SCTP)' \
                    '--service-type=+[t]:t:(ClusterIP NodePort LoadBalancer)' \
                    '*:vm name:' ;;
                image-upload) _arguments \
                    '--pvc-name=+[name]:str:' \
                    '--pvc-size=+[size]:str:' \
                    '--storage-class=+[name]:str:' \
                    '--image-path=+[file]:file:_files' ;;
            esac
            ;;
    esac
}

_kubevirt "$@"
