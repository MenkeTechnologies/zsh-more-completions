#compdef kube-vip
# Documentation: https://github.com/kube-vip/kube-vip/blob/main/cmd/kube-vip.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kube-vip - Virtual IP manager for Kubernetes
# Subcommands and persistent flags taken from cmd/kube-vip.go (cobra root).

local curcontext="$curcontext" state line ret=1

local -a persistent_flags=(
  '--interface=[name of the interface to bind to]:interface:_net_interfaces'
  '--serviceInterface=[interface to bind to for services]:interface:_net_interfaces'
  '--vip=[the virtual IP address]:vip'
  '--vipSubnet=[the virtual IP address subnet]:subnet'
  '--nodeName=[name used for lease holder]:name'
  '--address=[address (IP or DNS) to use as a VIP]:address'
  '--port=[port for the VIP]:port'
  '--arp[enable ARP for VIP changes]'
  '--wireguard[enable Wireguard for services VIPs]'
  '--table[enable routing table for services VIPs]'
  '--enableLoadBalancer[enable load balancing on the VIP with IPVS]'
  '--lbPort=[load balancer port for the VIP]:port'
  '--lbForwardingMethod=[load balancer forwarding method]:method'
  '--ddns[use Dynamic DNS + DHCP to allocate VIP]'
  '--leaderElection[use Kubernetes leader election for clustering]'
  '--leaderElectionType=[leader election backend]:type:(kubernetes etcd)'
  '--leaseName=[name of the lease used for leader election]:name'
  '--leaseDuration=[seconds a leader lease can be held]:seconds'
  '--leaseRenewDuration=[seconds a leader can renew its lease]:seconds'
  '--leaseRetry=[seconds between leader election retries]:seconds'
  '--bgp[enable BGP support within kube-vip]'
  '--bgpRouterID=[router ID for the BGP server]:id'
  '--sourceIF=[source interface for BGP peering]:interface:_net_interfaces'
  '--sourceIP=[source address for BGP peering]:ip'
  '--localAS=[local AS number for the BGP server]:as'
  '--peerAddress=[address of a BGP peer]:address'
  '--peerAS=[AS number for a BGP peer]:as'
  '--peerPass=[md5 password for a BGP peer]:password'
  '--multihop[enable BGP multihop support]'
  '--bgppeers=[comma separated BGP peers]:peers'
  '--annotations=[node annotations prefix for parsing]:prefix'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  $persistent_flags \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'manager:start the kube-vip manager'
      'service:start the Virtual IP / load balancer as a service'
      'sample:generate a sample configuration'
      'manifest:generate a kube-vip manifest'
      'kubeadm:add or remove kube-vip from a kubeadm config'
      'version:version and release information'
    )
    _describe -t commands 'kube-vip command' commands && ret=0
    ;;
  args)
    case $line[1] in
      manifest)
        _arguments -s -S -C \
          '(- *)'{-h,--help}'[show help]' \
          $persistent_flags \
          '--inCluster[use the in-cluster token to authenticate]' \
          '--image=[hardcoded image for the manifest]:image' \
          '1:type:(pod daemonset rbac)' \
          '*::arg:->manifest_args' && ret=0
        case $line[1] in
          daemonset)
            _arguments -s -S \
              '--taint[taint the manifest for control planes only]' && ret=0
            ;;
          rbac)
            _arguments -s -S \
              '--role[generate only a Role for namespaced access]' \
              '--rolebinding[generate only a RoleBinding for namespaced access]' && ret=0
            ;;
        esac
        ;;
      manager|service|sample|kubeadm)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          $persistent_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
