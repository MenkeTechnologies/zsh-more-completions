#compdef dohnut
# =============================================================================
# dohnut — commonshost/dohnut's Node.js DNS-
#   TO-DNS-OVER-HTTPS (DoH) PROXY SERVER.
#   Accepts plain UDP / TCP DNS queries on a
#   local socket and forwards each query to
#   one (or more, in parallel) UPSTREAM DoH
#   resolvers over HTTP/2 — Cloudflare,
#   Quad9, Google, Commons Host, etc. — using
#   RFC 8484 wire-format DNS-over-HTTPS.
#   Encrypts all DNS traffic + hides queries
#   from local ISP / LAN snooping.  Built
#   directly on `dns-packet ^5.2.1` (the
#   canonical pure-JS DNS protocol codec by
#   mafintosh/maximkr).  TS-Node=106 leader
#   bump CLOSING Axis 51 (DNS Server /
#   Resolver Library) at 1/1/1 three-language
#   symmetry.
#
# AXIS 51 — DNS SERVER / RESOLVER LIBRARY — CLOSES @ R795
# ========================================================
# Closes the three-language DNS protocol-
# library axis at 1/1/1 symmetry:
#   * Rust       (R793): hickory-dns 0.26.1
#                — bundled in `crab-hole`
#                  (Pi-Hole clone DNS server
#                  with blocklist trie)
#   * Go         (R794): miekg/dns v1.1.72
#                — bundled in `dnsping`
#                  (probe-style DNS server
#                  latency + loss measurement
#                  tool)
#   * TS-Node    (R795, THIS ROUND):
#                dns-packet ^5.2.1 — bundled
#                in this round's `dohnut`
#                (DoH proxy server with
#                load-balancing, query
#                spoofing, and user-agent
#                spoofing privacy
#                countermeasures)
#
# `dns-packet` (mafintosh/dns-packet, 350+
# stars on GitHub, MIT) is the canonical
# pure-JS DNS protocol codec — encodes +
# decodes RFC 1035 DNS messages to/from
# Buffers without any C-bindings or native
# modules.  Used by:
#   - dohnut (this round)                  — DoH
#                                            proxy
#   - dns2 (npm `dns2`)                    — a
#                                            higher-
#                                            level
#                                            server
#                                            wrapper
#                                            around
#                                            dns-
#                                            packet
#   - native-dns (npm `native-dns`)        — older
#                                            DNS
#                                            client +
#                                            server
#                                            (less
#                                            maintained)
#   - dns-socket (npm `dns-socket`)        — UDP
#                                            socket
#                                            wrapper
#                                            around
#                                            dns-
#                                            packet
#   - mdns-js, multicast-dns, mdns-discovery — mDNS
#                                              tools
#                                              that
#                                              use
#                                              dns-
#                                              packet
#                                              for
#                                              the
#                                              wire
#                                              format
#
# Distinguishing dohnut from sibling DoH /
# DoT tooling:
#   - cloudflared (`_cloudflared`, in
#     corpus): Cloudflare's tunnel client
#     PLUS a DoH proxy when run with
#     `--proxy-dns`.  Bundled with a tunnel
#     daemon.  Heavier install
#   - dnscrypt-proxy (`_dnscrypt-proxy`, in
#     corpus): the original encrypted-DNS
#     proxy.  Supports DoH + DNSCrypt
#     protocol.  Go-based, single binary,
#     much heavier feature set
#   - dnsmasq (`_dnsmasq`): classic LAN
#     resolver + DHCP server.  No DoH
#     support out of the box
#   - dohnut is the NODE.JS-NATIVE entry in
#     this design space.  Tiny dependency
#     footprint, fast cold-start, runs on
#     anything with Node 11+.  Single npm
#     install or `npx dohnut`.  Designed
#     for Raspberry Pi / Odroid / cheap
#     low-power hosts
#
# KEY DOHNUT FEATURES (verbatim from
# upstream README):
#   - AUTOMATIC PERFORMANCE LOAD-BALANCING
#     — `--load-balance performance` (default)
#     continuously measures HTTP/2 PING-frame
#     round-trip-time to each configured DoH
#     resolver and routes queries to the
#     fastest one.  Adapts to network
#     conditions on the fly
#   - PRIVACY LOAD-BALANCING — `--load-
#     balance privacy` uniformly distributes
#     queries across all enabled DoH
#     resolvers so no single service can
#     build a complete query profile
#   - QUERY SPOOFING — `--countermeasures
#     spoof-queries` adds plausible
#     deniability by interleaving fake
#     queries (drawn from a public top 1
#     million domains list via exponential
#     distribution) before, after, with
#     delay, or not at all relative to
#     legitimate queries
#   - USER-AGENT SPOOFING — `--counter
#     measures spoof-useragent` rotates a
#     random `User-Agent` header per DoH
#     request drawn from a public real-
#     world browser-traffic dataset.
#     Prevents HTTP-layer profiling
#   - HTTP/2 CONNECTION REUSE — single
#     persistent HTTP/2 connection per DoH
#     resolver multiplexes all queries.
#     No TCP / TLS handshake overhead per
#     query
#   - SOCKET ACTIVATION — works with
#     systemd socket-activated launch
#     (Linux) and launchd-managed sockets
#     (macOS) via `sd-notify` + `socket-
#     activation` packages
#   - DOCKER MULTI-ARCH — official Docker
#     image at `commonshost/dohnut` for
#     x86_64 + arm64 + arm/v7
#   - PI-HOLE INTEGRATION — runs as the
#     upstream resolver for Pi-Hole's
#     dnsmasq.  Combine with `--bootstrap`
#     to avoid lookup loops when Dohnut is
#     also the host's resolver
#
# UPSTREAM DOH RESOLVER SHORTNAMES (the
# `@commonshost/resolvers` list):
#   * cleanbrowsing  — CleanBrowsing family-
#                      filter DoH
#   * cloudflare     — Cloudflare 1.1.1.1
#   * commonshost    — Commons Host (default)
#   * google         — Google Public DNS
#   * keoweon        — Keoweon
#   * mozilla        — Mozilla's Trusted
#                      Recursive Resolver
#   * nekomimi       — NekoMimi
#   * powerdns       — PowerDNS public
#                      recursive
#   * quad9          — Quad9 (security
#                      filtering)
#   * rubyfish       — RubyFish
#   * securedns      — SecureDNS
# Plus arbitrary `https://...` URLs for
# any RFC 8484-compliant DoH endpoint
#
# CONFIG FILE FORMAT (`--config <PATH>`):
# JSON file with the same key names as the
# CLI flags.  Multi-value flags are JSON
# arrays.  Example:
#
#   {
#     "listen": ["127.0.0.1:53", "[::1]:53"],
#     "doh":    ["commonshost", "cloudflare"],
#     "load-balance": "performance",
#     "countermeasures": ["spoof-queries",
#                         "spoof-useragent"],
#     "bootstrap": ["1.1.1.1", "9.9.9.9"],
#     "datagram-protocol": "udp6",
#     "cache-directory": "/var/cache/dohnut"
#   }
#
# ENVIRONMENT VARIABLES:
# All CLI options can also be specified as
# env vars with the `DOHNUT_` prefix.  Names
# are upper-cased; hyphens become underscores.
# Multi-value vars are space-separated
# (quoted in bash, raw in .env files).
# Example:
#   DOHNUT_DOH="commonshost cloudflare quad9"
#   DOHNUT_LISTEN="127.0.0.1:53 [::1]:53"
#   DOHNUT_LOAD_BALANCE="performance"
#
# CRITICAL DIRECT DEPENDENCIES (from
# package.json):
#   - dns-packet ^5.2.1        — pure-JS DNS
#                                wire-format
#                                codec
#                                [AXIS 51 LIBRARY]
#   - @commonshost/resolvers ^1.4
#                              — DoH shortname
#                                → URL map
#   - base64url 3              — DoH GET
#                                request URL
#                                encoding
#                                (RFC 8484
#                                base64url
#                                section)
#   - chalk 2.4                — terminal
#                                colour
#   - pino 5.13                — JSON
#                                structured
#                                logger
#   - please-upgrade-node 3.2  — Node.js
#                                version
#                                check at
#                                startup
#   - socket-activation 3.2    — systemd /
#                                launchd
#                                socket
#                                activation
#                                support
#   - uri-templates 0.2        — RFC 6570
#                                URI template
#                                expansion
#                                for DoH
#                                endpoints
#   - user-agents 1.0          — real-world
#                                User-Agent
#                                dataset
#                                (powers
#                                spoof-
#                                useragent)
#   - yargs 14                 — CLI parser
#   - yauzl 2.10               — ZIP archive
#                                reader
#                                (decompresses
#                                the bundled
#                                top-1M-
#                                domains list)
#   - sd-notify 2.3            — systemd
#                                READY=1
#                                notification
#
# Node.js >=11.7.0 MSRV per package.json
# `engines.node = ">=11.7.0"`.
#
# UPSTREAM:
#   * Source             : https://github.com/commonshost/dohnut
#   * Docs               : https://help.commons.host/dohnut/
#   * Commons Host       : https://commons.host
#   * dns-packet         : https://github.com/mafintosh/dns-packet
#   * Docker hub         : https://hub.docker.com/r/commonshost/dohnut
#   * RFC 8484           : https://tools.ietf.org/html/rfc8484
#   * License            : ISC
#   * Authors            : Kenny Shen, Sebastiaan Deckers (Commons Host)
#
# INSTALL:
#   # Global npm install
#   npm install --global dohnut
#
#   # Or npx (downloads + runs without
#   # installing)
#   npx dohnut [OPTIONS]
#
#   # Docker
#   docker run --publish 53:53/udp \
#       commonshost/dohnut \
#       --listen 0.0.0.0:53 \
#       --doh commonshost \
#       --bootstrap 9.9.9.9
#
# USAGE EXAMPLES:
#
#   # Run with defaults (listen 127.0.0.1:53
#   # + [::1]:53, upstream commonshost)
#   sudo dohnut
#
#   # Localhost-only proxy to Commons Host
#   dohnut --listen 127.0.0.1 ::1 \
#          --doh commonshost
#
#   # Custom DoH resolver URL
#   dohnut --doh https://localhost/my-own-resolver
#
#   # Fan out to multiple resolvers (default
#   # = performance load-balance)
#   dohnut --doh commonshost cloudflare quad9 cleanbrowsing
#
#   # All interfaces (IPv4 + IPv6)
#   dohnut --listen :: 0.0.0.0
#
#   # Non-privileged port
#   dohnut --listen 8053
#
#   # Custom port + protocol
#   dohnut --port 53 --datagram-protocol udp4
#
#   # Validate config (exit 0 OK, 1 error)
#   dohnut --test \
#       --doh https://example.com \
#       --listen 192.168.12.34
#
#   # Privacy load-balancing across 3
#   # resolvers
#   dohnut --load-balance privacy \
#       --doh quad9 cloudflare commonshost
#
#   # Enable query spoofing (sends fake
#   # queries for plausible deniability)
#   dohnut --countermeasures spoof-queries
#
#   # Enable user-agent spoofing
#   dohnut --countermeasures spoof-useragent
#
#   # Both countermeasures
#   dohnut --countermeasures spoof-queries spoof-useragent
#
#   # Bootstrap when Dohnut is also the OS
#   # resolver (avoid lookup loop)
#   dohnut --bootstrap 192.168.1.1 1.1.1.1 \
#                       8.8.8.8 9.9.9.9
#
#   # Load options from JSON config file
#   dohnut --config ~/dohnut-options.json
#
#   # Custom cache directory for spoof-
#   # queries top-1M domains list
#   dohnut --cache-directory /var/cache/dohnut \
#       --countermeasures spoof-queries
#
#   # Help + version
#   dohnut --help
#   dohnut --version
#
# OPTIONS (sourced directly from
# https://github.com/commonshost/dohnut/blob/main/docs/cli/README.md):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _dohnut_resolvers
_dohnut_resolvers=(
    'cleanbrowsing:CleanBrowsing family-filter DoH'
    'cloudflare:Cloudflare 1.1.1.1'
    'commonshost:Commons Host (default upstream)'
    'google:Google Public DNS'
    'keoweon:Keoweon DoH'
    'mozilla:Mozilla Trusted Recursive Resolver'
    'nekomimi:NekoMimi DoH'
    'powerdns:PowerDNS public recursive'
    'quad9:Quad9 (security filtering)'
    'rubyfish:RubyFish DoH'
    'securedns:SecureDNS'
)

local -a _dohnut_lb_strategies
_dohnut_lb_strategies=(
    'performance:Route to the fastest DoH resolver (HTTP/2 PING-based)'
    'privacy:Uniformly distribute queries across all enabled resolvers'
)

local -a _dohnut_countermeasures
_dohnut_countermeasures=(
    'spoof-queries:Interleave fake queries from top-1M-domains list'
    'spoof-useragent:Rotate random real-world User-Agent header per request'
)

local -a _dohnut_datagram_protocols
_dohnut_datagram_protocols=(
    'udp4:IPv4 UDP sockets'
    'udp6:IPv6 UDP sockets (default; dual-stack on most systems)'
)

_arguments -C \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*'{--doh,--upstream,--proxy}'=[upstream DoH resolver URL or shortname (repeatable; default commons.host)]:resolver:->resolver' \
    '*'{--listen,--local,-l}'=[local DNS server bind address (repeatable; default 127.0.0.1:53 + [::1]:53)]:host:port: ' \
    '(--test --validate --configtest)--test[validate arguments without starting (exit 0 OK, 1 error)]' \
    '(--test --validate --configtest)--validate[alias for --test]' \
    '(--test --validate --configtest)--configtest[alias for --test]' \
    '(--load-balance --lb)--load-balance=[load-balance strategy across multiple DoH resolvers]:strategy:->lb' \
    '(--load-balance --lb)--lb=[alias for --load-balance]:strategy:->lb' \
    '*--countermeasures=[privacy countermeasure (repeatable)]:countermeasure:->cm' \
    '*--bootstrap=[IPv4/IPv6 of fallback DNS resolver for initial DoH URI lookup (repeatable)]:host: ' \
    '--datagram-protocol=[UDP socket protocol for partially specified --listen entries]:protocol:->dgproto' \
    '--cache-directory=[directory for cached state (default cwd; only used by spoof-queries)]:dir:_files -/' \
    '--config=[JSON config file path]:file:_files -g "*.json"' \
    '--port=[shortcut for listening port]:port: ' \
    && ret=0

case $state in
    resolver)
        _alternative \
            'shortnames:DoH shortname:_describe -t shortnames "DoH resolver" _dohnut_resolvers' \
            'urls:DoH URL: ' \
            && ret=0
        ;;
    lb)
        _describe -t strategies 'load-balance strategy' _dohnut_lb_strategies && ret=0 ;;
    cm)
        _describe -t cms 'countermeasure' _dohnut_countermeasures && ret=0 ;;
    dgproto)
        _describe -t dgprotos 'datagram protocol' _dohnut_datagram_protocols && ret=0 ;;
esac

return ret
