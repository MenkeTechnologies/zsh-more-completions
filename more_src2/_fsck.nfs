#compdef fsck.nfs
# Documentation: man fsck.nfs(8)
# Source: Debian sysvinit src/initscripts/fsck.nfs (sh) — dummy fsck.nfs that always succeeds.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*:device or mountpoint:_files' \
    && ret=0

return ret
