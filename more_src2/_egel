#compdef egel
# =============================================================================
# egel — egel-lang/egel's "Egel Programming
#   Language" — an UNTYPED CONCURRENT FUNCTIONAL
#   SCRIPTING language based on EAGER COMBINATOR
#   REWRITING with a concise but powerful
#   syntax.  Designed as a symbolic evaluator
#   with first-class async/await, unicode-
#   correct strings (icu4c-backed), exception
#   handling that propagates ANY value (not
#   just an exception type), and dynamically-
#   loadable C++ extension modules.  Built in
#   C++ on top of icu4c + fmt + libffi + GNU
#   lightning (the latter providing AOT JIT
#   compilation).  127th language entry in the
#   corpus.
#
# 127TH LANGUAGE ENTRY — Egel opens the new
# 3+1 micro-cycle following the closure of
# Axis 47 (Apache Kafka Client) at 1/1/1 three-
# language symmetry in R779 (TS-Node=102
# `_superstream-kafka-analyzer` on kafkajs
# v2.2.4 + R778 Go=102 `_wal-listener` on
# IBM/sarama v1.45.2 + R777 Rust=102
# `_kafka-delta-ingest` on rdkafka 0.37).
#
# Distinguishing Egel from the 126 prior
# corpus languages — closest neighbours and
# their differences:
#   - HASKELL (`_ghc`, `_runghc`, `_stack`):
#     Haskell is LAZY + STATICALLY POLYMORPHIC
#     + PURE.  Egel is EAGER + UNTYPED +
#     IMPURE (mutable refs via `ref`/`set_ref`/
#     `get_ref`)
#   - FREGE (`_fregec`, this round's
#     candidate parent): Frege is Haskell-on-
#     JVM — lazy, statically typed.  Egel is
#     eager, untyped, native C++ interpreter
#   - SCHEME / RACKET (`_scheme`, `_racket`):
#     Scheme uses applicative reduction +
#     dynamic typing — close in evaluation
#     model BUT Scheme is list-based +
#     macro-driven.  Egel is COMBINATOR-
#     REWRITING based + pattern-driven
#   - CLOJURE (`_clj`, `_clojure`): JVM lisp,
#     eager + dynamic — close evaluation
#     model BUT Clojure is JVM-hosted +
#     immutable-by-default.  Egel is native
#     C++ + mutable refs allowed
#   - ERLANG (`_erl`, `_erlc`) / ELIXIR (`_iex`,
#     `_mix`): BEAM VM + actor model + lazy-
#     eager hybrid.  Egel is symbolic
#     rewriter + async/await + futures, no
#     actor message-passing primitive
#   - JOY / FACTOR / FORTH (`_factor`,
#     `_forth-* family): CONCATENATIVE — point-
#     free, stack-based.  Egel is APPLICATIVE
#     — function application is explicit,
#     terms have variables
#   - MLATU (concatenative typed): Mlatu is
#     concatenative + typed.  Egel is
#     applicative + untyped
#   - REBOL / RED (`_rebol`, `_red`): symbolic
#     dialect-driven evaluation.  Egel is
#     pattern-driven combinator rewriting —
#     similar symbolic spirit but Egel's
#     evaluation model is closer to lambda-
#     calculus + pattern-matching abstraction
#     rather than dialect dispatch
#   - WOLFRAM (`_wolfram`, `_wolframscript`):
#     CLOSEST EVALUATION MODEL — Wolfram is
#     also a SYMBOLIC TERM REWRITER with
#     pattern-driven function definitions.
#     Differences:
#       * Egel is open-source MIT; Wolfram
#         is proprietary
#       * Egel has explicit `data X = ...`
#         declarations; Wolfram tags are
#         schema-free symbols
#       * Egel async/await + GNU lightning
#         AOT JIT.  Wolfram has Parallel*[]
#         but no AOT compilation surface
#       * Egel's host-extension model is C++
#         + dlopen + libffi.  Wolfram's
#         extension model is MathLink /
#         WSTP
#
# KEY EGEL LANGUAGE FEATURES:
#   - EAGER COMBINATOR REWRITING — terms are
#     reduced left-to-right, fully evaluating
#     arguments before substituting into the
#     head.  Equivalent to call-by-value
#     lambda calculus extended with pattern-
#     matching abstraction
#   - PATTERN-MATCHING ABSTRACTION — the
#     anonymous abstraction `[ pat -> body |
#     pat -> body | ... ]` is the primary
#     combinator constructor.  Uppercase
#     names are variables (matched), lower-
#     case are constants (matched literally).
#     Example: `[ (cons HEAD TAIL) -> HEAD ]`
#   - BACKSLASH LAMBDA — `\X -> X` is a
#     single-clause lambda; equivalent to
#     `[ X -> X ]` but more compact.  Mirrors
#     Haskell / Miranda lambda syntax
#   - TAG-PATTERN MATCHING — `[ I:int -> ...
#     | C:cons -> ... ]` matches by runtime
#     tag, comparable to Haskell's typeclass
#     dispatch but at the value level
#   - LET EXPRESSIONS — `let X = expr in body`
#     for local binding.  Semicolon `;`
#     sequences expressions, last value is
#     the result
#   - VARIADIC ABSTRACTIONS — `[ X Y -> 2 |
#     X -> 1 | -> 0 ]` matches 2/1/0
#     arguments respectively.  No special
#     arity declaration needed
#   - DATA DECLARATIONS — `data nil` /
#     `data cons` introduce tag constants.
#     `data leaf` `data node` for tree-
#     shaped algebraic types
#   - DEF DECLARATIONS — `def fact = [ 0 ->
#     1 | N -> N * fact (N - 1) ]` binds a
#     name to a combinator
#   - NAMESPACES — `namespace Math (export
#     pi = 3.14159 ...)` for module-style
#     scoping
#   - ASYNC / AWAIT — `async [ _ -> expensive
#     ]` returns a future.  `await F`
#     blocks for the result.  Futures are
#     scheduled on a thread pool
#   - DO NOTATION — `(do f |> g |> h) X`
#     reads bottom-up, equivalent to `h (g
#     (f X))`.  Not monadic — just function
#     composition syntactic sugar
#   - TRY/CATCH WITH ANY VALUE — `try expr
#     catch [ EXC -> ... ]`.  Any value
#     can be `throw`n, not just an
#     exception type.  Pattern-match in
#     the catch clause to handle different
#     thrown shapes
#   - MUTABLE REFS — `ref V`, `set_ref R
#     V'`, `get_ref R`.  Cycles formed
#     through refs are NOT garbage-
#     collected (interpreter caveat;
#     manually break the cycle in user
#     code)
#   - UNICODE STRINGS via icu4c —
#     `"Hello ∀ world"` parses as a unicode
#     string.  Char literal `'∀'` parses
#     as a unicode codepoint.  String
#     ops respect grapheme cluster
#     boundaries
#   - FORMAT VIA fmt LIB — `format "Hello
#     {}" "world"` uses C++ libfmt syntax.
#     Positional `{0}` and named `{name}`
#     placeholders both supported
#   - C++ EXTENSION MODULES — `.ego`
#     dynamically-loadable shared objects
#     register combinators with the
#     interpreter at load time.  See
#     `include/` for the C++ extension
#     API.  Bridged via libffi
#   - GNU LIGHTNING AOT BACKEND — selected
#     hot paths in the interpreter use
#     GNU lightning to AOT-compile to
#     native code.  Significant speedup
#     over pure tree-walking
#
# INVOCATION MODES:
#   * SCRIPT MODE        : `egel script.eg`
#                          — reads the file,
#                          evaluates top-
#                          level expressions
#                          and `main`
#                          combinator (if
#                          present)
#   * INTERACTIVE MODE   : `egel -` or `egel
#                          --interact`
#                          — REPL prompt
#                          `>` reads
#                          expressions and
#                          prints normal
#                          forms
#   * EVAL MODE          : `egel -e "1 + 2"`
#                          — evaluates a
#                          single
#                          expression
#                          string and
#                          exits
#   * INCLUDE PATHS      : `-I /path/to/
#                          modules` (repeat
#                          for multiple
#                          paths) extends
#                          where the
#                          interpreter
#                          looks for
#                          `.eg` source +
#                          `.ego` shared
#                          objects.  May
#                          also be set via
#                          the `EGEL_PATH`
#                          environment
#                          variable
#                          (colon-separated)
#
# CRITICAL DIRECT DEPENDENCIES (from the
# vendor-mode CMakeLists.vendor):
#   - icu4c                — Unicode strings +
#                            collation
#   - fmt                  — C++ formatting
#   - libffi               — foreign function
#                            interface (for
#                            `.ego` modules)
#   - GNU lightning        — AOT JIT
#
# C++17 or higher compiler required.  Tested
# on g++ + clang++ + MSVC.  Linux/MacOS/BSD/
# Windows-supported.
#
# UPSTREAM:
#   * Source             : https://github.com/egel-lang/egel
#   * License            : MIT
#   * Maintainer         : Marco Devillers (egel-lang)
#   * man page           : https://github.com/egel-lang/egel/blob/master/man/egel.1.md
#   * icu4c              : https://icu.unicode.org/
#   * fmt                : https://fmt.dev/
#   * GNU lightning      : https://www.gnu.org/software/lightning/
#
# INSTALL:
#   # System-wide build (foss model — uses
#   # distro libicu/libffi/fmt/lightning)
#   git clone https://github.com/egel-lang/egel
#   cd egel
#   cp CMakeLists.foss CMakeLists.txt
#   mkdir build && cd build
#   cmake ..
#   make
#   sudo make install
#
#   # Vendored build (statically links submodules)
#   cp CMakeLists.vendor CMakeLists.txt
#   git submodule update --init --recursive
#   mkdir build && cd build
#   cmake ..
#   make
#
#   # Local install to ~/usr/local
#   make DESTDIR=~ install
#
# USAGE EXAMPLES:
#
#   # Run a script
#   egel hello.eg
#
#   # Interactive REPL
#   egel -
#   egel --interact
#
#   # Evaluate a single expression
#   egel -e "1 + 2"
#   egel -e "format \"Hello {}\" \"world\""
#
#   # Add include path for module resolution
#   egel -I ./lib script.eg
#   egel -I ./lib -I /usr/local/share/egel script.eg
#
#   # Combine eval + include path
#   egel -I ./lib -e "import MyModule; MyModule::run"
#
#   # Print version
#   egel -v
#   egel --version
#
#   # Help
#   egel -h
#   egel --help
#
# SCRIPT EXAMPLE — fib:
#
#   def fib =
#     [ 0 -> 0
#     | 1 -> 1
#     | N -> fib (N - 1) + fib (N - 2)
#     ]
#
#   def main = print (fib 30)
#
# SCRIPT EXAMPLE — async parallel fib:
#
#   def main =
#     let F1 = async [ _ -> fib 30 ] in
#     let F2 = async [ _ -> fib 31 ] in
#     print (await F1 + await F2)
#
# OPTIONS (sourced directly from
# https://github.com/egel-lang/egel/blob/master/man/egel.1):
#
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[print brief usage information; may list debug options]' \
    '(- *)'{-v,--version}'[print the current version number]' \
    '(- --interact)--interact[enter interactive mode unconditionally (REPL)]' \
    '(-e --eval)'{-e+,--eval=}'[evaluate the given command string and exit]:command: ' \
    '*'{-I+,--include=}'[add an include path (repeatable; see EGEL_PATH env)]:path:_files -/' \
    '*:Egel source file:_files -g "*.(eg|ego)"' \
    && ret=0

return ret
