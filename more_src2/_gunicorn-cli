#compdef gunicorn-cli
# _gunicorn-cli — Gunicorn Python WSGI HTTP server CLI alias (Benoit Chesneau, Python); argparse
# upstream: https://github.com/benoitc/gunicorn

_gunicorn-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.py *.conf"' \
        '-c+[config file]:file:_files -g "*.py *.conf"' \
        '--bind=+[bind addr]:addr:' \
        '-b+[bind addr]:addr:' \
        '--backlog=+[backlog]:n:' \
        '--workers=+[workers]:n:' \
        '-w+[workers]:n:' \
        '--worker-class=+[worker class]:c:(sync eventlet gevent gthread tornado)' \
        '-k+[worker class]:c:(sync eventlet gevent gthread tornado)' \
        '--threads=+[threads per worker]:n:' \
        '--worker-connections=+[worker connections]:n:' \
        '--max-requests=+[max requests]:n:' \
        '--max-requests-jitter=+[max requests jitter]:n:' \
        '--timeout=+[timeout]:n:' \
        '-t+[timeout]:n:' \
        '--graceful-timeout=+[graceful timeout]:n:' \
        '--keep-alive=+[keep alive]:n:' \
        '--limit-request-line=+[limit request line]:n:' \
        '--limit-request-fields=+[limit request fields]:n:' \
        '--limit-request-field_size=+[limit request field size]:n:' \
        '--reload[auto reload]' \
        '--reload-engine=+[reload engine]:e:(auto poll inotify)' \
        '--reload-extra-file=+[reload extra file]:file:_files' \
        '--spew[trace all calls]' \
        '--check-config[check config and exit]' \
        '--print-config[print config and exit]' \
        '--preload[preload app]' \
        '--sendfile[enable sendfile]' \
        '--no-sendfile[disable sendfile]' \
        '--reuse-port[reuse port]' \
        '--chdir=+[chdir]:dir:_files -/' \
        '--daemon[daemonize]' \
        '-D[daemonize]' \
        '--raw-env=+[raw env key=value]:str:' \
        '-e+[raw env key=value]:str:' \
        '--pid=+[pid file]:file:_files' \
        '-p+[pid file]:file:_files' \
        '--worker-tmp-dir=+[worker tmp dir]:dir:_files -/' \
        '--user=+[user]:str:_users' \
        '-u+[user]:str:_users' \
        '--group=+[group]:str:_groups' \
        '-g+[group]:str:_groups' \
        '--umask=+[umask]:n:' \
        '-m+[umask]:n:' \
        '--initgroups[initialize groups]' \
        '--forwarded-allow-ips=+[forwarded allow IPs]:list:' \
        '--access-logfile=+[access log file]:file:_files' \
        '--access-logformat=+[access log format]:str:' \
        '--disable-redirect-access-to-syslog[disable redirect access to syslog]' \
        '--error-logfile=+[error log file]:file:_files' \
        '--log-file=+[error log file]:file:_files' \
        '--log-level=+[log level]:level:(debug info warning error critical)' \
        '--logger-class=+[logger class]:str:' \
        '--log-config=+[log config]:file:_files' \
        '--log-config-dict=+[log config dict]:str:' \
        '--log-syslog[syslog]' \
        '--log-syslog-to=+[syslog target]:str:' \
        '--log-syslog-prefix=+[syslog prefix]:str:' \
        '--log-syslog-facility=+[syslog facility]:str:' \
        '--statsd-host=+[statsd host]:host:_hosts' \
        '--statsd-prefix=+[statsd prefix]:str:' \
        '--dogstatsd-tags=+[dogstatsd tags]:list:' \
        '--proc-name=+[proc name]:str:' \
        '-n+[proc name]:str:' \
        '--default-proc-name=+[default proc name]:str:' \
        '--pythonpath=+[pythonpath]:str:' \
        '--paste=+[paste config]:str:' \
        '--paste-global=+[paste global key=value]:str:' \
        '--certfile=+[ssl cert]:file:_files' \
        '--keyfile=+[ssl key]:file:_files' \
        '--ssl-version=+[ssl version]:str:' \
        '--cert-reqs=+[cert reqs]:n:' \
        '--ca-certs=+[ca certs]:file:_files' \
        '--suppress-ragged-eofs[suppress ragged EOFs]' \
        '--do-handshake-on-connect[do handshake on connect]' \
        '--ciphers=+[ciphers]:str:' \
        '*:wsgi-app:'
}

_gunicorn-cli "$@"
