#compdef qualimap
# _qualimap — Bioinfo Genomics Group qualimap CLI quality control tool for high-throughput sequencing alignment BAM files producing graphical interactive HTML PDF report covering chromosome coverage GC bias mapping quality insert size duplication paired-end overlap RNA-seq counts-qc multi-sample bamqc rnaseq counts comp-counts multi-bamqc clustering modes (Bioinfo Genomics team, Java); custom argparse
# upstream: http://qualimap.conesalab.org/

_qualimap() {
    local -a sub=(
        'bamqc:per-bam alignment quality control'
        'rnaseq:RNA-Seq specific quality control'
        'counts:counts QC for RNA-Seq'
        'comp-counts:compute counts'
        'clustering:cluster samples'
        'multi-bamqc:multi-sample bamqc'
        'gui:launch graphical interface'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--java-mem-size=+[size]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qualimap subcommand' sub ;;
        args)
            case $words[1] in
                bamqc) _arguments \
                    '-bam+[input BAM]:file:_files -g "*.bam"' \
                    '-c[overlap counts]' \
                    '-outdir+[dir]:dir:_files -/' \
                    '-outformat+[fmt]:f:(HTML PDF)' \
                    '-nt+[threads]:n:' \
                    '-nw+[windows]:n:' \
                    '-hm+[homopolymer min size]:n:' \
                    '-gff+[regions GFF]:file:_files -g "*.gff *.gff3 *.bed"' \
                    '-p+[library protocol]:p:(strand-specific-forward strand-specific-reverse non-strand-specific)' \
                    '-sd[skip duplicated]' \
                    '-os[output statistics]' \
                    '-ip[ignore paired end]' \
                    '-oc+[chr stats output]:file:_files' \
                    '-os+[summary output]:file:_files' ;;
                rnaseq) _arguments \
                    '-bam+[input BAM]:file:_files -g "*.bam"' \
                    '-gtf+[gtf]:file:_files -g "*.gtf"' \
                    '-outdir+[dir]:dir:_files -/' \
                    '-outformat+[fmt]:f:(HTML PDF)' \
                    '-pe[paired end]' \
                    '-s[strand-specific stranded]' \
                    '-p+[protocol]:p:(strand-specific-forward strand-specific-reverse non-strand-specific)' ;;
                multi-bamqc) _arguments \
                    '-d+[file list]:file:_files' \
                    '-r[run bamqc]' \
                    '-outdir+[dir]:dir:_files -/' ;;
            esac
            ;;
    esac
}

_qualimap "$@"
