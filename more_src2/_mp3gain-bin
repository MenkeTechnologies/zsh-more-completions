#compdef mp3gain
# _mp3gain-bin — mp3gain lossless MP3 volume normalizer (C); ReplayGain-style analyze + apply per-frame global gain adjustments
# upstream: http://mp3gain.sourceforge.net

_mp3gain-bin() {
    _arguments \
        '-h[show help]' \
        '-v[show version]' \
        '-c[ignore clipping warning]' \
        '-d+[modify suggested DB gain]:n:' \
        '-e[skip Album field calculation]' \
        '-f[force re-calc]' \
        '-g+[apply gain]:n:' \
        '-l+[apply default gain]:n:' \
        '-o[output stats only]' \
        '-p[preserve mod time]' \
        '-q[quiet]' \
        '-r[track gain (default)]' \
        '-a[album gain]' \
        '-s+[stored tag action]:action:(c d r m i)' \
        '-t[write only ReplayGain tags]' \
        '-u[undo gain change]' \
        '-w[allow write to file with no perms]' \
        '-x[only output stats, no change]' \
        '-T[input is tab-separated list]' \
        '-?[show help]' \
        '*:mp3 file:_files -g "*.mp3"'
}

_mp3gain-bin "$@"
