#compdef enchant-2
# Documentation: enchant-2 --help (enchant)
# Source: Enchant — generic spell-check wrapper (frontend for aspell/hunspell/voikko/etc).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-a --pipe)'{-a,--pipe}'[Ispell pipe-protocol mode]' \
    '(-l --errors-only)'{-l,--errors-only}'[list only misspellings]' \
    '(-d --dictionary)'{-d,--dictionary=}'[use the given dictionary]:dict:' \
    '(-p --pwl)'{-p,--pwl=}'[use the given personal word list]:file:_files' \
    '(-L --show-lines)'{-L,--show-lines}'[display line numbers]' \
    '(- *)'{-v,--version}'[display version and exit]' \
    '*:file:_files' \
    && ret=0

return ret
