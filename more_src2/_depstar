#compdef depstar
# _depstar — Sean Corfield depstar uberjar/jar tool for tools.deps CLI alias (seancorfield team, Clojure); tools.deps function CLI — superseded by tools.build but still in use
# upstream: https://github.com/seancorfield/depstar

_depstar() {
    local -a sub=(
        'jar:build thin jar'
        'uberjar:build uberjar'
        'pom:generate pom.xml'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'depstar subcommand' sub ;;
        args)
            case $words[1] in
                jar|uberjar) _arguments \
                    ':jar=+[jar file]:file:_files -g "*.jar"' \
                    ':aot=+[aot compile]:b:(true false)' \
                    ':aliases=+[aliases edn]:str:' \
                    ':main-class=+[main class]:str:' \
                    ':sync-pom=+[sync pom]:b:(true false)' \
                    ':group-id=+[group id]:str:' \
                    ':artifact-id=+[artifact id]:str:' \
                    ':version=+[version]:str:' \
                    ':paths-only=+[paths only]:b:(true false)' \
                    ':delete-on-jar=+[delete on jar]:str:' \
                    ':classpath=+[classpath]:str:' \
                    ':exclude=+[exclude regex csv]:str:' \
                    ':no-pom=+[no pom]:b:(true false)' \
                    ':compile-aliases=+[compile aliases edn]:str:' \
                    ':compile-fn=+[compile fn]:str:' \
                    ':compile-ns=+[compile ns edn]:str:' \
                    ':jar-type=+[jar type]:t:(thin uber)' \
                    ':target-dir=+[target dir]:dir:_files -/' \
                    ':verbose=+[verbose]:b:(true false)' ;;
                pom) _arguments \
                    ':group-id=+[group id]:str:' \
                    ':artifact-id=+[artifact id]:str:' \
                    ':version=+[version]:str:' \
                    ':sync-pom=+[sync pom]:b:(true false)' ;;
            esac
            ;;
    esac
}

_depstar "$@"
