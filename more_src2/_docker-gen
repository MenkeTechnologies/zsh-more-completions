#compdef docker-gen
# Documentation: https://github.com/nginx-proxy/docker-gen
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '-config=[config file]:file:_files' \
  '*-config=[merge additional config file]:file:_files' \
  '*-container-filter=[container filter]:filter' \
  '*-event-filter=[docker events filter]:filter' \
  '-endpoint=[docker API endpoint]:endpoint' \
  '-include-stopped[include stopped containers]' \
  '-interval=[notify interval seconds]:secs' \
  '-keep-blank-lines[keep blank lines in output]' \
  '-notify=[notify command after regenerate]:cmd' \
  '*-notify-container=[notify container ID]:id' \
  '*-notify-filter=[notify container filter]:filter' \
  '-notify-output[log notify command output]' \
  '*-notify-sighup=[send HUP to container ID]:id' \
  '-notify-signal=[signal number for notify-container]:signal' \
  '-only-exposed[only exposed ports]' \
  '-only-published[only published ports]' \
  '-tlscacert=[TLS CA cert]:file:_files' \
  '-tlscert=[TLS client cert]:file:_files' \
  '-tlskey=[TLS client key]:file:_files' \
  '-tlsverify[verify docker TLS]' \
  '-version[show version]' \
  '-wait=[debounce window]:duration' \
  '-watch[watch container changes]' \
  '1:template:file:_files' \
  '2:dest: _default'
