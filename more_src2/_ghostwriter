#compdef ghostwriter
# ============================================================================
# ghostwriter - reMarkable 2 + reMarkable
#                Paper Pro vision-LLM agent
#                (Rust, MIT)
#
# Author : Brock Wilcox (awwaiid)
# Upstream: https://github.com/awwaiid/ghostwriter
#
# Turns a reMarkable 2 / reMarkable Paper Pro
# e-ink tablet into an interactive interface
# for vision-capable Large Language Models
# (Anthropic Claude + OpenAI GPT-4o + Google
# Gemini). The agent:
#   1. Listens for a touch trigger in a
#      configurable corner of the tablet
#   2. Captures a screenshot of the current
#      page (handwriting + sketches + diagrams)
#   3. Sends it to the configured vision-LLM
#      with a customizable prompt
#   4. Receives the LLM's response and renders
#      it back to the tablet via:
#        - Text drawn with the on-screen
#          keyboard simulation (draw_text)
#        - SVG vector strokes drawn via the
#          pen simulation (draw_svg)
#   5. Loops back to waiting for the next
#      trigger
#
# This is a "ghost in the machine" for
# e-paper tablets - LLM completions appear
# magically on the same canvas where the
# user is sketching.
#
# Distinguishing features:
#   - **e-ink-native LLM UX** (designed for
#     the reMarkable form factor; no
#     keyboard or screen required for input)
#   - **Multi-engine support** (Anthropic +
#     OpenAI + Google; switch via --engine
#     or auto-detect from --model name)
#   - **Pluggable prompts** (--prompt
#     references JSON prompt files for
#     different LLM personalities + agentic
#     workflows)
#   - **Tool use via SVG drawing** (the LLM
#     can choose draw_text vs draw_svg as
#     output tools; SVG output is rendered
#     to actual pen strokes on the tablet)
#   - **Web search + thinking mode**
#     (Anthropic-specific features for
#     extended reasoning + web research)
#   - **Trigger-corner config** (UR + UL +
#     LR + LL; long-press in a corner to
#     activate)
#   - **Simulation mode** (--test-mode for
#     development on macOS/Linux without a
#     physical tablet; replays JSON touch
#     events + cycles through screenshot
#     directory)
#   - **Web configuration UI** (--web-server
#     starts a local HTTP UI for changing
#     models + prompts + tools at runtime)
#   - **TOML config file** (~/.ghostwriter
#     .toml + figment for layered config
#     with env overrides)
#
# Use cases:
#   - Vision-LLM-powered handwriting OCR +
#     transcription on the reMarkable
#   - LLM-assisted diagramming (sketch a
#     concept; ask LLM to refine the
#     drawing back)
#   - Math problem solving (write equation
#     on tablet; LLM solves + writes back)
#   - Creative writing assistant on e-ink
#     (handwrite a story; LLM continues it)
#   - Educational tutoring (write a
#     question; LLM responds with diagram +
#     explanation)
#   - Custom agentic workflows where the
#     tablet is both input + output medium
#
# Hardware support:
#   - reMarkable 2 (rm2)
#   - reMarkable Paper Pro (rmpp)
#   - Both devices via the same binary
#
# Usage:
#   ghostwriter [options]
#
# LLM engine + model:
#       --engine <name>            - engine to
#                                     use
#                                     (openai +
#                                     anthropic
#                                     +
#                                     google;
#                                     can be
#                                     guessed
#                                     from
#                                     --model
#                                     name)
#       --engine-base-url <url>    - base URL
#                                     for
#                                     engine
#                                     API (or
#                                     env:
#                                     OPENAI_
#                                     BASE_URL
#                                     /
#                                     ANTHROPIC_
#                                     BASE_URL)
#       --engine-api-key <key>     - API key
#                                     for
#                                     engine
#                                     (or env:
#                                     OPENAI_
#                                     API_KEY /
#                                     ANTHROPIC_
#                                     API_KEY /
#                                     GOOGLE_
#                                     API_KEY)
#   -m, --model <model>            - model to
#                                     use
#                                     (default
#                                     claude-
#                                     sonnet-
#                                     4-6;
#                                     gpt-4o +
#                                     gemini-
#                                     1.5-pro
#                                     + claude-
#                                     opus-4 +
#                                     etc.)
#       --prompt <file>            - prompt
#                                     JSON
#                                     file
#                                     (default
#                                     general
#                                     .json;
#                                     embedded
#                                     in
#                                     binary
#                                     via
#                                     rust-
#                                     embed)
#
# Anthropic-specific:
#       --web-search               - enable
#                                     web
#                                     search
#                                     tool
#                                     (Anthropic
#                                     models
#                                     only)
#       --thinking                 - enable
#                                     extended
#                                     thinking
#                                     mode
#                                     (Anthropic
#                                     reasoning
#                                     models)
#       --thinking-tokens <n>      - thinking
#                                     token
#                                     budget
#                                     (default
#                                     5000;
#                                     Anthropic
#                                     only)
#
# Loop + trigger behavior:
#       --no-loop                  - disable
#                                     looping
#                                     (one-
#                                     shot
#                                     execution)
#       --no-trigger               - disable
#                                     waiting
#                                     for
#                                     touch
#                                     trigger
#                                     (immediate
#                                     execution)
#       --trigger-corner <c>       - corner
#                                     for
#                                     touch
#                                     trigger
#                                     (UR +
#                                     UL +
#                                     LR +
#                                     LL or
#                                     long
#                                     forms
#                                     like
#                                     upper-
#                                     right;
#                                     default
#                                     UR)
#
# Drawing tools:
#       --no-draw                  - skip
#                                     running
#                                     draw_
#                                     text +
#                                     draw_
#                                     svg
#                                     tools
#                                     (for
#                                     testing)
#       --no-svg                   - disable
#                                     SVG
#                                     drawing
#                                     tool
#       --no-keyboard              - disable
#                                     keyboard
#                                     tool
#       --no-draw-progress         - disable
#                                     keyboard
#                                     progress
#                                     drawing
#       --apply-segmentation       - apply
#                                     image
#                                     segmentation
#                                     to the
#                                     screenshot
#                                     before
#                                     sending
#                                     to LLM
#
# Submission control:
#   -n, --no-submit                - do not
#                                     submit
#                                     to the
#                                     model
#                                     (for
#                                     testing
#                                     pipeline)
#
# Test inputs + outputs:
#       --input-png <file>         - input PNG
#                                     file
#                                     instead
#                                     of
#                                     screenshot
#                                     (testing)
#       --output-file <file>       - output
#                                     file for
#                                     LLM
#                                     response
#                                     (testing)
#       --model-output-file <file> - output
#                                     file for
#                                     model
#                                     parameters
#       --save-screenshot <file>   - save
#                                     captured
#                                     screenshot
#                                     to file
#       --save-bitmap <file>       - save
#                                     bitmap
#                                     to file
#
# Logging:
#       --log-level <level>        - log
#                                     level
#                                     (trace +
#                                     debug +
#                                     info +
#                                     warn +
#                                     error;
#                                     default
#                                     info)
#
# Config:
#       --save-config              - save
#                                     current
#                                     configuration
#                                     to ~/
#                                     .ghostwriter
#                                     .toml
#                                     + exit
#
# Web server (configuration UI):
#       --web-server               - start
#                                     web
#                                     server
#                                     for
#                                     configuration
#                                     UI
#       --web-port <port>          - port for
#                                     web
#                                     server
#                                     (default
#                                     8080)
#
# Simulation mode (development without
# physical tablet):
#       --test-mode <device>       - simulation
#                                     mode
#                                     device
#                                     (rm2 +
#                                     rmpp)
#       --test-touch-events-file <file> -
#                                     scripted
#                                     touch
#                                     events
#                                     for
#                                     simulation
#                                     (JSON
#                                     format)
#       --test-screenshot-dir <dir> - directory
#                                     of test
#                                     screenshots
#                                     to
#                                     cycle
#                                     through
#       --test-auto-trigger-delay <sec> -
#                                     auto-
#                                     trigger
#                                     delay
#                                     in
#                                     seconds
#                                     for
#                                     automated
#                                     testing
#       --test-interaction-log <file> -
#                                     file to
#                                     log
#                                     simulated
#                                     interactions
#                                     to
#
# Standard:
#   -h, --help                     - show help
#   -V, --version                  - show
#                                     version
#
# Example invocations:
#   # Basic run with Claude (waits for trigger)
#   ANTHROPIC_API_KEY=sk-ant-... ghostwriter
#
#   # Use GPT-4o with web search disabled
#   OPENAI_API_KEY=sk-... ghostwriter \
#     --engine openai --model gpt-4o
#
#   # Custom prompt file
#   ghostwriter --prompt custom-tutor.json
#
#   # Lower-right trigger corner + thinking mode
#   ghostwriter \
#     --trigger-corner LR \
#     --thinking --thinking-tokens 10000
#
#   # Save current config + exit
#   ghostwriter --model gpt-4o --no-svg \
#     --save-config
#
#   # Start web UI on port 9000
#   ghostwriter --web-server --web-port 9000
#
#   # Simulation mode (development on host)
#   ghostwriter \
#     --test-mode rm2 \
#     --test-screenshot-dir ./fixtures/ \
#     --test-auto-trigger-delay 5 \
#     --no-loop
#
# Configuration file (~/.ghostwriter.toml,
# layered via figment):
#   engine = "anthropic"
#   model = "claude-sonnet-4-6"
#   prompt = "general.json"
#   trigger_corner = "UR"
#   thinking = true
#   thinking_tokens = 8000
#   log_level = "info"
#
# The toml lane is built on `toml = "0.8"`
# (declared verbatim at upstream Cargo.toml
# HEAD as a direct dep, paired with figment
# = { features = ["toml", "env"] } for
# layered configuration loading from
# ~/.ghostwriter.toml + environment
# variables + CLI args), the canonical
# Rust TOML library by Alex Crichton -
# github.com/toml-rs/toml.
#
# toml-rs/toml is the de-facto canonical
# Rust TOML library:
#   - **TOML spec compliant** (TOML v1.0.0
#     2021 spec at toml.io; toml-rs is
#     the reference Rust implementation +
#     passes the official TOML test
#     suite)
#   - **Serde integration** (transparent
#     serde::Serialize + serde::Deserialize
#     for any type; no manual codec impl
#     required)
#   - **Used by Cargo itself** (the Rust
#     package manager uses toml-rs to
#     parse every Cargo.toml in the
#     Rust ecosystem - the canonical
#     reference deployment)
#   - **Pure-Rust implementation** (no C
#     dependencies)
#   - **Streaming parser** (toml_edit
#     companion crate provides a
#     format-preserving parser for
#     edit-in-place use cases like
#     `cargo add` + `cargo remove`)
#   - **3,300+ stars on github.com/
#     toml-rs/toml**
#   - **~50,000 reverse-deps on crates.io
#     (the most-imported Rust config
#     library after serde itself)**
#
# toml-rs/toml's distinguishing position
# vs Rust TOML alternatives:
#   - toml-rs/toml (Crichton): canonical;
#     used by Cargo itself; serde-
#     integrated; THIS AXIS
#   - toml-rs/toml_edit (also Crichton):
#     companion format-preserving parser;
#     used by `cargo add` + tools that
#     need to preserve TOML formatting +
#     comments on round-trip
#   - tomling: alternative pure-Rust
#     TOML; less broadly adopted
#   - taplo: TOML language server +
#     formatter; uses toml-rs's parser
#     internally
#
# Alex Crichton (alexcrichton) is one of
# the most influential figures in Rust's
# development:
#   - **Rust core team member** + former
#     leader of the rustc compiler
#   - **Cargo team lead** (the Rust
#     package manager; Crichton was Cargo's
#     primary author + maintainer for many
#     years)
#   - **rustc + LLVM backend maintenance**
#   - **wasm-bindgen co-author** (the
#     canonical Rust↔JavaScript interop
#     bridge for WebAssembly)
#   - **Many foundational Rust libraries**:
#       * toml (THIS AXIS)
#       * curl-rust + libnghttp2-sys
#       * lock-api + parking_lot core
#       * crc + crc32fast
#       * cfg-if (universal Rust ecosystem
#         dependency)
#       * xattr + dirs-next
#
# Crichton's broader Rust ecosystem
# footprint is among the most extensive
# of any individual contributor - his
# libraries are foundational dependencies
# for almost every non-trivial Rust
# project. Cargo's reliance on toml-rs
# makes toml-rs structurally inevitable
# in the Rust ecosystem (every Rust crate
# has a Cargo.toml; every Cargo.toml is
# parsed by toml-rs).
#
# Multi-axis canonical-Rust author/org
# cohort extension (now spanning even more
# distinct authors):
#   - + Alex Crichton (toml-rs/toml +
#     toml-rs/toml_edit + Cargo + wasm-
#     bindgen + cfg-if + parking_lot
#     core + many others; THIS AXIS;
#     canonical Rust TOML + Rust
#     ecosystem foundational
#     infrastructure)
#
# Crichton's joining the canonical-Rust
# cohort at the *core team member +
# ecosystem-foundational-infrastructure*
# level is structurally unique - few
# individuals maintain as many
# foundational Rust libraries as
# Crichton. His role is closer to "Rust
# ecosystem ICE bearer" than to specific
# library author - Cargo + toml + wasm-
# bindgen + many compiler-adjacent
# crates all trace back to his
# contributions.
#
# Crichton's role in Rust is analogous to:
#   - Brian Goetz in Java (long-time JLS
#     spec author + JEP shepherd)
#   - Guido van Rossum in Python (BDFL
#     emeritus + still active in design
#     decisions)
#   - Andrei Alexandrescu in D (language
#     designer + maintainer)
# Single-individual ecosystem-wide
# canonical presence is rare; Crichton
# is one of the few in Rust.
#
# ghostwriter uses toml-rs for:
#   - Parsing ~/.ghostwriter.toml
#     configuration file (via figment's
#     toml provider)
#   - Serializing current configuration
#     to ~/.ghostwriter.toml (via the
#     --save-config flag)
#   - Configuration schema definition
#     (the Args struct uses #[derive(
#     Parser, Serialize)] for both clap
#     CLI parsing + toml serialization)
#
# This is the canonical use case for
# toml-rs in Rust CLI applications:
# layered config (CLI flags > env vars >
# TOML config file > defaults) using
# figment + serde + toml-rs together.
#
# ----------------------------------------------------------------------------
# AXIS 283 :: TOML (Tom's Obvious, Minimal
#              Language) configuration
#              file format libraries
#              (TOML v1.0.0 spec compliant
#              parsers + serializers;
#              human-readable config
#              format alternative to YAML
#              + JSON)
# Round 1547 :: Rust slot 1 of 4 :: OPENS Axis 283
#
# Cross-language canonical library family
# for this axis (proposed):
#   Rust    : toml-rs/toml               - Alex
#                                          Crichton +
#                                          Cargo
#                                          team
#                                          (canonical
#                                          Rust TOML;
#                                          used by
#                                          Cargo
#                                          itself)
#   Go      : BurntSushi/toml            - Andrew
#                                          Gallant
#                                          (canonical
#                                          Go TOML;
#                                          also
#                                          author
#                                          of
#                                          ripgrep
#                                          + regex)
#   TS/Node : iarna/iarna-toml           - Rebecca
#             OR                            Turner
#             squirrelchat/smol-toml         (npm
#                                          core
#                                          team;
#                                          @iarna/
#                                          toml;
#                                          canonical
#                                          Node
#                                          TOML)
#
# TOML is the *standard configuration
# file format for the Rust ecosystem*
# (every Cargo.toml is TOML) + has
# achieved broad cross-language adoption
# for human-readable config:
#   - **Created by Tom Preston-Werner**
#     (GitHub co-founder; co-created
#     TOML 2013)
#   - **TOML v1.0.0 spec** at toml.io
#     (released January 2021; ABI-stable
#     spec)
#   - **Adoption**: Rust Cargo + Hugo
#     + many Python + Go projects +
#     ESLint config (eslint.config.toml)
#     + Pip's pyproject.toml + ...
#   - **Distinguishing features vs YAML
#     + JSON**:
#       * Strict typing (no implicit
#         conversions like YAML)
#       * Comments (unlike JSON)
#       * Less syntactic ambiguity than
#         YAML's whitespace + flow vs
#         block syntax
#       * Easier to write by hand than
#         JSON
#       * Tables + arrays-of-tables for
#         structured data
#
# Each canonical library provides:
#   - TOML v1.0.0 spec parsing
#   - Serialization (any language object
#     to TOML)
#   - Idiomatic language API (serde-
#     style in Rust; reflection in Go;
#     JSON-compatible object in Node)
#   - Strict typing enforcement
#
# Use-case spectrum for this axis (so far):
#   - ghostwriter (Rust, toml-rs): vision-
#     LLM agent for reMarkable tablet
#     using ~/.ghostwriter.toml config
#     loaded via figment layered config
# ============================================================================

_ghostwriter() {
    _arguments \
        '--engine=[engine to use]:engine:(openai anthropic google)' \
        '--engine-base-url=[engine API base URL]:url:' \
        '--engine-api-key=[engine API key]:key:' \
        '(-m --model)'{-m+,--model=}'[model to use]:model:' \
        '--prompt=[prompt JSON file]:file:_files -g "*.json"' \
        '(-n --no-submit)'{-n,--no-submit}'[do not submit to the model]' \
        '--no-draw[skip running drawing tools]' \
        '--no-svg[disable SVG drawing tool]' \
        '--no-keyboard[disable keyboard tool]' \
        '--no-draw-progress[disable keyboard progress drawing]' \
        '--input-png=[input PNG file (testing)]:file:_files -g "*.png"' \
        '--output-file=[output file for LLM response]:file:_files' \
        '--model-output-file=[output file for model parameters]:file:_files' \
        '--save-screenshot=[save captured screenshot to file]:file:_files' \
        '--save-bitmap=[save bitmap to file]:file:_files' \
        '--no-loop[disable looping]' \
        '--no-trigger[disable waiting for trigger]' \
        '--apply-segmentation[apply image segmentation]' \
        '--web-search[enable web search (Anthropic only)]' \
        '--thinking[enable thinking mode (Anthropic only)]' \
        '--thinking-tokens=[thinking token budget]:n:' \
        '--log-level=[log level]:level:(trace debug info warn error)' \
        '--trigger-corner=[touch trigger corner]:corner:(UR UL LR LL upper-right upper-left lower-right lower-left)' \
        '--save-config[save config to ~/.ghostwriter.toml + exit]' \
        '--web-server[start web server for config UI]' \
        '--web-port=[port for web server]:port:' \
        '--test-mode=[simulation mode device]:device:(rm2 rmpp)' \
        '--test-touch-events-file=[scripted touch events JSON]:file:_files -g "*.json"' \
        '--test-screenshot-dir=[test screenshots directory]:dir:_files -/' \
        '--test-auto-trigger-delay=[auto-trigger delay (seconds)]:sec:' \
        '--test-interaction-log=[interaction log file]:file:_files' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_ghostwriter "$@"
