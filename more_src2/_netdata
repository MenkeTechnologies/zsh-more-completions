#compdef netdata
# Documentation: https://learn.netdata.cloud/docs/netdata-agent/daemon
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for netdata (monitoring agent)

_arguments -s -S \
  '-c[config file]:file:_files' \
  '-D[run in foreground (do not fork)]' \
  '-d[run in background (fork)]' \
  '-h[show help]' \
  '-i[listening IP address]:address:' \
  '-p[API/Web port]:port:' \
  '-P[PID file path]:file:_files' \
  '-s[prefix for /proc and /sys]:path:_files -/' \
  '-t[internal clock interval seconds]:seconds:' \
  '-u[run as user]:user:_users' \
  '-v[show version]' \
  '-V[show version]' \
  '-W[advanced/special operation]:operation:(buildinfo set get unittest debug stacksize sqlite-check sqlite-fix sqlite-compact)' \
  '--claim-token=[claim token]:token:' \
  '--claim-rooms=[claim rooms]:rooms:' \
  '--claim-url=[claim URL]:url:_urls' \
  '--claim-proxy=[claim proxy]:proxy:' \
  '--claim-id=[claim ID]:id:' && return 0
