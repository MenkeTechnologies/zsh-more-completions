#compdef kubie
# Documentation: https://github.com/sbstp/kubie
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for kubie. Subcommands derived from src/cmd/meta.rs (clap
# derive macros) in the upstream repo.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[print version]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'ctx:spawn a shell in the given context'
      'ns:change the namespace in which the current shell operates'
      'info:view info about the current kubie shell'
      'exec:execute a command inside the given context and namespace'
      'export:print the path to an isolated config file for context/namespace'
      'lint:check the Kubernetes config files for issues'
      'edit:edit the given context'
      'edit-config:edit kubie config file'
      'update:check for an update and replace kubie binary'
      'delete:delete a context (garbage collects dangling users/clusters)'
      'generate-completion:generate a completion script'
      'help:show help for a command'
    )
    _describe -t commands 'kubie command' commands && ret=0
    ;;
  args)
    case $words[1] in
      ctx)
        _arguments -s -S \
          '(-n --namespace)'{-n+,--namespace=}'[namespace to spawn shell in]:namespace:' \
          '*'{-f+,--kubeconfig=}'[files to load contexts from]:file:_files' \
          '(-r --recursive)'{-r,--recursive}'[enter the context by spawning a recursive shell]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:context:' \
          && ret=0
        ;;
      ns)
        _arguments -s -S \
          '(-r --recursive)'{-r,--recursive}'[enter namespace via a recursive shell]' \
          '(-u --unset)'{-u,--unset}'[unset namespace in the currently active context]' \
          '(- *)'{-h,--help}'[show help]' \
          '1:namespace:' \
          && ret=0
        ;;
      exec)
        _arguments -s -S \
          '(-e --exit-early)'{-e,--exit-early}'[exit early if a command fails when using a wildcard context]' \
          '--context-headers=[override behavior.print_context_in_exec]:behavior:(auto always never)' \
          '(- *)'{-h,--help}'[show help]' \
          '1:context:' \
          '2:namespace:' \
          '*:command:_normal' \
          && ret=0
        ;;
      info)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:info kind:(ctx ns depth)' \
          && ret=0
        ;;
      export)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:context:' \
          '2:namespace:' \
          && ret=0
        ;;
      edit|delete)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:context:' \
          && ret=0
        ;;
      generate-completion)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          '1:shell:(bash elvish fish powershell zsh)' \
          && ret=0
        ;;
      lint|edit-config|update)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
