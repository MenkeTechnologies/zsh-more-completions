#compdef fengari fengaric
# ============================================================================
# _fengari — zsh completion for fengari-lua/fengari-node-cli, "The Lua
#             command-line application, but using Fengari under Node" —
#             TS-Node=156 leader bump CLOSING Axis 101 Lua/Luau bindings at
#             1/1/1 three-language symmetry (triple-156 landmark and 94th
#             axis closed).
#             Covers both reference Lua-CLI mirrors:
#               fengari   — equivalent of `lua` (interpreter / REPL)
#               fengaric  — equivalent of `luac` (compiler / bytecode dump)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/fengari-lua/fengari-node-cli
#   Maintainer : fengari-lua  (Fengari project's own org —
#                Daurnimator + contributors)
#   License    : MIT
#   Stars      : 35
#   Language   : JavaScript (Node.js)
#   Module     : fengari-node-cli  (npm package name)
#   Binaries   : fengari   (package.json bin: "./src/lua-cli.js")
#                fengaric  (package.json bin: "./src/luac-cli.js")
#   Last push  : 2021-06-23
#
# WHAT IT IS
#   Fengari is the canonical pure-JS implementation of Lua 5.3,
#   written in ECMAScript 6+ — a *direct, line-for-line port*
#   of the reference C implementation's interpreter and standard
#   library.  fengari-node-cli is the official command-line
#   wrapper that lets you invoke Lua 5.3 as a Node binary:
#   `fengari` mirrors the reference `lua` interpreter (with the
#   same flag surface and REPL loop), `fengaric` mirrors the
#   reference `luac` bytecode compiler.  Behavior matches the
#   Lua reference manual section 7 — flags, environment
#   variables (`LUA_INIT`, `LUA_PATH`, `LUA_CPATH`,
#   `LUA_INIT_5_3`, `LUA_PATH_5_3`, `LUA_CPATH_5_3`),
#   interactive prompts (`_PROMPT`, `_PROMPT2`),
#   error-handling, and `__tostring` metamethod dispatch all
#   resolve byte-for-byte the way they do under upstream Lua.
#
#   Use this binary when you need a `lua`-compatible binary
#   inside a Node environment that doesn't ship `lua` itself —
#   CI runners, ephemeral Docker images, npx-driven test
#   harnesses, browser-targeted build pipelines that emit Lua
#   bytecode through `fengaric -o`, or anywhere you want the
#   Lua wire-compatibility surface without compiling a native
#   binary.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/lua-cli.js
#                       `print_usage` text + src/luac-cli.js
#                       `usage` text; extracted via `gh api
#                       repos/fengari-lua/fengari-node-cli/
#                       contents/src/lua-cli.js` and
#                       `src/luac-cli.js`)
#
#   fengari [OPTIONS] [<SCRIPT> [<ARGS>...]]
#                                    (the Lua interpreter —
#                                    drop-in replacement for
#                                    `lua`)
#
#   Options:
#     -e <STAT>                      Execute string `STAT`
#                                    (repeatable — each `-e`
#                                    runs before the script,
#                                    in argv order)
#     -i                             Enter interactive mode
#                                    after executing the script
#                                    (default REPL when no
#                                    SCRIPT is given)
#     -l <NAME>                      Require library `NAME`
#                                    before script runs
#                                    (repeatable)
#     -v                             Show version information
#     -E                             Ignore environment
#                                    variables (skip
#                                    `LUA_INIT`, `LUA_PATH`,
#                                    `LUA_CPATH` lookups)
#     --                             Stop handling options
#                                    (everything after is
#                                    treated as the script
#                                    name + args)
#     -                              Stop handling options and
#                                    execute stdin (read the
#                                    Lua source from stdin)
#
#   fengaric [OPTIONS] [<FILENAME>]
#                                    (the Lua compiler — drop-in
#                                    replacement for `luac`;
#                                    emits Lua 5.3 bytecode to
#                                    `OUTPUT` or stdout)
#
#   Options:
#     -l                             List (use `-l -l` for full
#                                    listing — disassembled
#                                    bytecode with constant
#                                    table, debug info, and
#                                    per-instruction line
#                                    numbers)
#     -o <NAME>                      Output to file `NAME`
#                                    [default: luac.out]
#     -p                             Parse only (don't emit
#                                    output)
#     -s                             Strip debug information
#                                    (no line-numbers in the
#                                    output bytecode)
#     -v                             Show version information
#     --                             Stop handling options
#     -                              Stop handling options and
#                                    process stdin
#
# AXIS / CORPUS POSITION
#   Direct dependency on `fengari ^0.1.0` declared in
#   package.json — `fengari` is THE canonical pure-JavaScript
#   implementation of Lua 5.3, maintained by the fengari-lua
#   project led by Daurnimator (fengari-lua/fengari, 2,400+
#   stars; the predominant pure-JS Lua 5.3 implementation
#   used by Brython-style polyglot tooling, the Roblox-style
#   playground at love2d-online, the WebTorrent peer-script
#   sandbox, classroom-targeted Lua REPLs that run in the
#   browser, and every downstream Fengari consumer including
#   `fengari-web` for browser bundles and `fengari-interop`
#   for two-way JS↔Lua marshalling).
#   `fengari` exposes the typed `luaL_newstate()` factory
#   returning an `LState` object, the typed
#   `lua_pcall(L, nargs, nres, errfunc)` /
#   `luaL_loadbuffer(L, buf, len, name)` /
#   `luaL_loadfile(L, name)` /
#   `lua_getglobal(L, name)` / `lua_setglobal(L, name)` /
#   `lua_createtable(L, narr, nrec)` /
#   `lua_pushcfunction(L, fn)` /
#   `lua_pushstring(L, str)` /
#   `lua_pushliteral(L, str)` /
#   `lua_pushboolean(L, b)` /
#   `lua_pushnumber(L, n)` /
#   `lua_pushinteger(L, i)` /
#   `lua_pushnil(L)` /
#   `lua_pushvalue(L, idx)` /
#   `lua_setfield(L, idx, k)` / `lua_getfield(L, idx, k)` /
#   `lua_rawgeti(L, idx, n)` / `lua_rawseti(L, idx, n)` /
#   `lua_seti(L, idx, n)` / `lua_geti(L, idx, n)` /
#   `lua_settop(L, n)` / `lua_gettop(L)` /
#   `lua_remove(L, idx)` / `lua_insert(L, idx)` /
#   `lua_pop(L, n)` /
#   `lua_type(L, idx)` / `lua_tojsstring(L, idx)` /
#   `lua_tostring(L, idx)` /
#   `lua_tonumber(L, idx)` / `lua_tointeger(L, idx)` /
#   `lua_toboolean(L, idx)` /
#   `lua_topointer(L, idx)` /
#   `lua_call(L, nargs, nres)` /
#   `lua_xmove(from, to, n)` /
#   `lua_status(L)` /
#   `lua_resume(L, from, narg)` /
#   `lua_isstring(L, idx)` / `lua_isnumber(L, idx)` /
#   `lua_isfunction(L, idx)` / `lua_istable(L, idx)` /
#   `lua_isnil(L, idx)` / `lua_isthread(L, idx)` /
#   `lua_iscfunction(L, idx)` /
#   `luaL_typename(L, idx)` /
#   `luaL_traceback(L, L1, msg, level)` /
#   `luaL_callmeta(L, idx, method)` /
#   `luaL_error(L, fmt, args...)` /
#   `luaL_openlibs(L)` /
#   `lua_writestringerror(s)` primitives, plus the helper
#   `to_jsstring(luaString)` / `to_luastring(jsString)`
#   conversion utilities for the JS↔Lua string boundary
#   (fengari distinguishes them explicitly because Lua strings
#   are byte arrays, not UTF-16 like JS strings).
#   fengari-node-cli's `src/lua-cli.js` wraps `luaL_newstate()`
#   per CLI invocation, opens all standard libraries via
#   `luaL_openlibs(L)`, parses argv against the reference
#   `lua` flag set, loads `LUA_INIT` / `LUA_INIT_5_3` from the
#   environment (unless `-E` is set), and dispatches between
#   `dofile` / `dostring` / `dolibrary` / interactive REPL
#   based on the flag combination — line-for-line a
#   reimplementation of the reference `lua.c` driver inside
#   the Fengari VM.  Verified via:
#     gh api repos/fengari-lua/fengari-node-cli/contents/
#         package.json
#       → "fengari": "^0.1.0"
#       → "readline-sync": "^1.4.7"
#       → "sprintf-js": "^1.1.1"
#       → bin: { "fengari": "./src/lua-cli.js",
#                 "fengaric": "./src/luac-cli.js" }
#     gh api repos/fengari-lua/fengari-node-cli/contents/
#         src/lua-cli.js
#       → require('fengari') → { lua, lauxlib, lualib,
#                                  FENGARI_COPYRIGHT,
#                                  to_jsstring, to_luastring }
#       → print_usage prints the verbatim Lua-reference
#         option set: -e stat / -i / -l name / -v / -E /
#                       -- / -
#     gh api repos/fengari-lua/fengari-node-cli/contents/
#         src/luac-cli.js
#       → usage prints the verbatim luac-reference option
#         set: -l (use -l -l for full) / -o name (default
#         "luac.out") / -p / -s / -v / -- / -
#   This entry is the TS-Node=156 leader bump that CLOSES Axis
#   101 (Lua/Luau bindings) at 1/1/1 three-language symmetry —
#   triple-156 landmark and the 94th axis closed.  Pairings:
#     Rust=156   : lune-org/lune on mlua v0.11.6 (luau feature)
#                  (_lune, R993 — Axis 101 OPENED)
#     Go=156     : gvcgo/version-manager on yuin/gopher-lua
#                  v1.1.1 (_vmr, R994)
#     TS-Node=156: fengari-lua/fengari-node-cli on fengari
#                  ^0.1.0 (this file, R995 — Axis 101 CLOSED;
#                  covers fengari + fengaric binaries via
#                  #compdef)
#
#   No completion for `fengari` or `fengaric` ships with Apple
#   zsh (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_fengari() {
    case "${service:-${words[1]}}" in
        fengaric)
            _arguments -s \
                '-l[list (use -l -l for full listing — disassembled bytecode)]' \
                '-o+[output to file (default luac.out)]:name:_files' \
                '-p[parse only (do not emit output)]' \
                '-s[strip debug information]' \
                '-v[show version information]' \
                '*:Lua source file:_files -g "*.lua"' ;;
        fengari|*)
            _arguments -s \
                '*-e+[execute string `stat` (repeatable)]:stat:' \
                '-i[enter interactive mode after executing script]' \
                '*-l+[require library `name` (repeatable)]:name:' \
                '-v[show version information]' \
                '-E[ignore environment variables (LUA_INIT, LUA_PATH, LUA_CPATH)]' \
                '*:Lua script:_files -g "*.lua"' ;;
    esac
}

_fengari "$@"
