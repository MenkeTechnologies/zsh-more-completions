#compdef pptp pptpclient
# _pptpclient — pptpclient pptp (PPTP VPN client wrapper that opens the GRE tunnel and exec()s pppd with a routing-aware peer; --quirks platform quirks, --idle-wait seconds, --max-echo-wait seconds, --debug verbose, --localbind src ip, --nolaunchpppd skip pppd; positional argument is the PPTP server host then optional pppd extra args after `--`)
# upstream: https://sourceforge.net/projects/pptpclient
# Flags from pptpclient pptp.c on tip.

_pptpclient() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--quirks+[platform quirks]:quirks:' \
        '--idle-wait+[seconds]:seconds:' \
        '--max-echo-wait+[seconds]:seconds:' \
        '--debug[debug]' \
        '--localbind+[source address]:addr:' \
        '--nolaunchpppd[do not launch pppd]' \
        '--phone+[phone number]:phone:' \
        '--logstring+[log string]:str:' \
        '1:PPTP server:_hosts' \
        '*::pppd args:'
}

_pptpclient "$@"
