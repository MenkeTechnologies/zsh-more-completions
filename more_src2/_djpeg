#compdef djpeg
# Documentation: https://manpages.debian.org/djpeg.1
# Source: libjpeg / mozjpeg — JPEG decoder.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-colors -quantize)-colors[reduce to N colors]:n:' \
    '(-colors -quantize)-quantize[same as -colors]:n:' \
    '-fast[fast / low-quality processing options]' \
    '(-grayscale -rgb)-grayscale[force grayscale output]' \
    '(-grayscale -rgb)-rgb[force RGB output]' \
    '-scale[scale output by M/N]:M/N:' \
    '(-bmp -gif -gif0 -os2 -pnm -targa)-bmp[output BMP (Windows flavor)]' \
    '(-bmp -gif -gif0 -os2 -pnm -targa)-gif[output GIF (LZW)]' \
    '(-bmp -gif -gif0 -os2 -pnm -targa)-gif0[output GIF (uncompressed)]' \
    '(-bmp -gif -gif0 -os2 -pnm -targa)-os2[output BMP (OS/2 1.x)]' \
    '(-bmp -gif -gif0 -os2 -pnm -targa)-pnm[output PNM / PPM / PGM (default)]' \
    '(-bmp -gif -gif0 -os2 -pnm -targa)-targa[output Targa]' \
    '-dct[DCT method]:method:(int fast float)' \
    '-dither[color quantization dithering]:mode:(fs ordered none)' \
    '-icc[extract ICC profile to file]:file:_files' \
    '-map[quantize to colors used in image file]:file:_files' \
    '-nosmooth[fast lower-quality upsampling]' \
    '-onepass[one-pass color quantization]' \
    '-maxmemory[memory limit (KB)]:n:' \
    '-maxscans[abort if input > N scans]:n:' \
    '-outfile[output file]:file:_files' \
    '-memsrc[load input into memory before decompressing]' \
    '-report[report progress]' \
    '-skip[decompress all rows except Y0..Y1]:Y0,Y1:' \
    '-crop[decompress only WxH+X+Y subregion]:geometry:' \
    '-strict[treat warnings as fatal]' \
    '-verbose[debug printout]' \
    '-debug[debug printout (alias)]' \
    '(- *)-version[print version]' \
    '*:input .jpg:_files -g "*.(jpg|jpeg|jpe|jif|jfif|jfi)"' \
    && ret=0

return ret
