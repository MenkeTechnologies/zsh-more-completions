#compdef designspaceLib designspace
# _designspaceLib — fonttools designspaceLib CLI for reading writing manipulating variable-font .designspace files axes mappings sources instances rules conditions Adobe-compatible variation document (fonttools team, Python); argparse
# upstream: https://github.com/fonttools/fonttools

_designspaceLib() {
    local -a sub=(
        'show:show designspace info'
        'validate:validate designspace'
        'add-axis:add axis to designspace'
        'remove-axis:remove axis'
        'add-source:add source master'
        'remove-source:remove source master'
        'add-instance:add instance'
        'remove-instance:remove instance'
        'add-rule:add rule'
        'remove-rule:remove rule'
        'compile:compile to variable TTF/OTF'
        'normalize:normalize axis-values'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'designspaceLib subcommand' sub ;;
        args)
            case $words[1] in
                add-axis) _arguments \
                    '--name=+[name]:str:' \
                    '--tag=+[tag]:str:' \
                    '--minimum=+[F]:f:' \
                    '--default=+[F]:f:' \
                    '--maximum=+[F]:f:' \
                    '--label-name=+[name]:str:' \
                    '--hidden[hidden]' \
                    '*:designspace:_files -g "*.designspace"' ;;
                add-source|add-instance) _arguments \
                    '--font-file=+[file]:file:_files -g "*.ufo *.otf *.ttf"' \
                    '--family-name=+[name]:str:' \
                    '--style-name=+[name]:str:' \
                    '--location=+[csv axis=value]:str:' \
                    '*:designspace:_files -g "*.designspace"' ;;
                compile) _arguments \
                    '-o+[dir]:dir:_files -/' \
                    '--format=+[f]:f:(ttf otf)' \
                    '--variable[build variable]' \
                    '--instances[build instances]' \
                    '*:designspace:_files -g "*.designspace"' ;;
                show|validate|normalize) _arguments '*:designspace:_files -g "*.designspace"' ;;
            esac
            ;;
    esac
}

_designspaceLib "$@"
