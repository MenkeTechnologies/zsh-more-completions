#compdef forta-agent
# ============================================================================
# _forta-agent — zsh completion for the Forta Detection Bot SDK CLI
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/forta-network/forta-bot-sdk
#   npm        : https://www.npmjs.com/package/forta-agent
#   Homepage   : https://forta.org/
#   Docs       : https://docs.forta.network
#   Version    : 0.1.48 (latest published on npm)
#   License    : MIT
#   Stars      : 71
#   Language   : TypeScript
#
# WHAT IT IS
#   forta-agent is the official npm-published TypeScript/JavaScript SDK + CLI
#   for building, running, publishing, and managing detection bots that run on
#   the Forta Network — a decentralized monitoring system for EVM-compatible
#   blockchains.  The package was previously named `forta-agent-sdk`;  the
#   repository was renamed to `forta-bot-sdk` but the npm binary continues to
#   ship as `forta-agent` (`bin.forta-agent` → `dist/cli/index.js`).
#
# CLI ARGUMENT GRAMMAR  (verbatim from cli/index.ts yargs definitions)
#   forta-agent <command> [flags]
#
#   Commands:
#     init        Initialize a Forta Agent project
#                   --typescript    initialize as TypeScript project
#                   --python        initialize as Python project
#     info        Inspect state of the Forta Bot
#                   --agentId <id>  bot id to inspect (default this agent)
#     run         Run the Forta Agent with latest blockchain data
#                   --tx <hash>           run with specified tx hash
#                   --block <hash|num>    run with specified block
#                   --alert <hash>        run with specified alert hash
#                   --sequence <list>     run with sequence of tx/block/alerts
#                   --range <start..end>  run with block range (e.g. 15..20)
#                   --file <path>         run with json file fixture
#                   --prod                production server mode for Scanner
#                   --config <path>       config file (default forta.config.json)
#                   --nocache             disable cache writes
#     publish     Publish the Forta Agent to the network
#                   --config <path>       config file
#     push        Push the Forta Agent image to the repository
#                   --config <path>       config file
#                   --manifest            also upload the manifest
#     stake       Stake on a Forta Agent
#                   --agentId <id>        agent to stake on (default this one)
#     disable     Disables the Forta Agent
#     enable      Enables the Forta Agent
#     keyfile     Prints out keyfile information
#     logs        Retrieve logs on Forta Agent
#                   --after <ISO>         oldest timestamp to include
#                   --before <ISO>        latest timestamp to include
#                   --scannerId <id>      filter by scanner id
#                   --agentId <id>        bot id (default this one)
#
# AXIS / CORPUS POSITION
#   Direct dependency on @grpc/grpc-js (^1.3.6) — the official pure-JS gRPC
#   client/server library maintained by Google's grpc-ecosystem org, used by
#   forta-agent's run command to expose the bot's handleTransaction /
#   handleBlock / handleAlert / handleHealth RPC services consumed by the
#   Forta Scanner.  Verified via:
#     gh api repos/forta-network/forta-bot-sdk/contents/package.json
#     npm view forta-agent dependencies
#   This entry is the TS-Node pole of the gRPC Framework axis, paired with
#   Rust=tonic and Go=google.golang.org/grpc on the other two poles.
#
#   No completion for `forta-agent` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_forta-agent() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help and exit]' \
        '(- *)'{-v,--version}'[show version number]' \
        '1: :_forta-agent_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                init)      _forta-agent_init      && ret=0 ;;
                info)      _forta-agent_info      && ret=0 ;;
                run)       _forta-agent_run       && ret=0 ;;
                publish)   _forta-agent_publish   && ret=0 ;;
                push)      _forta-agent_push      && ret=0 ;;
                stake)     _forta-agent_stake     && ret=0 ;;
                disable)   _forta-agent_disable   && ret=0 ;;
                enable)    _forta-agent_enable    && ret=0 ;;
                keyfile)   _forta-agent_keyfile   && ret=0 ;;
                logs)      _forta-agent_logs      && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_forta-agent_commands] )) ||
_forta-agent_commands() {
    local -a commands
    commands=(
        'init:initialize a Forta Agent project (--typescript or --python scaffold)'
        'info:inspect state of the Forta Bot (chain settings, manifest, health)'
        'run:run the Forta Agent against latest blockchain data or fixtures'
        'publish:publish the Forta Agent to the network (writes on-chain manifest)'
        'push:push the Forta Agent docker image to the repository'
        'stake:stake on a Forta Agent to activate it on the network'
        'disable:disable the Forta Agent (remove from active scanning)'
        'enable:enable the Forta Agent (re-enroll into scanning)'
        'keyfile:print out keyfile information (address, encrypted JSON path)'
        'logs:retrieve logs from the Forta Agent for a time window'
    )
    _describe -t commands 'forta-agent command' commands
}

(( $+functions[_forta-agent_init] )) ||
_forta-agent_init() {
    _arguments \
        '(--python)--typescript[initialize as TypeScript project]' \
        '(--typescript)--python[initialize as Python project]' \
        '(- *)'{-h,--help}'[show help for init]'
}

(( $+functions[_forta-agent_info] )) ||
_forta-agent_info() {
    _arguments \
        '--agentId=[bot id to retrieve information for (default this agent)]:agent id:' \
        '(- *)'{-h,--help}'[show help for info]'
}

(( $+functions[_forta-agent_run] )) ||
_forta-agent_run() {
    _arguments \
        '--tx=[run with the specified transaction hash]:tx hash:' \
        '--block=[run with the specified block hash or number]:block id:' \
        '--alert=[run with the specified alert hash]:alert hash:' \
        '--sequence=[run with the specified sequence of tx hash, block number or alert hash]:sequence:' \
        '--range=[run with the specified block range (e.g. 15..20)]:block range:' \
        '--file=[run with the specified json fixture file]:fixture json:_files -g "*.json"' \
        '--prod[run a server listening for events from a Forta Scanner]' \
        '--config=[specify a config file (default forta.config.json)]:config file:_files -g "*.(json|jsonc)"' \
        '--nocache=[disable cache writes (reads remain enabled)]:nocache:(true false)' \
        '(- *)'{-h,--help}'[show help for run]'
}

(( $+functions[_forta-agent_publish] )) ||
_forta-agent_publish() {
    _arguments \
        '--config=[specify a config file (default forta.config.json)]:config file:_files -g "*.(json|jsonc)"' \
        '(- *)'{-h,--help}'[show help for publish]'
}

(( $+functions[_forta-agent_push] )) ||
_forta-agent_push() {
    _arguments \
        '--config=[specify a config file (default forta.config.json)]:config file:_files -g "*.(json|jsonc)"' \
        '--manifest[upload the manifest after pushing the image]' \
        '(- *)'{-h,--help}'[show help for push]'
}

(( $+functions[_forta-agent_stake] )) ||
_forta-agent_stake() {
    _arguments \
        '--agentId=[specify an agent to stake on (default this agent)]:agent id:' \
        '(- *)'{-h,--help}'[show help for stake]'
}

(( $+functions[_forta-agent_disable] )) ||
_forta-agent_disable() {
    _arguments \
        '(- *)'{-h,--help}'[show help for disable]'
}

(( $+functions[_forta-agent_enable] )) ||
_forta-agent_enable() {
    _arguments \
        '(- *)'{-h,--help}'[show help for enable]'
}

(( $+functions[_forta-agent_keyfile] )) ||
_forta-agent_keyfile() {
    _arguments \
        '(- *)'{-h,--help}'[show help for keyfile]'
}

(( $+functions[_forta-agent_logs] )) ||
_forta-agent_logs() {
    _arguments \
        '--after=[ISO timestamp of the oldest time to include in logs]:ISO timestamp:' \
        '--before=[ISO timestamp of the latest time to include in logs]:ISO timestamp:' \
        '--scannerId=[only return logs for specified scanner id]:scanner id:' \
        '--agentId=[agent id to retrieve logs for (default this agent)]:agent id:' \
        '(- *)'{-h,--help}'[show help for logs]'
}

_forta-agent "$@"
