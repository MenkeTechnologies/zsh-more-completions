#compdef freak
# Documentation: https://emboss.bioinformatics.nl/cgi-bin/emboss/help/freak
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS freak: residue/base frequency along a window
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-seqall=[input sequence(s)]:sequence USA:_files' \
  '-letters=[residues to count (one-letter codes)]:codes:' \
  '-window=[window size]:size:' \
  '-step=[step between windows]:step:' \
  '-plot[produce graph output]' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-outfile=[report output file]:file:_files' \
  '*:sequence USA:_files' && ret=0
return ret
