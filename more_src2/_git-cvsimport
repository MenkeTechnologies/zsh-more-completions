#compdef git-cvsimport
# Documentation: https://git-scm.com/docs/git-cvsimport
# Source: git/git git-cvsimport.perl — import a CVS module into Git (Perl, Getopt::Std).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output]' \
    '-o+[branch for CVS HEAD]:branch:_default' \
    '-d+[CVSROOT]:cvsroot:_default' \
    '-A+[author conversion file]:file:_files' \
    '-p+[options for cvsps]:opts:_default' \
    '-P+[take CVS revisions from file]:file:_files' \
    '-C+[git repository]:dir:_files -/' \
    '-z+[fuzz time in seconds for commit grouping]:fuzz:_default' \
    '-i[do not perform CVS-to-Git import]' \
    '-k[strip keyword expansion]' \
    '-u[convert \\r\\n to \\n]' \
    '-s+[substitute character in branch names]:subst:_default' \
    '-a[import all branches/tags]' \
    '-m[attempt to detect merges based on commit message]' \
    '*-M+[regex used to detect merges]:regex:_default' \
    '-S+[regex to skip CVS revisions]:regex:_default' \
    '-L+[commit limit]:n:_default' \
    '-r+[remote-tracking branch prefix]:remote:_default' \
    '-R[generate cvs-revisions file]' \
    '1::CVS module:_default' \
    && ret=0

return ret
