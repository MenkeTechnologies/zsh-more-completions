#compdef llvm-diff
# _llvm-diff — LLVM IR semantic diff tool (LLVM project, C++); structural compare of two LLVM IR modules
# upstream: https://github.com/llvm/llvm-project

_llvm-diff() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '*:file:_files -g "*.(bc|ll)"'
}

_llvm-diff "$@"
