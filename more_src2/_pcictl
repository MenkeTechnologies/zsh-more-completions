#compdef pcictl
# Documentation: man pcictl(8)
# Source: netbsd/src usr.sbin/pcictl — manipulate the PCI bus (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-N[display attached driver names]' \
    '-n[list devices as numbers instead of names]' \
    '-b+[PCI bus number]:bus:_default' \
    '-d+[PCI device number]:device:_default' \
    '-f+[PCI function (default 0)]:function:_default' \
    '1:PCI bus device:_files' \
    '2::command:(list dump read write)' \
    '*::register or value:_default' \
    && ret=0

return ret
