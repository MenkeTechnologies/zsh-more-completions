#compdef keploy
# Documentation: https://keploy.io/docs/running-keploy/cli-commands/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_keploy_commands() {
  local -a commands=(
    'record:Record API calls as test cases and mocks'
    'test:Run recorded test cases and execute assertions'
    'gen:Generate unit tests using an LLM (deprecated)'
    'normalize:Update test responses based on latest runs'
    'rerecord:Re-record existing test cases'
    'report:Display detailed test result summaries'
    'templatize:Parameterize dynamic field values'
    'config:Generate keploy.yaml configuration file'
    'example:Show usage scenarios for various setups'
    'completion:Generate shell completion'
    'help:Show help'
  )
  _describe -t commands 'keploy command' commands
}

_keploy() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[Show help]' \
    '1:command:_keploy_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        record)
          _arguments \
            '(-c --command)'{-c+,--command=}'[Command to run]:command:' \
            '(-p --path)'{-p+,--path=}'[Path to store test cases]:path:_directories' \
            '(-d --delay)'{-d+,--delay=}'[Delay in seconds before running app]:seconds:' \
            '--config-path=[Path to config file]:file:_files' \
            '--container-name=[Docker container name]:container:' \
            '(-n --network-name)'{-n+,--network-name=}'[Docker network name]:network:' \
            '--pass-through-ports=[Ports to pass through]:ports:' \
            '--proxy-port=[Proxy port]:port:' \
            '--metadata=[Metadata]:metadata:' \
            '--rerecord=[Test set to re-record]:testset:' \
            '--debug[Enable debug mode]'
          ;;
        test)
          _arguments \
            '(-c --command)'{-c+,--command=}'[Command to run]:command:' \
            '(-p --path)'{-p+,--path=}'[Path to test cases]:path:_directories' \
            '(-d --delay)'{-d+,--delay=}'[Delay in seconds before running app]:seconds:' \
            '--api-timeout=[API timeout in seconds]:seconds:' \
            '--config-path=[Path to config file]:file:_files' \
            '--container-name=[Docker container name]:container:' \
            '(-n --network-name)'{-n+,--network-name=}'[Docker network name]:network:' \
            '--pass-through-ports=[Ports to pass through]:ports:' \
            '--proxy-port=[Proxy port]:port:' \
            '(-t --test-sets)'{-t+,--test-sets=}'[Test sets to run]:testsets:' \
            '(-g --generate-test-report)'{-g+,--generate-test-report=}'[Generate test report]:bool:(true false)' \
            '--remove-unused-mocks[Remove unused mocks]' \
            '--ignore-ordering[Ignore response ordering]' \
            '--skip-preview[Skip preview]'
          ;;
        config)
          local -a subcommands=(
            'generate:Generate config file'
          )
          _describe -t subcommands 'config subcommand' subcommands
          ;;
        completion)
          _arguments '1:shell:(bash zsh fish powershell)'
          ;;
      esac
      ;;
  esac
}

_keploy "$@"
