#compdef questdb
# Documentation: https://github.com/questdb/questdb/blob/master/core/src/main/bin/questdb.sh
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for questdb - QuestDB time-series database

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:start QuestDB'
  'stop:stop QuestDB'
  'status:show QuestDB status'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'questdb command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start)
        _arguments -s -S \
          '-d[root directory]:directory:_files -/' \
          '-f[force overwrite of public dir]' \
          '-n[disable HUP signal handler]' \
          '-c[container mode]' \
          '-p[enable profiling]' \
          '-t[process tag]:tag' && ret=0
        ;;
      (stop)
        _arguments -s -S \
          '-t[process tag]:tag' && ret=0
        ;;
      (status)
        _arguments -s -S \
          '-t[process tag]:tag' && ret=0
        ;;
    esac
    ;;
esac

return ret
