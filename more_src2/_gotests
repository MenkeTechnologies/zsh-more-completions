#compdef gotests
# Documentation: https://github.com/cweill/gotests
# Reference accessed: 2026-05-16
# Verified: cweill/gotests upstream README flags table.
# Removed from prior file: bogus man.archlinux.org search URL;
# missing -template (real flag is -template NAME with options like
# testify), -template_params, -template_params_file, -use_go_cmp,
# AI flags, -version. Fixed incorrect -named description.

# gotests: Go test stub generator from function signatures
local curcontext="$curcontext" ret=1
_arguments -C \
  '-all[generate tests for all functions and methods]' \
  '-excl=[regex for functions/methods to exclude]:regex:' \
  '-exported[generate tests only for exported functions]' \
  '-i[print test inputs in errors]' \
  '-named[map-based table tests with named cases]' \
  '-only=[regex for functions/methods to include]:regex:' \
  '-nosubtests[disable subtests]' \
  '-parallel[enable parallel subtests]' \
  '-w[write output to test files]' \
  '-template=[named template]:name:(testify)' \
  '-template_dir=[custom template directory]:dir:_files -/' \
  '-template_params=[JSON template parameters]:json:' \
  '-template_params_file=[template parameters file]:file:_files' \
  '-use_go_cmp[use go-cmp for comparisons]' \
  '-ai[use AI to generate test cases]' \
  '-ai-model=[AI model]:model:' \
  '-ai-endpoint=[AI endpoint]:url:' \
  '-ai-min-cases=[min AI test cases]:n:' \
  '-ai-max-cases=[max AI test cases]:n:' \
  '-version[show version]' \
  '*:go file or dir:_files -g "*.go(-.)"' && ret=0
return ret
