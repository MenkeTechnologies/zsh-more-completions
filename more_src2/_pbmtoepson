#compdef pbmtoepson
# Documentation: man pbmtoepson (Netpbm)
# Source: convert a PBM image to an Epson ESC printer command stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dpi=[output resolution]:n:' \
    '-protocol=[Epson printer protocol]:protocol:(escp9 escp)' \
    '(-adjacent -nonadjacent)-adjacent[print adjacent pins]' \
    '(-adjacent -nonadjacent)-nonadjacent[skip adjacent pins]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
