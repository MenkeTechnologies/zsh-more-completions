#compdef manticore
# Documentation: https://github.com/trailofbits/manticore
# Reference accessed: 2026-05-19
# Verified: upstream source (manticore/__main__.py) at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '*-v[increase verbosity]' \
  '--config=[YAML config file]:file:_files' \
  '--workspace=[workspace directory]:dir:_files -/' \
  '--no-colors[disable colored output]' \
  '--policy=[exploration policy]:p:(random adhoc uncovered dicount icount syscount depth)' \
  '--coverage=[output file for coverage data]:file:_files' \
  '--entrysymbol=[entry point symbol]:symbol:' \
  '--data=[initial concrete data]:data:' \
  '--file=[symbolic input file]:file:_files' \
  '--env=[environment variable]:env:' \
  '--pure-symbolic[treat all writable memory as symbolic]' \
  '--verbose-trace[dump verbose trace per state]' \
  '--txlimit=[max symbolic transactions]:n:' \
  '--txnocoverage[disable coverage stopping criteria]' \
  '--txnoether[skip ether transmission attempts]' \
  '--txaccount=[caller account type]:t:(attacker owner combo1)' \
  '--txpreconstrain[constrain transactions]' \
  '--contract=[contract name]:name:' \
  '--avoid-constant[avoid constant function calls]' \
  '--limit-loops[limit symbolic loops]' \
  '--no-testcases[do not generate test cases]' \
  '--only-alive-testcases[only alive test cases]' \
  '--thorough-mode[enable exhaustive exploration]' \
  '--list-detectors[list available detectors]' \
  '--exclude=[exclude detector(s) csv]:list:' \
  '--exclude-all[skip all detectors]' \
  '*:argv:_files' && ret=0

return ret
