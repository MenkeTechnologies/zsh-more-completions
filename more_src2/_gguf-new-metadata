#compdef gguf-new-metadata
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/gguf-py/gguf/scripts/gguf_new_metadata.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse in gguf-py/gguf/scripts/gguf_new_metadata.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--general-name=[set general.name metadata]:name' \
  '--general-description=[set general.description metadata]:description' \
  '--chat-template=[chat template string (or JSON string containing templates)]:template' \
  '--chat-template-config=[config file containing chat template(s)]:file:_files' \
  '--chat-template-file=[Jinja file containing chat template]:file:_files -g "*.jinja"' \
  '--pre-tokenizer=[set tokenizer.ggml.pre metadata]:pre-tokenizer' \
  '*--remove-metadata=[remove metadata by key from output model]:key' \
  '*--special-token=[set special token by value]:token:->st' \
  '*--special-token-by-id=[set special token by id]:token:->stid' \
  '--force[bypass warnings without confirmation]' \
  '--verbose[increase output verbosity]' \
  '1:input GGUF model:_files -g "*.gguf"' \
  '2:output GGUF model:_files -g "*.gguf"' && ret=0

return ret
