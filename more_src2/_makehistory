#compdef makehistory
# Documentation: man makehistory(8)
# Source: InterNetNews/inn expire/makehistory.c — rebuild history and overview from spool (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[append mode]' \
    '-b[delete articles with bad/missing required headers]' \
    '-F[fork to process overview generation]' \
    '-f+[history file path]:file:_files' \
    '-I[ignore articles below low-mark]' \
    '-l+[overview tmp seg size]:size:_default' \
    '-L+[load average threshold]:load:_default' \
    '-O[create overview]' \
    '-S[write overview to stdout, do not store]' \
    '-s+[history size hint (number of pairs)]:N:_default' \
    '-T+[temporary directory]:dir:_files -/' \
    '-x[do not write history]' \
    && ret=0

return ret
