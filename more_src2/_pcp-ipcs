#compdef pcp-ipcs
# Documentation: https://man7.org/linux/man-pages/man1/pcp-ipcs.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-l[show resource limits]' \
  '--limits[show resource limits]' \
  '-u[show status summary]' \
  '--summary[show status summary]' \
  '-i+[print details on the resource identified by id]:id:' \
  '--id=[print details on the resource identified by id]:id:' \
  '-m[display active shared memory segments]' \
  '--shmems[display active shared memory segments]' \
  '-q[display active message queues]' \
  '--queues[display active message queues]' \
  '-s[display active semaphore sets]' \
  '--semaphores[display active semaphore sets]' \
  '-a[display information for all three resources]' \
  '--all[display information for all three resources]' \
  '-c[show creator and owner details]' \
  '--creator[show creator and owner details]' \
  '-t[show time information]' \
  '--time[show time information]' \
  '-p[show PIDs of creator and last operator]' \
  '--pid[show PIDs of creator and last operator]' \
  '-b[present sizes in bytes]' \
  '--bytes[present sizes in bytes]' \
  '--human[present sizes in human-readable format]' \
  '-h+[target host]:host:_hosts' \
  '--host=[target host]:host:_hosts' \
  '--archive=[archive source]:archive:_files' \
  '-O+[time origin]:time:' \
  '--origin=[time origin]:time:' \
  '-Z+[timezone specification]:tz:' \
  '--timezone=[timezone specification]:tz:' && ret=0

return ret
