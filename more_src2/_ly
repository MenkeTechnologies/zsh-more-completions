#compdef ly
# Documentation: https://github.com/fairyglade/ly/blob/master/src/main.zig
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show all commands]' \
  '(-v --version)'{-v,--version}'[show ly version]' \
  '(-c --config)'{-c,--config=}'[override default configuration path]:config dir:_files -/' \
  '--use-kmscon-vt[use KMSCON instead of kernel VT]' \
  '--validate-config=[validate the given configuration file]:config file:_files' && ret=0

return ret
