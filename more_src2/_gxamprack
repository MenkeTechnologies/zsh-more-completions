#compdef gxamprack
# _gxamprack — Hermann Meyer Guitarix gxamprack standalone amplifier rack focused on selectable amp models impulse response cabinet sim and effect rack chain (guitarix team, C++/GTK); GOption
# upstream: https://github.com/brummer10/guitarix

_gxamprack() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--help-all[show all help]' \
        '--help-gtk[GTK help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[debug level]:n:' \
        '--debug=+[debug level]:n:' \
        '-n+[client name]:str:' \
        '--name=+[client name]:str:' \
        '-r+[rcfile]:file:_files -g "*.gx *.gxrc *.gxprs"' \
        '--rcfile=+[rcfile]:file:_files -g "*.gx *.gxrc *.gxprs"' \
        '-l+[load preset]:str:' \
        '--load=+[load preset]:str:' \
        '-c+[cabinet IR]:file:_files -g "*.wav *.flac *.aiff *.ogg"' \
        '--cab-ir=+[cabinet IR]:file:_files -g "*.wav *.flac *.aiff *.ogg"' \
        '-a+[amp model]:m:(Marshall Fender VOX Mesa Engl Soldano clean crunch lead bass)' \
        '--amp=+[amp model]:m:(Marshall Fender VOX Mesa Engl Soldano clean crunch lead bass)' \
        '-N[no GUI]' \
        '--nogui[no GUI]' \
        '-S+[jack server name]:str:' \
        '--server-name=+[jack server name]:str:' \
        '-A+[input audio]:str:' \
        '--audio-input=+[input audio]:str:' \
        '-B+[output audio]:str:' \
        '--audio-output=+[output audio]:str:' \
        '*:preset:_files -g "*.gx *.gxrc *.gxprs"'
}

_gxamprack "$@"
