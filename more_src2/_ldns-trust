#compdef ldns-trust ldns-update-trust
# _ldns-trust — NLnet Labs ldns trust-anchor helper (subcommands: list installed anchors, fetch from .well-known/dnssec-trust-anchors via DNSKEY, update local trust-anchor store using RFC5011 automated updates; -f anchor file, -p protocol (DNS-over-HTTPS|DNS), -v verbose, -h help, -V version)
# upstream: https://github.com/NLnetLabs/ldns
# Flags from NLnetLabs/ldns examples/ldns-trust* on tip.

_ldns-trust() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-f+[anchor file]:file:_files' \
        '-p+[protocol]:proto:(DNS DOH DOT)' \
        '1::action:(list fetch update)'
}

_ldns-trust "$@"
