#compdef dhcpd
# _dhcpd — OpenBSD dhcpd (DHCP + BOOTP server; assigns IP addresses and network parameters per /etc/dhcpd.conf; supports peer synchronisation between two dhcpds via -y/-Y)
# upstream: https://github.com/openbsd/src (usr.sbin/dhcpd)
# Flags from usr.sbin/dhcpd/dhcpd.8 on tip.

_dhcpd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-f[foreground]' \
        '-n[validate config + exit]' \
        '-v[verbose]' \
        '-A+[pf abandoned-lease table]:table:' \
        '-C+[pf changed-lease table]:table:' \
        '-c+[config file (default /etc/dhcpd.conf)]:file:_files' \
        '-L+[pf leased-IP table]:table:' \
        '-l+[lease database (default /var/db/dhcpd.leases)]:file:_files' \
        '-u+[unprivileged bind address]:address:' \
        '-Y+[sync target host[:port]]:target:' \
        '-y+[sync listen [address:]port]:listen:' \
        '*:interface:_net_interfaces'
}

_dhcpd "$@"
