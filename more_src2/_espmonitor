#compdef espmonitor
# _espmonitor — ESP32 serial monitor with backtrace decoding (esp-rs/espmonitor)
# upstream: https://github.com/esp-rs/espmonitor
# Flags from espmonitor/src/types.rs (clap derive AppArgs).

_espmonitor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-r --reset --no-reset)'{-r,--reset}'[reset chip on start (default)]' \
        '(-r --reset --no-reset)--no-reset[do not reset chip on start]' \
        '(-s --speed)'{-s+,--speed=}'[serial baud rate (default 115200)]:baud:' \
        '(-b --bin)'{-b+,--bin=}'[path to ELF binary matching firmware on device]:file:_files' \
        '1:serial device:_files -g "/dev/tty*"'
}

_espmonitor "$@"
