#compdef kubectl-cilium_policy_gen
# Documentation: https://github.com/SoulKyu/cpg
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# cpg (SoulKyu/cpg), binary kubectl-cilium_policy_gen: generate
# CiliumNetworkPolicy from Hubble flows.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '--debug[debug logging]' \
  '--log-level=[log level]:level:(debug info warn error)' \
  '--json[JSON log format]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'generate:connect to Hubble Relay and generate policies from live dropped flows'
      'replay:process captured flow data from a jsonpb file'
      'explain:inspect evidence and attribution for generated policies'
    )
    _describe -t commands 'kubectl cilium_policy_gen command' commands && ret=0
    ;;
  args)
    case $line[1] in
      generate)
        _arguments -s -S \
          '(-s --server)'{-s+,--server=}'[Hubble Relay address]:address:' \
          '--tls[enable TLS for gRPC connection]' \
          '--timeout=[connection timeout]:duration:' \
          '*'{-n+,--namespace=}'[namespace filter (repeatable)]:namespace:' \
          '(-A --all-namespaces)'{-A,--all-namespaces}'[observe all namespaces]' \
          '*--ignore-protocol=[drop flows matching L4 protocols]:proto:(tcp udp icmpv4 icmpv6 sctp)' \
          '*--ignore-drop-reason=[exclude flows by Cilium drop reason]:reason:' \
          '--fail-on-infra-drops[exit 1 when an infra drop is observed]' \
          '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
          '--flush-interval=[aggregation flush interval]:duration:' \
          '--cluster-dedup[skip policies matching live cluster state]' \
          '--dry-run[preview changes without writing files]' \
          '--no-diff[suppress unified diff in dry-run mode]' \
          '--l7[enable opt-in L7 matching]' && ret=0
        ;;
    esac
    ;;
esac

return ret
