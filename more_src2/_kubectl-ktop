#compdef kubectl-ktop
# Documentation: https://github.com/vladimirvivien/ktop
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; flags cross-checked against
# vladimirvivien/ktop cmd/ktop.go.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-A --all-namespaces)'{-A,--all-namespaces}'[display metrics for all accessible namespaces]' \
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:namespace:' \
  '--context=[kube context]:context:' \
  '--kubeconfig=[kubeconfig file]:file:_files' \
  '--node-columns=[comma-separated list of node columns]:columns:' \
  '--pod-columns=[comma-separated list of pod columns]:columns:' \
  '--show-all-columns[show all columns]' \
  '--metrics-source=[metrics source]:source:(prom prometheus metrics-server none)' \
  '--prometheus-scrape-interval=[Prometheus scrape interval]:interval:' \
  '--prometheus-retention=[Prometheus metrics retention]:duration:' \
  '--prometheus-max-samples=[max samples per time series]:n:' \
  '--prometheus-components=[components to scrape]:components:' \
  '--log-level=[log verbosity]:level:(debug info warn error)' \
  '--log-format=[log record format]:format:(text json)' && ret=0

return ret
