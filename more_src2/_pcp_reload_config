#compdef pcp_reload_config
# Documentation: https://www.pgpool.net/docs/latest/en/html/pcp-reload-config.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcp_reload_config: reload Pgpool-II config
local curcontext="$curcontext" ret=1
_arguments -C \
  "(- *)--help[show help]" \
  "(- *)-\\?[show help]" \
  "(- *)-V[show version]" \
  "(- *)--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[enable debug message]" \
  "--debug[enable debug message]" \
  "-v[verbose output]" \
  "--verbose[verbose output]" \
  "-U[PCP user name]:user:_users" \
  "--username=[PCP user name]:user:_users" \
  "-h[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[PCP port number]:port:" \
  "--port=[PCP port number]:port:" \
  "-s[breadth of command impact]:scope:(c cluster l local)" \
  "--scope=[breadth of command impact]:scope:(c cluster l local)" \
  '*::pcp_reload_config args:_files' && ret=0
return ret
