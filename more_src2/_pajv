#compdef pajv
# _pajv — Polyglot AJV JSON-schema validator CLI (json-schema-everywhere/pajv)
# upstream: https://github.com/json-schema-everywhere/pajv
# Subcommands & flags from commands/{validate,test,help}.js.

_pajv() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)-h[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'validate:validate data against schema (default)'
                'test:assert data is valid/invalid against schema'
                'help:print command help'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                validate|test)
                    _arguments \
                        '-s+[JSON schema file]:file:_files -g "*.(json|yml|yaml)"' \
                        '*-d+[data file (repeatable)]:file:_files' \
                        '*-r+[referenced schema file]:file:_files' \
                        '*-m+[metaschema file]:file:_files' \
                        '*-c+[custom keyword/format module]:file:_files -g "*.js"' \
                        '--errors=[error output format]:fmt:(json line text js no)' \
                        '--changes=[show data changes]:fmt:(json line js)' \
                        '--valid[expect data to be valid (test)]' \
                        '--invalid[expect data to be invalid (test)]'
                    ;;
            esac
            ;;
    esac
}

_pajv "$@"
