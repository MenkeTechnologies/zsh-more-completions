#compdef ember
# _emberjs — Ember.js framework CLI (Tilde Inc / Ember Core); convention-based JS framework with Glimmer renderer
# upstream: https://github.com/ember-cli/ember-cli

_emberjs() {
    local -a sub=(
        'asset-sizes:print built asset sizes'
        'build:build app for production'
        'destroy:undo a generator'
        'generate:generate code from blueprint'
        'g:alias for generate'
        'help:show help'
        'init:initialize new app in current dir'
        'install:install addon (deprecated)'
        'lint:run linters'
        'new:create new app'
        'serve:run dev server'
        's:alias for serve'
        'test:run tests'
        't:alias for test'
        'version:show version'
        'v:alias for version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--silent[silent]' \
        '--no-welcome[no welcome msg]' \
        '--disable-analytics[disable analytics]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ember subcommand' sub ;;
        args)
            case $words[1] in
                serve|s) _arguments \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
                    '(-e --environment)'{-e,--environment}'+[env]:env:(development production test)' \
                    '--proxy+[proxy URL]:url:_urls' \
                    '--secure-proxy[use secure proxy]' \
                    '--ssl[serve over HTTPS]' \
                    '--ssl-cert+[TLS cert]:file:_files' \
                    '--ssl-key+[TLS key]:file:_files' \
                    '--live-reload-host+[live-reload host]:host:_hosts' \
                    '--live-reload-port+[live-reload port]:port:' \
                    '--live-reload[live reload]' \
                    '--no-live-reload[no live reload]' \
                    '--watcher+[watcher]:watcher:(polling node events)' ;;
                build) _arguments \
                    '(-e --environment)'{-e,--environment}'+[env]:env:(development production test)' \
                    '--output-path+[output dir]:dir:_files -/' \
                    '--watch[watch]' \
                    '--watcher+[watcher]:watcher:(polling node events)' ;;
                test|t) _arguments \
                    '--config-file+[config file]:file:_files' \
                    '--server[run dev server]' \
                    '--launch+[launch]:launch:' \
                    '--module+[module]:module:' \
                    '--filter+[filter]:str:' \
                    '--test-port+[test port]:port:' \
                    '--query+[query string]:str:' \
                    '--testem-debug+[testem debug]:flag:' \
                    '--no-build[skip build]' \
                    '--test-page+[test page]:url:_urls' ;;
                generate|g|destroy) _arguments \
                    '1:blueprint:(component component-class component-test helper helper-test initializer instance-initializer mixin model model-test route route-test serializer serializer-test service service-test template util util-test acceptance-test transform transform-test addon addon-import in-repo-addon)' \
                    '*:name:' ;;
                new|init) _arguments \
                    '--blueprint+[blueprint]:blueprint:' \
                    '--lang+[lang]:lang:' \
                    '--directory+[directory]:dir:_files -/' \
                    '--name+[name]:name:' \
                    '--skip-git[skip git init]' \
                    '--skip-npm[skip npm install]' \
                    '--welcome[show welcome]' \
                    '--yarn[use yarn]' \
                    '--pnpm[use pnpm]' \
                    '--ci-provider+[ci provider]:provider:(travis github none)' \
                    '--embroider[use embroider]' \
                    '--no-application-blueprint[skip default blueprint]' \
                    '1:name:' ;;
            esac
            ;;
    esac
}

_emberjs "$@"
