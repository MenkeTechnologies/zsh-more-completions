#compdef pick
# Documentation: man pick(1)
# Source: nmh uip/pick.c (master) — select messages by content (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-and[logical AND]' \
    '-or[logical OR]' \
    '-not[logical NOT]' \
    '-lbrace[open group]' \
    '-rbrace[close group]' \
    '*-cc+[match Cc pattern]:pattern:_default' \
    '*-date+[match Date pattern]:pattern:_default' \
    '*-from+[match From pattern]:pattern:_default' \
    '*-search+[match any field/body]:pattern:_default' \
    '*-subject+[match Subject pattern]:pattern:_default' \
    '*-to+[match To pattern]:pattern:_default' \
    '-after+[messages after date]:date:_default' \
    '-before+[messages before date]:date:_default' \
    '-datefield+[date field name]:field:_default' \
    '*-sequence+[sequence name]:name:_default' \
    '-nosequence[skip sequence]' \
    '(-public -nopublic)-public[public sequence]' \
    '(-public -nopublic)-nopublic[private sequence]' \
    '(-zero -nozero)-zero[clear sequence first]' \
    '(-zero -nozero)-nozero[do not clear]' \
    '(-list -nolist)-list[list message numbers]' \
    '(-list -nolist)-nolist[no list]' \
    '-debug[debug output]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
