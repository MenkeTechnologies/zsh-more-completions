#compdef qt-faststart
# Documentation: https://ffmpeg.org/ffmpeg-formats.html
# Reference accessed: 2026-05-20
# Verified: local `qt-faststart` usage banner:
#   Usage: qt-faststart <infile.mov> <outfile.mov>
# Source: https://github.com/FFmpeg/FFmpeg/blob/master/tools/qt-faststart.c

local curcontext="$curcontext" state line ret=1

_arguments \
  '1:input file:_files -g "*.(mov|mp4|m4v|m4a|MOV|MP4|M4V|M4A)"' \
  '2:output file:_files -g "*.(mov|mp4|m4v|m4a|MOV|MP4|M4V|M4A)"' && ret=0

return ret
