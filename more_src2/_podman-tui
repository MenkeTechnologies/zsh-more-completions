#compdef podman-tui
# Documentation: https://github.com/containers/podman-tui
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (cmd/root.go).

_podman-tui() {
  local curcontext="$curcontext" state line ret=1

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-d --debug)'{-d,--debug}'[run application in debug mode]' \
    '(-l --log-file)'{-l+,--log-file=}'[application runtime log file]:file:_files' \
    '1:command:(version help)' && ret=0

  return ret
}

_podman-tui "$@"
