#compdef kermit
# Documentation: https://www.mankier.com/1/kermit
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# C-Kermit: combined serial and network communication software package
local curcontext="$curcontext" ret=1
_arguments -C \
  '-s+[send file(s)]:file:_files' \
  '-r[receive file(s)]' \
  '-a+[as-name for transferred files]:name:' \
  '-g+[get file(s) from a Kermit server]:remote spec:' \
  '-k[receive file(s) to stdout]' \
  '-l+[serial communications device]:device:_files' \
  '-b+[speed for serial device]:bps:' \
  '-p+[parity]:parity:(even odd mark space none)' \
  '-m+[modem type]:modem:' \
  '-v+[window size for Kermit protocol]:size:' \
  '-e+[maximum incoming packet length]:length:' \
  '-D+[delay before sending in remote mode]:seconds:' \
  '-M+[username for Telnet/Rlogin/FTP]:user:_users' \
  '-C+[interactive commands to execute]:commands:' \
  '-j+[make a TCP/IP connection]:host:_hosts' \
  '-J+[TCP/IP connection, be like Telnet]:host:_hosts' \
  '-9+[make an FTP connection]:host:_hosts' \
  '-F+[use already-open TCP connection]:fd:' \
  '-y+[alternative initialization file]:file:_files' \
  '-i[force binary (image) mode]' \
  '-T[force text mode]' \
  '-P[do not convert file path names]' \
  '-V[disable automatic text/binary switching]' \
  '-c[enter connect state before transfer]' \
  '-n[enter connect state after transfer]' \
  '-h[print help for command-line options]' \
  '-S[stay in command parser after action options]' \
  '-R[remote-only mode]' \
  '-d[create debug.log file]' \
  '-x[enter server mode]' \
  '-B[running in batch/background]' \
  '-O[server mode for one command only]' \
  '-E[exit automatically when connection closes]' \
  '-q[quiet mode]' \
  '-f[send FINISH command to Kermit server]' \
  '-G+[get file(s), send to stdout]:remote spec:' \
  '-L[recursive directory descent for -s]' \
  '-w[overwrite existing files]' \
  '-Q[quick Kermit protocol settings]' \
  '-I[force streaming on reliable connections]' \
  '-H[suppress startup herald and greeting]' \
  '-Y[skip initialization file]' \
  '-z[force foreground behavior]' \
  '-A[start as Internet service (IKSD)]' \
  '-0[100 percent transparent connect state]' \
  '-8[8-bit clean connection]' \
  '-t[Xon turnaround for half-duplex]' \
  '*:args:_files' && ret=0
return ret
