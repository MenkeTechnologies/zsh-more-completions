#compdef rdmaucma rdmaucma-bpfcc
# _rdmaucma — trace RDMA Userspace Connection Manager events (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/rdmaucma.py (argparse).

_rdmaucma() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-D --debug)'{-D,--debug}'[print BPF program before starting]'
    )
    _arguments $args
}

_rdmaucma "$@"
