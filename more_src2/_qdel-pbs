#compdef qdel
# _qdel-pbs — PBS qdel (delete queued or running PBS jobs; -W extension list (e.g. -Wforce skips MoM ack, -Wsuppress_email=N skips notification), -x include finished jobs, -t array selector limits which array sub-jobs are deleted; positional jobIDs)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qdel.c on tip.

_qdel-pbs() {
    _arguments \
        '-W+[extension list]:list:(force suppress_email=0 suppress_email=1)' \
        '-x[include finished jobs]' \
        '-t+[array selector]:range:' \
        '*:jobID:'
}

_qdel-pbs "$@"
