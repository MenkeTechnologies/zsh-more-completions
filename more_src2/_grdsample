#compdef grdsample
# Documentation: https://docs.generic-mapping-tools.org/latest/grdsample.html
# Source: GenericMappingTools/gmt classic-mode grdsample — resample a grid onto a new lattice.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[output grid spacing (dx/dy)]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-T[toggle gridline vs pixel registration]' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-n+[interpolation mode]:mode:_default' \
    '-r[pixel registration (default gridline)]' \
    '-x+[CPU cores limit]:n:_default' \
    '(- *)-\?[show help]' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf)(-.)"' \
    && ret=0

return ret
