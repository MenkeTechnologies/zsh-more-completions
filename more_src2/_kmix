#compdef kmix
# Documentation: https://userbase.kde.org/KMix
# Reference accessed: 2026-05-19
# Verified: KMix-specific options --keepvisibility and --failsafe
# confirmed via KDE UserBase + kmix_autostart.desktop (which invokes
# `kmix --keepvisibility`). Removed Qt4-era invented flags: --help-qt,
# --help-kde, --style, --stylesheet, --platform, --display,
# --platformpluginpath, --graphicssystem, --reverse, file positional.
# STUB+: KDE/Qt6 standard options plus two verified kmix flags.

# KMix: KDE volume mixer
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including Qt]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' \
  '--keepvisibility[inhibit unhiding the main window if KMix already running]' \
  '--failsafe[start KMix in failsafe mode]' && ret=0
return ret
