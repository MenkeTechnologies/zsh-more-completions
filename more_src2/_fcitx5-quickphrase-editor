#compdef fcitx5-quickphrase-editor
# Documentation: https://github.com/fcitx/fcitx5-qt/tree/master/qt5/quickphrase-editor
# Reference accessed: 2026-05-16
# Verified: quickphrase-editor is a GUI plugin loaded by fcitx5-qt5-gui-wrapper
# (or qt6 equivalent), not a standalone CLI binary. The wrapper accepts -h
# (Qt help), -w (parent window ID), -t (test config existence) and positional
# config path.

# fcitx5-quickphrase-editor: GUI plugin for fcitx5 quickphrase editing
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-w --winid)'{-w,--winid=}'[parent window ID]:winid:' \
  '(-t --test)'{-t,--test}'[test if config exists]' \
  '*:config path:_files' && ret=0
return ret
