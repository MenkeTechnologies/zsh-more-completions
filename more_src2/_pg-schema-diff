#compdef pg-schema-diff
# Documentation: https://github.com/stripe/pg-schema-diff
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pg-schema-diff: Stripe's declarative Postgres schema migration tool.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'apply:apply schema migration to a database'
  'plan:generate a migration plan'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pg-schema-diff command' commands && ret=0 ;;
  (args)
    case $words[1] in
      (apply)
        _arguments \
          '--from-dsn=[source database connection string]:dsn:' \
          '--to-dir=[directory with target schema files]:dir:_files -/' \
          '--allow-hazards=[allow listed hazard kinds]:hazards:' && ret=0 ;;
      (plan)
        _arguments \
          '--from-dsn=[source database connection string]:dsn:' \
          '--to-dir=[directory with target schema files]:dir:_files -/' && ret=0 ;;
    esac ;;
esac

return ret
