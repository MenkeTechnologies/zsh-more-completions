#compdef kmines
# Documentation: https://invent.kde.org/games/kmines/-/blob/master/src/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream src/main.cpp adds no game-specific options beyond
# KAboutData::setupCommandLine (Qt/KF6 standard set).
# Removed bogus --display= (Qt4-era, not in KF6/Qt6).
# STUB: KDE/Qt standard options only.

# KMines: KDE Minesweeper game
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options including Qt]' \
  '(- *)'{-v,--version}'[show version]' \
  '--author[show author information]' \
  '--license[show license information]' && ret=0
return ret
