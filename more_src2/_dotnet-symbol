#compdef dotnet-symbol
# Documentation: https://github.com/dotnet/symstore/tree/main/src/dotnet-symbol
# Reference accessed: 2026-05-27
# Verified: upstream src/dotnet-symbol/Program.cs CommandLineApplication option list

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--microsoft-symbol-server[add Microsoft symbol server (msdl.microsoft.com)]' \
  '--internal-server[add internal symweb symbol server]' \
  '--authenticated-server-path=[symbol server with PAT (token then URL)]:token-and-url:' \
  '--server-path=[custom symbol server URL]:url:' \
  '(-o --output)'{-o+,--output=}'[output directory for downloaded files]:directory:_files -/' \
  '--overwrite[overwrite existing files]' \
  '--timeout=[operation timeout in minutes]:minutes:' \
  '--cache-directory=[symbol cache directory]:directory:_files -/' \
  '--recurse-subdirectories[process subdirectories recursively]' \
  '--modules[download module/identity files]' \
  '--symbols[download symbol files]' \
  '--debugging[download debugging-related files]' \
  '--windows-pdbs[force Windows PDB format]' \
  '--host-only[restrict to host-specific keys]' \
  '--verifycore[verify ELF core dump validity]' \
  '(-d --diagnostics)'{-d,--diagnostics}'[enable diagnostic tracing output]' \
  '(- *)'{-h,-\?,--help}'[show help]' \
  '*:input file:_files' && ret=0

return ret
