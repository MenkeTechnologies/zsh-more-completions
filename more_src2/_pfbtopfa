#compdef pfbtopfa
# Documentation: pfbtopfa usage (Ghostscript)
# Source: convert PostScript Type 1 PFB (binary) to PFA (ASCII).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:input pfb:_files -g "*.pfb"' \
    '2:output pfa:_files -g "*.pfa"' \
    && ret=0

return ret
