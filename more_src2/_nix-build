#compdef nix-build
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-build
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-build - Nix build command

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--arg[pass argument to Nix expression]:name: :value:' \
  '--argstr[pass string argument to Nix expression]:name: :value:' \
  '--arg-from-file[pass file contents as argument]:name: :file:_files' \
  '--arg-from-stdin[pass stdin contents as argument]:name:' \
  '(-A --attr)'{-A,--attr}'[select attribute from top-level expression]:attribute:' \
  '--no-out-link[do not create a symlink to the output path]' \
  '(-o --out-link)'{-o,--out-link}'[change name of symlink to output path]:symlink:_files' \
  '--dry-run[show what would be built or downloaded]' \
  '(-K --keep-failed)'{-K,--keep-failed}'[keep build directory on failure]' \
  '(-k --keep-going)'{-k,--keep-going}'[keep going on build failures]' \
  '(-j --max-jobs)'{-j,--max-jobs}'[set number of parallel build jobs]:jobs:' \
  '--cores[set number of CPU cores per build]:cores:' \
  '--max-silent-time[set max silent time before killing]:seconds:' \
  '--timeout[set max build time]:seconds:' \
  '*--option[set Nix configuration option]:name: :value:' \
  '--no-build-output' \
  '-Q[suppress build output]' \
  '(-v --verbose)'{-v,--verbose}'[increase verbosity level]' \
  '--quiet[decrease verbosity level]' \
  '--fallback[fall back to building from source if substitution fails]' \
  '--readonly-mode[read-only mode (no store DB writes)]' \
  '--log-format[set log format]:format:(raw internal-json bar bar-with-logs)' \
  '(-I --include)'{-I,--include}'[add path to Nix expression search path]:path:_files' \
  '--impure[allow impure expressions]' \
  '(-E --expr)'{-E,--expr}'[interpret arguments as Nix expressions]:expr:' \
  '--eval-store[URL of the Nix store to use for evaluation]:url:' \
  '--repair[fix corrupted or missing store paths]' \
  '*:Nix expression:_files -g "*.nix"'
