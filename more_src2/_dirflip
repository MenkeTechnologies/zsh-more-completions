#compdef dirflip
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dirflip.html
# Source: MRtrix3/mrtrix3 cmd/dirflip.cpp — flip directions to optimise gradient encoding (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-permutations+[number of permutations to try]:n:_default' \
    '-cartesian[output [x y z] instead of [az el]]' \
    '1:in (input directions):_files' \
    '2:out (output directions):_files' \
    && ret=0

return ret
