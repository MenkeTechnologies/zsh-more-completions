#compdef pcretest
# Documentation: pcretest -help (legacy PCRE)
# Source: PCRE test program for matching patterns against subjects.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(-16 -32)-16[use 16-bit library]' \
    '(-16 -32)-32[use 32-bit library]' \
    '-b[show compiled code]' \
    '-C-[show compile-time option(s)]::arg:(linksize pcre8 pcre16 pcre32 utf ucp jit newline bsr)' \
    '-d[debug (-b + -i)]' \
    '-dfa[force DFA matching]' \
    '-i[show info about compiled patterns]' \
    '-M[find MATCH_LIMIT minimum for each subject]' \
    '-m[output memory used]' \
    '-O[set PCRE_NO_AUTO_POSSESS]' \
    '-o+[size of offsets vector]:n:' \
    '-p[use POSIX interface]' \
    '-q[quiet (no version banner)]' \
    '-S+[set stack size in MiB]:n:' \
    '-s[output match results in alphabetic order]' \
    '-t-[time matching (repeat N times)]::n:' \
    '-tm-[time execution only]::n:' \
    '1:input file:_files' \
    '2:output file:_files' \
    && ret=0

return ret
