#compdef eu-stack
# _eu-stack-bin — elfutils stack tracer (Ulrich Drepper, Red Hat); print thread stack of a running process or core
# upstream: https://sourceware.org/elfutils

_eu-stack-bin() {
    _arguments \
        '(-p --pid)'{-p,--pid}'+[attach PID]:pid:_pids' \
        '--core+[core file]:file:_files' \
        '--executable+[executable]:file:_files' \
        '(-a --activation)'{-a,--activation}'[show activation]' \
        '(-d --debugname)'{-d,--debugname}'[print debug info]' \
        '(-i --inlines)'{-i,--inlines}'[show inline frames]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-m --module-names)'{-m,--module-names}'[print module names]' \
        '(-r --raw)'{-r,--raw}'[raw addresses]' \
        '(-s --source)'{-s,--source}'[print source info]' \
        '--debuginfo-path+[debuginfo path]:path:_files -/' \
        '-1[show only first frame]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:pid:_pids'
}

_eu-stack-bin "$@"
