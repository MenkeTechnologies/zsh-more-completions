#compdef deepseek-tui
# Documentation: https://github.com/Hmbown/DeepSeek-TUI
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for deepseek-tui (DeepSeek AI coding agent TUI)

_arguments -s -S \
  '(- *)--help[Print help message]' \
  '(- *)--version[Display installed version]' \
  '--yolo[auto-approve all tools in trusted workspace]' \
  '--last[resume the most recent session in this workspace]' \
  '(-p --profile)'{-p,--profile}'=[named configuration profile]:profile:' \
  '--model=[model override (or auto)]:model:' \
  '--provider=[API provider]:provider:' \
  '*:directory:_files -/'
