#compdef kissat
# _kissat — Armin Biere kissat CLI parallel-friendly CDCL SAT solver C-based rewrite of CaDiCaL benchmark-winning SAT-Competition-2020-2022-Champion accepting DIMACS-CNF formulas producing SAT UNSAT verdict with assignment model output DRUP DRAT proof generation simplification preprocessing-inprocessing (Armin Biere team, C); getopt
# upstream: https://github.com/arminbiere/kissat

_kissat() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no model printing]' \
        '--no-model[no model printing]' \
        '-s[print statistics]' \
        '--stats[print statistics]' \
        '-O+[default option]:str:' \
        '--time=+[sec]:n:' \
        '--conflicts=+[N]:n:' \
        '--decisions=+[N]:n:' \
        '--default=+[default]:s:(plain unsat sat)' \
        '--seed=+[seed]:n:' \
        '--keep-going[keep going]' \
        '--restarts=+[N]:n:' \
        '--reduce=+[N]:n:' \
        '--profile=+[name]:str:' \
        '--proof=+[file]:file:_files -g "*.drup *.drat"' \
        '--ascii[ASCII proof]' \
        '*:cnf file:_files -g "*.cnf *.cnf.gz *.cnf.bz2 *.cnf.xz *.dimacs"'
}

_kissat "$@"
