#compdef ps2ps2
# Documentation: https://ghostscript.readthedocs.io/en/latest/Use.html
# Reference accessed: 2026-05-20
# Verified: ps2ps2 wraps ghostscript; flags above are Ghostscript -s and -d
# options confirmed by the local `ps2ps2` shipped with ghostscript.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '*-s+[Ghostscript -s option]:option:' \
  '*-d+[Ghostscript -d option]:option:' \
  '1:input PostScript:_files -g "*.(ps|eps)"' \
  '2:output PostScript:_files -g "*.ps"' && ret=0

return ret
