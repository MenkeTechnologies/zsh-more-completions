#compdef function-runtime-oci
# _function-runtime-oci — Crossplane reference Composition Functions runtime (Kong CLI)
# upstream: https://github.com/crossplane/function-runtime-oci
# Top-level + subcommand flags from cmd/function-runtime-oci/{main,start,run,spark}.go on tip.

_function-runtime-oci() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --debug)'{-d,--debug}'[print verbose logging statements]' \
        '(-v --version)'{-v,--version}'[print version and quit]' \
        '(-r --registry)'{-r,--registry}'=[default registry for unspecified-tag containers]:registry:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                start:'listen for Composition Function runs over gRPC'
                run:'run a Composition Function'
                spark:'internal namespaced executor (do not invoke directly)'
            )
            _describe -t commands 'function-runtime-oci subcommand' subs
            ;;
        args)
            case $line[1] in
                start)
                    _arguments \
                        '(-c --cache-dir)'{-c,--cache-dir}'=[cache directory for function images]:dir:_files -/' \
                        '--map-root-uid=[UID mapped to 0 in the function user namespace]:uid:' \
                        '--map-root-gid=[GID mapped to 0 in the function user namespace]:gid:' \
                        '--network=[network type for gRPC listener]:type:(unix tcp)' \
                        '--address=[address to listen for gRPC connections]:addr:'
                    ;;
                run)
                    _arguments \
                        '(-c --cache-dir)'{-c,--cache-dir}'=[cache directory for function images]:dir:_files -/' \
                        '--timeout=[maximum function runtime before kill]:duration:' \
                        '--image-pull-policy=[whether the image may be pulled from a remote registry]:policy:(Always Never IfNotPresent)' \
                        '--network-policy=[whether the function may access the network]:policy:(Runner Isolated)' \
                        '--map-root-uid=[UID mapped to 0 in the function user namespace]:uid:' \
                        '--map-root-gid=[GID mapped to 0 in the function user namespace]:gid:'
                    ;;
                spark)
                    _arguments \
                        '(-c --cache-dir)'{-c,--cache-dir}'=[cache directory for function images]:dir:_files -/' \
                        '--runtime=[OCI runtime binary to invoke]:bin:_command_names -e' \
                        '--max-stdio-bytes=[max stdout/stderr size]:n:' \
                        '--ca-bundle-path=[additional CA bundle for fetching function images]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_function-runtime-oci "$@"
