#compdef dune-release
# Documentation: https://github.com/tarides/dune-release/blob/main/bin/main.ml
# Reference accessed: 2026-05-27
# Verified: upstream bin/main.ml, bin/cli.ml and per-command bin/*.ml on main.

local curcontext="$curcontext" state line ret=1

local -a _dr_subcommands _dr_opam_actions _dr_lint_tests _dr_delegate_vars _dr_config_actions
_dr_subcommands=(
  'bistro:full release workflow (tag, distrib, publish, opam)'
  'check:check that the package is ready for distribution'
  'config:show, set or create the dune-release configuration'
  'delegate-info:print a tarball/docdir/version/publication-message variable'
  'distrib:create a package distribution archive'
  'help:show help about dune-release and its subcommands'
  'lint:check package distribution consistency and conventions'
  'opam:interact with opam and the OCaml opam repository'
  'publish:publish package distribution archives'
  'tag:tag the package source tree with a version'
  'undraft:undraft a draft GitHub release and opam-repository PR'
)

_dr_opam_actions=(
  'descr:write the package description to stdout'
  'pkg:create an opam package description for a distribution'
  'submit:submit a package to the OCaml opam repository'
  'field:output a field of the opam package description'
)

_dr_lint_tests=(std-files opam)
_dr_delegate_vars=(tarball docdir version publication-message)
_dr_config_actions=(show set create)

# Common option block reused across most subcommands
_dr_common_options() {
  _arguments -s \
    '(-C --pkg-dir)'{-C,--pkg-dir=}'[change to directory before doing anything]:dir:_files -/' \
    '--verbosity=[set logging verbosity]:level:(quiet error warning info debug)' \
    '--color=[colorize output]:when:(auto always never)' \
    '--help[show help]'
}

_arguments -C \
  '(- *)--version[print dune-release version]' \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'dune-release subcommand' _dr_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      bistro)
        _dr_common_options
        _arguments \
          '--dry-run[show what would be done without performing actions]' \
          '(-p --pkg-names)'{-p,--pkg-names=}'[opam packages to release (comma list)]:names:' \
          '(-V --pkg-version)'{-V,--pkg-version=}'[package version]:version:' \
          '(-t --tag)'{-t,--tag=}'[git tag for the distribution archive]:tag:' \
          '--keep-v[do not drop the initial v in the version string]' \
          '--token=[GitHub token to use]:token:' \
          '--include-submodules[include git submodules in distribution archive]' \
          '--draft[produce a draft (cannot be merged) release]' \
          '--prerelease[mark the GitHub release as prerelease]' \
          '--keep-build-dir[keep distribution build directory after archival]' \
          '--skip-lint[do not lint the archive distribution]' \
          '--skip-build[do not build the package from the archive]' \
          '--skip-tests[do not run package tests from the archive]' \
          '(-l --local-repo)'{-l,--local-repo=}'[location of the local opam-repository fork]:path:_files -/' \
          '(-r --remote-repo)'{-r,--remote-repo=}'[location of the remote opam-repository fork]:uri:' \
          '--opam-repo=[GitHub opam-repository to release to (user/repo)]:repo:' \
          '--no-auto-open[do not open a browser to view the new PR]' \
          '--dev-repo=[location of the dev repo of the current package]:uri:' && ret=0
        ;;
      check)
        _dr_common_options
        _arguments \
          '(-p --pkg-names)'{-p,--pkg-names=}'[opam packages to release]:names:' \
          '(-V --pkg-version)'{-V,--pkg-version=}'[package version]:version:' \
          '(-t --tag)'{-t,--tag=}'[git tag for the distribution archive]:tag:' \
          '--keep-v[do not drop the initial v in the version string]' \
          '--build-dir=[distribution build directory]:dir:_files -/' \
          '--skip-lint[do not lint the archive distribution]' \
          '--skip-build[do not build the package from the archive]' \
          '--skip-tests[do not run package tests from the archive]' \
          '--skip-change-log[do not check that the change log can be parsed]' \
          '--working-tree[use the working tree state rather than VCS HEAD]' && ret=0
        ;;
      config)
        _dr_common_options
        _arguments \
          '1:action:('"${_dr_config_actions[*]}"')' \
          '2:key:' \
          '3:value:' && ret=0
        ;;
      delegate-info)
        _dr_common_options
        _arguments \
          '1:variable:('"${_dr_delegate_vars[*]}"')' && ret=0
        ;;
      distrib)
        _dr_common_options
        _arguments \
          '--dry-run[show what would be done without performing actions]' \
          '--build-dir=[distribution build directory]:dir:_files -/' \
          '(-p --pkg-names)'{-p,--pkg-names=}'[opam packages to release]:names:' \
          '(-V --pkg-version)'{-V,--pkg-version=}'[package version]:version:' \
          '(-t --tag)'{-t,--tag=}'[git tag for the distribution archive]:tag:' \
          '--keep-v[do not drop the initial v in the version string]' \
          '--keep-build-dir[keep distribution build directory after archival]' \
          '--skip-lint[do not lint the archive distribution]' \
          '--skip-build[do not build the package from the archive]' \
          '--skip-tests[do not run package tests from the archive]' \
          '--include-submodules[include git submodules in distribution archive]' && ret=0
        ;;
      help)
        _dr_common_options
        _arguments \
          '1:topic:(release troubleshoot bistro check config delegate-info distrib lint opam publish tag undraft)' && ret=0
        ;;
      lint)
        _dr_common_options
        _arguments \
          '--dry-run[show what would be done without performing actions]' \
          '(-p --pkg-names)'{-p,--pkg-names=}'[opam packages to release]:names:' \
          '(-V --pkg-version)'{-V,--pkg-version=}'[package version]:version:' \
          '(-t --tag)'{-t,--tag=}'[git tag for the distribution archive]:tag:' \
          '--keep-v[do not drop the initial v in the version string]' \
          '*:test:('"${_dr_lint_tests[*]}"')' && ret=0
        ;;
      opam)
        _dr_common_options
        _arguments \
          '--dry-run[show what would be done without performing actions]' \
          '--build-dir=[distribution build directory]:dir:_files -/' \
          '(-l --local-repo)'{-l,--local-repo=}'[location of local opam-repository fork]:path:_files -/' \
          '(-r --remote-repo)'{-r,--remote-repo=}'[location of remote opam-repository fork]:uri:' \
          '--opam-repo=[GitHub opam-repository (user/repo)]:repo:' \
          '(-u --user)'{-u,--user=}'[GitHub account to push opam-repository branches to]:user:' \
          '--keep-v[do not drop the initial v in the version string]' \
          '--dist-opam=[opam file to use for the distribution]:file:_files' \
          '--dist-uri=[distribution archive URI]:uri:' \
          '--dist-file=[package distribution archive]:file:_files' \
          '(-t --tag)'{-t,--tag=}'[git tag for the distribution archive]:tag:' \
          '(-p --pkg-names)'{-p,--pkg-names=}'[opam packages to release]:names:' \
          '(-V --pkg-version)'{-V,--pkg-version=}'[package version]:version:' \
          '--pkg-descr=[package description file]:file:_files' \
          '--readme=[readme file to use]:file:_files' \
          '--change-log=[change log file to use]:file:_files' \
          '(-m --message)'{-m,--message=}'[publication message]:msg:' \
          '--no-auto-open[do not open a browser to view the new PR]' \
          '(-y --yes)'{-y,--yes}'[do not prompt for confirmation]' \
          '--token=[GitHub token to use]:token:' \
          '--draft[produce a draft release]' \
          '1:action:(('"$(printf '%s ' "${_dr_opam_actions[@]}")"'))' \
          '2:field:' && ret=0
        ;;
      publish)
        _dr_common_options
        _arguments \
          '--build-dir=[distribution build directory]:dir:_files -/' \
          '(-V --pkg-version)'{-V,--pkg-version=}'[package version]:version:' \
          '(-t --tag)'{-t,--tag=}'[git tag for the distribution archive]:tag:' \
          '--keep-v[do not drop the initial v in the version string]' \
          '--dist-opam=[opam file to use for the distribution]:file:_files' \
          '--change-log=[change log file to use]:file:_files' \
          '--dist-file=[package distribution archive]:file:_files' \
          '(-m --message)'{-m,--message=}'[publication message]:msg:' \
          '--dry-run[show what would be done without performing actions]' \
          '(-y --yes)'{-y,--yes}'[do not prompt for confirmation]' \
          '--token=[GitHub token to use]:token:' \
          '--draft[produce a draft release]' \
          '--prerelease[mark the GitHub release as prerelease]' \
          '--dev-repo=[location of the dev repo]:uri:' \
          '*:artefact:(distrib doc)' && ret=0
        ;;
      tag)
        _dr_common_options
        _arguments \
          '--dry-run[show what would be done without performing actions]' \
          '--change-log=[change log file to use]:file:_files' \
          '--keep-v[do not drop the initial v in the version string]' \
          '--commit=[commit-ish to tag (default HEAD)]:commitish:' \
          '(-f --force)'{-f,--force}'[overwrite an existing tag]' \
          '(-s --sign)'{-s,--sign}'[sign the tag with the user OpenPGP key]' \
          '(-d --delete)'{-d,--delete}'[delete the tag]' \
          '(-m --message)'{-m,--message=}'[tag message]:msg:' \
          '(-y --yes)'{-y,--yes}'[do not prompt for confirmation]' \
          '1:version:' && ret=0
        ;;
      undraft)
        _dr_common_options
        _arguments \
          '--dist-opam=[opam file to use for the distribution]:file:_files' \
          '--dist-file=[package distribution archive]:file:_files' \
          '--opam-repo=[GitHub opam-repository (user/repo)]:repo:' \
          '--token=[GitHub token to use]:token:' \
          '(-l --local-repo)'{-l,--local-repo=}'[location of local opam-repository fork]:path:_files -/' \
          '(-r --remote-repo)'{-r,--remote-repo=}'[location of remote opam-repository fork]:uri:' \
          '--build-dir=[distribution build directory]:dir:_files -/' \
          '(-p --pkg-names)'{-p,--pkg-names=}'[opam packages to release]:names:' \
          '--dry-run[show what would be done without performing actions]' \
          '(-y --yes)'{-y,--yes}'[do not prompt for confirmation]' && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
