#compdef gatsby
# _gatsby-bin — Gatsby React-based static site generator (Netlify); GraphQL data layer + plugin ecosystem
# upstream: https://github.com/gatsbyjs/gatsby

_gatsby-bin() {
    local -a sub=(
        'develop:start development server'
        'build:build production site'
        'serve:serve built site'
        'info:print env info'
        'clean:wipe local .cache and public'
        'feedback:respond to telemetry feedback'
        'repl:open Node REPL with site context'
        'new:create new Gatsby site'
        'plugin:plugin subcommands'
        'recipes:run recipes'
        'telemetry:enable/disable telemetry'
        'login:authenticate to Gatsby Cloud'
        'logout:logout'
        'options:print all global flags'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--verbose[verbose log]' \
        '--no-color[disable color]' \
        '--json[JSON output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gatsby subcommand' sub ;;
        args)
            case $words[1] in
                develop) _arguments \
                    '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-o --open)'{-o,--open}'[open browser]' \
                    '(-S --https)'{-S,--https}'[serve over HTTPS]' \
                    '(-c --cert-file)'{-c,--cert-file}'+[TLS cert]:file:_files' \
                    '(-k --key-file)'{-k,--key-file}'+[TLS key]:file:_files' \
                    '--inspect+[node --inspect host:port]:str:' \
                    '--inspect-brk+[node --inspect-brk host:port]:str:' \
                    '--graphql-tracing[enable graphql tracing]' \
                    '--open-tracing-config-file+[opentracing config]:file:_files' ;;
                build) _arguments \
                    '--prefix-paths[build with path prefix]' \
                    '--no-uglify[do not uglify]' \
                    '--profile[profile build]' \
                    '--graphql-tracing[enable graphql tracing]' \
                    '--write-to-file+[manifest file]:file:_files' \
                    '--open-tracing-config-file+[opentracing config]:file:_files' ;;
                serve) _arguments \
                    '(-H --host)'{-H,--host}'+[host]:host:_hosts' \
                    '(-p --port)'{-p,--port}'+[port]:port:' \
                    '(-o --open)'{-o,--open}'[open browser]' \
                    '--prefix-paths[serve under path prefix]' ;;
                new) _arguments '1:project dir:_files -/' '2:starter:' ;;
                telemetry) _arguments '1:action:(enable disable)' ;;
            esac
            ;;
    esac
}

_gatsby-bin "$@"
