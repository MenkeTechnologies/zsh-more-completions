#compdef gs ghostscript
# Documentation: https://manpages.debian.org/gs.1
# Source: Artifex/GhostScript — PostScript / PDF interpreter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-d[define name in systemdict (name or name=value)]:def:' \
    '*-s[define name with string value (name=string)]:def:' \
    '-q[quiet startup]' \
    '-dSAFER[restrict file operations (default)]' \
    '-dNOSAFER[disable SAFER]' \
    '-dNOPAUSE[no pause/prompt between pages]' \
    '-dBATCH[exit at end of file (no interactive prompt)]' \
    '-dQUIET[suppress most progress messages]' \
    '-sDEVICE=[output device]:device:(pdfwrite ps2write epswrite txtwrite png16m png16 png48 pngalpha pngmono pnggray jpeg jpegcmyk jpeggray tiffcrle tiffg3 tiffg32d tiffg4 tifflzw tiffpack tiff12nc tiff24nc tiff32nc tiff48nc tiff64nc tiffsep tiffscaled bbox display nullpage ink_cov)' \
    '-sOutputFile=[output file (- for stdout, %d for per-page)]:file:_files' \
    '-r[resolution dpi (NxM or N)]:dpi:' \
    '-g[device size (WxH pixels)]:WxH:' \
    '*-I[add directory to library search path]:dir:_directories' \
    '-dFirstPage=[first page to process]:n:' \
    '-dLastPage=[last page to process]:n:' \
    '-dPDFSETTINGS=[PDF conversion preset]:preset:(/screen /ebook /printer /prepress /default)' \
    '-dAutoRotatePages=[auto-rotate]:mode:(/None /All /PageByPage)' \
    '-dEmbedAllFonts=[embed all fonts]:bool:(true false)' \
    '-dSubsetFonts=[subset embedded fonts]:bool:(true false)' \
    '-dCompressFonts=[compress embedded fonts]:bool:(true false)' \
    '-c[execute PostScript before file(s)]:postscript:' \
    '-f[end -c segment / start input files]' \
    '*:PostScript / PDF file:_files -g "*.(ps|pdf|eps)"' \
    && ret=0

return ret
