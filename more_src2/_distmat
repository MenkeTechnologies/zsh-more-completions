#compdef distmat
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/distmat.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS distmat: build a distance matrix from multiple aligned sequences
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequence=[aligned sequence(s)]:alignment USA:_files' \
  '-nucmethod=[nucleotide method]:method:(0 1 2 3 4 5)' \
  '-protmethod=[protein method]:method:(0 1 2)' \
  '-ambiguous[allow ambiguity codes]' \
  '-gapweight=[gap weight]:weight:' \
  '-position=[base position to use (1-3 codon)]:pos:(0 12 3 123)' \
  '-calculatea[calculate parameter a (Tajima-Nei)]' \
  '-parametera=[parameter a value]:val:' \
  '-outfile=[matrix output file]:file:_files' \
  '*:alignment USA:_files' && ret=0
return ret
