#compdef dtrace-cli
# _dtrace-cli — Sun/Solaris dtrace dynamic tracing framework CLI alias (illumos/Solaris/macOS team, C); custom argparse
# upstream: https://github.com/opendtrace/opendtrace

_dtrace-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-32[generate 32-bit]' \
        '-64[generate 64-bit]' \
        '-A[create driver.conf entries]' \
        '-a[claim anonymous tracing state]' \
        '-b+[buffer size]:str:' \
        '-c+[command]:str:' \
        '-C[run cpp on program]' \
        '-D+[name[=value]]:str:' \
        '-e[exit after compiling]' \
        '-f+[probe function]:str:' \
        '-F[combine consecutive output]' \
        '-G[generate ELF file]' \
        '-i+[probe id]:n:' \
        '-I+[include dir]:dir:_files -/' \
        '-L+[library dir]:dir:_files -/' \
        '-l[list probes]' \
        '-m+[module]:str:' \
        '-n+[probe specifier]:str:' \
        '-o+[output file]:file:_files' \
        '-p+[pid]:pid:_pids' \
        '-P+[provider]:str:' \
        '-q[quiet]' \
        '-s+[script file]:file:_files -g "*.d"' \
        '-S[show D code]' \
        '-U+[name]:str:' \
        '-v[verbose]' \
        '-V[show version]' \
        '-w[allow destructive actions]' \
        '-x+[opt[=val]]:str:' \
        '-X+[mode]:m:(a c s t)' \
        '-Z[allow zero probes]' \
        '*:arg:'
}

_dtrace-cli "$@"
