#compdef kubetest2-gce
# _kubetest2-gce — kubetest2 deployer for GCE (kubernetes-sigs/kubetest2)
# upstream: https://github.com/kubernetes-sigs/kubetest2
# Flags from kubetest2-gce/deployer/deployer.go (gpflag).

_kubetest2-gce() {
    _arguments \
        '--build[build kubernetes]' \
        '--up[provision the test cluster]' \
        '--down[tear down the test cluster]' \
        '--test=[tester to run after deployer up]:tester:(ginkgo exec node clusterloader2)' \
        '*--env=[env variable for kube-*.sh scripts]:env:' \
        '--boskos-acquire-timeout-seconds=[Boskos acquire timeout]:s:' \
        '--boskos-heartbeat-interval-seconds=[Boskos heartbeat interval]:s:' \
        '--boskos-resource-type=[Boskos project type]:type:(gce-project gke-project)' \
        '--repo-root=[path to local kubernetes repo]:dir:_files -/' \
        '--gcp-project=[GCP project]:project:' \
        '--gcp-zone=[GCP zone]:zone:' \
        '--enable-compute-api[enable GCP compute API on Up]' \
        '--overwrite-logs-dir[overwrite an existing logs directory]' \
        '--boskos-location=[Boskos server URL]:url:_urls' \
        '--legacy-mode[treat repo-root as kubernetes/kubernetes]' \
        '--num-nodes=[number of nodes]:n:' \
        '--kubernetes-version=[Kubernetes version]:ver:' \
        '--enable-cache-mutation-detector[set ENABLE_CACHE_MUTATION_DETECTOR=true]' \
        '--runtime-config=[KUBE_RUNTIME_CONFIG]:cfg:' \
        '--enable-pod-security-policy[set ENABLE_POD_SECURITY_POLICY=true]' \
        '--create-custom-network[set CREATE_CUSTOM_NETWORK=true]' \
        '--node-scopes=[NODE_SCOPES env]:scopes:' \
        '--node-service-account=[KUBE_GCE_NODE_SERVICE_ACCOUNT env]:sa:' \
        '--node-accelerators=[NODE_ACCELERATORS env]:accel:' \
        '--cloud-provider=[CLOUD_PROVIDER env]:provider:' \
        '--feature-gates=[KUBE_FEATURE_GATES env]:gates:' \
        '--master-size=[MASTER_SIZE env]:size:' \
        '--node-size=[NODE_SIZE env]:size:' \
        '--ingress-gce-image=[ingress-gce image]:image:' \
        '*::tester args:_normal'
}

_kubetest2-gce "$@"
