#compdef dv2dt
# Documentation: https://www.ctan.org/pkg/dtl
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dv2dt: disassemble TeX DVI file to DTL text format (part of DTL bundle)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:DVI input file:_files -g "*.dvi"' && ret=0
return ret
