#compdef mailcatcher
# Documentation: https://github.com/sj26/mailcatcher
# Reference accessed: 2026-05-19
# Verified: upstream lib/mail_catcher.rb OptionParser in sj26/mailcatcher on GitHub.

# MailCatcher: SMTP test trap with web UI
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-f --foreground)'{-f,--foreground}'[run in foreground (non-Windows)]' \
  '(-b --browse)'{-b,--browse}'[open browser on start]' \
  '(-v --verbose)'{-v,--verbose}'[increase logging verbosity]' \
  '--ip=[bind IP for both SMTP and HTTP]:ip' \
  '--smtp-ip=[smtp ip]:ip' \
  '--smtp-port=[smtp port]:port' \
  '--http-ip=[http ip]:ip' \
  '--http-port=[http port]:port' \
  '--http-path=[http path prefix]:path' \
  '--messages-limit=[max stored messages]:n' \
  '--no-quit[disable quit button]' && ret=0
return ret
