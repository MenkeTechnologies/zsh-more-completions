#compdef mcphost
# Documentation: https://github.com/mark3labs/mcphost
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mcphost: cobra-based Go CLI host for MCP servers
# Subcommands today: script, hooks (init|list|validate), auth (login|logout|status).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'script:run executable YAML-based automation script'
  'hooks:manage hooks configuration'
  'auth:manage authentication'
  'help:help about any command'
)

_arguments -C -s -S \
  '--config=[MCP config file]:file:_files' \
  '--system-prompt=[system prompt text or file]:file:_files' \
  '(-m --model)'{-m+,--model=}'[LLM id (provider/model)]:model' \
  '--debug[enable debug logging]' \
  '(-p --prompt)'{-p+,--prompt=}'[non-interactive prompt string]:prompt' \
  '--quiet[suppress all output except AI response]' \
  '--no-exit[after non-interactive prompt, stay in REPL]' \
  '--max-steps=[max agent steps (0 unlimited)]:count' \
  '--stream[enable streaming model output]' \
  '--no-stream[disable streaming]' \
  '--compact[compact unstylized output]' \
  '--no-hooks[temporarily disable all hooks]' \
  '--approve-tool-run[prompt before each tool call]' \
  '--save-session=[persist session path]:file:_files' \
  '--load-session=[restore session path]:file:_files' \
  '(-s --session)'{-s+,--session=}'[session file read/write]:file:_files' \
  '--provider-url=[override API base URL]:url' \
  '--provider-api-key=[provider API key]:key' \
  '--tls-skip-verify[skip TLS verification (insecure)]' \
  '--max-tokens=[max completion tokens]:count' \
  '--temperature=[sampling temperature]:float' \
  '--top-p=[nucleus top-p]:float' \
  '--top-k=[top-k]:int' \
  '--stop-sequences=[comma-separated stop sequences]:list' \
  '--num-gpu-layers=[Ollama GPU layers]:int' \
  '--main-gpu=[Ollama main GPU index]:int' \
  '(-h --help)'{-h,--help}'[help]' \
  '(-v --version)'{-v,--version}'[version]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd) _describe -t commands 'mcphost command' commands && ret=0 ;;
  args)
    case $words[1] in
      script) _files && ret=0 ;;
      hooks)
        local -a hooks_sub=(
          'init:initialize hooks configuration'
          'list:view active hooks'
          'validate:validate hook configuration'
        )
        _describe -t commands 'mcphost hooks command' hooks_sub && ret=0
        ;;
      auth)
        local -a auth_sub=(
          'login:authenticate (e.g. anthropic OAuth)'
          'logout:remove stored credentials'
          'status:display authentication status'
        )
        _describe -t commands 'mcphost auth command' auth_sub && ret=0
        ;;
      *) _default && ret=0 ;;
    esac
    ;;
esac

return ret
