#compdef eu-elfcompress
# _eu-elfcompress-bin — elfutils ELF section compress/decompress (Mark Wielaard, Red Hat); rewrite ELF with compressed debug sections
# upstream: https://sourceware.org/elfutils

_eu-elfcompress-bin() {
    _arguments \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-t --type)'{-t,--type}'+[compression type]:type:(none zlib zlib-gnu zlib-gabi zstd zstd-gabi)' \
        '(-n --name)'{-n,--name}'+[section name]:name:' \
        '(-p --permissive)'{-p,--permissive}'[allow tweaks]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-? --help)'{-?,--help}'[show help]' \
        '--version[show version]' \
        '*:file:_files'
}

_eu-elfcompress-bin "$@"
