#compdef git-xet
# Documentation: https://github.com/xetdata/xet-tools
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above (archived; XetHub joined Hugging Face).

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(-h --help)'{-h,--help}'[Show help]' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'install:Configure git filter/lfs hooks for XetHub'
      'uninstall:Remove git-xet integration from this repo'
      'lockfiles:Materialize or update Cabal/stack lockfiles'
      'git-lfs-pointer:Create or inspect git-lfs pointer files'
      'login:Authenticate against XetHub'
      'version:Show git-xet version'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
