#compdef drone
# _drone-cli — Drone CI CLI (harness/drone-cli)
# upstream: https://github.com/harness/drone-cli

_drone-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--server=[drone server URL]:url:' \
        '--token=[drone API token]:token:' \
        '--autoscaler=[autoscaler address]:addr:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_drone_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                build)
                    local -a build_subs=(
                        'ls:list builds'
                        'last:show last build'
                        'info:show build info'
                        'create:create a build'
                        'stop:stop a build'
                        'approve:approve a build'
                        'decline:decline a build'
                        'promote:promote a build'
                        'rollback:rollback a build'
                    )
                    _describe -t cmds 'build subcommand' build_subs && ret=0 ;;
                repo)
                    local -a repo_subs=(
                        'ls:list repositories'
                        'info:show repo info'
                        'enable:enable a repo'
                        'disable:disable a repo'
                        'update:update a repo'
                        'sync:sync repositories'
                        'chown:change repo owner'
                        'repair:repair a repo'
                    )
                    _describe -t cmds 'repo subcommand' repo_subs && ret=0 ;;
                secret)
                    local -a secret_subs=(
                        'ls:list secrets'
                        'info:show secret info'
                        'add:add a secret'
                        'update:update a secret'
                        'rm:remove a secret'
                    )
                    _describe -t cmds 'secret subcommand' secret_subs && ret=0 ;;
                user)
                    local -a user_subs=(
                        'ls:list users'
                        'info:show user info'
                        'add:add a user'
                        'rm:remove a user'
                    )
                    _describe -t cmds 'user subcommand' user_subs && ret=0 ;;
                log)
                    local -a log_subs=(
                        'view:view build logs'
                        'purge:purge build logs'
                    )
                    _describe -t cmds 'log subcommand' log_subs && ret=0 ;;
                cron)
                    local -a cron_subs=(
                        'ls:list cron jobs'
                        'info:show cron info'
                        'add:add a cron job'
                        'rm:remove a cron job'
                    )
                    _describe -t cmds 'cron subcommand' cron_subs && ret=0 ;;
                deploy|exec|info|server|queue|lint|sign|convert|jsonnet|starlark|plugins|template|orgsecret) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_drone_commands] )) ||
_drone_commands() {
    local -a commands
    commands=(
        'build:manage builds'
        'deploy:trigger a deployment'
        'exec:execute a local pipeline'
        'info:show server info'
        'log:manage build logs'
        'repo:manage repositories'
        'secret:manage secrets'
        'user:manage users'
        'server:manage server'
        'queue:manage build queue'
        'cron:manage cron jobs'
        'lint:lint a pipeline'
        'sign:sign a pipeline'
        'convert:convert a pipeline'
        'jsonnet:convert jsonnet to yaml'
        'starlark:convert starlark to yaml'
        'plugins:manage plugins'
        'template:manage templates'
        'orgsecret:manage organization secrets'
    )
    _describe -t commands 'drone command' commands
}

_drone-cli "$@"
