#compdef netbird
# Documentation: https://docs.netbird.io/get-started/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'up:connect to the NetBird network'
  'down:disconnect from peers and management'
  'status:retrieve peer connection status'
  'login:authenticate to management service'
  'ssh:SSH to a remote peer'
  'expose:publish local ports to the public internet'
  'networks:manage network selection'
  'profile:handle multiple accounts/profiles'
  'debug:diagnostic and troubleshooting tools'
  'service:manage the NetBird daemon service'
  'version:show version'
)

local -a global_flags
global_flags=(
  '(- *)--help[show help]'
  '(- *)--version[show version]'
  '--admin-url=[management dashboard URL]:url'
  '(-A --anonymize)'{-A,--anonymize}'[anonymize IPs in logs and output]'
  '(-c --config)'{-c,--config}'=[override profile file location]:file:_files'
  '--daemon-addr=[service socket address]:addr'
  '(-n --hostname)'{-n,--hostname}'=[custom device hostname]:name'
  '--log-file=[log output destinations]:file:_files'
  '(-l --log-level)'{-l,--log-level}'=[logging verbosity]:level:(panic fatal error warn info debug trace)'
  '(-m --management-url)'{-m,--management-url}'=[management service URL]:url'
  '--preshared-key=[WireGuard PreSharedKey]:key'
  '(-s --service)'{-s,--service}'=[system service name]:name'
  '(-k --setup-key)'{-k,--setup-key}'=[registration key]:key'
  '--setup-key-file=[file containing setup key]:file:_files'
)

_arguments -C \
  $global_flags \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'netbird command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      up)
        _arguments \
          $global_flags \
          '--allow-server-ssh[allow connecting to the NetBird SSH server]' \
          '--block-inbound[block inbound traffic]' \
          '--block-lan-access[block LAN access]' \
          '--disable-auto-connect[disable auto-connect on startup]' \
          '--disable-client-routes[disable client routes]' \
          '--disable-dns[disable DNS]' \
          '--disable-firewall[disable firewall]' \
          '--disable-ipv6[opt out of IPv6 overlay]' \
          '--disable-server-routes[disable server routes]' \
          '--disable-ssh-auth[disable SSH auth]' \
          '--dns-resolver-address=[DNS resolver address]:addr' \
          '--dns-router-interval=[DNS router interval]:duration' \
          '--enable-lazy-connection[enable lazy connection mode]' \
          '--enable-rosenpass[enable Rosenpass post-quantum security]' \
          '--rosenpass-permissive[Rosenpass permissive mode]' \
          '--enable-ssh-local-port-forwarding[enable local SSH port forwarding]' \
          '--enable-ssh-remote-port-forwarding[enable remote SSH port forwarding]' \
          '--enable-ssh-root[allow SSH root access]' \
          '--enable-ssh-sftp[enable SFTP on the SSH server]' \
          '--external-ip-map=[external IP mapping]:mapping' \
          '--extra-dns-labels=[extra DNS labels]:labels' \
          '--extra-iface-blacklist=[extra interface blacklist]:list' \
          '(-F --foreground-mode)'{-F,--foreground-mode}'[run in foreground]' \
          '--interface-name=[WireGuard interface name]:name' \
          '--mtu=[MTU]:n' \
          '(-N --network-monitor)'{-N,--network-monitor}'[enable network monitor]' \
          '--no-browser[skip browser-based SSO]' \
          '--profile=[profile to use]:name' \
          '--ssh-jwt-cache-ttl=[JWT cache TTL in seconds]:seconds' \
          '--wireguard-port=[WireGuard UDP port]:port' && ret=0
        ;;
      down)
        _arguments $global_flags && ret=0
        ;;
      status)
        _arguments \
          $global_flags \
          '--check[health check mode]' \
          '(-d --detail)'{-d,--detail}'[show detailed peer information]' \
          '--filter-by-connection-type=[filter by P2P/Relayed]:type:(p2p relayed)' \
          '--filter-by-ips=[filter by IP addresses]:ips' \
          '--filter-by-names=[filter by peer names]:names' \
          '--filter-by-status=[filter by connection status]:status:(idle connecting connected)' \
          '--ipv4[show IPv4 only]' \
          '--ipv6[show IPv6 only]' \
          '--json[output JSON]' \
          '--yaml[output YAML]' && ret=0
        ;;
      login)
        _arguments \
          $global_flags \
          '--no-browser[skip browser-based SSO]' \
          '--profile=[profile to use]:name' && ret=0
        ;;
      ssh)
        _arguments \
          $global_flags \
          '*-L[local port forwarding]:spec' \
          '*-R[remote port forwarding]:spec' \
          '(-o --known-hosts)'{-o,--known-hosts}'=[SSH known_hosts file path]:file:_files' \
          '--login=[SSH username alias]:user' \
          '--no-browser[skip browser-based SSO]' \
          '--no-cache[skip cached JWT]' \
          '(-p --port)'{-p,--port}'=[remote SSH port]:port' \
          '--strict-host-key-checking=[host key validation]:bool:(true false)' \
          '(-t --tty)'{-t,--tty}'[force pseudo-terminal]' \
          '(-u --user)'{-u,--user}'=[SSH username]:user' \
          '1:host:' && ret=0
        ;;
      expose)
        _arguments \
          $global_flags \
          '--protocol=[protocol]:proto:(http https tcp udp tls)' \
          '--with-custom-domain=[pre-configured custom domain]:domain' \
          '--with-external-port=[public-facing port]:port' \
          '--with-name-prefix=[service name prefix]:prefix' \
          '--with-password=[password protection]:password' \
          '--with-pin=[6-digit PIN protection]:pin' \
          '--with-user-groups=[SSO group restrictions]:groups' && ret=0
        ;;
      networks)
        local -a network_cmds
        network_cmds=(
          'list:list networks'
          'select:select networks'
          'deselect:deselect networks'
        )
        _arguments -C \
          '1:subcommand:->networkcmd' \
          '*::arg:->networkargs' && ret=0
        case "$state" in
          networkcmd)
            _describe -t commands 'networks subcommand' network_cmds && ret=0
            ;;
          networkargs)
            case "$words[1]" in
              select)
                _arguments \
                  '(-a --append)'{-a,--append}'[append to selection]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      profile)
        _arguments \
          $global_flags \
          '*:profile arg:' && ret=0
        ;;
      debug)
        local -a debug_cmds
        debug_cmds=(
          'bundle:create a debug bundle'
          'for:run debug mode for a duration'
          'log:debug logging'
          'trace:network trace'
        )
        _arguments -C \
          '1:subcommand:->debugcmd' \
          '*::arg:->debugargs' && ret=0
        case "$state" in
          debugcmd)
            _describe -t commands 'debug subcommand' debug_cmds && ret=0
            ;;
          debugargs)
            case "$words[1]" in
              bundle|for)
                _arguments \
                  '(-A --anonymize)'{-A,--anonymize}'[anonymize output]' \
                  '(-C --log-file-count)'{-C,--log-file-count}'=[log file count]:n' \
                  '(-S --system-info)'{-S,--system-info}'[include system info]' \
                  '(-U --upload-bundle)'{-U,--upload-bundle}'[upload bundle]' \
                  '--upload-bundle-url=[upload destination URL]:url' && ret=0
                ;;
              trace)
                _arguments \
                  '--ack[match ACK flag]' \
                  '--fin[match FIN flag]' \
                  '--psh[match PSH flag]' \
                  '--rst[match RST flag]' \
                  '--syn[match SYN flag]' \
                  '--urg[match URG flag]' \
                  '--dport=[destination port]:port' \
                  '--sport=[source port]:port' \
                  '(-p --protocol)'{-p,--protocol}'=[protocol]:proto:(tcp udp icmp)' \
                  '--icmp-code=[ICMP code]:code' \
                  '--icmp-type=[ICMP type]:type' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      service)
        local -a service_cmds
        service_cmds=(
          'install:install the service'
          'uninstall:uninstall the service'
          'start:start the service'
          'stop:stop the service'
          'restart:restart the service'
          'status:show service status'
          'reconfigure:reconfigure the service'
          'reset-params:reset service parameters'
        )
        _arguments -C \
          '1:subcommand:->servicecmd' \
          '*::arg:->serviceargs' && ret=0
        case "$state" in
          servicecmd)
            _describe -t commands 'service subcommand' service_cmds && ret=0
            ;;
          serviceargs)
            case "$words[1]" in
              install)
                _arguments \
                  '--disable-profiles[disable profiles]' \
                  '--disable-update-settings[disable update settings]' \
                  '*--service-env=[KEY=VALUE service env var]:env' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      *)
        _arguments $global_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
