#compdef lookatme
# Documentation: https://github.com/d0c-s4vage/lookatme
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--debug[enable debug mode]' \
  '(-l --log)'{-l,--log}'=[log file path]:file:_files' \
  '--tutorial=[show tutorial (all or named)]:topic:' \
  '(-t --theme)'{-t,--theme}'=[color theme]:theme:(dark light)' \
  '--style=[syntax highlighting style]:style:' \
  '--dump-styles[dump resolved styles to stdout]' \
  '--live[watch input file and auto-reload]' \
  '--live-reload[watch input file and auto-reload]' \
  '(-s --safe)'{-s,--safe}'[do not load extensions from source markdown]' \
  '--no-ext-warn[load extensions without warnings]' \
  '(-i --ignore-ext-failure)'{-i,--ignore-ext-failure}'[ignore extension load failures]' \
  '(-e --exts)'{-e,--exts}'=[comma-separated extensions to load]:extensions:' \
  '--single[render the source as a single slide]' \
  '--one[render the source as a single slide]' \
  '*:markdown file:_files -g "*.md"' && ret=0

return ret
