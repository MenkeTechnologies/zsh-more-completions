#compdef netgen
# Documentation: https://manpages.ubuntu.com/manpages/focal/man1/netgen.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Netgen: automatic 3D tetrahedral mesh generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-batchmode[run in batch mode (no GUI)]' \
  '--batchmode[run in batch mode (no GUI)]' \
  '-geofile=[geometry input file]:file:_files -g "*.(geo|in2d|stl|step|stp|igs)"' \
  '-meshfile=[output mesh file]:file:_files -g "*.(vol|mesh)"' \
  '-meshfiletype=[mesh file format]:format:("Neutral Format" "Surface Mesh Format" "DIFFPACK Format" "TecPlot Format" "Tochnog Format" "Abaqus Format" "Fluent Format" "Permas Format" "FEAP Format" "Elmer Format" "STL Format" "VRML Format" "Gmsh Format" "Gmsh2 Format" "OpenFOAM 1.5+ Format" "JCMwave Format" "TET Format")' \
  '--meshfiletype=[mesh file format]:format:("Neutral Format" "Surface Mesh Format" "DIFFPACK Format" "TecPlot Format" "Tochnog Format" "Abaqus Format" "Fluent Format" "Permas Format" "FEAP Format" "Elmer Format" "STL Format" "VRML Format" "Gmsh Format" "Gmsh2 Format" "OpenFOAM 1.5+ Format" "JCMwave Format" "TET Format")' \
  '-meshsize=[global maximum mesh element size]:val:' \
  '-meshsizefile=[mesh size definition file]:file:_files' \
  '-inputmeshfile=[input mesh file (batchmode)]:file:_files' \
  '-mergefile=[merge with mesh file]:file:_files' \
  '-refinementfile=[refinement info file]:file:_files' \
  '-loadgeom[load geometry without meshing]' \
  '-meshscale=[scale factor for mesh]:val:' \
  '-cmd=[batch-mode command string]:cmd:' \
  '-localh[allow local mesh refinement]' \
  '-veryfine[very fine mesh density]' \
  '-fine[fine mesh density]' \
  '-moderate[moderate density (default)]' \
  '-coarse[coarse density]' \
  '-verycoarse[very coarse density]' \
  '-V[verbose output]' \
  '*:geometry file:_files -g "*.(geo|in2d|stl|step|stp|igs|brep|iges)"' && ret=0
return ret
