#compdef quandl-cli quandl nasdaq-data-link
# _quandl-cli — Nasdaq Quandl quandl-cli nasdaq-data-link CLI command-line frontend wrapping the Nasdaq Data Link formerly Quandl REST financial-economic-alternative data API managing datasets datatables time-series Sharadar Zacks Wikipedia Wiki-Prices FRED OECD WHO BIS futures Continuous-Futures end-of-day continuous-futures fundamentals (Nasdaq team, Go); cobra
# upstream: https://data.nasdaq.com/

_quandl-cli() {
    local -a sub=(
        'login:authenticate'
        'dataset:dataset operations'
        'datatable:datatable operations'
        'time-series:time series'
        'database:database operations'
        'search:search'
        'metadata:metadata operations'
        'download:download dataset bulk'
        'futures:futures operations'
        'continuous-futures:continuous futures'
        'fundamentals:fundamentals'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--collapse=+[c]:c:(none daily weekly monthly quarterly annual)' \
        '--transform=+[t]:t:(none diff rdiff cumul normalize)' \
        '--start-date=+[YYYY-MM-DD]:str:' \
        '--end-date=+[YYYY-MM-DD]:str:' \
        '--limit=+[N]:n:' \
        '--rows=+[N]:n:' \
        '--order=+[o]:o:(asc desc)' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv xml table)' \
        '--format=+[format]:f:(json yaml csv xml table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'quandl-cli subcommand' sub ;;
        args)
            case $words[1] in
                dataset|time-series|continuous-futures|fundamentals) _arguments '*:database/dataset:' ;;
                datatable) _arguments '*:datatable code:' ;;
                search) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_quandl-cli "$@"
