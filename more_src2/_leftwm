#compdef leftwm
# Documentation: https://github.com/leftwm/leftwm/blob/main/leftwm/src/bin/leftwm.rs
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for leftwm (tiling window manager).
# leftwm dispatches each subcommand to a separate leftwm-<subcommand> binary.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'check:check syntax of the configuration file'
  'command:send external commands to LeftWM'
  'state:print the current state of LeftWM'
  'theme:manage LeftWM themes'
  'config:manage LeftWM configuration file'
  'log:retrieve information logged by leftwm-worker'
  'help:show help'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:_default' && ret=0

case $state in
  command)
    _describe -t commands 'leftwm command' commands && ret=0
    ;;
esac

return ret
