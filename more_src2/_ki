#compdef ki
# _ki — Ki: combinatorial multi-cursor modal text editor (ki-editor/ki-editor)
# upstream: https://github.com/ki-editor/ki-editor
# Subcommands from src/cli.rs (clap derive); top-level args open a file.

_ki() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_ki_top' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                @)
                    _arguments \
                        '1: :_ki_at_commands' \
                        '*::at args:->atargs' && ret=0
                    case $state in
                        atargs)
                            case $words[1] in
                                grammar)
                                    _arguments '1: :(build fetch)' && ret=0 ;;
                                log)
                                    _arguments '1: :(default lsp)' && ret=0 ;;
                                keymap)
                                    _arguments '1: :(keymap-drawer table)' && ret=0 ;;
                                in)
                                    _arguments '1:working directory:_files -/' && ret=0 ;;
                                embed)
                                    _arguments '1:working directory:_files -/' && ret=0 ;;
                                version) ;;
                            esac ;;
                    esac ;;
                edit)
                    _arguments '1:path to file:_files' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_ki_top] )) ||
_ki_top() {
    local -a entries
    entries=(
        '@:run a Ki subcommand (grammar / log / keymap / in / embed / version)'
        'edit:edit a file at the given path (creates it if missing)'
    )
    _describe -t commands 'ki command' entries
    _files
}

(( $+functions[_ki_at_commands] )) ||
_ki_at_commands() {
    local -a commands
    commands=(
        'grammar:build or fetch tree-sitter grammar files'
        'log:control or tail Ki logs (KI_LOG env var sets level)'
        'keymap:display the keymap in various formats'
        'in:run Ki with the given path as working directory'
        'embed:run Ki in embedded mode (e.g. VS Code extension)'
        'version:print Ki version'
    )
    _describe -t commands 'ki @ command' commands
}

_ki "$@"
