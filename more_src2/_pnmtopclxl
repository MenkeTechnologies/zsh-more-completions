#compdef pnmtopclxl
# Documentation: man pnmtopclxl (Netpbm)
# Source: convert a Netpbm image stream to HP PCL XL printer commands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dpi=[output resolution dpi]:n:' \
    '-xoffs=[x offset in pixels]:n:' \
    '-yoffs=[y offset in pixels]:n:' \
    '-center[centre on the page]' \
    '-duplex=[duplex mode]:mode:(vertical horizontal)' \
    '-format=[paper format]:format:(letter legal a3 a4 a5 b4 b5 executive ledger jisb4 jisb5)' \
    '-feeder=[paper feeder tray]:n:' \
    '-copies=[number of copies]:n:' \
    '-rendergray[render as grayscale]' \
    '-jobsetup=[job setup file]:file:_files' \
    '-embedded[output embedded in another job]' \
    '-colorok[allow color output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
