#compdef kamal
# Documentation: https://kamal-deploy.org/docs/commands/view-all-commands/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Kamal deploy tool. Corrected from prior file against Kamal 2 docs:
# replaced removed 'traefik' command with 'proxy', added build/docs/
# help/secrets/upgrade; fixed global options (-v is --verbose not
# --version; --version is a value flag; added -c/-p/-h/-r/-q/-H).

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[enable detailed logging]' \
  '(-q --quiet)'{-q,--quiet}'[enable minimal logging]' \
  '(-c --config-file)'{-c,--config-file}'=[config file path]:file:_files' \
  '(-d --destination)'{-d,--destination}'=[config destination]:destination:' \
  '(-p --primary)'{-p,--primary}'[execute on primary host only]' \
  '(-h --hosts)'{-h,--hosts}'=[run on specific hosts]:hosts:' \
  '(-r --roles)'{-r,--roles}'=[run on specific roles]:roles:' \
  '(-H --skip-hooks)'{-H,--skip-hooks}'[disable hook execution]' \
  '--version=[target app version]:version:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case "$state" in
  commands)
    local -a cmds=(
      'setup:set up a new application on servers'
      'deploy:deploy the application'
      'redeploy:redeploy the application'
      'rollback:rollback to a previous version'
      'details:show details about the application'
      'audit:show audit log'
      'build:build the application image'
      'config:show configuration'
      'docs:show documentation'
      'help:show help'
      'init:initialize a new Kamal project'
      'lock:acquire deploy lock'
      'unlock:release deploy lock'
      'remove:remove the application from servers'
      'app:manage the application'
      'accessory:manage accessories'
      'proxy:manage kamal-proxy'
      'prune:prune old images and containers'
      'registry:manage registry'
      'secrets:manage secrets'
      'server:manage servers'
      'upgrade:upgrade Kamal on servers'
      'version:show Kamal version'
    )
    _describe -t commands 'kamal command' cmds && ret=0
    ;;
esac
return ret
