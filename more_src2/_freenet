_freenet() {
    case "$service" in
        fdev)
            _fdev_main "$@"
            return
            ;;
    esac

    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--mode=[operation mode]:mode:(local network)' \
        '--log-level=[log level (env LOG_LEVEL)]:level:(error warn info debug trace)' \
        '--max-blocking-threads=[max blocking threads (env MAX_BLOCKING_THREADS)]:n:' \
        '--max-hosting-storage=[max hosting storage in bytes]:bytes:' \
        '--shutdown-drain-secs=[shutdown drain seconds]:n:' \
        '--ws-api-address=[WS API bind address]:ip:' \
        '--ws-api-port=[WS API bind port]:port:' \
        '--address=[network bind IP]:ip:' \
        '--network-port=[network bind port]:port:' \
        '--public-network-address=[public-advertised IP]:ip:' \
        '--public-network-port=[public-advertised port]:port:' \
        '--is-gateway[run as a gateway peer]' \
        '--skip-load-from-network[skip bootstrap state sync]' \
        '*--gateway=[additional gateway peer]:addr:' \
        '--ignore-protocol-checking[skip protocol-version verification]' \
        '--config-dir=[override config directory]:dir:_files -/' \
        '--data-dir=[override data directory]:dir:_files -/' \
        '--log-dir=[override log directory]:dir:_files -/' \
        '--secrets-dir=[override secrets directory]:dir:_files -/' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _fr_cmds=(
                'network:run node in network mode (default)'
                'local:run node in local-only mode'
                'service:manage Freenet system service'
                'update:auto-update to latest version'
                'uninstall:remove service + binaries + data'
                'secrets:manage node KEK (Key Encryption Key)'
            )
            _describe -t commands 'freenet command' _fr_cmds && ret=0
            ;;
        args)
            case $words[1] in
                service)
                    _arguments \
                        '1:action:(start stop restart status install uninstall enable disable logs)' && ret=0
                    ;;
                secrets)
                    _arguments \
                        '1:action:(status rotate migrate)' \
                        '--backend=[KEK backend]:backend:(keyring systemd file)' && ret=0
                    ;;
                update|uninstall)
                    _arguments \
                        '--yes[skip confirmation prompts]' && ret=0
                    ;;
                network|local)
                    _arguments \
                        '*: :_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_fdev_main() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _fd_cmds=(
                'build:build contract package from project'
                'inspect:inspect contract metadata'
                'init:initialize new contract project'
                'new:create new contract / delegate package'
                'publish:publish package to network'
                'execute:execute node command (put/get/update/subscribe)'
                'test:test framework (uses Turmoil)'
                'network-metrics-server:start network metrics HTTP server'
                'query:query node state'
                'diagnostics:diagnostics dump'
                'get-contract-id:compute contract ID from package'
                'wasm-runtime:local WASM executor'
            )
            _describe -t commands 'fdev command' _fd_cmds && ret=0
            ;;
        args)
            case $words[1] in
                execute)
                    _arguments \
                        '1:command:(put get update subscribe get-contract-id)' \
                        '*:contract file:_files -g "*.wasm"' && ret=0
                    ;;
                new)
                    _arguments \
                        '1:kind:(contract delegate website)' \
                        '--path=[project path]:dir:_files -/' && ret=0
                    ;;
                build|inspect|publish|get-contract-id)
                    _arguments \
                        '1:file:_files -g "*.wasm"' && ret=0
                    ;;
                diagnostics)
                    _arguments \
                        '*--contract-keys=[contract keys to inspect]:keys:' && ret=0
                    ;;
                test)
                    _arguments \
                        '1:test config:_files -g "*.(toml|yaml|yml|json)"' && ret=0
                    ;;
                init)
                    _arguments \
                        '--path=[project path]:dir:_files -/' && ret=0
                    ;;
                network-metrics-server)
                    _arguments \
                        '--port=[HTTP port]:port:' \
                        '--bind=[bind address]:addr:' && ret=0
                    ;;
                query)
                    _arguments \
                        '*:contract key:' && ret=0
                    ;;
                wasm-runtime)
                    _arguments \
                        '*:wasm executor config:_files' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_freenet "$@"
