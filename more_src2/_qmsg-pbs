#compdef qmsg
# _qmsg-pbs — PBS qmsg (write a message into the output (-O), error (-E) or both (-OE/-EO) streams of one or more running PBS jobs; positional arguments are the destination stream selector flags followed by the message string then jobIDs)
# upstream: https://github.com/openpbs/openpbs
# Flags from openpbs src/cmds/qmsg.c on tip.

_qmsg-pbs() {
    _arguments \
        '-O[output stream]' \
        '-E[error stream]' \
        '1:message:' \
        '*:jobID:'
}

_qmsg-pbs "$@"
