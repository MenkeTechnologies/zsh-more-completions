#compdef mtvtoppm
# Documentation: man mtvtoppm (Netpbm)
# Source: convert an MTV ray-tracer image file to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:mtv file:_files' \
    && ret=0

return ret
