#compdef dmtxwrite
# Documentation: https://manpages.debian.org/testing/dmtx-utils/dmtxwrite.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --codewords)'{-c,--codewords}'[print codeword listing instead of creating barcode]' \
  '(-d --module)'{-d,--module}'+[module size in pixels]:px' \
  '(-e --encoding)'{-e,--encoding}'+[encoding scheme]:scheme:(b f a c t x e 8)' \
  '(-f --format)'{-f,--format}'+[output image format]:format:(png pdf svg ps eps gif tiff bmp tif)' \
  '(-l --list-formats)'{-l,--list-formats}'[list available image formats]' \
  '(-m --margin)'{-m,--margin}'+[margin size in pixels]:px' \
  '(-o --output)'{-o,--output}'+[barcode output filename]:file:_files' \
  '(-p --preview)'{-p,--preview}'[ASCII art preview]' \
  '(-r --resolution)'{-r,--resolution}'+[image print resolution dpi]:dpi' \
  '(-s --symbol-size)'{-s,--symbol-size}'+[symbol size sr|RxC]:size' \
  '(-C --color)'{-C,--color}'+[barcode color (not implemented)]:color' \
  '(-B --bg-color)'{-B,--bg-color}'+[background color (not implemented)]:color' \
  '(-M --mosaic)'{-M,--mosaic}'[create non-standard Data Mosaic barcode]' \
  '(-R --rotate)'{-R,--rotate}'+[rotate degrees (not implemented)]:deg' \
  '(-v --verbose)'{-v,--verbose}'[verbose messages]' \
  '*:input:_files' && ret=0

return ret
