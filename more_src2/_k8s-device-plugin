#compdef k8s-device-plugin
# Documentation: https://github.com/NVIDIA/k8s-device-plugin/blob/main/cmd/nvidia-device-plugin/main.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# k8s-device-plugin (NVIDIA): expose GPUs as k8s extended resources
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print the version]' \
  '--mig-strategy=[strategy for exposing MIG devices]:strategy:(none single mixed)' \
  '--fail-on-init-error=[fail the plugin on init error]:bool:(true false)' \
  '--device-list-strategy=[strategy for passing the device list]:strategy:(envvar volume-mounts cdi-annotations)' \
  '--device-id-strategy=[strategy for passing device IDs]:strategy:(uuid index)' \
  '--driver-root=[root path for the NVIDIA driver installation]:path:' \
  '--dev-root=[root path for the NVIDIA device nodes]:path:' \
  '--pass-device-specs[pass the list of DeviceSpecs to the kubelet on Allocate()]' \
  '--gdrcopy-enabled[start containers with GDRCopy support]' \
  '--gds-enabled[start containers with GPUDirect Storage support]' \
  '--mofed-enabled[start containers with MOFED support]' \
  '--config-file=[config file as alternative to flags/env]:file:_files' \
  '--cdi-annotation-prefix=[prefix for CDI container annotation keys]:prefix:' \
  '--nvidia-cdi-hook-path=[path for NVIDIA CDI hooks in the generated CDI spec]:file:_files' \
  '--driver-root-ctr-path=[path where the NVIDIA driver root is mounted in the container]:path:' \
  '--mps-root=[host path where MPS-specific mounts/files are created]:path:' \
  '--device-discovery-strategy=[strategy to discover devices]:strategy:(auto nvml tegra)' \
  '--imex-channel-ids=[list of IMEX channels to inject]:ids:' \
  '--imex-required[the specified IMEX channels are required]' \
  '--kubelet-socket=[socket for communicating with the kubelet]:socket:_files' \
  '--cdi-feature-flags=[feature flags for CDI spec generation]:flags:' \
  '*::k8s-device-plugin args:_files' && ret=0
return ret
