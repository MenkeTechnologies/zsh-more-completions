#compdef ilert-cli ilert
# _ilert-cli — iLert ilert-cli CLI command-line frontend wrapping the iLert German Munich alert management incident response on-call paging status page platform REST API providing user team service alert-source escalation-policy schedule rotation override uptime-monitor heartbeat incident alert acknowledge resolve assign tag status-page service-status maintenance-window webhook (iLert team Birol Yildiz Christian Fröhlingsdorf, Go); cobra
# upstream: https://www.ilert.com/

_ilert-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'whoami:show identity'
        'user:user operations'
        'team:team operations'
        'service:service operations'
        'alert-source:alert source operations'
        'escalation-policy:escalation policy operations'
        'schedule:schedule operations'
        'rotation:rotation operations'
        'override:override operations'
        'uptime-monitor:uptime monitor operations'
        'heartbeat:heartbeat operations'
        'incident:incident operations'
        'alert:alert operations'
        'tag:tag operations'
        'status-page:status page operations'
        'maintenance-window:maintenance window operations'
        'webhook:webhook operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-url=+[url]:str:' \
        '--organization=+[id]:str:' \
        '--basic-auth=+[user:password]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml *.toml"' \
        '--config=+[file]:file:_files -g "*.yml *.yaml *.toml"' \
        '-o+[format]:f:(json yaml table)' \
        '--output=+[format]:f:(json yaml table)' \
        '--insecure[skip TLS verify]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ilert subcommand' sub ;;
        args)
            case $words[1] in
                user|team|service|alert-source|escalation-policy|schedule|rotation|override|uptime-monitor|heartbeat|incident|alert|tag|status-page|maintenance-window|webhook) _arguments '1:op:(list get create update delete acknowledge resolve assign close mute unmute trigger)' '*:id:' ;;
            esac
            ;;
    esac
}

_ilert-cli "$@"
