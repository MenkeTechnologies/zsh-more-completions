#compdef gguf-dump
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/gguf-py/gguf/scripts/gguf_dump.py
# Reference accessed: 2026-05-27
# Verified: upstream argparse in gguf-py/gguf/scripts/gguf_dump.py

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--no-tensors[do not dump tensor metadata]' \
  '--json[produce JSON output]' \
  '--json-array[include full array values in JSON output (long)]' \
  '--data-offset[show start of data offset]' \
  '--data-alignment[show data alignment applied globally to data field]' \
  '--markdown[produce markdown output]' \
  '--verbose[increase output verbosity]' \
  '1:GGUF model:_files -g "*.gguf"' && ret=0

return ret
