#compdef renode renode-test
# _renode — Antmicro Renode CLI for the embedded systems multi-architecture simulator running ARM Cortex-M RISC-V x86 platforms with virtual peripherals UART CAN I2C SPI Ethernet emulation Robot-Framework test suite (antmicro team, C#); System.CommandLine
# upstream: https://github.com/renode/renode

_renode() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--port=+[port]:n:' \
        '-P+[port]:n:' \
        '--disable-xwt[no XWT GUI]' \
        '-X[no XWT GUI]' \
        '--console[console mode]' \
        '-c[console mode]' \
        '--keep-temporary-files[keep temp files]' \
        '--hide-monitor[hide monitor]' \
        '--hide-log[hide log]' \
        '--hide-analyzers[hide analyzers]' \
        '--robot-server-port=+[port]:n:' \
        '--gui-window-position=+[x,y]:str:' \
        '--gui-window-size=+[w,h]:str:' \
        '--root=+[dir]:dir:_files -/' \
        '--config=+[file]:file:_files -g "*.config"' \
        '--plain[plain output]' \
        '-p[plain output]' \
        '--log-level=+[level]:l:(noisy debug info warning error)' \
        '--log-file=+[file]:file:_files' \
        '--remote=+[host:port]:str:' \
        '--gdb=+[host:port]:str:' \
        '--profiler[enable profiler]' \
        '--profiler-output=+[file]:file:_files' \
        '-e+[command]:str:' \
        '--execute=+[command]:str:' \
        '*:script:_files -g "*.resc *.repl"'
}

_renode "$@"
