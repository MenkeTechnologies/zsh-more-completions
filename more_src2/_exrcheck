#compdef exrcheck
# _exrcheck — validate OpenEXR file contents (AcademySoftwareFoundation/openexr)
# upstream: https://github.com/AcademySoftwareFoundation/openexr
# Flags from src/bin/exrcheck/main.cpp (custom getopt-style usage).

_exrcheck() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '-m[avoid excessive memory allocation]' \
        '-t[avoid spending excessive time]' \
        '-s[use stream API instead of file API]' \
        '-c[add core library checks]' \
        '*:EXR file:_files -g "*.exr"'
}

_exrcheck "$@"
