#compdef ppmshift
# Documentation: man ppmshift (Netpbm)
# Source: shift each scanline of a PPM by a random amount up to N pixels.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:max shift in pixels:' \
    '2:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
