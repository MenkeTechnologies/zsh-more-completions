#compdef fbreader FBReader
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/fbreader.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-zlui[start with specified UI type]:ui-type:(gtk qt qt4)' \
  '-lang[set user interface language]:lang:(ar zh cs nl en fi fr de hu id it lt ru es sv uk)' \
  '*:ebook:_files -g "*.{epub,fb2,mobi,html,txt,rtf,chm,pdb}"' && ret=0

return ret
