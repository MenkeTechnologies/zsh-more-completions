#compdef gowin_pack
# _gowin_pack — Project Apicula gowin_pack CLI packing nextpnr-gowin output FASM hex netlist representations into Gowin .fs FPGA bitstream files for LittleBee GW1N GW1NR GW2A series chips with optional checksum SPI flash header for openFPGALoader downstream programming (YowASIC team, Python); custom argparse
# upstream: https://github.com/YosysHQ/apicula

_gowin_pack() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-d+[device]:d:(GW1N-1 GW1N-9 GW1N-9C GW1N-4 GW1NS-2 GW1NSR-4C GW2A-18 GW2A-18C GW2AR-18 GW2A-55C GW1NZ-1 GW1NR-9C)' \
        '-o+[output file]:file:_files -g "*.fs"' \
        '-s+[svf file]:file:_files -g "*.svf"' \
        '-c[compress]' \
        '--cpu+[name]:str:' \
        '--family=+[f]:f:(GW1N-1 GW1N-4 GW1N-9 GW1NR-9 GW1NS-2 GW2A-18 GW1NZ-1 GW1NR-9C)' \
        '--png=+[image]:file:_files -g "*.png"' \
        '--allow_pinless_io[allow pinless io]' \
        '--jtag-as-gpio[JTAG as GPIO]' \
        '--sspi-as-gpio[SSPI as GPIO]' \
        '--mspi-as-gpio[MSPI as GPIO]' \
        '--ready-as-gpio[READY as GPIO]' \
        '--done-as-gpio[DONE as GPIO]' \
        '--reconfign-as-gpio[RECONFIG_N as GPIO]' \
        '--mode-as-gpio[MODE as GPIO]' \
        '*:fasm file:_files -g "*.fasm *.txt"'
}

_gowin_pack "$@"
