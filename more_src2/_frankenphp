#compdef frankenphp
# Documentation: https://frankenphp.dev/docs/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# FrankenPHP — PHP application server built on top of Caddy.

local curcontext="$curcontext" state line ret=1
local -a subcmds

subcmds=(
  'run:run with a Caddyfile configuration'
  'php-server:serve content from the current directory'
  'php-cli:run a PHP CLI script'
  'extension-init:initialize a PHP extension'
  'completion:generate shell completions'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[Caddyfile path]:file:_files' \
  '1: :->cmd' \
  '*:: :->rest' && ret=0

case $state in
  cmd)
    _describe -t commands 'frankenphp' subcmds && ret=0
    ;;
  rest)
    case $words[1] in
      completion)
        _values 'shell' bash zsh fish powershell && ret=0
        ;;
      *)
        _normal && ret=0
        ;;
    esac
    ;;
esac

return ret
