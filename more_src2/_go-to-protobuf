#compdef go-to-protobuf
# _go-to-protobuf — Kubernetes Go-struct → Protobuf IDL generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/go-to-protobuf/protobuf/cmd.go on tip.

_go-to-protobuf() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-h --go-header-file)'{-h,--go-header-file=}'[Go header file prepended to generated files]:file:_files' \
        '(-p --packages)'{-p,--packages=}'[comma-sep input package dirs (- skip, + opt-in)]:list:' \
        '--apimachinery-packages=[comma-sep apimachinery input package dirs]:list:' \
        '--output-dir=[output base directory]:dir:_files -/' \
        '*--proto-import=[imported-proto search path (repeatable)]:dir:_files -/' \
        '--conditional=[Go build tag condition for generated code]:tag:' \
        '--clean[remove all generated files for the listed packages]' \
        '--only-idl[generate only the .proto IDL]' \
        '--keep-gogoproto[keep gogoprotobuf extensions in generated IDL]' \
        '--skip-generated-rewrite[skip fixing up generated.pb.go (debug)]' \
        '--drop-gogo-go[drop gogo references from generated code]' \
        '--drop-embedded-fields=[comma-sep embedded Go types to omit]:list:' \
        '-v[klog verbosity level]:n:'
}

_go-to-protobuf "$@"
