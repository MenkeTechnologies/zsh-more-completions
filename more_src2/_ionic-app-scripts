#compdef ionic-app-scripts
# _ionic-app-scripts — Ionic legacy app build scripts (Ionic Team); ng4-era build wrapper for Ionic 3 apps
# upstream: https://github.com/ionic-team/ionic-app-scripts

_ionic-app-scripts() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--rootDir+[root dir]:dir:_files -/' \
        '--srcDir+[src dir]:dir:_files -/' \
        '--wwwDir+[www dir]:dir:_files -/' \
        '--buildDir+[build dir]:dir:_files -/' \
        '--target+[target]:target:(cordova browser web)' \
        '--platform+[platform]:platform:(ios android windows)' \
        '--dev[development build (default)]' \
        '--prod[production build]' \
        '--port+[serve port]:port:' \
        '--address+[bind addr]:host:_hosts' \
        '--livereload[live reload]' \
        '--no-livereload[no live reload]' \
        '--lab[Ionic Lab]' \
        '--browser+[browser]:browser:(chrome firefox safari opera)' \
        '--browseroption+[browser options]:str:' \
        '--env+[env preset]:env:(dev prod)' \
        '--aot[ahead of time compile]' \
        '--minifyjs[minify JS]' \
        '--minifycss[minify CSS]' \
        '--optimizejs[optimize JS]' \
        '--debug[debug mode]' \
        '--nointeractive[no prompts]' \
        '--silent[silent]' \
        '*:task:'
}

_ionic-app-scripts "$@"
