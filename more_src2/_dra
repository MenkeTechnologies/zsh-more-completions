#compdef dra
# Documentation: https://github.com/devmatteini/dra
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dra: download release assets from GitHub

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'download:download (and optionally install) release assets'
  'untag:generate version-free asset name pattern'
  'completion:generate shell completion scripts'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'dra command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (download)
        _arguments \
          '(-s --select)'{-s,--select}'=[select asset matching pattern]:pattern' \
          '(-o --output)'{-o,--output}'=[output file or directory]:path:_files' \
          '(-i --install)'{-i,--install}'[install to directory]' \
          '(-I --install-file)'{-I,--install-file}'=[executable to install from archive]:file' \
          '(-a --automatic)'{-a,--automatic}'[auto-select asset matching OS/arch]' \
          '(-t --tag)'{-t,--tag}'=[download specific release tag]:tag' \
          '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
          '1:repository (owner/repo)' && ret=0
        ;;
      (untag)
        _arguments \
          '1:asset name' && ret=0
        ;;
      (completion)
        _arguments \
          '1:shell:(bash zsh fish elvish powershell)' && ret=0
        ;;
    esac
    ;;
esac

return ret
