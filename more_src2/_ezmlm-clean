#compdef ezmlm-clean
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-clean.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-m[timed-out post sent as MIME enclosure (default)]' \
  '-M[timed-out post appended to message]' \
  '-r[timed-out post returned to sender (default)]' \
  '-R[timed-out post discarded silently]' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' && ret=0

return ret
