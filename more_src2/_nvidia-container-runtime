#compdef nvidia-container-runtime
# _nvidia-container-runtime — runc-compatible OCI runtime that injects NVIDIA devices into the spec, then execs runc
# upstream: https://github.com/NVIDIA/nvidia-container-toolkit
# CLI surface from internal/runtime/runtime.go on tip: --version honored locally, every other flag is passed through to the underlying runc (see _runc).

_nvidia-container-runtime() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print NVIDIA Container Runtime version]' \
        '--debug[passed through to runc]' \
        '--log=[passed through to runc]:file:_files' \
        '--log-format=[passed through to runc]:fmt:(text json)' \
        '--root=[passed through to runc]:dir:_files -/' \
        '--systemd-cgroup[passed through to runc]' \
        '--rootless=[passed through to runc]:mode:(true false auto)' \
        '1: :->cmd' \
        '*::arg:->args'
}

_nvidia-container-runtime "$@"
