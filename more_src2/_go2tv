#compdef go2tv

_arguments -s -S \
  '(- *)--help[display help and exit]' \
  '(- *)--version[display version and exit]' \
  '-v[path to video file]:video file:_files' \
  '-s[path to subtitle file]:subtitle file:_files' \
  '-l[list available media renderers]' \
  '-t[target media renderer]:target:' \
  '-u[stream URL]:url:' \
  '-d[enable debug mode]' \
  '*:file:_files'
