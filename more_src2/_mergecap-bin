#compdef mergecap
# _mergecap-bin — Wireshark capture-file merger; combine several .pcap files into one
# upstream: https://gitlab.com/wireshark/wireshark

_mergecap-bin() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-V[show version]' \
        '-a[append packets even if timestamps go backward]' \
        '-F+[output format]:fmt:' \
        '-I+[idb merge mode]:mode:' \
        '-s+[snap length]:n:' \
        '-T+[output encapsulation]:type:' \
        '-w+[output file]:file:_files' \
        '-c+[concat]:bool:' \
        '*:file:_files'
}

_mergecap-bin "$@"
