#compdef foamNewBC
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamNewBC — generate boilerplate for a custom boundary-condition class.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-f -fixedValue fixedValue -m -mixed mixed)'{-f,-fixedValue}'[fixedValue base]' \
    '(-f -fixedValue fixedValue -m -mixed mixed)'{-m,-mixed}'[mixed base]' \
    '(-a -all all template -s -scalar scalar -v -vector vector -t -tensor tensor -symmTensor symmTensor -sphericalTensor sphericalTensor)'{-a,-all}'[template class]' \
    '(-a -all all template -s -scalar scalar -v -vector vector -t -tensor tensor -symmTensor symmTensor -sphericalTensor sphericalTensor)'{-s,-scalar}'[scalar field type]' \
    '(-a -all all template -s -scalar scalar -v -vector vector -t -tensor tensor -symmTensor symmTensor -sphericalTensor sphericalTensor)'{-v,-vector}'[vector field type]' \
    '(-a -all all template -s -scalar scalar -v -vector vector -t -tensor tensor -symmTensor symmTensor -sphericalTensor sphericalTensor)'{-t,-tensor}'[tensor field type]' \
    '(-a -all all template -s -scalar scalar -v -vector vector -t -tensor tensor -symmTensor symmTensor -sphericalTensor sphericalTensor)-symmTensor[symmetric tensor field type]' \
    '(-a -all all template -s -scalar scalar -v -vector vector -t -tensor tensor -symmTensor symmTensor -sphericalTensor sphericalTensor)-sphericalTensor[spherical tensor field type]' \
    '*:BC class name:' \
    && ret=0

return ret
