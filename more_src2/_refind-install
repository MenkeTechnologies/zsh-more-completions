#compdef refind-install
# Documentation: https://www.rodsbooks.com/refind/refind-install.html
# Reference accessed: 2026-05-16
# Verified: upstream rodsbooks.com refind-install docs. Bash script
# with Linux + macOS dual-mode flags.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# refind-install: install rEFInd boot manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '--notesp[install to OS X root rather than ESP (macOS only)]' \
  '--usedefault=[install to fallback EFI/BOOT on unmounted ESP/FAT]:device:' \
  '--ownhfs=[install to non-standard HFS+ volume (macOS only)]:device:' \
  '--root=[install to mountpoint other than current OS]:mountpoint:_files -/' \
  '--nodrivers[skip automatic driver installation]' \
  '--alldrivers[copy all driver files for system architecture]' \
  '--shim=[set up Secure Boot via Shim]:file:_files' \
  '--preloader=[set up Secure Boot via PreLoader]:file:_files' \
  '--localkeys[re-sign binaries with locally generated MOK keys]' \
  '--encryptkeys[encrypt private key with password (with --localkeys)]' \
  '--keepname[retain rEFInd filename instead of renaming to grubx64.efi]' \
  '--yes[answer yes to all prompts]' && ret=0
return ret
