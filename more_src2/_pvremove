#compdef pvremove
# _pvremove — remove physical volume (LVM2); clear LVM label and metadata from a device
# upstream: https://gitlab.com/lvmteam/lvm2

_pvremove() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-f --force)'{-f,--force}'[force]' \
        '(-y --yes)'{-y,--yes}'[no prompts]' \
        '--labelsector+[label sector]:n:' \
        '--reportformat+[report format]:fmt:(basic json)' \
        '*:device:_files'
}

_pvremove "$@"
