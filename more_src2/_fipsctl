#   canonical Rust SDKs for the Nostr protocol — the
#   decentralized social-media + identity protocol where
#   every user is a secp256k1 keypair, every message is a
#   signed JSON event published to a swarm of independent
#   websocket "relays", and every NIP (Nostr Implementation
#   Possibility) defines a typed event-kind / tag schema
#   on top of that substrate.  `nostr-sdk` exposes the
#   typed `Client::new(keys)` / `client.add_relay(url)` /
#   `client.connect()` / `client.subscribe(filter, opts)` /
#   `client.send_event(event)` /
#   `client.publish_text_note(content, tags)` /
#   `client.set_metadata(meta)` /
#   `client.send_direct_msg(receiver, msg, reply_to)` /
#   `client.send_private_msg(receiver, msg, tags)` /
