_fipsctl_fipsctl() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-s --socket)'{-s,--socket}'=[control socket path override]:path:_files' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _fipsctl_commands=(
                'show:show node information'
                'acl:show peer ACL information'
                'keygen:generate a new FIPS identity keypair (secp256k1)'
                'connect:connect to a peer'
                'disconnect:disconnect a peer'
                'stats:query historical node statistics'
            )
            _describe -t commands 'fipsctl command' _fipsctl_commands && ret=0
            ;;
        args)
            case $words[1] in
                show)
                    local -a _show_what=(
                        'status:node status overview'
                        'peers:authenticated peers'
                        'links:active links'
                        'tree:spanning tree state'
                        'sessions:end-to-end sessions'
                        'bloom:bloom filter state'
                        'mmp:MMP metrics summary'
                        'cache:coordinate cache stats'
                        'connections:pending handshake connections'
                        'transports:transport instances'
                        'routing:routing table summary'
                        'identity-cache:identity cache entries (known node pubkeys)'
                    )
                    _describe -t sub 'show what' _show_what && ret=0
                    ;;
                acl)
                    local -a _acl_what=(
                        'show:loaded peer ACL state'
                    )
                    _describe -t sub 'acl what' _acl_what && ret=0
                    ;;
                keygen)
                    _arguments \
                        '(-d --dir)'{-d,--dir}'=[output directory for fips.key and fips.pub]:dir:_files -/' \
                        '(-f --force)'{-f,--force}'[overwrite existing key files]' \
                        '(-s --stdout)'{-s,--stdout}'[print nsec and npub to stdout instead of writing files]' && ret=0
                    ;;
                connect)
                    _arguments \
                        '1:peer (npub bech32 or hostname):' \
                        '2:transport address (e.g. 1.2.3.4:2121):' \
                        '3:transport:(udp tcp tor ethernet)' && ret=0
                    ;;
                disconnect)
                    _arguments \
                        '1:peer (npub bech32 or hostname):' && ret=0
                    ;;
                stats)
                    if (( CURRENT == 2 )); then
                        local -a _stats_what=(
                            'list:list available history metrics'
                            'peers:list peers tracked in the stats history'
                            'history:fetch a time-series window for a metric'
                        )
                        _describe -t sub 'stats what' _stats_what && ret=0
                    elif [[ $words[2] == history ]]; then
                        _arguments \
                            '1:metric name:' \
                            '--peer=[peer npub bech32 or hostname]:peer:' \
                            '--window=[window duration Ns/Nm/Nh]:duration:' \
                            '--granularity=[sample resolution]:granularity:(1s 1m)' \
                            '--plot[render a Unicode block sparkline instead of JSON]' && ret=0
                    fi
                    ;;
            esac
            ;;
    esac

    return ret
}

_fipsctl_fipstop() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-s --socket)'{-s,--socket}'=[control socket path override]:path:_files' \
        '--gateway-socket=[gateway control socket path override]:path:_files' \
        '(-r --refresh)'{-r,--refresh}'=[refresh interval in seconds (default 2)]:seconds:'
}

_fipsctl_fips_gateway() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '(-c --config)'{-c,--config}'=[path to configuration file]:file:_files -g "*.yaml *.yml *.toml"' \
        '(-l --log-level)'{-l,--log-level}'=[log level (default info)]:level:(trace debug info warn error)'
}

case "${service:-${words[1]}}" in
    fipstop)        _fipsctl_fipstop "$@" ;;
    fips-gateway)   _fipsctl_fips_gateway "$@" ;;
    fipsctl|*)      _fipsctl_fipsctl "$@" ;;
esac
