#compdef neo4j
# Documentation: https://neo4j.com/docs/operations-manual/current/neo4j-admin-neo4j-cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# neo4j - command-line tool to manage the Neo4j graph database.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S -C \
  '--verbose[enable verbose output]' \
  '--expand-commands[allow command expansion in config]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case "$state" in
  command)
    local -a commands
    commands=(
      'console:Start server in foreground'
      'start:Start server as a daemon'
      'stop:Stop the daemon'
      'restart:Restart the daemon'
      'status:Show current status'
      'version:Show version'
      'help:Show help'
    )
    _describe -t commands 'neo4j commands' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      console|start|stop|restart|status|version|help)
        _arguments -s -S \
          '--verbose[enable verbose output]' \
          '--expand-commands[allow command expansion in config]' && ret=0
        ;;
    esac
    ;;
esac

return ret
