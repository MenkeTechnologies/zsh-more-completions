#compdef mockgen
# _go-mock — gomock mockgen mock generator (Google + Uber); part of go.uber.org/mock, generates mocks for Go interfaces
# upstream: https://github.com/uber-go/mock

_go-mock() {
    _arguments \
        '-source+[source file with interfaces]:file:_files' \
        '-destination+[destination file]:file:_files' \
        '-package+[mock package name]:name:' \
        '-build_flags+[go build flags]:flags:' \
        '-mock_names+[mock type names]:str:' \
        '-self_package+[fully-qualified package import path]:path:' \
        '-imports+[explicit imports]:imports:' \
        '-aux_files+[additional source files]:str:' \
        '-write_package_comment+[write package comment]:bool:(true false)' \
        '-copyright_file+[copyright file]:file:_files' \
        '-debug_parser[debug parser]' \
        '-typed[typed mock]' \
        '-help[show help]' \
        '-version[show version]' \
        '*:interface name:'
}

_go-mock "$@"
