#compdef ffplay-cli
# _ffplay-cli — FFmpeg ffplay minimalist media player CLI alias (FFmpeg team, C); custom argparse
# upstream: https://github.com/FFmpeg/FFmpeg

_ffplay-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-formats[list formats]' \
        '-codecs[list codecs]' \
        '-loglevel=+[level]:l:(quiet panic fatal error warning info verbose debug trace)' \
        '-v+[level]:l:(quiet panic fatal error warning info verbose debug trace)' \
        '-report[generate report]' \
        '-hide_banner[hide banner]' \
        '-x+[width]:n:' \
        '-y+[height]:n:' \
        '-fs[fullscreen]' \
        '-an[disable audio]' \
        '-vn[disable video]' \
        '-sn[disable subtitles]' \
        '-ast+[stream]:str:' \
        '-vst+[stream]:str:' \
        '-sst+[stream]:str:' \
        '-ss+[time]:str:' \
        '-t+[duration]:str:' \
        '-bytes=+[mode]:m:(0 1 -1)' \
        '-seek_interval=+[seconds]:n:' \
        '-nodisp[no display]' \
        '-noborder[no border]' \
        '-alwaysontop[always on top]' \
        '-volume=+[0-100]:n:' \
        '-f+[input format]:str:' \
        '-window_title=+[title]:str:' \
        '-left=+[x]:n:' \
        '-top=+[y]:n:' \
        '-loop=+[count]:n:' \
        '-showmode=+[mode]:m:(0 1 2 video waves rdft)' \
        '-vf+[video filter]:str:' \
        '-af+[audio filter]:str:' \
        '-stats[print stats]' \
        '-nostats[no stats]' \
        '-fast[fast decoding]' \
        '-genpts[generate pts]' \
        '-drp=+[mode]:n:' \
        '-lowres=+[level]:n:' \
        '-sync=+[type]:t:(audio video ext)' \
        '-autoexit[exit when done]' \
        '-exitonkeydown[exit on keydown]' \
        '-exitonmousedown[exit on mousedown]' \
        '-codec=+[codec]:str:' \
        '-acodec=+[codec]:str:' \
        '-vcodec=+[codec]:str:' \
        '-scodec=+[codec]:str:' \
        '-autorotate=+[bool]:b:(0 1)' \
        '-framedrop[drop late frames]' \
        '-infbuf[infinite buffer]' \
        '-filter_threads=+[n]:n:' \
        '-i+[input file]:file:_files' \
        '*:input:_files'
}

_ffplay-cli "$@"
