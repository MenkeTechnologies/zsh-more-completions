#compdef piuparts
# Documentation: https://manpages.debian.org/piuparts
# Source: h01ger/piuparts piuparts.py — install/upgrade/remove package testing in clean chroot (Python, optparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '(-a --apt)'{-a,--apt}'[apt-get install instead of dpkg]' \
    '--arch=-[architecture]:arch:_default' \
    '(-b --basetgz)'{-b+,--basetgz=}'[chroot tarball]:file:_files -g "*.{tgz,tar.gz}"' \
    '*--bindmount=-[bind mount path]:path:_files -/' \
    '-B+[save chroot after each operation]:file:_files' \
    '(-d --distribution)'{-d+,--distribution=}'[distribution]:dist:_default' \
    '*-D+[depends file]:file:_files' \
    '--debfoster-options=-[debfoster options]:opts:_default' \
    '--no-eatmydata[do not use eatmydata]' \
    '--dpkg-noforce-unsafe-io[do not pass --force-unsafe-io to dpkg]' \
    '--dpkg-force-confdef[pass --force-confdef to dpkg]' \
    '--do-not-verify-signatures[skip apt signature verification]' \
    '--no-check-valid-until[disable Valid-Until check]' \
    '--allow-database[allow chroot to access database services]' \
    '--distupgrade-to-testdebs[dist-upgrade to repo with --testdebs-repo]' \
    '--distupgrade-to-testdebs-from=-[dist-upgrade source]:repo:_default' \
    '(-e --existing-chroot)'{-e+,--existing-chroot=}'[reuse existing chroot]:dir:_files -/' \
    '--hard-link[hard-link instead of copy]' \
    '(-i --ignore)'{-i+,--ignore=}'[ignore file pattern]:pattern:_default' \
    '*-I+[ignore regex]:regex:_default' \
    '--install-recommends[install recommends]' \
    '--install-suggests[install suggests]' \
    '(-k --keep-tmpdir)'{-k,--keep-tmpdir}'[keep tmp directory]' \
    '--keep-sources-list[do not overwrite sources.list]' \
    '(-K --keyring)'{-K+,--keyring=}'[apt keyring]:file:_files' \
    '(-l --log-file)'{-l+,--log-file=}'[log file]:file:_files' \
    '--list-installed-files[list installed files for each package]' \
    '--log-level=-[log level]:level:(debug info dump error exception)' \
    '--lvm-volume=-[LVM volume]:volume:_default' \
    '--lvm-snapshot-size=-[LVM snapshot size]:size:_default' \
    '--schroot=-[schroot name]:name:_default' \
    '--docker-image=-[Docker image]:image:_default' \
    '--merged-usr[create merged-/usr chroot]' \
    '(-m --mirror)'{-m+,--mirror=}'[mirror URL]:url:_urls' \
    '*--extra-repo=-[additional apt source line]:line:_default' \
    '*--extra-old-packages=-[install before upgrade]:pkg:_default' \
    '*--fake-essential-packages=-[treat package as essential]:pkg:_default' \
    '--fail-if-inadequate[fail if adequate finds errors]' \
    '--fail-on-broken-symlinks[fail on broken symlinks]' \
    '--install-purge-install[run install/purge/install cycle]' \
    '--install-remove-install[run install/remove/install cycle]' \
    '--max-command-output-size=-[max output size]:size:_default' \
    '--minimize[minimise chroot]' \
    '--skip-minimize[skip chroot minimisation]' \
    '--no-adequate[skip adequate check]' \
    '--no-diversions[disable diversion checks]' \
    '--no-install-purge-test[skip install/purge test]' \
    '--no-upgrade-test[skip upgrade test]' \
    '(-n --no-upgrade-test)'{-n,--no-upgrade-test}'[skip upgrade test]' \
    '*--pedantic-purge-test[pedantic purge test]' \
    '--proxy=-[HTTP proxy]:url:_urls' \
    '--scriptsdir=-[scripts directory]:dir:_files -/' \
    '(-s --shell)'{-s,--shell}'[open shell on chroot failure]' \
    '--shell-on-error[open shell on test failure]' \
    '--single-changes-list[treat as one changes file]' \
    '--single-packages[test each package individually]' \
    '--skip-cronfiles-test[skip cron file test]' \
    '--skip-logrotatefiles-test[skip logrotate file test]' \
    '*--testdebs-repo=-[test debs repository]:repo:_default' \
    '(-t --tmpdir)'{-t+,--tmpdir=}'[temporary directory]:dir:_files -/' \
    '--update-retries=-[apt-get update retries]:n:_default' \
    '--upgrade-before-dist-upgrade[upgrade before dist-upgrade]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '--warn-on-debsums-errors[warn on debsums errors]' \
    '--warn-on-install-over-symlink[warn when installing over symlink]' \
    '--warn-on-leftovers-after-purge[warn on leftover files after purge]' \
    '--warn-on-others[warn on other issues]' \
    '--warn-on-usr-move[warn on /usr-move issues]' \
    '*-N+[no/normal action]:opt:_default' \
    '*-p+[package]:pkg:_default' \
    '*-S+[skip step]:step:_default' \
    '*:package:_files -g "*.{deb,changes}"' \
    && ret=0

return ret
