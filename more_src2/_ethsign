#compdef ethsign
# _ethsign — Mikhail Vladimirov ethsign minimal Ethereum keystore CLI for signing transactions and messages with secp256k1 keys backed by encrypted JSON keystore files (dapptools team, C); getopt
# upstream: https://github.com/dapphub/dapptools

_ethsign() {
    local -a sub=(
        'ls:list addresses'
        'import:import keypair'
        'list-hd:list HD'
        'msg:sign message'
        'tx:sign transaction'
        'unlock:unlock keystore'
        'address:show address'
        'export:export key'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--key-store=+[dir]:dir:_files -/' \
        '-k+[dir]:dir:_files -/' \
        '--passphrase-file=+[file]:file:_files' \
        '-p+[file]:file:_files' \
        '--from=+[addr]:str:' \
        '-f+[addr]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ethsign subcommand' sub ;;
        args)
            case $words[1] in
                msg) _arguments \
                    '--from=+[addr]:str:' \
                    '--data=+[hex]:str:' \
                    '--no-prefix[no Ethereum signed message prefix]' \
                    '*:message:' ;;
                tx) _arguments \
                    '--from=+[addr]:str:' \
                    '--to=+[addr]:str:' \
                    '--value=+[wei]:str:' \
                    '--gas-price=+[wei]:str:' \
                    '--gas-limit=+[N]:n:' \
                    '--max-fee=+[wei]:str:' \
                    '--priority-fee=+[wei]:str:' \
                    '--nonce=+[N]:n:' \
                    '--chain-id=+[N]:n:' \
                    '--data=+[hex]:str:' \
                    '--type=+[t]:t:(0 1 2 legacy access-list dynamic-fee)' ;;
                import|export|address) _arguments '*:key:' ;;
            esac
            ;;
    esac
}

_ethsign "$@"
