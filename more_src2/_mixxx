#compdef mixxx
# Documentation: https://github.com/mixxxdj/mixxx/blob/main/src/util/cmdlineargs.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-f --full-screen --fullScreen)'{-f,--full-screen}'[start in fullscreen mode]' \
  '--locale=[custom locale for translations]:locale' \
  '--start-autodj[launch Auto DJ on startup]' \
  '--rescan-library[rescan library on startup]' \
  '--settings-path=[settings directory]:dir:_files -/' \
  '--resource-path=[resource directory]:dir:_files -/' \
  '--timeline-path=[debug statistics timeline output]:path:_files' \
  '--enable-legacy-vumeter[use legacy VU meter]' \
  '--enable-legacy-spinny[use legacy spinny]' \
  '--controller-debug[display/log controller data]' \
  '--controller-abort-on-warning[strict controller mapping validation]' \
  '--developer[enable developer mode]' \
  '--new-ui[load experimental QML interface]' \
  '--allow-dangerous-data-corruption-risk[allow unstable UI with existing profile]' \
  '--safe-mode[disable OpenGL and spinning vinyl]' \
  '--color=[console output coloring]:mode:(auto always never)' \
  '--log-level=[logging verbosity]:lvl:(critical warning info debug trace)' \
  '--log-flush-level=[log buffer flush threshold]:lvl:(critical warning info debug trace)' \
  '--log-max-file-size=[maximum log file size in bytes]:bytes' \
  '--debug-assert-break[break on failed DEBUG_ASSERT]' \
  '--style=[override GUI style]:style' \
  '--controller-preview-screens[preview controller screens]' \
  '*:audio file:_files -g "*.{mp3,wav,flac,ogg,aiff,opus,m4a,mp4}"' && ret=0

return ret
