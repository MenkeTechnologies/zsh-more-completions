#compdef egress livekit-egress
# Documentation: https://github.com/livekit/egress
# Reference accessed: 2026-05-27
# Verified: upstream cmd/server/main.go (livekit/egress) urfave/cli/v3 flags

local curcontext="$curcontext" state line ret=1

local -a _egress_subcommands
_egress_subcommands=(
  'run-handler:runs a request in a new process (internal)'
  'help:show help'
)

_arguments -C \
  '--config=[LiveKit Egress yaml config file]:file:_files -g "*.(yaml|yml)"' \
  '--config-body=[LiveKit Egress yaml config body]:body:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'egress subcommand' _egress_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      run-handler)
        _arguments \
          '--request=[request payload]:json:' \
          '--config=[yaml config file]:file:_files -g "*.(yaml|yml)"' && ret=0
        ;;
      *)
        _arguments '*::arg:' && ret=0
        ;;
    esac
    ;;
esac

return ret
