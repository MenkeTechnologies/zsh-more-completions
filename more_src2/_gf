#compdef gf
# Documentation: https://github.com/tomnomnom/gf
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# tomnomnom/gf - grep wrapper for named patterns.
# Verified flags in main.go: -save, -list, -dump (Go flag package).
# All remaining args are passed straight through to grep.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-list[list available patterns]' \
  '-save=[save a pattern]:name:' \
  '-dump[dump the pattern used to stdout]' \
  ':pattern:->pattern' \
  '*:file:_files' && ret=0

case $state in
  pattern)
    # List saved gf patterns if available
    local -a patterns
    if [[ -d ~/.gf ]]; then
      patterns=(${${(f)"$(ls ~/.gf/*.json 2>/dev/null)"}:t:r})
    fi
    if (( #patterns )); then
      _describe -t patterns 'pattern' patterns && ret=0
    fi
    ;;
esac

return ret
