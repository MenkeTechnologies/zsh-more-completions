#compdef fpcmkcfg
# Documentation: fpcmkcfg -h (Free Pascal config generator)
# Source: generate fpc.cfg / fp.cfg / fp.ini / fppkg.cfg from built-in templates.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-h[show help]' \
    '(- *)-V[show version]' \
    '(- *)-m[show builtin macros and exit]' \
    '(- *)-b[show builtin template and exit]' \
    '-t+[template file]:file:_files' \
    '-o+[output file]:file:_files' \
    '*-d+[define name=value]:name=value:' \
    '*-u+[remove name from name/value pairs]:name:' \
    '-s[skip backup file creation]' \
    '-p[force directory creation]' \
    '-v[verbose]' \
    '(-0 -1 -2 -3 -4)-0[use builtin fpc.cfg template (default)]' \
    '(-0 -1 -2 -3 -4)-1[use builtin fp.cfg template]' \
    '(-0 -1 -2 -3 -4)-2[use builtin fp.ini template]' \
    '(-0 -1 -2 -3 -4)-3[use builtin fppkg.cfg template]' \
    '(-0 -1 -2 -3 -4)-4[use builtin fppkg default compiler template]' \
    && ret=0

return ret
