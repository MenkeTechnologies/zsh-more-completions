#compdef pamdepth pnmdepth
# Documentation: man pamdepth (Netpbm)
# Source: change the maxval (bit depth) of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:new maxval:' \
    '2:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
