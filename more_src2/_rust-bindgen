#compdef rust-bindgen bindgen
# Documentation: https://rust-lang.github.io/rust-bindgen/command-line-usage.html
# Reference accessed: 2026-05-21
# Verified: rust-lang/rust-bindgen bindgen/options/cli.rs source.

# rust-bindgen: C/C++ to Rust FFI bindings generator
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-o --output)'{-o+,--output=}'[output bindings file]:file:_files' \
  '--depfile=[depfile output path]:file:_files' \
  '--default-enum-style=[default enum style]:style:(consts moduleconsts bitfield newtype newtype_global rust rust_non_exhaustive)' \
  '*--bitfield-enum=[mark enum as bitfield]:regex:' \
  '*--newtype-enum=[mark enum as newtype]:regex:' \
  '*--newtype-global-enum=[mark enum as global newtype]:regex:' \
  '*--rustified-enum=[mark enum as rust enum]:regex:' \
  '*--rustified-non-exhaustive-enum=[mark enum as non-exhaustive rust enum]:regex:' \
  '*--constified-enum=[mark enum as constified]:regex:' \
  '*--constified-enum-module=[mark enum as constified module]:regex:' \
  '--default-macro-constant-type=[default macro constant type]:type:(signed unsigned)' \
  '--default-alias-style=[default type alias style]:style:(type_alias new_type new_type_deref)' \
  '*--normal-alias=[mark type alias as normal]:regex:' \
  '*--new-type-alias=[mark alias as newtype]:regex:' \
  '*--new-type-alias-deref=[mark alias as newtype with deref]:regex:' \
  '--default-non-copy-union-style=[default non-copy union style]:style:(bindgen_wrapper manually_drop)' \
  '*--bindgen-wrapper-union=[mark union as bindgen wrapper]:regex:' \
  '*--manually-drop-union=[mark union as manually drop]:regex:' \
  '*--blocklist-type=[block type regex]:regex:' \
  '*--blocklist-function=[block function regex]:regex:' \
  '*--blocklist-item=[block item regex]:regex:' \
  '*--blocklist-file=[block file regex]:regex:' \
  '*--blocklist-var=[block variable regex]:regex:' \
  '*--allowlist-function=[allow function regex]:regex:' \
  '*--allowlist-type=[allow type regex]:regex:' \
  '*--allowlist-var=[allow variable regex]:regex:' \
  '*--allowlist-file=[allow file regex]:regex:' \
  '*--allowlist-item=[allow item regex]:regex:' \
  '--no-layout-tests[disable layout tests]' \
  '--no-derive-copy[do not derive Copy]' \
  '--no-derive-debug[do not derive Debug]' \
  '--no-derive-default[do not derive Default]' \
  '--impl-debug[create Debug impls instead of derive]' \
  '--impl-partialeq[create PartialEq impls instead of derive]' \
  '--with-derive-default[derive Default]' \
  '--with-derive-hash[derive Hash]' \
  '--with-derive-partialeq[derive PartialEq]' \
  '--with-derive-partialord[derive PartialOrd]' \
  '--with-derive-eq[derive Eq]' \
  '--with-derive-ord[derive Ord]' \
  '--no-doc-comments[do not generate doc comments]' \
  '--no-recursive-allowlist[do not recursively allowlist]' \
  '--objc-extern-crate[use extern crate objc]' \
  '--nonnull-references[treat references as nonnull]' \
  '--generate-block[generate Apple block types]' \
  '--generate-cstr[generate CStr types]' \
  '--block-extern-crate[use extern crate block]' \
  '--distrust-clang-mangling[disable clang mangling]' \
  '--builtins[emit builtins]' \
  '--ctypes-prefix=[c_types prefix]:prefix:' \
  '--anon-fields-prefix=[anonymous fields prefix]:prefix:' \
  '--time-phases[print time for each phase]' \
  '--emit-clang-ast[emit clang AST]' \
  '--emit-ir[emit internal IR]' \
  '--emit-ir-graphviz=[emit IR as graphviz]:file:_files' \
  '--enable-cxx-namespaces[enable C++ namespaces]' \
  '--disable-name-namespacing[disable name namespacing]' \
  '--disable-nested-struct-naming[disable nested struct naming]' \
  '--disable-untagged-union[disable untagged unions]' \
  '--disable-header-comment[disable bindgen header comment]' \
  '--ignore-functions[do not generate function bindings]' \
  '--generate=[whitelist what to generate]:items:' \
  '--ignore-methods[do not generate method bindings]' \
  '--no-convert-floats[do not convert floats]' \
  '--no-prepend-enum-name[do not prepend enum name]' \
  '--no-include-path-detection[do not detect include paths]' \
  '--fit-macro-constant-types[fit macro constant types]' \
  '*--opaque-type=[opaque type regex]:regex:' \
  '*--raw-line=[raw line to emit]:line:' \
  '*--module-raw-line=[module raw line]:mod:' \
  '--rust-target=[target Rust version]:version:' \
  '--rust-edition=[target Rust edition]:edition:(2015 2018 2021 2024)' \
  '--use-core[use core instead of std]' \
  '--conservative-inline-namespaces[conservative inline namespaces]' \
  '--generate-inline-functions[generate inline functions]' \
  '--verbose[verbose output]' \
  '--dump-preprocessed-input[dump preprocessed input]' \
  '--no-record-matches[do not record matches]' \
  '--no-size_t-is-usize[do not treat size_t as usize]' \
  '--no-rustfmt-bindings[do not run rustfmt on bindings]' \
  '--formatter=[code formatter]:formatter:(none rustfmt prettyplease)' \
  '--rustfmt-configuration-file=[rustfmt config]:file:_files' \
  '*--no-partialeq=[type regex to skip PartialEq]:regex:' \
  '*--no-copy=[type regex to skip Copy]:regex:' \
  '*--no-debug=[type regex to skip Debug]:regex:' \
  '*--no-default=[type regex to skip Default]:regex:' \
  '*--no-hash=[type regex to skip Hash]:regex:' \
  '*--must-use-type=[mark as must_use]:regex:' \
  '--enable-function-attribute-detection[detect function attributes]' \
  '--use-array-pointers-in-arguments[use array pointers in args]' \
  '--wasm-import-module-name=[wasm import module name]:name:' \
  '*--extern-fn-block-attrs=[attrs for extern fn blocks]:attr:' \
  '--dynamic-loading=[dynamic loading library name]:name:' \
  '--dynamic-link-require-all[require all dynamic symbols]' \
  '--prefix-link-name=[prefix link names]:prefix:' \
  '--respect-cxx-access-specs[respect C++ access specifiers]' \
  '--translate-enum-integer-types[translate enum integer types]' \
  '--c-naming[use C naming style]' \
  '--explicit-padding[generate explicit padding fields]' \
  '--vtable-generation[generate vtables]' \
  '--sort-semantically[sort output semantically]' \
  '--merge-extern-blocks[merge extern blocks]' \
  '*--override-abi=[override ABI for symbol]:regex=abi:' \
  '--wrap-unsafe-ops[wrap unsafe ops in unsafe blocks]' \
  '--clang-macro-fallback[use clang to evaluate macros]' \
  '--clang-macro-fallback-build-dir=[build dir for macro fallback]:dir:_files -/' \
  '--flexarray-dst[use DST for flexible array members]' \
  '--wrap-static-fns[generate wrappers for static functions]' \
  '--wrap-static-fns-path=[output path for static fn wrappers]:file:_files' \
  '--wrap-static-fns-suffix=[suffix for static fn wrappers]:suffix:' \
  '--default-visibility=[default field visibility]:vis:(public public_crate private)' \
  '--generate-deleted-functions[generate deleted C++ functions]' \
  '--generate-pure-virtual-functions[generate pure virtual functions]' \
  '--generate-private-functions[generate private functions]' \
  '*--field-attr=[per-field attributes]:spec:' \
  '--emit-diagnostics[emit diagnostics]' \
  '--generate-shell-completions=[generate shell completions]:shell:(bash zsh fish powershell elvish)' \
  '--experimental[enable experimental features]' \
  '--version[show bindgen version]' \
  '*:C/C++ header:_files -g "*.(h|hpp|hxx)(-.)"' && ret=0
return ret
