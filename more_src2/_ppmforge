#compdef ppmforge
# Documentation: man ppmforge (Netpbm)
# Source: synthesise a planet, clouds, or starscape PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-clouds[synthesise a cloud texture only]' \
    '-night[render planet at night]' \
    '-dimension+[fractal dimension]:dimen:' \
    '-hour+[hour 0..24]:hour:' \
    '(-inclination -tilt)-inclination+[axis inclination angle]:angle:' \
    '(-inclination -tilt)-tilt+[axis tilt angle]:angle:' \
    '-mesh+[fractal mesh size]:size:' \
    '-power+[fractal power factor]:factor:' \
    '-glaciers+[glaciers level]:level:' \
    '-ice+[ice level]:level:' \
    '-saturation+[color saturation]:sat:' \
    '-seed+[random seed]:seed:' \
    '-stars+[stars fraction 0..1]:fraction:' \
    '(-xsize -width)-xsize+[image width]:width:' \
    '(-xsize -width)-width+[image width]:width:' \
    '(-ysize -height)-ysize+[image height]:height:' \
    '(-ysize -height)-height+[image height]:height:' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
