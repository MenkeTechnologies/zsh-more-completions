#compdef puredns-cli puredns
# _puredns-cli — d3mondev puredns-cli CLI command-line frontend wrapping the PureDNS fast domain resolver and subdomain bruteforcing wildcard subdomain detection and filtering massdns-wrapper open-source written in Go solves-massdns-issues-around-batch-write-flag-thread-safety performs-DNS-wildcard-detection-and-filtering-trusted-resolvers-validation-stops-massdns-only-when-needed brute resolve bruteforce-mode trusted-resolvers-list rate-limit-per-resolver resume-from-file write-massdns write-wildcards write-wildcard-answers write-resolved write-trusted (d3mondev team, Go); cobra
# upstream: https://github.com/d3mondev/puredns

_puredns-cli() {
    local -a sub=(
        'resolve:resolve a list of domains'
        'bruteforce:DNS bruteforce'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-r+[resolvers file]:file:_files' \
        '--resolvers=+[file]:file:_files' \
        '--resolvers-trusted=+[file]:file:_files' \
        '--bin=+[massdns binary]:_files' \
        '-l+[rate limit]:n:' \
        '--rate-limit=+[N]:n:' \
        '-t+[trusted rate limit]:n:' \
        '--rate-limit-trusted=+[N]:n:' \
        '--wildcard-tests=+[N]:n:' \
        '--wildcard-batch=+[N]:n:' \
        '--skip-validation[skip validation]' \
        '--skip-wildcard-filter[skip wildcard filter]' \
        '--skip-sanitize[skip sanitize]' \
        '-w+[output file]:file:_files' \
        '--write=+[file]:file:_files' \
        '--write-massdns=+[file]:file:_files' \
        '--write-wildcards=+[file]:file:_files' \
        '--write-wildcard-answers=+[file]:file:_files' \
        '--write-trusted=+[file]:file:_files' \
        '--resume-from=+[file]:file:_files' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-n[no color]' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'puredns subcommand' sub ;;
        args)
            case $words[1] in
                resolve) _arguments '*:file:_files' ;;
                bruteforce) _arguments '1:wordlist:_files' '2:domain:' ;;
            esac
            ;;
    esac
}

_puredns-cli "$@"
