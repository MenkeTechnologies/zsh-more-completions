#compdef gron
# Documentation: https://github.com/tomnomnom/gron
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# gron - Make JSON greppable. Flags verified from tomnomnom/gron main.go
_arguments -s -S \
  '(-u --ungron)'{-u,--ungron}'[ungron: turn stream of assignments back into JSON]' \
  '(-v --values)'{-v,--values}'[print only values, not paths]' \
  '(-c --colorize)'{-c,--colorize}'[colorize output (default on tty)]' \
  '(-m --monochrome)'{-m,--monochrome}'[disable colorization]' \
  '(-s --stream)'{-s,--stream}'[treat each input line as separate JSON]' \
  '(-k --insecure)'{-k,--insecure}'[disable certificate validation for HTTPS]' \
  '(-j --json)'{-j,--json}'[represent gron data as JSON stream]' \
  '--no-sort[do not sort output (faster)]' \
  '--version[print version information]' \
  '(-x --proxy)'{-x+,--proxy=}'[proxy URL]:proxy:' \
  '--noproxy=[comma-separated hosts to exclude from proxy]:hosts:' \
  '*:JSON file or URL:_files -g "*.json"'
