#compdef ditaa
# Documentation: https://github.com/stathissideris/ditaa
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ditaa flags per upstream README. Note: -h is the SHORT form of --html (not --help);
# --help has no short form. --svg has no short form. -S is --no-shadows.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-o --overwrite)'{-o,--overwrite}'[overwrite existing output file]' \
  '(-s --scale)'{-s,--scale}'=[scale factor]:scale' \
  '(-e --encoding)'{-e,--encoding}'=[input file encoding]:encoding' \
  '(-A --no-antialias)'{-A,--no-antialias}'[disable antialiasing]' \
  '(-S --no-shadows)'{-S,--no-shadows}'[disable shadows]' \
  '(-E --no-separation)'{-E,--no-separation}'[disable shape separation]' \
  '(-r --round-corners)'{-r,--round-corners}'[use round corners]' \
  '(-t --tabs)'{-t,--tabs}'=[tab size]:size' \
  '(-b --background)'{-b,--background}'=[background color]:color' \
  '(-T --transparent)'{-T,--transparent}'[transparent background]' \
  '(-h --html)'{-h,--html}'[process HTML file with <pre class=textdiagram> tags]' \
  '--svg[output SVG instead of PNG]' \
  '--svg-font-url=[SVG font URL]:url' \
  '(-W --fixed-slope)'{-W,--fixed-slope}'[fixed slope for parallelograms/trapezoids]' \
  '(-d --debug)'{-d,--debug}'[enable debug grid overlay]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--help[show help]' \
  '--version[show version]' \
  '1:input file:_files -g "*.{txt,ditaa,atxt}"' \
  '2:output file:_files -g "*.{png,svg}"' && ret=0

return ret
