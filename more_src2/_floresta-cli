# WHAT IT IS
#   Floresta is "a lightweight and embeddable Bitcoin client,
#   built for sovereignty" â€” a full Bitcoin node implemented
#   in Rust using the Utreexo accumulator for compact state
#   (instead of a multi-gigabyte UTXO set, Floresta keeps an
#   accumulator hash and exchanges inclusion proofs with
#   peers).  The workspace ships two binaries:
#
#     florestad      The long-lived daemon â€” runs the
#                    Bitcoin node, electrum server, JSON-RPC
#                    server, and accumulator pipeline.
#                    (Already covered by `_florestad`.)
#
#     floresta-cli   This binary â€” a command-line JSON-RPC
#                    client that speaks to a running
#                    `florestad` over its bundled JSON-RPC
#                    endpoint.  Same flavor as `bitcoin-cli`
#                    for Bitcoin Core, but speaking
#                    Floresta's extended RPC surface
#                    (Utreexo-roots, watch-only descriptor
#                    loading, rescan-with-confidence, etc.).
#
# CLI ARGUMENT GRAMMAR  (verbatim from bin/floresta-cli/src/
#                       main.rs clap-derive `Cli` struct +
#                       `Methods` enum + per-variant
#                       `#[command(name = "...")]`
#                       declarations; extracted via `gh api
#                       repos/getfloresta/Floresta/contents/
#                       bin/floresta-cli/src/main.rs`)
#
#   floresta-cli [GLOBAL OPTIONS] <SUBCOMMAND> [args...]
#
#   Global options:
#     -c, --config-file <FILE>       Custom config file path
#     -n, --network <NETWORK>        Bitcoin network to use
#                                    [default: bitcoin]
#                                    (bitcoin | signet |
#                                     testnet | testnet4 |
#                                     regtest)
#     -d, --debug                    Turn debugging on
#                                    (repeatable: `-d` /
#                                    `-dd` / `-ddd`)
#     -H, --rpc-host <URL>           RPC host URL  (defaults
#                                    to the per-network port:
#                                    8332 mainnet / 38332
#                                    signet / 18332 testnet /
#                                    48332 testnet4 / 18442
#                                    regtest)
#     -u, --rpc-user <USERNAME>      RPC username
#     -P, --rpc-password <PASSWORD>  RPC password
#
#   Subcommands  (each routed to a JSON-RPC method on the
#                 connected `florestad` instance):
#     getblockchaininfo              Get blockchain info
#     getblockhash <HEIGHT>          Get the block hash at a
#                                    given height
#     getbestblockhash               Get the best (tip) block
#                                    hash
#     getblockcount                  Get the current block
#                                    count
#     getdifficulty                  Get the current chain
#                                    difficulty
#     gettxoutproof                  Get a Merkle inclusion
#                                    proof for one or more
#                                    TxOuts
#     gettransaction <TXID> [VERBOSE]
#                                    Get transaction details
#                                    by txid
#     rescanblockchain               Rescan the chain from
#                                    a given height /
#                                    block-confidence
#     sendrawtransaction <HEX-TX>    Broadcast a hex-encoded
#                                    raw transaction
#     getblockheader                 Get a block header
#     getdeploymentinfo [BLOCKHASH]  Get BIP-9 / soft-fork
#                                    deployment status
#     loaddescriptor <DESC>          Load a watch-only output
#                                    descriptor for indexing
#     getroots                       Get the current Utreexo
#                                    accumulator roots
#     getblock                       Get a block by hash
#     getpeerinfo                    List connected peers
#     getconnectioncount             Get the current number
#                                    of P2P connections
#     gettxout <TXID> <VOUT>         Look up an unspent output
#                                    by (txid, vout)
#     stop                           Gracefully shutdown
#                                    `florestad`
#     addnode                        Add a peer to the
#                                    address-manager
#                                    (manual peer)
#     disconnectnode                 Disconnect a peer
#     findtxout                      Search for a TxOut
#     getmemoryinfo [MODE]           Memory diagnostics
#     getrpcinfo                     RPC-server introspection
#     uptime                         Daemon uptime (seconds)
#     listdescriptors                List all loaded watch-
#                                    only descriptors
#     ping                           Ping all peers
#     getnetworkinfo                 Get network-layer info
#     getaddrmaninfo                 Get address-manager info
#                                    (peer-discovery state)
#
#   Standard clap auto-flags:
#     -h, --help                     Show help (root + each
#                                    subcommand)
#     -V, --version                  Show version (0.5.0)
#
# AXIS / CORPUS POSITION
#   Direct dependency on `bitcoin` (workspace-wide; the
#   rust-bitcoin family of crates) declared in bin/floresta-
#   cli/Cargo.toml â€” `bitcoin` (a.k.a. `rust-bitcoin`) is THE
#   canonical Rust Bitcoin protocol library, maintained by
#   the rust-bitcoin org under the umbrella of the Bitcoin
#   Core developer community at the rust-bitcoin/rust-bitcoin
#   repository (2,500+ stars; the predominant typed Rust
#   Bitcoin primitives used by every major Rust Bitcoin
#   application â€” bitcoindevkit/bdk-sp, BP-WG/descriptor-
#   wallet, chainwayxyz/clementine, chainx-org/ChainX,
#   civkit/civkit-node, dfinity/ic, getfloresta/Floresta,
#   happybigmtn/bitchat-rust, Kriishna1/Ark-webapp,
#   LayerTwo-Labs/thunder-rust, nyonson/bitcoin-node-census,
#   plus the full LDK / Lightning Development Kit stack,
#   bdk / Bitcoin Development Kit, rust-miniscript,
#   rust-bitcoin-hashes, rust-secp256k1, and dozens of
#   other production Rust Bitcoin / Lightning applications;
#   used so universally across the Rust Bitcoin ecosystem
#   that it's the de-facto wire-protocol implementation â€”
#   when Bitcoin Core ships a soft fork, rust-bitcoin
#   adopts the typed primitives, and downstream crates
#   pick them up via the same `bitcoin::*` import path).
#   `bitcoin` exposes the typed `Network::{Bitcoin,
#   Testnet, Testnet4, Signet, Regtest}` enum,
#   `Block` / `BlockHeader` / `Transaction` / `TxIn` /
#   `TxOut` / `Sequence` / `Witness` / `Script` /
#   `ScriptBuf` / `ScriptHash` / `WitnessProgram` /
#   `Address` / `AddressType` / `PublicKey` /
#   `PrivateKey` / `WitnessVersion` / `WitnessMerkleNode`
#   / `MerkleNode` / `MerkleRoot` / `OutPoint` / `Txid` /
#   `Wtxid` / `BlockHash` / `WPubkeyHash` / `WScriptHash` /
#   `PubkeyHash` / `ScriptHash` schemas, the typed
#   `Amount` (with `Amount::ONE_BTC`, `Amount::ONE_SAT`,
#   arithmetic in sats with explicit overflow checks, plus
#   `Amount::from_btc(1.5)` / `Amount::from_sat(1234567)`
#   / `Amount::to_btc()` / `Amount::to_sat()`), the typed
#   `consensus::{encode, deserialize, serialize, Decodable,
#   Encodable, Error}` wire-protocol codec, the typed
#   `secp256k1::*` cryptography surface
#   (`Secp256k1::new()`, `SecretKey::new(&mut rng)`,
#   `Message::from_digest(...)`, `Signature::sign_ecdsa(msg,
#   sk)`, `XOnlyPublicKey`, `KeyPair`, `Scalar`), the typed
#   `bip32::ExtendedPrivKey` / `ExtendedPubKey` /
#   `DerivationPath` / `ChildNumber` BIP-32 hierarchical
#   deterministic key surface, the typed `bip39::Mnemonic`
#   /  `MnemonicError` /  `Language` / `Seed` BIP-39
#   mnemonic surface, the typed `psbt::Psbt` PSBT (BIP-174)
#   surface with `Psbt::from_unsigned_tx` /
#   `Psbt::deserialize` / `Psbt::serialize` /
#   `psbt.update_inputs` / `psbt.finalize` /
#   `psbt.extract_tx`, the typed `taproot::TapTweakHash`
#   / `TapNodeHash` / `TapLeafHash` / `ControlBlock` /
#   `TaprootBuilder` / `TaprootSpendInfo` /
#   `LeafVersion` taproot (BIP-340/341/342) primitives,
#   and the typed `merkle_tree::MerkleBlock` /
#   `MerkleBlockError` Merkle-block primitives for
#   compact-block / Utreexo workflows.  floresta-cli's
#   `bin/floresta-cli/src/main.rs` constructs `Network`
#   from the `-n/--network` CLI flag, accepts `Txid`,
#   `BlockHash`, raw transaction hex etc. as positional
#   arguments via clap-derive (the typed `bitcoin::*`
#   primitives compose directly into the `Methods` enum
#   variants), and dispatches each subcommand to its
#   corresponding RPC method via the typed
#   `floresta_rpc::FlorestaRPC` trait.  Verified via:
#     gh api repos/getfloresta/Floresta/contents/bin/
#         floresta-cli/Cargo.toml
#       â†’ bitcoin = { workspace = true }
#       â†’ clap = { workspace = true, features = ["help"] }
#       â†’ [package] name = "floresta-cli", version =
#         "0.5.0"
#     gh api repos/getfloresta/Floresta/contents/bin/
#         floresta-cli/src/main.rs
#       â†’ use bitcoin::BlockHash; use bitcoin::Network;
#         use bitcoin::Txid
#       â†’ #[derive(Parser)] struct Cli { config_file,
#                                          network, debug,
#                                          rpc_host,
#                                          rpc_user,
#                                          rpc_password,
#                                          methods }
#       â†’ #[derive(Subcommand)] enum Methods {
#           GetBlockchainInfo, GetBlockHash, GetBestBlockHash,
#           GetBlockCount, GetDifficulty, GetTxOutProof,
#           GetTransaction, RescanBlockchain,
#           SendRawTransaction, GetBlockHeader,
#           GetDeploymentInfo, LoadDescriptor, GetRoots,
#           GetBlock, GetPeerInfo, GetConnectionCount,
#           GetTxOut, Stop, AddNode, DisconnectNode,
#           FindTxOut, GetMemoryInfo, GetRpcInfo, Uptime,
#           ListDescriptors, Ping, GetNetworkInfo,
#           GetAddrManInfo }
#       â†’ port defaults per network (8332 / 38332 / 18332 /
#         48332 / 18442)
#   This entry is the Rust=165 leader bump that OPENS Axis 110
#   (Bitcoin protocol via rust-bitcoin) at 1/0/0.  Pairing
#   Go and TS-Node bumps will follow at R1028 and R1029
#   (Go=165 candidates btcsuite/btcd consumers; TS-Node=165
#   candidates bitcoinjs-lib consumers).
#
#   No completion for `floresta-cli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) â€” confirmed absent.
# ============================================================================

_floresta-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-c --config-file)'{-c,--config-file}'=[custom config file path]:file:_files' \
        '(-n --network)'{-n,--network}'=[Bitcoin network (default bitcoin)]:network:(bitcoin signet testnet testnet4 regtest)' \
        '*'{-d,--debug}'[turn debugging on (repeatable)]' \
        '(-H --rpc-host)'{-H,--rpc-host}'=[RPC host URL]:url:' \
        '(-u --rpc-user)'{-u,--rpc-user}'=[RPC username]:user:' \
        '(-P --rpc-password)'{-P,--rpc-password}'=[RPC password]:password:' \
        '1: :_floresta_cli_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                getblockhash)
                    _arguments '1:block height:' && ret=0 ;;
                gettransaction)
                    _arguments \
                        '1:txid:' \
                        '2::verbose (true|false):(true false)' && ret=0 ;;
                sendrawtransaction)
                    _arguments '1:hex-encoded raw transaction:' && ret=0 ;;
                loaddescriptor)
                    _arguments '1:output descriptor:' && ret=0 ;;
                gettxout)
                    _arguments \
                        '1:txid:' \
                        '2:vout (output index):' && ret=0 ;;
                getdeploymentinfo)
                    _arguments '::blockhash:' && ret=0 ;;
                getmemoryinfo)
                    _arguments '::mode:' && ret=0 ;;
                getblockchaininfo|getbestblockhash|getblockcount|getdifficulty|gettxoutproof|rescanblockchain|getblockheader|getroots|getblock|getpeerinfo|getconnectioncount|stop|addnode|disconnectnode|findtxout|getrpcinfo|uptime|listdescriptors|ping|getnetworkinfo|getaddrmaninfo)
                    _arguments '*: :' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_floresta_cli_commands] )) ||
_floresta_cli_commands() {
    local -a commands
    commands=(
        'getblockchaininfo:get blockchain info'
        'getblockhash:get the block hash at a given height'
        'getbestblockhash:get the best (tip) block hash'
        'getblockcount:get the current block count'
        'getdifficulty:get the current chain difficulty'
        'gettxoutproof:get a Merkle inclusion proof for TxOuts'
        'gettransaction:get transaction details by txid'
        'rescanblockchain:rescan the chain from a given height'
        'sendrawtransaction:broadcast a hex-encoded raw transaction'
        'getblockheader:get a block header'
        'getdeploymentinfo:get BIP-9 / soft-fork deployment status'
        'loaddescriptor:load a watch-only output descriptor'
        'getroots:get the current Utreexo accumulator roots'
        'getblock:get a block by hash'
        'getpeerinfo:list connected peers'
        'getconnectioncount:get the current number of P2P connections'
        'gettxout:look up an unspent output by (txid, vout)'
        'stop:gracefully shutdown florestad'
        'addnode:add a peer to the address-manager'
        'disconnectnode:disconnect a peer'
        'findtxout:search for a TxOut'
        'getmemoryinfo:memory diagnostics'
        'getrpcinfo:RPC-server introspection'
        'uptime:daemon uptime (seconds)'
        'listdescriptors:list all loaded watch-only descriptors'
        'ping:ping all peers'
        'getnetworkinfo:get network-layer info'
        'getaddrmaninfo:get address-manager info'
    )
    _describe -t commands 'floresta-cli command' commands
}

_floresta-cli "$@"
