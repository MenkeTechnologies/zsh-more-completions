#compdef ffprobe-cli
# _ffprobe-cli — FFmpeg ffprobe multimedia stream analyzer CLI alias (FFmpeg team, C); custom argparse
# upstream: https://github.com/FFmpeg/FFmpeg

_ffprobe-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-version[show version]' \
        '-formats[list supported formats]' \
        '-demuxers[list demuxers]' \
        '-muxers[list muxers]' \
        '-devices[list devices]' \
        '-codecs[list codecs]' \
        '-decoders[list decoders]' \
        '-encoders[list encoders]' \
        '-bsfs[list bitstream filters]' \
        '-protocols[list protocols]' \
        '-filters[list filters]' \
        '-pix_fmts[list pixel formats]' \
        '-layouts[list channel layouts]' \
        '-sample_fmts[list sample formats]' \
        '-colors[list color names]' \
        '-loglevel=+[level]:l:(quiet panic fatal error warning info verbose debug trace)' \
        '-v+[level]:l:(quiet panic fatal error warning info verbose debug trace)' \
        '-report[generate report]' \
        '-hide_banner[hide banner]' \
        '-print_format=+[format]:f:(default csv flat ini json xml)' \
        '-of+[format]:f:(default csv flat ini json xml)' \
        '-sections[show available sections]' \
        '-select_streams=+[selector]:str:' \
        '-show_data[show payload data]' \
        '-show_data_hash=+[algorithm]:a:(md5 sha1 sha256 sha512)' \
        '-show_error[show errors]' \
        '-show_format[show format info]' \
        '-show_format_entry=+[entry]:str:' \
        '-show_entries=+[entries]:str:' \
        '-show_packets[show packets]' \
        '-show_frames[show frames]' \
        '-show_streams[show streams]' \
        '-show_programs[show programs]' \
        '-show_chapters[show chapters]' \
        '-count_frames[count frames]' \
        '-count_packets[count packets]' \
        '-show_private_data[show private data]' \
        '-show_program_version[show ffprobe version]' \
        '-show_library_versions[show library versions]' \
        '-show_versions[show all versions]' \
        '-show_pixel_formats[show pixel formats]' \
        '-bitexact[bitexact mode]' \
        '-read_intervals=+[intervals]:str:' \
        '-default[default options]' \
        '-noprivate[no private data]' \
        '-f+[input format]:str:' \
        '-unit[show units]' \
        '-prefix[use SI prefixes]' \
        '-byte_binary_prefix[binary prefix for byte values]' \
        '-sexagesimal[show time in HH:MM:SS]' \
        '-pretty[prettify]' \
        '-i+[input file]:file:_files' \
        '*:input:_files'
}

_ffprobe-cli "$@"
