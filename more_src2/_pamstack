#compdef pamstack
# Documentation: man pamstack (Netpbm)
# Source: combine multiple Netpbm images into a single multi-plane PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-tupletype+[output tuple type]:type:(BLACKANDWHITE GRAYSCALE GRAYSCALE_ALPHA RGB RGB_ALPHA CMYK)' \
    '(-lcmmaxval)-firstmaxval[use first input maxval]' \
    '(-firstmaxval)-lcmmaxval[use LCM of input maxvals]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
