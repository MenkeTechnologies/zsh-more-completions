#compdef nvidia-cdi-hook
# _nvidia-cdi-hook — NVIDIA CDI hook dispatcher (called by an OCI runtime per CDI yaml; modifies the container filesystem)
# upstream: https://github.com/NVIDIA/nvidia-container-toolkit
# Subcommands + top-level flags from cmd/nvidia-cdi-hook/{main,commands/commands}.go on tip (urfave/cli/v3).

_nvidia-cdi-hook() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--version[print version and exit]' \
        '(-d --debug)'{-d,--debug}'[enable debug-level logging]' \
        '--quiet[suppress all output except errors (overrides --debug)]' \
        '1: :->cmd'
    case $state in
        cmd)
            local -a subs=(
                chmod:'chmod paths inside the container'
                create-symlinks:'create symlinks inside the container'
                cudacompat:'configure CUDA forward-compat libraries'
                disable-device-node-modification:'disable runtime device-node creation'
                update-ldcache:'run ldconfig inside the container'
            )
            _describe -t commands 'nvidia-cdi-hook subcommand' subs
            ;;
    esac
}

_nvidia-cdi-hook "$@"
