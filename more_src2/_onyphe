#compdef onyphe
# Documentation: https://github.com/koromodako/aionyphe
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# onyphe (aionyphe): async Python SDK + CLI for Onyphe API
local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '-h[show help]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'export:export data for given OQL query'
      'search:search OQL query with pagination'
      'myip:get your public IP address'
      'user:get user account information'
    )
    _describe -t commands 'onyphe command' commands && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _arguments -s -S \
          '-h[show help]' \
          '--first=[starting page]:page:' \
          '--last=[ending page]:page:' \
          '*:OQL query:' && ret=0
        ;;
      export)
        _arguments -s -S \
          '-h[show help]' \
          '*:OQL query:' && ret=0
        ;;
      myip|user)
        _arguments -s -S '-h[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
