#compdef pyghidra
# _pyghidra — Python entrypoint for Ghidra GUI or headless scripting (NationalSecurityAgency/ghidra)
# upstream: https://github.com/NationalSecurityAgency/ghidra
# Flags from Ghidra/Features/PyGhidra/src/main/py/src/pyghidra/__main__.py (argparse).

_pyghidra() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '(-g --gui)'{-g,--gui}'[start Ghidra GUI instead of headless]' \
        '--install-dir=[Ghidra installation directory]:dir:_files -/' \
        '--skip-analysis[skip analysis after loading binary]' \
        '--project-name=[project name]:name:' \
        '--project-path=[project path]:dir:_files -/' \
        '*-D+[Java system property name=value]:kv:' \
        '*-X+[Java -X argument]:opt:' \
        '1:binary path:_files' \
        '2:headless script (.py):_files -g "*.py"' \
        '*::script args:_files'
}

_pyghidra "$@"
