#compdef olecfinfo olecfexport olecfmount
# _libolecf — libolecf tools (libyal Microsoft Compound Document File parser used by legacy .doc/.xls/.ppt/.thumbcache_*.db files; olecfinfo prints directory + stream metadata, olecfexport extracts each stream to a file, olecfmount FUSE-mounts the file read-only with each stream as a regular file; -h help, -V version, -v verbose, -t target dir, -X exclusive)
# upstream: https://github.com/libyal/libolecf
# Flags from libyal/libolecf olecftools/olecfinfo.c on tip.

_libolecf() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-t+[target dir]:dir:_files -/' \
        '-X[exclusive]' \
        '*:OLE CF file:_files -g "*.(doc|xls|ppt|msg|db)"'
}

_libolecf "$@"
