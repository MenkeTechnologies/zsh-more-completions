#compdef ReorientTensorImage
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/ReorientTensorImage.cxx — reorient a DT tensor image using a transform (C++, positional; note: antsApplyTransforms -e 2 now does this).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:Dimension:(2 3 4)' \
    '2:infile.nii:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:outfile.nii:_files' \
    '4:transform (composite.h5 / warp.nii.gz / affine.mat / affine.txt):_files -g "*.{h5,nii,nii.gz,mat,txt}"' \
    && ret=0

return ret
