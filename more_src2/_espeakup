#compdef espeakup
# Documentation: https://github.com/linux-speakup/espeakup
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# espeakup: bridge between speakup and the espeak-ng synthesizer
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show brief help and exit]' \
  '(- *)'{-v,--version}'[show version and exit]' \
  '(-d --debug)'{-d,--debug}'[run in foreground, do not fork]' \
  '(-V --default-voice)'{-V,--default-voice}'=[default espeak-ng voice]:voice' \
  '(-P --pid-path)'{-P,--pid-path}'=[pid file path in daemon mode]:file:_files' \
  '--alsa-volume[drive the ALSA volume]' && ret=0

return ret
