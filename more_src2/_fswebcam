#compdef fswebcam
# Documentation: https://codeberg.org/fsphil/fswebcam
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode]' \
  '(-l --loop)'{-l,--loop}'=[loop mode with delay]:seconds:' \
  '(-b --background)'{-b,--background}'[run in background]' \
  '--pid=[PID file]:file:_files' \
  '--log=[log file]:file:_files' \
  '--gmt[use GMT for timestamps]' \
  '(-d --device)'{-d,--device}'=[video device]:device:_files -g "/dev/video*"' \
  '(-i --input)'{-i,--input}'=[input number]:input:' \
  '--list-inputs[list available inputs]' \
  '(-t --tuner)'{-t,--tuner}'=[tuner number]:tuner:' \
  '(-f --frequency)'{-f,--frequency}'=[tuner frequency]:frequency:' \
  '(-p --palette)'{-p,--palette}'=[colour palette]:palette:' \
  '(-r --resolution)'{-r,--resolution}'=[capture resolution]:resolution:' \
  '--fps=[frames per second]:fps:' \
  '(-F --frames)'{-F,--frames}'=[number of frames to capture]:frames:' \
  '(-S --skip)'{-S,--skip}'=[number of frames to skip]:frames:' \
  '(-D --delay)'{-D,--delay}'=[delay between captures]:seconds:' \
  '--greyscale[convert to greyscale]' \
  '--invert[invert image colours]' \
  '--flip=[flip image]:direction:(h v)' \
  '--crop=[crop image]:geometry:' \
  '--scale=[scale image]:geometry:' \
  '--rotate=[rotate image]:degrees:(0 90 180 270)' \
  '--deinterlace[deinterlace image]' \
  '--no-banner[disable banner]' \
  '--banner-colour=[banner colour]:colour:' \
  '--line-colour=[line colour]:colour:' \
  '--text-colour=[text colour]:colour:' \
  '--font=[font]:font:_files' \
  '--title=[title text]:title:' \
  '--subtitle=[subtitle text]:subtitle:' \
  '--timestamp=[timestamp format]:format:' \
  '--info=[info text]:text:' \
  '--underlay=[underlay image]:image:_files' \
  '--overlay=[overlay image]:image:_files' \
  '(-c --config)'{-c,--config}'=[config file]:config:_files' \
  '--save=[save image]:file:_files' \
  '--exec=[execute command after capture]:command:' \
  '(-j --jpeg)'{-j,--jpeg}'=[JPEG quality (0-95)]:quality:' \
  '--png=[PNG compression (0-9)]:compression:' \
  '1:output file:_files' && ret=0

return ret
