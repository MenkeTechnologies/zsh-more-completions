#compdef kubectl-warp
# Documentation: https://github.com/ernoaapa/kubectl-warp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--image=[image for the container to run]:image:' \
  '--rsync-args=[space separated arguments for the rsync command]:args:' \
  '(-i --stdin)'{-i,--stdin}'[pass stdin to the container]' \
  '(-t --tty)'{-t,--tty}'[stdin is a TTY]' \
  '*--include=[include only specific paths from current directory for syncing]:path:' \
  '*--exclude=[exclude specific paths from current directory from syncing]:path:' \
  '--service-account-name=[the service account name that you want the pod to use]:name:' \
  '*--node-selector=[key=value pairs used for the nodeSelector]:keyvalue:' \
  '(-n --namespace)'{-n+,--namespace=}'[if present, the namespace scope for this CLI request]:namespace:' \
  '--kubeconfig=[path to the kubeconfig file]:file:_files' \
  '--context=[the name of the kubeconfig context to use]:context:' \
  '--cluster=[the name of the kubeconfig cluster to use]:cluster:' \
  '--user=[the name of the kubeconfig user to use]:user:' \
  '(-s --server)'{-s+,--server=}'[the address and port of the Kubernetes API server]:server:' \
  '--token=[bearer token for authentication to the API server]:token:' \
  '--insecure-skip-tls-verify[skip server certificate validation]' \
  '*::arg:_default'
