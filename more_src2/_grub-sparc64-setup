#compdef grub-sparc64-setup
# Documentation: https://man.archlinux.org/man/grub-sparc64-setup.8.en
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# grub-sparc64-setup: set up bootblock on sparc64
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '(- *)--usage[brief usage summary]' \
  '(- *)-V[show version]' \
  '(- *)--version[show version]' \
  '(-a --allow-floppy)'{-a,--allow-floppy}'[make the drive bootable as a floppy]' \
  '(-b --boot-image)'{-b+,--boot-image=}'[boot image file]:file:_files' \
  '(-c --core-image)'{-c+,--core-image=}'[core image file]:file:_files' \
  '(-d --directory)'{-d+,--directory=}'[GRUB files directory]:dir:_files -/' \
  '(-f --force)'{-f,--force}'[install despite detected problems]' \
  '(-m --device-map)'{-m+,--device-map=}'[device map file]:file:_files' \
  '--no-rs-codes[disable reed-solomon codes when embedding core.img]' \
  '(-s --skip-fs-probe)'{-s,--skip-fs-probe}'[skip filesystem probing on the device]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '*:device:_files -g "/dev/*"' && ret=0
return ret
