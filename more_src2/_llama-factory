#compdef llama-factory llamafactory llamafactory-cli
# _llama-factory — hiyouga LLaMA Factory all-in-one LLM fine-tuning toolkit CLI for SFT DPO PPO RLHF KTO ORPO and inference on Llama Qwen Mistral Mixtral Gemma DeepSeek (hiyouga team, Python); argparse
# upstream: https://github.com/hiyouga/LLaMA-Factory

_llama-factory() {
    local -a sub=(
        'train:train model SFT/DPO/PPO/ORPO/KTO'
        'eval:evaluate on benchmark'
        'export:export merged model'
        'chat:chat with trained model'
        'api:start OpenAI-compatible API'
        'webchat:start web chat UI'
        'webui:start training web UI'
        'env:show env info'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'llama-factory subcommand' sub ;;
        args)
            case $words[1] in
                train|eval|export|chat|api|webchat) _arguments \
                    '--model_name_or_path=+[id or path]:str:' \
                    '--adapter_name_or_path=+[id or path]:str:' \
                    '--template=+[t]:t:(default alpaca vicuna llama2 llama3 mistral mixtral qwen yi gemma deepseek deepseekv2 chatglm2 chatglm3 chatglm4 chatml baichuan baichuan2 zephyr starchat codegeex2 falcon glm4 internlm internlm2 phi phi3 cohere)' \
                    '--dataset=+[dataset]:str:' \
                    '--dataset_dir=+[dir]:dir:_files -/' \
                    '--stage=+[s]:s:(sft pt rm ppo dpo orpo kto)' \
                    '--finetuning_type=+[t]:t:(lora freeze full)' \
                    '--lora_rank=+[N]:n:' \
                    '--lora_alpha=+[N]:n:' \
                    '--lora_dropout=+[F]:f:' \
                    '--lora_target=+[csv]:str:' \
                    '--quantization_bit=+[N]:n:(4 8)' \
                    '--double_quantization[double quantization]' \
                    '--per_device_train_batch_size=+[N]:n:' \
                    '--per_device_eval_batch_size=+[N]:n:' \
                    '--gradient_accumulation_steps=+[N]:n:' \
                    '--learning_rate=+[F]:f:' \
                    '--num_train_epochs=+[F]:f:' \
                    '--max_samples=+[N]:n:' \
                    '--cutoff_len=+[N]:n:' \
                    '--output_dir=+[dir]:dir:_files -/' \
                    '--logging_steps=+[N]:n:' \
                    '--save_steps=+[N]:n:' \
                    '--save_total_limit=+[N]:n:' \
                    '--warmup_ratio=+[F]:f:' \
                    '--lr_scheduler_type=+[t]:t:(linear cosine polynomial constant constant_with_warmup inverse_sqrt cosine_with_restarts reduce_lr_on_plateau)' \
                    '--bf16[bf16]' \
                    '--fp16[fp16]' \
                    '--ddp_find_unused_parameters[ddp find unused]' \
                    '--deepspeed=+[file]:file:_files -g "*.json"' \
                    '--report_to=+[r]:r:(none wandb tensorboard mlflow azure_ml all)' \
                    '*:config yaml:_files -g "*.yaml *.yml *.json"' ;;
            esac
            ;;
    esac
}

_llama-factory "$@"
