#compdef rpm2cpio
# Documentation: https://man7.org/linux/man-pages/man8/rpm2cpio.8.html
# Reference accessed: 2026-05-21
# Verified: upstream man7.org rpm2cpio(8) — the tool documents NO
# flags. Synopsis is `rpm2cpio [filename]` and accepts `-` for
# stdin. Removed from prior file: fabricated --help and --version
# (neither is documented).

_arguments \
  '1:rpm file:_files -g "*.rpm"'
