#compdef power-bi pbi pbi-tools
# _power-bi — Microsoft Power BI power-bi pbi-tools CLI command-line frontend wrapping the Microsoft Power BI Power BI Service Power BI Embedded REST API managing workspaces datasets reports dashboards capacities gateways apps imports refresh schedules dataflows tenants admin users groups deployments PBIX PBIT files (Microsoft team, .NET); custom argparse
# upstream: https://learn.microsoft.com/en-us/power-bi/

_power-bi() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'workspace:workspace operations'
        'dataset:dataset operations'
        'report:report operations'
        'dashboard:dashboard operations'
        'capacity:capacity operations'
        'gateway:gateway operations'
        'app:app operations'
        'import:import a PBIX file'
        'refresh:refresh a dataset'
        'dataflow:dataflow operations'
        'admin:admin operations'
        'tenant:tenant settings'
        'user:user operations'
        'group:group operations'
        'deployment:deployment pipeline operations'
        'export:export a report'
        'pbix:extract or compile a PBIX file'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--client-id=+[id]:str:' \
        '--client-secret=+[secret]:str:' \
        '--tenant=+[id]:str:' \
        '--token=+[token]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--api-url=+[url]:str:' \
        '--workspace-id=+[id]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'power-bi subcommand' sub ;;
        args)
            case $words[1] in
                workspace|dataset|report|dashboard|capacity|gateway|app|dataflow|user|group|deployment) _arguments '1:op:(list get create update delete refresh clone publish)' '*:id:' ;;
                pbix) _arguments '1:op:(extract compile compare info)' '*:file:_files -g "*.pbix *.pbit"' ;;
                import|export) _arguments '*:file:_files -g "*.pbix *.pbit"' ;;
            esac
            ;;
    esac
}

_power-bi "$@"
