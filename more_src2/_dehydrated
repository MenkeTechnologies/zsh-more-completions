#compdef dehydrated
# Documentation: https://github.com/dehydrated-io/dehydrated/blob/master/dehydrated
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-e,--env}'[output environment variables]' \
  '(-c --cron)'{-c,--cron}'[sign/renew certificates]' \
  '--register[register account key]' \
  '--account[update account contact information]' \
  '--display-terms[display terms of service]' \
  '(-s --signcsr)'{-s,--signcsr}'[sign a CSR]:csr file:_files -g "*.csr"' \
  '(-r --revoke)'{-r,--revoke}'[revoke a certificate]:cert file:_files -g "*.pem"' \
  '--deactivate[deactivate account]' \
  '(-gc --cleanup)'{-gc,--cleanup}'[move unused certificate files to archive]' \
  '(-gcd --cleanup-delete)'{-gcd,--cleanup-delete}'[delete unused certificate files]' \
  '--accept-terms[accept CA terms of service]' \
  '(-fc --full-chain)'{-fc,--full-chain}'[print full chain with signcsr]' \
  '(-4 --ipv4)'{-4,--ipv4}'[use IPv4 only]' \
  '(-6 --ipv6)'{-6,--ipv6}'[use IPv6 only]' \
  '(-d --domain)'{-d,--domain}'[domain to manage]:domain' \
  '--ca=[CA URL or preset]:ca' \
  '--alias=[certificate directory name]:alias' \
  '(-g --keep-going)'{-g,--keep-going}'[continue on errors in cron mode]' \
  '(-x --force)'{-x,--force}'[force renewal regardless of expiration]' \
  '--force-validation[force revalidation]' \
  '(-n --no-lock)'{-n,--no-lock}'[disable lockfile]' \
  '--lock-suffix=[suffix for lockfile]:suffix' \
  '--ocsp[require OCSP stapling]' \
  '(-p --privkey)'{-p,--privkey}'[use alternate private key]:key file:_files' \
  '--domains-txt=[domains file path]:file:_files' \
  '(-f --config)'{-f,--config}'[config file]:file:_files' \
  '(-k --hook)'{-k,--hook}'[hook script path]:script:_files' \
  '--preferred-chain=[preferred cert chain]:issuer' \
  '(-o --out)'{-o,--out}'[output directory]:directory:_directories' \
  '--alpn=[ALPN output directory]:directory:_directories' \
  '(-t --challenge)'{-t,--challenge}'[challenge type]:type:(http-01 dns-01 dns-persist-01 tls-alpn-01)' \
  '(-a --algo)'{-a,--algo}'[key algorithm]:algo:(rsa secp384r1 prime256v1)' \
  '--acme-profile=[ACME profile]:name' \
  '--order-timeout=[order timeout seconds]:n' \
  '--validation-timeout=[validation timeout seconds]:n' && ret=0

return ret
