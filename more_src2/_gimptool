#compdef gimptool gimptool-2.0
# Documentation: https://manpages.debian.org/gimptool
# Source: GNOME/gimp tools/gimptool.c — GIMP build helper / plugin installer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(-n --just-print --dry-run --recon)'{-n,--just-print,--dry-run,--recon}'[show what would be done]' \
    '(--quiet --silent)'{--quiet,--silent}'[suppress output]' \
    '--msvc-syntax[use MSVC syntax for paths]' \
    '--includedir[print GIMP include dir]' \
    '--cflags[print C flags for plugin build]' \
    '--cflags-noui[print C flags without UI]' \
    '--cflags-nogimpui[print C flags without gimpui]' \
    '--cflags-geglop[print C flags for GEGL operations]' \
    '--libs[print libraries for plugin build]' \
    '--libs-noui[print libraries without UI]' \
    '--libs-nogimpui[print libraries without gimpui]' \
    '--libs-geglop[print libraries for GEGL operations]' \
    '--build=-[build a plugin]:source:_files -g "*.c"' \
    '--build-noui=-[build a non-UI plugin]:source:_files -g "*.c"' \
    '--build-nogimpui=-[build plugin without gimpui]:source:_files -g "*.c"' \
    '--build-geglop=-[build a GEGL operation]:source:_files -g "*.c"' \
    '--install=-[build and install a plugin]:source:_files -g "*.c"' \
    '--install-bin=-[install an existing plugin binary]:bin:_files' \
    '--install-script=-[install a script-fu]:script:_files -g "*.scm"' \
    '--install-admin=-[install plugin system-wide]:source:_files -g "*.c"' \
    '--install-admin-bin=-[install plugin binary system-wide]:bin:_files' \
    '--install-admin-script=-[install script-fu system-wide]:script:_files -g "*.scm"' \
    '--install-noui=-[install non-UI plugin]:source:_files -g "*.c"' \
    '--install-admin-noui=-[install non-UI plugin system-wide]:source:_files -g "*.c"' \
    '--install-nogimpui=-[install plugin without gimpui]:source:_files -g "*.c"' \
    '--install-admin-nogimpui=-[install plugin without gimpui system-wide]:source:_files -g "*.c"' \
    '--uninstall-bin=-[uninstall plugin]:name:_default' \
    '--uninstall-script=-[uninstall script-fu]:name:_default' \
    '--uninstall-admin-bin=-[uninstall plugin system-wide]:name:_default' \
    '--uninstall-admin-script=-[uninstall script-fu system-wide]:name:_default' \
    && ret=0

return ret
