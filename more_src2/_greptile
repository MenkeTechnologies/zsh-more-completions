#compdef greptile
# Documentation: https://github.com/greptileai/cli
# Reference accessed: 2026-05-22
# Verified: README.md install and use commands.

# Zsh completion for greptile - Greptile code review CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'greptile command' \
      'addPath[add greptile to system PATH]' \
      'login[authenticate with GitHub]' \
      'auth[authenticate with GitHub]' \
      'review[run code review]' \
      'start[start interactive session]' \
      'add[add repository to session]:repo:' \
      'list[list repositories in session]' \
      'remove[remove repository from session]:repo:' && ret=0
    ;;
  args)
    case $line[1] in
      add|remove)
        _arguments '1:repository:(owner/repo)' && ret=0
        ;;
    esac
    ;;
esac

return ret
