#compdef magnum-api
# Documentation: https://docs.openstack.org/magnum/latest/configuration/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above; oslo.log options verified at
#           https://docs.openstack.org/oslo.log/latest/configuration/index.html

# OpenStack Magnum API server (uses oslo.config + oslo.log)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '*--config-file=[config file (may be repeated)]:file:_files' \
  '*--config-dir=[config dir (may be repeated)]:dir:_directories' \
  '--debug[set log level to debug]' \
  '-d[set log level to debug]' \
  '--log-config-append=[log config file]:file:_files' \
  '--log-date-format=[log date format]:fmt' \
  '--log-dir=[log directory]:dir:_directories' \
  '--log-file=[log file]:file:_files' \
  '--nodebug[do not set log level to debug]' \
  '--rate-limit-burst=[log rate limit burst]:n' \
  '--rate-limit-except-level=[log rate limit except level]:level' \
  '--rate-limit-interval=[log rate limit interval]:n' \
  '--rpc-conn-pool-size=[RPC conn pool size]:n' \
  '--rpc-response-timeout=[RPC response timeout]:n' \
  '--syslog-log-facility=[syslog facility]:facility' \
  '--transport-url=[transport URL]:url' \
  '--use-journal[log to systemd journal]' \
  '--use-json[log as JSON]' \
  '--use-syslog[log via syslog]' \
  '--use-stderr[log to stderr]' \
  '--watch-log-file[watch log file]' && ret=0
return ret
