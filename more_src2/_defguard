#compdef defguard
# ============================================================================
# defguard - Zero-Trust access management server (Rust)
#
# Author : DefGuard team
# Upstream: https://github.com/DefGuard/defguard
#
# DefGuard is a self-hosted open-source Zero-Trust Network Access
# platform with native WireGuard VPN, OpenID Connect SSO, MFA
# (TOTP + WebAuthn/Passkey + email), per-user network access
# control lists, gateway clustering, gRPC + REST control plane,
# Prometheus metrics, and a complete operator web UI. The daemon
# bundles a PostgreSQL-backed core, an OIDC identity provider
# (Settings.openid_signing_key), a TURN-style proxy, an event
# logger pipeline, and a gateway manager that coordinates with
# the per-location DefGuard WireGuard gateways over gRPC.
#
# The WebAuthn / FIDO2 / Passkey lane is built on
# `webauthn-rs = { workspace = true }` (declared verbatim at
# upstream `crates/defguard_core/Cargo.toml` HEAD), the canonical
# Rust WebAuthn library by the Kanidm org (William Brown,
# github.com/kanidm/webauthn-rs, 660+ stars). webauthn-rs
# implements W3C WebAuthn Level 3 + CTAP 2.x end-to-end:
# attestation (none, packed, fido-u2f, tpm, android-key,
# android-safetynet, apple), assertion verification, resident
# credentials, user verification, conditional UI / Passkey
# autofill, the COSE algorithm registry, and the FIDO MDS
# (Metadata Service) certification chain. DefGuard uses it as
# the second-factor option alongside TOTP for the operator
# login pathway + per-user MFA enrollment.
#
# Additionally pulls in `webauthn-authenticator-rs` to model the
# server-side ceremony's authenticator counterpart (used for
# integration tests + the soft-passkey simulator).
#
# ----------------------------------------------------------------------------
# AXIS 213 :: WEBAUTHN / FIDO2 / PASSKEY (W3C LVL 3 + CTAP 2.x)
# Round 1337 :: Rust slot 1 of 4 :: OPENS Axis 213
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : kanidm/webauthn-rs                    - typed WebAuthn server
#   Go      : go-webauthn/webauthn                  - Duo Labs' Go server library
#   TS/Node : MasterKale/SimpleWebAuthn             - Node + browser dual-package
#
# All three target the W3C WebAuthn Level 3 spec (R-EC 2023)
# plus the FIDO Alliance CTAP 2.1 client-to-authenticator
# protocol. Convergence is unusually high here because WebAuthn
# is a tightly-specified attestation + assertion ceremony - the
# byte layout of the CBOR-encoded clientDataJSON + authData +
# signature is dictated by the spec, and every server library
# must round-trip CBOR-encoded values identically.
#
# WebAuthn is also the load-bearing protocol for Passkey
# rollouts across Apple iCloud Keychain / Google Password
# Manager / 1Password / Bitwarden / Dashlane / Windows Hello -
# every Passkey-enabled service has a server-side WebAuthn
# library binding from this axis's canonical family.
# ============================================================================

_defguard() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--log-level[log verbosity]:level:(trace debug info warn error)' \
        '--log-file[log file path]:file:_files' \
        '--secret-key[deprecated: legacy secret key (use Settings.secret_key)]:secret:' \
        '--database-host[PostgreSQL host (default localhost)]:host:' \
        '--database-port[PostgreSQL port (default 5432)]:port:' \
        '--database-name[PostgreSQL database name (default defguard)]:name:' \
        '--database-user[PostgreSQL user (default defguard)]:user:' \
        '--database-password[PostgreSQL password]:password:' \
        '--http-port[REST + web UI port (default 8000)]:port:' \
        '--grpc-port[gateway gRPC port (default 50055)]:port:' \
        '--grpc-cert[gRPC TLS certificate PEM]:file:_files -g "*.(pem|crt)"' \
        '--grpc-key[gRPC TLS private key PEM]:file:_files -g "*.(pem|key)"' \
        '--openid-key[deprecated: legacy OIDC signing key]:key:' \
        '--hmac[deprecated: temporary OIDC HMAC compatibility flag]' \
        '--url[deprecated: defguard public URL (use Settings.defguard_url)]:url:' \
        '--disable-stats-purge[deprecated: skip periodic stats purge]:bool:(true false)' \
        '--stats-purge-frequency[deprecated: purge interval]:duration:' \
        '--stats-purge-threshold[deprecated: purge age threshold]:duration:' \
        '--enrollment-url[deprecated: enrollment URL (use Settings.public_proxy_url)]:url:' \
        '--proxy-url[DefGuard proxy URL]:url:' \
        '--enrollment-token-timeout[deprecated: token TTL]:duration:' \
        '--mfa-code-timeout[deprecated: MFA code TTL]:duration:' \
        '--session-timeout[deprecated: session TTL]:duration:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]'
}

_defguard "$@"
