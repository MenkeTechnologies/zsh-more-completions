#compdef dh_autoreconf dh_autoreconf_clean
# _dh_autoreconf — debhelper wrapper for autoreconf (Debian/dh-autoreconf)
# upstream: https://salsa.debian.org/debian/dh-autoreconf
# Flags from dh_autoreconf(1) man page.

_dh_autoreconf() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*-X+[exclude files matching pattern]:pattern:' \
        '*--exclude=[exclude files matching pattern]:pattern:' \
        '--mode=[change-detection mode]:mode:(md5 timesize)' \
        '--as-needed[enable -Wl,--as-needed in ltmain.sh]' \
        '-D+[run in source directory]:dir:_files -/' \
        '--sourcedirectory=[run in source directory]:dir:_files -/' \
        '*:: :_command_names -e'
}

_dh_autoreconf "$@"
