#compdef radvd-utils
# Documentation: https://manpages.ubuntu.com/manpages/noble/man8/radvdump.8.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: radvd-utils is a Debian/Ubuntu package name (not a binary). It
# ships radvdump; this completion is a wrapper that delegates to that
# command's real flag set.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'radvdump:dump router advertisement messages on the wire'
)
_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'radvd-utils command' commands && ret=0 ;;
  args)
    case $line[1] in
      radvdump)
        _arguments \
          '(-v --version)'{-v,--version}'[show version]' \
          '(-h --help)'{-h,--help}'[show help]' \
          '(-f --file-format)'{-f,--file-format}'[output radvd config file format]' \
          '(-e --exclude-defaults)'{-e,--exclude-defaults}'[exclude default-valued options]' \
          '(-d --debug)'{-d,--debug}'[debug level 0-4]:level:(0 1 2 3 4)' && ret=0
        ;;
    esac
    ;;
esac
return ret
