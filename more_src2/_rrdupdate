#compdef rrdupdate
# Documentation: https://oss.oetiker.ch/rrdtool/doc/rrdupdate.en.html
# Reference accessed: 2026-05-21
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(-t --template)'{-t,--template}'+[ds names]:ds:' \
  '(-d --daemon)'{-d,--daemon}'+[rrdcached address]:address:' \
  '(-s --skip-past-updates)'{-s,--skip-past-updates}'[silently skip data older than the latest update]' \
  '*:rrd file:_files -g "*.rrd"' && ret=0

return ret
