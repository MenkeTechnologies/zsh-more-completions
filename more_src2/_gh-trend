#compdef gh-trend
# Documentation: https://github.com/ramtiga/gh-trend
# Source: ramtiga/gh-trend — gh CLI extension for trending repositories.
# Reference accessed: 2026-06-01
# Also reachable as `gh trend`. Uses ~/.netrc for star/unstar features.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-l --lang)'{-l+,--lang=}'[filter by programming language]:lang:_default' \
    '(-d --desc)'{-d,--desc}'[display repository descriptions]' \
    '(-n --num)'{-n+,--num=}'[limit number of results]:n:_default' \
    '(-b --brows)'{-b,--brows}'[open repository in browser]' \
    '(-s --star)'{-s,--star}'[star a repository]' \
    '(-u --unstar)'{-u,--unstar}'[unstar a repository]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
