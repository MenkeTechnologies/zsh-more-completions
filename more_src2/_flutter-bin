#compdef flutter
# _flutter-bin — Flutter Mobile/Web/Desktop framework CLI (Google, Dart); build/run/test Flutter apps
# upstream: https://github.com/flutter/flutter

_flutter-bin() {
    local -a sub=(
        'analyze:analyze project'
        'assemble:assemble for an output'
        'attach:attach to running app'
        'bash-completion:print bash completion'
        'build:build distribution'
        'channel:list/switch channels'
        'clean:clean build artifacts'
        'config:configure SDK'
        'create:create new project'
        'custom-devices:custom devices'
        'daemon:run as daemon'
        'devices:list connected devices'
        'doctor:check setup'
        'downgrade:downgrade SDK'
        'drive:run flutter drive tests'
        'emulators:list/launch emulators'
        'gen-l10n:generate localizations'
        'help:show help'
        'install:install on device'
        'logs:print device logs'
        'mcp-server:run MCP server'
        'pub:pub package manager'
        'precache:download offline artifacts'
        'run:run app'
        'screenshot:take screenshot'
        'symbolize:symbolize stack trace'
        'test:run tests'
        'upgrade:upgrade SDK'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[device id]:device:' \
        '--device-id+[device id]:device:' \
        '--no-color[no color]' \
        '--show-test-device[show test device]' \
        '--enable-analytics[enable analytics]' \
        '--disable-analytics[disable analytics]' \
        '--suppress-analytics[suppress analytics]' \
        '--prefixed-errors[prefixed errors]' \
        '--bug-report[bug report mode]' \
        '--no-bug-report[no bug report]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flutter subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--org+[organization]:str:' \
                    '--project-name+[project name]:str:' \
                    '--description+[description]:str:' \
                    '-t+[template]:template:(app module package plugin plugin_ffi)' \
                    '--template+[template]:template:' \
                    '-a+[android language]:lang:(java kotlin)' \
                    '--android-language+[android language]:lang:(java kotlin)' \
                    '-i+[ios language]:lang:(objc swift)' \
                    '--ios-language+[ios language]:lang:(objc swift)' \
                    '--platforms+[platforms]:str:' \
                    '--no-pub[no pub get]' \
                    '--empty[empty project]' \
                    '--overwrite[overwrite]' \
                    '*:dir:_files -/' ;;
                build) _arguments '1:type:(aar apk appbundle bundle ios ios-framework ipa linux macos macos-framework web web-server windows xcframework)' '*:args:' ;;
                run) _arguments \
                    '--release[release]' \
                    '--profile[profile]' \
                    '--debug[debug]' \
                    '--target+[entry file]:file:_files -g "*.dart"' \
                    '-t+[entry file]:file:_files -g "*.dart"' \
                    '--flavor+[flavor]:flavor:' \
                    '--observatory-port+[observatory port]:port:' \
                    '--vmservice-port+[vmservice port]:port:' \
                    '--hot[hot reload]' \
                    '--no-hot[no hot reload]' \
                    '--start-paused[start paused]' \
                    '--use-application-binary+[app binary]:file:_files' ;;
                test) _arguments \
                    '--coverage[coverage]' \
                    '--name+[name regex]:regex:' \
                    '--plain-name+[plain name]:str:' \
                    '--reporter+[reporter]:reporter:(compact expanded github json)' \
                    '--platform+[platform]:platform:' \
                    '*:test:_files' ;;
                pub) _arguments '*:pub cmd:' ;;
            esac
            ;;
    esac
}

_flutter-bin "$@"
