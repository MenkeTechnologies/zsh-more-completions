#compdef judgeval
# Documentation: https://github.com/judgmentlabs/judgeval
# Reference accessed: 2026-05-23
# Verified: judgeval --help and judgeval scorer --help (Typer CLI).

# Zsh completion for judgeval - Judgment Labs evaluation and scorer CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--install-completion[install shell completion]' \
  '--show-completion[show shell completion script]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'judgeval command' \
      'load-otel-env[run command with OpenTelemetry env vars]' \
      'version[show CLI version]' \
      'scorer[manage custom scorers]' && ret=0
    ;;
  args)
    case $line[1] in
      scorer)
        if (( CURRENT == 2 )); then
          _values 'scorer command' \
            'upload[upload custom scorer to Judgment]' \
            'init[initialize custom scorer skeleton]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
