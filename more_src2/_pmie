#compdef pmie
# _pmie — Performance Co-Pilot pmie (Performance Metrics Inference Engine evaluating arithmetic + logic rules against pmcd-supplied metrics and firing actions on threshold matches; -c config file, -h host, -a archive, -t interval seconds, -d daemonize, -l log file, -m machine, -O sample offset, -V verbose)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmie/src/pmie.c on tip.

_pmie() {
    _arguments \
        '-c+[config file]:file:_files' \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-t+[interval]:interval:' \
        '-d[daemonize]' \
        '-l+[log file]:file:_files' \
        '-V[verbose]' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-O+[sample offset]:offset:' \
        '-z[use archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-A+[align time]:time:' \
        '-D+[debug flags]:flags:' \
        '-n+[namespace]:file:_files' \
        '-q[quiet]' \
        '-U+[user]:user:_users'
}

_pmie "$@"
