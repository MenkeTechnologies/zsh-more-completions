#compdef mastodon-rs
# _mastodon-rs — Mastodon Rust CLI client; fetch timelines, post statuses, manage follows from terminal
# upstream: https://github.com/mre/mastodon-rs

_mastodon-rs() {
    local -a sub=(
        'login:authenticate against an instance'
        'logout:remove saved credentials'
        'post:publish a status'
        'timeline:fetch a timeline'
        'follow:follow a user'
        'unfollow:unfollow a user'
        'search:search statuses/users/tags'
        'notifications:fetch notifications'
        'bookmark:bookmark a status'
        'profile:show profile'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-i --instance)'{-i,--instance}'+[instance URL]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mastodon-rs subcommand' sub ;;
        args)
            case $words[1] in
                timeline) _arguments '1:timeline:(home public local notifications)' ;;
                post) _arguments \
                    '(-v --visibility)'{-v,--visibility}'+[visibility]:vis:(public unlisted private direct)' \
                    '(-w --cw)'{-w,--cw}'+[content warning]:text:' \
                    '1:text:' ;;
            esac
            ;;
    esac
}

_mastodon-rs "$@"
