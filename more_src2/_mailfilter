#compdef mailfilter
# Documentation: https://manpages.debian.org/bookworm/mailfilter/mailfilter.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mailfilter: POP3 server-side mail filter
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-L --logfile)'{-L,--logfile=}'[log file]:file:_files' \
  '(-M --mailfilterrc)'{-M,--mailfilterrc=}'[configuration file]:file:_files' \
  '(-r --return-value)'{-r,--return-value}'[enable additional return values]' \
  '(-s --skip-ssl-verify)'{-s,--skip-ssl-verify}'[skip SSL certificate verification]' \
  '(-t --test)'{-t,--test}'[simulate deletes without removing mail]' \
  '(-i --ignore-time-stamps)'{-i,--ignore-time-stamps}'[ignore invalid Message-ID time stamps]' \
  '(-v --verbose)'{-v,--verbose=}'[verbosity level]:level:(0 1 2 3)' && ret=0
return ret
