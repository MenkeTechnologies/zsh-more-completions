#compdef plakar
# Documentation: https://www.plakar.io/docs/v1.0.6/
# Reference accessed: 2026-05-20
# Verified: upstream README at https://github.com/PlakarKorp/plakar.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args
local -a commands

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help]' \
  'at[specify repository location]:location' \
  '1: :->command' \
  '*:: :->args' && ret=0

case $state in
  command)
    commands=(
      'create:Initialize a new repository'
      'backup:Create a new snapshot'
      'restore:Restore files from a snapshot'
      'ls:List snapshots in the repository'
      'cat:Print file contents from a snapshot'
      'diff:Compare snapshots'
      'sync:Synchronize backups to another location'
      'ui:Launch the web-based UI'
      'info:Display repository information'
      'check:Verify repository integrity'
      'prune:Remove old snapshots'
      'repair:Detect and fix state inconsistencies'
      'maintenance:Run maintenance tasks'
      'archive:Archive snapshots'
      'clone:Clone a repository'
      'locate:Find files across snapshots'
      'query:Query repository data'
      'mount:Mount snapshots as filesystem'
      'agent:Run backup agent'
      'scheduler:Schedule tasks'
      'server:Repository server'
      'login:Authenticate to a service'
      'logout:Log out of a service'
      'token:Manage tokens'
      'policy:Configure policies'
      'source:Configure sources'
      'destination:Configure destinations'
      'store:Manage stores'
      'version:Display version'
      'help:Show help'
    )
    _describe -t commands command commands && ret=0
    ;;
  args)
    _default && ret=0
    ;;
esac

return ret
