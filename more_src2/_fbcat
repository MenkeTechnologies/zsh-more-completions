#compdef fbcat
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/fbcat.1.html
# Reference accessed: 2026-05-17
# Verified: Ubuntu bionic fbcat(1) manpage. fbcat takes a single
# optional positional [fbdev]; no -d/-s/-V flags upstream.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -d/--device, -s/--black-is-zero, -V/--version, -h/--help
# flags (none documented upstream).

# fbcat: framebuffer capture (positional fbdev only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:framebuffer device:_files -g "/dev/fb*"' && ret=0
return ret
