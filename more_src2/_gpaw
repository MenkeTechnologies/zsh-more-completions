#compdef gpaw gpaw-python
# _gpaw — Jens Mortensen GPAW grid-based projector-augmented-wave DFT package using ASE for electronic structure calculations (gpaw team, Python/C); argparse
# upstream: https://gitlab.com/gpaw/gpaw

_gpaw() {
    local -a sub=(
        'run:run a GPAW calculation'
        'python:run python script with GPAW'
        'info:show GPAW info'
        'install-data:install PAW datasets'
        'dataset:dataset subcommands'
        'sbatch:submit to slurm'
        'mpi:run with MPI'
        'test:run tests'
        'benchmark:run benchmarks'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-P+[number of MPI processes]:n:' \
        '--parallel=+[N]:n:' \
        '--mpi=+[MPI processes]:n:' \
        '--gpu[enable GPU]' \
        '--gpu-id=+[gpu id]:n:' \
        '--xc=+[xc functional]:f:(LDA PBE RPBE BLYP B3LYP HSE06 vdW-DF vdW-DF2 BEEF-vdW SCAN TPSS PW91)' \
        '--basis=+[basis]:b:(dzp tzp tzdp pvalence-dzp pvalence-tzp pw fd lcao)' \
        '--mode=+[mode]:m:(fd lcao pw aedz)' \
        '--restart=+[restart file]:file:_files -g "*.gpw"' \
        '--output=+[output file]:file:_files -g "*.out *.log"' \
        '--no-mpi[no MPI]' \
        '--debug[debug mode]' \
        '--verbose[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gpaw subcommand' sub ;;
        args)
            case $words[1] in
                run|python) _arguments '*:python script:_files -g "*.py *.gpw"' ;;
                dataset) _arguments '1:dataset cmd:(install list show download)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_gpaw "$@"
