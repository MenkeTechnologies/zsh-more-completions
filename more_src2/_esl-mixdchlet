#compdef esl-mixdchlet
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-mixdchlet.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-mixdchlet: fit/score/generate/sample mixture-Dirichlet priors
local curcontext="$curcontext" state line ret=1
local -a commands=(
  'fit:fit mixture Dirichlet to count data'
  'score:score count data under a fitted mixture'
  'gen:generate count vectors from a mixture'
  'sample:sample a random mixture Dirichlet'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'esl-mixdchlet subcommand' commands && ret=0 ;;
  args)
    case ${words[1]} in
      fit)
        _arguments \
          '-h[show help]' \
          '-s[random seed]:n' \
          '*:count file:_files' && ret=0 ;;
      score)
        _arguments \
          '-h[show help]' \
          '*:mixture and count files:_files' && ret=0 ;;
      gen)
        _arguments \
          '-h[show help]' \
          '-s[random seed]:n' \
          '-M[counts per sampled vector]:n' \
          '-N[number of count vectors]:n' \
          '*:mixture file:_files' && ret=0 ;;
      sample)
        _arguments \
          '-h[show help]' \
          '-s[random seed]:n' \
          '-K[alphabet size]:n' \
          '-Q[number of mixture components]:n' && ret=0 ;;
    esac ;;
esac
return ret
