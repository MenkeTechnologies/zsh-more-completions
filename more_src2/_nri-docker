#compdef nri-docker
# Documentation: https://github.com/newrelic/nri-docker
# Reference accessed: 2026-05-19
# Verified: upstream repo README at the URL above. Flag set is the
# infra-integrations-sdk DefaultArgumentList; this binary is config-driven via
# env vars (CONTAINER_RUNTIME_PATH etc.) plus the SDK defaults.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-verbose[print more information to logs]' \
  '-pretty[print pretty formatted JSON]' \
  '-metrics[publish metrics data]' \
  '-inventory[publish inventory data]' \
  '-events[publish events data]' \
  '-metadata[add customer-defined key-value attributes]' \
  '-nri_add_hostname[add hostname attribute to the samples]' \
  '-nri_cluster=[cluster name]:cluster:' \
  '-nri_service=[service name]:service:' \
  '-temp_dir=[path for temporal data]:dir:_files -/' \
  '*::nri-docker args:_files' && ret=0
return ret
