#compdef datascript
# _datascript — Nikita Prokopov DataScript in-memory database for Clojure/ClojureScript CLI alias (tonsky team, Clojure); custom argparse
# upstream: https://github.com/tonsky/datascript

_datascript() {
    local -a sub=(
        'eval:evaluate Datalog query'
        'shell:open repl with empty datascript db'
        'load:load EDN/JSON into a db'
        'dump:dump db to EDN'
        'tx:apply transaction file'
        'q:run query'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--db=+[db file]:file:_files' \
        '-d+[db file]:file:_files' \
        '--schema=+[schema file]:file:_files' \
        '-s+[schema file]:file:_files' \
        '--format=+[format]:f:(edn transit json)' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datascript subcommand' sub ;;
        args)
            case $words[1] in
                q|eval) _arguments \
                    '1:query:' \
                    '--file=+[query file]:file:_files' \
                    '-f+[query file]:file:_files' ;;
                load|dump|tx) _arguments \
                    '1:file:_files' \
                    '--format=+[format]:f:(edn transit json)' ;;
            esac
            ;;
    esac
}

_datascript "$@"
