#compdef dbus-monitor
# Documentation: https://manpages.debian.org/dbus-monitor
# Source: freedesktop/dbus tools/dbus-monitor.c — monitor D-Bus messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '(--session --system --address)--session[monitor session bus]' \
    '(--session --system --address)--system[monitor system bus]' \
    '(--session --system --address)--address=-[monitor named bus address]:address:_default' \
    '(--profile --pcap)--profile[profile-format output]' \
    '(--profile --pcap)--pcap[pcap-format binary output]' \
    '--binary[output messages as binary]' \
    '--monitor[use Monitoring interface]' \
    '*:match rule:_default' \
    && ret=0

return ret
