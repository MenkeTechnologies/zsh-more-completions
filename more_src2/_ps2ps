#compdef ps2ps ps2ps2
# Documentation: man ps2ps(1)
# Source: Ghostscript ghostpdl ps2ps (master) — "distill" PostScript through gs (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '*-d-[gs -d option]:option:_default' \
    '*-s-[gs -s option]:option:_default' \
    '1:input PostScript file:_files -g "*.{ps,eps}"' \
    '2:output PostScript file:_files -g "*.ps"' \
    && ret=0

return ret
