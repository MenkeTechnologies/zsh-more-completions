#compdef logdaemon
# _logdaemon — Wietse Venema logdaemon family runtime (replacement /usr/libexec/* daemons (rshd, rlogind, telnetd, ftpd) hardened with /etc/logdaemon configuration, tcp-wrappers acl checks and forced-command lists; per-binary flags include -h help, -d debug, -l strict logging, -t tcp/wrapper-style, -v verbose; positional argument is a config file when supported)
# upstream: https://www.porcupine.org/wietse/logdaemon/ (logdaemon)
# Common flag surface from Wietse Venema logdaemon README on tip.

_logdaemon() {
    _arguments \
        '-h[show help]' \
        '-d[debug]' \
        '-l[strict logging]' \
        '-t[tcp wrapper acl]' \
        '-v[verbose]' \
        '*:config or arg:_files'
}

_logdaemon "$@"
