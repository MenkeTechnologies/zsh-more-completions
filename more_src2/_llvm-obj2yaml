#compdef llvm-obj2yaml
# _llvm-obj2yaml — LLVM object file to YAML dumper (LLVM project, C++); print ELF/COFF/Mach-O/wasm structure as YAML
# upstream: https://github.com/llvm/llvm-project

_llvm-obj2yaml() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '--output=+[output file]:file:_files' \
        '--raw-data[raw section data]' \
        '--raw-segment+[raw segment]:str:' \
        '*:file:_files'
}

_llvm-obj2yaml "$@"
