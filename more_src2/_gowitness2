#compdef gowitness2
# _gowitness2 — Leon Jacobs sensepost gowitness2 CLI command-line frontend wrapping the gowitness golang web screenshot utility using Chrome Headless open-source written in Go file-input single-target nmap-input nessus-input report-server-built-in scan-CIDR scan-list scan-nmap scan-nessus scan-single SQLite-DB GORM-database technologies-detect screenshot-Chrome-Headless CSS-XPath custom-resolutions user-agent timeout proxies (sensepost Leon Jacobs team, Go); cobra
# upstream: https://github.com/sensepost/gowitness

_gowitness2() {
    local -a sub=(
        'scan:scan operations'
        'single:scan a single URL'
        'file:scan from a file'
        'nmap:scan from Nmap XML'
        'nessus:scan from Nessus XML'
        'report:report operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-D+[DB URL]:str:' \
        '--db-uri=+[uri]:str:' \
        '-X+[chrome path]:_files' \
        '--chrome-path=+[file]:_files' \
        '-c+[chrome flag]:str:' \
        '*--chrome-flag=+[flag]:str:' \
        '-P+[screenshot path]:dir:_files -/' \
        '--screenshot-path=+[dir]:dir:_files -/' \
        '--screenshot-format=+[fmt]:f:(png jpeg)' \
        '--full-page[full page]' \
        '-T+[timeout sec]:n:' \
        '--timeout=+[sec]:n:' \
        '-Y+[user agent]:str:' \
        '--user-agent=+[ua]:str:' \
        '-r+[resolution]:str:' \
        '--resolution-x=+[N]:n:' \
        '--resolution-y=+[N]:n:' \
        '-p+[proxy]:str:' \
        '--proxy=+[url]:str:' \
        '-W[disable HTTPS check]' \
        '--no-http[no HTTP]' \
        '--no-https[no HTTPS]' \
        '-d+[delay sec]:n:' \
        '--delay=+[sec]:n:' \
        '--save-content[save content]' \
        '--save-tech[save technologies]' \
        '--debug-log=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gowitness subcommand' sub ;;
        args)
            case $words[1] in
                scan) _arguments '1:type:(single file nmap nessus)' '*:arg:' ;;
                single) _arguments '*:url:' ;;
                file|nmap|nessus) _arguments '*:file:_files' ;;
                report) _arguments '1:op:(serve generate)' '*:arg:' ;;
            esac
            ;;
    esac
}

_gowitness2 "$@"
