#compdef lsix
# Documentation: https://github.com/hackerb9/lsix
# Reference accessed: 2026-05-19
# Verified: hackerb9/lsix README. STUB — upstream README states the
# tool is "designed to be very simple, with no command line flags,
# no configuration files, no knobs to twiddle". Only positional image
# arguments are accepted.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h/--help flag (not present in the lsix script).

_lsix() {
  _arguments \
    '*:image files:_files -g "*.(png|jpg|jpeg|gif|bmp|tiff|tif|webp|svg|ico)(-.)"'
}

_lsix "$@"
