#compdef guile-config
# Documentation: https://docs.oracle.com/cd/E86824_01/html/E54763/guile-config-1.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'link:print libraries to link with'
  'compile:print C compiler flags'
  'info:print Guile build directory variable'
)

_arguments -C \
  '(- *)--version[show installed script and Guile version]' \
  '--help[show usage info]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'guile-config subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (info)
        _values 'variable' 'prefix' 'datadir' 'libdir' 'includedir' 'sysconfdir' 'pkglibdir' 'pkgdatadir' 'pkgincludedir' && ret=0
        ;;
    esac
    ;;
esac

return ret
