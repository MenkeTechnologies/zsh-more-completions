#compdef pcp-summary
# Documentation: https://man7.org/linux/man-pages/man1/pcp.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-\?[show help]' \
  '(- *)--help[show help]' \
  '-V[show version]' \
  '--version[show version]' \
  '-a+[archive source]:archive:_files' \
  '--archive=[archive source]:archive:_files' \
  '-h+[target host]:host:_hosts' \
  '--host=[target host]:host:_hosts' \
  '-n+[alternative Performance Metrics Name Space]:pmnsfile:_files' \
  '--namespace=[alternative Performance Metrics Name Space]:pmnsfile:_files' \
  '-O+[origin time within archive window]:time:' \
  '--origin=[origin time within archive window]:time:' \
  '-L[use local context without PMCD]' \
  '--local-PMDA[use local context without PMCD]' \
  '-P[display pmie performance information]' \
  '--pmie[display pmie performance information]' \
  '-D+[enable diagnostic output]:debug:' \
  '--debug=[enable diagnostic output]:debug:' && ret=0

return ret
