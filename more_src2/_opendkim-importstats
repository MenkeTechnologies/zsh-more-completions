#compdef opendkim-importstats
# Documentation: https://manpages.debian.org/bookworm/opendkim-tools/opendkim-importstats.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm opendkim-importstats(8) manpage.

# opendkim-importstats: import OpenDKIM statistics into SQL database
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-d --dbname)'{-d,--dbname=}'[SQL database name]:name:' \
  '-E[abort on errors instead of continuing]' \
  '-F[write malformed line data to stderr]' \
  '(-h --dbhost)'{-h,--dbhost=}'[SQL host]:host:_hosts' \
  '-m[input is email message; wait for blank line]' \
  '(-P --dbport)'{-P,--dbport=}'[SQL port]:port:' \
  '(-p --dbpasswd)'{-p,--dbpasswd=}'[SQL password]:password:' \
  '-r[do not auto-add unknown reporters]' \
  '-S[do not skip duplicate message records]' \
  '(-s --dbscheme)'{-s,--dbscheme=}'[SQL backend scheme]:scheme:' \
  '(-u --dbuser)'{-u,--dbuser=}'[SQL user]:user:_users' \
  '-v[verbose]' \
  '-x[apply schema extension records]' && ret=0
return ret
