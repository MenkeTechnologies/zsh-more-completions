#compdef nimble
# _nimble-bin — Nim package manager + build runner (Nim community + status.im, Nim); manage Nim projects + deps
# upstream: https://github.com/nim-lang/nimble

_nimble-bin() {
    local -a sub=(
        'add:add dependency'
        'build:build project'
        'c:alias for compile'
        'check:check package validity'
        'clean:clean build outputs'
        'develop:add package as develop dep'
        'dep:print dependency graph'
        'doc:generate docs'
        'dump:dump package metadata'
        'help:show help'
        'init:initialize new project'
        'install:install package'
        'list:list available packages'
        'lock:write nimble lock'
        'manicheck:check broken manifests'
        'manage:manage installed packages'
        'path:print path to package'
        'publish:publish package'
        'pkg:package commands'
        'refresh:refresh package list'
        'remove:remove package'
        'run:run binary'
        'search:search packages'
        'sync:sync deps'
        'task:list tasks'
        'tasks:alias for task'
        'test:run tests'
        'tor:run tor task'
        'uninstall:uninstall package'
        'upgrade:upgrade installed package'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '-y[assume yes]' \
        '--accept[assume yes]' \
        '-n[assume no]' \
        '--reject[assume no]' \
        '--verbose[verbose]' \
        '--silent[silent]' \
        '--noColor[no color]' \
        '--nim+[Nim compiler path]:file:_files' \
        '--noLockFile[no lock file]' \
        '--useSystemNim[use system nim]' \
        '--package-list+[package list file]:file:_files' \
        '--ver[print package version]' \
        '--debug[debug]' \
        '--solver+[solver]:solver:(legacy sat)' \
        '--lockfile[use lock file]' \
        '--developFile+[develop file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nimble subcommand' sub ;;
        args)
            case $words[1] in
                install|uninstall|develop|remove|upgrade) _arguments '*:package:' ;;
                init) _arguments '*:name:' ;;
                build|c|run|test) _arguments '*:args:' ;;
                search) _arguments '*:keyword:' ;;
            esac
            ;;
    esac
}

_nimble-bin "$@"
