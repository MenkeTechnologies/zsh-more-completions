#compdef rpmgrill
# Documentation: https://github.com/default-to-open/rpmgrill/blob/master/bin/rpmgrill
# Reference accessed: 2026-05-21
# Verified: upstream default-to-open/rpmgrill bin/rpmgrill usage().

# rpmgrill: post-build RPM lint / inspection framework
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show usage]' \
  '--version[show version]' \
  '--man[display man page]' \
  '--list-plugins[list available plugins and exit]' \
  '--disable=[disable comma-separated plugins]:plugins:' \
  '(-v --verbose)'{-v,--verbose}'[show verbose progress indicators]' \
  '(-n --dry-run)'{-n,--dry-run}'[make no actual changes]' \
  '--blacklist-config=[YAML config to suppress test failures]:file:_files' \
  '*:base dir:_files -/' && ret=0
return ret
