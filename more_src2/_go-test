#compdef go-test
# _go-test — go test wrapper completion; same flags as `go test` subcommand
# upstream: https://pkg.go.dev/cmd/go

_go-test() {
    _arguments \
        '-args[end of flags, rest passed to test binary]' \
        '-c[compile but do not run]' \
        '-o+[output binary]:file:_files' \
        '-bench+[benchmark regex]:regex:' \
        '-benchmem[print memory allocs]' \
        '-benchtime+[benchmark duration]:duration:' \
        '-blockprofile+[block profile file]:file:_files' \
        '-blockprofilerate+[block profile rate]:n:' \
        '-count+[run count]:n:' \
        '-cover[enable coverage]' \
        '-covermode+[cover mode]:mode:(set count atomic)' \
        '-coverpkg+[cover packages]:pkgs:' \
        '-coverprofile+[cover profile file]:file:_files' \
        '-cpu+[GOMAXPROCS list]:list:' \
        '-cpuprofile+[CPU profile file]:file:_files' \
        '-failfast[stop at first failure]' \
        '-fullpath[print full file paths in errors]' \
        '-fuzz+[fuzz regex]:regex:' \
        '-fuzztime+[fuzz duration]:duration:' \
        '-fuzzminimizetime+[fuzz minimize duration]:duration:' \
        '-list+[list matching tests]:regex:' \
        '-memprofile+[memory profile file]:file:_files' \
        '-memprofilerate+[memory profile rate]:n:' \
        '-mutexprofile+[mutex profile file]:file:_files' \
        '-mutexprofilefraction+[mutex profile fraction]:n:' \
        '-outputdir+[output dir]:dir:_files -/' \
        '-parallel+[parallel test count]:n:' \
        '-race[enable race detector]' \
        '-msan[enable memory sanitizer]' \
        '-asan[enable address sanitizer]' \
        '-run+[run regex]:regex:' \
        '-short[short mode]' \
        '-shuffle+[shuffle order]:value:(on off seed)' \
        '-skip+[skip regex]:regex:' \
        '-timeout+[test timeout]:duration:' \
        '-trace+[trace file]:file:_files' \
        '-v[verbose]' \
        '-vet+[vet]:list:' \
        '*:packages:'
}

_go-test "$@"
