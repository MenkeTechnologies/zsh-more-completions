#compdef longhorn-engine
# _longhorn-engine — Longhorn block-device engine CLI (urfave/cli; replica/controller/sync-agent/snapshot/backup subcommands)
# upstream: https://github.com/longhorn/longhorn-engine
# Subcommands + flags from main.go on tip.

_longhorn-engine() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--debug[enable debug logging]' \
        '--url=[engine controller gRPC URL]:url:_urls' \
        '--volume-name=[volume name (for validation)]:name:' \
        '--engine-instance-name=[engine instance name (for validation)]:name:' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            local -a subs=(
                controller:'start a controller process'
                replica:'start a replica process'
                sync-agent:'start a sync-agent process'
                sync-agent-server-reset:'reset the sync-agent server'
                start-with-replicas:'start a controller with given replicas'
                add-replica:'add a replica to a volume'
                verify-rebuild-replica:'verify replica rebuild integrity'
                ls-replica:'list replicas on a volume'
                rm-replica:'remove a replica from a volume'
                update-replica:'update replica metadata (mode etc.)'
                rebuild-status:'report replica rebuild status'
                snapshot:'manage snapshots'
                snapshot-hash:'compute hash for a snapshot'
                snapshot-hash-cancel:'cancel a snapshot hash computation'
                snapshot-hash-status:'report status of a snapshot hash'
                backup:'create/list/restore backups'
                expand:'expand a volume'
                unmap-mark-snap-chain-removed:'mark snapshot chain as unmapped+removed'
                journal:'control engine journal'
                info:'show engine/volume info'
                frontend:'manage volume frontend (tgt / iSCSI / nbd)'
                system-backup:'manage system backups'
                profiler:'control profiling endpoints'
                version:'print engine version'
            )
            _describe -t commands 'longhorn-engine subcommand' subs
            ;;
    esac
}

_longhorn-engine "$@"
