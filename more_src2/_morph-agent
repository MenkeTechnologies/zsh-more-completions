#compdef morph-agent
# Documentation: https://github.com/morph-l2/morph-CLI
# Reference accessed: 2026-05-22
# Verified: src/index.ts and commands/wallet.ts, chain.ts, eco.ts, agentpay.ts.

# Zsh completion for morph-agent - Morph L2 on-chain operations CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--json[output in JSON format]' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'morph-agent command' \
      'wallet[wallet management]' \
      'onchain[RPC, explorer, alt-fee, and EIP-7702]' \
      'eco[DEX swap and cross-chain bridge]' \
      'agentpay[x402 payments and ERC-8004 identity]' && ret=0
    ;;
  args)
    case $line[1] in
      wallet)
        if (( CURRENT == 3 )); then
          _values 'wallet command' \
            create import list default address remove balance transfer sl sl-list sl-remove && ret=0
        elif [[ $line[2] == balance || $line[2] == transfer ]]; then
          _arguments \
            '(-w --wallet)'{-w,--wallet}'[private-key wallet name]:name:' \
            '--sl[social login wallet name]:name:' \
            '--address[query arbitrary address]:address:' \
            '--token[ERC-20 token symbol or address]:token:' \
            '--dry-run[preview without broadcasting]' && ret=0
        fi
        ;;
      onchain)
        if (( CURRENT == 3 )); then
          _values 'onchain command' rpc explorer altfee 7702 && ret=0
        elif [[ $line[2] == rpc ]]; then
          if (( CURRENT == 4 )); then
            _values 'rpc command' balance nonce gas block call tx && ret=0
          else
            _arguments '--address[wallet address]:address:' '--number[block number]:number:' '--hash[transaction hash]:hash:' '--data[calldata hex]:data:' '--to[contract address]:address:' && ret=0
          fi
        elif [[ $line[2] == explorer ]]; then
          if (( CURRENT == 4 )); then
            _values 'explorer command' address-info txs tokens tx token-search token-info contract && ret=0
          else
            _arguments '--address[wallet or contract address]:address:' '--limit[max results]:count:' '--query[search keyword]:text:' '--token[token contract]:address:' && ret=0
          fi
        elif [[ $line[2] == altfee ]]; then
          if (( CURRENT == 4 )); then
            _values 'altfee command' tokens token-info estimate send && ret=0
          else
            _arguments \
              '--fee-token-id[fee token ID]:id:' \
              '--dry-run[preview transaction]' \
              '(-w --wallet)'{-w,--wallet}'[wallet name]:name:' \
              '--sl[social login wallet]:name:' && ret=0
          fi
        elif [[ $line[2] == 7702 ]]; then
          if (( CURRENT == 4 )); then
            _values '7702 command' delegate authorize send batch revoke && ret=0
          else
            _arguments \
              '-a[address to check]:address:' \
              '--delegate[delegate contract address]:address:' \
              '--dry-run[preview transaction]' \
              '(-w --wallet)'{-w,--wallet}'[wallet name]:name:' \
              '--sl[social login wallet]:name:' && ret=0
          fi
        fi
        ;;
      eco)
        if (( CURRENT == 3 )); then
          _values 'eco command' swap bridge && ret=0
        elif [[ $line[2] == swap ]]; then
          if (( CURRENT == 4 )); then
            _values 'swap command' quote send approve allowance && ret=0
          else
            _arguments \
              '--from[source token]:token:' \
              '--to[destination token]:token:' \
              '--amount[amount to swap]:amount:' \
              '--slippage[slippage percent]:percent:' \
              '--recipient[recipient for calldata]:address:' \
              '--dry-run[preview without sending]' && ret=0
          fi
        elif [[ $line[2] == bridge ]]; then
          if (( CURRENT == 4 )); then
            _values 'bridge command' chains tokens token-search quote balance login make-order submit-order swap order history && ret=0
          else
            _arguments \
              '--from-chain[source chain]:chain:(morph eth base bnb arbitrum matic)' \
              '--to-chain[destination chain]:chain:(morph eth base bnb arbitrum matic)' \
              '--jwt[JWT from bridge login]:jwt:' && ret=0
          fi
        fi
        ;;
      agentpay)
        if (( CURRENT == 3 )); then
          _values 'agentpay command' x402 identity && ret=0
        elif [[ $line[2] == x402 ]]; then
          if (( CURRENT == 4 )); then
            _values 'x402 command' supported discover pay config verify settle register server && ret=0
          else
            _arguments '--url[target URL]:url:' '--max-payment[max USDC payment]:amount:' '--dry-run[preview payment]' && ret=0
          fi
        elif [[ $line[2] == identity ]]; then
          if (( CURRENT == 4 )); then
            _values 'identity command' registry info balance metadata reputation register total set-metadata set-uri set-wallet unset-wallet feedback read-feedback reviews revoke-feedback append-response && ret=0
          else
            _arguments '--agent-id[agent ID]:id:' '--dry-run[preview transaction]' && ret=0
          fi
        fi
        ;;
    esac
    ;;
esac

return ret
