#compdef keditbookmarks
# Documentation: https://manpages.debian.org/testing/keditbookmarks/keditbookmarks.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# keditbookmarks: bookmark organizer and editor. Corrected from prior
# file: added documented import/export options and application options
# (--address, --customcaption, --nobrowser, --dbusObjectName); removed
# invented --graphicssystem/--platform/--platformpluginpath (not in the
# documented option set).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)--help-all[show all options inc Qt/KF]' \
  '(- *)--help-qt[show Qt-specific options]' \
  '(- *)--help-kde[show KDE-specific options]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '(- *)--author[show author info]' \
  '(- *)--license[show license info]' \
  '--importmoz=[import Mozilla format bookmarks]:file:_files' \
  '--importns=[import Netscape 4.x format bookmarks]:file:_files' \
  '--importie=[import Internet Explorer Favorites]:file:_files' \
  '--importopera=[import Opera format bookmarks]:file:_files' \
  '--exportmoz=[export to Mozilla format]:file:_files' \
  '--exportns=[export to Netscape format]:file:_files' \
  '--exporthtml=[export to printable HTML format]:file:_files' \
  '--exportie=[export to Internet Explorer Favorites]:file:_files' \
  '--exportopera=[export to Opera format]:file:_files' \
  '--address=[open at specified position in bookmarks file]:address:' \
  '--customcaption=[set user-readable caption]:caption:' \
  '--nobrowser[hide browser-related functions]' \
  '--dbusObjectName=[set unique DBus object name]:name:' \
  '--caption=[set application caption]:caption:' \
  '--icon=[set application icon]:icon:' \
  '--style=[GUI style]:style:' \
  '--stylesheet=[Qt stylesheet]:file:_files' \
  '--display=[X display]:display:' \
  '--reverse[reverse layout direction]' \
  '*:file:_files -g "*.xbel"' && ret=0
return ret
