#compdef lark
# Documentation: https://github.com/larksuite/cli
# Source: larksuite/cli cmd/ — Lark/Feishu official CLI (Go, spf13/cobra).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _lark_cmds
_lark_cmds=(
    'api:call Lark/Feishu Open Platform APIs directly'
    'auth:manage authentication credentials'
    'config:manage CLI configuration'
    'doctor:diagnose the environment'
    'event:handle event subscriptions'
    'profile:manage profiles'
    'schema:work with API schemas'
    'service:interact with business services (Messenger/Docs/Base/Sheets/Calendar/Mail/Tasks/Meetings)'
    'skill:manage AI agent skills'
    'update:update the CLI'
    'completion:generate shell completion script'
)

_arguments -C \
    '(--profile)--profile=[profile to use]:profile:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'lark command' _lark_cmds && ret=0
        ;;
esac

return ret
