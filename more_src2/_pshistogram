#compdef pshistogram
# Documentation: https://docs.generic-mapping-tools.org/latest/histogram.html
# Source: GenericMappingTools/gmt classic-mode pshistogram — plot histograms of 1-D data.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-T+[bin boundaries (min/max/inc or file/list)]:opts:_default' \
    '-J+[projection (typically -Jx linear)]:proj:_default' \
    '-A[plot horizontally (not vertical)]' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[CPT for bars]:cpt:_files -g "*.cpt(-.)"' \
    '-D+[annotate each bar with count]:opts:_default' \
    '-E+[bar width / shift bins]:opts:_default' \
    '-F[center bins on nodes (not left edge)]' \
    '-G+[bar fill color]:fill:_default' \
    '-I[query min/max after binning]' \
    '-L+[include out-of-range in first/last bins]:opts:_default' \
    '-N+[overlay normal distribution curve]:opts:_default' \
    '-Q+[cumulative or reverse-cumulative]:opts:_default' \
    '-R+[data domain bounds]:region:_default' \
    '-S[stairs-step diagram (no internal bars)]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[bar outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z+[histogram type]:type:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '-p+[perspective view]:perspective:_default' \
    '*:input table:_files' \
    && ret=0

return ret
