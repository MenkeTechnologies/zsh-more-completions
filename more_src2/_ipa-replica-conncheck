#compdef ipa-replica-conncheck
# Documentation: https://www.mankier.com/1/ipa-replica-conncheck
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '(-h --hostname)'{-h,--hostname=}'[FQDN of this server]:host:_hosts' \
  '(-R --replica)'{-R,--replica=}'[remote replica machine address]:host:_hosts' \
  '(-m --master)'{-m,--master=}'[remote master machine address]:host:_hosts' \
  '(-a --auto-master-check)'{-a,--auto-master-check}'[automatically log in to master and run master part]' \
  '(-r --realm)'{-r,--realm=}'[Kerberos realm]:realm:' \
  '(-k --kdc)'{-k,--kdc=}'[KDC server address]:host:_hosts' \
  '(-p --principal)'{-p,--principal=}'[Kerberos principal]:principal:' \
  '(-w --password)'{-w,--password=}'[password for the principal]:pw:' \
  '(-c --check-ca)'{-c,--check-ca}'[also check dogtag CA requirements]' \
  '(--port)--port=[port]:port:' && ret=0

return ret
