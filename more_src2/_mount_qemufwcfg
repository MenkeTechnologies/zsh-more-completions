#compdef mount_qemufwcfg
# Documentation: man mount_qemufwcfg(8)
# Source: netbsd/src sbin/mount_qemufwcfg — mount QEMU fw_cfg files (C, FUSE).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-F+[device path (default /dev/qemufwcfg)]:device:_files' \
    '-g+[group ownership of files]:gid:_default' \
    '-M+[directory permissions (default 0555)]:dir-mode:_default' \
    '-m+[file permissions (default 0444)]:file-mode:_default' \
    '-u+[user ownership of files]:uid:_default' \
    '1:mount point:_files -/' \
    && ret=0

return ret
