#compdef gnt-storage
# _gnt-storage — Google Ganeti gnt-storage CLI for managing Ganeti cluster storage units lvm-vg lvm-pv file blockdev rbd ext on-node listing modification storage repair across nodes (ganeti team, Python); custom argparse
# upstream: https://github.com/ganeti/ganeti

_gnt-storage() {
    local -a sub=(
        'info:show storage info'
        'list:list storage units'
        'modify:modify storage'
        'repair:repair storage'
        'diagnose-disk:diagnose disk'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '--cluster=+[name]:str:' \
        '--no-headers[no headers]' \
        '--separator=+[char]:str:' \
        '-o+[output fields]:str:' \
        '--output=+[output fields]:str:' \
        '--storage-type=+[t]:t:(lvm-vg lvm-pv file sharedfile rbd ext blockdev)' \
        '-t+[t]:t:(lvm-vg lvm-pv file sharedfile rbd ext blockdev)' \
        '--allocatable=+[b]:b:(yes no)' \
        '--reason=+[text]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gnt-storage subcommand' sub ;;
        args)
            case $words[1] in
                modify|repair|diagnose-disk) _arguments \
                    '*:node:name:' ;;
                list|info) _arguments \
                    '--nodes=+[csv]:str:' \
                    '*:storage type:(lvm-vg lvm-pv file sharedfile rbd ext blockdev)' ;;
            esac
            ;;
    esac
}

_gnt-storage "$@"
