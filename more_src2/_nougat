#compdef nougat nougat_api
# Documentation: https://github.com/facebookresearch/nougat
# Reference accessed: 2026-05-27
# Verified: upstream setup.py entry_points (console_scripts: nougat = predict:main,
# nougat_api = app:main) and predict.py argparse definition.
# Deviations from spec: dropped --nougat-extract and --nougat-train binaries
# (do not exist in console_scripts); added --pages/-p, --no-markdown,
# --no-skipping, plus short aliases for batchsize/checkpoint/model/out which
# the real argparse exposes.

local curcontext="$curcontext" state line ret=1

case $service in
  nougat)
    _arguments -s -S \
      '(-b --batchsize)'{-b+,--batchsize=}'[batch size]:n:' \
      '(-c --checkpoint)'{-c+,--checkpoint=}'[path to checkpoint directory]:dir:_files -/' \
      '(-m --model)'{-m+,--model=}'[model tag to use]:tag:' \
      '(-o --out)'{-o+,--out=}'[output directory]:dir:_files -/' \
      '--recompute[recompute already computed PDF, discarding previous predictions]' \
      '--full-precision[use float32 instead of bfloat16]' \
      '(--no-markdown)--markdown[add markdown-compat postprocessing (default)]' \
      '(--markdown)--no-markdown[disable markdown-compat postprocessing]' \
      '--no-skipping[do not apply failure detection heuristic]' \
      '(-p --pages)'{-p+,--pages=}[page numbers like 1-4,7]':pages:' \
      '(- *)'{-h,--help}'[show help message and exit]' \
      '*:pdf:_files -g "*.pdf"' && ret=0
    ;;
  nougat_api)
    # FastAPI app: nougat_api = app:main. No documented CLI flags beyond
    # uvicorn passthrough; provide file completion fallback.
    _arguments -s -S \
      '(- *)'{-h,--help}'[show help message and exit]' \
      '*:file:_files' && ret=0
    ;;
  *)
    _arguments -s -S '*:file:_files' && ret=0
    ;;
esac

return ret
