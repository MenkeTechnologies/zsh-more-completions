#compdef irmin
# Documentation: https://github.com/mirage/irmin/blob/main/src/irmin-cli/cli.ml
# Reference accessed: 2026-05-27
# Verified: upstream src/irmin-cli/cli.ml and resolver.ml (mirage/irmin)

# Zsh completion for irmin (distributed database CLI)

local curcontext="$curcontext" state line ret=1

local -a _irmin_subcommands
_irmin_subcommands=(
  'help:display help about Irmin and Irmin commands'
  'init:initialize a store'
  'get:read the value associated with a key'
  'set:update the value associated with a key'
  'remove:delete a key'
  'list:list subdirectories'
  'tree:list the store contents'
  'clone:copy a remote repository to a local store'
  'fetch:download objects and refs from another repository'
  'merge:merge branches'
  'pull:fetch and merge with another repository'
  'push:update remote references along with associated objects'
  'snapshot:return a snapshot for the current state of the database'
  'revert:revert the contents of the store to a previous state'
  'watch:get notifications when values change'
  'dot:dump the contents of the store as a Graphviz file'
  'graphql:run a graphql server'
  'server:run irmin-server'
  'options:get information about backend specific configuration options'
  'branches:list branches'
  'log:list commits'
)

# Common options shared across commands (from cli.ml/resolver.ml)
local -a _irmin_common
_irmin_common=(
  '(-s --store)'{-s+,--store=}'[storage backend]:store:(git git-mem fs mem pack tezos)'
  '(-h --hash)'{-h+,--hash=}'[hash function]:hash:(blake2b blake2s rmd160 sha1 sha224 sha256 sha384 sha512 tezos)'
  '(-c --contents)'{-c+,--contents=}'[user-defined contents type]:contents:(string json json-value)'
  '--root=[location of the Irmin store on disk]:dir:_files -/'
  '--config=[configuration file path]:file:_files'
  '*--opt=[backend-specific option (key=value)]:option:'
  '*--options=[backend-specific options]:option:'
  '--branch=[current branch name]:branch:'
  '--bare[bare git repository]'
  '--head=[reference (commit hash) to use as HEAD]:commit:'
  '-H+[extra HTTP headers to use when sync]:header:'
  '--verbosity=[log verbosity level]:level:(app error warning info debug)'
  '(-q --quiet)'{-q,--quiet}'[be quiet (logs at error level)]'
  '(-v --verbose)'{-v,--verbose}'[increase verbosity (logs at info level)]'
  '--color=[colorize the output]:when:(auto always never)'
  '--help[show help]'
  '--version[print version]'
)

_arguments -C \
  $_irmin_common \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'irmin subcommand' _irmin_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      get|list|tree|init|snapshot|branches|options)
        _arguments \
          $_irmin_common \
          '1:path:' && ret=0
        ;;
      set)
        _arguments \
          $_irmin_common \
          '--author=[commit author name]:name:' \
          '--message=[commit message]:msg:' \
          '1:path:' \
          '2:value:' && ret=0
        ;;
      remove)
        _arguments \
          $_irmin_common \
          '--author=[commit author name]:name:' \
          '--message=[commit message]:msg:' \
          '1:path:' && ret=0
        ;;
      clone)
        _arguments \
          $_irmin_common \
          '(-d --depth)'{-d+,--depth=}'[limit the history depth]:depth:' \
          '1:remote:' && ret=0
        ;;
      fetch|push)
        _arguments \
          $_irmin_common \
          '1:remote:' && ret=0
        ;;
      merge)
        _arguments \
          $_irmin_common \
          '--author=[commit author name]:name:' \
          '--message=[commit message]:msg:' \
          '1:branch:' && ret=0
        ;;
      pull)
        _arguments \
          $_irmin_common \
          '--author=[commit author name]:name:' \
          '--message=[commit message]:msg:' \
          '1:remote:' && ret=0
        ;;
      revert)
        _arguments \
          $_irmin_common \
          '1:snapshot:' && ret=0
        ;;
      watch)
        _arguments \
          $_irmin_common \
          '1:path:' \
          '*:command:_command_names -e' && ret=0
        ;;
      dot)
        _arguments \
          $_irmin_common \
          '(-d --depth)'{-d+,--depth=}'[limit the history depth]:depth:' \
          '--no-dot-call[do not call the dot utility]' \
          '--full[show the full graph including filesystem nodes and blobs]' \
          '1:basename:' && ret=0
        ;;
      graphql)
        _arguments \
          $_irmin_common \
          '(-p --port)'{-p+,--port=}'[port for graphql server]:port:' \
          '(-a --address)'{-a+,--address=}'[address for graphql server]:addr:' && ret=0
        ;;
      log)
        _arguments \
          $_irmin_common \
          '--plain[show plain text without pager]' \
          '--pager=[pager program to use]:cmd:_command_names -e' \
          '(-n --max-count)'{-n+,--max-count=}'[number of entries to show]:n:' \
          '--skip=[number of entries to skip]:n:' \
          '--reverse[print in reverse order]' && ret=0
        ;;
      server)
        _arguments \
          $_irmin_common \
          '(-p --port)'{-p+,--port=}'[port for the server]:port:' \
          '(-a --address)'{-a+,--address=}'[server address]:addr:' \
          '--uri=[URI to bind]:uri:' && ret=0
        ;;
      help)
        _arguments \
          '1:topic:(topics irmin.yml init get set remove list tree clone fetch merge pull push snapshot revert watch dot graphql server options branches log)' && ret=0
        ;;
      *)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
