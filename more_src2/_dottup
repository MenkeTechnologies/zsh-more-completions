#compdef dottup
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/dottup.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# EMBOSS dottup: word-match dot plot of two sequences (tuple match)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-asequence=[first sequence]:sequence USA:_files' \
  '-bsequence=[second sequence]:sequence USA:_files' \
  '-wordsize=[word size]:size:' \
  '-stretch[stretch to fit]' \
  '-boxit[draw a box around the plot]' \
  '-graph=[graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '-xygraph=[XY graph format]:format:(x11 png ps cps colourps eps gif pdf hp7470 hp7580 meta data)' \
  '*:sequence USA:_files' && ret=0
return ret
