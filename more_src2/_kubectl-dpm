#compdef kubectl-dpm
# Documentation: https://github.com/bavarianbidi/kubectl-dpm
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --config)'{-c+,--config=}'[path to the dpm config file]:file:_files' \
  '--kubeconfig=[path to kubeconfig file]:file:_files' \
  '--context=[kubeconfig context to use]:context:' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    _describe -t commands 'kubectl-dpm command' \
      'run:run a debug session using a configured profile' && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments -s -S \
          '(-p --profile)'{-p+,--profile=}'[debug profile to use]:profile:' \
          '(-i --image)'{-i+,--image=}'[debug container image]:image:' \
          '(-n --namespace)'{-n+,--namespace=}'[pod namespace]:namespace:' \
          '--context=[kubeconfig context to use]:context:' \
          '--kubeconfig=[path to kubeconfig file]:file:_files' \
          '*:pod:_default' && ret=0
        ;;
    esac
    ;;
esac

return ret
