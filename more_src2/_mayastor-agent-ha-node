#compdef mayastor-agent-ha-node agent-ha-node
# _mayastor-agent-ha-node — Mayastor per-node HA agent (detects NVMe path failures via udev and switches the kernel initiator to a healthy nexus replica)
# upstream: https://github.com/openebs/mayastor-control-plane
# Flags from control-plane/agents/src/bin/ha/node/main.rs Cli on tip (clap).

_mayastor-agent-ha-node() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-c --cluster-agent)'{-c,--cluster-agent}'=[HA cluster-agent URL]:url:_urls' \
        '(-n --node-name)'{-n,--node-name}'=[Kubernetes node name (must match csi-node)]:name:' \
        '(-g --grpc-endpoint)'{-g,--grpc-endpoint}'=[DEPRECATED: gRPC bind address]:addr:' \
        '--grpc-ip=[gRPC server bind IP]:ip:' \
        '--grpc-port=[gRPC server bind port]:port:' \
        '--fake-grpc-endpoint=[report this endpoint upstream]:addr:' \
        '*'{-t,--tracing-tags}'=[csv key=value tags for tracing (TRACING_TAGS)]:csv:' \
        '(-d --detection-period)'{-d,--detection-period}'=[path-failure detection period (DETECTION_PERIOD)]:duration:' \
        '(-r --retransmission-period)'{-r,--retransmission-period}'=[retransmission period (RETRANSMISSION_PERIOD)]:duration:' \
        '(-a --aggregation-period)'{-a,--aggregation-period}'=[failed-path aggregation period (AGGREGATION_PERIOD)]:duration:' \
        '(-p --path-connection-timeout)'{-p,--path-connection-timeout}'=[connection timeout for path replacement (PATH_CONNECTION_TIMEOUT)]:duration:' \
        '(-s --subsys-refresh-period)'{-s,--subsys-refresh-period}'=[NVMe subsystem refresh period (SUBSYS_REFRESH_PERIOD)]:duration:' \
        '--udev-monitor=[udev monitor source]:source:(udev kernel)' \
        '(-j --jaeger)'{-j,--jaeger}'=[Jaeger collector endpoint]:url:_urls' \
        '--csi-socket=[csi-node UDS socket for gRPC over UDS]:socket:_files' \
        '(-e --events-url)'{-e,--events-url}'=[NATS JetStream events URL]:url:_urls' \
        '--events-replicas=[JetStream replication factor for events]:n:' \
        '(-f --fmt-style)'{-f,--fmt-style}'=[log format style]:style:(default compact pretty json)' \
        '--ansi-colors=[enable ANSI colours]:bool:(true false)'
}

_mayastor-agent-ha-node "$@"
