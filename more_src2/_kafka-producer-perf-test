#compdef kafka-producer-perf-test
# Documentation: https://kafka.apache.org/documentation/ (kafka-producer-perf-test.sh --help, Kafka 4.2.0)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
    '(- *)'{-h,--help}'[Show this help message and exit]'
    '--bootstrap-server[The server(s) to connect to]:host\:port:'
    '--topic[Produce records to this topic]:topic:'
    '--num-records[Number of records to produce]:count:'
    '--throughput[Throttle maximum record throughput (-1 to disable)]:throughput:'
    '--payload-delimiter[Delimiter used when --payload-file is provided]:delimiter:'
    '--producer-props[(DEPRECATED) Kafka producer config properties (key=value)]:properties:'
    '--command-property[Kafka producer config properties (key=value)]:properties:'
    '--producer.config[(DEPRECATED) Producer config properties file]:file:_files'
    '--command-config[Producer config properties file]:file:_files'
    '--print-metrics[Print out metrics at the end of the test]'
    '--transactional-id[The transactional id to use]:id:'
    '--transaction-duration-ms[The maximum duration of each transaction in ms]:ms:'
    '--warmup-records[Number of records to treat as warmup]:count:'
    '--reporting-interval[Interval in ms at which to print progress info]:ms:'
    '--record-size[Record size in bytes]:bytes:'
    '--payload-file[File to read the record payloads from]:file:_files'
    '--payload-monotonic[Payload is a monotonically increasing integer]'
)

_arguments -s -S $arguments
