#compdef foremost
# _foremost-bin — Foremost file carver (US AFOSI); recover files based on headers, footers, internal data structures
# upstream: https://github.com/sergev/foremost

_foremost-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-d[detect indirect blocks (UFS)]' \
        '-i+[input image]:file:_files' \
        '-o+[output dir]:dir:_files -/' \
        '-c+[config file]:file:_files' \
        '-T[add date timestamp to output dir]' \
        '-q[quick]' \
        '-Q[suppress error msgs]' \
        '-v[verbose]' \
        '-w[only write audit file]' \
        '-a[write all headers without verification]' \
        '-k+[chunk size MiB]:n:' \
        '-b+[block size]:n:' \
        '-t+[types comma list]:types:(jpg gif png bmp avi exe mpg wav riff wmv mov pdf ole doc zip rar htm cpp all)' \
        '-s+[skip bytes]:n:' \
        '*:image:_files'
}

_foremost-bin "$@"
