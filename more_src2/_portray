#compdef portray
# Documentation: https://timothycrosley.github.io/portray/
# Reference accessed: 2026-06-04

# Zsh completion for portray (Python documentation tool)
local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help message and exit]' \
  '(- *)--version[show version and exit]' \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'in_browser:open documentation in the default browser'
      'server:start a local documentation server'
      'as_html:render documentation as static HTML'
      'on_github_pages:deploy documentation to GitHub Pages'
      'project_configuration:output the project configuration'
    )
    _describe -t commands 'portray command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      in_browser)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help message]' \
          '--port=[port to serve on]:port number:' \
          '--host=[host to serve on]:host:' \
          '(-d --directory)'{-d,--directory}'[root directory of the project]:directory:_directories' \
          '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
          '*'{-m,--module}'[Python module to document]:module name:' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory for documentation]:directory:_directories' && ret=0
        ;;
      server)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help message]' \
          '--port=[port to serve on]:port number:' \
          '--host=[host to serve on]:host:' \
          '(-d --directory)'{-d,--directory}'[root directory of the project]:directory:_directories' \
          '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
          '*'{-m,--module}'[Python module to document]:module name:' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory for documentation]:directory:_directories' \
          '--open[open in browser after starting]' \
          '--no-open[do not open in browser after starting]' && ret=0
        ;;
      as_html)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help message]' \
          '(-d --directory)'{-d,--directory}'[root directory of the project]:directory:_directories' \
          '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
          '*'{-m,--module}'[Python module to document]:module name:' \
          '(-o --output-dir)'{-o,--output-dir}'[output directory for documentation]:directory:_directories' \
          '--overwrite[overwrite existing output directory]' && ret=0
        ;;
      on_github_pages)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help message]' \
          '(-d --directory)'{-d,--directory}'[root directory of the project]:directory:_directories' \
          '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
          '*'{-m,--module}'[Python module to document]:module name:' \
          '(-msg --message)'{-msg,--message}'[commit message for GitHub Pages]:message:' && ret=0
        ;;
      project_configuration)
        _arguments -s -S \
          '(- *)'{-h,--help}'[show help message]' \
          '(-d --directory)'{-d,--directory}'[root directory of the project]:directory:_directories' \
          '(-c --config)'{-c,--config}'[path to configuration file]:config file:_files' \
          '*'{-m,--module}'[Python module to document]:module name:' && ret=0
        ;;
    esac
    ;;
esac

return ret
