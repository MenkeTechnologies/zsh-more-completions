#  Web-scale MongoDB GUI: connects to MongoDB clusters and exposes
#  collections via a browser-based UI (Express server on port 3100 by
#  default).  Sister tools: mongo-express (in corpus), nosqlclient,
#  Studio 3T, MongoDB Compass.
#
#  CLI library taxonomy update: 3rd documented TypeScript/Node CLI
#  library — TJ Holowaychuk's commander.js.  Node ecosystem now has 3
#  documented libraries (R340 oclif + R341 yargs + R343 commander.js)
#  joining the multi-library leaders.  commander.js is the OG Node CLI
#  library — the model from which `Click` (Python) and many others draw
#  inspiration.
#
#  commander.js API differs from yargs (R341) and oclif (R340):
#    const program = new Command();           // explicit instance
#    program.name(...).description(...).version(...);  // chained metadata
#    program.command("verb")                  // subcommand registration
#      .description(...)
#      .option("--flag", "desc")             // boolean flag
#      .option("-p, --port <port>", "desc", "default")  // value flag
#      .allowExcessArguments(false)          // strict mode
#      .action(handler);
#    program.option(...) for ROOT default-action options
#    program.parse(process.argv);            // EXPLICIT FINAL PARSE
#  Note: yargs terminates parse via `.argv` accessor; oclif via
#  `await this.parse(Class)` in command class; commander.js requires
#  EXPLICIT `program.parse(process.argv)` call.
#  Brings cross-language CLI library taxonomy variant count to 82.
#
#  Surface (verbatim from cli.ts):
#  Commands:
#    start                       Start the Mongoku server (DEFAULT action)
#    stop                        Stop the Mongoku server running with PM2
#    help                        Show help
#
#  Start command flags (also work as default-action root flags):
#    --pm2                       Run with PM2 (process manager)
#    -p, --port <port>           Port to run on (default: 3100;
#                                env: MONGOKU_SERVER_PORT)
#    --readonly                  Enable read-only mode (no modifications)
#
#  Standard commander.js auto-added flags:
#    -h, --help                  Show help
#    -V, --version               Show version
#
#  Env variables consulted (per cli.ts startAction):
#    MONGOKU_SERVER_PORT          Default port (3100)
#    MONGOKU_SERVER_ORIGIN        Server origin URL
#    MONGOKU_SERVER_BODY_SIZE_LIMIT   Body size limit (default Infinity)
#    MONGOKU_READ_ONLY_MODE       Read-only toggle
#
#  Dup-skipped neighbors during hunt (smaller surface or different lib):
#    - create-web3-dapp (alchemyplatform 915 stars — narrow scaffold)
#    - donkey (batiste/donkey 8 stars — API gateway, narrow)
# ============================================================================

_mongoku() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '--pm2[run with PM2 process manager]' \
    '(-p --port)'{-p,--port}'=[port to run on (default 3100)]:port' \
    '--readonly[enable read-only mode]' \
    '1: :->cmd'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'start:start the Mongoku server'
        'stop:stop the Mongoku server (PM2-managed)'
        'help:show help'
      )
      _describe -t commands 'mongoku command' verbs
      ;;
  esac
}

_mongoku "$@"
