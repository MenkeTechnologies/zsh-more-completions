#compdef git-kommit kommit
# Documentation: https://raw.githubusercontent.com/vigo/kommit/main/README.md
# Reference accessed: 2026-05-19
# Verified: upstream vigo/kommit README usage line. The binary is
# git-kommit (invoked as `git kommit`); it stores extra commit message
# text appended via a prepare-commit-msg hook.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)-h[print usage message]' \
  '-m+[append message]:message:' \
  '-t+[append message with timestamp]:message:' \
  '-c[check if hook is installed]' \
  '-e[edit messages]' \
  '-s[show current message(s)]' \
  '-i[install kommit hook to .git/hooks/prepare-commit-msg]' \
  '-r[remove kommit hook]' \
  '-b[print bash completion snippet]' && ret=0

return ret
