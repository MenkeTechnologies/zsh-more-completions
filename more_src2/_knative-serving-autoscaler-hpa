#compdef knative-serving-autoscaler-hpa
# _knative-serving-autoscaler-hpa — Knative Serving HPA-class PodAutoscaler reconciler (sharedmain)
# upstream: https://github.com/knative/serving
# Flags from cmd/autoscaler-hpa/main.go + knative.dev/pkg sharedmain on tip.

_knative-serving-autoscaler-hpa() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--disable-controllers=[csv of disabled controllers]:csv:' \
        '--disable-ha=[disable high-availability mode]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_knative-serving-autoscaler-hpa "$@"
