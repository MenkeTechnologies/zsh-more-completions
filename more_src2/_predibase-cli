#compdef predibase-cli
# Documentation: https://github.com/predibase/predibase
# Reference accessed: 2026-05-23
# Verified: predibase/cli.py Typer app (predibase PyPI, console script pbase).

# Zsh completion for predibase-cli - Predibase ML platform CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'predibase command' \
      'create[create Predibase resources]' \
      'deploy[deploy Predibase resources]' \
      'delete[delete Predibase resources]' \
      'list[list Predibase resources]' \
      'prompt[prompt Predibase models]' \
      'settings[configure Predibase settings]' \
      'upload[upload to Predibase]' \
      'finetune[finetune a model]' \
      'download[download an artifact]' \
      'version[show Predibase SDK version]' \
      'login[login with API token]' \
      'init-profile[initialize default profile]' \
      'train[train model from Ludwig config]' \
      'predict[predict using trained model]' \
      'tensorboard[launch TensorBoard for model]' && ret=0
    ;;
  args)
    case $line[1] in
      login)
        _arguments \
          '(-t --token)'{-t+,--token=}'[API token]:token:' && ret=0
        ;;
      init-profile)
        _arguments \
          '(-r --repository-name)'{-r+,--repository-name=}'[model repository name]:repo:' \
          '(-e --engine-name)'{-e+,--engine-name=}'[engine name]:engine:' && ret=0
        ;;
      train)
        _arguments \
          'config[Ludwig config file]:file:_files' \
          'dataset[dataset path]:file:_files' \
          'repo[model repository]:repo:' \
          'engine[engine name]:engine:' \
          '(-m --message)'{-m+,--message=}'[commit message]:message:' \
          '--watch[watch training progress]' && ret=0
        ;;
      predict)
        _arguments \
          '(-m --model-name)'{-m+,--model-name=}'[model name]:model:' \
          '--target[prediction target column]:column:' \
          '--input-csv[CSV file to predict on]:file:_files' \
          '(-e --engine)'{-e+,--engine=}'[engine name]:engine:' && ret=0
        ;;
      tensorboard)
        _arguments \
          '(-m --model-id)'{-m+,--model-id=}'[model ID]:id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
