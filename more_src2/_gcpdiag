#compdef gcpdiag
# Documentation: https://gcpdiag.dev/docs/usage/
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a verbs

verbs=(
  'lint:run diagnostics in GCP projects'
  'runbook:run automated diagnostic steps'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--project=[GCP project ID]:project:' \
  '--name=[filter specific resource names]:name:' \
  '--location=[scope to GCP regions/zones]:location:' \
  '--label=[filter by resource labels]:label:' \
  '--billing-project=[billing project]:project:' \
  '--auth-adc[use application default credentials]' \
  '--auth-key=[authenticate via service account key file]:file:_files' \
  '--include=[include rule patterns]:pattern:' \
  '--exclude=[exclude rule patterns]:pattern:' \
  '--include-extended[include additional extended rules]' \
  '--show-skipped[display skipped rules]' \
  '--hide-ok[conceal passing rules]' \
  '--output=[output format]:format:(terminal json csv)' \
  '--config=[load YAML configuration]:file:_files' \
  '--within-days=[lookback period in days]:days:' \
  '--logging-ratelimit-requests=[rate limit for queries]:n:' \
  '--logging-page-size=[page size]:n:' \
  '--logging-fetch-max-entries=[max entries to fetch]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '1: :->verb' \
  '*::args:->args' && ret=0

case $state in
  (verb)
    _describe -t verbs 'gcpdiag verb' verbs && ret=0
    ;;
esac

return ret
