#compdef leetcode
# Documentation: https://github.com/skygragon/leetcode-cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# https://formulae.brew.sh/formula/leetcode-cli — LeetCode CLI client (skygragon)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'help:display help'
  'user:manage account login'
  'list:browse available questions'
  'show:show a question and generate code'
  'test:run local tests'
  'submit:submit a solution'
  'stat:show coding progress'
  'submission:download previous submissions'
  'cache:manage local cache'
  'plugin:plugin manager'
  'config:manage configuration'
  'session:manage sessions'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:_default' && ret=0

case $state in
  cmd) _describe -t commands 'leetcode command' commands && ret=0 ;;
esac

return ret
