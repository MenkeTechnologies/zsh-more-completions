#compdef pm-is-supported
# Documentation: man pm-is-supported(1)
# Source: openSUSE/pm-utils src/pm-is-supported.in (master) — check what suspend modes are supported (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:check:(--suspend --hibernate --suspend-hybrid)' \
    && ret=0

return ret
