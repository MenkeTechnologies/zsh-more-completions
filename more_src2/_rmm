#compdef rmm
# Documentation: man rmm(1)
# Source: nmh uip/rmm.c (master) — remove (rename) nmh messages (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-unlink -nounlink)-unlink[delete files instead of renaming]' \
    '(-unlink -nounlink)-nounlink[rename (default)]' \
    '-rmmproc+[external remove program]:cmd:_command_names -e' \
    '-normmproc[no external remove program]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
