_karakeep-sync() {
    # karakeep-sync runs as a stdio-based
    # scheduler with no command-line flags
    # (configured entirely via env vars)
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_karakeep-sync "$@"
