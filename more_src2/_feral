#compdef feral
# ============================================================================
# _feral — zsh completion for the Feral programming language reference
#           implementation — a dynamically-typed minimalist interpreted
#           language where "imports, structs, enums, and functions are
#           variables" (167th programming language entry, R940 round-
#           number commit landmark)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/Feral-Lang/Feral
#   Maintainer : Feral-Lang (Electrux et al.)
#   License    : MIT
#   Stars      : 147
#   Language   : C++ (CMake; cxx_std_20)
#   Project    : Feral 2.0.1
#   Binary     : feral  (CMakeLists.txt
#                `add_executable(feral src/Main.cpp)`)
#   Source ext : .fer  (cached bytecode resides under
#                `<lib>/bin/<srcFile>.fer`)
#   Last push  : 2026-05-31
#
# WHAT IT IS
#   Feral is "a dynamically typed, imperative, interpreted language
#   which revolves (to most extent) around the idea of minimalism"
#   — the language syntax intentionally omits imports, structs,
#   and enums and instead exposes those as first-class library
#   constructs.  Every `let x = import('std/io')`, every
#   `struct(member = 5)`, every enum, and every function is a
#   regular value that can be passed, copied, and mutated.  The
#   reference implementation is a tree-walking VM written in C++
#   that runs Feral source files (`.fer`), caches bytecode for
#   reuse, and exposes a stage-by-stage debug pipeline
#   (`--tokens`, `--parse`, `--optparse`, `--ir`, `--dry`) for
#   compiler internals work.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/Main.cpp `args::ArgParser`
#                       calls — Feral uses an in-tree minimal arg
#                       parser, not a third-party library)
#   feral [OPTIONS] <SOURCE.fer>
#
#   Options:
#     -v, --version                  Prints program version
#     -t, --tokens                   Show lexical tokens
#     -p, --parse                    Show parser AST
#     -P, --optparse                 Show optimized AST (AST
#                                    after passes)
#     -i, --ir                       Show codegen IR
#     -n, --nobc                     Disable cached bytecode files
#     -d, --dry                      Dry run — generate IR but
#                                    don't run the VM
#     -e, --logerr                   Show logs on stderr
#     -V, --verbose                  Verbose compiler output
#                                    (LogLevels::INFO)
#     -D, --debug                    Debug compiler output
#                                    (LogLevels::DEBUG)
#     -T, --trace                    Trace compiler output
#                                    (LogLevels::TRACE)
#     -h, --help                     Show help
#
#   Positional:
#     <source>                       Source file to compile/run
#                                    (`.fer`).  If not found in
#                                    cwd, the binary searches
#                                    `<lib>/bin/<source>.fer` in
#                                    the configured Feral lib
#                                    path.
#
# LANGUAGE-CORPUS POSITION
#   Feral is the 167th programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R937 (_mevlog / pawurb Rust=142 OPENS Axis 87 Ethereum /
#   alloy-rs Library) and continued through R938 (_tenderly /
#   Tenderly Go=142) and R939 (_tx2uml / naddison36 TS-Node=142
#   CLOSES Axis 87 at 1/1/1 three-language symmetry — triple-142
#   landmark and 80th axis closed).  R940 round-number commit
#   landmark.  Feral joins Biscuit/BL (R936 166th), Rux (R932
#   165th), Jule (R928 164th), Nevalang (R924 163rd), Corvid
#   (R920 162nd — round-number R920 commit landmark), Soppo
#   (R916 161st), Cyrus (R912 160th — round-number language
#   milestone), Lumina (R908 159th), Penne (R904 158th),
#   EndBASIC (R900 157th — R900 TRIPLE-9 commit landmark),
#   goboscript (R896 156th), Alan (R892 155th), Mech (R888 154th
#   — triple-8 landmark), Lisette (R884 153rd), Bril (R880
#   152nd), Vyxal (R876 151st), EYG (R872 150th — round-number
#   language milestone), Roto (R868 149th), Pipefish (R864
#   148th), Mochi (R860 147th), Oden (R856 146th), Hop (R852
#   145th), Lustre via Kind 2 (R848 144th), Ravi (R844 143rd),
#   ZetZ (R840 142nd), Granule (R836 141st), Sixten (R832
#   140th), Imba (R828 139th), Tao (R824 138th), Dada (R820
#   137th), Acton (R816 136th), and Stanza (R812 135th).
#
#   No completion for `feral` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_feral() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-t --tokens)'{-t,--tokens}'[show lexical tokens]' \
        '(-p --parse)'{-p,--parse}'[show parser AST]' \
        '(-P --optparse)'{-P,--optparse}'[show optimized AST (after passes)]' \
        '(-i --ir)'{-i,--ir}'[show codegen IR]' \
        '(-n --nobc)'{-n,--nobc}'[disable cached bytecode files]' \
        '(-d --dry)'{-d,--dry}'[dry run - generate IR but do not run VM]' \
        '(-e --logerr)'{-e,--logerr}'[show logs on stderr]' \
        '(-V --verbose)'{-V,--verbose}'[verbose compiler output (INFO)]' \
        '(-D --debug)'{-D,--debug}'[debug compiler output (DEBUG)]' \
        '(-T --trace)'{-T,--trace}'[trace compiler output (TRACE)]' \
        ':Feral source file:_files -g "*.fer"'
}

_feral "$@"
