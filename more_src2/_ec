#compdef ec
# Documentation: https://github.com/embedchain/embedchain
# Reference accessed: 2026-05-23
# Verified: embedchain/cli.py Click commands (PyPI console script ec).

# Zsh completion for ec - Embedchain RAG application CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'ec command' \
      'create-app[create new embedchain app directory]' \
      'install-reqs[install Python requirements]' \
      'start[start API and UI servers]' \
      'create[create app from deployment template]' \
      'dev[run local dev server for template]' \
      'deploy[deploy embedchain app]' && ret=0
    ;;
  args)
    case $line[1] in
      create-app)
        _arguments \
          '--docker[use docker to create app]' \
          '1:app name:' && ret=0
        ;;
      start)
        _arguments '--docker[run with docker]' && ret=0
        ;;
      create)
        _arguments \
          '--template[deployment template]:template:(fly.io modal.com render.com streamlit.io gradio.app hf/gradio.app hf/streamlit.io)' \
          '*:extra args:' && ret=0
        ;;
      dev)
        _arguments \
          '--debug[enable debug reload]' \
          '--host[bind host]:host:' \
          '--port[bind port]:port:' && ret=0
        ;;
    esac
    ;;
esac

return ret
