#compdef mount_procfs
# Documentation: man mount_procfs(8)
# Source: netbsd/src sbin/mount_procfs — mount the process file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options (nolinux excludes Linux compat nodes)]:options:_default' \
    '1:source (/proc):_files -/' \
    '2:mount point:_files -/' \
    && ret=0

return ret
