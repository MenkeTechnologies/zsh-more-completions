#compdef dump-syscalls-info
# _dump-syscalls-info — dump Linux syscall info from a vmlinux ELF (cilium/tetragon)
# upstream: https://github.com/cilium/tetragon
# Subcommands from cmd/dump-syscalls-info/main.go (kong).

_dump-syscalls-info() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'info:dump syscalls info from a vmlinux ELF'
                'ids:dump syscall IDs (using glibc headers)'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                info)
                    _arguments \
                        '--vmlinux=[vmlinux ELF file]:file:_files' \
                        '--jsonfile=[JSON file to update/create]:file:_files -g "*.json"' \
                        '--dry-run[do not write output]'
                    ;;
                ids)
                    _arguments \
                        '*--abi=[ABI to include]:abi:(common 64 32 x32)' \
                        '--outdir=[output directory]:dir:_files -/'
                    ;;
            esac
            ;;
    esac
}

_dump-syscalls-info "$@"
