#compdef ipa-server-upgrade
# Documentation: https://www.mankier.com/1/ipa-server-upgrade
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-d --debug)'{-d,--debug}'[debug]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--log-file=[log file]:file:_files' \
  '--force[force upgrade regardless of version check]' \
  '--skip-version-check[skip version check]' && ret=0

return ret
