#compdef go-librespot
# Documentation: https://github.com/devgianlu/go-librespot
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above. Flags from cmd/daemon/cli_config.go (pflag).

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '--config_dir=[configuration directory]:directory:_directories' \
  '(-c --conf)'{-c+,--conf=}'[override config values (field=value or field1.field2=value)]:override' \
  '*:: :_files' && ret=0

return ret
