#compdef multirender_test
# Documentation: https://github.com/libsdl-org/SDL/blob/main/src/test/SDL_test_common.c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: SDL test program; uses SDLTest_CommonArg parser.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '(-h --help)'{-h,--help}'[show help]' \
  '--trackmem[track memory allocations]' \
  '--randmem[fill allocated memory with random data]' \
  '--no-color[disable colored log output]' \
  '--no-time[disable timestamps in log output]' \
  '--log+[enable log category]:category:(all system audio video render input)' \
  '--info+[print SDL info]:type:(all video modes render event event_motion)' \
  '--video+[video driver]:driver:' \
  '--renderer+[SDL renderer driver name]:driver:(software opengl opengles2 metal direct3d direct3d11 direct3d12 vulkan)' \
  '--gldebug[enable OpenGL debug context]' \
  '--display+[display index]:index:' \
  '--fullscreen[fullscreen window]' \
  '--fullscreen-desktop[fullscreen desktop window]' \
  '--windows+[number of windows]:n:' \
  '--title+[window title]:title:' \
  '--icon+[window icon file]:file:_files' \
  '--center[center window]' \
  '--position+[window position X,Y]:position:' \
  '--geometry+[window WxH]:geometry:' \
  '--logical+[logical resolution WxH]:wxh:' \
  '--scale+[content scale]:scale:' \
  '--depth+[color depth in bits]:bits:' \
  '--refresh+[refresh rate in Hz]:hz:' \
  '--vsync[enable VSync]' \
  '--noframe[borderless window]' \
  '--resizable[resizable window]' \
  '--minimize[start minimized]' \
  '--maximize[start maximized]' \
  '--hidden[hidden window]' \
  '--grab[grab input]' \
  '--audio+[audio driver]:driver:' \
  '--rate+[audio sample rate]:hz:' \
  '--format+[audio sample format]:fmt:(U8 S8 S16 S16LE S16BE S32 S32LE S32BE F32 F32LE F32BE)' \
  '--channels+[audio channel count]:n:' \
  '*:image file:_files' && ret=0

return ret
