#compdef equivs-build
# Documentation: https://manpages.debian.org/bookworm/equivs/equivs-build.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for equivs-build - Build Debian packages from equivs control files

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-f --full)'{-f,--full}'[do a full build (debuild signed)]' \
  '(-s --source)'{-s,--source}'[build a source package only]' \
  '(-a --arch)'{-a,--arch}'[build for specified architecture]:arch:' \
  '(-t --templates)'{-t,--templates}'[use alternative templates directory]:dir:_files -/' \
  '1:control file:_files' && ret=0

return ret
