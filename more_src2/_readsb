#compdef readsb
# _readsb — Mode-S / ADS-B / TIS decoder daemon (wiedehopf/readsb)
# upstream: https://github.com/wiedehopf/readsb
# Flags from help.h (argp).

_readsb() {
    local -a args
    args=(
        '(- *)--help[show help]'
        '(- *)--usage[show short usage]'
        '(- *)--version[show version]'
        '--structs[dump internal struct sizes and exit]'
        '--lat=[receiver surface latitude]:lat:'
        '--lon=[receiver surface longitude]:lon:'
        '--no-interactive[disable interactive mode, print to stdout]'
        '--interactive-ttl=[remove from list if idle for N seconds (default 60)]:seconds:'
        '--modeac[enable decoding of SSR Modes 3/A & 3/C]'
        '--modeac-auto[enable Mode A/C when a Beast connection asks for it]'
        '--max-range=[absolute max range for position decoding (nm, default 300)]:nm:'
        '--fix[enable single-bit CRC correction (default)]'
        '--no-fix[disable single-bit CRC correction]'
        '--no-fix-df[disable CRC fix on the DF type filter (more DF17, less CPU)]'
        '--metric[use metric units]'
        '--show-only=[only show messages from this ICAO on stdout]:hex:'
        '--process-only=[only process messages from this ICAO]:hex:'
        '--filter-DF=[only show this DF type on stdout]:type:'
        '--device-type=[SDR type (rtlsdr / bladerf / hackrf / plutosdr / ifile / soapy / none)]:type:(rtlsdr bladerf hackrf plutosdr ifile soapy none)'
        '--device=[device identifier (rtlsdr serial, etc.)]:device:'
        '--gain=[gain in dB or "auto"]:gain:'
        '--freq=[frequency (Hz, default 1090MHz)]:hz:'
        '--interactive[interactive mode (implies --throttle)]'
        '--raw[only show raw hex message values]'
        '--preamble-threshold=[detector preamble threshold (lower = more CPU)]:threshold:'
        '--forward-mlat[forward beast mlat results to beast outputs]'
        '--forward-mlat-sbs[forward mlat results to sbs outputs]'
        '--stats[print stats at exit, no other output]'
        '--stats-range[collect/show range histogram]'
        '--stats-every=[print + reset stats every N seconds]:seconds:'
        '--auto-exit=[exit after N seconds]:seconds:'
        '--range-outline-hours=[retain range outline for this many hours]:hours:'
        '--onlyaddr[show only ICAO addresses]'
        '--gnss[show altitudes as GNSS when available]'
        '--snip=[strip IQ samples below this level]:level:'
        '--debug=[debug flags: n=net P=CPR S=speed-check]:flags:'
        '--devel=[development debug mode]:mode:'
        '--ifile=[read IQ samples from this file]:file:_files'
        '--iformat=[IQ sample format]:format:(uc8 sc16 sc16q11)'
        '--quiet[disable output (default)]'
        '--net[enable networking outputs]'
        '--net-only[disable SDR input, network only]'
        '--net-bind-address=[network listen bind address]:address:'
        '--net-api-port=[port for the JSON API server]:port:'
        '--net-bo-port=[beast output port]:port:'
        '--net-bi-port=[beast input port]:port:'
        '--net-ro-port=[raw output port]:port:'
        '--net-ri-port=[raw input port]:port:'
        '--net-sbs-port=[SBS output port]:port:'
        '--net-sbs-in-port=[SBS input port]:port:'
        '--net-vrs-port=[VRS JSON output port]:port:'
        '--net-json-port=[JSON output port]:port:'
        '--net-asterix-in-port=[ASTERIX input port]:port:'
        '--net-asterix-out-port=[ASTERIX output port]:port:'
        '--net-beast-reduce-out-port=[reduced-beast output port]:port:'
        '*--net-connector=[outbound connection: IP,PORT,protocol]:spec:'
        '--net-heartbeat=[heartbeat interval (seconds)]:seconds:'
        '--net-buffer=[network buffer size]:bytes:'
        '--net-receiver-id[include receiver id in raw output]'
        '--net-ingest[reduced output meant for adsbexchange]'
        '--write-json=[directory for JSON output]:dir:_files -/'
        '--write-json-every=[write JSON every N seconds]:seconds:'
        '--write-json-globe-history=[directory for globe-history JSON]:dir:_files -/'
        '--heatmap=[heatmap interval (seconds)]:seconds:'
        '--heatmap-dir=[heatmap output directory]:dir:_files -/'
        '--db-file=[aircraft DB file]:file:_files'
        '--db-file-lt=[long-term DB file]:file:_files'
        '--dcfilter[apply DC blocking filter]'
        '--enable-agc[enable AGC on the SDR]'
        '--enable-biastee[enable bias-tee on the SDR]'
        '--decode-threads=[number of message-decode threads]:n:'
        '--ac-hash-bits=[aircraft hash table size (log2)]:bits:'
        '--api-shutdown-delay=[delay (s) before shutting down the API]:seconds:'
        '--receiver-focus=[only process messages from this receiver-id]:rxid:'
        '--cpr-focus=[show CPR details for this ICAO hex]:hex:'
        '--leg-focus=[show leg-marking details for this ICAO hex]:hex:'
        '--trace-focus=[show traceAdd details for this ICAO hex]:hex:'
        '--full-trace-dir=[directory for full traces]:dir:_files -/'
    )
    _arguments -s $args
}

_readsb "$@"
