#compdef gh-copilot
# Documentation: https://github.com/github/gh-copilot
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# github/gh-copilot - GitHub Copilot in the CLI extension.

_gh_copilot_commands() {
  local -a commands=(
    'suggest:suggest a command'
    'explain:explain a command'
    'alias:configure shell aliases for Copilot CLI'
    'config:adjust tool settings and preferences'
  )
  _describe 'command' commands
}

_gh_copilot() {
  local curcontext="$curcontext" state line
  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '--hostname=[GitHub host for authentication]:host:_hosts' \
    '1:command:_gh_copilot_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        suggest)
          _arguments \
            '(-t --target)'{-t+,--target=}'[target shell type]:type:(shell gh git)' \
            '*:query'
          ;;
        explain)
          _arguments '*:command to explain'
          ;;
        alias)
          _arguments \
            '1:shell:(bash zsh powershell fish)'
          ;;
      esac
      ;;
  esac
}

_gh_copilot "$@"
