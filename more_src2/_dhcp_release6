#compdef dhcp_release6
# Documentation: https://manpages.debian.org/bookworm/dnsmasq-utils/dhcp_release6.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dhcp_release6 sends a DHCPv6 release packet to free an IPv6 lease (dnsmasq).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[print usage information]' \
  '(-n --iface)'{-n+,--iface=}'[network interface]:iface:_net_interfaces' \
  '(-s --server-id)'{-s+,--server-id=}'[server DUID (colon-hex)]:duid' \
  '(-c --client-id)'{-c+,--client-id=}'[client DUID (colon-hex)]:duid' \
  '(-i --iaid)'{-i+,--iaid=}'[DHCPv6 IAID (decimal)]:iaid' \
  '(-a --ip)'{-a+,--ip=}'[IPv6 address to release]:ip' \
  '(-d --dry-run)'{-d,--dry-run}'[print packet hex and exit]' && ret=0
return ret
