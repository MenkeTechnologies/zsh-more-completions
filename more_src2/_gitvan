_gitvan() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _gv_cmds=(
                'daemon:long-running daemon watching git events'
                'event:simulate or replay git events'
                'cron:cron-driven workflow scheduler'
                'audit:build/inspect workflow audit logs'
                'hooks:manage Knowledge Hooks reactive queries'
                'workflow:manage GitVan workflow .ttl files'
                'jtbd:Jobs-To-Be-Done intent-driven workflows'
                'cleanroom:reproducible build environment'
                'job:manage Bree-backed jobs'
                'schedule:cron-schedule management'
                'worktree:git worktree management'
                'submodule:git submodule helpers'
                'init:initialize gitvan in repo'
                'setup:setup gitvan globals'
                'save:quick-save commit'
                'ensure:idempotent state assertion'
                'pack:install a gitvan pack'
                'marketplace:pack registry interaction'
                'scaffold:scaffold new components'
                'compose:gitvan-as-docker-compose'
                'chat:conversational gitvan interface'
                'llm:LLM-driven workflow generation'
                'revops:revenue-ops analytics'
                'studio:Next.js-based gitvan IDE'
            )
            _describe -t commands 'gitvan command' _gv_cmds && ret=0
            ;;
        args)
            case $words[1] in
                daemon)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'daemon sub-command' \
                          '(start stop status restart)' && ret=0
                    else
                        _arguments \
                            '--root=[root directory]:dir:_files -/' \
                            '--worktrees=[worktrees to monitor]:scope:(current all)' \
                            '--auto-start[auto-start daemon on boot]' \
                            '--port=[daemon port]:port:' \
                            '--force[force]' \
                            '--verbose[verbose output]' && ret=0
                    fi
                    ;;
                workflow)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'workflow sub-command' \
                          '(list run validate create stats cursor)' && ret=0
                    else
                        _arguments \
                            '1:workflow ID:' \
                            '--dry-run[show what would be executed]' \
                            '--verbose[detailed output]' \
                            '--interactive[interactive mode]' \
                            '--title=[workflow title]:title:' && ret=0
                    fi
                    ;;
                hooks)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'hooks sub-command' \
                          '(list evaluate validate stats refresh)' && ret=0
                    else
                        _arguments \
                            '1:hook ID:' \
                            '--category=[filter by category]:cat:' \
                            '--domain=[filter by domain]:domain:' \
                            '--dry-run[do not execute]' \
                            '--verbose[detailed output]' && ret=0
                    fi
                    ;;
                cron)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'cron sub-command' \
                          '(list start dry-run status)' && ret=0
                    else
                        _arguments \
                            '--root=[root directory]:dir:_files -/' \
                            '--interval=[check interval in seconds]:sec:' \
                            '--max-concurrent=[max concurrent jobs]:n:' \
                            '--time=[ISO timestamp to simulate]:ts:' \
                            '--verbose[verbose output]' \
                            '--next[show next execution times]' && ret=0
                    fi
                    ;;
                schedule)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'schedule sub-command' \
                          '(list apply enable disable)' && ret=0
                    else
                        _arguments \
                            '1:job ID:' \
                            '2:cron expression:' \
                            '--name=[schedule name]:name:' \
                            '--description=[schedule description]:desc:' \
                            '--disabled[create in disabled state]' \
                            '--restart[restart scheduler after apply]' \
                            '--timezone=[timezone]:tz:(UTC America/New_York America/Los_Angeles Europe/London Europe/Paris Asia/Tokyo)' \
                            '--verbose[detailed output]' \
                            '--enabled-only[show only enabled]' \
                            '--format=[output format]:fmt:(table json yaml)' && ret=0
                    fi
                    ;;
                worktree)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'worktree sub-command' \
                          '(list create remove prune repair info)' && ret=0
                    else
                        _arguments \
                            '1:path:_files -/' \
                            '--branch=[branch name]:branch:' \
                            '--starting-point=[starting branch/commit]:ref:' \
                            '--force[force]' \
                            '--verbose[detailed output]' \
                            '--format=[output format]:fmt:(table json yaml)' && ret=0
                    fi
                    ;;
                submodule)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'submodule sub-command' \
                          '(status check init update sync verify)' && ret=0
                    else
                        _arguments \
                            '--verbose[verbose output]' \
                            '--json[JSON output]' \
                            '--force[force]' \
                            '--list-methods[list available methods]' && ret=0
                    fi
                    ;;
                job)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'job sub-command' \
                          '(list run chain show)' && ret=0
                    else
                        _arguments '1:job ID:' && ret=0
                    fi
                    ;;
                llm)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'llm sub-command' \
                          '(generate job)' && ret=0
                    else
                        _arguments \
                            '1:prompt:' \
                            '--save[save generated workflow]' && ret=0
                    fi
                    ;;
                revops)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'revops sub-command' \
                          '(metrics report health forecast customers)' && ret=0
                    else
                        _arguments \
                            '--growth-rate=[expected growth rate %]:n:' \
                            '--months=[forecast horizon in months]:n:' \
                            '--at-risk[show at-risk customers]' && ret=0
                    fi
                    ;;
                event)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'event sub-command' \
                          '(simulate replay)' && ret=0
                    else
                        _arguments \
                            '1:event type:(commit push merge tag)' \
                            '--files=[file glob]:glob:' && ret=0
                    fi
                    ;;
                audit)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'audit sub-command' \
                          '(build list show)' && ret=0
                    else
                        _arguments \
                            '--output=[output path]:path:_files' && ret=0
                    fi
                    ;;
                pack|marketplace)
                    _arguments \
                        '1:pack name:' \
                        '*:query:' && ret=0
                    ;;
                scaffold|compose|chat|jtbd|cleanroom|init|setup|save|ensure|studio)
                    _arguments \
                        '*:argument:' \
                        '--verbose[verbose output]' \
                        '--dry-run[dry run]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_gitvan "$@"
