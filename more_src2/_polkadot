#compdef polkadot
# Documentation: https://github.com/paritytech/polkadot-sdk/blob/master/polkadot/cli/src/cli.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'build-spec:build chain specification (deprecated)'
  'export-chain-spec:export chain specification'
  'check-block:validate blocks'
  'export-blocks:export blocks'
  'export-state:export state into chain spec'
  'import-blocks:import blocks'
  'purge-chain:remove the chain'
  'revert:revert chain to previous state'
  'benchmark:benchmarking sub-commands'
  'key:key management utilities'
  'chain-info:db meta columns info'
)

_arguments -C \
  '--chain=[chain spec]:chain:' \
  '--dev[development chain]' \
  '(-d --base-path)'{-d,--base-path=}'[base path]:dir:_files -/' \
  '*'{-l,--log=}'[log filter]:filter:' \
  '--detailed-log-output[verbose logging]' \
  '--disable-log-color[strip color]' \
  '--enable-log-reloading[reload logs at runtime]' \
  '--tracing-targets=[tracing targets]:targets:' \
  '--tracing-receiver=[tracing receiver]:type:(Log Telemetry)' \
  '--name=[node name]:name:' \
  '--state-pruning=[state pruning]:value:' \
  '--blocks-pruning=[blocks pruning]:value:' \
  '--rpc-cors=[RPC CORS]:value:' \
  '--rpc-methods=[allowed RPC methods]:level:(safe auto unsafe)' \
  '--rpc-external[expose RPC externally]' \
  '--prometheus-external[expose Prometheus externally]' \
  '--rpc-max-connections=[max RPC connections]:n:' \
  '(- *)--help[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'polkadot subcommand' subcommands && ret=0
    ;;
esac

return ret
