# evil-winrm-py3: Python implementation of Evil-WinRM (PowerShell remoting attack)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-i+[target IP/hostname]:host:_hosts' \
  '--ip=[target IP/hostname]:host:_hosts' \
  '--port=[port (default 5985)]:port:' \
  '--uri=[WSMan URI (default /wsman)]:uri:' \
  '--ua=[user agent for WinRM client]:ua:' \
  '-u+[username]:user:_users' \
  '--user=[username]:user:_users' \
  '-p+[password]:pass:' \
  '--password=[password]:pass:' \
  '-H+[NTLM hash for pass-the-hash]:hash:' \
  '--hash=[NTLM hash for pass-the-hash]:hash:' \
  '--priv-key-pem=[local path to private key PEM file]:file:_files' \
  '--cert-pem=[local path to certificate PEM file]:file:_files' \
  '-k[use Kerberos authentication]' \
  '--kerberos[use Kerberos authentication]' \
  '--no-pass[do not prompt for password]' \
  '--spn-prefix=[SPN prefix]:prefix:' \
  '--spn-hostname=[SPN hostname]:host:' \
  '--ssl[use SSL/HTTPS transport]' \
  '--log[log session to file]' \
  '--debug[enable debug logging]' \
  '--no-colors[disable color output]' && ret=0
return ret
