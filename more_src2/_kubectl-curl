#compdef kubectl-curl
# Documentation: https://github.com/crabique/kubectl-curl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-curl (crabique, the krew `curl` plugin): wraps kubectl port-forward
# + curl. Invoked as `kubectl curl [<curl arguments>|version|help]`; all curl
# options are passed through.

_arguments -s -S \
  '(- * -V --version)'{-h,--help,--manual}'[show help]' \
  '(- * -h --help --manual)'{-V,--version}'[show plugin version]' \
  '*:curl arguments:_default'
