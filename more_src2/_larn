#compdef larn
# Documentation: man larn(6)
# Source: netbsd/src games/larn/main.c — dungeon crawler (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c[clear the high scores file]' \
    '(- *)-h[show command line options]' \
    '-i[display high scores with inventories]' \
    '-l[show log of all games played]' \
    '-n[suppress welcome message, start immediately]' \
    '-o+[options file (default ~/.larnopts)]:options file:_files' \
    '-s[display the high scores]' \
    && ret=0

return ret
