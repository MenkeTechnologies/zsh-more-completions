#compdef der2ascii
# Documentation: https://github.com/google/der-ascii/blob/main/cmd/der2ascii/main.go
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# der2ascii: convert DER/BER to the DER ASCII language

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '-i[input file (defaults to stdin)]:input file:_files' \
  '-o[output file (defaults to stdout)]:output file:_files' \
  '-pem[treat input as PEM and decode the first block]' \
  '-pem-all[treat input as PEM and decode all blocks]' \
  '-pem-password[password for decrypting PEM blocks]:password:' \
  '-hex[treat input as hex, ignoring punctuation and whitespace]' \
  '-array[treat input as comma-separated integers]' \
  '*:DER input:_files' && ret=0

return ret
