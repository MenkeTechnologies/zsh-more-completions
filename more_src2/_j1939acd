#compdef j1939acd j1939spy j1939sr j1939cat
# Documentation: source-direct extraction from upstream
# linux-can/can-utils per-tool `static struct option long_opts
# []` table decoded source-direct from each <name>.c, plus the
# matching getopt argstring.
# Reference accessed: 2026-05-30 via gh api.
# linux-can can-utils SAE J1939 toolset R205 — pivot to SAE
# J1939 (the heavy-duty-vehicle protocol layered on CAN-bus,
# used in trucks, buses, agricultural and construction
# equipment) command-line tooling.  The 4 j1939* binaries in
# can-utils form the userspace test/debug toolkit for the
# Linux kernel's CAN_J1939 socket family.  Sister tools to the
# heavily-covered CAN family (candump, cangen, cansniffer,
# canplayer, cansequence, canbusload, cangw, canlogserver,
# canfdtest, cansend, can-utils umbrella + the isotp* family
# isotpdump/isotpsend/isotprecv/isotpsniffer/isotptun/
# isotpserver/isotpperf + the asc2log/log2asc/log2long log-
# conversion family) all already in the corpus.

case $service in

  j1939acd)
    # j1939acd: J1939 Address Claim Daemon - manages the
    # dynamic CA address claim protocol on a J1939 bus
    # (assigning preferred-address-with-fallback-range).
    _arguments -s -S \
      '(-? --help)'{-\\?,--help}'[print help and exit]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '(-r --range)'{-r+,--range=}'[fallback address range (e.g. 128-247)]:range:' \
      '(-c --cache)'{-c+,--cache=}'[path to NAME-cache file]:file:_files' \
      '(-a --address)'{-a+,--address=}'[preferred source address (1-byte hex/dec)]:addr:' \
      ':CAN interface (e.g. vcan0 can0):_net_interfaces' \
      ':64-bit NAME identifier (hex):'
    ;;

  j1939spy)
    # j1939spy: passive J1939 traffic-spy/sniffer.  Like
    # candump but with J1939-aware decoding (PGN/SA/DA/priority
    # framing) instead of raw CAN frames.
    _arguments -s -S \
      '(-? --help)'{-\\?,--help}'[print help and exit]' \
      '(-P --promisc)'{-P,--promisc}'[promiscuous mode: capture all J1939 traffic on the interface]' \
      '(-b --block)'{-b+,--block=}'[block size for reads]:n:' \
      '(-t --time)'{-t-,--time=-}'[print timestamps (optional source)]::source:(abs rel)' \
      ':CAN interface:_net_interfaces'
    ;;

  j1939sr)
    # j1939sr: J1939 send/receive single-shot test tool.  Like
    # cansend but on J1939 sockets with priority + PGN + size
    # control.
    _arguments -s -S \
      '(-? --help)'{-\\?,--help}'[print help and exit]' \
      '(-v --verbose)'{-v,--verbose}'[verbose output]' \
      '(-p --priority)'{-p+,--priority=}'[J1939 priority (0-7; default 6)]:prio:(0 1 2 3 4 5 6 7)' \
      '(-s --size)'{-s+,--size=}'[max transfer size in bytes]:bytes:' \
      '(-S --serialize)'{-S,--serialize}'[serialize multi-frame transfer]' \
      ':local J1939 address (IFACE:SA,PGN):' \
      ':remote J1939 address (IFACE:SA,PGN):'
    ;;

  j1939cat)
    # j1939cat: netcat-like tool for J1939 — pipes stdin to a
    # J1939 socket and J1939 socket output to stdout.  Used
    # for transferring arbitrary-size files across a J1939 bus
    # using ISO 11783 transport / multi-packet.  Decoded
    # source-direct from upstream's `const char optstring[] =
    # "?hi:vs:rp:P:R:B"` + the help-block.
    _arguments -s -S \
      '(-? -h)'{-\\?,-h}'[print help and exit]' \
      '-v[verbose output]' \
      '-i+[input file (default stdin)]:file:_files' \
      '-s+[max transfer size in bytes (default 117440505)]:bytes:' \
      '-r[receive mode (default = send)]' \
      '-p+[J1939 priority (0-7; default 6)]:prio:(0 1 2 3 4 5 6 7)' \
      '-P+[poll timeout in ms before sending (uses MSG_DONTWAIT)]:ms:' \
      '-R+[send repeat count (default 1)]:n:' \
      '-B[allow send/receive of broadcast packets]' \
      ':FROM address (- or IFACE:SA,PGN,NAME):' \
      ':TO address (- or IFACE:SA,PGN,NAME):'
    ;;

esac
