#compdef nfsen
# Documentation: https://nfsen.sourceforge.net/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'start:start nfsen'
  'stop:stop nfsen'
  'restart:restart nfsen'
  'status:show status'
  'reconfig:reconfigure'
  'add:add profile'
  'modify:modify profile'
  'delete:delete profile'
  'config:show config'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nfsen command' commands && ret=0 ;;
esac

return ret
