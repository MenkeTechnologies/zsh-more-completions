#compdef kubeseal-cli
# _kubeseal-cli — Bitnami Labs kubeseal-cli CLI command-line client for the Sealed Secrets Kubernetes Controller encrypting Kubernetes Secret manifests into SealedSecret CRDs sealed-secrets-controller pubkey fetching cert reading offline-resealing-validating-recryption-encrypt-decrypt-private-key-rotation-policy strict-namespace-cluster-wide (Bitnami team, Go); cobra
# upstream: https://github.com/bitnami-labs/sealed-secrets

_kubeseal-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--controller-namespace=+[ns]:str:' \
        '--controller-name=+[name]:str:' \
        '--cert=+[file]:file:_files -g "*.pem *.crt"' \
        '--key=+[file]:file:_files -g "*.pem *.key"' \
        '--fetch-cert[fetch cert from controller]' \
        '--scope=+[scope]:s:(strict namespace-wide cluster-wide)' \
        '--from-file=+[file]:file:_files' \
        '--raw[raw value mode]' \
        '--re-encrypt[re-encrypt with new cert]' \
        '--update-status[update status]' \
        '-w+[output file]:file:_files' \
        '--output-file=+[file]:file:_files' \
        '-f+[format]:f:(yaml json)' \
        '--format=+[format]:f:(yaml json)' \
        '-n+[namespace]:str:' \
        '--namespace=+[name]:str:' \
        '--name=+[name]:str:' \
        '--key-version=+[name]:str:' \
        '--validate[validate]' \
        '--print-version[print version]' \
        '--merge-into=+[file]:file:_files' \
        '--key-cutoff=+[time]:str:' \
        '--accept-deprecated-v1-data[accept deprecated v1]' \
        '*::secret file:_files -g "*.yaml *.yml *.json"'
}

_kubeseal-cli "$@"
