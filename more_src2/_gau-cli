#compdef gau-cli gau
# _gau-cli — Corben Leo lc gau-cli CLI command-line frontend wrapping the getallurls gau fetch known URLs from AlienVault Open Threat Exchange the Wayback Machine and Common Crawl for any given domain open-source written in Go AlienVault-OTX-Common-Crawl-Wayback URLScan multiple-providers blacklist extensions allow-list disallow-list configurable subdomains random-user-agent fp filter parallel threads timeout retries proxy verbose include-extensions exclude-extensions from-date to-date (Corben Leo lc team, Go); flag
# upstream: https://github.com/lc/gau

_gau-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-providers+[providers]:p:(wayback commoncrawl otx urlscan)' \
        '--providers=+[p]:p:(wayback commoncrawl otx urlscan)' \
        '-config+[file]:file:_files -g "*.toml"' \
        '--config=+[file]:file:_files -g "*.toml"' \
        '-o+[output file]:file:_files' \
        '--o=+[file]:file:_files' \
        '-blacklist+[exts]:str:' \
        '--blacklist=+[exts]:str:' \
        '--from=+[YYYYMM]:str:' \
        '--to=+[YYYYMM]:str:' \
        '--include-subs[include subdomains]' \
        '--subs[include subdomains]' \
        '--include[include exts]:str:' \
        '--exclude+[exts]:str:' \
        '--json[JSON output]' \
        '--fp[fast parser]' \
        '-mc+[match codes]:str:' \
        '--mc=+[codes]:str:' \
        '-fc+[filter codes]:str:' \
        '--fc=+[codes]:str:' \
        '-mt+[match types]:str:' \
        '--mt=+[types]:str:' \
        '-ft+[filter types]:str:' \
        '--ft=+[types]:str:' \
        '--retries=+[N]:n:' \
        '--threads=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '--proxy=+[url]:str:' \
        '--random-agent[random UA]' \
        '*:domain:'
}

_gau-cli "$@"
