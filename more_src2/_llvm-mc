#compdef llvm-mc
# _llvm-mc — LLVM machine code assembler/disassembler (LLVM project, C++); assemble or disassemble target machine instructions
# upstream: https://github.com/llvm/llvm-project

_llvm-mc() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-o+[output file]:file:_files' \
        '-arch=+[arch]:arch:' \
        '-triple=+[triple]:triple:' \
        '-mcpu=+[cpu]:cpu:' \
        '-mattr=+[mattr]:str:' \
        '-filetype=+[output file type]:type:(asm obj null)' \
        '--assemble[assemble (default)]' \
        '--disassemble[disassemble]' \
        '--cdis[cycle disassemble]' \
        '--mdis[markup disassemble]' \
        '--mc-relax-all[relax all fixups]' \
        '--show-encoding[show encoding]' \
        '--show-inst[show inst]' \
        '--show-inst-operands[show inst operands]' \
        '--print-imm-hex[print imm hex]' \
        '--output-asm-variant=+[output asm variant]:n:' \
        '--g[generate debug info]' \
        '-g[generate debug info]' \
        '-gdwarf-2[dwarf 2]' \
        '-gdwarf-3[dwarf 3]' \
        '-gdwarf-4[dwarf 4]' \
        '-gdwarf-5[dwarf 5]' \
        '--main-file-name=+[main file name]:str:' \
        '--save-temp-labels[save temp labels]' \
        '--position-independent[position-independent]' \
        '--no-warn[no warnings]' \
        '-W[no warnings]' \
        '--fatal-warnings[fatal warnings]' \
        '-I+[include dir]:dir:_files -/' \
        '--defsym=+[define symbol]:sym=val:' \
        '*:file:_files -g "*.(s|S|asm)"'
}

_llvm-mc "$@"
