#compdef k3d
# _k3d-bin — k3d Rancher k3s in Docker (Rancher / SUSE, Go); run lightweight k3s clusters in Docker
# upstream: https://github.com/k3d-io/k3d

_k3d-bin() {
    local -a sub=(
        'cluster:cluster commands'
        'completion:print shell completion'
        'config:config commands'
        'debug:debug commands'
        'help:show help'
        'image:image commands'
        'kubeconfig:kubeconfig commands'
        'node:node commands'
        'registry:registry commands'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '--timestamps[show timestamps]' \
        '--trace[trace log]' \
        '--verbose[verbose log]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'k3d subcommand' sub ;;
        args)
            case $words[1] in
                cluster) _arguments '1:cluster cmd:(create delete edit get list start stop)' '*:cluster name:' ;;
                node) _arguments '1:node cmd:(create delete edit get list start stop)' '*:node name:' ;;
                kubeconfig) _arguments '1:kubeconfig cmd:(get merge write)' '*:cluster name:' ;;
                image) _arguments '1:image cmd:(import)' '*:image:' ;;
                registry) _arguments '1:registry cmd:(create delete get list)' '*:registry name:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_k3d-bin "$@"
