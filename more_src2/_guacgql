#compdef guacgql
# _guacgql — GUAC GraphQL API server (guacsec/guac)
# upstream: https://github.com/guacsec/guac
# Flags from cmd/guacgql/cmd/root.go + pkg/cli/store.go (cobra).

_guacgql() {
    local -a args
    args=(
        '--gql-backend=[graphql backend]:backend:(keyvalue arango ent neo4j neptune)'
        '--gql-listen-port=[graphql server listen port]:port:'
        '--gql-tls-cert-file=[TLS certificate (PEM) for graphql server]:file:_files -g "*.pem"'
        '--gql-tls-key-file=[TLS key (PEM) for graphql server]:file:_files -g "*.pem"'
        '--gql-debug[enable the graphql playground]'
        '--gql-trace[trace graphql requests/responses to the console]'
        '--enable-prometheus[enable Prometheus metrics]'
        '--enable-otel[enable OpenTelemetry metrics + tracing]'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
    )
    _arguments -s $args
}

_guacgql "$@"
