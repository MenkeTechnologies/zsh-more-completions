_lc39() {
    _arguments -s \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-p --port)'{-p,--port}'=[port on which the service will listen (default 3000)]:port:' \
        '(-x --prefix)'{-x,--prefix}'=[routes prefix to add to the service]:prefix:' \
        '(-l --log-level)'{-l,--log-level}'=[Fastify pino log level]:level:(trace debug info warn error fatal silent)' \
        '(-e --env-path)'{-e,--env-path}'=[env file path (dotenv + dotenv-expand)]:envfile:_files' \
        '--expose-metrics=[expose /-/metrics for Prometheus (default true)]:bool:(true false)' \
        '--enable-tracing=[enable tracing (preview, default false)]:bool:(true false)' \
        '--expose-documentation=[expose /documentation Swagger UI (default true)]:bool:(true false)' \
        '1:Fastify service entry-point file:_files -g "*.js *.cjs *.mjs *.ts"'
}

_lc39 "$@"
