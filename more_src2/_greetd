#compdef greetd
# Documentation: https://github.com/kennylevinsen/greetd
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for greetd - minimal login manager daemon

_arguments \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'[config file]:file:_files -g "*.toml"' \
  '(-s --session-worker)'{-s,--session-worker}'[start session worker]:fd'
