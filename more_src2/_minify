#compdef minify
# Documentation: https://github.com/tdewolff/minify/tree/master/cmd/minify
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Added -a/--all, -i/--inplace,
# --exclude, --ext, --include, --url, --css-version; removed unsupported
# -p/--preserve enum (real flag is bool-counted), the bogus --type alias,
# and the unsupported "--svg-keep-comments" name (CLI uses --svg-precision
# only — confirmed via flag listing).

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-a --all)'{-a,--all}'[minify all files, even hidden]' \
  '(-b --bundle)'{-b,--bundle}'[bundle files]' \
  '(-i --inplace)'{-i,--inplace}'[overwrite the input file]' \
  '(-l --list)'{-l,--list}'[list all accepted filetypes]' \
  '(-o --output)'{-o,--output=}'[output file or directory]:file:_files' \
  '(-p --preserve)'{-p,--preserve}'[preserve mode/owner/group/timestamps/links]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-r --recursive)'{-r,--recursive}'[recurse into directories]' \
  '(-s --sync)'{-s,--sync}'[copy unsupported files]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '(-w --watch)'{-w,--watch}'[watch for changes]' \
  '--exclude=[exclude filename pattern]:pattern' \
  '--ext=[ext map: a=b, c=d, ...]:map' \
  '--include=[force include pattern]:pattern' \
  '--match=[filename pattern to include]:pattern' \
  '--mime=[force MIME type]:mime type' \
  '--type=[force file type]:type:(css html js json svg xml)' \
  '--url=[URL where file is loaded for relative refs]:url' \
  '--css-precision=[CSS decimal precision]:int' \
  '--css-version=[CSS specification version]:version' \
  '--html-keep-comments[keep HTML comments]' \
  '--html-keep-conditional-comments[keep conditional comments]' \
  '--html-keep-default-attrvals[keep default attribute values]' \
  '--html-keep-document-tags[keep document tags]' \
  '--html-keep-end-tags[keep end tags]' \
  '--html-keep-quotes[keep attribute quotes]' \
  '--html-keep-whitespace[keep whitespace]' \
  '--js-precision=[JS decimal precision]:int' \
  '--js-keep-var-names[keep variable names]' \
  '--js-version=[JS specification version]:version' \
  '--json-precision=[JSON decimal precision]:int' \
  '--json-keep-numbers[keep original number formatting]' \
  '--svg-precision=[SVG decimal precision]:int' \
  '--svg-keep-comments[keep SVG comments]' \
  '--xml-keep-whitespace[keep XML whitespace]' \
  '*:files:_files'
