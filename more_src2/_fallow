#compdef fallow
# ---------------------------------------------------------------------------
# fallow — codebase intelligence for TypeScript and JavaScript;
#          Rust-native static analysis layer for unused code, circular
#          dependencies, boundary violations, and duplicate exports
#          (Rust, 2,738★)
#
# upstream: https://github.com/fallow-rs/fallow
# author : the fallow-rs collective (docs at https://docs.fallow.tools)
# license: MIT
#
# Source-direct completion: every top-level subcommand below is verbatim
# from crates/cli/src/main.rs on the fallow-rs/fallow v2.87.0 tip —
# clap-derive `Command` Subcommand enum + per-subcommand structs.  Given
# the breadth of the CLI surface (~30 top-level subcommands with deep
# nested subcommand trees under `hooks`, `ci`, `license`, `telemetry`,
# `impact`, `ci-template`, `coverage`), this completion focuses on
# top-level discovery + key per-subcommand flags for the most-used
# commands (`dead-code`/`check`, `fix`, `init`, `watch`, `dupes`); pair
# with `fallow <subcommand> --help` for the exhaustive option list.
#
# Direct deps from crates/cli/Cargo.toml (selected, via workspace
# dependencies in workspace Cargo.toml):
#   toml_edit          0.25    ← canonical Rust format-preserving TOML
#                                editor (this axis) — by Ed Page (epage/
#                                toml_edit at the toml-rs collective);
#                                round-trips comments + whitespace +
#                                key order through parse/modify/serialize
#                                cycles, unlike plain `toml-rs` which
#                                deserializes to typed structs and loses
#                                source formatting.  Used by Cargo
#                                itself for `cargo add`/`cargo remove`/
#                                `cargo set-version` operations on
#                                `Cargo.toml`.  fallow uses it for
#                                `format-config` and TOML config editing
#                                in `fix`/`audit` workflows.
#   oxc_parser, oxc_ast, oxc_semantic, oxc_resolver, oxc_span (all
#                              from Boshen Chen's oxc-project Oxidation
#                              Compiler — fastest JS/TS parser in Rust;
#                              powers oxlint, fallow, deno-lint-rs)
#   clap (derive)              (CLI parser)
#   rayon                      (data-parallel iterators)
#   serde + serde_json + serde_yaml_ng + jsonc-parser + toml + toml_edit
#                              (multi-format config serialization;
#                              jsonc-parser by David Sherret for
#                              JSON-with-comments + trailing-comma
#                              support that .fallowrc.jsonc uses)
#   schemars                   (Graham Reith GREsau's JSON schema
#                              generation from Rust types — powers
#                              `fallow config-schema` / `plugin-schema`)
#
# fallow analyzes TypeScript/JavaScript codebases for code-quality
# issues that the TypeScript compiler itself doesn't flag: unused files,
# unused exports, unused dependencies, unused type/enum/class members,
# unresolved imports, unlisted dependencies, duplicate exports, circular
# dependencies, re-export cycles, architectural boundary violations,
# stale `// fallow-disable` suppressions, pnpm catalog/dependency-
# override issues.  Configurable via `.fallowrc.json` (JSON) or
# `.fallowrc.jsonc` (JSON-with-comments) or `fallow.toml` (TOML);
# scaffolded by `fallow init`.  Designed for CI integration with
# upload-inventory / upload-source-maps / upload-static-findings against
# fallow.tools cloud + reconcile-review for PR/MR feedback envelopes.
#
# === AXIS 176 OPENER — format-preserving TOML editors ====================
# Axis position: Rust=231 OPENS Axis 176 at slot 1/0/0.  Canonical Rust
# format-preserving TOML editor is `toml_edit` by Ed Page (epage) at the
# toml-rs collective — round-trips comments + whitespace + key order
# through parse/modify/serialize cycles, unlike plain `toml-rs` which
# deserializes to typed structs and loses source formatting.  Used by
# Cargo itself for `cargo add` / `cargo remove` / `cargo set-version`
# operations on `Cargo.toml`, by agent-of-empires for config editing,
# and by fallow for `format-config` and config-edit workflows in
# `fix`/`audit`.  Pure-Rust, no system C dependencies.
#
# Cycle position in current 3+1 micro-cycle:
#   Rust=231     ← THIS FILE              (axis 176 OPENS, slot 1/0/0)
#   Go=231       ← next round              (axis 176 continues, slot 2/0/0)
#   TS-Node=231  ← round after             (axis 176 CLOSES at triple-231, slot 1/1/1)
# ---------------------------------------------------------------------------

_fallow() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'--version'[print version]' \
        '1: :->cmds' \
        '*::arg:->args' && ret=0

    case $state in
        cmds)
            local -a subcmds
            subcmds=(
                'dead-code:analyze project for unused code and circular dependencies (alias: check)'
                'check:alias for dead-code'
                'watch:watch for changes and re-run analysis'
                'fix:auto-fix unused exports/deps/enum members; add duplicate-export rules to config'
                'init:initialize a .fallowrc.json configuration file (optionally a git pre-commit hook)'
                'hooks:install or remove fallow-managed Git and agent hooks (install / remove subcommands)'
                'ci:CI helpers for PR/MR feedback envelopes (subcommand)'
                'config-schema:print the JSON Schema for fallow configuration files'
                'plugin-schema:print the JSON Schema for external plugin files'
                'config:show the resolved config and which config file was loaded (--path prints path only)'
                'list:list all files / exports / dependencies discovered by analysis'
                'dupes:run duplication analysis (cross-references with dead code when --include-dupes is set in dead-code)'
                'health:show health/coverage/license/sidecar status'
                'flags:show feature flags and their current values'
                'explain:explain why an export is used / unused (FILE:EXPORT format)'
                'audit:run dead-code + duplication + fix-readiness audit (CI-friendly)'
                'impact:enable / disable / status Impact tracking (subcommand)'
                'ci-template:print or vendor CI templates (gitlab subcommand)'
                'migrate:migrate config across major fallow versions'
                'license:manage license activation (activate / status / inspect subcommands)'
                'telemetry:opt-in telemetry status / enable / disable (subcommand)'
                'coverage:resumable first-run setup for license + sidecar + recipe + analysis (setup subcommand)'
                'setup-hooks:legacy hook setup (prefer hooks install --target git)'
                'install:install fallow binaries / agents to user/system PATH'
                'uninstall:uninstall fallow binaries / agents'
                'activate:activate a license (alias for `license activate`)'
                'inspect:inspect a fallow asset (license JWT / config / etc.)'
                'gitlab:GitLab CI template helper (alias for `ci-template gitlab`)'
                'setup:resumable first-run setup (alias for `coverage setup`)'
                'analyze:run coverage analysis (typically called by setup workflow)'
                'upload-inventory:upload analysis inventory to fallow.tools cloud'
                'upload-source-maps:upload source maps for cloud-side resolution'
                'upload-static-findings:upload static-analysis findings to cloud'
                'reconcile-review:validate a rendered review envelope and compute reconcile plan'
                'format-config:rewrite a fallow config file in canonical format-preserving form (uses toml_edit)'
            )
            _describe -t commands 'fallow command' subcmds && ret=0
            ;;
        args)
            case $words[1] in
                dead-code|check)
                    _arguments \
                        '--unused-files[only report unused files]' \
                        '--unused-exports[only report unused exports]' \
                        '--unused-deps[only report unused dependencies]' \
                        '--unused-types[only report unused type exports]' \
                        '--private-type-leaks[opt in to private type leak API hygiene findings (only that type)]' \
                        '--unused-enum-members[only report unused enum members]' \
                        '--unused-class-members[only report unused class members]' \
                        '--unresolved-imports[only report unresolved imports]' \
                        '--unlisted-deps[only report unlisted dependencies]' \
                        '--duplicate-exports[only report duplicate exports]' \
                        '--circular-deps[only report circular dependencies]' \
                        '--re-export-cycles[only report re-export cycles]' \
                        '--boundary-violations[only report architectural boundary violations]' \
                        '--stale-suppressions[only report stale `// fallow-disable` suppressions]' \
                        '--unused-catalog-entries[only report unused pnpm catalog entries]' \
                        '--empty-catalog-groups[only report empty pnpm catalog groups]' \
                        '--unresolved-catalog-references[only report unresolved pnpm catalog references]' \
                        '--unused-dependency-overrides[only report unused pnpm dependency overrides]' \
                        '--misconfigured-dependency-overrides[only report misconfigured pnpm dependency overrides]' \
                        '--include-dupes[also run duplication analysis and cross-reference with dead code]' \
                        '--trace=[trace why an export is used/unused (FILE:EXPORT_NAME)]:FILE\:EXPORT:' \
                        '--trace-file=[trace all edges for a file (imports, exports, importers)]:path:_files' \
                        '--trace-dependency=[trace where a dependency is used]:package name:' \
                        '--top=[show only the top N items per category]:N:' \
                        '*--file=[only report issues in the specified file(s); useful for lint-staged]:path:_files' && ret=0
                    ;;
                watch)
                    _arguments \
                        '--no-clear[do not clear the screen between re-analyses]' && ret=0
                    ;;
                fix)
                    _arguments \
                        '--dry-run[show what would be changed without modifying files]' \
                        '(--yes --force)'{--yes,--force}'[skip confirmation prompt (required in non-TTY environments like CI or AI agents)]' \
                        '--no-create-config[refuse to create a new fallow config file when none exists (recommended for pre-commit hooks, CI bots, fallow watch)]' && ret=0
                    ;;
                init)
                    _arguments \
                        '--toml[generate TOML instead of JSONC]' \
                        '--hooks[scaffold shell-level pre-commit git hook (alias for `hooks install --target git`)]' \
                        '--branch=[fallback base branch/ref for pre-commit hook when no upstream is set (requires --hooks)]:branch:' && ret=0
                    ;;
                config)
                    _arguments \
                        '--path[print only the config file path (useful in shell scripts)]' && ret=0
                    ;;
                hooks)
                    _arguments \
                        '1: :->hooks_cmds' \
                        '*::arg:->hooks_args' && ret=0
                    case $state in
                        hooks_cmds)
                            local -a sub; sub=(
                                'install:install a fallow-managed hook (--target git|agent)'
                                'remove:remove a fallow-managed hook'
                            )
                            _describe -t commands 'hooks subcommand' sub && ret=0
                            ;;
                        hooks_args)
                            case $words[1] in
                                install|remove)
                                    _arguments \
                                        '--target=[hook surface]:target:(git agent)' && ret=0
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                telemetry)
                    _arguments \
                        '1: :(status enable disable)' && ret=0
                    ;;
                impact)
                    _arguments \
                        '1: :(enable disable status)' && ret=0
                    ;;
                license)
                    _arguments \
                        '1: :(activate status inspect)' && ret=0
                    ;;
                ci-template|gitlab)
                    _arguments \
                        '*:DIR (write vendored helpers under DIR instead of printing):_files -/' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_fallow "$@"
