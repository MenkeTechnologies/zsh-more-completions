#compdef initializer
# _initializer — operator-registry initializer (reads a directory of OLM manifests and writes a sqlite catalog db)
# upstream: https://github.com/operator-framework/operator-registry
# Flags from cmd/initializer/main.go on tip (cobra).

_initializer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-m --manifests)'{-m,--manifests}'=[relative path to directory of manifests]:dir:_files -/' \
        '(-o --output)'{-o,--output}'=[relative path to sqlite output file]:file:_files' \
        '--permissive[allow registry load errors]' \
        '--debug[enable debug logging (hidden)]'
}

_initializer "$@"
