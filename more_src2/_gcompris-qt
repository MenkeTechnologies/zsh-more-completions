# gcompris-qt: KDE GCompris educational software (Qt)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--export-activities-as-sql[export activities as SQL]' \
  '(-c --cursor)'{-c,--cursor}'[run with default system cursor]' \
  '(-C --nocursor)'{-C,--nocursor}'[run without cursor (touch screen)]' \
  '(-f --fullscreen)'{-f,--fullscreen}'[fullscreen mode]' \
  '(-w --window)'{-w,--window}'[window mode]' \
  '(-s --sound)'{-s,--sound}'[sound enabled]' \
  '(-m --mute)'{-m,--mute}'[sound muted]' \
  '--disable-kioskmode[disable kiosk mode (default)]' \
  '--enable-kioskmode[enable kiosk mode]' \
  '--renderer=[renderer]:renderer:(opengl software Direct3D11 Direct3D12 Metal)' \
  '--launch=[activity name]:activity:' \
  '(-l --list-activities)'{-l,--list-activities}'[list available activities]' \
  '--difficulty=[activity difficulty range]:range:' \
  '--start-level=[start level number]:n:' \
  '--with-sequence=[sequence JSON file]:file:_files' \
  '--locale=[locale]:locale:' \
  '(--show-home-button)--hide-home-button[hide home button]' \
  '(--hide-home-button)--show-home-button[show home button]' && ret=0
return ret
