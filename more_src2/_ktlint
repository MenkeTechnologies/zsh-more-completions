#compdef ktlint
# Documentation: https://pinterest.github.io/ktlint/latest/install/cli/
# Reference accessed: 2026-05-19
# Verified: official ktlint CLI documentation. Removed from prior file:
# undocumented --android/-a, --code-style (as a top-level option;
# belongs to generateEditorConfig subcommand), --disabled_rules,
# --experimental, --verbose, --log-type, --force-color/-y; corrected
# -v/--version to -V/--version; added --stdin-path and the
# generateEditorConfig / installGitPreCommitHook / installGitPrePushHook
# subcommands; replaced bogus man.archlinux.org search URL.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'generateEditorConfig:generate a .editorconfig with default rule properties'
  'installGitPreCommitHook:install a git pre-commit hook running ktlint'
  'installGitPrePushHook:install a git pre-push hook running ktlint'
)

_arguments -C -s -S \
  '(- *)'{-h,--help}'[show help information]' \
  '(- *)'{-V,--version}'[show ktlint version]' \
  '(-F --format)'{-F,--format}'[autocorrect style violations where possible]' \
  '--color[colorize output]' \
  '--color-name=[name of color to use]:color:' \
  '(-l --log-level)'{-l+,--log-level=}'[set logging level]:level:(trace debug info warn error none)' \
  '--editorconfig=[path to default .editorconfig]:file:_files' \
  '--limit=[maximum number of errors to show]:n:' \
  '--relative[report file paths relative to working dir]' \
  '--reporter=[reporter to use]:reporter:(plain json sarif html checkstyle plain-summary)' \
  '(-R --ruleset)'{-R+,--ruleset=}'[custom ruleset jar]:file:_files -g "*.jar"' \
  '--stdin[read file from stdin]' \
  '--stdin-path=[file path to report for stdin input]:path:_files' \
  '--baseline=[baseline file to compare violations against]:file:_files' \
  '--patterns-from-stdin[read include patterns from stdin]' \
  '1: :->cmd' \
  '*:kotlin file:_files -g "*.(kt|kts)"' && ret=0

case $state in
  (cmd) _describe -t commands 'ktlint command' commands && ret=0 ;;
esac

return ret
