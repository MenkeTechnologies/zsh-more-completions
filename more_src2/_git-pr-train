#compdef git-pr-train
# _git-pr-train — chained-PR (PR train) management for GitHub (realyze/pr-train)
# upstream: https://github.com/realyze/pr-train
# Flags from index.js (commander.js).

_git-pr-train() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--init[create example .pr-train.yml]' \
        '(-p --push)'{-p,--push}'[push changes]' \
        '(-l --list)'{-l,--list}'[list branches in current train]' \
        '(-r --rebase)'{-r,--rebase}'[rebase rather than merge]' \
        '(-f --force)'{-f,--force}'[force push to remote]' \
        '--push-merged[push all branches incl. merged]' \
        '--remote=[remote to push to]:remote:' \
        '(-b --base)'{-b+,--base=}'[base branch for first/combined PR]:branch:' \
        '(-d --draft --no-draft)'{-d,--draft}'[create PRs as draft]' \
        '(-d --draft --no-draft)--no-draft[do not create PRs as draft]' \
        '(-c --create-prs)'{-c,--create-prs}'[create GitHub PRs from train branches]' \
        '*:branch:'
}

_git-pr-train "$@"
