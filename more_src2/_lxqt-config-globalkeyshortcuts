#compdef lxqt-config-globalkeyshortcuts
# Documentation: https://github.com/lxqt/lxqt-globalkeys/blob/master/config/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: source declares no custom QCommandLineOption; only built-in help and
# version are available (Qt addHelpOption / addVersionOption).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' && ret=0

return ret
