_qore() {
    _arguments -s \
        '(- *)'{-h,--help}'[show usage information and exit]' \
        '(- *)'{-V,--version}'[show version + build + library info]' \
        '(- *)--short-version[show only the version number]' \
        '(- *)--version-animation[show animated 3D version logo]' \
        '(- *)--lgpl[show LGPL license text]' \
        '(- *)--mit[show MIT license text]' \
        '(- *)'{-i,--list-warnings}'[list all available warnings]' \
        '(- *)'{-o,--list-parse-options}'[list all parse options]' \
        '(- *)'{-H,--parse-option-help}'[show parse-option help]' \
        '(- *)'{-s,--show-charsets}'[show supported character sets]' \
        '(- *)'{-a,--show-aliases}'[show charset aliases]' \
        '(- *)'{-B,--show-build-options}'[show build-time options]' \
        '(- *)--show-targets[list available LLVM targets]' \
        '(- *)--module-dir[show system module directory]' \
        '(- *)--user-module-dir[show user module directory]' \
        '(- *)--module-path[show module search path]' \
        '(- *)--module-api[show current module API version]' \
        '(- *)--module-apis[show all supported module API versions]' \
        '(- *)--latest-module-api[show latest module API version]' \
        '(-c --charset)'{-c,--charset}'=[default character set encoding]:encoding:' \
        '*'{-D,--define}'=[set a parse define (KEY[=VAL], repeatable)]:define:' \
        '(-e --exec)'{-e,--exec}'=[execute code from command line]:code:' \
        '--exec-mode=[execution mode]:mode:(ir jit aot interp)' \
        '--ir-dump[dump the IR]' \
        '--ir-fallback-warn[warn on IR fallback]' \
        '--ir-fallback-report[report IR fallbacks]' \
        '--jit-ir-threshold=[JIT IR threshold]:n:' \
        '--jit-jit-threshold=[JIT JIT threshold]:n:' \
        '*'{-l,--load}'=[load a Qore module (repeatable)]:module:' \
        '(-m --show-module-errors)'{-m,--show-module-errors}'[show module errors]' \
        '*'{-p,--set-parse-option}'=[set a parse option (repeatable)]:option:' \
        '(-x --exec-class)'{-x,--exec-class}'=[execute as class]:class:' \
        '(-X --eval)'{-X,--eval}'=[evaluate expression and print result]:expr:' \
        '(-z --time-zone)'{-z,--time-zone}'=[set the time zone]:zone:' \
        '(-b --disable-signals)'{-b,--disable-signals}'[disable signal handlers]' \
        '(-g --disable-gc)'{-g,--disable-gc}'[disable the garbage collector]' \
        '(-r --warnings-are-errors)'{-r,--warnings-are-errors}'[treat warnings as errors]' \
        '(-W --enable-all-warnings)'{-W,--enable-all-warnings}'[enable all warnings]' \
        '--strict-warnings[enable strict warnings]' \
        '*'{-w,--enable-warning}'=[enable a specific warning (repeatable)]:warning:' \
        '--compile[compile script to native code (AOT)]' \
        '--output=[output file for --compile]:file:_files' \
        '--opt-level=[LLVM optimization level]:level:(0 1 2 3)' \
        '--target=[LLVM target triple (cross-compile)]:triple:' \
        '--static[statically link the compiled binary]' \
        '--compile-module[compile as a Qore module (.qm)]' \
        '--interactive[force interactive REPL mode]' \
        '--no-repl[disable the REPL even when stdin is TTY]' \
        '(-G --enable-debug)'{-G,--enable-debug}'[enable debug support]' \
        '(-M --modern)'{-M,--modern}'[force %modern parse defaults]' \
        '--no-global-vars[disable global variables]' \
        '(-d --debug)'{-d,--debug}'=[set debug level]:level:' \
        '(-t --trace)'{-t,--trace}'[enable tracing]' \
        '--only-first-exception[stop on first exception]' \
        '*:Qore source file:_files -g "*.qr *.q"'
}

_qore "$@"
