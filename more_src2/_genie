#compdef genie
# Documentation: https://wiki.gnome.org/Projects/Genie
# Reference accessed: 2026-05-16
# Verified: Genie is a syntax alternative to Vala; no dedicated
# `genie` binary exists. Compilation uses `valac` for .gs files.
# This completion exposes the valac flags most relevant to Genie.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# genie: Vala-syntax alternative (compiled with valac)
local curcontext="$curcontext" ret=1
_arguments -C \
  '*--pkg=[include library bindings]:package:' \
  '--ccode[emit C source instead of binary]' \
  '(-o --output)'{-o+,--output=}'[output filename]:file:_files' \
  '--vapidir=[VAPI search directory]:dir:_files -/' \
  '--girdir=[GIR search directory]:dir:_files -/' \
  '--metadatadir=[metadata search directory]:dir:_files -/' \
  '--gir=[generate GIR file]:name:' \
  '--library=[library name]:name:' \
  '*:Genie source:_files -g "*.gs(-.)"' && ret=0
return ret
