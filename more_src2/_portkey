#compdef portkey
# Documentation: https://portkey.ai/docs/guides/coding-agents/agent-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'setup:full setup wizard (gateway, MCP, skills)'
  'status:show current config, routing hints, MCP counts'
  'skills:manage workspace skills'
  'mcp:manage MCP servers'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--portkey-key=[Portkey API key]:key:' \
  '--provider=[provider or config slug]:provider:' \
  '(-y --yes)'{-y,--yes}'[skip all prompts, accept defaults]' \
  '--skip-mcp[skip MCP server setup]' \
  '--skip-skills[skip skill sync]' \
  '--codex-wire-api=[Codex wire API]:api:(chat responses)' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'portkey command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (setup)
        _arguments \
          '--portkey-key=[Portkey API key]:key:' \
          '--provider=[provider or config slug]:provider:' \
          '(-y --yes)'{-y,--yes}'[skip prompts]' \
          '--skip-mcp[skip MCP server setup]' \
          '--skip-skills[skip skill sync]' \
          '--codex-wire-api=[Codex wire API]:api:(chat responses)' && ret=0 ;;
      (skills)
        _arguments '*::sub:(sync list)' && ret=0 ;;
      (mcp)
        _arguments '*::sub:(add)' && ret=0 ;;
    esac ;;
esac

return ret
