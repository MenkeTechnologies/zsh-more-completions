#compdef pg_test_fsync
# Documentation: https://www.postgresql.org/docs/current/app-pgtestfsync.html
# Source: postgres/postgres src/bin/pg_test_fsync/pg_test_fsync.c — measure fsync performance (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[show version]' \
    '(- *)'{-\?,--help}'[show help]' \
    {-f+,--filename=}'[test file]:file:_files' \
    {-s+,--secs-per-test=}'[seconds per test]:seconds:_default' \
    && ret=0

return ret
