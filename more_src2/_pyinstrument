#compdef pyinstrument
# Documentation: https://pyinstrument.readthedocs.io/en/latest/guide.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-m+[run library module as script]:module' \
  '-c+[program passed in as string]:code' \
  '--from-path[search for scriptfile in PATH (POSIX only)]' \
  '-o+[save report to file]:output file:_files' \
  '--outfile=[save report to file]:output file:_files' \
  '-r+[renderer]:renderer:(text html json speedscope pyisession pstats)' \
  '--renderer=[renderer]:renderer:(text html json speedscope pyisession pstats)' \
  '*-p+[pass option to renderer]:option' \
  '-t[preserve ordering, do not condense repeated calls (timeline)]' \
  '--timeline[preserve ordering, do not condense repeated calls]' \
  '--unicode[force unicode text output]' \
  '--no-unicode[force ASCII text output]' \
  '--color[force color output]' \
  '--no-color[disable color output]' \
  '--show=[show frames matching glob]:pattern' \
  '--show-regex=[show frames matching regex]:regex' \
  '--show-all[show all frames]' \
  '--hide=[hide frames matching glob]:pattern' \
  '--hide-regex=[hide frames matching regex]:regex' \
  '-i+[sampling interval in seconds]:interval' \
  '--interval=[sampling interval in seconds]:interval' \
  '--use-timing-thread[use separate timing thread]' \
  '--load=[load previous profile session]:file:_files' \
  '--load-prev=[load previous session by identifier]:id' \
  '--target-description=[custom report description]:text' \
  '*:script:_files -g "*.py"' && ret=0

return ret
