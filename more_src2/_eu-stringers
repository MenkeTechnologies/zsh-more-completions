#compdef eu-strings
# _eu-stringers — elfutils strings (Ulrich Drepper, Red Hat, C); print printable sequences (binutils-strings clone)
# upstream: https://sourceware.org/elfutils

_eu-stringers() {
    _arguments \
        '(-a --all)'{-a,--all}'[scan whole file]' \
        '(-z --print-file-name)'{-z,--print-file-name}'[print filename]' \
        '(-f --print-file-name)'{-f,--print-file-name}'[print filename]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-n --bytes)'{-n,--bytes}'+[min length]:n:' \
        '(-t --radix)'{-t,--radix}'+[radix]:base:(d o x)' \
        '(-e --encoding)'{-e,--encoding}'+[encoding]:enc:(s S b l B L)' \
        '*:file:_files'
}

_eu-stringers "$@"
