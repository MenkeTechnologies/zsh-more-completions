#compdef dcm2json
# Documentation: https://support.dcmtk.org/docs-snapshot/dcm2json.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmdata/apps/dcm2json.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmdata/apps/dcm2json.cc OFCommandLine setup + docs/man/dcm2json.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(-es --encode-strict)'{-es,--encode-strict}'[report error for inf and nan (default)]' \
  '(-ee --encode-extended)'{-ee,--encode-extended}'[permit inf and nan in JSON numbers]' \
  '(-ia --is-ds-auto)'{-ia,--is-ds-auto}'[encode IS/DS as number if valid, otherwise string (default)]' \
  '(-in --is-ds-num)'{-in,--is-ds-num}'[always encode IS/DS as number, fail if invalid]' \
  '(-is --is-ds-string)'{-is,--is-ds-string}'[always encode IS/DS as string]' \
  '(-b --bulk-disabled)'{-b,--bulk-disabled}'[write everything as inline binary (default)]' \
  '(+b --bulk-enabled)'{+b,--bulk-enabled}'[write large attributes as bulk data]' \
  '(+bz --bulk-size)'{+bz+,--bulk-size=}'[bulk data size threshold in kBytes (default 1)]:kbytes:' \
  '(+bp --bulk-uri-prefix)'{+bp+,--bulk-uri-prefix=}'[URI prefix for bulk data retrieval]:uri:' \
  '(+bd --bulk-dir)'{+bd+,--bulk-dir=}'[directory for bulk data files (default .)]:dir:_files -/' \
  '(+bs --bulk-subdir)'{+bs,--bulk-subdir}'[create subdirectory for each SOP instance]' \
  '(+c --charset-keep)'{+c,--charset-keep}'[write the original charset to JSON (default)]' \
  '(-c --charset-replace)'{-c,--charset-replace}'[replace the original charset with UTF-8 in JSON]' \
  '(+Cr --charset-require)'{+Cr,--charset-require}'[require declaration of extended charset (default)]' \
  '(+Ca --charset-assume)'{+Ca+,--charset-assume=}'[assume charset if none declared]:charset:' \
  '(+Cc --charset-check-all)'{+Cc,--charset-check-all}'[check all data elements with string values]' \
  '(+fc --formatted-code)'{+fc,--formatted-code}'[enable whitespace formatting (default)]' \
  '(-fc --compact-code)'{-fc,--compact-code}'[print only required characters]' \
  '(+m --write-meta)'{+m,--write-meta}'[write data set with meta information]' \
  '1:dcmfile-in:_files' \
  '2:jsonfile-out:_files'
