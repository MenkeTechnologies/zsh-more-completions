#compdef envd
# Documentation: https://github.com/tensorchord/envd
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for envd (urfave/cli)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--debug[verbose logs]' \
  '--analytics[enable telemetry]' \
  '--analytics-token[telemetry token]:token' \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      bootstrap build completion context debug destroy env exec image init login new pause prune
      resume run top up version
    )
    _describe -t commands 'envd command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
