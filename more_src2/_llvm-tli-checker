#compdef llvm-tli-checker
# _llvm-tli-checker — LLVM target library info checker (LLVM project, C++); verify TargetLibraryInfo vs library symbols
# upstream: https://github.com/llvm/llvm-project

_llvm-tli-checker() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--triple=+[triple]:triple:' \
        '--dump-tli[dump TLI table]' \
        '--report=+[report level]:level:(summary discrepancy full)' \
        '*:file:_files'
}

_llvm-tli-checker "$@"
