#compdef pswiggle
# Documentation: https://docs.generic-mapping-tools.org/latest/pswiggle.html
# Source: GenericMappingTools/gmt classic-mode pswiggle — anomaly wiggle plot along (x,y) tracks.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-J+[projection]:proj:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-Z+[anomaly scale (data units / dist unit)]:scale:_default' \
    '-A+[preferred positive azimuth]:azim:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C+[subtract center value before plotting]:value:_default' \
    '-D+[reference point for vertical scale bar]:opts:_default' \
    '-F+[scale-bar panel styling]:opts:_default' \
    '-G+[fill for positive/negative wiggles]:fill:_default' \
    '-I+[fixed azimuth projection]:azim:_default' \
    '-T+[track pen]:pen:_default' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '-W+[outline pen]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-t+[transparency percent]:pct:_default' \
    '-w+[cyclical coord conversion]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
