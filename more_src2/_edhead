#compdef edhead
# _edhead — edit a FITS file header in an interactive editor (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from edhead.c (single-letter getopt-style).

_edhead() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-v[verbose output]' \
        '-n[output new file]' \
        '-e+[editor to use]:editor:_command_names -e' \
        '*:FITS file:_files -g "*.(fits|fit|fts|imh)"'
}

_edhead "$@"
