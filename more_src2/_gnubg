#compdef gnubg
# Documentation: https://manpages.debian.org/gnubg
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# GNU Backgammon.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-b --no-bearoff)'{-b,--no-bearoff}'[do not use bearoff database]' \
  '(-c --commands)'{-c,--commands}'+[evaluate commands in file and exit]:file:_files' \
  '(-d --debug)'{-d,--debug}'[turn on debug]' \
  '(-D --datadir)'{-D,--datadir}'+[data directory]:dir:_files -/' \
  '(-P --pkgdatadir)'{-P,--pkgdatadir}'+[program-specific data directory]:dir:_files -/' \
  '(-O --docdir)'{-O,--docdir}'+[program documentation directory]:dir:_files -/' \
  '(-s --prefsdir)'{-s,--prefsdir}'+[user preferences directory]:dir:_files -/' \
  '(-l --lang)'{-l,--lang}'+[language]:lang:' \
  '(-p --python)'{-p,--python}'+[start in python mode or run script]:file:_files -g "*.py"' \
  '(-q --quiet)'{-q,--quiet}'[disable sound effects]' \
  '(-r --no-rc)'{-r,--no-rc}'[do not read .gnubgrc/.gnubgautorc]' \
  '(-S --splash)'{-S,--splash}'[show GTK splash screen]' \
  '(-t --tty)'{-t,--tty}'[start on tty instead of using window system]' \
  '(-w --window-system-only)'{-w,--window-system-only}'[ignore tty input when using window system]' \
  '*:file:_files -g "*.{sgf,mat,gam}"' && ret=0

return ret
