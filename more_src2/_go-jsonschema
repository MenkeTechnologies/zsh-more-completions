#compdef go-jsonschema
# Documentation: upstream README at github.com/atombender/go-jsonschema
# Reference accessed: 2026-05-30
# go-jsonschema — code-gen tool that turns JSON Schema definitions
# into Go data types + unmarshalling code that validates input JSON
# according to the schema's validation rules.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-p --package)-p+[package name for generated code]:package:' \
  '(-p --package)--package=[package name for generated code]:package:' \
  '*--schema-package=[map schema ID to Go import path (ID=PATH)]:mapping:' \
  '*--schema-output=[output file for a specific schema (ID=PATH)]:mapping:_files' \
  '(-o --output)-o+[output file]:file:_files' \
  '(-o --output)--output=[output file]:file:_files' \
  '(-h --help)-h[show help]' \
  '(-h --help)--help[show help]' \
  '--version[show version]' \
  '*:JSON schema file:_files -g "*.json"' \
  && ret=0

return ret
