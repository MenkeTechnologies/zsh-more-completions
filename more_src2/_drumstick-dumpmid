#compdef drumstick-dumpmid
# _drumstick-dumpmid — dump ALSA-sequencer / MIDI events as text (pedrolcl/drumstick)
# upstream: https://github.com/pedrolcl/drumstick
# Flags from utils/dumpmid/dumpmid.cpp (QCommandLineParser).

_drumstick-dumpmid() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-p --port)'{-p+,--port=}'[source MIDI port (client:port)]:port:'
}

_drumstick-dumpmid "$@"
