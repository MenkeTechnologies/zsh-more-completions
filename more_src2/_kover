#compdef kover
# _kover — JetBrains kover Kotlin code coverage tool CLI alias (Kotlin team, Kotlin); gradle plugin
# upstream: https://github.com/Kotlin/kotlinx-kover

_kover() {
    local -a sub=(
        'koverReport:generate full coverage report'
        'koverHtmlReport:generate html report'
        'koverXmlReport:generate xml report'
        'koverBinaryReport:generate binary report'
        'koverVerify:verify coverage thresholds'
        'koverPrintCoverage:print coverage to console'
        'koverLog:print coverage to log'
        'koverHtmlReportRelease:html report for release'
        'koverXmlReportRelease:xml report for release'
        'koverVerifyRelease:verify release coverage'
        'koverGenerateArtifact:generate kover artifact'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--info[gradle info]' \
        '-i[gradle info]' \
        '--debug[gradle debug]' \
        '-d[gradle debug]' \
        '--stacktrace[gradle stack trace]' \
        '-s[gradle stack trace]' \
        '--rerun-tasks[rerun tasks]' \
        '--no-rebuild[no rebuild]' \
        '--offline[offline]' \
        '-Pkover.disable=+[disable kover]:b:(true false)' \
        '-Pkover.tool=+[tool]:t:(JACOCO INTELLIJ KOVER)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kover subcommand' sub ;;
        args)
            case $words[1] in
                koverReport|koverHtmlReport|koverXmlReport|koverBinaryReport|koverVerify) _arguments \
                    '--rerun-tasks[rerun]' ;;
            esac
            ;;
    esac
}

_kover "$@"
