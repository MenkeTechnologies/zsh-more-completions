#compdef qenable
# _qenable-pbs — PBS qenable (server-side queue control: set queue's enabled attribute true so jobs may be queued into it; positional argument is a list of queue names; admin-only command — runs as the PBS server's manager identity)
# upstream: https://github.com/openpbs/openpbs
# Argument shape from openpbs src/cmds/qenable.c on tip.

_qenable-pbs() {
    _arguments \
        '*:queue:'
}

_qenable-pbs "$@"
