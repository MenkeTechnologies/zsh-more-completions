#compdef goc
# =============================================================================
# goc — Qiniu Cloud's "A Comprehensive Coverage Testing System
#       for The Go Programming Language" — a Go CLI tool +
#       service-center daemon that collects coverage data from
#       running Go binaries.  Distinguishing from `go test -cover`,
#       `go tool cover`, gocov, and other Go coverage tools by:
#         - SERVICE-REGISTRATION MODEL: instrumented binaries
#           register with a central goc service center via
#           HTTP, allowing coverage data to be collected from
#           LIVE running services (not just unit tests)
#         - BUILD-TIME INSTRUMENTATION: `goc build` /
#           `goc install` / `goc run` wrap Go's build pipeline,
#           injecting a coverage collector + service registration
#           into the produced binary
#         - PROFILE AGGREGATION: collected profiles can be
#           fetched by service name + filtered by file pattern
#           (--coverfile / --skipfile glob filters)
#         - DIFF MODE: `goc diff` compares coverage profiles
#           between branches + posts comments to GitHub PRs (via
#           Prow CI integration)
#         - MERGE MODE: `goc merge` combines multiple coverage
#           profiles into a single .cov file
#         - SERVICE LIFECYCLE: `goc list` / `goc register` /
#           `goc remove` / `goc clear` manage which services are
#           tracked + when their counters reset
#         - tablewriter OUTPUT: every list/diff/profile output
#           rendered through olekukonko/tablewriter's
#           imperative SetHeader/Append/Render API
#       Used by: Go teams running long-lived services that need
#       PRODUCTION coverage data (not just unit-test coverage),
#       CI/CD pipelines integrating Go coverage with PR review
#       workflows, and as a reference implementation of cobra +
#       sirupsen/logrus + tablewriter table-rendering in Go.
#
# Author:  Qiniu Cloud (qiniu organization on GitHub) — Chinese
#          cloud storage + content delivery company.  goc
#          released 2020 by Qiniu's Go engineering team; active
#          development through 2024 with ~875 stars.
# Source:  https://github.com/qiniu/goc
#          https://github.com/qiniu/goc/blob/master/cmd/root.go
#          https://github.com/qiniu/goc/blob/master/cmd/{build,run,cover,init,install,diff,merge,register,remove,clear,profile,list}.go
# CLI:     cmd/root.go — spf13/cobra subcommand tree.  Persistent
#          flags: --debug (debug mode), --debugcisyncfile
#          (hidden internal flag for CI testing).  Headline
#          library: olekukonko/tablewriter (cobra is well-
#          documented across many Go completions — tablewriter
#          is the new variant being documented here).
# Library: github.com/olekukonko/tablewriter
#          ("tablewriter" — Oleku Konko (oleku.konko@gmail.com)
#           — released 2014 as one of the FIRST production-
#           quality Go ASCII table renderers, predating jedib0t/
#           go-pretty (R610) by 4+ years.  Distinct from go-
#           pretty, rodaine/table, and stdlib text/tabwriter by:
#             1. SETTER-METHOD IMPERATIVE API — table :=
#                tablewriter.NewWriter(io.Writer);
#                table.SetHeader([]string{...});
#                table.Append([]string{...});
#                table.Render();
#                — simpler than go-pretty's table.Writer
#                interface, with all configuration via setter
#                methods on the *Table struct
#             2. NewWriter(io.Writer) CONSTRUCTOR — writes
#                directly to any io.Writer (os.Stdout, bytes.
#                Buffer, file, network socket, etc.); no
#                separate Render step + output mirror
#             3. MANY SETTER METHODS — SetAutoWrapText,
#                SetAutoFormatHeaders, SetHeaderAlignment,
#                SetAlignment, SetColumnAlignment,
#                SetColMinWidth, SetColWidth, SetTablePadding,
#                SetAutoMergeCells, SetHeaderLine, SetRowLine,
#                SetBorder, SetCenterSeparator,
#                SetColumnSeparator, SetRowSeparator,
#                SetHeaderColor, SetColumnColor,
#                SetFooterColor, SetFooter, SetCaption
#             4. PER-COLUMN COLOR via SetColumnColor(
#                tablewriter.Colors{Bold, FgRedColor}, ...) —
#                accepts variadic Colors slices per column
#             5. AUTO-FORMAT HEADERS — by default headers are
#                upper-cased + cell text wrapped at column
#                boundaries; SetAutoFormatHeaders(false)
#                preserves case + SetAutoWrapText(false)
#                disables wrapping
#             6. AUTO-MERGE CELLS — SetAutoMergeCells(true)
#                merges adjacent cells with the same value
#                vertically — useful for hierarchical data
#             7. Pure Go, no external runtime deps (only
#                mattn/go-runewidth for wide-character width
#                computation))
# License: Apache-2.0 (goc); MIT (tablewriter)
# Status:  goc — 875+ stars on qiniu/goc, Qiniu Cloud maintained,
#          used in production at Qiniu + many Chinese Go shops;
#          tablewriter — 4,800+ stars on olekukonko/tablewriter,
#          one of the TOP-30 most-starred Go libraries ever,
#          ~3 billion go.sum downloads, foundational dependency
#          of yggdrasil-network/yggdrasil-go (5.2k stars) +
#          mehrdadrad/mylg (2.7k stars) + pydio/cells (2.2k
#          stars) + Scalingo/cli + ayoisaiah/f2 + felixonmars/
#          BaiduPCS-Go + chaos-mesh/chaosd + celo-org/celo-
#          blockchain + dineshba/tf-summarize + qiniu/goc
#          (THIS) + thousands of Go CLIs going back to 2014.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — GO CROSSES TO 61 +
#                                                  AXIS 10 EXPANDS IN GO
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents
# the 61ST Go CLI library variant.  Go climbs from 60 to 61 documented
# libraries (olekukonko/tablewriter via goc).  Go **catches Rust at 61**
# (Rust=Go=61, TS-Node=60 → 50/50 two-way tie at the top).  New
# leaderboard: Rust=61, Go=61, TypeScript-Node=60 (Rust+Go tied at the
# top — twelfth two-way tie at leaderboard top in this round-sequence).
# Taxonomy now spans 353 cross-language CLI library variants across 85
# documented languages.
#
# Pattern: R613 Rust=61 (comfy-table — Axis 10 → 2 Rust variants) →
# R614 Go=61 (olekukonko/tablewriter THIS — Axis 10 → 2 Go variants) →
# expected R615 TS-Node=61 → expected R616 86th language.  This is the
# 2nd of 3 leader bumps in the current segment.
#
# This completion EXPANDS Axis 10 (TABLES / TABULAR OUTPUT) within Go
# to TWO variants — matching Rust's R613 expansion.  Three-language
# Axis 10 distribution: Rust=2, Go=2, TS-Node=1.
#
#   Go Axis 10 variants:
#     - jedib0t/go-pretty/v6 (jedib0t/go-pretty) — R610 (_yorkie)
#       — COMPOSABLE Writer/AppendRow API with multi-format
#       Render (Table/CSV/HTML/Markdown/TSV), 18-field
#       ColumnConfig per column, companion progress/list/text
#       packages, ContentArrangement-like Style.Options
#     - olekukonko/tablewriter (olekukonko/tablewriter) — R614
#       (THIS) — SIMPLE setter-method imperative API with
#       NewWriter(io.Writer) + SetHeader + Append + Render;
#       AutoFormatHeaders + AutoWrapText + SetAutoMergeCells +
#       per-column Colors slices; PURE Go without external deps
#       beyond runewidth (oldest production Go table lib, 2014)
#
# Two Go Axis 10 variants span the FULL design philosophies of Go
# table rendering:
#   tablewriter       = SIMPLE setter-method imperative (2014, OG)
#                        — NewWriter(io.Writer) + SetHeader + Append +
#                        Render; ~3 billion downloads
#   go-pretty         = COMPOSABLE Writer + multi-format Render (2018)
#                        — table.NewWriter() + AppendRow + Render*
#                        + 18-field ColumnConfig
#
# Axis 10 distribution: Rust=2, Go=2, TS-Node=1 — Rust+Go tied at 2,
# TS-Node alone at 1.  Expected R615 TS-Node=2 (as-table or text-
# table or table npm) restores three-way symmetry.
#
# (Leaderboard at R614: Rust=61, Go=61, TS-Node=60.  Rust Axis 6 /
# Errors remains at 6 — the deepest single-axis coverage of any
# language in the taxonomy.  Axis 9 / Logging remains at 5/5/5.
# Axis 10 now Rust=2, Go=2, TS-Node=1.)
#
# -----------------------------------------------------------------------------
#
# WHAT IS olekukonko/tablewriter AND WHY IS IT THE 61ST GO CLI LIBRARY?
#
# tablewriter (https://github.com/olekukonko/tablewriter, 4,800+ stars)
# is **Oleku Konko's "ASCII table in golang"** — the ORIGINAL
# production-quality Go ASCII table renderer, released in 2014 (8
# years before jedib0t/go-pretty was created).  This library has the
# longest production track record of any Go table library and remains
# the most widely-used Go table library by raw downloads (~3 billion
# go.sum downloads cumulative).
#
# tablewriter's distinguishing characteristics:
#
#   1. SETTER-METHOD IMPERATIVE API — tablewriter's central API is
#      a *Table struct with setter methods:
#
#          import "github.com/olekukonko/tablewriter"
#
#          table := tablewriter.NewWriter(os.Stdout)
#          table.SetHeader([]string{"Service", "Address", "Coverage"})
#          table.SetAutoWrapText(false)
#          table.SetAlignment(tablewriter.ALIGN_LEFT)
#          table.SetHeaderAlignment(tablewriter.ALIGN_CENTER)
#          table.SetColumnAlignment([]int{
#              tablewriter.ALIGN_LEFT,
#              tablewriter.ALIGN_LEFT,
#              tablewriter.ALIGN_RIGHT,
#          })
#          table.SetBorder(true)
#          table.SetRowLine(true)
#
#          for _, svc := range services {
#              table.Append([]string{
#                  svc.Name,
#                  svc.Address,
#                  fmt.Sprintf("%.1f%%", svc.Coverage),
#              })
#          }
#          table.Render()
#          // Output:
#          // +------------+-------------------+----------+
#          // | SERVICE    | ADDRESS           | COVERAGE |
#          // +------------+-------------------+----------+
#          // | api-server | 10.1.2.3:8080     |    87.5% |
#          // | worker-1   | 10.1.2.4:9000     |    72.3% |
#          // | worker-2   | 10.1.2.5:9000     |    91.2% |
#          // +------------+-------------------+----------+
#
#      Compare:
#         * jedib0t/go-pretty (R610): table.Writer interface +
#                                       AppendRow + Render multi-
#                                       format
#         * rodaine/table: minimal New("col1","col2") + AddRow
#         * stdlib text/tabwriter: padded tabular text, no borders
#         * Rust comfy-table (R613): builder + ContentArrangement
#         * Rust tabled (R609): derive-based struct-as-row
#         * Node.js cli-table3 (R608): push() imperative
#         * tablewriter: SETTER-METHOD on *Table struct, 2014 OG
#      FIRST documented Go Axis 10 library with simple setter-
#      method API as the primary configuration mechanism.
#
#   2. AutoFormatHeaders + AutoWrapText — tablewriter applies
#      automatic formatting by default unless explicitly disabled:
#
#          table.SetAutoFormatHeaders(true)   // default
#          // headers become UPPER-CASE
#
#          table.SetAutoWrapText(true)        // default
#          // long cells wrap at column boundaries
#
#          table.SetAutoFormatHeaders(false)
#          // preserves original case for headers
#
#          table.SetAutoWrapText(false)
#          // cells exceed column boundaries (truncate/no-wrap)
#
#      The auto-format behavior is intentional — Oleku Konko wanted
#      tablewriter to produce "clean output by default" for the
#      common case of CLI tools logging service status.  Compare:
#         * jedib0t/go-pretty: explicit Format per cell
#         * rodaine/table: no auto-format
#         * stdlib text/tabwriter: no auto-format
#         * tablewriter: AutoFormat ON by default
#      FIRST documented Go Axis 10 library with auto-format-on-by-
#      default header + cell wrapping behavior.
#
#   3. SetAutoMergeCells FOR HIERARCHICAL DATA — tablewriter
#      supports automatic VERTICAL cell merging when adjacent
#      cells in the same column have identical values:
#
#          table.SetAutoMergeCells(true)
#          table.SetRowLine(true)   // visible row borders
#          table.SetHeader([]string{"REGION", "ZONE", "INSTANCE"})
#          table.Append([]string{"us-east-1", "a", "i-001"})
#          table.Append([]string{"us-east-1", "a", "i-002"})
#          table.Append([]string{"us-east-1", "b", "i-003"})
#          table.Append([]string{"us-west-2", "a", "i-004"})
#          table.Render()
#          // Output (note merged cells in REGION + ZONE):
#          // +-----------+------+----------+
#          // | REGION    | ZONE | INSTANCE |
#          // +-----------+------+----------+
#          // | us-east-1 | a    | i-001    |
#          // +           +      +----------+
#          // |           |      | i-002    |
#          // +           +------+----------+
#          // |           | b    | i-003    |
#          // +-----------+------+----------+
#          // | us-west-2 | a    | i-004    |
#          // +-----------+------+----------+
#
#      Compare:
#         * jedib0t/go-pretty (R610): AutoMerge bool in ColumnConfig
#                                       (similar feature)
#         * rodaine/table: no merge
#         * stdlib text/tabwriter: no merge
#         * Rust tabled (R609): #[tabled(inline)] for nested only
#         * Rust comfy-table (R613): no auto-merge
#         * Node.js cli-table3 (R608): colSpan/rowSpan manual
#         * tablewriter: SetAutoMergeCells via single boolean
#      FIRST documented Go Axis 10 library with automatic vertical
#      cell-merging for hierarchical data via single-flag toggle.
#
#   4. PER-COLUMN tablewriter.Colors SLICES — tablewriter
#      supports per-column color via variadic Colors slices:
#
#          import tw "github.com/olekukonko/tablewriter"
#
#          table.SetHeaderColor(
#              tw.Colors{tw.Bold, tw.FgHiCyanColor},
#              tw.Colors{tw.Bold, tw.FgHiCyanColor},
#              tw.Colors{tw.Bold, tw.FgHiCyanColor},
#          )
#          table.SetColumnColor(
#              tw.Colors{tw.FgGreenColor},
#              tw.Colors{tw.FgYellowColor},
#              tw.Colors{tw.FgRedColor, tw.Bold},
#          )
#          table.SetFooterColor(
#              tw.Colors{tw.FgBlueColor},
#              tw.Colors{tw.FgBlueColor},
#              tw.Colors{tw.FgBlueColor},
#          )
#
#      The tw.Colors type is a []int slice of ANSI escape codes;
#      tw.Bold/FgCyanColor/FgRedColor/etc. are int constants.
#      Compare:
#         * jedib0t/go-pretty (R610): text.Colors slice in
#                                       ColumnConfig (similar)
#         * rodaine/table: no color support
#         * stdlib text/tabwriter: no color
#         * Rust tabled (R609): Color setting via crossterm
#         * Rust comfy-table (R613): Cell::fg/bg + Attribute
#         * Node.js cli-table3 (R608): chalk-style strings
#         * tablewriter: tw.Colors slice per column for header/
#                         body/footer
#      FIRST documented Go Axis 10 library with separate per-
#      column color slices for header + body + footer.
#
#   5. OLEKU-KONKO 11-YEAR PROVENANCE — tablewriter is by Oleku
#      Konko (oleku.konko@gmail.com), a Nigerian Go developer
#      who released the library in 2014 and has continuously
#      maintained it for 11 years (2014-2025).  It is the OLDEST
#      production-quality Go table library and one of the most
#      widely-used Go libraries by raw downloads.  Downstream
#      users (per go.sum reverse-deps + GitHub code search):
#         * docker / moby (originally; later migrated)
#         * helm (originally; uses different lib now)
#         * yggdrasil-network/yggdrasil-go (5.2k stars)
#         * mehrdadrad/mylg (2.7k stars)
#         * pydio/cells (2.2k stars)
#         * Scalingo/cli
#         * ayoisaiah/f2 (2.4k stars)
#         * chaos-mesh/chaosd
#         * felixonmars/BaiduPCS-Go (960 stars)
#         * dineshba/tf-summarize (704 stars)
#         * doomsday-project/doomsday
#         * davecheney/pc (by Dave Cheney himself)
#         * qiniu/goc (THIS — 875 stars)
#         * thousands more Go CLIs
#      FIRST documented Go Axis 10 library with this specific
#      Oleku-Konko 11-year sustained-single-maintainer + OG-Go-
#      table-library provenance.
#
# tablewriter's relationship to other Axis 10 libraries:
#
#   * Unlike jedib0t/go-pretty (R610) — go-pretty is COMPOSABLE
#                                         Writer with multi-format
#                                         Render; tablewriter is
#                                         SIMPLE setter-method
#                                         table-only
#   * Unlike rodaine/table — rodaine is minimal MIT-licensed
#                              alternative; tablewriter is fuller-
#                              featured with auto-format defaults
#   * Unlike stdlib text/tabwriter — stdlib is bare padded
#                                      tabular text; tablewriter
#                                      has borders + colors +
#                                      merge
#   * Closest cross-language analogs:
#         * Rust tabled (R609) — derive-based (different style)
#         * Rust comfy-table (R613) — imperative builder
#                                       (similar API style!)
#         * Node.js cli-table3 (R608) — imperative push (similar)
#         * Python tabulate — list-of-lists with auto-headers
#         * Python prettytable — Python PrettyTable
#     tablewriter is the FIRST documented Go Axis 10 library
#     providing simple setter-method imperative API + AutoFormat
#     defaults + SetAutoMergeCells + per-column tw.Colors slices,
#     released 2014 with the OLDEST sustained Go table-library
#     development history.
#
# -----------------------------------------------------------------------------
#
# THE goc CLI — cobra + logrus + viper + tablewriter
#
# goc's CLI is in cmd/root.go.  Uses cobra subcommand tree with logrus
# logging + viper config binding:
#
#     var rootCmd = &cobra.Command{
#         Use:   "goc",
#         Short: "goc is a comprehensive coverage testing tool for go language",
#         PersistentPreRun: func(cmd *cobra.Command, args []string) {
#             log.SetReportCaller(true)
#             log.SetLevel(log.InfoLevel)
#             // ... logrus.TextFormatter setup ...
#         },
#     }
#
#     rootCmd.PersistentFlags().BoolVar(&debugGoc, "debug", false,
#         "run goc in debug mode")
#
# Subcommand tree:
#     goc
#       ├── build      Wrap `go build` with coverage instrumentation
#       │              -o, --output <file>   Output binary file
#       ├── run        Wrap `go run` with coverage instrumentation
#       ├── cover      Apply coverage instrumentation to source
#       │              --target <dir>        Target folder to cover
#       ├── install    Wrap `go install` with coverage instrumentation
#       ├── init       Clear register info (start new test round)
#       ├── list       List registered services
#       ├── register   Register a service into the service center
#       │              --center <url>        Service center URL
#       │              -n, --name <name>     Service name
#       │              -a, --address <addr>  Service address
#       │              --ip_revise <bool>    Whether to IP-revise
#       ├── profile    Fetch coverage profile from service center
#       │              -o, --output <file>   Output profile file
#       │              --service <list>      Service name filter
#       │              --address <list>      Address filter
#       │              -f, --force <bool>    Force-fetch all profiles
#       │              --coverfile <list>    Cover file patterns
#       │              --skipfile <list>     Skip file patterns
#       ├── diff       Coverage profile diff analysis
#       │              -n, --new-profile <f>    Target profile
#       │              -b, --base-profile <f>   Baseline profile
#       │              --coverage-threshold-percentage <pct>
#       │              --prow-postsubmit-job <name>
#       │              --prow-remote-profile-name <name>
#       │              --github-token <path>
#       ├── merge      Merge multiple coherent .cov files
#       │              -o, --output <file>   Output .cov file
#       ├── clear      Clear coverage counters of registered services
#       │              --service <list>
#       │              --address <list>
#       └── remove     Remove specified service from register center
#                      --service <list>
#                      --address <list>
#
# tablewriter is used in cmd/list.go + cmd/diff.go + cmd/profile.go to
# render service tables + coverage diff tables to stdout.
#
# Five-axis distinctness from every other Go Axis 10 library:
#
#   1. SETTER-METHOD IMPERATIVE API — tablewriter uses *Table struct
#      setter methods; go-pretty uses table.Writer interface; rodaine
#      uses New("col1","col2") constructor; stdlib uses io.Writer
#      tabwriter.NewWriter().
#
#   2. AUTO-FORMAT-ON-BY-DEFAULT — tablewriter auto-uppercase headers
#      + auto-wrap cells unless explicitly disabled.
#
#   3. SetAutoMergeCells SINGLE-FLAG TOGGLE — tablewriter merges
#      vertically-adjacent identical cells via single boolean.
#
#   4. SEPARATE HEADER + BODY + FOOTER COLOR SLICES — tablewriter has
#      SetHeaderColor + SetColumnColor + SetFooterColor as separate
#      methods accepting per-column Colors slices.
#
#   5. 11-YEAR OLEKU-KONKO PROVENANCE — tablewriter is by Oleku Konko
#      with continuous 2014-2025 development; oldest production-
#      quality Go table library.
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/qiniu/goc/blob/master/cmd/*.go
# cobra Command + Flags() definitions; verified per-file.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _goc_cmds
_goc_cmds=(
    'build:wrap go build with coverage instrumentation'
    'run:wrap go run with coverage instrumentation'
    'cover:apply coverage instrumentation to source'
    'install:wrap go install with coverage instrumentation'
    'init:clear register info (start new test round)'
    'list:list all registered services'
    'register:register a service into the service center'
    'profile:fetch coverage profile from service registry center'
    'diff:do coverage profile diff analysis (supports Prow + GitHub PRs)'
    'merge:merge multiple coherent .cov coverage files'
    'clear:clear code coverage counters of all registered services'
    'remove:remove specified service from the register center'
    'help:show help for a subcommand'
)

_arguments -C \
    '--debug[run goc in debug mode]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '1: :->cmd' \
    '*::arg:->args' \
    && ret=0

case $state in
    cmd)
        _describe -t commands 'goc subcommand' _goc_cmds && ret=0
        ;;
    args)
        case $words[1] in
            build|install)
                _arguments \
                    '(-o --output)'{-o+,--output=}'[force build to write to named output]:output binary:_files' \
                    && ret=0
                ;;
            cover)
                _arguments \
                    '--target=[target folder to cover (default .)]:dir:_directories' \
                    && ret=0
                ;;
            register)
                _arguments \
                    '--center=[cover profile host center URL]:url:_urls' \
                    '(-n --name)'{-n+,--name=}'[service name]:name:_default' \
                    '(-a --address)'{-a+,--address=}'[service address]:addr:_default' \
                    '--ip_revise=[whether to do IP revise during registering]:bool:(true false)' \
                    && ret=0
                ;;
            profile)
                _arguments \
                    '(-o --output)'{-o+,--output=}'[output profile file]:profile file:_files -g "*.cov"' \
                    '*--service=[service name to fetch profile (see goc list)]:service:_default' \
                    '*--address=[address to fetch profile (see goc list)]:address:_default' \
                    '(-f --force)'{-f+,--force=}'[force-fetching all available profiles]:bool:(true false)' \
                    '*--coverfile=[only output matching file patterns]:pattern:_default' \
                    '*--skipfile=[skip matching file patterns]:pattern:_default' \
                    && ret=0
                ;;
            diff)
                _arguments \
                    '(-n --new-profile)'{-n+,--new-profile=}'[local target profile]:profile:_files -g "*.cov"' \
                    '(-b --base-profile)'{-b+,--base-profile=}'[local baseline profile]:profile:_files -g "*.cov"' \
                    '--coverage-threshold-percentage=[coverage threshold percentage]:pct:_default' \
                    '--prow-postsubmit-job=[Prow postsubmit job for base profile]:job:_default' \
                    '--prow-remote-profile-name=[name of profile in Prow job]:name:_default' \
                    '--github-token=[path to GitHub token (default /etc/github/oauth)]:token file:_files' \
                    && ret=0
                ;;
            merge)
                _arguments \
                    '(-o --output)'{-o+,--output=}'[output .cov file (default mergeprofile.cov)]:profile file:_files -g "*.cov"' \
                    '*: :_files -g "*.cov"' \
                    && ret=0
                ;;
            clear|remove)
                _arguments \
                    '*--service=[service name to act on (see goc list)]:service:_default' \
                    '*--address=[address to act on (see goc list)]:address:_default' \
                    && ret=0
                ;;
            help)
                _describe -t commands 'subcommand' _goc_cmds && ret=0
                ;;
        esac
        ;;
esac

return ret
