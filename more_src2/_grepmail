#compdef grepmail
# Documentation: man grepmail(1)
# Source: gitpan/grepmail grepmail — search mailbox/maildir for matches (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[print help]' \
    '(- *)--version[print version]' \
    '-a[use received date for -d matching]' \
    '-b[pattern must match body]' \
    '-B[print bodies with limited headers]' \
    '-C+[cache file]:file:_files' \
    '-d+[required date range]:date-spec:_default' \
    '-D[debug mode]' \
    '-e+[explicit pattern]:pattern:_default' \
    '-E+[complex expression]:expr:_default' \
    '-f+[patterns from file]:file:_files' \
    '-F[force processing all data as mailboxes]' \
    '-h[pattern must match header]' \
    '-H[print headers only]' \
    '-i[ignore case]' \
    '-j+[match status flags]:flags:(A R D O F)' \
    '-l[list filenames of matches]' \
    '-L[follow symbolic links (implies -R)]' \
    '-M[do not search non-text MIME attachments]' \
    '-m[append X-Mailfolder header]' \
    '-n[print line numbers]' \
    '-q[quiet mode]' \
    '-r[print file + match count]' \
    '-R[recurse directories]' \
    '-s+[size range]:size-spec:_default' \
    '-S[ignore signatures]' \
    '-u[suppress duplicates]' \
    '-v[print non-matching emails]' \
    '-V[display version]' \
    '-w[word boundary match]' \
    '-X+[signature separator regex]:regex:_default' \
    '-Y+[header pattern (implies -h)]:header-regex:_default' \
    '*:mailbox file:_files' \
    && ret=0

return ret
