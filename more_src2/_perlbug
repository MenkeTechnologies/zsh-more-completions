#compdef perlbug
# Documentation: perlbug --help (perlbug 1.43)
# Source: Perl perlbug — generate Perl5 bug reports.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-v[verbose configuration data]' \
    '(-f -b)-f+[file containing body of report]:file:_files' \
    '(-f -b)-b+[body text on command line]:text:' \
    '*-p+[patch / attachment file (comma-separated)]:file:_files' \
    '-F+[output report to file (default perlbug.rep)]:file:_files' \
    '-S[save / send without confirmation]' \
    '-a+[send to address instead of saving]:address:_email_addresses' \
    '(-c -C)-c+[Cc address (default root)]:address:_email_addresses' \
    '(-c -C)-C[do not send copy to administrator]' \
    '-s+[subject]:subject:' \
    '-r+[return address]:address:_email_addresses' \
    '-e+[editor]:editor:_command_names -e' \
    '-t[test mode]' \
    '-T[thank-you mode (perl-thanks@perl.org)]' \
    '-d[data mode (print config; no mail)]' \
    '(- *)-h[show help]' \
    '(-ok --ok -nok --nok -okay --okay -nokay --nokay)-ok[OK report]' \
    '(-ok --ok -nok --nok -okay --okay -nokay --nokay)-okay[OK report (alias)]' \
    '(-ok --ok -nok --nok -okay --okay -nokay --nokay)-nok[not-OK report]' \
    '(-ok --ok -nok --nok -okay --okay -nokay --nokay)-nokay[not-OK report (alias)]' \
    && ret=0

return ret
