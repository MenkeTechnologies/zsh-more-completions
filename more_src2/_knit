#compdef knit knitr
# _knit — Yihui Xie knitr R-package literate-programming CLI rendering .Rnw .Rmd .Rmd .Rhtml files into TeX HTML Markdown documents executing chunks with knit/Sweave/spin (rstudio team, R); R argparse
# upstream: https://github.com/yihui/knitr

_knit() {
    local -a sub=(
        'knit:knit a file'
        'spin:spin R script'
        'pandoc:run pandoc convert'
        'purl:extract code chunks'
        'rocco:render two-column rocco'
        'knit2html:knit then htmlize'
        'knit2pdf:knit then PDF'
        'knit2wp:knit and post to WP'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'knit subcommand' sub ;;
        args)
            case $words[1] in
                knit|knit2html|knit2pdf) _arguments \
                    '--output=+[file]:file:_files' \
                    '--encoding=+[enc]:e:(UTF-8 latin1 ASCII)' \
                    '--quiet[quiet]' \
                    '--envir=+[envir]:str:' \
                    '--tangle[tangle code]' \
                    '*:Rnw/Rmd file:_files -g "*.Rnw *.rnw *.Rmd *.rmd *.Rtex *.rtex *.Rhtml *.rhtml *.Rmd *.md"' ;;
                spin) _arguments \
                    '--knit[run knit afterwards]' \
                    '--report[output report format]' \
                    '--text=+[script text]:str:' \
                    '--envir=+[envir]:str:' \
                    '--format=+[fmt]:f:(Rmd qmd Rnw Rhtml Rtex)' \
                    '--doc=+[doc pattern]:str:' \
                    '--inline=+[inline pattern]:str:' \
                    '*:R script:_files -g "*.R *.r"' ;;
                purl) _arguments \
                    '--output=+[file]:file:_files' \
                    '--documentation=+[N]:n:(0 1 2)' \
                    '--quiet[quiet]' \
                    '*:Rnw/Rmd file:_files -g "*.Rnw *.Rmd *.rmd *.Rhtml *.Rtex"' ;;
                pandoc) _arguments \
                    '--output=+[file]:file:_files' \
                    '--from=+[format]:f:(markdown rst html mediawiki textile docbook latex)' \
                    '--to=+[format]:f:(html pdf docx epub odt rtf rst markdown gfm commonmark plain)' \
                    '*:input:_files' ;;
            esac
            ;;
    esac
}

_knit "$@"
