#compdef glab-snippet
# _glab-snippet — GitLab glab snippet subcommand alias (GitLab Inc., Go); spf13/cobra
# upstream: https://gitlab.com/gitlab-org/cli

_glab-snippet() {
    local -a sub=(
        'create:create a snippet'
        'delete:delete a snippet'
        'view:view a snippet'
        'list:list snippets'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--repo=+[repository]:str:' \
        '-R+[repository]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glab-snippet subcommand' sub ;;
        args)
            case $words[1] in
                create) _arguments \
                    '--title=+[title]:str:' \
                    '-t+[title]:str:' \
                    '--filename=+[file name]:str:' \
                    '-f+[file name]:str:' \
                    '--description=+[description]:str:' \
                    '-d+[description]:str:' \
                    '--visibility=+[visibility]:v:(public internal private)' \
                    '-v+[visibility]:v:(public internal private)' \
                    '--personal[personal snippet]' \
                    '-p[personal snippet]' \
                    '*:file:_files' ;;
                view) _arguments \
                    '--web[open in browser]' \
                    '-w[open in browser]' \
                    '--raw[raw output]' \
                    '-r[raw output]' \
                    '*:id:' ;;
                delete) _arguments '*:id:' ;;
                list) _arguments \
                    '--all[all]' \
                    '-A[all]' \
                    '--per-page=+[per page]:n:' \
                    '-P+[per page]:n:' \
                    '--personal[personal snippets]' \
                    '-p[personal snippets]' \
                    '--page=+[page]:n:' ;;
            esac
            ;;
    esac
}

_glab-snippet "$@"
