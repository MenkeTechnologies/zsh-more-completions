#compdef dolphin
# _dolphin — KDE file manager (KDE/dolphin)
# upstream: https://github.com/KDE/dolphin
# Flags from src/main.cpp (QCommandLineParser).

_dolphin() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '--select[select the files/folders passed as arguments]'
        '--split[start with a split view]'
        '--new-window[explicitly open in a new window]'
        '(--sudo --admin)'{--sudo,--admin}'[set up Dolphin for administrative tasks]'
        '--daemon[start the Dolphin DBus daemon]'
        '*:URL or path:_files'
    )
    _arguments -s $args
}

_dolphin "$@"
