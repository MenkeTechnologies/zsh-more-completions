#compdef gnome-disk-utility gnome-disks
# Documentation: https://manpages.debian.org/bookworm/gnome-disk-utility/gnome-disks.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm gnome-disks(1) manpage. Real binary is gnome-disks.

# gnome-disks: GNOME Disks (block device management GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--block-device=[switch to disk for given block device]:device:_files -g "/dev/*"' \
  '--format-device[show Format Volume dialog (use with --block-device)]' \
  '--xid=[make dialog transient to given X window ID]:winid:' \
  '--restore-disk-image=[show Restore Disk Image dialog]:file:_files -g "*.(img|iso|dmg)"' && ret=0
return ret
