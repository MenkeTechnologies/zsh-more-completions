#compdef pamshadedrelief
# Documentation: man pamshadedrelief (Netpbm)
# Source: produce a shaded-relief image from an elevation PGM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-gamma+[output gamma]:g:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:input pgm:_files -g "*.(pam|pnm|pgm)"' \
    && ret=0

return ret
