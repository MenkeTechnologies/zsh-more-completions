#compdef llama-tokenize
# Documentation: https://github.com/ggml-org/llama.cpp/blob/master/tools/tokenize/tokenize.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# llama.cpp tokenization utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-m[model file]:file:_files -g "*.gguf"' \
  '--model=[model file]:file:_files -g "*.gguf"' \
  '-f[file to tokenize]:file:_files' \
  '--file=[file to tokenize]:file:_files' \
  '-p[prompt]:text:' \
  '--prompt=[prompt]:text:' \
  '--stdin[read prompt from standard input]' \
  '--ids[output token IDs only]' \
  '--no-bos[do not prepend BOS token]' \
  '--no-escape[do not process escape sequences]' \
  '--no-parse-special[do not parse control tokens]' \
  '--show-count[show total token count]' \
  '--log-disable[disable stderr log output]' \
  '*::llama-tokenize args:_files' && ret=0
return ret
