#compdef ks ksonnet
# Documentation: https://github.com/ksonnet/ksonnet
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'apply:apply local manifests to remote clusters'
  'component:manage components'
  'delete:delete components from cluster'
  'diff:diff against env or local config'
  'env:manage environments'
  'generate:generate component from prototype'
  'help:show help'
  'import:import manifests from file/dir'
  'init:initialize ksonnet application'
  'module:manage modules'
  'param:manage parameters'
  'pkg:manage packages and dependencies'
  'prototype:manage prototypes'
  'registry:manage registries'
  'show:show generated manifests'
  'upgrade:upgrade ksonnet app schema'
  'validate:validate manifests against k8s api'
  'version:show version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[increase verbosity (may be given multiple times)]' \
  '--dir=[ksonnet application root (defaults to CWD)]:dir:_files -/' \
  '--tls-skip-verify[skip TLS verify]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'ks command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (apply)
        _arguments \
          '(-c --component)*'{-c+,--component=}'[component name]:comp:' \
          '--create[create resources]' \
          '--gc-tag=[gc tag]:tag:' \
          '--skip-gc[do not gc]' \
          '--dry-run[dry run]' \
          '*:env:' && ret=0 ;;
      (env) _values 'subcommand' 'add' 'current' 'describe' 'list' 'rm' 'set' 'targets' 'update' && ret=0 ;;
      (prototype) _values 'subcommand' 'describe' 'list' 'preview' 'search' 'use' && ret=0 ;;
      (param) _values 'subcommand' 'delete' 'diff' 'list' 'set' && ret=0 ;;
      (pkg) _values 'subcommand' 'describe' 'install' 'list' && ret=0 ;;
      (registry) _values 'subcommand' 'add' 'describe' 'list' && ret=0 ;;
      (component) _values 'subcommand' 'list' 'rm' && ret=0 ;;
      (module) _values 'subcommand' 'create' 'list' && ret=0 ;;
      (init|show|generate|delete|diff|import|upgrade|validate) _arguments '*: :' && ret=0 ;;
    esac ;;
esac

return ret
