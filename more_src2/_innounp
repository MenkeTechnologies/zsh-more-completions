#compdef innounp
# _innounp — Innounp Inno Setup Unpacker CLI alias (innounp team, Pascal); custom argparse
# upstream: https://sourceforge.net/projects/innounp/

_innounp() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-x[extract files]' \
        '-v[verify but do not extract]' \
        '-e[extract files without paths]' \
        '-t[test files]' \
        '-l[list files]' \
        '-d+[output dir]:dir:_files -/' \
        '-p+[password]:str:' \
        '-m[extract internal embedded files]' \
        '-s[strip path]' \
        '-a[process all copies]' \
        '-q[quiet]' \
        '-y[overwrite]' \
        '-n[skip overwrite]' \
        '-r[do not refrain from reading file content]' \
        '-cENCODING+[encoding]:str:' \
        '-b[batch mode (no prompts)]' \
        '-o[overwrite without prompting]' \
        '-u+[language]:str:' \
        '*:installer:_files -g "*.{exe,iss}"'
}

_innounp "$@"
