#compdef gitlab-runner
# _gitlab-runner-bin — GitLab Runner CI executor (GitLab Inc, Go); register, run, and manage GitLab CI runners
# upstream: https://gitlab.com/gitlab-org/gitlab-runner

_gitlab-runner-bin() {
    local -a sub=(
        'artifacts-downloader:download artifacts'
        'artifacts-uploader:upload artifacts'
        'cache-archiver:archive a cache'
        'cache-extractor:extract a cache'
        'cache-init:init cache permissions'
        'completion:print shell completion'
        'exec:execute a build locally'
        'fleeting:fleeting plugin commands'
        'help:show help'
        'install:install runner as service'
        'list:list runners from config'
        'proxy-exec:internal proxy-exec'
        'register:register a new runner'
        'reset-token:reset runner token'
        'restart:restart runner service'
        'run:run multi-runner service'
        'run-single:run a single runner'
        'service-installer:install runner as service'
        'start:start runner service'
        'status:show service status'
        'stop:stop runner service'
        'uninstall:uninstall runner service'
        'unregister:unregister a runner'
        'verify:verify runner registration'
        'version:show version'
        'wrapper:internal CI wrapper'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '--debug[debug log]' \
        '--log-level+[log level]:level:(panic fatal error warning info debug)' \
        '-l+[log level]:level:' \
        '--log-format+[log format]:fmt:(runner text json)' \
        '--cpuprofile+[cpu profile file]:file:_files' \
        '--config+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gitlab-runner subcommand' sub ;;
        args)
            case $words[1] in
                register) _arguments \
                    '-n[non-interactive]' \
                    '--non-interactive[non-interactive]' \
                    '--registration-token+[registration token]:str:' \
                    '-r+[registration token]:str:' \
                    '--url+[GitLab URL]:url:_urls' \
                    '-u+[GitLab URL]:url:_urls' \
                    '--token+[token]:str:' \
                    '--executor+[executor]:executor:(shell docker docker-windows docker-ssh ssh parallels virtualbox kubernetes custom)' \
                    '--description+[description]:str:' \
                    '--tag-list+[tag list]:tags:' \
                    '--run-untagged[run untagged]' \
                    '--locked+[locked to project]:bool:(true false)' \
                    '--access-level+[access level]:level:(not_protected ref_protected)' \
                    '--maximum-timeout+[max timeout]:n:' \
                    '--docker-image+[docker image]:image:' \
                    '--ssh-host+[ssh host]:host:_hosts' \
                    '--ssh-port+[ssh port]:port:' \
                    '--ssh-user+[ssh user]:user:_users' \
                    '--ssh-password+[ssh password]:pass:' \
                    '--ssh-identity-file+[ssh key file]:file:_files' \
                    '--paused[paused]' ;;
                unregister) _arguments \
                    '--name+[runner name]:name:' \
                    '-n+[runner name]:name:' \
                    '--token+[runner token]:str:' \
                    '-t+[runner token]:str:' \
                    '--all-runners[all runners]' \
                    '--config+[config file]:file:_files' ;;
                exec) _arguments \
                    '1:executor:(shell docker docker-windows ssh parallels virtualbox kubernetes custom)' \
                    '*:job:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_gitlab-runner-bin "$@"
