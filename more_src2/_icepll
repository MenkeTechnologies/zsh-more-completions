#compdef icepll
# Documentation: https://github.com/YosysHQ/icestorm/blob/master/icepll/icepll.cc
# Reference accessed: 2026-05-27
# Verified: upstream getopt string "i:o:pSmf:n:bB:q" in icepll/icepll.cc

# icepll: Project IceStorm PLL configuration calculator for Lattice iCE40 FPGAs.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-i+[PLL input frequency in MHz]:input MHz:' \
  '-o+[PLL output frequency in MHz]:output MHz:' \
  '-p[use SB_PLL40_PAD primitive instead of SB_PLL40_CORE]' \
  '-S[disable SIMPLE feedback path mode]' \
  '-m[save PLL configuration as a Verilog module]' \
  '-f+[output filename for Verilog config]:file:_files' \
  '-n+[custom Verilog module name]:module name:' \
  '-b[find best input frequency using standard oscillators]' \
  '-B+[find best input frequency using frequencies from file]:freq list file:_files' \
  '-q[suppress informational output to stdout]' && ret=0

return ret
