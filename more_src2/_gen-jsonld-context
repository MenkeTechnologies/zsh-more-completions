#compdef gen-jsonld-context
# _gen-jsonld-context — emit a JSON-LD @context from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/jsonldcontextgen.py (click).

_gen-jsonld-context() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(jsonld|json)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(json json-ld)'
        '--base=[base URI for the model]:uri:'
        '--prefixes[emit the prefixes block in the context]'
        '--no-prefixes[omit the prefixes block]'
        '--model[emit the model classes in the context]'
        '--no-model[omit model classes]'
        '--flatprefixes[emit prefixes as flat @vocab entries]'
        '--no-flatprefixes[emit prefixes as nested entries]'
        '--emit-frame[emit a JSON-LD frame alongside the context]'
        '--no-emit-frame[do not emit a frame]'
        '--embed-context-in-frame[embed the @context inside the emitted frame]'
        '--no-embed-context-in-frame[reference the @context separately from the frame]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-jsonld-context "$@"
