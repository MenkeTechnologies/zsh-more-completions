#compdef ol
# ============================================================================
# ol - CLI for the Outline wiki / knowledge base API (Node, MIT)
#
# Author : Doist (engineering team)
# Upstream: https://github.com/Doist/outline-cli
# npm    : @doist/outline-cli
#
# `ol` is a commander.js-based CLI for the Outline wiki + knowledge
# base (getoutline.com - the open-source self-hosted knowledge
# platform). It covers the full Outline API: authentication +
# multi-account selection (`ol auth login`, `ol --user`),
# document CRUD + search, collection management, "skills" (LLM
# extensions), changelog browsing, and `update` for self-update.
# Multi-account aware (per-account credential cache) with JSON +
# NDJSON output modes specifically designed for AI/LLM agent
# tool-use orchestration.
#
# The OAuth2/OIDC lane is built on `oauth4webapi 3.8.6` (declared
# verbatim at upstream package.json HEAD), the canonical Node
# OAuth2 + OpenID Connect client by Filip Skokan (panva). This
# package is the universal-runtime successor to panva's earlier
# `openid-client` library (which is Node-only) and is now the
# de-facto pick for OAuth2 + OIDC across Node, Deno, Bun, edge
# workers (Cloudflare / Vercel / Netlify), and React Native.
#
# `oauth4webapi` implements RFC 6749 (OAuth2 Authorization
# Framework) + RFC 7636 (PKCE) + RFC 7662 (Token Introspection) +
# RFC 7009 (Token Revocation) + RFC 8414 (Authorization Server
# Metadata) + RFC 8628 (Device Authorization Grant) + the full
# OpenID Connect Core 1.0 / OIDC Discovery / OIDC Dynamic
# Registration spec stack. All operations are typed via TypeScript
# interfaces and return tagged-union results (`SuccessResponse`
# vs error responses are distinguishable at the type level rather
# than via thrown exceptions).
#
# The Doist `ol` CLI uses `oauth4webapi` for the device-code +
# authorization-code flows that authenticate the CLI against the
# Outline OAuth2 server, with PKCE protection on every flow.
#
# ----------------------------------------------------------------------------
# AXIS 207 :: OAUTH 2.0 (RFC 6749 + PKCE RFC 7636 + INTROSPECT RFC 7662)  [CLOSES]
# Round 1321 :: TS-Node slot 3 of 4 :: CLOSES Axis 207 (200TH AXIS CLOSED)
#
# Cross-language canonical library family for this axis:
#   Rust    : ramosbugs/oauth2-rs            [R1319 _rustmailer]
#   Go      : golang.org/x/oauth2            [R1320 _nginx-sso]
#   TS/Node : panva/oauth4webapi             [R1321 THIS FILE]
#
# Round-number landmark: the 200th axis closure in the corpus.
# Across 200 axes the cross-language convergence pattern remains
# remarkably stable: every axis lands a clean-room canonical Rust
# library + Go library + TS/Node library + four real-world
# downstream consumers (one per round) that exercise the library
# under non-trivial workload.
#
# Notable across this axis closure: oauth4webapi is panva's
# universal-runtime rewrite of openid-client, designed to run
# anywhere fetch + crypto.subtle are present (Node 18+ / Deno /
# Bun / Cloudflare Workers / Edge Runtime). This is the 2026
# direction across multiple lanes: the Rust ecosystem also moved
# this way with its `*-rs` -> `*-async` rewrites; the Go ecosystem
# similarly moved to a single "works everywhere" mode after the
# Go 1.21+ standardization push.
# ============================================================================

_ol() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--no-spinner[disable loading animations]' \
        '--accessible[screen-reader-friendly output]' \
        '--user[act as a specific stored account (id or name)]:user:' \
        '--json[emit JSON output]' \
        '--ndjson[emit newline-delimited JSON output]' \
        '--full[include all fields in JSON output]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_ol_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                auth)        _ol_auth ;;
                account)     _ol_simple_sub account ;;
                search)      _arguments '1:query:' '--limit[result limit]:n:' '(- *)'{-h,--help}'[help]' ;;
                document)    _ol_simple_sub document ;;
                collection)  _ol_simple_sub collection ;;
                skill)       _ol_simple_sub skill ;;
                changelog)   _arguments '(- *)'{-h,--help}'[help]' ;;
                update)      _arguments '(- *)'{-h,--help}'[help]' ;;
            esac
            ;;
    esac

    return ret
}

_ol_cmds() {
    local -a cmds
    cmds=(
        'auth:Manage authentication (login, logout, switch)'
        'account:Manage stored Outline accounts'
        'search:Search across Outline content'
        'document:Manage Outline documents (list, get, create, update, archive, delete, move)'
        'collection:Manage Outline collections'
        'skill:Manage LLM skills attached to documents'
        'changelog:View Outline changelog'
        'update:Self-update the CLI'
    )
    _describe -t commands 'ol command' cmds
}

_ol_auth() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:((login\:"Log in to Outline" logout\:"Log out" status\:"Show current auth status" switch\:"Switch active account"))' \
        '*::arg:->_default'
}

_ol_simple_sub() {
    _arguments \
        '(- *)'{-h,--help}'[help]' \
        '1:subcommand:(list get create update delete archive restore move share)' \
        '*::arg:->_default'
}

_ol "$@"
