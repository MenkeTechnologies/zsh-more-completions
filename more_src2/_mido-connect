#compdef mido-connect
# _mido-connect — forward MIDI messages from local ports to a remote server (mido/mido)
# upstream: https://github.com/mido/mido
# Flags from mido/scripts/mido_connect.py (argparse).

_mido-connect() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '1:address host\:port:' \
        '*:input port:'
}

_mido-connect "$@"
