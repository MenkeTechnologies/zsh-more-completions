#compdef esy-cli esy
# _esy-cli-cli — esy OCaml/Reason package manager and build tool CLI alias (esy team, OCaml/JavaScript); commander/cmdliner hybrid
# upstream: https://github.com/esy/esy

_esy-cli() {
    local -a sub=(
        'install:install dependencies'
        'i:install dependencies'
        'fetch:fetch dependencies'
        'solve:solve dependencies'
        'build:build project'
        'b:build project'
        'build-dependencies:build dependencies'
        'build-shell:open build shell'
        'build-package:build a specific package'
        'build-plan:show build plan'
        'export-build:export build artifacts'
        'export-dependencies:export dependency builds'
        'import-build:import build artifacts'
        'import-dependencies:import dependency builds'
        'release:create release'
        'shell:open shell with project env'
        'print-env:print environment variables'
        'command-env:print command env'
        'exec-env:print exec env'
        'build-env:print build env'
        'add:add package to dependencies'
        'remove:remove package'
        'list-installed:list installed packages'
        'cleanup:cleanup'
        'gc:garbage collect'
        'why:why is a package installed'
        'graph:show dependency graph'
        'show:show package info'
        'status:show project status'
        'ls-builds:list builds'
        'ls-libs:list libraries'
        'ls-modules:list modules'
        'version:show version'
        'help:show help'
        'install-cache:install esy cache'
        'npm-release:create npm release'
        'create:scaffold new project'
        'new:scaffold new project'
        'init:initialize package'
        'run-script:run package script'
        'x:exec command in project env'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--prefix-path=+[esy prefix]:dir:_files -/' \
        '-P+[esy prefix]:dir:_files -/' \
        '--sandbox-path=+[sandbox path]:dir:_files -/' \
        '-S+[sandbox path]:dir:_files -/' \
        '--cache-path=+[cache path]:dir:_files -/' \
        '--cache-tarballs-path=+[cache tarballs]:dir:_files -/' \
        '--solve-timeout=+[seconds]:n:' \
        '--fetch-concurrency=+[concurrency]:n:' \
        '--build-concurrency=+[concurrency]:n:' \
        '--opam-repository=+[repo]:str:' \
        '--esy-opam-override=+[override]:str:' \
        '--esy-opam-override-checkout=+[checkout]:str:' \
        '--npm-registry=+[registry]:url:_urls' \
        '--solve-cudf-command=+[cmd]:str:' \
        '--solver=+[solver]:s:(default mccs)' \
        '--no-color[no color]' \
        '--color=+[color]:c:(always never auto)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'esy subcommand' sub ;;
        args)
            case $words[1] in
                add|remove|show|why) _arguments '*:package:' ;;
                build|build-dependencies|build-package) _arguments \
                    '*:target:' \
                    '--release[release mode]' \
                    '--dev[dev mode]' ;;
                init|new|create) _arguments '1:dir:_files -/' '--template=+[template]:str:' ;;
                release) _arguments \
                    '--release-version=+[version]:str:' \
                    '--release-name=+[name]:str:' ;;
                run-script|x) _arguments \
                    '1:script:' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_esy-cli "$@"
