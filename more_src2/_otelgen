#compdef otelgen
# _otelgen — synthetic OpenTelemetry log / metric / trace generator (krzko/otelgen)
# upstream: https://github.com/krzko/otelgen
# Subcommands + flags from internal/cli/*.go (urfave/cli/v2).

_otelgen() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a globals
    globals=(
        '(-d --duration)'{-d+,--duration=}'[run for this many seconds]:seconds:'
        '*--header=[additional headers in key=value form (repeatable)]:header:'
        '(-i --insecure)'{-i,--insecure}'[disable client TLS transport security]'
        '--log-level=[logger level]:level:(debug info warn error)'
        '--otel-exporter-otlp-endpoint=[OTLP exporter endpoint URL]:url:'
        '(-p --protocol)'{-p+,--protocol=}'[transport protocol]:proto:(grpc http)'
        '(-r --rate)'{-r+,--rate=}'[emission rate in seconds]:seconds:'
        '(-s --service-name)'{-s+,--service-name=}'[service.name attribute (default otelgen)]:name:'
    )

    _arguments -C \
        $globals \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_otelgen_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                logs)
                    _arguments $globals \
                        '1: :(single multi)' && ret=0 ;;
                metrics)
                    _arguments $globals \
                        '1: :(counter gauge histogram exponential-histogram sum)' && ret=0 ;;
                traces)
                    _arguments $globals \
                        '1: :(single multi)' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_otelgen_commands] )) ||
_otelgen_commands() {
    local -a commands
    commands=(
        'logs:generate synthetic OpenTelemetry logs'
        'metrics:generate synthetic OpenTelemetry metrics'
        'traces:generate synthetic OpenTelemetry traces'
    )
    _describe -t commands 'otelgen command' commands
}

_otelgen "$@"
