#compdef kustomize
# _kustomize-cli-bin — kustomize k8s overlay tool (kubernetes-sigs, Go); render kustomization.yaml into final k8s manifests
# upstream: https://github.com/kubernetes-sigs/kustomize

_kustomize-cli-bin() {
    local -a sub=(
        'build:render kustomization'
        'cfg:cfg subcommands (deprecated)'
        'completion:print shell completion'
        'create:create new kustomization'
        'edit:edit existing kustomization'
        'fn:run KRM functions'
        'localize:localize a kustomization'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kustomize subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '--load-restrictor+[load restrictor]:str:(LoadRestrictionsRootOnly LoadRestrictionsNone)' \
                    '--enable-helm[enable helm]' \
                    '--enable-alpha-plugins[enable alpha plugins]' \
                    '--enable-managedby-label[enable managedby label]' \
                    '--helm-command+[helm command]:cmd:_command_names -e' \
                    '--mount+[mount]:path:_files' \
                    '--network[enable network for KRM fns]' \
                    '--network-name+[network name]:name:' \
                    '--reorder+[reorder]:str:(legacy none)' \
                    '-o+[output file]:file:_files' \
                    '--output+[output file]:file:_files' \
                    '--stack-trace[show stack trace]' \
                    '*:dir:_files -/' ;;
                create) _arguments \
                    '--namespace+[namespace]:str:' \
                    '--resources+[resources]:resources:' \
                    '--labels+[labels]:labels:' \
                    '--annotations+[annotations]:annotations:' \
                    '--nameprefix+[name prefix]:prefix:' \
                    '--namesuffix+[name suffix]:suffix:' \
                    '--detectresources[detect resources]' ;;
                edit) _arguments \
                    '1:edit cmd:(add fix remove set)' \
                    '*:args:' ;;
                fn) _arguments \
                    '1:fn cmd:(eval render run source sink)' \
                    '*:args:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kustomize-cli-bin "$@"
