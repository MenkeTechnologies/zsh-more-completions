_libsql-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--db-path=+[path]:_files' \
        '--auth-token=+[token]:str:' \
        '-a+[auth token]:str:' \
        '--encryption-key=+[key]:str:' \
        '--encryption-cipher=+[c]:c:(none aes256gcm)' \
        '--remote=+[url]:str:' \
        '--http-tls[use TLS]' \
        '--insecure[skip TLS verify]' \
        '--http-replication[HTTP replication]' \
        '--sync-url=+[url]:str:' \
        '--sync-interval=+[d]:str:' \
        '--read-your-writes[read your writes]' \
        '-i[interactive]' \
        '--interactive[interactive]' \
        '-c+[command]:str:' \
        '--command=+[cmd]:str:' \
        '*-c+[command]:str:' \
        '--echo[echo SQL]' \
        '-e[echo SQL]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b[batch mode]' \
        '--batch[batch mode]' \
        '--history-file=+[file]:file:_files -g ".libsql_history *.history"' \
        '--no-history[no history]' \
        '--format=+[fmt]:f:(json csv table jsonl quoted spaces)' \
        '-f+[format]:f:(json csv table jsonl quoted spaces)' \
        '--separator=+[c]:str:' \
        '-s+[separator]:str:' \
        '--header[show header]' \
        '--no-header[no header]' \
        '--readonly[read only]' \
        '--init=+[file]:file:_files -g "*.sql"' \
        '--bail[stop on error]' \
        '--mode=+[m]:m:(box list column quote tabs tcl insert)' \
        '*:database:'
}

_libsql-cli "$@"
