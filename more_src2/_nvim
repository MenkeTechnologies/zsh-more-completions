#compdef nvim
# Documentation: https://neovim.io/doc/user/starting.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (and `nvim --help` output).

# Zsh completion for nvim (Neovim text editor)

_nvim() {
    local curcontext="$curcontext" state line
    typeset -A opt_args

    _arguments -s -S \
        '*--cmd+[execute <cmd> before any config]:command:' \
        '*-c+[execute <cmd> after config and first file]:command:' \
        '-l+[execute Lua script]:script:_files' \
        '-S+[source session after loading first file]:file:_files' \
        '-s+[read Normal mode commands from scriptin]:file:_files' \
        '-u+[use specified config file]:vimrc:_files' \
        '-d[diff mode]' \
        '-e[ex mode]' \
        '-E[improved ex mode]' \
        '-es[silent (batch) mode]' \
        '-Es[silent (batch) mode]' \
        '(- *)'{-h,--help}'[print help message and exit]' \
        '-i+[use specified shada file]:shada file:_files' \
        '-n[no swap file, use memory only]' \
        '-o+[open N windows (default: one per file)]:number:' \
        '-O+[open N vertical windows (default: one per file)]:number:' \
        '-p+[open N tab pages (default: one per file)]:number:' \
        '-R[read-only (view) mode]' \
        '(- *)'{-v,--version}'[print version information and exit]' \
        '-V+[verbose level/file]:level:' \
        '--api-info[write msgpack-encoded API metadata to stdout]' \
        '--clean[factory defaults (skip user config, plugins, shada)]' \
        '--embed[use stdin/stdout as a msgpack-rpc channel]' \
        '--headless[do not start a UI]' \
        '--listen+[serve RPC API from this address]:address:' \
        '--remote[execute commands remotely on a server]' \
        '--server+[connect to this Nvim server]:address:' \
        '--startuptime+[write startup timing messages to file]:file:_files' \
        '*:file:_files'
}

_nvim "$@"
