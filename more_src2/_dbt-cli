#compdef dbt-cli dbt2 dbtctl
# _dbt-cli — dbt Labs dbt-cli CLI command-line frontend wrapping the dbt data build tool analytics engineering SQL transformation framework providing run test seed snapshot compile build docs source debug deps clean init list parse run-operation rpc serve show models materialization sources exposures macros (dbt Labs team, Python); click
# upstream: https://docs.getdbt.com/

_dbt-cli() {
    local -a sub=(
        'run:run models'
        'test:run tests'
        'seed:run seeds'
        'snapshot:run snapshots'
        'compile:compile models'
        'build:build run test seed and snapshot'
        'docs:docs operations'
        'source:source operations'
        'debug:debug connection'
        'deps:install dependencies'
        'clean:clean artifacts'
        'init:initialize a project'
        'list:list resources'
        'parse:parse project'
        'run-operation:run a macro'
        'rpc:RPC server'
        'serve:serve docs'
        'show:show preview output'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--no-version-check[no version check]' \
        '--debug[debug]' \
        '--log-format=+[fmt]:f:(default json text logfmt)' \
        '--log-path=+[dir]:dir:_files -/' \
        '--printer-width=+[N]:n:' \
        '--profile=+[name]:str:' \
        '--profiles-dir=+[dir]:dir:_files -/' \
        '--project-dir=+[dir]:dir:_files -/' \
        '--target=+[name]:str:' \
        '--target-path=+[dir]:dir:_files -/' \
        '--threads=+[N]:n:' \
        '--vars=+[yaml]:str:' \
        '--use-colors=+[bool]:s:(true false)' \
        '-s+[select]:str:' \
        '--select=+[selector]:str:' \
        '--models=+[models]:str:' \
        '--exclude=+[selector]:str:' \
        '--selector=+[name]:str:' \
        '--state=+[dir]:dir:_files -/' \
        '--defer[defer to previous run]' \
        '--no-defer[no defer]' \
        '--full-refresh[full refresh]' \
        '--fail-fast[fail fast]' \
        '--store-failures[store failures]' \
        '--cache-selected-only[cache selected only]' \
        '--write-json[write json]' \
        '--show[show preview]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dbt-cli subcommand' sub ;;
        args)
            case $words[1] in
                run|test|build|compile|seed|snapshot|source|list|show) _arguments '*:selector:' ;;
                docs) _arguments '1:op:(generate serve)' ;;
                run-operation) _arguments '1:macro:' '*:args:' ;;
            esac
            ;;
    esac
}

_dbt-cli "$@"
