#compdef ibcheckstate
# Documentation: https://manpages.debian.org/testing/infiniband-diags/ibcheckstate.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# ibcheckstate: check IB fabric port states
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-v[verbose]' \
  '-N[no GID check]' \
  '-n[no GID resolution]' \
  '-C[CA name]:name:' \
  '-P[CA port]:port:' \
  '-s[summary only]' \
  '-G[output GID-based]' \
  '-z[show zero values too]' \
  '*::ibcheckstate args:_files' && ret=0
return ret
