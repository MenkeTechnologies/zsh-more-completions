#compdef logss
# Documentation: https://github.com/todoesverso/logss
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# Zsh completion for logss (a simple cli for logs splitting)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)-h[print help]' \
  '-c+[substring/regex containers]:patterns:' \
  '-C+[get input from a command]:command:' \
  '-f+[input configuration file]:file:_files' \
  '-o+[output path for matched patterns]:path:_files -/' \
  '-r+[render speed in milliseconds]:ms:' \
  '-t+[threads per container for triggers]:threads:' \
  '-e[exit on empty input]' \
  '-s[start in single view mode]' \
  '-V[start in vertical view mode]' \
  '*:input file:_files' && ret=0

return ret
