#compdef db_dump
# Documentation: db_dump usage (Berkeley DB 18.1.40)
# Source: dump Berkeley DB database contents to a portable format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-V[show version]' \
    '-b+[blob directory]:dir:_files -/' \
    '-d+[debug flags ahr]:flags:(a h r ah ar hr ahr)' \
    '-D+[max data length]:bytes:' \
    '-f+[output file]:file:_files' \
    '-h+[environment home]:dir:_files -/' \
    '-k[dump key only]' \
    '-l[list databases in environment]' \
    '-m+[dump named in-memory subdatabase]:database:' \
    '-N[silent: do not acquire DB env lock]' \
    '-P+[password]:password:' \
    '-p[printable characters as ASCII]' \
    '-r[salvage and dump]' \
    '-R[aggressive salvage]' \
    '-s+[subdatabase to dump]:database:' \
    '-S+[verify ov]:flags:(o v ov)' \
    '-v+[max queue overflow length]:n:' \
    '1:db file:_files' \
    && ret=0

return ret
