#compdef fpcres fpcjres
# Documentation: fpcres / fpcjres (Free Pascal resource converter)
# Source: convert RC / RES / external resource files for Free Pascal compilation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,-\?,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-i --input)'{-i+,--input=}'[input file (ignored, compat)]:file:_files' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '*'{-I+,--include=}'[include search path (RC files)]:dir:_files -/' \
    '*'{-D+,--define=}'[define symbol[=value]]:sym[=val]:' \
    '*'{-U+,--undefine=}'[undefine symbol]:sym:' \
    '-of+[output file format]:format:(res elf coff mach-o external)' \
    '(-a --arch)'{-a+,--arch=}'[object architecture]:arch:(i386 x86_64 arm aarch64 powerpc powerpc64 armeb m68k sparc alpha ia64 mips mipsel bigendian littleendian)' \
    '(-s --subarch)'{-s+,--subarch=}'[ARM sub-architecture]:subarch:(all v4t v6 v5tej xscale v7)' \
    '*:resource file:_files -g "*.(rc|res)"' \
    && ret=0

return ret
