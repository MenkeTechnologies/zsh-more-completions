#compdef git-effort git-summary git-feature git-release git-mr git-archive-file git-touch
# Documentation: https://github.com/tj/git-extras
#                — surfaces transcribed from man/*.1 files in tj/git-extras master.
# Reference accessed: 2026-05-30
# git-extras family round 1. Companion to the pre-existing
# more_src/_git-changelog. Covers 7 of the most commonly-used tj/git-extras
# subcommands. Each one is a standalone git plugin invokable as
# `git <subcommand>` or as `git-<subcommand>` directly.

local curcontext="$curcontext" state line ret=1

case $service in

  git-effort)
    # man/git-effort.1 — commits-per-file effort statistics.
    #   git-effort [--above <value>] [<path>...] [-- [<log options>...]]
    _arguments -s -S \
      '--above=[ignore files with commits <= value]:value:' \
      '*:path:_files' \
      '*::log options after --:' \
      && ret=0
    ;;

  git-summary)
    # man/git-summary.1 — two synopsis shapes:
    #   git-summary [--dedup-by-email] [--no-merges] [<committish>]
    #   git-summary --line [<path>]
    # --line cannot combine with --dedup-by-email or --no-merges.
    _arguments -s -S \
      '(--line)--dedup-by-email[remove duplicate authors sharing one email]' \
      '(--line)--no-merges[exclude merge commits]' \
      '(--dedup-by-email --no-merges)--line[summarize lines instead of commits; last arg = <path>]' \
      '--output-style=[summary display style]:style:(tabular oneline)' \
      '*:committish or path:__git_revisions' \
      && ret=0
    ;;

  git-feature)
    # man/git-feature.1 — two synopsis shapes:
    #   git-feature [-a PREFIX] [-s SEP] [-r [REMOTE]] [--from START] NAME...
    #   git-feature [-a PREFIX] [-s SEP] finish [--squash] NAME...
    # When `finish` appears as the first non-option positional, --remote/--from
    # are not relevant and --squash becomes available.
    _arguments -s -S \
      '(-a --alias)-a+[branch prefix (default feature)]:prefix:' \
      '(-a --alias)--alias=[branch prefix (default feature)]:prefix:' \
      '(-s --separator)-s+[prefix-name separator (default /)]:char:' \
      '(-s --separator)--separator=[prefix-name separator (default /)]:char:' \
      '(-r --remote)-r+[set remote tracking branch (default origin)]:remote:__git_remotes' \
      '(-r --remote)--remote=[set remote tracking branch (default origin)]:remote:__git_remotes' \
      '--from=[start-point for new branch]:branch:__git_branch_names' \
      '--squash[squash-merge when finishing]' \
      '*:branch name or "finish":' \
      && ret=0
    ;;

  git-release)
    # man/git-release.1 — semver-aware release with pre/post-release hooks.
    #   git-release [<tagname> | --semver <name>] [-r <remote>] [-m <commit info>]
    #               [--no-empty-commit] [-c] [-s] [-u <key-id>] [--prefix <tag prefix>]
    #               [[--] <hook arguments...>]
    _arguments -s -S \
      '--semver=[increment semver tag]:level:(major minor patch)' \
      '--prefix=[tag prefix for semver tags]:prefix:' \
      '-r+[push destination remote]:remote:__git_remotes' \
      '-m+[custom commit message]:message:' \
      '--no-empty-commit[skip empty release commit]' \
      '-c[generate/update changelog with commits since last tag]' \
      '-s[create signed annotated tag]' \
      '-u+[GPG key-id for signed tag]:key-id:' \
      '*:tagname or hook arguments:' \
      && ret=0
    ;;

  git-mr)
    # man/git-mr.1 — GitLab merge request checkout.
    #   git-mr <number> [<remote>]
    #   git-mr <url>
    #   git-mr clean
    _arguments -s -S \
      '1:MR number / URL / "clean":' \
      '2:remote:__git_remotes' \
      && ret=0
    ;;

  git-archive-file)
    # man/git-archive-file.1 — no options. Creates a zip of the current HEAD.
    _arguments -s -S \
      && ret=0
    ;;

  git-touch)
    # man/git-touch.1 — create + stage a new file.
    _arguments -s -S \
      '1:filename to create + stage:_files' \
      && ret=0
    ;;

esac

return ret
