#compdef ohcli OHcli OHcli.py
# Documentation: https://github.com/humarf/OHsentinel/wiki/OHcli
# Reference accessed: 2026-05-19
# Verified: upstream OHsentinel wiki at the URL above. STUB: minimal.
# OHcli.py is a CLI for OpenHome (UPnP) devices, not OpenHPI.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '(-l --log)'{-l+,--log=}'[log destination]:dest:(file screen syslog systemd)' \
  '--loglevel=[log level]:level:(debug info warning error critical)' \
  '-u+[device UUID]:uuid:' \
  '-n+[device name]:name:' \
  '-t+[device type]:type:(product sender all)' \
  '-c+[command to execute]:command:' \
  '*-i+[input argument Name=Value]:input:' \
  '*-o+[output parameter]:output:' \
  '-r+[remote OHsentinel command]:cmd:' \
  '*:mode or arg:(command search explore remote)' && ret=0
return ret
