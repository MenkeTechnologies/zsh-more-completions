#compdef getsebool
# _getsebool — SELinux getsebool (print state of SELinux booleans; -a all booleans, -V version, -h help; positional argument is one or more boolean names; companion to setsebool(8) for runtime policy customization)
# upstream: https://github.com/SELinuxProject/selinux
# Flags from SELinuxProject/selinux policycoreutils/sebool/getsebool.c on tip.

_getsebool() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-a[all booleans]' \
        '*:boolean:'
}

_getsebool "$@"
