#compdef prometheus-operator-admission-webhook admission-webhook
# _prometheus-operator-admission-webhook — Prometheus Operator validating webhook
# upstream: https://github.com/prometheus-operator/prometheus-operator
# Flags from cmd/admission-webhook/main.go on tip.

_prometheus-operator-admission-webhook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-auto-gomemlimit-ratio=[GOMEMLIMIT/cgroup-memory ratio (0 disables)]:f:' \
        '-name-validation-scheme=[Prometheus metric/label name validation]:scheme:(legacy utf8)' \
        '-promql-options=[comma-sep PromQL parser opts]:opts:(experimental-functions duration-expression-parsing extended-range-selectors binop-fill-modifiers)' \
        '-web.listen-address=[HTTP/HTTPS bind host\:port]:host\:port:' \
        '-web.tls-cert-file=[TLS cert file]:file:_files' \
        '-web.tls-key-file=[TLS key file]:file:_files' \
        '-web.client-ca-file=[client CA bundle]:file:_files' \
        '-web.tls-min-version=[minimum TLS version]:ver:(VersionTLS10 VersionTLS11 VersionTLS12 VersionTLS13)' \
        '-log-format=[log format]:fmt:(logfmt json)' \
        '-log-level=[log level]:level:(debug info warn error)'
}

_prometheus-operator-admission-webhook "$@"
