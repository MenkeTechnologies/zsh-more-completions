#compdef gf-cli gf
# _gf-cli — TomNomNom Tom Hudson gf-cli CLI command-line frontend wrapping the gf wrapper around grep open-source written in Go simple-Linux-grep-pattern-matching-with-pre-configured-templates patterns-XSS-SSRF-SQLi-RCE-LFI-redirect-debug_logic-img-traversal-base64-jsvar-php-errors-aws-keys-firebase-IDOR-CORS interactive-pattern-naming-mode patterns-JSON-format hide-line-numbers (TomNomNom team, Go); flag
# upstream: https://github.com/tomnomnom/gf

_gf-cli() {
    local -a patterns
    patterns=(
        'xss:cross-site scripting'
        'ssrf:server-side request forgery'
        'sqli:SQL injection'
        'rce:remote code execution'
        'lfi:local file inclusion'
        'redirect:open redirect'
        'debug_logic:debug logic'
        'img-traversal:image path traversal'
        'base64:base64 strings'
        'jsvar:JS variables'
        'php-errors:PHP errors'
        'aws-keys:AWS keys'
        'firebase:firebase URLs'
        'idor:IDOR'
        'cors:CORS'
        'http-auth:HTTP basic auth'
        'urls:URLs'
        'allow_url_include:PHP file inclusion'
        'meg-headers:meg headers'
        'json-sec:JSON sec patterns'
        '-list:list patterns'
        '-save:save current pattern'
        '-dump:dump pattern definition'
    )
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-list[list patterns]' \
        '-save+[save pattern name]:str:' \
        '-dump+[dump pattern]:str:' \
        '1:pattern:->p' \
        '*:files:_files'

    case $state in
        p) _describe -t patterns 'gf pattern' patterns ;;
    esac
}

_gf-cli "$@"
