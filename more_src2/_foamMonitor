#compdef foamMonitor
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamMonitor — live gnuplot of an OpenFOAM data file (residuals/probes/etc).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-ascii -a)'{-ascii,-a}'[show the graph by printing ASCII in the terminal]' \
    '(-columns -c)'{-columns,-c}'[display specified columns, comma-separated]:cols:' \
    '(-flip -f)'{-flip,-f}'[plot data on x-axis, independent variable on y-axis]' \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-logscale -l)'{-logscale,-l}'[plot y-axis on log scale (for residuals)]' \
    '(-once -o)'{-once,-o}'[print a graph one time without refreshing]' \
    '(-refresh -r)'{-refresh,-r}'[refresh display every N sec (default 10)]:time:' \
    '(-size -s)'{-size,-s}'[output plot size "640,480"]:size:' \
    '(-title -t)'{-title,-t}'[graph title (default "Data Monitoring")]:title:' \
    '(-yrange -y)'{-yrange,-y}'[y-axis data range "[0:1]"]:range:' \
    '*:data file:_files' \
    && ret=0

return ret
