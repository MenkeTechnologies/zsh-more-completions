#compdef dspy
# _dspy — Omar Khattab Stanford DSPy programming model for declarative LM pipelines with compiled prompt/weights optimization (stanfordnlp team, Python); argparse
# upstream: https://github.com/stanfordnlp/dspy

_dspy() {
    local -a sub=(
        'compile:compile a DSPy program'
        'serve:serve a DSPy module'
        'init:initialize a DSPy project'
        'eval:evaluate program performance'
        'optimize:run optimizer'
        'inspect:inspect program traces'
        'cache:cache subcommands'
        'config:configuration subcommands'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--lm=+[language model id]:str:' \
        '--rm=+[retrieval model id]:str:' \
        '--cache-dir=+[cache dir]:dir:_files -/' \
        '--no-cache[disable cache]' \
        '--temperature=+[F]:f:' \
        '--max-tokens=+[N]:n:' \
        '--api-key=+[API key]:str:' \
        '--api-base=+[API base URL]:url:_urls' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--seed=+[N]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dspy subcommand' sub ;;
        args)
            case $words[1] in
                compile|optimize) _arguments \
                    '--optimizer=+[optimizer]:o:(BootstrapFewShot BootstrapFewShotWithRandomSearch COPRO MIPRO MIPROv2 GRPO Ensemble SignatureOptimizer LabeledFewShot)' \
                    '--trainset=+[trainset file]:file:_files' \
                    '--valset=+[valset file]:file:_files' \
                    '--metric=+[metric name]:str:' \
                    '--num-threads=+[N]:n:' \
                    '--save=+[save file]:file:_files' \
                    '*:program:_files -g "*.py"' ;;
                eval) _arguments \
                    '--devset=+[devset file]:file:_files' \
                    '--metric=+[metric]:str:' \
                    '--num-threads=+[N]:n:' \
                    '*:program:_files -g "*.py"' ;;
                serve) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--workers=+[N]:n:' \
                    '*:program:_files -g "*.py"' ;;
                cache) _arguments '1:cache cmd:(clear list path)' ;;
                config) _arguments '1:config cmd:(get set unset list)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_dspy "$@"
