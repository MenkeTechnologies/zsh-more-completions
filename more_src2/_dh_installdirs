#compdef dh_installdirs
# Documentation: https://manpages.debian.org/dh_installdirs
# Source: Debian/debhelper dh_installdirs — create directories in package build directories (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '-A[apply files to all -p packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '--sourcedir=-[source directory]:dir:_files -/' \
    '(--no-create-in-sourcedir)--create-in-sourcedir[also create dirs in source dir]' \
    '--no-create-in-sourcedir[do not create dirs in source dir]' \
    '*-O+[passthrough option]:opt:_default' \
    '*:directory to create:_files -/' \
    && ret=0

return ret
