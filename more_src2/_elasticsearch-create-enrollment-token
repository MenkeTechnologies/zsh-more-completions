#compdef elasticsearch-create-enrollment-token
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/create-enrollment-token.html
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  {-s,--scope}'[scope of the enrollment token]:scope:(node kibana)' \
  {-f,--force}'[force token creation against an unhealthy cluster]' \
  '--url[specify the Elasticsearch URL to connect to]:url' \
  '-E[configure a setting]:setting' \
  && return 0
