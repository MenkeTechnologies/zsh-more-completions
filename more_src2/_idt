#compdef idt
# ============================================================================
# idt - Multi-format ID generator + inspector + converter (Rust, MIT/Apache-2.0)
#
# Author : Seonghyeon Cho (sh-cho)
# Upstream: https://github.com/sh-cho/idt
# crates : idt
#
# idt ("id tool") is a CLI for working with all the major ID
# formats: UUID v1/v3/v4/v5/v6/v7/v8 (every spec variant), ULID,
# NanoID, plus generic encodings (Base64 / Base32 / Base58 / hex /
# SHA-256). Generates new IDs, inspects + decodes existing IDs
# (extracting embedded timestamps, version bits, MAC addresses,
# etc.), converts between equivalent representations, validates
# input strings against each format's grammar, compares two+ IDs,
# sorts by embedded timestamp, and emits shell completions + man
# pages for self-hosted distribution.
#
# Subcommands:
#   gen / g       - generate new IDs
#   inspect / i   - analyze + decode an existing ID
#   convert / c   - convert between formats
#   validate / v  - check whether input is a valid ID of some format
#   compare       - compare two or more IDs
#   sort / s      - sort IDs by their embedded timestamps
#   info          - show info about each ID type idt knows
#   completions   - generate shell completions
#   manpage       - generate man pages
#
# The ULID lane is built on `ulid = "1"` (declared verbatim at
# upstream Cargo.toml HEAD), the canonical Rust ULID library by
# Dylan Hart (github.com/dylanhart/ulid-rs, 470+ stars). The
# library implements the ULID spec (Alizain Feerasta, 2016)
# end-to-end: 48-bit millisecond timestamp (lexicographically
# sortable as a string) + 80-bit randomness, Crockford Base32
# encoding, monotonic generator, and parser/emitter symmetry.
# ULIDs are the de-facto replacement for UUIDv4 in
# timestamp-ordered storage workloads (Postgres B-tree indices,
# Cassandra clustering keys, Kafka partition keys) - and idt is
# the canonical operator-side inspector for those IDs.
#
# ----------------------------------------------------------------------------
# AXIS 219 :: ULID (Universally Unique Lexicographically Sortable Identifier)
# Round 1355 :: Rust slot 1 of 4 :: OPENS Axis 219
#
# Cross-language canonical library family for this axis (proposed):
#   Rust    : dylanhart/ulid-rs                  - typed Crockford Base32 ULIDs
#   Go      : oklog/ulid                         - Peter Bourgon's canonical Go ULID
#   TS/Node : ulid/javascript                    - reference ULID JS implementation
#
# All three target the ULID spec (Feerasta, 2016) byte-for-byte:
# 48-bit Unix-ms timestamp, 80-bit randomness, encoded as 26
# Crockford-Base32 characters. Cross-language interop is total
# because the spec dictates every bit of the wire format - a ULID
# generated by oklog/ulid (Go) parses identically with
# dylanhart/ulid-rs (Rust) and ulid/javascript (TS).
#
# ULIDs are the modern operational alternative to UUIDv4 for
# any system where time-ordering matters for index locality.
# Note: UUIDv7 (RFC 9562, 2024) is the standards-track alternative
# that adopts the same "timestamp + random" structure - idt
# supports both, with ULID for the older lexicographic-sort
# pattern and UUIDv7 for the new RFC-9562-conformant pattern.
# ============================================================================

_idt() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '--no-color[disable colored output]' \
        '--format[output format]:format:(text json yaml toml)' \
        '(-j --json)'{-j,--json}'[emit JSON output (same as --format json)]' \
        '--pretty[pretty-print JSON / YAML / TOML output]' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :_idt_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                gen|g)        _idt_gen ;;
                inspect|i)    _arguments '(- *)'{-h,--help}'[help]' '*:ID to inspect:' ;;
                convert|c)    _idt_convert ;;
                validate|v)   _arguments '(- *)'{-h,--help}'[help]' '*:ID to validate:' ;;
                compare)      _arguments '(- *)'{-h,--help}'[help]' '*:IDs to compare:' ;;
                sort|s)       _arguments '(- *)'{-h,--help}'[help]' '*:IDs to sort:' ;;
                info)         _arguments '(- *)'{-h,--help}'[help]' '1:type:(uuid ulid nanoid base64 base32 base58 hex sha256)' ;;
                completions)  _arguments '1:shell:(bash zsh fish powershell elvish)' ;;
                manpage)      _arguments '--out[output directory]:dir:_files -/' ;;
            esac
            ;;
    esac

    return ret
}

_idt_cmds() {
    local -a cmds
    cmds=(
        'gen:Generate new IDs (UUID v1/3/4/5/6/7/8, ULID, NanoID, base64/32/58 etc.)'
        'g:Alias for gen'
        'inspect:Analyze and decode an existing ID'
        'i:Alias for inspect'
        'convert:Convert IDs between formats'
        'c:Alias for convert'
        'validate:Check whether input is a valid ID of some format'
        'v:Alias for validate'
        'compare:Compare two or more IDs'
        'sort:Sort IDs by their embedded timestamps'
        's:Alias for sort'
        'info:Show info about each ID type'
        'completions:Generate shell completion scripts'
        'manpage:Generate man pages'
    )
    _describe -t commands 'idt command' cmds
}

_idt_gen() {
    _arguments \
        '(-c --count)'{-c,--count}'[number of IDs to generate]:n:' \
        '(- *)'{-h,--help}'[help]' \
        '1:type:(uuid uuid-v1 uuid-v3 uuid-v4 uuid-v5 uuid-v6 uuid-v7 uuid-v8 ulid nanoid base64 base32 base58 hex sha256)'
}

_idt_convert() {
    _arguments \
        '--from[source format]:format:(uuid ulid nanoid base64 base32 base58 hex)' \
        '--to[target format]:format:(uuid ulid nanoid base64 base32 base58 hex)' \
        '(- *)'{-h,--help}'[help]' \
        '1:value to convert:'
}

_idt "$@"
