#compdef gmtflexure
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/gmtflexure.html
# Source: GenericMappingTools/gmt supplements/potential — 1-D plate-flexure solver.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-D+[densities mantle/load/infill/water]:densities:_default' \
    '-E+[elastic thickness (m/km) or flexural rigidity]:thickness:_default' \
    '-Q+[vertical load (none/file/topography)]:opts:_default' \
    '-A+[boundary conditions]:bc:_default' \
    '-C+[Poisson ratio / Young modulus]:opts:_default' \
    '-F+[constant horizontal in-plane force]:F:_default' \
    '-L[variable restoring force by deflection sign]' \
    '-M+[horizontal/vertical units]:opts:_default' \
    '-S[compute curvature]' \
    '-T+[pre-existing deformation file]:file:_files' \
    '*-V[verbose (stackable)]' \
    '-W+[water depth]:depth:_default' \
    '-Z+[observation level from undeformed surface]:level:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-o+[output column selection]:cols:_default' \
    '*:input table:_files' \
    && ret=0

return ret
