#compdef mrcheckerboardmask
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrcheckerboardmask.html
# Source: MRtrix3/mrtrix3 cmd/mrcheckerboardmask.cpp — checkerboard binary mask from a template image (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-tiles+[number of tiles in any direction]:n:_default' \
    '-invert[invert output binary mask]' \
    '-nan[use NaN as the output zero value]' \
    '1:input (template image):_files -g "*.{nii,nii.gz,mif}"' \
    '2:output (binary mask):_files' \
    && ret=0

return ret
