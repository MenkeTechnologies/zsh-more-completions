#compdef lxqt-archiver
# Documentation: https://github.com/lxqt/lxqt-archiver
# Reference accessed: 2026-05-19
# Verified: upstream src/main.cpp GOptionEntry table.

# lxqt-archiver: lightweight archive manager
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-a --add-to)'{-a+,--add-to=}'[add files to the specified archive and quit]:archive:_files' \
  '(-d --add)'{-d,--add}'[add files asking the name of the archive and quit]' \
  '(-e --extract-to)'{-e+,--extract-to=}'[extract archives to the specified folder and quit]:folder:_files -/' \
  '(-f --extract)'{-f,--extract}'[extract archives asking the destination folder and quit]' \
  '(-h --extract-here)'{-h,--extract-here}'[extract contents in the archive folder and quit]' \
  '--default-dir=[default folder for --add and --extract commands]:folder:_files -/' \
  '--force[create destination folder without asking confirmation]' \
  '--help[show help]' \
  '--version[show version]' \
  '*:file:_files' && ret=0
return ret
