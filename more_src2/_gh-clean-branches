#compdef gh-clean-branches gh-clone-org gh-combine-prs gh-install gh-montage gh-repo-stats
# Documentation: upstream READMEs at github.com/{davidraviv/gh-clean-branches,matt-bartel/gh-clone-org,rnorth/gh-combine-prs,redraw/gh-install,andyfeller/gh-montage,mona-actions/gh-repo-stats}
# Reference accessed: 2026-05-30
# gh-extension family round 5. Companions to rounds 158-161 multi-stems and
# the pre-existing _gh-poi/_gh-notify/_gh-dash/etc files. Sourced from
# topics/gh-extension Shell-language star listing.
# Hunt-defer log this round:
#   gh-pr-review (agynio/gh-pr-review) — README describes "command
#     categories" (Review Management / Comment Threading / Thread
#     Resolution) without naming specific subcommands or flags. Defer
#     per the gh-grep / gh-aw / gh-actions-importer precedent.
#   gh-branch (mislav/gh-branch) — bare `gh branch` interactive fzf
#     switcher with no documented flags. Defer.
#   gh-net (github/gh-net) — ARCHIVED 2023-10-20, README states it's
#     bare `gh net` only. Skip per archived-no-surface precedent.
#   gh-gei (github/gh-gei) — Migration CLI with 4 sub-extensions
#     (ado2gh / bbs2gh / gl2gh / gei) and a generate-script
#     subcommand; README enumerates environment variables but no
#     specific CLI flag inventory. Defer.

local curcontext="$curcontext" state line ret=1

case $service in

  gh-clean-branches)
    # davidraviv/gh-clean-branches — delete local branches missing upstream
    # and unpushed commits.
    _arguments -s -S \
      '--dry-run[preview branches marked for deletion]' \
      '--force[force delete via git branch -D (overrides safety)]' \
      '--verbose[detailed logging]' \
      && ret=0
    ;;

  gh-clone-org)
    # matt-bartel/gh-clone-org — clone all repos in an organization.
    #   gh clone-org [-t TOPIC] [-s QUERY] [-p PATH] [-y] [-n] ORG
    _arguments -s -S \
      '(-h --help)-h[show help]' \
      '(-h --help)--help[show help]' \
      '(-t --topic)-t+[filter repos by topic]:topic:' \
      '(-t --topic)--topic=[filter repos by topic]:topic:' \
      '(-s --search)-s+[GitHub search query (overrides --topic)]:query:' \
      '(-s --search)--search=[GitHub search query (overrides --topic)]:query:' \
      '(-p --path)-p+[clone destination (default cwd)]:path:_files -/' \
      '(-p --path)--path=[clone destination (default cwd)]:path:_files -/' \
      '(-y --yes)-y[skip confirmation prompts]' \
      '(-y --yes)--yes[skip confirmation prompts]' \
      '(-n --dry-run)-n[preview without cloning]' \
      '(-n --dry-run)--dry-run[preview without cloning]' \
      '1:organization:' \
      && ret=0
    ;;

  gh-combine-prs)
    # rnorth/gh-combine-prs — combine multiple PRs into one (e.g. Dependabot).
    # ARCHIVED 2025-12-23 — surface is stable but defer-able. Keeping it
    # because the surface is well-documented and the archived date is
    # recent enough that users may still have the binary installed.
    _arguments -s -S \
      '--query=[PR search query (required, e.g. author:app/dependabot)]:query:' \
      '--selected-pr-numbers=[target specific PRs (comma-separated)]:numbers:' \
      '--limit=[max combined PRs (default 50)]:N:' \
      '--skip-pr-check[combine regardless of check status]' \
      && ret=0
    ;;

  gh-install)
    # redraw/gh-install — install binary/.deb releases from a GitHub repo.
    # Honors $GH_BINPATH (default $HOME/.local/bin).
    _arguments -s -S \
      '1:user/repo:' \
      && ret=0
    ;;

  gh-montage)
    # andyfeller/gh-montage — avatar montage from GitHub org/team/file.
    #   gh montage <organization>
    #   gh montage <organization>/<team>
    #   gh montage <path/to/username_file>
    # Requires ImageMagick 7.1.0+.
    _arguments -s -S \
      '(-a --avatar-pixels)-a+[avatar size in pixels (default 48)]:N:' \
      '(-a --avatar-pixels)--avatar-pixels=[avatar size in pixels (default 48)]:N:' \
      '(-m --montage-width)-m+[montage width in avatar count (default 58)]:N:' \
      '(-m --montage-width)--montage-width=[montage width in avatar count (default 58)]:N:' \
      '(-o --output-file)-o+[output filename (without .jpg)]:name:' \
      '(-o --output-file)--output-file=[output filename (without .jpg)]:name:' \
      '(-f --force)-f[overwrite existing files]' \
      '(-f --force)--force[overwrite existing files]' \
      '(-d --debug)-d[enable debugging output]' \
      '(-d --debug)--debug[enable debugging output]' \
      '1:organization, org/team, or path to username file:_files' \
      && ret=0
    ;;

  gh-repo-stats)
    # mona-actions/gh-repo-stats — repository statistics for migrations.
    #   gh repo-stats --org <ORG_NAME>
    # The README enumerates output capabilities (CSV / tables / JSON)
    # but only names --org as the explicit CLI flag. Conservative
    # completion: surface only what is documented.
    _arguments -s -S \
      '--org=[organization name]:org:' \
      && ret=0
    ;;

esac

return ret
