#compdef jaeger-anonymizer
# _jaeger-anonymizer — Jaeger trace anonymizer (jaegertracing/jaeger)
# upstream: https://github.com/jaegertracing/jaeger
# Flags from cmd/anonymizer/app/flags.go (cobra) on tip.

_jaeger-anonymizer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--query-host-port=[jaeger-query gRPC endpoint host\:port]:host\:port:' \
        '--output-dir=[directory for anonymized output]:dir:_files -/' \
        '--trace-id=[trace ID to anonymize]:id:' \
        '--max-spans-count=[max spans to fetch from query]:n:' \
        '--hash-standard-tags[hash standard span tags]' \
        '--hash-custom-tags[hash custom span tags]' \
        '--hash-logs[hash span logs]' \
        '--hash-process[hash process tags]' \
        '--start-time=[start time (unix microseconds)]:n:' \
        '--end-time=[end time (unix microseconds)]:n:'
}

_jaeger-anonymizer "$@"
