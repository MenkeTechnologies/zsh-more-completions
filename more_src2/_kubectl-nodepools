#compdef kubectl-nodepools
# Documentation: https://github.com/grafana/kubectl-nodepools
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-nodepools: list Kubernetes node pools. Subcommands list/nodes,
# -l/--label, plus default kubectl flags (e.g. --context). No --namespace.
local curcontext="$curcontext" state line ret=1
local -a commands
commands=(
  'list:list node pools'
  'nodes:list nodes in a pool'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-l --label)'{-l+,--label=}'[node-pool label key]:label:' \
  '--context=[kubectl context]:context:' \
  '--kubeconfig=[kubeconfig path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'kubectl-nodepools command' commands && ret=0 ;;
esac
return ret
