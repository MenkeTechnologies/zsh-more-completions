#compdef pulsemixer
# _pulsemixer-bin — pulsemixer ncurses PulseAudio mixer (Python); sinks/sources/clients control without GUI
# upstream: https://github.com/GeorgeFilipkin/pulsemixer

_pulsemixer-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--server+[PulseAudio server]:host:_hosts' \
        '--list[list all sinks/sources/cards/clients]' \
        '--list-sinks[list sinks]' \
        '--list-sources[list sources]' \
        '--id+[sink/source id]:id:' \
        '--name+[sink/source name]:name:' \
        '--get-volume[print current volume]' \
        '--set-volume+[set volume %]:n:' \
        '--change-volume+[change volume by %]:n:' \
        '--get-mute[print mute status]' \
        '--mute[mute]' \
        '--unmute[unmute]' \
        '--toggle-mute[toggle mute]' \
        '--max-volume+[max volume]:n:' \
        '--set-default+[set default sink/source]:name:' \
        '--unlock-channels[allow independent channel volume]' \
        '--config+[config file]:file:_files' \
        '--no-mouse[disable mouse support]' \
        '--color+[color theme]:theme:'
}

_pulsemixer-bin "$@"
