#compdef dwibiascorrect
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwibiascorrect.html
# Source: MRtrix3/mrtrix3 bin/dwibiascorrect — DWI B1 bias correction dispatcher (Python, ants|fsl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[bias-field estimation mask]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-bias+[output estimated bias field]:image:_files' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '1:algorithm:(ants fsl)' \
    '2:input DWI:_files -g "*.{nii,nii.gz,mif}"' \
    '3:output DWI:_files' \
    && ret=0

return ret
