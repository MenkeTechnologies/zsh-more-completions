#compdef glances
# _glances — Nicolas Hennion's glances (curses + web-UI cross-platform system monitor; standalone/client/server/webserver/SNMP modes)
# upstream: https://github.com/nicolargo/glances
# Flags from glances/main.py on tip (argparse); honors --config (default /etc/glances/glances.conf or ~/.config/glances/glances.conf).

_glances() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version and exit]' \
        '(-d --debug)'{-d,--debug}'[enable debug logging]' \
        '(-C --config)'{-C+,--config=}'[config file path]:file:_files' \
        '(-P --plugins)'{-P+,--plugins=}'[load plugins from directory]:dir:_files -/' \
        '--modules-list[list available modules and exit]' \
        '--disable-plugin=[comma-separated plugins to disable]:list:' \
        '--enable-plugin=[comma-separated plugins to enable]:list:' \
        '--disable-process[disable process plugin]' \
        '--disable-webui[disable embedded web UI]' \
        '--light[lighter display]' \
        '-0[disable IRIX-style CPU display]' \
        '-1[per-CPU display]' \
        '-2[disable left sidebar]' \
        '-3[disable quicklook]' \
        '-4[full quicklook display]' \
        '-5[disable top stats]' \
        '(-6 --meangpu)'{-6,--meangpu}'[show mean per-GPU stats]' \
        '--disable-history[disable history charts]' \
        '--disable-bold[disable bold fonts]' \
        '--disable-bg[disable background colors]' \
        '--enable-irq[enable IRQ plugin]' \
        '--enable-process-extended[detailed info for selected process]' \
        '--disable-separator[do not draw plugin separators]' \
        '--disable-cursor[hide the selection cursor]' \
        '--arrow-keys-sort[use arrow keys to sort processes]' \
        '--sort-processes=[default process sort key]:key:(cpu_percent memory_percent username io_counters name)' \
        '--programs[group processes by program name]' \
        '--export=[exporters to enable (comma-separated)]:list:(csv json influxdb influxdb2 cassandra opentsdb statsd rabbitmq mqtt kafka prometheus elasticsearch graph zeromq couchdb riemann graphite)' \
        '--export-csv-file=[CSV file path]:file:_files' \
        '--export-csv-overwrite[overwrite existing CSV file]' \
        '--export-json-file=[JSON file path]:file:_files' \
        '--export-graph-path=[graph output directory]:dir:_files -/' \
        '--export-process-filter=[process filter for export]:regex:' \
        '(-c --client)'{-c+,--client=}'[run in client mode and connect to host]:host:_hosts' \
        '(-s --server)'{-s,--server}'[run in server mode]' \
        '--browser[run in browser mode (autodiscovery)]' \
        '--disable-autodiscover[disable Zeroconf server autodiscovery]' \
        '(-p --port)'{-p+,--port=}'[client/server/web port]:port:' \
        '(-B --bind)'{-B+,--bind=}'[server bind address]:ip:' \
        '-u+[username[:password]@hostname]:userhost:' \
        '--username[ask for client/server authentication username]' \
        '--password[ask for client/server authentication password]' \
        '--snmp-community=[SNMP community string]:str:' \
        '--snmp-port=[SNMP port]:port:' \
        '--snmp-version=[SNMP protocol version]:ver:(1 2c 3)' \
        '--snmp-user=[SNMPv3 username]:user:' \
        '--snmp-auth=[SNMPv3 auth proto]:proto:(MD5 SHA)' \
        '--snmp-force[force SNMP mode]' \
        '(-t --time)'{-t+,--time=}'[refresh interval (sec)]:sec:' \
        '(-w --webserver)'{-w,--webserver}'[run in web server mode]' \
        '--enable-mcp[expose MCP server endpoint]' \
        '--mcp-path=[MCP server URL prefix]:path:' \
        '--cached-time=[server cache TTL (sec)]:sec:' \
        '--stop-after=[stop after N refreshes]:n:' \
        '--open-web-browser[open browser when --webserver]' \
        '(-q --quiet)'{-q,--quiet}'[run quietly (no UI)]' \
        '(-f --process-filter)'{-f+,--process-filter=}'[process filter (regex)]:regex:' \
        '--process-focus=[focus on a single PID]:pid:' \
        '--process-short-name[show short command names]' \
        '--process-long-name[show full cmdline]' \
        '--stdout=[print stats to stdout]:plugin-list:' \
        '--stdout-json=[print stats to stdout as JSON]:plugin-list:' \
        '--stdout-csv=[print stats to stdout as CSV]:plugin-list:' \
        '--issue[run issue-report mode and exit]' \
        '--trace-malloc[trace memory allocations]' \
        '--memory-leak[show memory leaks before exit]' \
        '--api-doc[print REST API documentation]' \
        '--api-restful-doc[print RESTful API documentation]' \
        '--hide-kernel-threads[hide kernel threads from process view]' \
        '(-b --byte)'{-b,--byte}'[show network/disk in bytes/s]' \
        '--diskio-show-ramfs[include ramfs/tmpfs in diskio stats]' \
        '--diskio-iops[show diskio IOPS instead of B/s]' \
        '--diskio-latency[show diskio latency]' \
        '--fahrenheit[show temperatures in °F]' \
        '--fs-free-space[show free fs space instead of used]' \
        '--sparkline[render numeric values as sparklines]' \
        '--disable-unicode[disable Unicode in the UI]' \
        '--hide-public-info[hide public IP info]' \
        '--disable-config-exec[ignore on_<event> config-file scripts]'
}

_glances "$@"
