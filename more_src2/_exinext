#compdef exinext
# Documentation: https://manpages.debian.org/bookworm/exim4-base/exinext.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm exinext(8) manpage. Takes a single positional
# address or message-id argument; no CLI flags documented.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# exinext: print next-delivery time for a queued Exim message or address
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:address or message-id:' && ret=0
return ret
