#compdef particleshadergen
# Documentation: particleshadergen --help (Qt Quick 3D 6.x)
# Reference accessed: 2026-05-20
# Verified: local invocation of particleshadergen --help.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show help including generic Qt options]' \
  {-C+,--directory=}'[change working directory]:dir:_files -/' \
  {-v,--verbose}'[verbose output]' \
  {-n,--dry-run}'[run as normal but create no files]' \
  {-o+,--output-dir=}'[output directory for generated files]:dir:_files -/' \
  {-r+,--resource-file=}'[generated resource file name]:file:_files' && ret=0

return ret
