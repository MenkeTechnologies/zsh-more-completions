#compdef qlik-cli qlik
# _qlik-cli — Qlik qlik-cli CLI command-line frontend wrapping the Qlik Sense Enterprise SaaS Qlik Cloud Services REST API JSON-RPC managing apps spaces tenants users groups collections data-connections analytic-monitoring chart catalog data-files extensions notes alerts reload-tasks repository-service licensing identity-provider (Qlik team, Go); cobra
# upstream: https://qlik.dev/

_qlik-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'app:app management'
        'space:space management'
        'tenant:tenant management'
        'user:user management'
        'group:group management'
        'collection:collection management'
        'connection:data connection management'
        'data-file:data file operations'
        'extension:extension operations'
        'note:note operations'
        'reload:reload task operations'
        'license:license operations'
        'identity-provider:identity provider'
        'chart:chart operations'
        'sheet:sheet operations'
        'measure:measure operations'
        'dimension:dimension operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--server=+[url]:str:' \
        '--api-key=+[key]:str:' \
        '--bearer-token=+[token]:str:' \
        '--certificate-key=+[file]:file:_files' \
        '--certificate-client=+[file]:file:_files' \
        '--certificate-ca=+[file]:file:_files' \
        '--server-type=+[t]:t:(cloud windows)' \
        '--insecure[skip TLS verify]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '--context=+[name]:str:' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qlik-cli subcommand' sub ;;
        args)
            case $words[1] in
                app|space|tenant|user|group|collection|connection|data-file|extension|note|reload|chart|sheet|measure|dimension) _arguments '1:op:(list get create update delete reload publish unpublish import export copy)' '*:id:' ;;
            esac
            ;;
    esac
}

_qlik-cli "$@"
