#compdef mythmetadatalookup
# Documentation: https://github.com/MythTV/mythtv/blob/master/mythtv/programs/mythmetadatalookup/mythmetadatalookup_commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mythmetadatalookup: MythTV metadata/artwork lookup
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help,--usage}'[show help]' \
  '(- *)--version[show version]' \
  '--chanid=[channel ID]:id:' \
  '--starttime=[start time]:time:' \
  '(-j --jobid)'{-j,--jobid=}'[job ID]:id:' \
  '--refresh-all[refresh all default metadata]' \
  '--refresh-all-rules[refresh metadata only for rules without metadata]' \
  '--refresh-all-artwork[refresh artwork for all rules/recordings]' \
  '--refresh-all-artwork-dangerously[refresh artwork (re-download even if present)]' \
  '--refresh-rules[refresh metadata for one recording rule]' \
  '(-v --verbose)'{-v,--verbose=}'[log filtering]:level:' \
  '--logpath=[log to file]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[reduce logging]' \
  '--loglevel=[logging level]:level:(emerg alert crit err warning notice info debug trace)' \
  '--syslog=[syslog facility]:facility:' && ret=0
return ret
