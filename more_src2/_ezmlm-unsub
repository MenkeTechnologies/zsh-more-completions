#compdef ezmlm-unsub
# Documentation: https://untroubled.org/ezmlm/man/man1/ezmlm-unsub.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h+[hash value (1-99) for SQL sublist distribution]:hash:' \
  '-H[hash in normal range 0..52 (default)]' \
  '-m[use configured subscriber database (default)]' \
  '-M[use standard subscriber database]' \
  '-n[arguments are address+name pairs]' \
  '-N[arguments are addresses only (default)]' \
  '-S+[connect to given subscriber database plugin]:subdb:' \
  '-v[version]' \
  '-V[version]' \
  '1:dir:_files -/' \
  '*:address:' && ret=0

return ret
