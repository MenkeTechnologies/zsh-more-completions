#compdef dask-cli daskctl
# _dask-cli — Dask dask-cli daskctl CLI command-line frontend wrapping the Dask parallel computing framework Python providing scheduler worker info config tools listings cluster spec dask-worker dask-scheduler dask-ssh dask-cuda dask-cuda-worker dask-mpi dask-jobqueue Dask-yarn for distributed-DataFrame-Array-Bag-ML (Dask team, Python); click
# upstream: https://www.dask.org/

_dask-cli() {
    local -a sub=(
        'scheduler:run a scheduler'
        'worker:run a worker'
        'cluster:cluster management'
        'docs:open docs'
        'info:show client info'
        'config:configuration'
        'tls:TLS operations'
        'cuda:dask-cuda operations'
        'mpi:dask-mpi operations'
        'ssh:dask-ssh operations'
        'jobqueue:dask-jobqueue operations'
        'yarn:dask-yarn operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--host=+[host]:_hosts' \
        '--port=+[port]:n:' \
        '--dashboard-address=+[host:port]:str:' \
        '--scheduler-address=+[host:port]:str:' \
        '--nthreads=+[N]:n:' \
        '--nworkers=+[N]:n:' \
        '--memory-limit=+[bytes]:str:' \
        '--name=+[name]:str:' \
        '--listen-address=+[host:port]:str:' \
        '--contact-address=+[host:port]:str:' \
        '--protocol=+[p]:p:(tcp tls inproc ucx)' \
        '--tls-ca-file=+[file]:file:_files' \
        '--tls-cert=+[file]:file:_files' \
        '--tls-key=+[file]:file:_files' \
        '--no-dashboard[disable dashboard]' \
        '--no-show[no show client]' \
        '--idle-timeout=+[duration]:str:' \
        '--worker-class=+[name]:str:' \
        '--preload=+[module]:str:' \
        '--scheduler-file=+[file]:file:_files' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml table)' \
        '--format=+[format]:f:(json yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dask-cli subcommand' sub ;;
    esac
}

_dask-cli "$@"
