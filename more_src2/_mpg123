#compdef mpg123
# Documentation: mpg123 --help (mpg123 1.33)
# Source: mpg123 — high performance MPEG 1.0/2.0/2.5 audio player for Layers 1, 2 and 3.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-v[increase verbosity level]' \
    '-q[quiet (do not print title)]' \
    '-t[testmode (no output)]' \
    '-s[write to stdout]' \
    '-w+[write output as WAV file]:file:_files' \
    '-k+[skip first N frames]:n:' \
    '-n+[decode only N frames]:n:' \
    '-c[check range violations]' \
    '-y[disable resync on errors]' \
    '-b+[output buffer (Kbytes)]:n:' \
    '-f+[change scalefactor]:n:' \
    '-r+[set/force samplerate]:rate:' \
    '-o+[select output module]:module:' \
    '-a+[set audio device]:device:' \
    '(-2 -4)-2[downsample 1:2 (22 kHz)]' \
    '(-2 -4)-4[downsample 1:4 (11 kHz)]' \
    '-d+[play every Nth frame only]:n:' \
    '-h+[play every frame N times]:n:' \
    '(-0 -1 -m)-0[decode channel 0 (left) only]' \
    '(-0 -1 -m)-1[decode channel 1 (right) only]' \
    '(-0 -1 -m)-m[mix both channels (mono)]' \
    '-p+[HTTP proxy]:proxy:' \
    '-@+[file containing filenames/URLs]:file:_files' \
    '(-z -Z)-z[shuffle play (with wildcards)]' \
    '(-z -Z)-Z[random play]' \
    '-u+[HTTP authentication string]:auth:' \
    '-E+[equalizer data file]:file:_files' \
    '-C[enable control keys]' \
    '--no-gapless[do not skip junk/padding in mp3s]' \
    '(- *)-?[show help]' \
    '(- *)--version[print name + version]' \
    '(- *)--longhelp[show extended help]' \
    '*:audio file or URL:_files -g "*.{mp3,mp2,mp1,m3u,pls}"' \
    && ret=0

return ret
