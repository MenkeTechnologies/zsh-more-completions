#compdef qp
# Documentation: https://github.com/Zweih/qp
# Reference accessed: 2026-05-20
# Verified: upstream README (Zweih/qp — installed-package query tool).

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--no-headers[omit column headers in table output]' \
  '--full-timestamp[display full timestamp (date and time)]' \
  '(--regen-cache --cache-only)--no-cache[disable cache loading and saving]' \
  '(--no-cache --cache-only)--regen-cache[force fresh data and save cache]' \
  '(--no-cache --regen-cache)--cache-only[update cache only]' \
  '*:: :->cmd' && ret=0

case $state in
  cmd)
    local -a commands=(
      'select:choose fields to display (alias s)'
      's:choose fields to display'
      'where:apply filtering queries (alias w)'
      'w:apply filtering queries'
      'order:sort results by field (alias o)'
      'o:sort results by field'
      'limit:restrict result count (alias l)'
      'l:restrict result count'
      'format:set output type (alias f)'
      'f:set output type'
    )
    _describe -t commands 'qp subcommand' commands && ret=0
    ;;
esac

return ret
