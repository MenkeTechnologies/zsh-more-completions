#compdef deadlock deadlock-bpfcc
# _deadlock — detect potential pthread mutex deadlocks (iovisor/bcc)
# upstream: https://github.com/iovisor/bcc
# Flags from tools/deadlock.py (argparse).

_deadlock() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '--binary=[binary to trace (defaults to /proc/<pid>/exe)]:file:_files'
        '--dump-graph=[dump the mutex wait-graph to this JSON file]:file:_files -g "*.json"'
        '--verbose[print mutex wait-graph statistics]'
        '--lock-symbols=[comma-separated lock symbol(s) (default pthread_mutex_lock)]:symbols:'
        '--unlock-symbols=[comma-separated unlock symbol(s) (default pthread_mutex_unlock)]:symbols:'
        '(-t --threads)'{-t+,--threads=}'[max threads to trace (default 65536)]:n:'
        '(-e --edges)'{-e+,--edges=}'[max edge cases to record (default 65536)]:n:'
        '(-s --stacktraces)'{-s+,--stacktraces=}'[max stack traces (rounded to next pow2)]:n:'
        '1:PID:'
    )
    _arguments $args
}

_deadlock "$@"
