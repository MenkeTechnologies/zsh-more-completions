#compdef kioclient kioclient5 kioclient6
# _kioclient — KIO kioclient (CLI for KIO operations: copy/move/remove/ls/cat/exec/mkdir/openProperties etc., transparently using KIO workers for sftp/smb/fish/desktop/trash protocols)
# upstream: https://invent.kde.org/frameworks/kio (src/kioclient)
# Subcommands from kio src/kioclient/kioclient.cpp on tip.

_kioclient() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--commands[list commands]' \
        '--overwrite[overwrite destination]' \
        '--noninteractive[never prompt]' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'kioclient command' '(copy move remove mkdir ls cat exec openProperties download upload sftp)' ;;
        args) _arguments '*:url:_files' ;;
    esac
}

_kioclient "$@"
