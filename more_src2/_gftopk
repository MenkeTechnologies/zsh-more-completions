#compdef gftopk gftype gftodvi
# Documentation: gftopk --help / gftype --help (TeX Live 2026)
# Source: TeX GF (generic font) tools — gftopk / gftype / gftodvi.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '-verbose[display progress reports]' \
    '(- *)-version[show version]' \
    '1:GF file:_files -g "*.gf"' \
    '2:output (PK or DVI):_files' \
    && ret=0

return ret
