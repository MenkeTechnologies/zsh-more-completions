#compdef fsck_fskit
# Documentation: https://keith.github.io/xcode-man-pages/fsck_fskit.8.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--progress[display fsck progress]' \
  '-t+[file system type]:fstype:(msdos exfat hfs apfs)' \
  '*:device:_files -g "/dev/(r)disk*"' && ret=0

return ret
