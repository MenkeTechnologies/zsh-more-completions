#compdef fetch-ebook-metadata
# Documentation: https://manual.calibre-ebook.com/generated/en/fetch-ebook-metadata.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '*'{-p,--allowed-plugin}'=[plugin]:plugin:(Google "Google Images" Amazon.com Edelweiss "Open Library" "Big Book Search")' \
  '(-a --authors)'{-a,--authors}'=[authors]:authors:' \
  '(-c --cover)'{-c,--cover}'=[cover output]:file:_files' \
  '*'{-I,--identifier}'=[identifier]:id:' \
  '(-i --isbn)'{-i,--isbn}'=[ISBN]:isbn:' \
  '(-o --opf)'{-o,--opf}'[OPF output]' \
  '(-d --timeout)'{-d,--timeout}'=[timeout]:seconds:' \
  '(-t --title)'{-t,--title}'=[title]:title:' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]'
