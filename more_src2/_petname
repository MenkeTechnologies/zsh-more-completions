#compdef petname
# Documentation: https://github.com/dustinkirkland/petname
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(-w --words)'{-w,--words=}'[number of words]:n:' \
  '(-l --letters)'{-l,--letters=}'[max chars per word]:n:' \
  '(-s --separator)'{-s,--separator=}'[separator]:char:' \
  '(-d --dir)'{-d,--dir=}'[word-list directory]:dir:_files -/' \
  '(-c --complexity)'{-c,--complexity=}'[complexity level]:level:(0 1 2)' \
  '(-u --ubuntu)'{-u,--ubuntu}'[Ubuntu-style alliterative naming]'
