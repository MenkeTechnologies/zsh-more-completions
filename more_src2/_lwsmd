#compdef lwsmd
# Documentation: man lwsmd(8)
# Source: josephholsten/pbis lwsm/server/main.c (master) — PBIS service manager daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--start-as-daemon[start as background process]' \
    '--syslog[log to syslog]' \
    '--logfile=[log file]:file:_files' \
    '--loglevel=[log level]:level:(error warning info verbose debug trace)' \
    '--container=[start as container for service group]:group:_default' \
    '--help[show help]' \
    && ret=0

return ret
