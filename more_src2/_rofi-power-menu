#compdef rofi-power-menu
# _rofi-power-menu — rofi-power-menu CLI shell wrapper presenting a rofi dmenu power menu listing shutdown reboot logout suspend hibernate lock confirmation prompts forwarded to systemctl loginctl swaylock i3lock executing user-selected action confirmation prompts for desktop integration (jluttine team, shell); getopt
# upstream: https://github.com/jluttine/rofi-power-menu

_rofi-power-menu() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--choices=+[ids]:str:' \
        '--choose=+[choice]:c:(shutdown reboot suspend hibernate logout lockscreen)' \
        '--confirm=+[choices]:str:' \
        '--symbols=+[s]:s:(font-awesome icon-name unicode)' \
        '--symbols-font=+[name]:str:' \
        '--no-symbols[no symbols]' \
        '--dry-run[print only do not run]' \
        '--show=+[choice]:c:(shutdown reboot suspend hibernate logout lockscreen)' \
        '*::'
}

_rofi-power-menu "$@"
