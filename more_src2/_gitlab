#compdef gitlab
# Documentation: https://github.com/NARKOZ/gitlab
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# ruby-gitlab / NARKOZ/gitlab CLI: passes method names from Gitlab::Client through to
# the GitLab REST API. Common methods include users, user, projects, project, issues,
# merge_requests, etc. Filter results with --only=FIELDS or --except=FIELDS.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--only=[only show fields]:fields' \
  '--except=[exclude fields]:fields' \
  '*:: :_files' && ret=0

return ret
