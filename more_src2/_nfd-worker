#compdef nfd-worker
# _nfd-worker — Node Feature Discovery per-node worker (kubernetes-sigs/node-feature-discovery)
# upstream: https://github.com/kubernetes-sigs/node-feature-discovery
# Flags from cmd/nfd-worker/main.go on tip.

_nfd-worker() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-config=[nfd-worker configuration file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-oneshot[run once and exit instead of looping]' \
        '-port=[gRPC server bind port]:port:' \
        '-options=[inline JSON config overrides]:json:' \
        '-no-publish[disable NodeFeature object publishing]' \
        '-no-owner-refs[do not set owner references on created objects]' \
        '*-feature-sources=[enabled feature sources]:source:(all cpu kernel memory network pci storage system usb custom local fake)' \
        '*-label-sources=[enabled label sources]:source:(all cpu kernel memory network pci storage system usb custom local fake)' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]'
}

_nfd-worker "$@"
