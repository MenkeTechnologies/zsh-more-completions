#compdef gopass-jsonapi
# Documentation: https://github.com/gopasspw/gopass-jsonapi
# Reference accessed: 2026-05-16
# Verified: upstream main.go.

# gopass-jsonapi: browser native messaging host for gopass
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'listen:run as native messaging host'
  'configure:configure browser integration'
  'version:show version'
  'help:show help'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'gopass-jsonapi command' commands && ret=0 ;;
  args)
    case $line[1] in
      configure)
        _arguments \
          '--browser=[browser]:browser:(chrome firefox)' \
          '--path=[gopass_wrapper.sh install path]:path:_files -/' \
          '--manifest-path=[manifest install path]:path:_files -/' \
          '--global[install for all users (requires root)]' \
          '--libpath=[library path for global install]:path:_files -/' \
          '--gopass-path=[path to gopass binary]:path:_files' \
          '--print[print installation summary]' && ret=0 ;;
    esac ;;
esac
return ret
