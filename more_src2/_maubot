#compdef mbc maubot
# _maubot — maubot Matrix bot framework CLI; manages instances, plugins, clients via maubot management API
# upstream: https://github.com/maubot/maubot

_maubot() {
    local -a sub=(
        'login:authenticate against a maubot server'
        'logout:remove saved credentials'
        'auth:obtain access token from a Matrix homeserver'
        'build:build a plugin from current directory'
        'upload:upload a plugin'
        'init:create plugin skeleton'
        'rpc:invoke management API'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'maubot subcommand' sub ;;
        args)
            case $words[1] in
                login|logout) _arguments \
                    '(-s --server)'{-s,--server}'+[server URL]:url:_urls' \
                    '(-u --username)'{-u,--username}'+[user]:user:' \
                    '(-p --password)'{-p,--password}'+[pass]:pass:' \
                    '(-a --alias)'{-a,--alias}'+[alias]:name:' ;;
                build) _arguments \
                    '(-u --upload)'{-u,--upload}'[upload after build]' \
                    '(-o --output)'{-o,--output}'+[output file]:file:_files' \
                    '(-s --server)'{-s,--server}'+[server]:url:_urls' ;;
            esac
            ;;
    esac
}

_maubot "$@"
