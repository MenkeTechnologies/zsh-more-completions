#compdef rocq
# Documentation: https://github.com/rocq-prover/rocq/blob/master/topbin/rocq.ml
# Documentation: https://github.com/rocq-prover/rocq/blob/master/topbin/rocqshim.ml
# Documentation: https://github.com/rocq-prover/rocq/blob/master/man/rocq.1
# Documentation: https://github.com/rocq-prover/rocq/blob/master/man/coqtop.1
# Reference accessed: 2026-05-27
# Verified: upstream rocq-prover/rocq master branch topbin/rocq.ml subcommand table

local curcontext="$curcontext" state line ret=1

local -a _rocq_subcommands
_rocq_subcommands=(
  'compile:Compile a Rocq source file'
  'c:Alias for compile'
  'repl:Interactive read-eval-print loop'
  'top:Alias for repl'
  'repl-with-drop:repl with Drop command'
  'top-with-drop:Alias for repl-with-drop'
  'native-precompile:Preprocess a compiled Rocq file for use by native_compute'
  'check:Check a compiled Rocq file (alias for rocqchk)'
  'votour:Low level debugging of compiled files'
  'preprocess-mlg:Preprocess Rocq grammar files (.mlg) to produce OCaml sources'
  'pp-mlg:Alias for preprocess-mlg'
  'dep:Print dependencies for compiling Rocq files'
  'doc:Generate documentation from a Rocq source file'
  'wc:Count lines of code in a Rocq source file'
  'workmgr:Control the number of parallel workers used by Rocq'
  'tex:Process Rocq code in a Latex document'
  'makefile:Generate a Makefile to compile a Rocq project'
  'timelog2html:Combine timing information and a Rocq source file'
)

_rocq_worker_args() {
  _arguments -s -S \
    '*-I+[add ML loadpath]:dir:_files -/' \
    '*-Q+[add local loadpath]:dir:_files -/:dirpath:' \
    '*-R+[add installed loadpath]:dir:_files -/:dirpath:' \
    '*-exclude-dir+[skip subdirectories]:dir:_files -/' \
    '-nois[start without loading Init.Prelude]' \
    '-noinit[alias for -nois]' \
    '-init-file+[use custom startup file]:file:_files' \
    '-q[skip loading rcfile]' \
    '-top+[set toplevel module name]:dirpath:' \
    '-topfile+[set the toplevel file name]:file:_files' \
    '*-require+[load a compiled library]:qualid:' \
    '*-ri+[load and import a library]:qualid:' \
    '*-require-import+[load and import a library]:qualid:' \
    '*-re+[load and transitively import a library]:qualid:' \
    '*-require-export+[load and transitively import a library]:qualid:' \
    '*-rfrom+[load from a specific directory]:root:' \
    '*-require-from+[load library from a directory]:root:' \
    '*-rifrom+[load and import from a directory]:root:' \
    '*-require-import-from+[load and import from a directory]:root:' \
    '*-refrom+[load and transitively import from a directory]:root:' \
    '*-require-export-from+[load and transitively import from a directory]:root:' \
    '*-l+[load a Rocq vernacular source]:file:_files -g "*.v"' \
    '*-load-vernac-source+[load a Rocq vernacular source]:file:_files -g "*.v"' \
    '*-lv+[verbosely load a Rocq vernacular source]:file:_files -g "*.v"' \
    '*-load-vernac-source-verbose+[verbosely load a Rocq vernacular source]:file:_files -g "*.v"' \
    '*-load-vernac-object+[obsolete synonym of -require]:lib:' \
    '*-load-ml-source+[load an ML source file]:file:_files' \
    '*-load-ml-object+[load an ML object file]:file:_files' \
    '*-arg+[pass option to compiler]:arg:' \
    '-batch[batch mode (exits after argument parsing)]' \
    '-compat+[provide compatibility with a previous version]:version:' \
    '-beautify[pretty-print the input file]' \
    '-color+[control color output]:when:(yes no auto)' \
    '-config[print Rocq configuration and exit]' \
    '-coqlib+[override default Rocq library directory]:dir:_files -/' \
    '-debug[turn on debugging]' \
    '-bt[print backtraces on errors]' \
    '-emacs[indicate execution under Emacs]' \
    '-filteropts[print remaining options after filtering]' \
    '-impredicative-set[set sort Set impredicative]' \
    '-indices-matter[universe-polymorphic inductives indices matter]' \
    '-mangle-names+[mangle names with a prefix]:prefix:' \
    '-native-compiler+[control native compilation]:mode:(yes no ondemand)' \
    '-native-output-dir+[output directory for native code]:dir:_files -/' \
    '-no-glob[do not emit glob files]' \
    '-dump-glob+[dump globalizations to a file]:file:_files' \
    '-m+[memory limit in MB]:mb:' \
    '-memory-limit+[set memory limit]:mb:' \
    '-o+[output file]:file:_files' \
    '-output-context[print the global vernacular context]' \
    '-profile+[write profile to file]:file:_files' \
    '-quick[generate vio quickly]' \
    '-schedule-vio-checking+[schedule vio checking]:n:' \
    '-schedule-vio2vo+[schedule vio2vo]:n:' \
    '*-set+[set a runtime flag]:flag:' \
    '*-unset+[unset a runtime flag]:flag:' \
    '-toploop+[use given toploop]:module:' \
    '-vio2vo[convert vio files to vo]' \
    '-w+[warning settings]:warnings:' \
    '-where[print Rocq standard library location and exit]' \
    '-v[print version and exit]' \
    '-version[print version and exit]' \
    '--version[print version and exit]' \
    '-print-version[print machine-readable version and exit]' \
    '--print-version[print machine-readable version and exit]' \
    '-boot[boot mode]' \
    '(- *)'{-h,-H,-help,--help}'[show help]' \
    '*:file:_files -g "*.v"' && ret=0
}

_arguments -C \
  '(- *)'{-v,--version}'[print human readable version info]' \
  '(- *)--print-version[print machine readable version info]' \
  '(- *)'{-h,-H,-help,--help}'[show help]' \
  '-debug-shim[print shim debug info]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'rocq subcommand' _rocq_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      compile|c|repl|top|repl-with-drop|top-with-drop|check|native-precompile)
        _rocq_worker_args
        ;;
      dep)
        _arguments -s -S \
          '*-I+[add ML loadpath]:dir:_files -/' \
          '*-Q+[add local loadpath]:dir:_files -/:dirpath:' \
          '*-R+[add installed loadpath]:dir:_files -/:dirpath:' \
          '-coqlib+[override default Rocq library directory]:dir:_files -/' \
          '-boot[boot mode]' \
          '-noglob[suppress glob output]' \
          '-f+[read a project file]:file:_files' \
          '-vos[expect vos compilation]' \
          '-dyndep+[dynamic dependency mode]:mode:(opt byte both none var)' \
          '-m+[meta directory]:dir:_files -/' \
          '-w+[warning settings]:warnings:' \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files -g "*.v"' && ret=0
        ;;
      doc)
        _arguments -s -S \
          '--html[produce HTML output]' \
          '--latex[produce LaTeX output]' \
          '--texmacs[produce TeXmacs output]' \
          '--dvi[produce DVI output]' \
          '--ps[produce PostScript output]' \
          '--pdf[produce PDF output]' \
          '--stdout[write to standard output]' \
          '-o+[output file]:file:_files' \
          '-d+[output directory]:dir:_files -/' \
          '-s[short table of contents]' \
          '-l[light mode]' \
          '-g[gallina mode]' \
          '-t+[title]:title:' \
          '--body-only[output body only]' \
          '--no-index[suppress index]' \
          '--no-preamble[suppress preamble]' \
          '--toc[generate table of contents]' \
          '--with-header+[use a header file]:file:_files' \
          '--with-footer+[use a footer file]:file:_files' \
          '*-Q+[add logical mapping]:dir:_files -/:dirpath:' \
          '*-R+[add recursive logical mapping]:dir:_files -/:dirpath:' \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files -g "*.(v|tex)"' && ret=0
        ;;
      makefile)
        _arguments -s -S \
          '-f+[read a project file]:file:_files' \
          '-o+[write Makefile to file]:file:_files' \
          '*-Q+[add logical mapping]:dir:_files -/:dirpath:' \
          '*-R+[add recursive mapping]:dir:_files -/:dirpath:' \
          '*-I+[add ML loadpath]:dir:_files -/' \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files' && ret=0
        ;;
      wc)
        _arguments '*:file:_files -g "*.v"' && ret=0
        ;;
      workmgr)
        _arguments -s -S \
          '-j+[max number of parallel jobs]:n:' \
          '(- *)'{-h,--help}'[show help]' \
          '*::arg:' && ret=0
        ;;
      tex)
        _arguments -s -S \
          '-o+[output file]:file:_files' \
          '-image+[coqtop binary to use]:file:_files' \
          '-w[ignore warnings]' \
          '-v[verbose]' \
          '(- *)'{-h,--help}'[show help]' \
          '*:file:_files -g "*.tex"' && ret=0
        ;;
      timelog2html)
        _arguments '*:file:_files' && ret=0
        ;;
      preprocess-mlg|pp-mlg)
        _arguments '*:file:_files -g "*.mlg"' && ret=0
        ;;
      votour)
        _arguments '*:file:_files -g "*.vo"' && ret=0
        ;;
      *)
        _files
        ;;
    esac
    ;;
esac

return ret
