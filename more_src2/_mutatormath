#compdef mutatormath
# _mutatormath — Erik van Blokland MutatorMath multidimensional interpolation CLI for processing .designspace files generating UFO instances from masters with non-orthogonal axes used in variable-font workflows (LettError team, Python); argparse
# upstream: https://github.com/LettError/MutatorMath

_mutatormath() {
    local -a sub=(
        'build:build instances from designspace'
        'check:check designspace'
        'list-axes:list designspace axes'
        'list-masters:list designspace masters'
        'list-instances:list designspace instances'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mutatormath subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--output=+[output dir]:dir:_files -/' \
                    '--no-info[no fontinfo update]' \
                    '--no-kerning[no kerning update]' \
                    '--no-mute[no mute]' \
                    '--bend[allow bend]' \
                    '--no-bend[no bend]' \
                    '--reset-base[reset base name]' \
                    '--report-only[report only]' \
                    '*:designspace:_files -g "*.designspace"' ;;
                check|list-axes|list-masters|list-instances) _arguments \
                    '*:designspace:_files -g "*.designspace"' ;;
            esac
            ;;
    esac
}

_mutatormath "$@"
