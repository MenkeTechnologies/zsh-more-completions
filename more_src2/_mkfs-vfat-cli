#compdef mkfs-vfat-cli mkfs.vfat-cli mkfs.fat-cli mkfs-fat-cli mkdosfs
# _mkfs-vfat-cli — dosfstools mkfs.vfat/mkfs.fat FAT filesystem creator CLI alias (dosfstools team, C); custom argparse
# upstream: https://github.com/dosfstools/dosfstools

_mkfs-vfat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-a[disable alignment]' \
        '-A[disable atari format]' \
        '--codepage=+[codepage]:n:' \
        '-b+[backup boot sector]:n:' \
        '-c[check for bad blocks]' \
        '-C[create image]' \
        '-D+[drive number]:n:' \
        '--variant=+[variant]:v:(standard atari)' \
        '-f+[number of FATs]:n:' \
        '-F+[FAT size]:n:(12 16 32)' \
        '-g+[geometry heads/sectors]:str:' \
        '-i+[volume id hex]:str:' \
        '--invariant[invariant write]' \
        '-I[ignore safety check]' \
        '-l+[bad blocks file]:file:_files' \
        '-m+[message file]:file:_files' \
        '-M+[fat media type]:n:' \
        '--mbr=+[bool]:b:(y yes n no auto)' \
        '-n+[volume name]:str:' \
        '--offset=+[sectors]:n:' \
        '-r+[root dir entries]:n:' \
        '-R+[reserved sectors]:n:' \
        '-s+[sectors per cluster]:n:' \
        '-S+[logical sector size]:n:' \
        '-v[verbose]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper,loop}*"'
}

_mkfs-vfat-cli "$@"
