#compdef plasmashell
# Documentation: https://invent.kde.org/plasma/plasma-workspace/-/blob/master/shell/main.cpp
# Reference accessed: 2026-05-20
# Verified: upstream source at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--help-all[show all help options]' \
  '(- *)--version[show version]' \
  '--replace[replace an existing instance]' \
  '(-n --no-respawn)'{-n,--no-respawn}'[do not restart plasma-shell after a crash]' \
  '(-p --shell-plugin)'{-p+,--shell-plugin=}'[force loading the given shell plugin]:plugin:(org.kde.plasma.desktop org.kde.plasma.mobile)' \
  '(-d --qmljsdebugger)'{-d,--qmljsdebugger}'[enable QML JavaScript debugger]' \
  '--feedback[lists the available options for user feedback]' && ret=0

return ret
