#compdef flowcap num2dot rwguess
# Documentation: upstream tools.netsa.cert.org/silk/{flowcap,num2dot,
# rwguess}.html
# Reference accessed: 2026-05-30 via WebFetch.
# CERT NetSA SiLK R92 — 3-stem multi-binary harvest covering the
# remaining auxiliary SiLK pipeline binaries: flowcap (NetFlow/IPFIX
# capture daemon), num2dot (integer-IP → dotted-decimal converter),
# rwguess (deprecated SNMP-interface summarizer).

local curcontext="$curcontext" state line ret=1

case $service in

  flowcap)
    # NetFlow/IPFIX capture daemon — collects flow records into
    # files for processing by rwsender(8) downstream.
    local -a _log_levels _log_dest_keywords
    _log_levels=( emerg alert crit err warning notice info debug )
    _log_dest_keywords=( none stdout stderr syslog both )
    _arguments -s -S \
      '--destination-directory=[directory for aggregated packed flow files]:dir:_directories' \
      '--sensor-configuration=[sensor configuration file]:file:_files' \
      '--max-file-size=[approximate maximum flowcap file size]:size:' \
      '--probes=[comma-separated probe names (default all)]:probes:' \
      '--timeout=[maximum duration output files remain open (default 60s)]:seconds:' \
      '--clock-time=[close files at predictable times (optional offset)]:offset:' \
      '--fc-version=[IPv4 flow file record version]:version:(2 3 4 5)' \
      '--freespace-minimum=[minimum free space on FS (default 1GB)]:size:' \
      '--space-maximum-percent=[max filesystem usage percent (default 98)]:percent:' \
      '--compression-method=[output compression]:method:(none zlib lzo1x snappy best)' \
      '--verify-sensor-config=[validate sensor config (optional VERBOSE)]:level:' \
      '--log-destination=[log destination]:destination:($_log_dest_keywords)' \
      '--log-directory=[directory for rotated logs]:dir:_directories' \
      '--log-pathname=[non-rotating log file]:file:_files' \
      '--log-level=[log severity threshold]:level:($_log_levels)' \
      '--log-sysfacility=[syslog facility number]:N:' \
      '--log-basename=[custom application name in log filenames]:basename:' \
      '--log-post-rotate=[command to run on rotated log files (default gzip)]:command:' \
      '--pidfile=[process ID file]:file:_files' \
      '--no-chdir[do not chdir to / during daemon init]' \
      '--no-daemon[run in foreground]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' && ret=0
    ;;

  num2dot)
    # Convert integer-format IP addresses in textual SiLK output to
    # dotted-decimal notation. IPv6 not supported (use PySiLK).
    _arguments -s -S \
      '--ip-fields=[column numbers containing IPs (default 1; up to 3)]:fields:' \
      '--delimiter=[input column delimiter (default |)]:char:' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:textual input file:_files' && ret=0
    ;;

  rwguess)
    # DEPRECATED since SiLK 3.8.3 (will be removed in v4.0) — use
    # rwpdu2silk(1) + rwstats(1) or rwuniq(1) instead.
    # Summarizes SNMP-interface usage in NetFlow v5 PDU input.
    _arguments -s -S \
      '--top=[show top N interfaces (default 10)]:N:' \
      '--print-all[show all SNMP interfaces by number (not by frequency)]' \
      '(- *)--help[show help]' \
      '(- *)--version[show version]' \
      '*:NetFlow v5 PDU file:_files' && ret=0
    ;;

esac

return ret
