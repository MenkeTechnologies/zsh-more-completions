#compdef ppm2tiff
# Documentation: ppm2tiff (libtiff)
# Source: convert PPM/PGM/PBM to TIFF.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-r+[rows per strip]:n:' \
    '-R+[x&y resolution dpi]:dpi:' \
    '-c+[compression scheme]:scheme:(jpeg lzw zip packbits g3 g4 none)' \
    ':input.ppm:_files -g "*.(ppm|pgm|pbm)"' \
    ':output.tif:_files -g "*.(tif|tiff)"' \
    && ret=0

return ret
