#compdef readeck
# _readeck — Olivier Meunier readeck self-hosted bookmark and read-it-later manager with content extraction (readeck team, Go); cobra
# upstream: https://codeberg.org/readeck/readeck

_readeck() {
    local -a sub=(
        'serve:run the http server'
        'config:configuration subcommands'
        'doc:generate documentation'
        'jobs:job subcommands'
        'user:user subcommands'
        'tokens:token subcommands'
        'adduser:create a user'
        'login:create a session login token'
        'metrics:show metrics'
        'export-bookmarks:export bookmarks'
        'completion:generate completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--config=+[config file]:file:_files -g "*.toml"' \
        '-c+[config file]:file:_files -g "*.toml"' \
        '--data=+[data dir]:dir:_files -/' \
        '-d+[data dir]:dir:_files -/' \
        '--log-level=+[level]:l:(debug info warn error)' \
        '--log-format=+[format]:f:(text json logfmt)' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'readeck subcommand' sub ;;
        args)
            case $words[1] in
                serve) _arguments \
                    '--host=+[bind address]:host:_hosts' \
                    '--port=+[port]:port:_ports' \
                    '--allowed-hosts=+[hosts csv]:str:' \
                    '--use-x-forwarded[trust X-Forwarded]' \
                    '--read-only[read only]' ;;
                user) _arguments '1:user cmd:(add list edit delete password set-role)' ;;
                tokens) _arguments '1:tokens cmd:(create list delete)' ;;
                jobs) _arguments '1:jobs cmd:(list cancel retry workers)' ;;
                config) _arguments '1:config cmd:(show generate validate)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_readeck "$@"
