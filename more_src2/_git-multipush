#compdef git-multipush
# Documentation: https://github.com/gavinbeatty/git-multipush
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Push a branch to multiple remotes (gavinbeatty/git-multipush)

_arguments -s -S \
  '-v[verbose output]' \
  '--verbose[verbose output]' \
  '-h[help]' \
  '--help[help]' \
  '*::remote:__git_remotes' && return 0
