#compdef eddystone
# Documentation: https://github.com/bluez/bluez/blob/master/tools/eddystone.c
# Source: BlueZ tools/eddystone.c — Eddystone-URL / UID / TLM beacon transmitter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-i --index)'{-i+,--index=}'[controller index]:num:' \
    '(- *)'{-v,--version}'[show version]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
