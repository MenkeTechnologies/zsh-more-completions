#compdef ppmtoyuv
# Documentation: man ppmtoyuv (Netpbm)
# Source: convert a PPM image to YUV (Abekas YUV format).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
