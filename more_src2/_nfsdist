#compdef nfsdist nfsdist-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/nfsdist.py argparse)
# Reference accessed: 2026-05-29
# nfsdist — summarize NFS operation latency as a histogram on the client (BCC/eBPF).

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-T --notimestamp)'{-T,--notimestamp}'[do not include timestamp on interval output]' \
  '(-m --milliseconds)'{-m,--milliseconds}'[millisecond histogram (default microseconds)]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '--ebpf[(internal) eBPF debug output]' \
  '1:interval (seconds, default unlimited):' \
  '2:count (number of outputs, default unlimited):' \
  && ret=0

return ret
