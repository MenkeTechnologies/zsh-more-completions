#compdef filecap
# Documentation: man filecap(8)
# Source: stevegrubb/libcap-ng utils/filecap.c (master) — show/set file POSIX capabilities (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-a -d)-a[show all files with capabilities]' \
    '(-a -d)-d[list all known capability names]' \
    '*:dir/file or capability:_files' \
    && ret=0

return ret
