#compdef gosh
# Documentation: https://practical-scheme.net/gauche/man/gauche-refe/Invoking-Gosh.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gosh: Gauche Scheme interpreter.
local curcontext="$curcontext" ret=1

_arguments -C \
  '-V[show version and exit]' \
  '-b[batch mode (suppress prompts)]' \
  '-i[interactive mode (force prompts)]' \
  '-q[skip default initialization file]' \
  '-r+[start with Scheme standard revision]:std:(5 6 7)' \
  '-u+[load and use module]:module:' \
  '-l+[load file]:file:_files -g "*.scm"' \
  '-L+[load file (silent if missing)]:file:_files -g "*.scm"' \
  '-A+[append path to load path]:dir:_files -/' \
  '-I+[prepend path to load path]:dir:_files -/' \
  '-E+[evaluate expression (wrapped in parens)]:expr:' \
  '-e+[evaluate expression]:expr:' \
  '-m+[invoke main with given module]:mod:' \
  '-f+[set runtime/compiler flag]:flag:' \
  '-v+[execute specified Gauche version]:ver:' \
  '-p+[enable profiler]:style:(time sample)' \
  '*:file:_files -g "*.scm"' && ret=0

return ret
