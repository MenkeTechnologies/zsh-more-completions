#compdef ratelimit envoy-ratelimit
# _ratelimit — Envoy global rate-limiting gRPC service (Lyft/Envoyproxy implementation; consumed by Envoy's HTTP/Network rate-limit filters)
# upstream: https://github.com/envoyproxy/ratelimit
# Source: src/service_cmd/main.go on tip; no CLI flags — runtime configuration is env-driven (USE_STATSD, STATSD_HOST/PORT, RUNTIME_ROOT, RUNTIME_SUBDIRECTORY, RUNTIME_WATCH_ROOT, RUNTIME_IGNOREDOTFILES, RUNTIME_PATH, LOG_LEVEL, REDIS_TYPE, REDIS_URL, REDIS_AUTH, REDIS_POOL_SIZE, BACKEND_TYPE, MEMCACHE_HOST_PORT, GRPC_HOST, GRPC_PORT, GRPC_SERVER_USE_TLS, GRPC_SERVER_TLS_CERT, GRPC_SERVER_TLS_KEY, EXTRA_STATS, etc. — see src/settings/settings.go).

_ratelimit() {
    _arguments \
        '(- *)'{-h,--help}'[show help]'
}

_ratelimit "$@"
