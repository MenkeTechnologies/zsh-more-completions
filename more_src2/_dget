#compdef dget
# Documentation: https://manpages.debian.org/dget
# Source: debian/devscripts scripts/dget.pl — download Debian source/binary packages (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-a --all)'{-a,--all}'[fetch all versions]' \
    '(-b --backup)'{-b,--backup}'[backup existing files]' \
    '(-q --quiet)'{-q,--quiet}'[quiet output]' \
    '--build[run dpkg-buildpackage after extracting]' \
    '(-x --extract)'{-d,--download-only,-x,--extract}'[download only / extract]' \
    '(-u --allow-unauthenticated)'{-u,--allow-unauthenticated}'[allow unauthenticated]' \
    '(-k --insecure)'{-k,--insecure}'[allow insecure SSL]' \
    '--no-cache[force download]' \
    '(--no-conf --noconf)'{--noconf,--no-conf}'[ignore conf files]' \
    '*--path=-[add directory to search path]:dir:_files -/' \
    '*:URL or package=version:_default' \
    && ret=0

return ret
