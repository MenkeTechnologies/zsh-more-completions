#compdef distcc-cli distcc2 distccd-cli
# _distcc-cli — Martin Pool Google Samba Project distcc-cli CLI command-line frontend wrapping the distcc the distributed C/C++/ObjC compiler open-source originally Martin Pool at Samba Project now Google Inc distcc accelerates compilation by running cc on a farm of machines runs as either a daemon distccd or in-line standalone server pump mode for #include preprocessing in parallel on the compile farm GCC Clang remote compilation TCP cluster volunteer machines compile distributed-compile pump dist-mode show-host-list show-version cleanup help (Martin Pool Google Samba Project, C); custom argparse
# upstream: https://distcc.github.io/

_distcc-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--show-hosts[show hosts]' \
        '--scan-includes[scan includes]' \
        '-j[show concurrency]' \
        '--show-jobs[show jobs]' \
        '--show-principal[show principal]' \
        '--show-version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--zero[no remote compile]' \
        '--allow=+[host]:_hosts' \
        '*--allow=+[host]:_hosts' \
        '-N+[allow]:_hosts' \
        '--allow-private[allow private nets]' \
        '--jobs=+[N]:n:' \
        '--log-file=+[file]:file:_files' \
        '--log-level=+[l]:l:(critical error warning notice info debug)' \
        '--log-stderr[log to stderr]' \
        '--lifetime=+[sec]:n:' \
        '--max-jobs=+[N]:n:' \
        '--nice=+[N]:n:' \
        '--no-detach[no detach]' \
        '--no-fifo[no fifo]' \
        '--no-fork[no fork]' \
        '--no-prefork[no prefork]' \
        '--pid-file=+[file]:file:_files -g "*.pid"' \
        '--port=+[port]:n:' \
        '-p+[port]:n:' \
        '--priority=+[N]:n:' \
        '--retry=+[N]:n:' \
        '--user=+[user]:_users' \
        '--allow-jobs=+[N]:n:' \
        '--make-me-popular[make popular]' \
        '--stats[stats]' \
        '--stats-port=+[port]:n:' \
        '--enable-tcp-insecure[enable insecure TCP]' \
        '--auth[require auth]' \
        '--keytab=+[file]:file:_files' \
        '--listen=+[host]:_hosts' \
        '--zeroconf[zeroconf]' \
        '*:cmd:_command_names'
}

_distcc-cli "$@"
