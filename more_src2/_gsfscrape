#compdef gsfscrape
# ============================================================================
# gsfscrape - get-set-fetch/scraper CLI (TypeScript, MIT)
#
# Author : get-set-fetch
# Upstream: https://github.com/get-set-fetch/scraper
# npm    : @get-set-fetch/scraper
#
# A Node.js web scraper that supports both headless (Puppeteer / Playwright)
# and HTML-only (Cheerio / jsdom) DOM clients, with pluggable storage
# (SQLite / MySQL / PostgreSQL) and pluggable exporters (CSV / ZIP).
#
# The cheerio lane is bound in `src/domclient/CheerioClient.ts`:
#
#     import cheerio from 'cheerio';
#     import { IDomNode } from './DomClient';
#
#     export default class CheerioClient implements IDomNode {
#         root: cheerio.Root;
#         elm:  cheerio.Element;
#         constructor(bufferOrRoot: Buffer|cheerio.Root, elm?: cheerio.Element) {
#             this.root = bufferOrRoot instanceof Buffer
#                 ? cheerio.load(bufferOrRoot.toString('utf8'))
#                 : bufferOrRoot;
#             this.elm = elm;
#         }
#         querySelectorAll(selector: string): IDomNode[] {
#             const elms = this.elm
#                 ? this.root(selector, this.elm)
#                 : this.root(selector);
#             return elms.toArray().map(elm => new CheerioClient(this.root, elm));
#         }
#     }
#
# This is the canonical use of cheerio - take a buffer / string, hand it
# to `cheerio.load()` to get a Root, then `root(selector)` to project
# elements (jQuery semantics) and `.text()` / `.attr()` to pull data out.
# The package.json declares `cheerio ^1.0.0-rc.10` plus `@types/cheerio`
# as direct dependencies; no proxy / wrapper - the scraper's HTML-only
# lane IS cheerio.
#
# ----------------------------------------------------------------------------
# AXIS 195 :: HTML SCRAPING WITH CSS SELECTORS  [CLOSES at triple-250]
# Round 1285 :: TS-Node slot 3 of 4 :: CLOSES Axis 195 (188th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : scraper      (rust-scraper/scraper)  - html5ever + selectors  [R1283 _fyin]
#   Go      : goquery      (PuerkitoBio/goquery)   - x/net/html + cascadia [R1284 _namigo]
#   TS/Node : cheerio      (cheeriojs/cheerio)     - parse5 + css-select   [R1285 THIS FILE]
#
# Triple-250 round-number landmark. Across Rust=250, Go=250, TS-Node=250
# the three lanes have each landed a real scraper-app consumer on the
# canonical CSS-selector HTML library of their ecosystem. Convergence
# was independent: Servo's html5ever (2013-) for Rust; the Go-team
# `golang.org/x/net/html` tokenizer (2014-) plus andybalholm/cascadia
# (2011-) for Go; inikulin's parse5 (2014-) plus fb55's css-select for
# TS/Node. Three teams, three parser stacks, three CSS-selector engines,
# one converged surface area shaped by the jQuery `$(selector).find().text()`
# pattern that web developers already know from the DOM.
#
# Cheerio sits at 30k+ stars on github.com/cheeriojs/cheerio (May 2026),
# making it the largest of the three by GitHub star count - but the
# ratio is misleading because cheerio carries cross-over traffic from
# every Node tutorial that wants to "scrape a page with jQuery in
# Node". The deep usage anchor is the same: a Document type, a Selection
# type, `.text()` / `.attr()` projections, optional iteration with
# `.each()`. The TS lane closes Axis 195 here at triple-250.
# ============================================================================

_gsfscrape() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '--version[print version and exit]' \
        '--logLevel[pino log level threshold]:level:(trace debug info warn error fatal silent)' \
        '--logDestination[log file path (relative or absolute); default stdout]:file:_files' \
        '--config[scraper config file (JSON)]:config file:_files -g "*.json"' \
        '--overwrite[overwrite existing project / data]' \
        '--export[export output file path]:file:_files' \
        '--exportType[output exporter format]:type:(csv zip)' \
        '--discover[run resource discovery pass]' \
        '--save[persist project / resources to storage]' \
        '--scrape[run the full scrape (discover + save)]' \
        '--retry[retry-failed-resource pass; integer count]:retries:' \
        '--report[print run report]:format:'
}

_gsfscrape "$@"
