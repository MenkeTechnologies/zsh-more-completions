#compdef fluent-cat
# Documentation: https://github.com/fluent/fluentd/blob/master/lib/fluent/command/cat.rb
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-p --port)'{-p,--port=}'[fluent tcp port]:port:' \
  '(-h --host)'{-h,--host=}'[fluent host]:host:_hosts' \
  '(-u --unix)'{-u,--unix}'[use unix socket instead of tcp]' \
  '(-s --socket)'{-s,--socket=}'[unix socket path]:file:_files' \
  '(-f --format)'{-f,--format=}'[input format]:fmt:(json msgpack none)' \
  '--json[same as -f json]' \
  '--msgpack[same as -f msgpack]' \
  '--none[same as -f none]' \
  '--message-key=[key field for none format]:key:' \
  '--time-as-integer[send time as integer for v0.12 or earlier]' \
  '--retry-limit=[number of retry attempts]:n:' \
  '--event-time=[time expression string]:time:' \
  '--help[show help]' \
  '*:tag:' && ret=0

return ret
