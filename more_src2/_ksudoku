#compdef ksudoku
# Documentation: https://apps.kde.org/ksudoku/
# Reference accessed: 2026-05-16
# Verified: upstream KDE ksudoku GUI app. KAboutData standard flags
# only; accepts optional positional URL.
# Removed from prior file: bogus man.archlinux.org search URL.

# ksudoku: KDE Sudoku game
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--help-all[show all options]' \
  '*:sudoku file:_files' && ret=0
return ret
