#compdef kstats
# _kstats — aircrack-ng kstats CLI for analyzing 802.11 WEP key-recovery statistics from aircrack-ng IVS files reporting key-byte vote counts FMS/Korek attack statistics (aircrack-ng team, C); getopt
# upstream: https://github.com/aircrack-ng/aircrack-ng

_kstats() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b+[BSSID]:str:' \
        '--bssid=+[BSSID]:str:' \
        '-e+[ESSID]:str:' \
        '--essid=+[ESSID]:str:' \
        '-r+[fudge factor]:n:' \
        '--fudge=+[fudge factor]:n:' \
        '-k+[korek attack mask]:str:' \
        '-K+[korek attack csv]:str:' \
        '--korek=+[csv]:str:' \
        '-d+[debug key]:str:' \
        '--debug=+[debug key]:str:' \
        '-D+[wep key bits]:n:(40 64 104 128 152 256 512)' \
        '--wep=+[wep key bits]:n:(40 64 104 128 152 256 512)' \
        '-o+[output file]:file:_files' \
        '--out=+[output file]:file:_files' \
        '-S+[stat type]:t:(votes percent rank delta histogram)' \
        '--stats=+[stat type]:t:(votes percent rank delta histogram)' \
        '-T+[threshold]:n:' \
        '--threshold=+[threshold]:n:' \
        '-i[ignore short]' \
        '--ignore-short[ignore short]' \
        '*:IVS or CAP file:_files -g "*.ivs *.cap *.pcap"'
}

_kstats "$@"
