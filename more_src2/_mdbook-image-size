#compdef mdbook-image-size
# _mdbook-image-size — image-size syntax preprocessor for mdBook (lhybdv/mdbook-image-size)
# upstream: https://github.com/lhybdv/mdbook-image-size
# Subcommand from src/bin/mdbook-image-size.rs (clap App).

_mdbook-image-size() {
    _arguments \
        '1:command:(supports)' \
        '2:renderer:(html epub markdown latex)'
}

_mdbook-image-size "$@"
