#compdef evidently
# Documentation: https://github.com/evidentlyai/evidently
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'ui:start the Evidently monitoring dashboard'
  'metric:run a metric on data'
  'report:generate an Evidently report'
  'test:run an Evidently test suite'
  'snapshot:create a snapshot for the UI service'
  'project:manage Evidently projects'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'evidently command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (ui)
        _arguments \
          '--host=[bind host]:host:_hosts' \
          '--port=[bind port]:port:' \
          '--workspace=[workspace directory]:dir:_files -/' \
          '--demo-projects=[demo projects to include]:projects:(all none bikes review)' \
          '--config-path=[config file path]:file:_files' \
          '--secret=[UI secret key]:secret:' \
          '--auth-config-path=[auth config path]:file:_files' && ret=0 ;;
      (metric|report|test)
        _arguments \
          '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
          '(-r --reference)'{-r+,--reference=}'[reference dataset]:file:_files' \
          '(-d --data)'{-d+,--data=}'[current dataset]:file:_files' \
          '(-o --output)'{-o+,--output=}'[output file]:file:_files' && ret=0 ;;
      (snapshot)
        _arguments \
          '--workspace=[workspace dir]:dir:_files -/' \
          '--project-id=[project id]:id:' && ret=0 ;;
      (project)
        _arguments '*::sub:(create list delete add)' && ret=0 ;;
    esac ;;
esac

return ret
