#compdef dapr-injector
# _dapr-injector — Dapr sidecar-injection admission webhook (dapr/dapr)
# upstream: https://github.com/dapr/dapr
# Flags from cmd/injector/options/options.go on tip.

_dapr-injector() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--healthz-port=[healthz bind port]:port:' \
        '--healthz-listen-address=[healthz bind address]:ip:' \
        '--port=[injector service bind port]:port:' \
        '--listen-address=[injector service bind address]:ip:' \
        '--scheduler-enabled=[patch sidecar with Scheduler address]:bool:(true false)' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--log-level=[log level]:level:(debug info warn error fatal panic)' \
        '--log-as-json[log as JSON]' \
        '--enable-metrics[enable Prometheus metrics endpoint]' \
        '--metrics-port=[Prometheus metrics bind port]:port:'
}

_dapr-injector "$@"
