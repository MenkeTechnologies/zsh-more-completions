#compdef endlessh
# Documentation: https://github.com/skeeto/endlessh
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# endlessh: SSH tarpit that traps SSH clients with very slow banner replies.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-p+[listening port (default 2222)]:port' \
  '-d+[message ms delay between banner lines (default 10000)]:delay' \
  '-l+[maximum banner line length 3-255 (default 32)]:length' \
  '-m+[maximum concurrent clients (default 4096)]:max clients' \
  '-f+[load configuration file]:file:_files' \
  '-v[diagnostic output (repeatable)]' \
  '-s[redirect diagnostics to syslog]' \
  '-4[bind to IPv4 only]' \
  '-6[bind to IPv6 only]' \
  '-h[show help]' && ret=0

return ret
