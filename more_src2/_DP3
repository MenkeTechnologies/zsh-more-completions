#compdef DP3 DPPP NDPPP
# Documentation: https://github.com/lofar-astron/DP3 (base/DP3.cc)
# Reference accessed: 2026-05-29
# LOFAR streaming pre-processing pipeline. Takes a parset file + key=value parset overrides.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{--help,-help,-h}'[display usage information]' \
  '(- *)'{--usage,-usage}'[display usage information]' \
  '(- *)'{-v,--version}'[show version information]' \
  '*:parset file or key=value:_files -g "*.parset"' && ret=0

return ret
