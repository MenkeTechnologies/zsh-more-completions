#compdef po-rule-migration
# _po-rule-migration — convert legacy Prometheus rule ConfigMaps into PrometheusRule CRs
# upstream: https://github.com/prometheus-operator/prometheus-operator
# Flags from cmd/po-rule-migration/main.go on tip.

_po-rule-migration() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-rule-config-map=[path to legacy rule ConfigMap YAML]:file:_files' \
        '-rule-crds-destination=[output directory for generated PrometheusRule CRs]:dir:_files -/'
}

_po-rule-migration "$@"
