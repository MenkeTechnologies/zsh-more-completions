#compdef just-mr
# _just-mr — JustBuild just-mr multi-repository fetch/setup tool that drives the just generic build system (just-buildsystem team, C++); custom argparse
# upstream: https://github.com/just-buildsystem/justbuild

_just-mr() {
    local -a sub=(
        'mrversion:show just-mr version'
        'setup:set up workspace'
        'setup-env:print env vars'
        'fetch:fetch a repo'
        'update:update remote refs'
        'do:run just under setup'
        'version:show version'
        'analyse:analyse target'
        'build:build target'
        'install:install target'
        'install-cas:install CAS object'
        'rebuild:rebuild target'
        'describe:describe target'
        'gc:garbage collect cache'
        'add-to-cas:add to CAS'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--repository-config=+[repos.json]:file:_files' \
        '-C+[repos.json]:file:_files' \
        '--checkout-locations=+[file]:file:_files' \
        '-L+[location]:str:' \
        '--local-build-root=+[dir]:dir:_files -/' \
        '-D+[dir]:dir:_files -/' \
        '--distdir=+[distfile dir]:dir:_files -/' \
        '--main=+[main repo]:str:' \
        '--just=+[just binary]:file:_command_names' \
        '--launcher=+[launcher json]:str:' \
        '--rc=+[rc file]:file:_files' \
        '--norc[ignore rc files]' \
        '--log-level=+[level]:l:(0 1 2 3 4 5)' \
        '--log-limit=+[level]:l:(0 1 2 3 4 5)' \
        '--log-file=+[log file]:file:_files' \
        '--no-log-to-stderr[no stderr logs]' \
        '--fetch-absent[fetch absent archives]' \
        '--remote-execution-address=+[host:port]:str:' \
        '--remote-execution-property=+[k=v]:str:' \
        '-q[quiet]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'just-mr subcommand' sub ;;
        args)
            case $words[1] in
                fetch) _arguments \
                    '-o+[output dir]:dir:_files -/' \
                    '--backup-to-remote[backup to remote]' \
                    '*:repo:' ;;
                setup|setup-env|do|build|analyse|install|describe|rebuild) _arguments \
                    '--main=+[main repo]:str:' \
                    '*:target:' ;;
            esac
            ;;
    esac
}

_just-mr "$@"
