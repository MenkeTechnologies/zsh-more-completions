#compdef mdbook-keeper
# _mdbook-keeper — improve Rust doctest runs from mdbook (tfpk/mdbook-keeper)
# upstream: https://github.com/tfpk/mdbook-keeper
# Subcommands from src/bin.rs (clap).

_mdbook-keeper() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-keeper "$@"
