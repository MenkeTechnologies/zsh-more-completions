#compdef docus
# _docus — Nuxt Studio team docus Nuxt-based content authoring framework CLI for building documentation marketing sites with markdown components content collections and design tokens (nuxt-themes team, TypeScript); commander.js
# upstream: https://github.com/nuxt-themes/docus

_docus() {
    local -a sub=(
        'init:initialize new docus project'
        'dev:start dev server'
        'build:build for production'
        'generate:generate static site'
        'preview:preview production build'
        'analyze:analyze bundle'
        'cleanup:cleanup generated files'
        'add:add module or component'
        'upgrade:upgrade docus version'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--cwd=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'docus subcommand' sub ;;
        args)
            case $words[1] in
                init) _arguments \
                    '--name=+[name]:str:' \
                    '--template=+[t]:t:(default blog landing-page documentation marketing)' \
                    '--package-manager=+[pm]:p:(npm pnpm yarn bun)' \
                    '*:project dir:_files -/' ;;
                dev) _arguments \
                    '--port=+[port]:n:' \
                    '--host=+[host]:str:' \
                    '--open[open browser]' \
                    '--no-clear[no clear screen]' \
                    '--tunnel[create tunnel]' ;;
                build|generate) _arguments \
                    '--prerender=+[csv routes]:str:' \
                    '--output=+[dir]:dir:_files -/' \
                    '--analyze[analyze bundle]' ;;
                add) _arguments '1:type:(module component layout page composable plugin)' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_docus "$@"
