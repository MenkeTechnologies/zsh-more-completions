#compdef rosrun
# Documentation: http://wiki.ros.org/rosbash
# Source: ros/ros noetic-devel tools/rosbash/scripts/rosrun — run an executable from a ROS package.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-p --prefix)'{-p+,--prefix=}'[prepend command before execution]:cmd:_command_names' \
    '(-d --debug)'{-d,--debug}'[enable debug output]' \
    '1:package:_default' \
    '2:executable:_default' \
    '*::args:_files' \
    && ret=0

return ret
