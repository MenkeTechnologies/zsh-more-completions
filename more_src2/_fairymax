#compdef fairymax fairy-max
# Documentation: https://manpages.org/fairymax/6
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Fairy-Max takes optional positional args:
#   first positional: hash table size (numeric, default 22 => 48MB)
#   second positional: alternate fmax.ini path
# It speaks the XBoard/CECP protocol on stdin; no GNU-style flags.

local ret=1
_arguments \
  '1:hash table size (numeric, default 22):' \
  '2:ini file:_files -g "*.ini"' && ret=0

return ret
