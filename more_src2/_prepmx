#compdef prepmx
# Documentation: prepmx (M-Tx 0.63d) — M-Tx → PMX preprocessor.
# Source: prepmx BASENAME[.mtx] → BASENAME.pmx.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:mtx source basename:_files -g "*.mtx(:r)"' \
    && ret=0

return ret
