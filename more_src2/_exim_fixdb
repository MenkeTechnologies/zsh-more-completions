#compdef exim_fixdb
# Documentation: https://manpages.debian.org/bookworm/exim4-base/exim_fixdb.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm exim_fixdb(8) manpage explicitly states "It has
# no options." Interactive editing tool for hint databases.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# exim_fixdb: interactively patch Exim hints databases
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:spool directory:_files -/' \
  '2:database name:(retry wait-remote_smtp wait-lmtp callout ratelimit misc tls seen)' && ret=0
return ret
