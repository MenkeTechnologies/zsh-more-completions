#compdef gatekeeper gator
# _gatekeeper — OpenPolicyAgent gatekeeper gator CLI Open Policy Agent Gatekeeper Kubernetes admission controller policy enforcement engine command-line testing and validation tool for ConstraintTemplate Rego policies validating manifests through gator test gator verify gator expand gator sync subcommands for CI integration (OPA team, Go); cobra
# upstream: https://open-policy-agent.github.io/gatekeeper/

_gatekeeper() {
    local -a sub=(
        'test:test against constraints'
        'verify:verify constraint expectations'
        'expand:expand resources via expansion templates'
        'sync:generate SyncSet for templates'
        'validate:validate constraint syntactically'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--audit-from-cache[audit from cache]' \
        '--gather-stats[gather statistics]' \
        '--include-trace[include trace]' \
        '--output=+[fmt]:f:(default json yaml table junit sarif)' \
        '-o+[output format]:f:(default json yaml table junit sarif)' \
        '--enable-k8s-native-validation[enable k8s native validation]' \
        '--allow-deletion-stage[allow deletion stage]' \
        '--ignore-keys=+[keys]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'gatekeeper subcommand' sub ;;
        args)
            case $words[1] in
                test|verify|expand|validate|sync) _arguments '*:files:_files -g "*.yaml *.yml *.json *.rego"' ;;
            esac
            ;;
    esac
}

_gatekeeper "$@"
