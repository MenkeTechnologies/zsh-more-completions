#compdef ryzenadj
# _ryzenadj — adjust AMD Ryzen mobile power/thermal limits (FlyGoat/RyzenAdj)
# upstream: https://github.com/FlyGoat/RyzenAdj
# Flags from main.c (argparse OPT_* macros).

_ryzenadj() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(-i --info)'{-i,--info}'[print info / metrics after adjustment]'
        '--dump-table[print whole power-metric table before+after adjustment]'
        '(-a --stapm-limit)'{-a+,--stapm-limit=}'[STAPM sustained power limit (mW)]:mW:'
        '(-b --fast-limit)'{-b+,--fast-limit=}'[PPT fast power limit (mW)]:mW:'
        '(-c --slow-limit)'{-c+,--slow-limit=}'[PPT slow power limit (mW)]:mW:'
        '(-d --slow-time)'{-d+,--slow-time=}'[slow PPT time constant (s)]:seconds:'
        '(-e --stapm-time)'{-e+,--stapm-time=}'[STAPM time constant (s)]:seconds:'
        '(-f --tctl-temp)'{-f+,--tctl-temp=}'[Tctl temperature limit (°C)]:celsius:'
        '(-g --vrm-current)'{-g+,--vrm-current=}'[VRM VDD current limit TDC (mA)]:mA:'
        '(-j --vrmsoc-current)'{-j+,--vrmsoc-current=}'[VRM SoC current limit TDC (mA)]:mA:'
        '--vrmgfx-current=[VRM GFX current limit TDC (mA)]:mA:'
        '--vrmcvip-current=[VRM CVIP current limit TDC (mA)]:mA:'
        '(-k --vrmmax-current)'{-k+,--vrmmax-current=}'[VRM VDD EDC max current (mA)]:mA:'
        '(-l --vrmsocmax-current)'{-l+,--vrmsocmax-current=}'[VRM SoC EDC max current (mA)]:mA:'
        '--vrmgfxmax_current=[VRM GFX EDC max current (mA)]:mA:'
        '(-m --psi0-current)'{-m+,--psi0-current=}'[PSI0 VDD current limit (mA)]:mA:'
        '--psi3cpu_current=[PSI3 CPU current limit (mA)]:mA:'
        '(-n --psi0soc-current)'{-n+,--psi0soc-current=}'[PSI0 SoC current limit (mA)]:mA:'
        '--psi3gfx_current=[PSI3 GFX current limit (mA)]:mA:'
        '(-o --max-socclk-frequency)'{-o+,--max-socclk-frequency=}'[max SoC clock (MHz)]:mhz:'
        '(-p --min-socclk-frequency)'{-p+,--min-socclk-frequency=}'[min SoC clock (MHz)]:mhz:'
        '(-q --max-fclk-frequency)'{-q+,--max-fclk-frequency=}'[max FCLK (MHz)]:mhz:'
        '(-r --min-fclk-frequency)'{-r+,--min-fclk-frequency=}'[min FCLK (MHz)]:mhz:'
        '(-s --max-vcn)'{-s+,--max-vcn=}'[max VCN (MHz)]:mhz:'
        '(-t --min-vcn)'{-t+,--min-vcn=}'[min VCN (MHz)]:mhz:'
        '(-u --max-lclk)'{-u+,--max-lclk=}'[max LCLK (MHz)]:mhz:'
        '(-v --min-lclk)'{-v+,--min-lclk=}'[min LCLK (MHz)]:mhz:'
        '(-w --max-gfxclk)'{-w+,--max-gfxclk=}'[max GFX clock (MHz)]:mhz:'
        '(-x --min-gfxclk)'{-x+,--min-gfxclk=}'[min GFX clock (MHz)]:mhz:'
        '(-y --prochot-deassertion-ramp)'{-y+,--prochot-deassertion-ramp=}'[Prochot deassertion ramp time]:n:'
        '--apu-skin-temp=[APU skin temp limit (°C)]:celsius:'
        '--dgpu-skin-temp=[dGPU skin temp limit (°C)]:celsius:'
        '--apu-slow-limit=[APU PPT slow limit, A+A dGPU (mW)]:mW:'
        '--skin-temp-limit=[skin temperature power limit (mW)]:mW:'
        '--gfx-clk=[forced clock speed (MHz, Renoir only)]:mhz:'
        '--oc-clk=[forced core clock speed (MHz, Renoir+ only)]:mhz:'
        '--oc-volt=[forced core VID (Renoir+ only)]:vid:'
        '--enable-oc[enable OC (Renoir+ only)]'
        '--disable-oc[disable OC (Renoir+ only)]'
        '--set-coall=[all-core Curve Optimiser]:value:'
        '--set-coper=[per-core Curve Optimiser]:value:'
        '--set-cogfx=[iGPU Curve Optimiser]:value:'
        '--power-saving[hidden power-efficiency profile (AC unplugged behavior)]'
        '--max-performance[hidden performance profile (AC plugged behavior)]'
    )
    _arguments -s $args
}

_ryzenadj "$@"
