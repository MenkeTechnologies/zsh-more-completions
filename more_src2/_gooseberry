#compdef gooseberry
# Documentation: https://github.com/out-of-cheese-error/gooseberry
# Reference accessed: 2026-05-22
# Verified: upstream src/gooseberry/cli.rs clap definitions.

# Zsh completion for gooseberry - Hypothesis knowledge base CLI

local curcontext="$curcontext" state line ret=1

_gooseberry_filters() {
  _arguments \
    '(-c --config)'{-c,--config}'[config file path]:file:_files' \
    '--from[annotations created after datetime]:when:' \
    '--before[annotations created before datetime]:when:' \
    '--include-updated[include annotations updated in range]' \
    '--uri[URL pattern filter]:pattern:' \
    '--any[pattern in quote/tags/text/uri]:pattern:' \
    '--tags[tags to match (comma-separated)]:tags:' \
    '--groups[hypothesis groups (comma-separated)]:groups:' \
    '--exclude-tags[tags to exclude]:tags:' \
    '--quote[text in annotated passage]:text:' \
    '--text[text in annotation body]:text:' \
    '--not[negate filters]' \
    '--and[require all --tags (with --tags)]' \
    '--page[page notes only]' \
    '--annotation[annotations only (exclude page notes)]'
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '1: :->cmds' \
  '*::arg:->args' && ret=0

case $state in
  cmds)
    _values 'gooseberry command' \
      'sync[sync Hypothesis annotations]' \
      'search[interactive search buffer]' \
      'tag[tag annotations by topic]' \
      'delete[delete annotations in bulk]' \
      'view[view filtered annotations]' \
      'uri[get URIs from annotations]' \
      'make[create knowledge-base files]' \
      'index[create index file]' \
      'complete[generate shell completions]' \
      'config[manage configuration]' \
      'clear[clear all gooseberry data]' \
      'move[move annotations from another group]' && ret=0
    ;;
  args)
    case $line[1] in
      search)
        _gooseberry_filters
        _arguments '--fuzzy[enable fuzzy search]' && ret=0
        ;;
      tag)
        _gooseberry_filters
        _arguments \
          '-d[remove tag instead of adding]' \
          '*:tags:' && ret=0
        ;;
      delete|index|move)
        _gooseberry_filters && ret=0
        ;;
      make)
        _gooseberry_filters
        _arguments \
          '--clear[clear knowledge base before recreate]' \
          '-f[skip confirmation when clearing]' \
          '--no-index[do not make index file]' && ret=0
        ;;
      clear)
        _arguments '-f[skip confirmation]' && ret=0
        ;;
      move)
        _gooseberry_filters
        _arguments \
          '1:group ID:' \
          '-s[open search buffer to filter further]' \
          '--fuzzy[enable fuzzy search with -s]' && ret=0
        ;;
      complete)
        _values 'shell' bash elvish fish powershell zsh && ret=0
        ;;
      config)
        if (( CURRENT == 3 )); then
          _values 'config command' \
            'default[print or write default config]' \
            'get[print current configuration]' \
            'where[print config file location]' \
            'authorize[change Hypothesis credentials]' \
            'group[change Hypothesis groups]' \
            'kb[knowledge base settings]' && ret=0
        elif [[ $line[2] == kb ]] && (( CURRENT == 4 )); then
          _values 'kb setting' \
            all directory annotation page link index extension hierarchy sort ignore nest && ret=0
        fi
        ;;
      view)
        _gooseberry_filters
        _arguments '--id[view annotation by ID]:id:' && ret=0
        ;;
      uri)
        _gooseberry_filters
        _arguments '*:ids:' && ret=0
        ;;
    esac
    ;;
esac

return ret
