#compdef fido2-assert
# Documentation: fido2-assert usage (libfido2)
# Source: get / verify FIDO2 assertions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-G -V)-G[get assertion]' \
    '(-G -V)-V[verify assertion]' \
    '-b[blob extension]' \
    '-d[debug]' \
    '-h[hmac-secret extension]' \
    '-p[user-presence required]' \
    '-r[allow updated counter (-V only)]' \
    '-u[U2F-only assertions]' \
    '-v[verbose]' \
    '-w[wait for user]' \
    '-t+[transport / option]:option:' \
    '-i+[input file]:file:_files' \
    '-o+[output file]:file:_files' \
    '*:device or key file:_files' \
    && ret=0

return ret
