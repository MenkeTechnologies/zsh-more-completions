#compdef firectl
# _firectl — Firecracker microVM control wrapper CLI (Firecracker microvm team, Go); spf13/cobra
# upstream: https://github.com/firecracker-microvm/firectl

_firectl() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--firecracker-binary=+[firecracker binary]:file:_files' \
        '-b+[firecracker binary]:file:_files' \
        '--kernel=+[kernel image]:file:_files' \
        '-k+[kernel image]:file:_files' \
        '--kernel-opts=+[kernel boot args]:str:' \
        '-a+[kernel boot args]:str:' \
        '--root-drive=+[root drive path]:file:_files' \
        '-r+[root drive path]:file:_files' \
        '--root-partition=+[root partition uuid]:str:' \
        '--add-drive=+[additional drive path:rw]:str:' \
        '-d+[additional drive path:rw]:str:' \
        '--tap-device=+[tap-device]:str:' \
        '-t+[tap-device]:str:' \
        '--vsock-device=+[vsock guest_cid]:str:' \
        '--vmm-binary=+[vmm binary]:file:_files' \
        '--vmm-config-path=+[vmm config path]:file:_files' \
        '--socket-path=+[firecracker socket]:file:_files' \
        '-s+[firecracker socket]:file:_files' \
        '--cpu-template=+[cpu template]:t:(C3 T2)' \
        '-c+[cpu template]:t:(C3 T2)' \
        '--ncpus=+[number of CPUs]:n:' \
        '--cpu-count=+[number of CPUs]:n:' \
        '--memory=+[memory MB]:n:' \
        '-m+[memory MB]:n:' \
        '--htenabled[hyperthreading enabled]' \
        '-t[hyperthreading enabled]' \
        '--metadata=+[metadata JSON file]:file:_files' \
        '--firecracker-log=+[firecracker log file]:file:_files' \
        '-l+[firecracker log file]:file:_files' \
        '--validate[validate config only]' \
        '*:arg:'
}

_firectl "$@"
