#compdef effekt
# Documentation: https://github.com/effekt-lang/effekt/blob/main/effekt/jvm/src/main/scala/effekt/EffektConfig.scala
# Reference accessed: 2026-05-27
# Verified: upstream EffektConfig.scala (Scallop opts) on the main branch.

# Effekt is non-subcommand based: a single binary with flag-driven modes
# (compile, build, repl, server). Trailing filenames are Effekt sources.

local curcontext="$curcontext" state line ret=1

local -a _effekt_backends _effekt_irs _effekt_time _effekt_platforms
_effekt_backends=(js js-web chez-callcc chez-cps chez-monadic llvm)
_effekt_irs=(none core cps machine target)
_effekt_time=(text json)

_arguments -s -S -C \
  '(--no-compile)--compile[compile to the backend representation]' \
  '(--compile)--no-compile[disable compile mode]' \
  '(--no-build)--build[compile and build a backend-specific executable]' \
  '(--build)--no-build[disable build mode]' \
  '--out=[path to write generated files (defaults to ./out)]:dir:_files -/' \
  '*--includes=[path to consider for includes]:dir:_files -/' \
  '--lib=[path to the standard library to be used]:dir:_files -/' \
  '--backend=[backend that should be used]:backend:('"${_effekt_backends[*]}"')' \
  '--llvm-version=[llvm version used to compile generated programs]:version:' \
  '--clang-includes=[additional include path for clang]:dir:_files -/' \
  '--clang-libraries=[additional library path for clang]:dir:_files -/' \
  '(--no-native)--native[optimize executable for the native CPU (LLVM only)]' \
  '(--native)--no-native[disable native CPU optimization]' \
  '*--prelude=[modules to be automatically imported in every file]:module:' \
  '(--no-exit-on-error)--exit-on-error[exit with non-zero status on error]' \
  '(--exit-on-error)--no-exit-on-error[do not exit non-zero on error]' \
  '(-O --no-optimize)'{-O,--optimize}'[run optimizations (in particular the inliner)]' \
  '(-O --optimize)--no-optimize[disable optimizations]' \
  '--max-inline-size=[maximum core tree-node size considered by the inliner]:n:' \
  '(--no-show-prelude)--show-prelude[print modules auto-imported in every file]' \
  '(--show-prelude)--no-show-prelude[disable show-prelude]' \
  '--ir-show=[intermediate representation to print]:ir:('"${_effekt_irs[*]}"')' \
  '(--no-ir-write-all)--ir-write-all[write all IRs to files in the output directory]' \
  '(--ir-write-all)--no-ir-write-all[disable IR writing]' \
  '(--no-show-documentation)--show-documentation[show documented statements as JSON]' \
  '(--show-documentation)--no-show-documentation[disable show-documentation]' \
  '(--no-write-documentation)--write-documentation[write documented statements to JSON in out dir]' \
  '(--write-documentation)--no-write-documentation[disable write-documentation]' \
  '--time=[measure time spent in each compilation phase]:format:('"${_effekt_time[*]}"')' \
  '(--no-valgrind)--valgrind[execute files using valgrind]' \
  '(--valgrind)--no-valgrind[do not execute files using valgrind]' \
  '--server[run as Language Server (LSP) instead of compiling]' \
  '--version[print Effekt version]' \
  '(- *)--help[show usage and exit]' \
  '*:effekt source file:_files -g "*.effekt"' && ret=0

return ret
