#compdef foamSequenceVTKFiles
# Documentation: https://openfoam.org/
# Source: OpenFOAM/OpenFOAM-dev bin/foamSequenceVTKFiles — re-number/symlink VTK time-series files for ParaView.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-case -c)'{-case,-c}'[case directory (default cwd)]:dir:_directories' \
    '(-dir -d)'{-dir,-d}'[post-processing directory (default postProcessing)]:dir:_directories' \
    '(-help -h)'{-help,-h}'[print usage]' \
    '(-out -o)'{-out,-o}'[output links directory (default sequencedVTK)]:dir:_directories' \
    && ret=0

return ret
