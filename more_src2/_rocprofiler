#compdef rocprofiler rocprof rocprofiler-systems rocprofiler-compute
# _rocprofiler — AMD ROCm rocprofiler GPU performance profiler tool with API counter and trace collection (ROCm team, C++); custom argparse
# upstream: https://github.com/ROCm/rocprofiler

_rocprofiler() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[input txt]:file:_files -g "*.txt *.json"' \
        '--input=+[input txt]:file:_files -g "*.txt *.json"' \
        '-o+[output file]:file:_files' \
        '--output-file=+[output file]:file:_files' \
        '-d+[output dir]:dir:_files -/' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--basenames=+[bool]:b:(on off)' \
        '--timestamp=+[bool]:b:(on off)' \
        '--ctx-wait=+[bool]:b:(on off)' \
        '--ctx-limit=+[bool]:b:(on off)' \
        '--heartbeat=+[bool]:b:(on off)' \
        '--obj-tracking=+[bool]:b:(on off)' \
        '--hsa-trace[trace HSA API]' \
        '--hip-trace[trace HIP API]' \
        '--kfd-trace[trace KFD API]' \
        '--roctx-trace[trace ROCTX]' \
        '--sys-trace[trace system]' \
        '--stats[collect stats]' \
        '--statsdb[collect stats DB]' \
        '--list-basic[list basic counters]' \
        '--list-derived[list derived counters]' \
        '--obs[observable]' \
        '--mpi[MPI mode]' \
        '--ncrep[no curl re-export]' \
        '-t+[output format]:f:(text csv json)' \
        '--out-format=+[output format]:f:(text csv json)' \
        '--plugin=+[plugin]:p:(file perfetto json att otf2 ctf)' \
        '--plugin-args=+[args]:str:' \
        '--m+[metric]:str:' \
        '--metrics=+[metrics csv]:str:' \
        '--counters=+[counters csv]:str:' \
        '-r+[range]:str:' \
        '--range=+[range]:str:' \
        '--kernel-filter=+[regex]:str:' \
        '--filter=+[regex]:str:' \
        '--summary=+[bool]:b:(on off)' \
        '*:command:_command_names'
}

_rocprofiler "$@"
