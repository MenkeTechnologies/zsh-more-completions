#compdef RNAfold
# Documentation: https://www.tbi.univie.ac.at/RNA/RNAfold.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ViennaRNA RNAfold: predict secondary structure of RNA sequence
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
  '(-T --temp)'{-T,--temp=}'[folding temperature in C]:temp:' \
  '(-p --partfunc)'{-p,--partfunc=-}'[compute partition function]::n:' \
  '--MEA=[maximum expected accuracy structure]:gamma:' \
  '(-d --dangles)'{-d,--dangles=}'[dangling-end model]:d:(0 1 2 3)' \
  '(-c --circ)'{-c,--circ}'[fold as a circular RNA]' \
  '(-g --gquad)'{-g,--gquad}'[allow G-quadruplex formation]' \
  '--noLP[disallow lonely (unstacked) pairs]' \
  '--noGU[disallow GU pairs]' \
  '--noClosingGU[disallow GU pairs at helix ends]' \
  '(-P --paramFile)'{-P,--paramFile=}'[free-energy parameter file]:file:_files' \
  '--nsp=[non-standard base pair list]:pairs:' \
  '--energyModel=[energy model]:em:' \
  '(-S --pfScale)'{-S,--pfScale=}'[pf scaling factor]:factor:' \
  '--bppmThreshold=[bpp threshold for plot]:thresh:' \
  '(-o --outfile)'{-o-,--outfile=-}'[output file]::file:_files' \
  '(-i --infile)'{-i,--infile=}'[input file]:file:_files' \
  '--commands=[command file]:file:_files' \
  '--noPS[suppress PostScript plot output]' \
  '--noDP[suppress dot-plot output]' \
  '(-4 --noTetra)'{-4,--noTetra}'[skip special hairpin energies]' \
  '--auto-id[auto-generate sequence IDs]' \
  '--id-prefix=[ID prefix]:prefix:' \
  '--id-start=[first ID number]:n:' \
  '--salt=[salt concentration in molar]:val:' \
  '(-C --constraint)'{-C,--constraint=-}'[apply structural constraints]::file:_files' \
  '--maxBPspan=[max base pair distance]:n:' \
  '*:RNA sequence file:_files -g "*.(fa|fasta|seq)"' && ret=0
return ret
