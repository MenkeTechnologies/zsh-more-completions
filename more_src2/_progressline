#compdef progressline
# Documentation: https://github.com/kattouf/ProgressLine
# Reference accessed: 2026-05-20
# Verified: kattouf/ProgressLine README. Tracks command progress
# in a compact one-line format. Original file flags were fabricated.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-s --activity-style)'{-s+,--activity-style=}'[activity indicator style]:style:(dots snake kitt spinner)' \
  '(-t --static-text)'{-t+,--static-text=}'[replace log output with custom text]:text' \
  '*'{-m+,--log-matches=}'[highlight stdin lines matching regex]:pattern' \
  '(-a --log-all)'{-a,--log-all}'[display all stdin data above progress line]' \
  '(-l --original-log-path)'{-l+,--original-log-path=}'[save full original log to file]:file:_files' && ret=0

return ret
