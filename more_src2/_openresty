#compdef openresty
# Documentation: https://nginx.org/en/docs/switches.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Note: openresty is a bundled nginx distribution and uses the same
# command-line switches as upstream nginx.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,'-?'}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'-V'[show version and configure options]' \
  '-c+[set configuration file]:config file:_files' \
  '-g+[set global directives]:directives' \
  '-p+[set prefix path]:prefix:_directories' \
  '-e+[set inline configuration]:configuration' \
  '-q[suppress non-error messages during configuration testing]' \
  '-s+[send signal to master process]:signal:(stop quit reopen reload)' \
  '-t[test configuration]' \
  '-T[test configuration, dump it and exit]' && ret=0

return ret
