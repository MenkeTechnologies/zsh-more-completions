#compdef impacket-keylistattack
# Documentation: https://github.com/fortra/impacket/blob/master/examples/keylistattack.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-keylistattack: extract user keys from a Read-Only Domain Controller via key list.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[verbose debug output]' \
  '-ts[print timestamps in log]' \
  '-rodcNo[RODC krbtgt account number]:n:' \
  '-rodcKey[AES key of the RODC]:hex:' \
  '-full[attack all domain users]' \
  '-domain[fully qualified domain name]:domain:' \
  '-kdc[KDC hostname or FQDN]:host:_hosts' \
  '-t[target a specific username]:user:' \
  '-tf[file with list of target usernames]:file:_files' \
  '-hashes[NTLM hashes (LMHASH:NTHASH)]:hash:' \
  '-no-pass[do not prompt for password]' \
  '-k[use Kerberos auth from ccache]' \
  '-aesKey[AES key (128 or 256 bits)]:hex:' \
  '-dc-ip[domain controller IP]:ip:' \
  '-target-ip[target machine IP]:ip:' \
  '*::positional:_files' && ret=0
return ret
