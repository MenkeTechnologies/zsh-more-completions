#compdef distancefieldgenerator
# Documentation: https://doc.qt.io/qt-6/qttools-index.html
# Source: qt/qttools src/distancefieldgenerator/main.cpp — prepare a font distance-field cache for Qt apps (C++, QCommandLineParser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    {-h,--help}'[show help]' \
    '--help-all[show help including Qt-specific options]' \
    {-v,--version}'[show version]' \
    '1::font file:_files -g "*.{ttf,otf,TTF,OTF}"' \
    && ret=0

return ret
