#compdef prev next
# Documentation: man prev(1) / man next(1)
# Source: nmh (man) — show previous/next message (C, wraps show(1)).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-showproc+[show program]:cmd:_command_names -e' \
    '-showmimeproc+[show MIME program]:cmd:_command_names -e' \
    '(-header -noheader)-header[show one-line header]' \
    '(-header -noheader)-noheader[no one-line header]' \
    '(-checkmime -nocheckmime)-checkmime[check MIME content]' \
    '(-checkmime -nocheckmime)-nocheckmime[no MIME check]' \
    '-version[show version]' \
    '-help[show help]' \
    '1::+folder:_default' \
    && ret=0

return ret
