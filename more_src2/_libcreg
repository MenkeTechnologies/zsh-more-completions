#compdef creginfo cregexport
# _libcreg — libyal Windows 9x/Me Registry File (CREG, classes.dat / user.dat / system.dat) parser; walks RGKN keys + RGDB values
# upstream: https://github.com/libyal/libcreg

_libcreg() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[codepage]:codepage:(ascii windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)' \
        '-X[exclusive]' \
        '*:CREG file:_files'
}

_libcreg "$@"
