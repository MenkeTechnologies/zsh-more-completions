#compdef rcvpack
# Documentation: man rcvpack(1)
# Source: nmh uip/rcvpack.c (master) — append received message to a file (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-mbox -mmdf)-mbox[mbox format]' \
    '(-mbox -mmdf)-mmdf[mmdf format]' \
    '-version[show version]' \
    '-help[show help]' \
    '1:file:_files' \
    && ret=0

return ret
