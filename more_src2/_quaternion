#compdef quaternion
# _quaternion — Quaternion Qt Matrix client (C++); cross-platform desktop client using libQuotient
# upstream: https://github.com/quotient-im/Quaternion

_quaternion() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '--style+[Qt style]:style:(default fusion windows macintosh)' \
        '--platform+[Qt platform]:platform:' \
        '--display+[X display]:display:' \
        '*:matrix URI:_urls'
}

_quaternion "$@"
