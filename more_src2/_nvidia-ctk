#compdef nvidia-ctk
# Documentation: https://github.com/NVIDIA/nvidia-container-toolkit
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nvidia-ctk: NVIDIA Container Toolkit CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'cdi:CDI device generation'
  'config:interact with the config file'
  'hook:container hook commands'
  'info:report toolkit information'
  'runtime:configure container runtime (docker/containerd/cri-o)'
  'system:system level commands'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-d --debug)'{-d,--debug}'[enable debug-level logging]' \
  '--quiet[suppress output except errors; overrides --debug]' \
  '--config=[path to the config file]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'nvidia-ctk command' commands && ret=0 ;;
esac
return ret
