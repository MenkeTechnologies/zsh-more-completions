#compdef icepack
# Documentation: https://manpages.debian.org/testing/fpga-icestorm/icepack.1.en.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# icepack: Project IceStorm iCE40 bitstream packer (.txt -> .bin).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)-h[show help]' \
  '-u[unpack mode (same as iceunpack)]' \
  '-v[verbose (repeat for more)]' \
  '-b[output CRAM bitmap as netpbm]' \
  '-f[output CRAM bitmap with filled tiles as netpbm]' \
  '-c[output checkerboard CRAM bitmap netpbm (repeat to flip)]' \
  '-r[netpbm output uses BRAM data instead of CRAM]' \
  '-B0[restrict netpbm output to bank 0]' \
  '-B1[restrict netpbm output to bank 1]' \
  '-B2[restrict netpbm output to bank 2]' \
  '-B3[restrict netpbm output to bank 3]' \
  '1:input:_files -g "*.{asc,bin}"' \
  '2:output:_files -g "*.{asc,bin}"' && ret=0

return ret
