#compdef gdal_calc gdal_calc.py
# Documentation: https://gdal.org/programs/gdal_calc.html
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--help-general[show generic GDAL command-line options]' \
  '(- *)--version[show version]' \
  '*-A+[input file]:file:_files' \
  '*-B+[input file]:file:_files' \
  '*-C+[input file]:file:_files' \
  '*-D+[input file]:file:_files' \
  '--A_band=[band for input A]:n:' \
  '--B_band=[band for input B]:n:' \
  '--outfile=[output file]:file:_files' \
  '*--calc=[calculation expression (numpy syntax)]:expr:' \
  '--NoDataValue=[NoData value for output]:value:' \
  '--type=[output data type]:type:(Byte Int8 UInt16 Int16 UInt32 Int32 UInt64 Int64 Float32 Float64 CInt16 CInt32 CFloat32 CFloat64)' \
  '--format=[output GDAL format]:format:' \
  '*--creation-option=[creation option]:NAME=VALUE:' \
  '*--co=[creation option]:NAME=VALUE:' \
  '--allBands=[apply calc to all bands of given input]:input:(A B C D)' \
  '--overwrite[overwrite existing output]' \
  '--debug[turn on debug output]' \
  '--quiet[quiet mode]' \
  '--projectionCheck[check projections of inputs]' \
  '--color-table=[apply color table to output]:file:_files' \
  '--extent=[handling of mismatched extents]:choice:(ignore fail union intersect)' \
  '--projwin=[custom output extent: ulx uly lrx lry]:bounds:' \
  '--user_namespace=[user namespace for calc]:dict:' \
  '--hideNoData[ignore NoData when computing]' && ret=0

return ret
