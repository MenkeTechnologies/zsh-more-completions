#compdef dotnet-svcutil
# Documentation: https://github.com/dotnet/wcf/tree/main/src/dotnet-svcutil/lib
# Reference accessed: 2026-05-27
# Verified: upstream src/dotnet-svcutil/lib/src/CommandProcessorOptions.cs CommandSwitch table

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-d --outputDir)'{-d+,--outputDir=}'[output directory]:directory:_files -/' \
  '(-o --outputFile)'{-o+,--outputFile=}'[output file name]:file:_files' \
  '*'{-n+,--namespace=}'[namespace mapping (contract,clr-namespace)]:mapping:' \
  '*'{-r+,--reference=}'[assembly reference]:assembly:_files -g "*.dll"' \
  '(-tf --targetFramework)'{-tf+,--targetFramework=}'[target framework moniker]:tfm:' \
  '(-bd --bootstrapDir)'{-bd+,--bootstrapDir=}'[bootstrap directory]:directory:_files -/' \
  '*'{-ct+,--collectionType=}'[collection types to use]:type:' \
  '(-edb --enableDataBinding)'{-edb,--enableDataBinding}'[enable data binding support]' \
  '*'{-et+,--excludeType=}'[type to exclude from generation]:type:' \
  '(-i --internal)'{-i,--internal}'[generate internal type access]' \
  '(-nl --noLogo)'{-nl,--noLogo}'[suppress logo display]' \
  '(-nsl --noStdlib)'{-nsl,--noStdlib}'[exclude standard library types]' \
  '(-nm --noTelemetry)'{-nm,--noTelemetry}'[disable telemetry]' \
  '(-ntr --noTypeReuse)'{-ntr,--noTypeReuse}'[disable type reuse]' \
  '(-pf --projectFile)'{-pf+,--projectFile=}'[project file]:project:_files -g "*.csproj"' \
  '(-ri --runtimeIdentifier)'{-ri+,--runtimeIdentifier=}'[runtime identifier]:rid:' \
  '(-ser --serializer)'{-ser+,--serializer=}'[serializer mode]:serializer:(Auto Default XmlSerializer DataContractSerializer)' \
  '(-syn --sync)'{-syn,--sync}'[enable synchronous operations]' \
  '(-so --syncOnly)'{-so,--syncOnly}'[generate synchronous operations only]' \
  '(-u --update)'{-u,--update=-}'[update existing service reference]::reference:' \
  '(-v --verbosity)'{-v+,--verbosity=}'[output verbosity level]:level:(Silent Minimal Normal Verbose Debug)' \
  '(-wr --wrapped)'{-wr,--wrapped}'[generate wrapped responses]' \
  '(-ac --acceptCertificate)'{-ac,--acceptCertificate}'[accept service certificate automatically]' \
  '(-sc --serviceContract)'{-sc,--serviceContract}'[generate service contracts only]' \
  '(-mc --messageContract)'{-mc,--messageContract}'[generate message contracts]' \
  '(-cn --cultureInfo)'{-cn+,--cultureInfo=}'[culture/localization info]:culture:' \
  '(-l --language)'{-l+,--language=}'[target language]:language:(csharp cs c# vb visualbasic)' \
  '*:input (URL, WSDL, XSD, .svcmap):_files' && ret=0

return ret
