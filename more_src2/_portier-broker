#compdef portier-broker
# ============================================================================
#  _portier-broker — portier-broker: Portier identity broker
#                    reference implementation in Rust
#                    (Portier project — passwordless email-link
#                    OpenID Connect authentication)
#
#  Source-direct extraction from
#    https://github.com/portier/portier-broker/blob/main/src/main.rs
#    https://github.com/docopt/docopt.rs (the docopt.rs library by
#    BurntSushi/Andrew Gallant — Rust port of the Python docopt
#    USAGE-string-as-SPEC pattern)
#
#  Maintained by Portier project (Stephan Maka et al — fork/
#  continuation of the original Mozilla Persona project).  579 GH
#  stars.  portier-broker is the REFERENCE IMPLEMENTATION of the
#  Portier identity broker spec: a PASSWORDLESS email-link sign-in
#  protocol on top of OpenID Connect.  User enters email →
#  broker sends one-time login link → user clicks link → broker
#  asserts identity to the relying party via OIDC.  Spiritual
#  successor to MOZILLA PERSONA (BrowserID, shut down by Mozilla
#  in 2016) — Portier picks up the same email-as-identity model
#  but on standards-track OIDC instead of BrowserID.  Runs as a
#  long-lived daemon binding to TCP and (on Unix) Unix sockets,
#  speaks HTTP/1 (hyper-rs).  Sister tools: dex (CoreOS/Linkerd
#  OIDC broker), keycloak (Red Hat IdP — Java), authelia (in
#  corpus via _authelia — Go IdP), zitadel (Zitadel IdP), oauth2-
#  proxy (in corpus via _oauth2-proxy — Bitly OAuth2 proxy),
#  pomerium (in corpus via _pomerium — Pomerium ZTNA gateway),
#  authentik (Python IdP), kanidm (Rust IdP).
#
#  CLI library taxonomy update: 13th Rust CLI library — Andrew
#  "BurntSushi" Gallant & Vinzent Steinberg's **docopt.rs**
#  (docopt/docopt.rs).  Rust ecosystem now has 13 documented CLI
#  libraries — RE-TAKING THE SOLO LEAD as the MOST-DOCUMENTED CLI
#  LANGUAGE in the cross-language taxonomy ahead of Go (12) and
#  TypeScript-Node (12).  🎉 Rust BREAKS the THREE-WAY TIE.
#
#  docopt.rs (docopt/docopt.rs) is BurntSushi/Andrew Gallant's
#  Rust port of the DOCOPT pattern originally invented by Vladimir
#  Keleshev (Python docopt, 2012).  DOCOPT'S CENTRAL INSIGHT:
#  the USAGE STRING IS THE SPEC.  Instead of declaring flags
#  programmatically (clap_derive's structs, gumdrop's
#  `#[derive(Options)]`, lexopt's match arms, bpaf's combinators,
#  pico-args's pulls, xflags's macro blocks, lexopt's iterators,
#  argh's structs), the developer WRITES THE MAN-PAGE-STYLE USAGE
#  STRING and docopt PARSES IT to generate the argv parser at
#  runtime.  This means: change the usage string → change the
#  parser, AUTOMATICALLY.  Used by rust-lang/cargo (PRE-clap,
#  cargo's first arg parser — replaced by clap in cargo 0.20+
#  circa 2017), rust-lang/rustfmt (PRE-clap, rustfmt's original
#  parser), BurntSushi/ripgrep (PRE-clap, ripgrep's original
#  parser — also replaced by clap), rust-lang/chalk (Rust trait
#  system reasoner 1998 stars — IN CORPUS via _chalk, still uses
#  docopt), portier/portier-broker (579 stars), cloudflare/quiche
#  (11529 stars — uses docopt for quiche-client/quiche-server
#  reference apps, IN CORPUS via _quiche-client/_quiche-server),
#  ecstatic-morse/ksuid (Segment KSUID CLI — IN CORPUS via
#  _ksuid), rayon-rs/rayon (rayon-demo uses docopt), qdrant/qdrant
#  (wal-ctl tool — IN CORPUS via _qdrant), rust-embedded/rust-
#  i2cdev examples, ja30278/gdrivefs (Rust Google Drive FUSE),
#  Arkanosis/microstatus (180 stars — Mastodon-compatible
#  ActivityPub server), portmidi-rs/musitdev examples, hone/
#  helix_docopt (Helix editor docopt integration), honzasp/spiral
#  (Spiral language compiler), and many other older Rust binaries
#  that prefer the man-page-style spec definition.
#
#  docopt.rs API:
#    use docopt::Docopt;
#    use serde::Deserialize;
#
#    // USAGE STRING IS THE SPEC — docopt parses this at runtime
#    // to generate the argv parser.  STRUCTURE follows the docopt
#    // grammar (http://docopt.org):
#    //
#    //   First line MUST be empty
#    //   "Usage:" section: invocation patterns
#    //     [OPTIONAL]
#    //     <required>
#    //     subcommand
#    //     --flag
#    //     ... (repeatable)
#    //   "Options:" section: flag descriptions
#    //     --flag=ARG       Description text
#    //     -f --flag=ARG    [default: VALUE]
#    const USAGE: &str = "
#    My Tool
#
#    Usage:
#      mytool [CONFIG]
#      mytool [CONFIG] --import-keys FILE [--dry-run]
#      mytool [CONFIG] --export-keys FILE
#      mytool --version
#      mytool --help
#
#    Options:
#      --version              Print version
#      --help                 Print help
#      --import-keys FILE     Import PEM keys
#      --dry-run              Parse but don't apply
#      --export-keys FILE     Export active keys as PEM
#    ";
#
#    // Args struct deserialized from parsed argv
#    #[derive(Debug, Deserialize)]
#    struct Args {
#      arg_CONFIG: Option<String>,
#      flag_import_keys: Option<String>,
#      flag_export_keys: Option<String>,
#      flag_dry_run: bool,
#      flag_version: bool,
#    }
#
#    fn main() {
#      let args: Args = Docopt::new(USAGE)
#        .and_then(|d| d.deserialize())
#        .unwrap_or_else(|e| e.exit());
#
#      // args.flag_import_keys, args.arg_CONFIG, etc.
#    }
#
#  docopt.rs distinctive features:
#    - USAGE STRING IS THE SPEC — parser is GENERATED from the
#      man-page-style USAGE string at runtime (using a PEG-like
#      grammar to interpret the docopt mini-language)
#    - FIELD NAMING CONVENTION on deserialized struct:
#      * `arg_NAME` — positional argument (e.g. `<NAME>` in USAGE
#        → field `arg_NAME` in struct; UPPERCASE positionals like
#        `[CONFIG]` → `arg_CONFIG`)
#      * `flag_NAME` — option flag (e.g. `--import-keys FILE` →
#        field `flag_import_keys`; HYPHENS converted to underscores)
#      * `cmd_NAME` — subcommand presence (e.g. `mount` →
#        `cmd_mount: bool`)
#    - serde-DRIVEN DESERIALIZATION — `Docopt::new(USAGE).
#      and_then(|d| d.deserialize())` produces a strongly typed
#      Args struct via serde's Deserialize derive
#    - REPEATED FLAGS — `--verbose...` in USAGE → `flag_verbose:
#      usize` (count)
#    - MUTUALLY-EXCLUSIVE PATTERNS — multiple Usage lines define
#      ALTERNATIVE invocation patterns (docopt picks the matching
#      one based on argv structure)
#    - OPTIONAL SECTIONS — `[...]` in USAGE marks optional;
#      `(...)` marks required groupings
#    - DEFAULTS — `[default: VALUE]` in Options descriptions
#      provides default values
#    - SHORT+LONG aliases — `-f --flag=ARG` declares both forms
#    - AUTO --help / --version detection — `Docopt::new(USAGE).
#      help(true).version(Some("1.0".into()))` configures
#    - ZERO COMPILE-TIME OVERHEAD for the parser — generated at
#      runtime from the USAGE string (vs clap_derive's proc-macro
#      compile-time generation); TRADEOFF: pays a one-time parsing
#      cost at startup
#    - INSPIRED BY Python's docopt (Vladimir Keleshev, 2012) which
#      was inspired by POSIX-format man-page conventions
#    - SAME UNDERLYING IDEA as Python docopt, Go docopt-go,
#      JavaScript docopt.js, etc. — DOCOPT IS LANGUAGE-AGNOSTIC
#      because the USAGE string grammar is the spec
#  Distinct from R275 Rust clap-derive (proc-macro
#  `#[derive(Parser)]` with attribute config — OPPOSITE PHILOSOPHY:
#  declare flags programmatically, auto-generate help; docopt: write
#  help, auto-generate parser), R330 Rust bpaf (functional
#  applicative combinator), R344 Rust google/argh (derive-on-struct),
#  R347 Rust RazrFalcon/pico-args (low-level imperative pull
#  parser), R404 Rust matklad/xflags (declarative MACRO block
#  syntax), R407 Rust blyxxyz/lexopt (minimal iterator-based pull
#  parser), R410 Rust murarth/gumdrop (zero-dep derive-macro).
#  Rust documented libraries so far: clap-derive, bpaf, argh, pico-
#  args, xflags, lexopt, gumdrop, docopt.rs (this round)... plus
#  older clap-builder, getopts, structopt (deprecated, now
#  clap_derive)... docopt.rs's distinguishing feature vs ALL other
#  Rust libs: docopt INVERTS the usual relationship — most libs
#  generate help FROM the spec; docopt generates the SPEC FROM the
#  help.  docopt.rs's approach: USAGE-STRING-IS-SPEC with `Docopt::
#  new(USAGE)` runtime parser generation + serde deserialization
#  to Args struct + `arg_NAME` (positional) / `flag_NAME` (option) /
#  `cmd_NAME` (subcommand) field naming convention + repeated flags
#  → count fields + mutually-exclusive Usage line patterns + `[...]`
#  optional / `(...)` required grouping + `[default: VALUE]` in
#  Options + zero compile-time parser overhead (runtime generation)
#  + LANGUAGE-AGNOSTIC docopt grammar shared with Python/Go/JS
#  docopt implementations — corpus's **first documented USAGE-
#  STRING-IS-SPEC Rust CLI library**.  Brings cross-language CLI
#  library taxonomy variant count to 152; Rust ecosystem now has
#  13 documented CLI libraries — RE-TAKING THE SOLO LEAD as the
#  MOST-DOCUMENTED CLI LANGUAGE in the cross-language taxonomy
#  ahead of Go (12) and TypeScript-Node (12).
#
#  Surface (verbatim from `src/main.rs` USAGE docopt string):
#
#  Usage:
#    portier-broker [CONFIG]                              # Run broker with optional TOML config path
#    portier-broker [CONFIG] --import-keys FILE [--dry-run]   # Import PEM private keys (with optional dry-run)
#    portier-broker [CONFIG] --export-keys FILE           # Export currently-active private keys as PEM
#    portier-broker --version                             # Print version and exit
#    portier-broker --help                                # Print help and exit
#
#  Positional:
#    CONFIG                         Path to TOML configuration file
#                                   (optional — if absent, broker
#                                   falls back to env-var-only
#                                   config)
#
#  Options:
#    --version                      Print version information and
#                                   exit
#    --help                         Print this help message and
#                                   exit
#    --import-keys FILE             Import PEM private keys from
#                                   FILE (existing keys are
#                                   replaced)
#    --dry-run                      Parse PEM to be imported, but
#                                   don't apply changes (useful
#                                   for validating key files
#                                   before rotation)
#    --export-keys FILE             Export currently active
#                                   private keys as PEM to FILE
#                                   (for backup or migration)
#
#  Examples:
#    portier-broker                                         # Run with default config
#    portier-broker config.toml                             # Run with TOML config file
#    portier-broker config.toml --import-keys keys.pem      # Import keys
#    portier-broker --import-keys keys.pem --dry-run        # Validate keys without applying
#    portier-broker config.toml --export-keys backup.pem    # Export active keys
#    portier-broker --version
#    portier-broker --help
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  also docopt.rs users):
#    - cargo (NOTE: cargo PRE-clap used docopt; cargo 0.20+ uses
#      clap-derive; cargo IN CORPUS via _cargo)
#    - rustfmt (NOTE: PRE-clap used docopt; current uses clap)
#    - ripgrep (NOTE: PRE-clap used docopt; current uses clap;
#      IN CORPUS via _rg)
#    - chalk (IN CORPUS via _chalk — rust-lang trait reasoner
#      1998 stars; still uses docopt)
#    - ksuid (IN CORPUS via _ksuid — Segment KSUID CLI; uses
#      docopt)
#    - quiche-client / quiche-server (IN CORPUS — Cloudflare QUIC
#      reference apps 11529 stars; use docopt)
#    - microstatus (Arkanosis/microstatus 180 stars — Mastodon
#      ActivityPub server; FUTURE candidate)
#    - gdrivefs (ja30278/gdrivefs 4 stars — Google Drive FUSE;
#      too niche)
# ============================================================================

_portier-broker() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[print help message and exit]' \
    '--version[print version information and exit]' \
    '--import-keys[import PEM private keys from file]:file:_files -g "*.pem"' \
    '--dry-run[parse PEM to be imported, but do not apply changes]' \
    '--export-keys[export currently active private keys as PEM to file]:file:_files' \
    ':config:_files -g "*.toml"'
}

_portier-broker "$@"
