#compdef qview
# _qview — qView (lightweight Qt6 image viewer with continuous panning, GIF/APNG/WebP animation, EXIF rotation; -f fullscreen, --fullscreen explicit, --portable use portable settings dir; positional list of files becomes the active playlist)
# upstream: https://github.com/jurplel/qView
# Flags from qView src/main.cpp on tip.

_qview() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-f[fullscreen]' \
        '--fullscreen[fullscreen]' \
        '--portable[use portable config]' \
        '*:image:_files -g "*.(png|jpg|jpeg|gif|bmp|webp|tiff|tif|avif|jxl|svg|ico|heic|psd)"'
}

_qview "$@"
