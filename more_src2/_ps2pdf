#compdef ps2pdf ps2pdf12 ps2pdf13 ps2pdf14 ps2pdfwr
# _ps2pdf — Ghostscript ps2pdf wrappers (PostScript -> PDF using Ghostscript's pdfwrite device; -dPDFSETTINGS controls quality (screen/ebook/printer/prepress/default), -dCompatibilityLevel sets PDF version, ps2pdf12/13/14 lock the version)
# upstream: https://github.com/ArtifexSoftware/ghostpdl
# Common -dXxx options forwarded to gs; see ghostpdl ps2pdf.in on tip.

_ps2pdf() {
    _arguments \
        '-dPDFSETTINGS=*[quality preset]:preset:(/screen /ebook /printer /prepress /default)' \
        '-dCompatibilityLevel=*[PDF compatibility level]:level:(1.3 1.4 1.5 1.6 1.7 2.0)' \
        '-dPDFA[generate PDF/A]' \
        '-dPDFX[generate PDF/X]' \
        '-dEmbedAllFonts=true[embed fonts]' \
        '-dSubsetFonts=true[subset fonts]' \
        '-dAutoRotatePages=*[autorotate]:mode:(/None /PageByPage /All)' \
        '-dColorImageResolution=*[color image DPI]:dpi:' \
        '-dGrayImageResolution=*[gray image DPI]:dpi:' \
        '-dMonoImageResolution=*[mono image DPI]:dpi:' \
        '1:input ps:_files -g "*.(ps|eps)"' \
        '2:output pdf:_files -g "*.pdf"'
}

_ps2pdf "$@"
