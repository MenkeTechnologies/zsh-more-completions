#compdef remote-coding-agent
# Documentation: https://github.com/awaisshah228/cdoing-agent
# Reference accessed: 2026-05-22
# Verified: packages/remote-coding-agent/src/cli.ts Commander program.

# Zsh completion for remote-coding-agent - multi-channel remote coding agent

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[config file path]:file:_files' \
  '(-d --dir)'{-d,--dir}'[working directory]:directory:_directories' \
  '(-p --provider)'{-p,--provider}'[AI provider]:provider:(anthropic openai google ollama)' \
  '(-m --model)'{-m,--model}'[model name]:model:' \
  '--api-key[API key]:key:' \
  '--mode[permission mode]:mode:(ask auto-edit auto)' \
  '--port[gateway port]:port:' \
  '--telegram-token[Telegram bot token]:token:' \
  '--log-level[log level]:level:(debug info warn error)' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'remote-coding-agent command' \
      'start[start agent default]' \
      'tui[start with TUI dashboard]' \
      'dashboard[start with web dashboard]' \
      'setup[interactive setup wizard]' \
      'login[OAuth or API key login]' \
      'init[generate config template]' \
      'status[check agent and channel status]' \
      'skills[list or manage skills]' && ret=0
    ;;
  args)
    case $line[1] in
      start)
        _arguments '--dashboard[also serve web dashboard]' && ret=0
        ;;
      setup)
        _arguments \
          '(-o --output)'{-o,--output}'[output config path]:file:_files' \
          '--flow[setup flow]:flow:(quickstart advanced)' \
          '--accept-risk[skip security acknowledgement]' \
          '--non-interactive[non-interactive mode]' \
          '--provider[AI provider]:provider:(anthropic openai google ollama)' \
          '(-m --model)'{-m,--model}'[model name]:model:' \
          '--api-key[API key]:key:' \
          '--telegram-token[Telegram bot token]:token:' \
          '--port[gateway port]:port:' \
          '--permission-mode[permission mode]:mode:(ask auto-edit auto)' \
          '--skills[comma-separated skill IDs]:skills:' && ret=0
        ;;
      login)
        _arguments \
          '--oauth[Claude OAuth login]' \
          '--provider[provider for API key]:provider:(anthropic openai google)' \
          '--key[API key to save]:key:' \
          '--role[credential role]:role:(assistant coding)' \
          '--status[show credential status]' \
          '--logout[clear OAuth tokens]' && ret=0
        ;;
      init)
        _arguments '(-o --output)'{-o,--output}'[output file path]:file:_files' && ret=0
        ;;
      skills)
        _arguments \
          '(-c --config)'{-c,--config}'[config file]:file:_files' \
          '--enable[enable skill]:skill:' \
          '--disable[disable skill]:skill:' && ret=0
        ;;
    esac
    ;;
esac

return ret
