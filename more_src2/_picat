#
#  Picat hand-rolled parser distinctive features:
#    - SINGLE-DASH long flags only — `-path`/`-version` (NOT
#      `--path`/`--version`); some flags accept `--help`/
#      `--version` as alternative double-dash forms
#    - sscanf("%lld") for integer parsing — typical C-style
#      string-to-long parsing of numeric flag values
#    - HAND-MAINTAINED USAGE STRING in `print_picat_usage()` —
#      not auto-generated from flag registration
#    - NO subcommand framework — single executable with flags
#      then positional PicatMainFile then user args
#    - NO env-var fallback for most flags except --path → PICATPATH
#      (which IS env-var-aware bidirectionally)
#    - PicatMainFileName is the FIRST non-flag positional — Picat
#      loads it and starts execution at its `main/1` predicate;
#      remaining args become `args/0` accessible from Picat code
#    - SAT-SOLVER-SPECIFIC BPSOLVER build variant disables some
#      flags via `#ifdef BPSOLVER` — when compiled as bp_solver
#      (B-Prolog SAT solver mode) the `-path`/`-p` flag set is
#      replaced
#  Picat's hand-rolled parser philosophy is shared with: B-Prolog
#  (Zhou's earlier system that Picat's VM was forked from),
#  ECLiPSe-CLP (constraint logic programming), traditional Prolog
#  implementations (SWI-Prolog uses its own slightly-richer
#  parser but similar hand-rolled spirit), Mercury (Mercury's mmc
#  compiler uses options.m in Mercury itself), and many older
#  academic-research compilers.  Picat is the FIRST DOCUMENTED
#  Picat CLI library in the corpus's cross-language taxonomy.
#  Picat joins the 33 other documented languages (Rust, Go,
#  TypeScript-Node, Python, Ruby, Perl, Haskell, OCaml, Elixir,
#  R, Bash, Deno, Lua, Scheme, Clojure, Common Lisp, Racket,
#  Crystal, Nim, Zig, Odin, V, Mojo, Roc, Hare, Standard ML,
#  Erlang, Pony, Prolog, Pike, F#, Janet, D) as the 34th
#  represented language.  Brings cross-language CLI library
#  taxonomy variant count to 163 (162 + hand-rolled-Picat = 163).
#
#  Surface (verbatim from `emu/init.c` `print_picat_usage()` and
#  `init_toam()` switch cases):
#
#  Usage:
#    picat [options]* PicatMainFileName A1 A2 ...
#
#  Options:
#    -path <PATH>                   Set PICATPATH env var to
#                                   <PATH> (controls module
#                                   search path for `import`
#                                   statements; alternative to
#                                   setting PICATPATH externally)
#    -p <P>                         Size for program area (in
#                                   bytes; minimum 1,000,000;
#                                   default ~16MB).  Increase
#                                   for large programs.
#    -s <S>                         Size for global and local
#                                   stacks (in bytes; minimum
#                                   1,000,000).  Increase for
#                                   deep-recursion programs or
#                                   large heaps.
#    -b <B>                         Size for trail stack (in
#                                   bytes; minimum 1,000,000).
#                                   Trail stack holds variable-
#                                   binding undo records;
#                                   increase for programs with
#                                   heavy backtracking.
#    -g <GOAL>                      Goal to evaluate after loading
#                                   the main file (instead of
#                                   calling `main/1`).  Example:
#                                   `picat -g 'solve(X), writeln(X)' problem.pi`
#    -d                             Debug mode (enables Picat
#                                   debug tracing)
#    -log                           Log mode (write execution log
#                                   to disk)
#        --help                     Show usage and exit
#        --version                  Show version and exit (current:
#                                   Picat version 3.9#8.2)
#    -v                             Show version (alias for
#                                   --version)
#
#  Positional:
#    PicatMainFileName              Path to Picat source file
#                                   (.pi extension).  Picat loads
#                                   this and calls `main/1` (or
#                                   `main/0` if `main/1` not
#                                   defined; or the goal from -g
#                                   if specified)
#    A1 A2 ...                      User arguments passed to the
#                                   Picat program; accessible via
#                                   the `cl/1` built-in or `args/0`
#                                   reflection
#
#  Examples:
#    picat hello.pi                                 # Load hello.pi and call main/1
#    picat -g 'solve(X), writeln(X)' problem.pi     # Custom goal
#    picat -s 100000000 deep.pi                     # Larger stack
#    picat -p 100000000 huge.pi                     # Larger program area
#    picat -path /opt/picat/lib hello.pi            # Custom module search path
#    picat -d hello.pi                              # Debug trace
#    picat --version                                # Print "Picat version 3.9#8.2"
#    picat --help                                   # Show usage
#    picat hello.pi arg1 arg2 arg3                  # Pass user args (accessible as cl)
#
#  Dup-skipped neighbors during hunt (in corpus or smaller user base,
#  similar hand-rolled C parsers):
#    - prolog / swipl (IN CORPUS — SWI-Prolog uses its own
#      hand-rolled parser similar in style to Picat's; previously
#      documented but parser library not formally entered into
#      taxonomy)
#    - gprolog (IN CORPUS via _gprolog + STOCK — GNU Prolog;
#      hand-rolled C parser)
#    - mercury (IN CORPUS via _mercury — covers mmc/mmake/mtags;
#      Mercury compiler uses options.m parser written in Mercury
#      itself, a hand-rolled-but-in-Mercury parser)
#    - minizinc (IN CORPUS — MiniZinc constraint modeler;
#      different family — Picat is logic+functional, MiniZinc is
#      modeling-DSL)
#    - ats2 / patsopt (patsopt IN CORPUS — ATS programming
#      language; hand-rolled parser too; FUTURE candidate for ATS
#      formal entry)
#    - lobster (CLEAR — Wouter van Oortmerssen's Lobster game
#      scripting; FUTURE candidate)
#    - curry / pakcs (CLEAR — Curry logic+functional via PAKCS;
#      FUTURE candidate)
#    - frege (CLEAR — Haskell-on-JVM; FUTURE candidate)
# ============================================================================

_picat() {
  local context state state_descr line
  typeset -A opt_args

  _arguments -s -S \
    '--help[show usage and exit]' \
    '--version[show version and exit]' \
    '-v[show version (alias for --version)]' \
    '-path[set PICATPATH (module search path)]:path:_directories' \
    '-p[size for program area (bytes; minimum 1000000)]:bytes:' \
    '-s[size for global and local stacks (bytes; minimum 1000000)]:bytes:' \
    '-b[size for trail stack (bytes; minimum 1000000)]:bytes:' \
    '-g[goal to evaluate after loading main file]:goal:' \
    '-d[debug mode]' \
    '-log[log mode (write execution log)]' \
    '*:file:_files -g "*.pi"'
}

_picat "$@"
