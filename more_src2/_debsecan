#compdef debsecan

_debsecan() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(- *)--version[show version and exit]' \
        '--suite=[Debian suite to check]:suite:(bookworm bullseye buster trixie sid)' \
        '--format=[output format]:format:(bugs packages detail summary report)' \
        '--source=[override vulnerability data source URL]:url:_urls' \
        '--status=[path to dpkg status file]:status file:_files' \
        '--config=[path to configuration file]:config file:_files' \
        '--cron[enable cron mode for scheduled reports]' \
        '--disable-https-check[disable HTTPS certificate validation]' \
        '--only-fixed[show only vulnerabilities that have been fixed]' \
        '--no-obsolete[hide obsolete packages]' \
        '--history=[path to history file]:history file:_files' \
        '--mailer=[mailer command to use]:mailer:_command_names' \
        '--mailto=[email address for reports]:email address:' && ret=0

    return ret
}

_debsecan "$@"
