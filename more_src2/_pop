#compdef pop
# Documentation: https://github.com/charmbracelet/pop
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Charm Pop - email sender

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  {-f,--from}'=[sender email address]:email' \
  '*'{-t,--to}'=[recipient email address]:email' \
  {-s,--subject}'=[email subject]:subject' \
  {-b,--body}'=[email body]:body' \
  '*'{-a,--attach}'=[file attachment]:file:_files' \
  '*--cc=[CC recipient]:email' \
  '*--bcc=[BCC recipient]:email' \
  '--preview[preview email before sending]' \
  {-u,--unsafe}'[allow unsafe HTML and extra markdown]' \
  {-x,--signature}'=[signature appended to email]:signature' \
  {-H,--smtp.host}'=[SMTP server host]:host' \
  {-P,--smtp.port}'=[SMTP server port]:port' \
  {-U,--smtp.username}'=[SMTP username]:username' \
  {-p,--smtp.password}'=[SMTP password]:password' \
  {-e,--smtp.encryption}'=[encryption type]:enc:(none ssltls starttls)' \
  {-i,--smtp.insecure}'[skip TLS verification]' \
  {-r,--resend.key}'=[Resend API key]:key' \
  && ret=0

return ret
