#compdef rootcp
# Documentation: https://github.com/root-project/root/blob/master/main/src/rootcp.cxx
# Reference accessed: 2026-05-27
# Verified: upstream RCmdLineOpts AddFlag calls in main/src/rootcp.cxx

# rootcp: copy objects between ROOT files.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --compress)'{-c+,--compress=}'[set compression algorithm/level (compress = 100*algorithm + level)]:value:' \
  '--recreate[recreate the destination file]' \
  '--replace[replace object if already existing]' \
  '(-r --recursive)'{-r,--recursive}'[recurse inside directories]' \
  '*-v[verbose output (repeatable)]' \
  '-vv[more verbose output]' \
  '*:file:_files -g "*.root"' && ret=0

return ret
