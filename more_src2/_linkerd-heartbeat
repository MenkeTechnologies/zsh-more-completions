#compdef linkerd-heartbeat
# _linkerd-heartbeat — Linkerd2 telemetry heartbeat (linkerd/linkerd2)
# upstream: https://github.com/linkerd/linkerd2
# Flags from controller/cmd/heartbeat/main.go on tip.

_linkerd-heartbeat() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-prometheus-url=[Prometheus URL]:url:_urls' \
        '-controller-namespace=[Linkerd control-plane namespace]:ns:' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]' \
        '-stderrthreshold=[stderr klog severity threshold]:level:(INFO WARNING ERROR FATAL)'
}

_linkerd-heartbeat "$@"
