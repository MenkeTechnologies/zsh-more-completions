#compdef kwm kwmc
# _kwm — Koekeishiya kwm tiling WM for macOS CLI alias (Koekeishiya, C); custom argparse (predecessor to chunkwm and yabai)
# upstream: https://github.com/koekeishiya/kwm

_kwm() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-c+[config file]:file:_files -g "kwmrc *.kwm"' \
        '-d[debug mode]' \
        '-i[ignore signals]' \
        '-l+[log file]:file:_files' \
        '-t+[hotkey daemon socket]:str:' \
        '*:command:'
}

_kwm "$@"
