#compdef dh_make
# Documentation: https://manpages.debian.org/bookworm/dh-make/dh_make.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for dh_make (Debian packaging skeleton creator)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-c --copyright)'{-c,--copyright}'[license type]:license:(gpl gpl2 gpl3 lgpl lgpl2 lgpl3 artistic apache bsd mit custom)' \
  '--copyrightfile[copyright file]:file:_files' \
  '--docs[provide documentation files]' \
  '(-e --email)'{-e,--email}'[maintainer email address]:email' \
  '(-n --native)'{-n,--native}'[create native Debian package]' \
  '(-f --file)'{-f,--file}'[use specified orig tarball]:tarball:_files -g "*.tar.*(N)"' \
  '(-l --library)'{-l,--library}'[set package class to library]' \
  '(-s --single)'{-s,--single}'[set package class to single binary]' \
  '(-i --indep)'{-i,--indep}'[set package class to arch-independent]' \
  '(-a --addmissing)'{-a,--addmissing}'[add missing files to existing debian directory]' \
  '(-t --templates)'{-t,--templates}'[apply custom template directory]:directory:_files -/' \
  '(-o --overlay)'{-o,--overlay}'[reuse existing debian directory]:directory:_files -/' \
  '(-p --packagename)'{-p,--packagename}'[force package name]:package name' \
  '(-C --packageclass)'{-C,--packageclass}'[set package class directly]:class' \
  '(-d --defaultless)'{-d,--defaultless}'[skip generation of default content]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-y --yes)'{-y,--yes}'[automatic mode, accept all defaults]' && ret=0

return ret
