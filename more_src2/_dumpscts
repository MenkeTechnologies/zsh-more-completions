#compdef dumpscts
# _dumpscts — Google CT SCT + leaf-data dumper
# upstream: https://github.com/google/certificate-transparency-go
# Flag from preload/dumpscts/dumpscts.go on tip.

_dumpscts() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-sct_file=[file to load SCTs and leaf data from]:file:_files'
}

_dumpscts "$@"
