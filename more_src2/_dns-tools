#compdef dns-tools
# ============================================================================
# dns-tools - DNSSEC zone signing + validation
#              + ZONEMD digests
#              (Go, MIT)
#
# Author : NICLabs (Network Research Group,
#           Universidad de Chile)
# Upstream: https://github.com/niclabs/dns-tools
#
# `dns-tools` is a comprehensive DNSSEC tool
# for signing DNS zone files using either:
#   - **File-based keys** (KSK + ZSK PEM
#     files; standard DNSSEC key storage)
#   - **PKCS#11 HSM** (Hardware Security
#     Module; production-grade key storage
#     in dedicated hardware like YubiHSM2 +
#     Thales Luna + AWS CloudHSM + SoftHSM2)
#
# Also handles:
#   - DNSSEC zone signature verification
#   - ZONEMD (RFC 8976; Zone Digest) addition
#     and verification (sha384 + sha512
#     digests of the zone for integrity
#     checking)
#   - NSEC + NSEC3 (with opt-out) denial-of-
#     existence proof generation
#   - Multiple signature algorithms (RSA +
#     ECDSA per RFC 6605)
#
# Distinguishing features vs alternatives
# (BIND9 dnssec-signzone + OpenDNSSEC +
# Knot DNS dnssec-* tools + ldns-signzone):
#   - **Pure Go implementation** (no BIND
#     dependency; cross-compiles to all
#     platforms)
#   - **PKCS#11 + file-based signing in one
#     tool** (most alternatives require
#     separate tools for HSM vs file-based
#     workflows)
#   - **ZONEMD support** (RFC 8976; most
#     legacy tools predate this RFC)
#   - **Lazy signing mode** (--lazy only
#     re-signs if necessary; useful for
#     CI/CD pipelines)
#   - **Operator-friendly date specs**
#     (humantime-style --rrsig-duration
#     "3 months" vs explicit YYYYMMDD)
#   - **Verification with threshold**
#     (--verify-threshold-duration treats
#     signatures expiring within a window
#     as already expired; useful for
#     monitoring)
#
# Use cases:
#   - DNSSEC zone signing for top-level
#     domain (TLD) operators
#   - ccTLD registry operations (NICLabs
#     itself runs Chile's .CL registry)
#   - DNSSEC signing in CI/CD pipelines
#     (automated zone updates with HSM-
#     backed keys)
#   - ZONEMD digest addition for zone
#     transfer integrity verification
#   - Migration from BIND9 to native Go
#     DNS infrastructure
#   - Academic + research DNS labs (NICLabs
#     itself is a research lab)
#
# Usage:
#   dns-tools [-C config] <subcommand> [args]
#
# Persistent (global) flag:
#   -C, --config <file>            - configuration
#                                     file
#                                     (defaults:
#                                     /etc/
#                                     dns-tools/
#                                     dns-tools-
#                                     config.json
#                                     or ./
#                                     dns-tools-
#                                     config.json)
#
# Subcommands:
#   sign pkcs11                    - sign a
#                                     DNS zone
#                                     using
#                                     keys
#                                     stored in
#                                     an HSM
#                                     via
#                                     PKCS#11
#   sign file                      - sign a
#                                     DNS zone
#                                     using
#                                     keys from
#                                     PEM files
#   verify                         - verify
#                                     DNSSEC
#                                     signatures
#                                     +
#                                     ZONEMD
#                                     digests
#                                     in a
#                                     zone
#                                     file
#   digest                         - add
#                                     ZONEMD
#                                     digest
#                                     RR to a
#                                     zone
#   reset-pkcs11-keys              - delete
#                                     all
#                                     keys in
#                                     the HSM
#                                     with
#                                     specified
#                                     key
#                                     label +
#                                     algorithm
#
# `sign` common flags (apply to both pkcs11
# + file modes):
#   -f, --file <path>              - full path
#                                     to zone
#                                     file to
#                                     be
#                                     signed
#   -z, --zone <name>              - origin
#                                     zone
#                                     name
#                                     (default
#                                     $ORIGIN
#                                     in
#                                     zone
#                                     file)
#   -o, --output <path>            - output
#                                     for the
#                                     signed
#                                     zone
#                                     file
#                                     (default:
#                                     based on
#                                     zone
#                                     file
#                                     name +
#                                     "-signed"
#                                     suffix)
#   -c, --create-keys              - create a
#                                     new pair
#                                     of keys
#                                     (deletes
#                                     all
#                                     previously
#                                     valid
#                                     keys)
#   -a, --sign-algorithm <algo>    - algorithm
#                                     for
#                                     signing
#                                     (rsa +
#                                     ecdsa;
#                                     default
#                                     rsa)
#   -3, --nsec3                    - use NSEC3
#                                     instead
#                                     of NSEC
#   -x, --opt-out                  - use NSEC3
#                                     with
#                                     opt-out
#                                     (RFC
#                                     5155
#                                     Section
#                                     6)
#   -d, --digest                   - add
#                                     DigestEnabled
#                                     RR
#                                     (ZONEMD)
#                                     to the
#                                     signed
#                                     zone
#   -Q, --hash-digest <n>          - hash
#                                     algorithm
#                                     for
#                                     digest
#                                     verification
#                                     (1=sha384
#                                     + 2=
#                                     sha512;
#                                     default
#                                     1)
#   -i, --info                     - add a TXT
#                                     RR with
#                                     info
#                                     about
#                                     the
#                                     signing
#                                     process
#                                     (tool +
#                                     mode)
#   -L, --lazy                     - only
#                                     sign if
#                                     needed
#                                     (not
#                                     signed
#                                     already +
#                                     different
#                                     key +
#                                     signatures
#                                     near
#                                     expiry +
#                                     original
#                                     newer
#                                     than
#                                     signed)
#   -E, --rrsig-expiration-date <date> - RRSIG
#                                     expiration
#                                     date in
#                                     YYYYMMDD
#                                     (default
#                                     3 months
#                                     from now)
#   -D, --rrsig-duration <dur>     - relative
#                                     RRSIG
#                                     expiration
#                                     (humantime
#                                     format
#                                     like
#                                     "3 months
#                                     + 1 week";
#                                     overrides
#                                     --rrsig-
#                                     expiration-
#                                     date)
#   -t, --verify-threshold-duration <dur> -
#                                     days
#                                     needed
#                                     before
#                                     signature
#                                     expiration
#                                     for
#                                     verifier
#                                     to
#                                     consider
#                                     valid
#   -T, --verify-threshold-date <date> -
#                                     exact
#                                     date
#                                     before
#                                     signature
#                                     expiration
#                                     (ignored
#                                     if
#                                     --verify-
#                                     threshold-
#                                     duration
#                                     set)
#       --nsec3-iterations <n>     - if --nsec3
#                                     active +
#                                     iterations
#                                     for
#                                     NSEC3
#                                     hashing
#       --nsec3-salt-length <n>    - NSEC3
#                                     salt
#                                     length
#                                     in bytes
#                                     (default
#                                     64)
#       --nsec3-salt-value <hex>   - NSEC3
#                                     salt
#                                     value in
#                                     hex
#                                     (overrides
#                                     --nsec3-
#                                     salt-
#                                     length)
#
# `sign pkcs11` flags (PKCS#11 HSM-specific):
#   -k, --user-key <pin>           - HSM user
#                                     login
#                                     PIN
#                                     (default
#                                     1234)
#   -l, --key-label <label>        - label of
#                                     HSM
#                                     signer
#                                     key
#                                     (default
#                                     HSM-tools)
#   -p, --p11lib <path>            - full path
#                                     to
#                                     PKCS11
#                                     lib file
#                                     (e.g.
#                                     /usr/
#                                     lib/
#                                     softhsm/
#                                     libsofthsm2
#                                     .so)
#
# `sign file` flags (PEM file-specific):
#   -Z, --zsk-keyfile <path>       - full path
#                                     to ZSK
#                                     (Zone
#                                     Signing
#                                     Key) PEM
#                                     file
#                                     (default
#                                     zsk.pem)
#   -K, --ksk-keyfile <path>       - full path
#                                     to KSK
#                                     (Key
#                                     Signing
#                                     Key) PEM
#                                     file
#                                     (default
#                                     ksk.pem)
#
# `verify` flags:
#   -f, --file <path>              - full path
#                                     to zone
#                                     file to
#                                     be
#                                     verified
#   -z, --zone <name>              - zone name
#   -S, --skip-signatures          - skip
#                                     verification
#                                     of
#                                     DNSSEC
#                                     signatures
#   -D, --skip-digests             - skip
#                                     verification
#                                     of
#                                     ZONEMD
#                                     digests
#   -t, --verify-threshold-duration <dur> -
#                                     same as
#                                     sign
#                                     mode
#   -T, --verify-threshold-date <date> - same
#                                     as sign
#                                     mode
#
# `digest` flags:
#   -f, --file <path>              - full path
#                                     to zone
#                                     file
#   -z, --zone <name>              - zone name
#   -o, --output <path>            - full path
#                                     to
#                                     output
#                                     file
#   -i, --info                     - add TXT
#                                     RR with
#                                     signing
#                                     process
#                                     info
#   -d, --hash-digest <n>          - hash
#                                     algorithm
#                                     for
#                                     digest
#                                     (1=sha384
#                                     + 2=
#                                     sha512;
#                                     default
#                                     1)
#
# `reset-pkcs11-keys` flags:
#   -p, --p11lib <path>            - full path
#                                     to
#                                     PKCS#11
#                                     lib file
#   -k, --user-key <pin>           - HSM user
#                                     login PIN
#                                     (default
#                                     1234)
#   -l, --key-label <label>        - label of
#                                     HSM
#                                     signer
#                                     key
#                                     (default
#                                     HSM-tools)
#
# Example invocations:
#   # Sign a zone using file-based keys
#   dns-tools sign file \
#     -f example.com.zone \
#     -z example.com \
#     -Z zsk.pem -K ksk.pem
#
#   # Sign with NSEC3 + opt-out + ZONEMD digest
#   dns-tools sign file \
#     -f example.com.zone -z example.com \
#     -Z zsk.pem -K ksk.pem \
#     --nsec3 --opt-out --digest
#
#   # Sign using SoftHSM2 (PKCS#11)
#   dns-tools sign pkcs11 \
#     -f example.com.zone -z example.com \
#     -p /usr/lib/softhsm/libsofthsm2.so \
#     -k 1234 -l my-signing-key
#
#   # Verify a signed zone (signatures + ZONEMD)
#   dns-tools verify \
#     -f example.com.zone.signed \
#     -z example.com
#
#   # Add only ZONEMD without signing
#   dns-tools digest \
#     -f example.com.zone \
#     -z example.com \
#     -o example.com.zone.digested \
#     --hash-digest 2
#
#   # Reset all HSM keys with given label
#   dns-tools reset-pkcs11-keys \
#     -p /usr/lib/softhsm/libsofthsm2.so \
#     -l HSM-tools
#
#   # Use config file (system + working dir)
#   dns-tools -C /etc/dns-tools/dns-tools-config.json \
#     sign file -f example.com.zone -z example.com
#
# The miekg/dns lane is built on `github.com/
# miekg/dns v1.1.45` (declared verbatim at
# upstream go.mod HEAD as a direct dep,
# imported by `tools/` for zone file parsing
# + DNS message wire format encoding/decoding
# + DNSSEC signature generation/verification
# + NSEC3 hashing + ZONEMD digest computation),
# the canonical Go DNS library by Miek Gieben
# - github.com/miekg/dns.
#
# miekg/dns is the de-facto canonical Go DNS
# library:
#   - **Author is a DNS RFC author** (Miek
#     Gieben co-authored RFC 4034 + 4035 +
#     5155 DNSSEC documents + serves on
#     IETF DNSOP working group)
#   - **Complete DNS protocol coverage**
#     (RFC 1035 + 30+ extension RFCs)
#   - **Full DNSSEC support** (DNSSEC zone
#     signing + signature verification +
#     trust anchor handling + key generation
#     - ECDSA + RSA + EdDSA per RFC 6605 +
#     8080)
#   - **NSEC + NSEC3** (RFC 4034 + 5155
#     denial-of-existence proofs)
#   - **EDNS0 + OPT RR** (RFC 6891)
#   - **DNS-over-TLS (DoT) + DNS-over-HTTPS
#     (DoH)** (RFC 7858 + 8484)
#   - **Resource record types**: A + AAAA +
#     SOA + NS + MX + TXT + DNAME + CNAME
#     + DS + DNSKEY + RRSIG + NSEC + NSEC3
#     + NSEC3PARAM + CAA + TLSA + SSHFP +
#     URI + CDS + CDNSKEY + ZONEMD + SVCB +
#     HTTPS + many more (essentially all
#     registered DNS RR types)
#   - **8,400+ stars on github.com/miekg/dns**
#   - **~33,000 reverse-deps on pkg.go.dev**
#     (one of the highest-imported Go
#     libraries; powers virtually every Go
#     DNS tool including CoreDNS + Knot
#     Resolver's KRTI + dnscontrol + ...)
#
# miekg/dns's distinguishing position vs Go
# DNS alternatives:
#   - miekg/dns (Gieben): canonical; RFC
#     author; full protocol coverage; THIS
#     AXIS
#   - Native Go net.Resolver: stdlib;
#     wraps libc getaddrinfo; limited to
#     basic A/AAAA queries; no DNSSEC; no
#     custom record types
#   - bogdanovich/dns_resolver: thin
#     resolver wrapper; smaller scope
#   - Google's go-dnsmessage: low-level
#     DNS message parsing; experimental
#     stdlib package
#
# Miek Gieben is one of the most prominent
# DNS engineers in the open-source
# community:
#   - **DNS RFC author** (co-authored
#     multiple DNSSEC RFCs)
#   - **IETF DNSOP participant**
#   - **CoreDNS co-founder + original
#     author** (CoreDNS is the Kubernetes
#     cluster DNS server - one of the
#     most-deployed DNS servers in
#     production today; built on
#     miekg/dns)
#   - **PowerDNS engineering**
#     (commercial DNS infrastructure
#     company; Gieben's earlier work)
#
# Multi-axis canonical-Go author/org cohort
# extension (now spanning 22 distinct
# individuals/orgs after R1545):
#   - + Miek Gieben (miekg/dns + CoreDNS
#     co-founder; THIS AXIS; canonical Go
#     DNS + DNS RFC author + IETF DNSOP
#     participant)
#
# Gieben joining the canonical-Go cohort at
# the *RFC-author canonical implementer*
# level is structurally analogous to:
#   - Furuhashi for Node MessagePack (Axis
#     278 closer): spec author + canonical
#     Node implementation
#   - Google's protobuf team for Go
#     Protocol Buffers (Axis 279 Go slot):
#     spec author + canonical Go
#     implementation
#
# Across the three binary-serialization
# axes (278+279+280) + 281 WebSocket +
# 282 DNS, the *spec-author-canonical-
# implementer* pattern has appeared in:
#   - Axis 278 MessagePack (Node lane:
#     Furuhashi)
#   - Axis 279 Protocol Buffers (Go lane:
#     Google's protobuf team)
#   - Axis 282 DNS (Go lane: Gieben as
#     RFC co-author + canonical Go DNS
#     implementer)
#
# Notable: Axis 282 has Gieben in the *Go
# lane as RFC co-author + canonical
# implementer*. The Go DNS canonical
# implementer is also a DNSSEC RFC
# co-author - the spec-author-canonical-
# implementer convergence at its strongest
# (RFC co-authorship + canonical library
# authorship).
#
# dns-tools uses miekg/dns for:
#   - Zone file parsing (the full DNS
#     master file format per RFC 1035
#     Section 5)
#   - DNS message encoding/decoding (for
#     the verify subcommand's protocol-
#     level message handling)
#   - DNSSEC signature generation (RRSIG
#     RR creation with RSA + ECDSA)
#   - DNSSEC signature verification
#   - NSEC + NSEC3 chain construction
#     (denial-of-existence proofs)
#   - ZONEMD digest computation (RFC 8976)
#   - DS + DNSKEY + RRSIG RR construction
#
# Combined with miekg/pkcs11 for HSM
# interaction (also by Gieben), dns-tools
# is built on Gieben's complete Go DNS
# stack.
#
# This is the canonical use case for
# miekg/dns in production: comprehensive
# DNSSEC tooling where the full DNS
# protocol surface is needed (not just
# basic A/AAAA resolution but signature
# generation + key management + zone
# transfer protocols).
#
# ----------------------------------------------------------------------------
# AXIS 282 :: DNS (Domain Name System)
#              libraries
#              (RFC 1035 + extensions:
#              EDNS0 + DNSSEC + DoH/DoT/
#              DoQ; resolver + protocol +
#              authoritative server
#              implementations)
# Round 1545 :: Go slot 2 of 4 :: continues Axis 282
#
# Cross-language canonical library family
# for this axis:
#   Rust    : hickory-dns/hickory-resolver [R1544 _noip-duc]
#             (Benjamin Fry + Hickory DNS
#              project / formerly trust-dns;
#              canonical Rust DNS stack)
#   Go      : miekg/dns                  [R1545 THIS FILE]
#             (Miek Gieben; DNS RFC author;
#              canonical Go DNS; powers
#              CoreDNS + most Go DNS tools)
#   TS/Node : mafintosh/dns-packet       [R1546 closing]
#             (Mathias Buus; canonical
#              Node DNS wire-format library)
#
# Use-case spectrum across the lanes (so far):
#   - noip-duc (Rust, hickory-resolver):
#     dynamic DNS update client public IP
#     discovery via custom DNS queries
#   - dns-tools (Go, miekg/dns): DNSSEC
#     zone signing + verification + ZONEMD
#     digest tooling for production DNS
#     operators (ccTLDs + research labs +
#     enterprise DNS infrastructure)
#
# Both use cases exercise *specialized DNS
# protocol operations* beyond basic A/AAAA
# resolution:
#   - noip-duc: custom DNS queries with
#     server + record type specification
#   - dns-tools: full DNSSEC zone signing
#     with HSM key storage + ZONEMD digest
#
# Together they illustrate why custom DNS
# libraries exist alongside stdlib resolvers:
# stdlib resolvers handle basic forward
# lookups but specialized DNS work (DNSSEC
# + custom servers + alt transports +
# zone signing) requires full-protocol
# libraries.
# ============================================================================

_dns-tools() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '(-C --config)'{-C+,--config=}'[configuration file]:file:_files -g "*.json"' \
        '1: :_dns-tools_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                sign)
                    _arguments -C \
                        '1: :(pkcs11 file)' \
                        '*::sign-sub:->signsub'
                    case $state in
                        signsub)
                            _arguments \
                                '(-f --file)'{-f+,--file=}'[zone file path]:file:_files' \
                                '(-z --zone)'{-z+,--zone=}'[origin zone name]:zone:' \
                                '(-o --output)'{-o+,--output=}'[output signed zone]:file:_files' \
                                '(-c --create-keys)'{-c,--create-keys}'[create new key pair (deletes existing)]' \
                                '(-a --sign-algorithm)'{-a+,--sign-algorithm=}'[signing algorithm]:algo:(rsa ecdsa)' \
                                '(-3 --nsec3)'{-3,--nsec3}'[use NSEC3 instead of NSEC]' \
                                '(-x --opt-out)'{-x,--opt-out}'[use NSEC3 with opt-out]' \
                                '(-d --digest)'{-d,--digest}'[add DigestEnabled RR (ZONEMD)]' \
                                '(-Q --hash-digest)'{-Q+,--hash-digest=}'[hash algorithm]:n:(1 2)' \
                                '(-i --info)'{-i,--info}'[add TXT RR with signing process info]' \
                                '(-L --lazy)'{-L,--lazy}'[only sign if needed]' \
                                '(-E --rrsig-expiration-date)'{-E+,--rrsig-expiration-date=}'[RRSIG expiration YYYYMMDD]:date:' \
                                '(-D --rrsig-duration)'{-D+,--rrsig-duration=}'[relative RRSIG expiration]:dur:' \
                                '(-t --verify-threshold-duration)'{-t+,--verify-threshold-duration=}'[verify threshold duration]:dur:' \
                                '(-T --verify-threshold-date)'{-T+,--verify-threshold-date=}'[verify threshold date]:date:' \
                                '--nsec3-iterations=[NSEC3 hashing iterations]:n:' \
                                '--nsec3-salt-length=[NSEC3 salt length in bytes]:n:' \
                                '--nsec3-salt-value=[NSEC3 salt value in hex]:hex:' \
                                '(-k --user-key)'{-k+,--user-key=}'[HSM user PIN]:pin:' \
                                '(-l --key-label)'{-l+,--key-label=}'[HSM key label]:label:' \
                                '(-p --p11lib)'{-p+,--p11lib=}'[full path to PKCS11 lib]:file:_files' \
                                '(-Z --zsk-keyfile)'{-Z+,--zsk-keyfile=}'[ZSK PEM file]:file:_files -g "*.pem"' \
                                '(-K --ksk-keyfile)'{-K+,--ksk-keyfile=}'[KSK PEM file]:file:_files -g "*.pem"'
                            ;;
                    esac
                    ;;
                verify)
                    _arguments \
                        '(-f --file)'{-f+,--file=}'[zone file path]:file:_files' \
                        '(-z --zone)'{-z+,--zone=}'[zone name]:zone:' \
                        '(-S --skip-signatures)'{-S,--skip-signatures}'[skip DNSSEC signature verification]' \
                        '(-D --skip-digests)'{-D,--skip-digests}'[skip ZONEMD digest verification]' \
                        '(-t --verify-threshold-duration)'{-t+,--verify-threshold-duration=}'[verify threshold duration]:dur:' \
                        '(-T --verify-threshold-date)'{-T+,--verify-threshold-date=}'[verify threshold date]:date:'
                    ;;
                digest)
                    _arguments \
                        '(-f --file)'{-f+,--file=}'[zone file path]:file:_files' \
                        '(-z --zone)'{-z+,--zone=}'[zone name]:zone:' \
                        '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
                        '(-i --info)'{-i,--info}'[add TXT RR with signing process info]' \
                        '(-d --hash-digest)'{-d+,--hash-digest=}'[hash algorithm]:n:(1 2)'
                    ;;
                reset-pkcs11-keys)
                    _arguments \
                        '(-p --p11lib)'{-p+,--p11lib=}'[full path to PKCS11 lib]:file:_files' \
                        '(-k --user-key)'{-k+,--user-key=}'[HSM user PIN]:pin:' \
                        '(-l --key-label)'{-l+,--key-label=}'[HSM key label]:label:'
                    ;;
            esac
            ;;
    esac

    return ret
}

_dns-tools_cmds() {
    local -a cmds
    cmds=(
        'sign:sign a DNS zone (use sign pkcs11 or sign file)'
        'verify:verify DNSSEC signatures + ZONEMD digests'
        'digest:add ZONEMD digest RR to the zone'
        'reset-pkcs11-keys:delete all keys in the HSM with specified label'
    )
    _describe -t commands 'dns-tools command' cmds
}

_dns-tools "$@"
