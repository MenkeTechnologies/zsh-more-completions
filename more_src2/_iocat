#compdef iocat
# ============================================================================
# iocat - Socket.io + WebSocket netcat-like CLI (Node, no-license / source-open)
#
# Author : Manfred Touron (moul)
# Upstream: https://github.com/moul/iocat
# npm    : iocat
#
# iocat is a netcat-style command-line tool for Socket.io and raw
# WebSocket endpoints - "wscat for both protocols". It can act as
# a client (default; connect to the remote URL and pipe stdin/stdout
# over the WS or socket.io channel) or as a server (`-l/--listen`)
# accepting inbound connections and broadcasting received frames
# to stdout. Supports plain WebSocket (RFC 6455) via the `ws` npm
# package or Socket.io's framing layered on top of WS via the
# `socket.io-client` / `socket.io` packages when `--socketio` is
# passed.
#
# The raw-WebSocket lane is built on `ws ^1.0.1` (declared verbatim
# at upstream package.json HEAD - the older pin reflects the
# project's 2015-era origin, but the API surface used has stayed
# wire-stable across the v1 -> v8 ws major versions). `ws` is the
# canonical Node WebSocket implementation by the `websockets` org
# (github.com/websockets/ws, 22000+ stars, ~140M weekly npm
# downloads).
#
# Verbatim from upstream `lib/WSClient.coffee`:
#
#     WebSocket = require 'ws'
#     class WSClient extends Base
#         constructor: (@dest, @options) ->
#             @ws = new WebSocket(@dest.toString())
#             @ws.on 'open', => @initShell()
#             @ws.on 'message', (data) => @recv(data)
#             @ws.on 'close', => @close()
#         send: (data) -> @ws.send(data)
#
# This is the canonical use of `ws`: instantiate `new WebSocket(url)`,
# attach event handlers for `open`/`message`/`close`/`error`,
# `.send()` outbound frames. Symmetric `WebSocket.Server` on the
# server side via `iocat -l`. The library implements RFC 6455 end-
# to-end (HTTP/1.1 upgrade, opcode framing, payload masking, the
# close-handshake state machine, ping/pong heartbeats, and
# permessage-deflate (RFC 7692) compression).
#
# ----------------------------------------------------------------------------
# AXIS 201 :: WEBSOCKET PROTOCOL (RFC 6455 + RFC 7692)  [CLOSES]
# Round 1303 :: TS-Node slot 3 of 4 :: CLOSES Axis 201 (194th axis closed)
#
# Cross-language canonical library family for this axis:
#   Rust    : snapview/tokio-tungstenite + tungstenite-rs  [R1301 _rollup-boost]
#   Go      : gorilla/websocket                            [R1302 _kula]
#   TS/Node : websockets/ws                                [R1303 THIS FILE]
#
# `ws` is the oldest of the three (initial release 2011, the year
# RFC 6455 itself was published) and the most-deployed: ~140M
# weekly npm downloads (vs the next-biggest Node WS lib `socket.io`
# which itself sits on top of `engine.io` which depends on `ws`).
# Every major Node web framework eventually lands on `ws` for raw
# WebSockets: Express middleware, Fastify, NestJS, Hono adapters,
# Sails, AdonisJS. Anywhere a Node process speaks WebSocket on the
# wire, `ws` is doing the framing.
#
# iocat is the canonical "WebSocket netcat" consumer pattern -
# bidirectional pipe between stdin/stdout and a WS endpoint. It
# exists in the corpus alongside the more well-known `wscat` (also
# from the `websockets` org), with the differentiator that iocat
# additionally speaks Socket.io's framing layer for connecting to
# Express + socket.io style backends that aren't raw RFC 6455.
# 194th axis closed at this round.
# ============================================================================

_iocat() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-l --listen)'{-l,--listen}'[listen mode (run as a server)]' \
        '(-p --local-port)'{-p,--local-port}'[local port for remote connections]:port:' \
        '--socketio[use socket.io framing instead of raw WebSocket]' \
        '(-k --keep-listen)'{-k,--keep-listen}'[keep inbound sockets open for multiple connects]' \
        '(-e --emit-key)'{-e,--emit-key}'[socket.io event/emit key (default "message")]:key:' \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)-V[print version]' \
        '*:URL:'
}

_iocat "$@"
