#compdef kuma-cli kumactl
# _kuma-cli — Kong Kuma kuma-cli CLI command-line frontend wrapping the Kuma CNCF Sandbox open-source modern Envoy-based service mesh that can run on Kubernetes EC2 OpenShift VMs and bare metal apply config delete generate get inspect install uninstall version completion management apply config delete generate dataplane mesh service circuit-breaker fault-injection health-check proxytemplate retry timeout traffic-log traffic-permission traffic-route traffic-trace meshes-gateways MeshTrafficPermission MeshHTTPRoute MeshAccessLog (Kong Kuma CNCF team Marco Palladino Mike Bilodeau, Go); cobra
# upstream: https://kuma.io/

_kuma-cli() {
    local -a sub=(
        'apply:apply a Kuma resource'
        'config:configure kumactl'
        'completion:generate shell completion'
        'delete:delete a Kuma resource'
        'generate:generate certificates and IDs'
        'get:show Kuma resource details'
        'inspect:inspect Kuma resources'
        'install:install Kuma components'
        'uninstall:uninstall Kuma components'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--config-file=+[file]:file:_files -g "*.yaml *.yml"' \
        '--api-timeout=+[d]:str:' \
        '--no-config[no config]' \
        '-m+[mesh]:str:' \
        '--mesh=+[name]:str:' \
        '--log-level=+[l]:l:(off info debug)' \
        '-o+[output format]:f:(table yaml json universal)' \
        '--output=+[fmt]:f:(table yaml json universal)' \
        '-f+[file]:file:_files -g "*.yaml *.yml"' \
        '--file=+[file]:file:_files -g "*.yaml *.yml"' \
        '-v+[variable]:str:' \
        '*--var=+[k=v]:str:' \
        '--dry-run[dry run]' \
        '--cni-enabled[CNI enabled]' \
        '--mode=+[m]:m:(zone global)' \
        '--zone=+[name]:str:' \
        '--namespace=+[ns]:str:' \
        '--registry=+[name]:str:' \
        '--version-flag=+[v]:str:' \
        '--store-type=+[t]:t:(memory postgres etcd kubernetes mysql)' \
        '--cp-mode=+[m]:m:(standalone zone global)' \
        '--global-zone-sync-base-uri=+[url]:str:' \
        '--admission-server-tls-cert-file=+[file]:file:_files' \
        '--admission-server-tls-key-file=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kumactl subcommand' sub ;;
        args)
            case $words[1] in
                get|delete|inspect|apply) _arguments '1:type:(circuit-breakers dataplanes external-services fault-injections health-checks meshes proxytemplates retries timeouts traffic-logs traffic-permissions traffic-routes traffic-traces zones zone-egresses zone-ingresses meshtraces meshtrafficpermissions meshhttproutes meshaccesslogs meshmetrics meshratelimits meshcircuitbreakers meshtrace meshtimeouts meshfaultinjections meshhealthchecks meshpassthroughs meshretries meshproxypatches)' '*:name:' ;;
                config) _arguments '1:op:(view control-planes contexts)' '*:arg:' ;;
                install|uninstall) _arguments '1:component:(control-plane crds demo gateway transparent-proxy logging metrics tracing observability ebpf zoneingress zoneegress)' '*:arg:' ;;
                generate) _arguments '1:op:(certificate dataplane-token user-token zone-token)' '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_kuma-cli "$@"
