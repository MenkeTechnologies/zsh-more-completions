#compdef pnmnorm pgmnorm
# Documentation: man pnmnorm (Netpbm)
# Source: stretch-normalize the brightness of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-bpercent -bvalue -bsingle)-bpercent=[black-clip percent]:percent:' \
    '(-bpercent -bvalue -bsingle)-bvalue=[black-clip sample value]:n:' \
    '(-bpercent -bvalue -bsingle)-bsingle[black clip to the single darkest sample]' \
    '(-wpercent -wvalue -wsingle)-wpercent=[white-clip percent]:percent:' \
    '(-wpercent -wvalue -wsingle)-wvalue=[white-clip sample value]:n:' \
    '(-wpercent -wvalue -wsingle)-wsingle[white clip to the single brightest sample]' \
    '-midvalue=[map midpoint value]:n:' \
    '-middle=[middle anchor sample]:n:' \
    '-maxexpand=[max expansion percent]:percent:' \
    '-keephues[normalise without shifting hues]' \
    '(-luminosity -colorvalue -saturation)-luminosity[normalise on luminosity]' \
    '(-luminosity -colorvalue -saturation)-colorvalue[normalise on per-channel value]' \
    '(-luminosity -colorvalue -saturation)-saturation[normalise on saturation]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
