autoload -U is-at-least

_oag() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_oag_commands" \
"*::: :->oag" \
&& ret=0
    case $state in
    (oag)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:oag-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
'--force-scaffold[Overwrite scaffold files (package.json, tsconfig.json, etc.) even if they already exist. By default, scaffold files are only written on initial creation to preserve customizations]' \
'-h[Print help]' \
'--help[Print help]' \
'::input -- Path to the OpenAPI spec file (YAML or JSON). Overrides the `input` field in the config:_files' \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':input -- Path to the OpenAPI spec file (YAML or JSON):_files' \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':input -- Path to the OpenAPI spec file (YAML or JSON):_files' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'*-p+[Pack IDs to download (e.g., node-client, fastapi-server)]:PACK:_default' \
'*--pack=[Pack IDs to download (e.g., node-client, fastapi-server)]:PACK:_default' \
'--force[Overwrite an existing oag.yaml file]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':shell -- Target shell for completions:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(packs)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
":: :_oag__packs_commands" \
"*::: :->packs" \
&& ret=0

    case $state in
    (packs)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:oag-packs-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
'--id=[Download a pack by ID from GitHub (e.g., node-client)]:ID:_default' \
'-h[Print help]' \
'--help[Print help]' \
'::source -- Path to a local pack directory:_files' \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
':id -- Pack ID to remove:_default' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_oag__packs__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:oag-packs-help-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(update)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_oag__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:oag-help-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(validate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(inspect)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(check)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(packs)
_arguments "${_arguments_options[@]}" : \
":: :_oag__help__packs_commands" \
"*::: :->packs" \
&& ret=0

    case $state in
    (packs)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:oag-help-packs-command-$line[1]:"
        case $line[1] in
            (list)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(install)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(remove)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(update)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(version)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_oag_commands] )) ||
_oag_commands() {
    local commands; commands=(
'generate:Generate code from an OpenAPI spec using oag.yaml configuration' \
'validate:Validate an OpenAPI spec and report its contents (paths, schemas, operations)' \
'inspect:Dump the parsed intermediate representation (IR) as JSON for debugging' \
'init:Create an oag.yaml config file and download packs from GitHub' \
'check:Run validators (lint, typecheck) on generated output directories' \
'completions:Generate shell completion scripts for tab-completion (bash, zsh, fish, powershell, elvish)' \
'packs:Manage packs for code generation' \
'update:Self-update oag to the latest release' \
'version:Print the current version' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'oag commands' commands "$@"
}
