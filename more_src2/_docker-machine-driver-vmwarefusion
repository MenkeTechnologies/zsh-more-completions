#compdef docker-machine-driver-vmwarefusion
# _docker-machine-driver-vmwarefusion — Docker Machine VMware Fusion driver (out-of-tree macOS plugin so docker-machine can spawn boot2docker VMs in VMware Fusion; plugin binary itself only exposes --version, --debug, --plugin; rest of the surface comes from docker-machine create --driver vmwarefusion)
# upstream: https://github.com/docker/machine (drivers/vmwarefusion)
# Flags from docker/machine drivers/vmwarefusion on tip.

_docker-machine-driver-vmwarefusion() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--debug[debug to stderr]' \
        '--plugin[run as plugin]'
}

_docker-machine-driver-vmwarefusion "$@"
