#compdef maildirmake
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/maildirmake.courier.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# maildirmake (courier): create maildirs and maildir folders
local curcontext="$curcontext" ret=1

_arguments -C \
  '-S[create a sharable maildir]' \
  '-q+[install a quota on the maildir]:quota' \
  '-f+[create folder in an existing maildir]:folder' \
  '-F+[create folder using system locale charset (instead of UTF-8)]:folder' \
  '-s+[create publicly accessible folders in sharable maildirs]:mode:(read write group)' \
  '--add=[create access links for a shared folder]:name=pathname' \
  '--del=[remove shared folder access links]:name' \
  '--checkutf8[verify pre-unicode maildir can convert to UTF-8]' \
  '--convutf8[convert pre-unicode maildir to UTF-8]' \
  '*:maildir path:_files -/' && ret=0

return ret
