#compdef podfeed
# Documentation: https://github.com/graelo/podfeed
# Reference accessed: 2026-05-20
# Verified: clap-generated completion (produced via `podfeed generate-completion zsh`).
# Source: cargo binstall podfeed@0.3.2
# Probed via: generate-completion zsh
# Repository: https://github.com/graelo/podfeed

autoload -U is-at-least

_podfeed() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_podfeed_commands" \
"*::: :->podfeed" \
&& ret=0
    case $state in
    (podfeed)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:podfeed-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
'-d+[Data dirpath]:DATA_DIR:_files -/' \
'--data-dir=[Data dirpath]:DATA_DIR:_files -/' \
'--base-url=[Base URL]:BASE_URL:_default' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(generate-completion)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- Shell for which you want completion:(bash elvish fish powershell zsh)' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_podfeed__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:podfeed-help-command-$line[1]:"
        case $line[1] in
            (generate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate-completion)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_podfeed_commands] )) ||
_podfeed_commands() {
    local commands; commands=(
'generate:Save the Tmux sessions to a new backup file' \
'generate-completion:Print a shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'podfeed commands' commands "$@"
}
(( $+functions[_podfeed__generate_commands] )) ||
_podfeed__generate_commands() {
    local commands; commands=()
    _describe -t commands 'podfeed generate commands' commands "$@"
}
(( $+functions[_podfeed__generate-completion_commands] )) ||
_podfeed__generate-completion_commands() {
    local commands; commands=()
    _describe -t commands 'podfeed generate-completion commands' commands "$@"
}
(( $+functions[_podfeed__help_commands] )) ||
_podfeed__help_commands() {
    local commands; commands=(
'generate:Save the Tmux sessions to a new backup file' \
'generate-completion:Print a shell completion script to stdout' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'podfeed help commands' commands "$@"
}
(( $+functions[_podfeed__help__generate_commands] )) ||
_podfeed__help__generate_commands() {
    local commands; commands=()
    _describe -t commands 'podfeed help generate commands' commands "$@"
}
(( $+functions[_podfeed__help__generate-completion_commands] )) ||
_podfeed__help__generate-completion_commands() {
    local commands; commands=()
    _describe -t commands 'podfeed help generate-completion commands' commands "$@"
}
(( $+functions[_podfeed__help__help_commands] )) ||
_podfeed__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'podfeed help help commands' commands "$@"
}

if [ "$funcstack[1]" = "_podfeed" ]; then
    _podfeed "$@"
else
    compdef _podfeed podfeed
fi
