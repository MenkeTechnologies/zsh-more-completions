#compdef med2xml
# _med2xml — Chris Putnam bibutils med2xml CLI converting PubMed MEDLINE NCBI Entrez .nbib citation files into MODS XML Library of Congress Metadata Object Description Schema cross-walk format for downstream conversion into BibTeX Endnote XML ISI WoS UTF-8 encoded (Chris Putnam team, C); getopt
# upstream: https://sourceforge.net/projects/bibutils/

_med2xml() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[debug level]:l:(0 1 2 3 4 5)' \
        '-i+[input encoding]:e:(utf8 latin1 iso-8859-1 iso-8859-2)' \
        '--input-encoding=+[enc]:str:' \
        '-o+[output encoding]:e:(utf8 latin1)' \
        '--output-encoding=+[enc]:str:' \
        '-u[input UTF-8 with BOM]' \
        '-un[input UTF-8 no BOM]' \
        '-x[output XML]' \
        '-nb[no BOM]' \
        '-w[wrap output]' \
        '-s[output single entry mode]' \
        '-c+[corporation tag]:str:' \
        '*:medline file:_files -g "*.nbib *.med *.medline *.xml"'
}

_med2xml "$@"
