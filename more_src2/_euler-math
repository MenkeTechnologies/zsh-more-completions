#compdef euler euler-math
# _euler-math — Rene Grothmann euler euler-math CLI Euler Math Toolbox numerical computer algebra system command-line frontend providing interactive shell symbolic-Maxima-backed numeric mathematics interval-arithmetic plots-matrices vectors linear-algebra ODE-PDE solver loops conditionals user-defined-functions scripting (Rene Grothmann team, C++); custom argparse
# upstream: http://www.euler-math-toolbox.de/

_euler-math() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-b[batch mode]' \
        '--batch[batch mode]' \
        '-e+[expression]:str:' \
        '--exec=+[expression]:str:' \
        '-l+[load file]:file:_files -g "*.e *.en *.euler"' \
        '--load=+[file]:file:_files -g "*.e *.en *.euler"' \
        '-d+[data dir]:dir:_files -/' \
        '--datadir=+[dir]:dir:_files -/' \
        '-g+[graph driver]:g:(qt gtk x11 dummy)' \
        '--graph=+[driver]:g:(qt gtk x11 dummy)' \
        '-m+[memory MB]:n:' \
        '--memory=+[MB]:n:' \
        '-n[no notebook]' \
        '--no-notebook[no notebook]' \
        '-s+[stack size]:n:' \
        '--stack=+[size]:n:' \
        '-t+[max threads]:n:' \
        '--threads=+[N]:n:' \
        '--log=+[file]:file:_files' \
        '--no-maxima[disable Maxima]' \
        '--maxima-path=+[path]:file:_files' \
        '*:euler file:_files -g "*.e *.en *.euler"'
}

_euler-math "$@"
