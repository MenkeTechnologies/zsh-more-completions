#compdef gobind
# Documentation: https://pkg.go.dev/golang.org/x/mobile/cmd/gobind

_arguments -s -S \
  '-lang=[target language (comma-separated)]:language:(go java objc)' \
  '-outdir=[output directory]:directory:_files -/' \
  '-javapkg=[custom Java package path prefix]:package:' \
  '-prefix=[custom Objective-C name prefix]:prefix:' \
  '-tags=[build tags (comma-separated)]:tags:' \
  '-v[verbose output]' \
  '*:package:_files -/'
