#compdef nix-hash
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-hash
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--flat[hash regular file contents (no NAR)]' \
  '--base16[print hash in hexadecimal (default)]' \
  '--base32[print hash in base-32]' \
  '--base64[print hash in base-64]' \
  '--sri[print hash in SRI format]' \
  '--type[hash algorithm]:type:(blake3 md5 sha1 sha256 sha512)' \
  '--truncate[truncate hashes longer than 160 bits to 160 bits]' \
  '--to-base16[convert to hexadecimal]:hash:' \
  '--to-base32[convert to base-32]:hash:' \
  '--to-base64[convert to base-64]:hash:' \
  '--to-sri[convert to SRI]:hash:' \
  '*:file or path:_files' && ret=0

return ret
