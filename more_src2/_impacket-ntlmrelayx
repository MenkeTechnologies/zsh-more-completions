#compdef impacket-ntlmrelayx
# Documentation: https://github.com/fortra/impacket/blob/master/examples/ntlmrelayx.py
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# impacket-ntlmrelayx: NTLM relay attack server with SMB/HTTP/MSSQL/LDAP/RPC/WinRM targets
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '-debug[enable DEBUG output]' \
  '-ts[add timestamp to logging]' \
  '(-t --target)'{-t,--target}'[single target]:target:' \
  '-tf[targets file]:file:_files' \
  '-w[watch for new targets]' \
  '(-i --interactive)'{-i,--interactive}'[interactive shell on success]' \
  '(-ip --interface-ip)'{-ip,--interface-ip}'[interface IP]:ip:' \
  '--no-smb-server[do not run SMB relay server]' \
  '--no-http-server[do not run HTTP relay server]' \
  '--no-wcf-server[do not run WCF relay server]' \
  '--no-raw-server[do not run raw relay server]' \
  '--no-rpc-server[do not run RPC relay server]' \
  '--no-winrm-server[do not run WinRM relay server]' \
  '--no-mssql-server[do not run MSSQL relay server]' \
  '--no-rdp-server[do not run RDP relay server]' \
  '--smb-port[SMB listen port]:port:' \
  '--http-port[HTTP listen port]:port:' \
  '--wcf-port[WCF listen port]:port:' \
  '--raw-port[raw listen port]:port:' \
  '--rpc-port[RPC listen port]:port:' \
  '--mssql-port[MSSQL listen port]:port:' \
  '--rdp-port[RDP listen port]:port:' \
  '--no-multirelay[do not multi-relay]' \
  '--keep-relaying[keep relaying after success]' \
  '(-ra --random)'{-ra,--random}'[pick random target]' \
  '-r[SMB redirect host]:host:' \
  '(-l --lootdir)'{-l,--lootdir}'[loot output directory]:dir:_files -/' \
  '(-of --output-file)'{-of,--output-file}'[output file]:file:_files' \
  '(-dh --dump-hashes)'{-dh,--dump-hashes}'[dump captured hashes to console]' \
  '-codec[codec for non-utf-8 strings]:codec:' \
  '-smb2support[enable SMB2 negotiation]' \
  '-ntlmchallenge[fixed NTLM challenge (hex)]:hex:' \
  '-socks[run a SOCKS proxy for relayed sessions]' \
  '-socks-address[SOCKS bind address]:ip:' \
  '-socks-port[SOCKS port]:port:' \
  '-http-api-port[SOCKS HTTP API port]:port:' \
  '(-wh --wpad-host)'{-wh,--wpad-host}'[WPAD spoof host]:host:' \
  '(-wa --wpad-auth-num)'{-wa,--wpad-auth-num}'[WPAD auth-required cycles]:n:' \
  '(-6 --ipv6)'{-6,--ipv6}'[listen on IPv6]' \
  '--remove-mic[remove NTLMSSP MIC]' \
  '--remove-sign-seal[remove signing/sealing flags]' \
  '--serve-image[image file to serve via WebDAV]:file:_files' \
  '-c[command to execute after relay]:cmd:' \
  '--mssql-db[default MSSQL database]:db:' \
  '-e[shell script to execute on success]:file:_files' \
  '--enum-local-admins[enumerate local admins]' \
  '--rpc-attack[RPC attack action]:action:' \
  '-rpc-mode[RPC mode]:mode:(SAMR TSCH)' \
  '-rpc-use-smb[transport RPC over SMB]' \
  '-auth-smb[SMB transport auth]:auth:' \
  '-hashes-smb[SMB transport hashes]:hash:' \
  '-rpc-smb-port[SMB transport port]:port:' \
  '-icpr-ca-name[ICPR CA name]:name:' \
  '(-q --query)'{-q,--query}'[MSSQL query to run]:query:' \
  '-machine-account[machine account for HTTP relay]:acct:' \
  '-machine-hashes[machine account hashes]:hash:' \
  '-domain[domain for HTTP relay]:domain:' \
  '-remove-target[remove HTTP target on success]' \
  '--no-dump[skip LDAP domain dump]' \
  '--no-da[skip Domain Admin elevation]' \
  '--no-acl[skip ACL operations]' \
  '--no-validate-privs[do not validate privileges]' \
  '--escalate-user[escalate this user]:user:' \
  '--delegate-access[delegate access via RBCD]' \
  '--sid[use objectSid]' \
  '--dump-laps[dump LAPS passwords]' \
  '--dump-gmsa[dump gMSA passwords]' \
  '--dump-adcs[dump ADCS templates/CAs]' \
  '--add-dns-record[add DNS record]:record:' \
  '--add-computer[add computer object]:name:' \
  '(-k --keyword)'{-k,--keyword}'[IMAP search keyword]:kw:' \
  '(-m --mailbox)'{-m,--mailbox}'[IMAP mailbox]:mbox:' \
  '(-a --all)'{-a,--all}'[fetch all mail]' \
  '(-im --imap-max)'{-im,--imap-max}'[max emails to fetch]:n:' \
  '--adcs[run AD CS attack]' \
  '--template[AD CS certificate template]:name:' \
  '--altname[AD CS alternative name]:name:' \
  '--shadow-credentials[shadow credentials attack]' \
  '--shadow-target[shadow credentials target]:target:' \
  '--pfx-password[PFX password]:pass:' \
  '--export-type[PFX export type]:type:(PEM PFX)' \
  '--cert-outfile-path[cert output path]:file:_files' \
  '--sccm-policies[SCCM policies attack]' \
  '--sccm-policies-clientname[SCCM client name]:name:' \
  '--sccm-policies-sleep[SCCM sleep]:sec:' \
  '--sccm-dp[SCCM distribution point attack]' \
  '--sccm-dp-extensions[SCCM DP file extensions]:exts:' \
  '--sccm-dp-files[SCCM DP files list]:file:_files' && ret=0
return ret
