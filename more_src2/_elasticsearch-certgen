#compdef elasticsearch-certgen
# Documentation: https://www.elastic.co/docs/reference/elasticsearch/command-line-tools/certgen
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elasticsearch-certgen: legacy cert generator (superseded by elasticsearch-certutil)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-E[config setting key=value]:kv:' \
  '--cert[existing CA cert]:file:_files' \
  '--key[existing CA key]:file:_files' \
  '--in[input YAML]:file:_files' \
  '--out[output zip]:file:_files' \
  '--days[validity days]:n:' \
  '--keysize[key size bits]:bits:(1024 2048 4096)' \
  '--p12[output as PKCS#12]:pass:' \
  '*::elasticsearch-certgen args:_files' && ret=0
return ret
