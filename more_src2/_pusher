#compdef pusher
# Documentation: https://github.com/pusher/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'login:authenticate the Pusher CLI'
  'logout:log out of the Pusher CLI'
  'channels:Channels product commands'
  'version:show CLI version'
  'help:show help for a command'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pusher command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (channels)
        if (( CURRENT == 2 )); then
          local -a chan_subs=(
            'apps:Channels app commands'
            'generate:generate client, server, or auth server'
          )
          _describe -t chcmds 'channels subcommand' chan_subs && ret=0
        else
          case $line[2] in
            (apps)
              _values 'apps subcommand' \
                'list' 'tokens' 'subscribe' 'trigger' 'channels' 'channel_info' 'functions' && ret=0
              ;;
            (generate)
              _values 'generate subcommand' 'client' 'server' 'auth_server' && ret=0
              ;;
          esac
        fi
        ;;
    esac ;;
esac

return ret
