#compdef postcat
# Documentation: https://www.postfix.org/postcat.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '-b[show body content]' \
  '-c+[config directory]:dir:_files -/' \
  '-d[print decimal type of each record]' \
  '-e[show message envelope content]' \
  '-h[show message header content]' \
  '-o[print queue file offset of each record]' \
  '-q[search Postfix queue for named files]' \
  '*-v[verbose logging (repeatable)]' \
  '*:file:_files'
