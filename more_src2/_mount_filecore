#compdef mount_filecore
# Documentation: man mount_filecore(8)
# Source: netbsd/src sbin/mount_filecore — mount an Acorn FILECORE file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[grant world access to all files]' \
    '-f[append filetype to filenames]' \
    '-g+[group ownership of files]:gid:_default' \
    '-n[grant owner access to all files]' \
    '-o+[mount options (comma-separated, see mount(8))]:options:_default' \
    '-R[grant owner read access to all files]' \
    '-u+[owner of files]:uid:_default' \
    '1:special device:_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
