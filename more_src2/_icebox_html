#compdef icebox_html
# Documentation: https://github.com/YosysHQ/icestorm
# Source: YosysHQ/icestorm icebox/icebox_html.py — generate HTML rendering of an iCE40 tile.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-x[tile X coordinate]:x:' \
    '-y[tile Y coordinate]:y:' \
    '-d[output directory for generated files]:outdir:_directories' \
    '(-3 -8)-8[iCE40 HX8K chip mode]' \
    '(-3 -8)-3[iCE40 LP384 chip mode]' \
    && ret=0

return ret
