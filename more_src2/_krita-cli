#compdef krita-cli
# Documentation: https://invent.kde.org/graphics/krita/-/blob/master/libs/ui/KisApplicationArguments.cpp
# Reference accessed: 2026-05-19
# Verified: upstream KisApplicationArguments.cpp. This file previously
# carried `#compdef krita`, colliding with the canonical _krita, and
# listed fabricated flags (--no-mlt, --no-pyqt, --debug-eventfilters,
# --debug-events, --debug-resourceloading) absent from upstream. The
# #compdef collision is resolved here; flags mirror the canonical set.

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--nosplash[do not show the splash screen]' \
  '--canvasonly[start Krita in canvas-only mode]' \
  '--fullscreen[start Krita in full-screen mode]' \
  '--workspace=[name of the workspace to open Krita with]:workspace' \
  '--windowlayout=[name of the window layout to open Krita with]:layout' \
  '--load-session=[name of the session to open Krita with]:session' \
  '--new-image=[create a new image]:colormodel,bitdepth,width,height' \
  '--template=[open a new document with a template]:file:_files -g "*.kra"' \
  '--dpi=[override display DPI]:dpiX,dpiY' \
  '--export[export to the given filename and exit]' \
  '--export-sequence[export animation to the given filename and exit]' \
  '--export-filename=[filename for export]:file:_files' \
  '--file-layer=[file layer to add to existing or new file]:file:_files' \
  '--resource-location=[override the configured location for Kritas resources]:dir:_files -/' \
  '*:file:_files -g "*.{kra,ora,psd,png,jpg,jpeg,tiff,tif,gif,bmp,xcf,svg,webp,exr}"' && ret=0

return ret
