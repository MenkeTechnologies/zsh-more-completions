#compdef plforge
# Documentation: https://github.com/Snowflake-Labs/polaris-local-forge
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for plforge - Polaris Local Forge task wrapper.
# plforge is a thin wrapper around go-task; subcommands are namespaced
# task names (cluster:create, polaris:deploy, catalog:setup, l2c:sync, ...).

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'cluster\:create:create the k3d cluster'
  'cluster\:delete:delete the cluster'
  'cluster\:reset:delete and recreate the cluster'
  'cluster\:bootstrap-check:wait for bootstrap deployments'
  'cluster\:polaris-check:wait for Apache Polaris deployment'
  'polaris\:deploy:deploy Apache Polaris to the cluster'
  'polaris\:bootstrap:run the Apache Polaris bootstrap job'
  'polaris\:check:verify Apache Polaris deployment'
  'polaris\:reset:purge and re-bootstrap Apache Polaris'
  'polaris\:purge:purge Apache Polaris data'
  'catalog\:setup:set up the demo catalog'
  'catalog\:cleanup:remove catalog resources'
  'catalog\:reset:cleanup and recreate the catalog'
  'catalog\:list:list available catalogs'
  'catalog\:info:display catalog configuration'
  'catalog\:verify\:sql:verify with PyIceberg + DuckDB'
  'catalog\:verify\:duckdb:verify using Python DuckDB'
  'catalog\:query:execute a read-only SQL query'
  'catalog\:explore\:sql:interactive DuckDB exploration'
  'catalog\:generate-notebook:create a verification notebook'
  'l2c\:inventory:list tables in local Polaris'
  'l2c\:setup:provision AWS + Snowflake infrastructure'
  'l2c\:setup\:aws:create S3 bucket plus IAM role and policy'
  'l2c\:setup\:snowflake:create Snowflake external volume + integration'
  'l2c\:sync:copy Iceberg data from RustFS to AWS S3'
  'l2c\:register:register synced tables as Snowflake external Iceberg tables'
  'l2c\:refresh:update registered tables (zero-downtime)'
  'l2c\:update:combined sync, refresh and register'
  'l2c\:migrate:full pipeline (setup + sync + register)'
  'l2c\:status:display migration state'
  'l2c\:clear:remove migrated data, keep infrastructure'
  'l2c\:cleanup:full teardown of L2C infrastructure'
  'doctor:assess system prerequisites'
  'init:initialize project directory'
  'prepare:generate configuration files'
  'teardown:execute teardown'
)

_arguments -s -S \
  '(- *)--help[show help and list tasks]' \
  '(- *)-h[show help and list tasks]' \
  '--completion=[generate shell completion script]:shell:(bash zsh)' \
  '--list-tasks[list task names]' \
  '--summary[show detailed help for a task]' \
  '--dry-run[preview without executing]' \
  '--yes[skip confirmation prompts]' \
  '--force[override safety checks]' \
  '1:task:->task' \
  '*::args:->args' && ret=0

case $state in
  (task)
    _describe -t commands 'plforge task' commands && ret=0
    ;;
  (args)
    _default && ret=0
    ;;
esac

return ret
