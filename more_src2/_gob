#      Cli.build {
#        verbose: <- Opt.flag {
#          short: "v",
#          long: "verbose",
#          help: "Enable verbose output"
#        },
#        output: <- Opt.maybeStr {
#          short: "o",
#          long: "output",
#          help: "Output file path"
#        },
#        count: <- Opt.u32 {
#          short: "n",
#          long: "count",
#          help: "Number of iterations",
#          default: Value 1
#        },
#        path: <- Param.str {
#          name: "path",
#          help: "Input file path"
#        },
#      }
#      |> Cli.finish {
#        name: "mytool",
