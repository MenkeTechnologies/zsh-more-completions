#compdef kmap2qmap
# Documentation: https://doc.qt.io/qt-6/qttools-index.html
# Source: qt/qttools src/kmap2qmap/main.cpp — convert Linux console kmap files to Qt qmap binary (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '--header[generate header form of compiled-in qmap]' \
    '*:kmap files (last is output qmap):_files -g "*.{kmap,kmap.gz,qmap}"' \
    && ret=0

return ret
