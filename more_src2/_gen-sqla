#compdef gen-sqla
# _gen-sqla — generate SQLAlchemy ORM classes from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/sqlalchemygen.py (click).

_gen-sqla() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output Python file (default stdout)]:file:_files -g "*.py"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(python sqla)'
        '--declarative[emit a declarative-base SQLAlchemy module (default)]'
        '--no-declarative[emit an imperative SQLAlchemy module instead]'
        '--generate-classes[emit Python classes for the SQLAlchemy mappings]'
        '--no-generate-classes[only emit the SQLAlchemy mappings]'
        '--pydantic[also emit matching Pydantic models]'
        '--no-pydantic[do not emit Pydantic models]'
        '--use-foreign-keys[emit foreign-key relationships]'
        '--no-use-foreign-keys[omit foreign-key relationships]'
        '--sqla-style=[SQLAlchemy code style (declarative mode only)]:style:(1.x 2.0)'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-sqla "$@"
