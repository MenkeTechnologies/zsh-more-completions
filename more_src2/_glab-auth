#compdef glab-auth
# _glab-auth — GitLab glab auth subcommand alias (GitLab Inc., Go); spf13/cobra
# upstream: https://gitlab.com/gitlab-org/cli

_glab-auth() {
    local -a sub=(
        'login:authenticate'
        'logout:logout'
        'status:show authentication status'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'glab-auth subcommand' sub ;;
        args)
            case $words[1] in
                login) _arguments \
                    '--hostname=+[GitLab hostname]:host:_hosts' \
                    '-h+[GitLab hostname]:host:_hosts' \
                    '--token=+[token]:str:' \
                    '-t+[token]:str:' \
                    '--stdin[token from stdin]' \
                    '--git-protocol=+[git protocol]:p:(ssh https)' \
                    '-p+[git protocol]:p:(ssh https)' \
                    '--web[browser based auth]' \
                    '-w[browser based auth]' \
                    '--api-host=+[api host]:host:_hosts' ;;
                logout) _arguments \
                    '--hostname=+[GitLab hostname]:host:_hosts' \
                    '-h+[GitLab hostname]:host:_hosts' ;;
                status) _arguments \
                    '--hostname=+[GitLab hostname]:host:_hosts' \
                    '-h+[GitLab hostname]:host:_hosts' \
                    '--show-token[show token]' \
                    '-t[show token]' ;;
            esac
            ;;
    esac
}

_glab-auth "$@"
