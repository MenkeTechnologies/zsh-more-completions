#compdef manpage-alert
# Documentation: https://manpages.debian.org/manpage-alert
# Source: debian/devscripts scripts/manpage-alert.sh — list binaries without a man page (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-f --file)'{-f,--file}'[show filenames of missing manpages]' \
    '(-p --package)'{-p,--package}'[show packages of missing manpages]' \
    '(-n --no-stat)'{-n,--no-stat}'[do not show statistics]' \
    '*:path:_files -/' \
    && ret=0

return ret
