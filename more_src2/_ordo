#compdef ordo
# _ordo — Bayesian rating tool for chess engine matches (michiguel/Ordo)
# upstream: https://github.com/michiguel/Ordo
# Flags from main.c (getopt).

_ordo() {
    _arguments \
        '(- *)-h[show help]' \
        '(- *)-H[show extended help / switches]' \
        '(- *)-v[show version]' \
        '-L[show license]' \
        '-p+[PGN input file]:file:_files -g "*.pgn"' \
        '-P+[PGN input list file]:file:_files' \
        '-c+[CSV output file]:file:_files' \
        '-o+[text output file]:file:_files' \
        '-g[group output]' \
        '-G[disable group check]' \
        '-j+[head-to-head output file]:file:_files' \
        '-e+[event match string]:str:' \
        '-C+[CTS match string]:str:' \
        '-m+[pins file]:file:_files' \
        '-r+[relations file]:file:_files' \
        '-y+[priors file]:file:_files' \
        '-a+[general average rating]:rating:' \
        '-F+[confidence percentage]:pct:' \
        '-A+[anchor player]:player:' \
        '-V[anchor error relative to average]' \
        '-M[force max-likelihood mode]' \
        '-s+[simulations]:n:' \
        '-w+[white advantage]:rating:' \
        '-u+[white advantage SD]:rating:' \
        '-d+[even-match draw rate percent]:pct:' \
        '-k+[even-match draw rate SD]:pct:' \
        '-z+[rating 76% expected]:rating:' \
        '-J[include CFS column]' \
        '-T[table mode]' \
        '-q[quiet mode]' \
        '-Q[quiet with simulation updates]' \
        '-R[hide old version]' \
        '-W[adjust white advantage]' \
        '-D[adjust draw rate]' \
        '-E[ELOSTAT-style output]' \
        '-X[ignore draws]' \
        '-N+[output decimal places]:n:' \
        '-t+[minimum games]:n:' \
        '-n+[CPU threads]:n:' \
        '-U+[output columns spec]:cols:' \
        '-Y+[synonyms file]:file:_files' \
        '-i+[includes file]:file:_files' \
        '-x+[excludes file]:file:_files' \
        '-b+[columns format string]:fmt:'
}

_ordo "$@"
