#compdef iblinter
# Documentation: https://github.com/IBDecodable/IBLinter
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# iblinter: linter for Interface Builder (.xib/.storyboard) files.
local -a _ibl_cmds
_ibl_cmds=(
  'lint:print lint warnings and errors (default)'
  'help:show help for a subcommand'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->c' \
  '*::arg:->a'

case $state in
  c) _describe -t commands 'iblinter command' _ibl_cmds ;;
  a)
    case $line[1] in
      lint)
        _arguments \
          '--path=[project root directory to validate]:path:_files -/' \
          '--reporter=[reporter used to log errors and warnings]:reporter:' \
          '--configuration-file=[path to IBLinter config file]:file:_files' \
          '*:included files/paths:_files'
        ;;
      help)
        _describe -t commands 'iblinter command' _ibl_cmds
        ;;
      *) _default ;;
    esac
    ;;
esac
