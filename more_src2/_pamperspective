#compdef pamperspective
# Documentation: man pamperspective (Netpbm)
# Source: perspective-correct a Netpbm image given a quadrilateral.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--bottom_margin=[bottom margin]:num:' \
    '--detail=[detail level]:num:' \
    '--frame_include=[frame_include]:bool:(yes no)' \
    '--height=[output height]:num:' \
    '--include=[include polygon (x1,y1;x2,y2;...)]:polygon:' \
    '--input_system=[input coord system]:spec:' \
    '--input_unit=[input unit]:spec:' \
    '--interpolation=[interpolation type]:spec:(nearest linear cubic bicubic)' \
    '--left_margin=[left margin]:num:' \
    '--margin=[margin]:num:' \
    '--output_system=[output coord system]:spec:' \
    '--proportion=[aspect-ratio mode]:spec:' \
    '--ratio=[aspect ratio]:num:' \
    '--right_margin=[right margin]:num:' \
    '--top_margin=[top margin]:num:' \
    '--width=[output width]:num:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
