#compdef genpolicy
# _genpolicy — Kata Containers (CoCo) Rego policy generator (turns a k8s YAML into an OPA policy attached as a base64 annotation)
# upstream: https://github.com/kata-containers/kata-containers
# Flags from src/tools/genpolicy/src/utils.rs on tip (clap).

_genpolicy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version and exit]' \
        '(-y --yaml-file)'{-y,--yaml-file}'=[Kubernetes input/output YAML file (defaults to stdin/stdout)]:file:_files -g "*.(yaml|yml)"' \
        '(-c --config-map-file)'{-c,--config-map-file}'=[DEPRECATED: configmap YAML (use --config-file)]:file:_files' \
        '*--config-file=[YAML file containing ConfigMaps/Secrets]:file:_files' \
        '(-p --rego-rules-path)'{-p,--rego-rules-path}'=[path to rego rules file]:file:_files' \
        '(-j --json-settings-path)'{-j,--json-settings-path}'=[path to genpolicy settings file or directory]:path:_files' \
        '(-u --use-cached-files)'{-u,--use-cached-files}'[cache container image layer + dm-verity info under ./layers_cache/]' \
        '(-r --raw-out)'{-r,--raw-out}'[print Rego policy text to stdout]' \
        '(-b --base64-out)'{-b,--base64-out}'[print base64-encoded Rego policy to stdout]' \
        '(-s --silent-unsupported-fields)'{-s,--silent-unsupported-fields}'[ignore unsupported Kubernetes YAML fields]' \
        '(-d --containerd-socket-path)'{-d,--containerd-socket-path}'=[use a running containerd to pull images]:socket:_files' \
        '*--insecure-registry=[allow plain-HTTP registry]:host:' \
        '*--runtime-class-names=[only emit policy for matching runtimeClassNames]:prefix:' \
        '--layers-cache-file-path=[layers cache file]:file:_files'
}

_genpolicy "$@"
