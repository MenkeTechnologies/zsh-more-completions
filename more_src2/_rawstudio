#compdef rawstudio
# _rawstudio — open-source raw image converter (rawstudio/rawstudio)
# upstream: https://github.com/rawstudio/rawstudio
# Flags from src/application.c (GOptionEntry option_entries).

_rawstudio() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-o --output)'{-o+,--output=}'[client mode: target filename]:file:_files' \
        '(-d --debug)'{-d+,--debug=}'[debug flags]:flags:' \
        '*:RAW image file:_files -g "*.(arw|cr2|crw|dng|nef|nrw|orf|pef|raf|raw|rw2|sr2|srw)"'
}

_rawstudio "$@"
