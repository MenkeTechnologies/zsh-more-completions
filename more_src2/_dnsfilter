#compdef dnsfilter
# _dnsfilter — djbdns dnsfilter (rewrite each input line by replacing IPv4 addresses with their PTR hostname; performs DNS lookups in parallel for log-postprocessing)
# upstream: https://github.com/dterweij/ndjbdns
# Flags from dnsfilter.c on tip.

_dnsfilter() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version and exit]' \
        '-c+[parallel queries (1-1000)]:n:' \
        '-l+[read-ahead lines (1-1000000)]:n:'
}

_dnsfilter "$@"
