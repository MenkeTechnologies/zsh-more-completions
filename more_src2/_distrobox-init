#compdef distrobox-init
# Documentation: https://github.com/89luca89/distrobox/blob/main/docs/usage/distrobox-init.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# distrobox-init runs inside the container; flags from docs/usage/distrobox-init.md.
# Note: --init-hooks is not documented; only --pre-init-hooks is.

_arguments -s \
  '(-n --name)'{-n,--name=}'[user name]:name:' \
  '(-u --user)'{-u,--user=}'[UID]:uid:' \
  '(-g --group)'{-g,--group=}'[GID]:gid:' \
  '(-d --home)'{-d,--home=}'[home directory]:dir:_files -/' \
  '--additional-packages=[extra packages]:pkgs:' \
  '(-I --init)'{-I,--init}'[use init]' \
  '--pre-init-hooks=[pre-init commands]:cmds:' \
  '--nvidia[integrate nVidia drivers]' \
  '(-U --upgrade)'{-U,--upgrade}'[upgrade mode]' \
  '*'{-v,--verbose}'[verbose]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:command:'
