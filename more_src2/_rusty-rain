#compdef rusty-rain
# rusty-rain - Cross-platform CMatrix-style "matrix rain" in Rust.
#
# Upstream: https://github.com/cowboy8625/rusty-rain  (458+ stars, Apache-2.0)
# Author:   cowboy8625 (Cody Bryan; cowboy8625@protonmail.com)
# Library:  ezemoji + crossterm 0.29 (canonical Rust cross-platform terminal IO)
#
# Source-direct extraction from src/cli.rs `Cli` struct (clap-derive 4.x)
# and the embedded HELP_* constants:
#   https://github.com/cowboy8625/rusty-rain/blob/master/src/cli.rs
#
# Char-group catalogue is hand-mirrored from the in-source HELP_CHARS table
# plus the three special hard-coded variants ("classic", "opensource",
# "pglangs") spliced into Grouping::from_str().  ezemoji 2.x supplies the rest.

local curcontext=$curcontext state line ret=1
typeset -A opt_args

_rusty_rain_groups() {
    local -a groups
    groups=(
        'all:show most of the Character Groups all at once'
        'alphalow:lower-case alphabet characters'
        'alphaup:upper-case alphabet characters'
        'arrow:arrow emojis or fancy characters'
        'bin:all ones and zeros (default group)'
        'cards:playing cards'
        'classic:closer to what the default look is for cmatrix (jap + num + punctuation)'
        'clock:clock face emoji'
        'crab:crab emoji'
        'dominosh:horizontal dominos'
        'dominosv:vertical dominos'
        'earth:earth emoji'
        'emojis:a bunch of random emojis'
        'jap:Japanese characters (default cmatrix katakana)'
        'large-letters:cool looking large letters'
        'moon:moon emoji'
        'num:numbers'
        'numbered-balls:pool-ball numbers'
        'numbered-cubes:numbered cubes'
        'opensource:open-source icon emojis (Nerd Font devicons)'
        'pglangs:programming-language icon emojis (Nerd Fonts)'
        'plants:plants of sorts'
        'shapes:squares and circles of a few colors'
        'smile:smiley face emoji'
    )
    _describe -t groups 'character group' groups
}

_rusty_rain_directions() {
    local -a dirs
    dirs=(
        'south:fall downward (default cmatrix behavior)'
        'down:alias for south'
        'north:rise upward'
        'up:alias for north'
        'east:flow rightward'
        'right:alias for east'
        'west:flow leftward'
        'left:alias for west'
    )
    _describe -t directions 'rain direction' dirs
}

_rusty_rain_colors() {
    local -a colors
    colors=(
        'white:RGB (255,255,255) - default head color'
        'red:RGB (255,0,0)'
        'blue:RGB (0,0,255)'
        'green:RGB (0,255,0) - default rain color'
    )
    _describe -t colors 'named color (or r,g,b tuple or #RRGGBB)' colors
}

_arguments -C \
    '(- *)'{-h,--help}'[print help (summary)]' \
    '(- *)'{-V,--version}'[print rusty-rain version]' \
    '(-s --shade)'{-s,--shade}'[enable color shading down each rain trail]' \
    '(-g --group)'{-g,--group}'+[set what kind of characters are printed as rain]:group:_rusty_rain_groups' \
    '(-C --color)'{-C,--color}'+[set color of rain (name, r,g,b, or #RRGGBB; default green)]:color:_rusty_rain_colors' \
    '(-B --bg-color)'{-B,--bg-color}'+[set background color of rain]:bg color:_rusty_rain_colors' \
    '(-G --shade-gradient)'{-G,--shade-gradient}'+[set shade-gradient color (default #000000)]:gradient color:_rusty_rain_colors' \
    '(-H --head)'{-H,--head}'+[set color of the first/head character (default white)]:head color:_rusty_rain_colors' \
    '(-d --direction)'{-d,--direction}'+[set the direction the rain falls (default south)]:direction:_rusty_rain_directions' \
    '(-S --speed)'{-S,--speed}'+[set rain speed as MAX,MIN tuple (millisecond delays)]:max,min:' \
    '(-D --display-group)'{-D,--display-group}'[overlay the currently-selected character group name]' \
    && ret=0

return ret
