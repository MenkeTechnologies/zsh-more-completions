#compdef gdb-multiarch arm-none-eabi-gdb
# Documentation: https://manpages.ubuntu.com/manpages/trusty/man1/gdb-multiarch.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--help[show help]' \
  '--version[show version]' \
  '(-q --quiet --silent)'{-q,--quiet,--silent}'[do not print version on startup]' \
  '(-b --baud)'{-b,--baud}'=[baud rate]:rate:(9600 19200 38400 57600 115200)' \
  '(-batch --batch)'{-batch,--batch}'[exit after processing commands]' \
  '--batch-silent[batch mode with no output]' \
  '--return-child-result[return child process exit code]' \
  '(-c --core)'{-c,--core}'=[core file]:core:_files' \
  '(-d --directory)'{-d,--directory}'=[source directory]:dir:_files -/' \
  '(-e --exec)'{-e,--exec}'=[executable]:executable:_files' \
  '(-p --pid)'{-p,--pid}'=[attach to process]:pid:_pids' \
  '(-s --symbols)'{-s,--symbols}'=[symbol file]:file:_files' \
  '(-x --command)'{-x,--command}'=[execute commands from file]:file:_files' \
  '(-ex --eval-command)'{-ex,--eval-command}'=[execute single command]:command:' \
  '--init-command=[execute commands before loading]:file:_files' \
  '--init-eval-command=[execute single command before loading]:command:' \
  '(-n --nx)'{-n,--nx}'[do not read .gdbinit files]' \
  '--nh[do not read ~/.gdbinit]' \
  '(-w --windows)'{-w,--windows}'[use GUI interface]' \
  '(-nw --nowindows)'{-nw,--nowindows}'[use command-line interface]' \
  '--tui[use TUI interface]' \
  '--interpreter=[set interpreter]:interpreter:(mi mi2 mi3 console)' \
  '--tty=[set terminal for debugged program]:tty:_files -g "/dev/pts/*"' \
  '--args[pass arguments to program]' \
  '--readnow[read symbol table immediately]' \
  '--readnever[do not read symbol table]' \
  '--write[allow writing to exec and core files]' \
  '--se=[symbol and exec file]:file:_files' \
  '--cd=[run GDB in directory]:dir:_files -/' \
  '--data-directory=[set GDB data directory]:dir:_files -/' \
  '--configuration[print GDB configuration details]' \
  '*:file:_files' && ret=0

return ret
