#compdef gpg-agent
# Documentation: gpg-agent --help on gpg-agent (GnuPG) 2.5.20
# Source: GnuPG gpg-agent — secret key management for GnuPG.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(--daemon --server)--daemon[run in daemon mode (background)]' \
    '(--daemon --server)--server[run in server mode (foreground)]' \
    '--no-detach[do not detach from the console]' \
    '(-s --sh -c --csh)'{-s,--sh}'[sh-style command output]' \
    '(-s --sh -c --csh)'{-c,--csh}'[csh-style command output]' \
    '--options=[read options from FILE]:file:_files' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '(-q --quiet)'{-q,--quiet}'[somewhat more quiet]' \
    '--log-file=[write server-mode logs to FILE]:file:_files' \
    '--disable-scdaemon[do not use SCdaemon]' \
    '--scdaemon-program=[SCdaemon program path]:pgm:_files' \
    '--tpm2daemon-program=[tpm2daemon program path]:pgm:_files' \
    '--extra-socket=[accept some commands via NAME]:name:_files' \
    '--keep-tty[ignore requests to change the TTY]' \
    '--keep-display[ignore requests to change the X display]' \
    '--enable-ssh-support[enable ssh support]' \
    '--ssh-fingerprint-digest=[algo for SSH fingerprints]:algo:(MD5 SHA1 SHA256 SHA384 SHA512)' \
    '--default-cache-ttl=[expire cached PINs after N seconds]:N:' \
    '--default-cache-ttl-ssh=[expire SSH keys after N seconds]:N:' \
    '--max-cache-ttl=[max PIN cache lifetime (s)]:N:' \
    '--max-cache-ttl-ssh=[max SSH key lifetime (s)]:N:' \
    '--ignore-cache-for-signing[bypass PIN cache when signing]' \
    '--no-allow-external-cache[disallow external password cache]' \
    '--no-allow-mark-trusted[disallow clients marking keys trusted]' \
    '--allow-preset-passphrase[allow presetting passphrase]' \
    '--enforce-passphrase-constraints[no bypassing passphrase policy]' \
    '--min-passphrase-len=[minimum passphrase length]:N:' \
    '--min-passphrase-nonalpha=[minimum non-alpha characters]:N:' \
    '--check-passphrase-pattern=[passphrase pattern file]:file:_files' \
    '--max-passphrase-days=[passphrase expiry days]:N:' \
    '--enable-passphrase-history[disallow reuse of old passphrases]' \
    '--batch[never use the PIN-entry]' \
    '--no-allow-loopback-pinentry[disallow override of pinentry]' \
    '--grab[let PIN-Entry grab keyboard and mouse]' \
    '--pinentry-program=[PIN-Entry program]:pgm:_files' \
    '--pinentry-timeout=[PIN-Entry timeout (s)]:N:' \
    '--allow-emacs-pinentry[allow Emacs passphrase prompt]' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*::command + args:_command_names -e' \
    && ret=0

return ret
