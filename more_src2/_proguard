#compdef proguard
# _proguard — Guardsquare ProGuard Java/Kotlin shrinker/optimizer (Guardsquare, Java); custom argparse
# upstream: https://github.com/Guardsquare/proguard

_proguard() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '@+[options file]:file:_files -g "*.pro"' \
        '-include+[options file]:file:_files -g "*.pro"' \
        '-basedirectory+[base dir]:dir:_files -/' \
        '-injars+[input jars]:list:_files' \
        '-outjars+[output jars]:list:_files' \
        '-libraryjars+[library jars]:list:_files' \
        '-skipnonpubliclibraryclasses[skip non-public lib classes]' \
        '-dontskipnonpubliclibraryclasses[do not skip non-public lib classes]' \
        '-dontskipnonpubliclibraryclassmembers[do not skip non-public lib members]' \
        '-keepdirectories+[keep directories]:list:' \
        '-target+[target version]:n:(1.0 1.1 1.2 1.3 1.4 1.5 1.6 1.7 1.8 1.9 11 17 21)' \
        '-forceprocessing[force processing]' \
        '-keep+[keep class spec]:spec:' \
        '-keepclassmembers+[keep members]:spec:' \
        '-keepclasseswithmembers+[keep classes with members]:spec:' \
        '-keepnames+[keep names]:spec:' \
        '-keepclassmembernames+[keep member names]:spec:' \
        '-keepclasseswithmembernames+[keep class member names]:spec:' \
        '-printseeds+[print seeds]:file:_files' \
        '-dontshrink[no shrinking]' \
        '-printusage+[print usage]:file:_files' \
        '-whyareyoukeeping+[why are you keeping]:spec:' \
        '-dontoptimize[no optimization]' \
        '-optimizations+[optimizations]:str:' \
        '-optimizationpasses+[optimization passes]:n:' \
        '-assumenosideeffects+[assume no side effects]:spec:' \
        '-assumenoexternalsideeffects+[assume no external side effects]:spec:' \
        '-assumenoescapingparameters+[assume no escaping params]:spec:' \
        '-assumenoexternalreturnvalues+[assume no external return values]:spec:' \
        '-allowaccessmodification[allow access modification]' \
        '-mergeinterfacesaggressively[merge interfaces aggressively]' \
        '-dontobfuscate[no obfuscation]' \
        '-printmapping+[print mapping]:file:_files' \
        '-applymapping+[apply mapping]:file:_files' \
        '-obfuscationdictionary+[obfuscation dictionary]:file:_files' \
        '-classobfuscationdictionary+[class obfuscation dictionary]:file:_files' \
        '-packageobfuscationdictionary+[package obfuscation dictionary]:file:_files' \
        '-overloadaggressively[overload aggressively]' \
        '-useuniqueclassmembernames[use unique class member names]' \
        '-dontusemixedcaseclassnames[no mixed case class names]' \
        '-keeppackagenames+[keep package names]:spec:' \
        '-flattenpackagehierarchy+[flatten package hierarchy]:str:' \
        '-repackageclasses+[repackage classes]:str:' \
        '-keepattributes+[keep attributes]:list:' \
        '-keepparameternames[keep parameter names]' \
        '-renamesourcefileattribute+[rename source file]:str:' \
        '-adaptclassstrings+[adapt class strings]:spec:' \
        '-adaptresourcefilenames+[adapt resource filenames]:list:' \
        '-adaptresourcefilecontents+[adapt resource file contents]:list:' \
        '-dontpreverify[no preverification]' \
        '-microedition[micro edition]' \
        '-android[android target]' \
        '-verbose[verbose]' \
        '-dontnote+[do not note]:spec:' \
        '-dontwarn+[do not warn]:spec:' \
        '-ignorewarnings[ignore warnings]' \
        '-printconfiguration+[print configuration]:file:_files' \
        '-dump+[dump processed jars]:file:_files' \
        '*:arg:'
}

_proguard "$@"
