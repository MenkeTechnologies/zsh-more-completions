#compdef makempx
# Documentation: https://tug.org/metapost.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above (MetaPost user manual).
# STUB — makempx is a preprocessor whose role has largely been absorbed
# into mpost itself; no canonical flag list is published. Treat extra
# arguments as MP source filenames.

local curcontext="$curcontext" ret=1
_arguments -C \
  '*:MP source file:_files -g "*.(mp|MPX|mpx)"' && ret=0
return ret
