#compdef expand-cli unexpand-cli
# _expand-cli — GNU coreutils expand convert tabs to spaces CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_expand-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-i[do not convert tabs after non-blanks]' \
        '--initial[do not convert tabs after non-blanks]' \
        '-t+[tab spec]:str:' \
        '--tabs=+[tab spec]:str:' \
        '-a[convert all blanks]' \
        '--all[convert all blanks]' \
        '*:files:_files'
}

_expand-cli "$@"
