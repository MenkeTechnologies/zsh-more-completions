#compdef psst-cli
# ============================================================================
# psst-cli - command-line Spotify track player +
#             reverse-engineered Spotify connection
#             stack (Rust, MIT)
#
# Author : Jan Pochyla (jpochyla)
# Upstream: https://github.com/jpochyla/psst
# crates : psst-cli (binary: psst-cli)
#
# `psst-cli` is the CLI test harness for the
# Psst project - Jan Pochyla's reverse-engineered
# native-Rust Spotify client. The main Psst
# binary is `psst-gui` (a native Druid-based
# desktop UI with 9,000+ GitHub stars). The
# psst-cli binary exists primarily as a testing
# + debugging tool for the psst-core library
# that handles:
#   - Spotify connection protocol (Spotify's
#     proprietary binary protocol, reverse-
#     engineered from official client traffic)
#   - Spotify CDN audio file fetching (chunked
#     Ogg Vorbis / AAC audio streams from
#     Spotify's content delivery network)
#   - Audio playback pipeline (cpal or cubeb
#     output backend + symphonia for decoding)
#   - Album/playlist/track ID resolution via
#     base62-encoded Spotify URIs
#   - LoudnessNormalization-aware playback
#
# Psst's architecture intentionally bypasses the
# libspotify SDK (deprecated by Spotify in 2015)
# in favor of a pure-Rust implementation derived
# from librespot (the canonical open-source
# Spotify protocol reimplementation):
#   - psst-core: the protocol + audio pipeline
#     library
#   - psst-cli: a minimal CLI player exercising
#     psst-core (THIS BINARY)
#   - psst-gui: the polished Druid-based GUI
#     desktop application
#
# Use cases:
#   - Native Linux/macOS/Windows Spotify client
#     with low memory footprint vs Electron-based
#     official Spotify client (~600MB RAM vs
#     ~100MB for psst-gui)
#   - Audiophile-grade playback with cubeb output
#     backend for low-latency cross-platform
#     audio
#   - Self-contained Spotify integration without
#     installing the official Spotify daemon
#   - Headless Spotify playback on home-server /
#     ARM SBC deployments
#
# Usage:
#   psst-cli <track_id>
#
# Positional argument:
#   <track_id>                     - Spotify
#                                     base62-
#                                     encoded
#                                     track ID
#                                     (e.g.
#                                     `4cOdK2wGLETKBW3PvgPWqT`
#                                     for Daft
#                                     Punk's
#                                     "One More
#                                     Time")
#
# Environment variables (REQUIRED - psst-cli
# reads credentials from environment, not
# command-line flags):
#   SPOTIFY_USERNAME               - Spotify
#                                     account
#                                     username
#                                     (Spotify
#                                     username
#                                     or email
#                                     address;
#                                     OAuth /
#                                     web login
#                                     not yet
#                                     supported
#                                     in psst-cli)
#   SPOTIFY_PASSWORD               - Spotify
#                                     account
#                                     password
#                                     (note: the
#                                     password-
#                                     based login
#                                     flow is
#                                     deprecated
#                                     by Spotify
#                                     in favor
#                                     of OAuth;
#                                     psst-gui
#                                     supports
#                                     OAuth)
#
# Interactive commands (typed on stdin while
# playing):
#   p                              - pause
#                                     playback
#   r                              - resume
#                                     playback
#   s                              - stop
#                                     playback
#   <                              - previous
#                                     track
#                                     (only
#                                     meaningful
#                                     when a
#                                     queue is
#                                     loaded)
#   >                              - next
#                                     track
#
# Example usage:
#   export SPOTIFY_USERNAME="my_user@example.com"
#   export SPOTIFY_PASSWORD="<spotify password>"
#   psst-cli 4cOdK2wGLETKBW3PvgPWqT
#
# Compile-time features (selected via cargo
# build --features):
#   cpal                           - cpal audio
#                                    output
#                                    backend
#                                    (DEFAULT;
#                                    cross-
#                                    platform
#                                    via the
#                                    cpal crate)
#   cubeb                          - cubeb audio
#                                    output
#                                    backend
#                                    (Mozilla's
#                                    cross-
#                                    platform
#                                    audio
#                                    library;
#                                    lower-
#                                    latency
#                                    than cpal)
#
# The symphonia lane is built on `symphonia =
# "0.5.4"` with selected codec features
# (declared verbatim at psst-core/Cargo.toml HEAD
# as a direct dep, used in the psst-core audio
# pipeline for decoding Ogg Vorbis + AAC audio
# streams fetched from Spotify's CDN), the
# canonical Rust audio decoding framework by
# Philip Deljanov (pdeljanov) - github.com/
# pdeljanov/Symphonia.
#
# Philip Deljanov's pdeljanov/Symphonia is the
# de-facto canonical Rust audio decoding
# library:
#   - 1,000+ reverse-deps on crates.io
#   - Pure-Rust implementation of multiple
#     audio codec families
#   - Container/format support: ISO/MP4 +
#     Matroska/WebM + OGG + AIFF + WAV + FLAC +
#     RIFF + Caf + MPEG ADTS
#   - Codec support: MP3 + AAC-LC + Ogg Vorbis +
#     FLAC + ALAC + AdpCM IMA + ADPCM Microsoft +
#     PCM + ULAW + ALAW
#   - Metadata extraction: ID3v1/v2 + Vorbis
#     comments + APE + ISO Box tags + RIFF list
#   - Streaming + random-access decoder API
#   - SIMD-accelerated codec implementations
#     where applicable
#   - No FFI dependencies (replaces
#     libavcodec/FFmpeg + libavformat for many
#     use cases)
#
# Symphonia's distinguishing position vs Rust
# audio alternatives:
#   - Symphonia (Deljanov): canonical multi-codec
#     framework; THIS AXIS
#   - rodio: higher-level audio playback library
#     (uses Symphonia underneath for decoding)
#   - rust-vorbis: Ogg Vorbis-specific bindings
#     to libvorbis C library
#   - claxon: FLAC-specific pure-Rust decoder
#   - hound: WAV-specific pure-Rust decoder
#
# Symphonia's positioning is unique in the Rust
# audio ecosystem - it's the *unified multi-
# codec decoder framework* that other crates
# build on. rodio defers to Symphonia for
# format-detection + decoder dispatch; many
# music player projects (Termusic + Music
# Player + Psst + ...) use Symphonia directly.
#
# Philip Deljanov's broader Rust ecosystem
# footprint:
#   - pdeljanov/Symphonia (canonical Rust
#     audio decoding; THIS AXIS)
#   - Other audio-pipeline-related crates in
#     the Symphonia ecosystem
#
# Deljanov's role in Rust is *specialized
# multi-codec audio infrastructure* - similar
# vertically-focused canonical position to:
#   - Patrick Klein (midir; Axis 269 Rust):
#     MIDI infrastructure
#   - Y. T. Chung (rust-ini + Shadowsocks +
#     bson): specialized protocol implementations
#   - Bytebeam Tech (rumqtt; Axis 270 Rust):
#     MQTT infrastructure
#
# These specialized-protocol canonical authors
# form a distinct cluster from the broader
# foundational-library authors (Tolnay + Crichton
# + Gallant). Each owns a specific protocol or
# format-handling vertical without spanning
# multiple unrelated verticals.
#
# psst-cli uses Symphonia transitively via
# psst-core's audio playback pipeline:
#   ```rust
#   use symphonia::core::{
#       codecs::DecoderOptions,
#       formats::{FormatOptions, FormatReader},
#       io::MediaSourceStream,
#       meta::MetadataOptions,
#       probe::Hint,
#   };
#
#   // psst-core fetches Ogg Vorbis bytes from
#   // Spotify CDN
#   let bytes = cdn.fetch_audio(file_id).await?;
#   let cursor = Cursor::new(bytes);
#   let stream = MediaSourceStream::new(
#       Box::new(cursor),
#       Default::default()
#   );
#   let probed = symphonia::default::get_probe()
#       .format(
#           &Hint::new(),
#           stream,
#           &FormatOptions::default(),
#           &MetadataOptions::default()
#       )?;
#   let track = probed.format.default_track()?;
#   let mut decoder = symphonia::default::
#       get_codecs().make(
#           &track.codec_params,
#           &DecoderOptions::default()
#       )?;
#   while let Ok(packet) = probed.format
#           .next_packet() {
#       let decoded = decoder.decode(&packet)?;
#       audio_output.write(decoded);
#   }
#   ```
# The decoded PCM samples flow into the cpal/
# cubeb audio output backend for hardware
# playback.
#
# ----------------------------------------------------------------------------
# AXIS 271 :: Audio codec / decoding libraries
#              (multi-format audio file decoding
#              + container parsing + metadata
#              extraction for music players +
#              audio analysis + format-conversion
#              tooling)
# Round 1511 :: Rust slot 1 of 4 :: OPENS Axis 271
#
# Cross-language canonical library family for this axis
# (proposed):
#   Rust    : pdeljanov/Symphonia          - Philip
#                                              Deljanov's
#                                              canonical
#                                              Rust multi-
#                                              codec
#                                              audio
#                                              decoding
#                                              framework;
#                                              pure-Rust;
#                                              no FFmpeg
#                                              dependency
#   Go      : hajimehoshi/oto OR             - Hajime
#             go-audio/audio                    Hoshi's
#                                              canonical
#                                              Go audio
#                                              playback
#                                              library
#                                              (oto)
#                                              + Yves
#                                              Junqueira's
#                                              go-audio
#                                              format/
#                                              decoder
#                                              umbrella
#   TS/Node : audio-decode + various          - canonical
#             format-specific decoders          Node
#                                              audio
#                                              decoding
#                                              libraries
#                                              (audio-
#                                              decode +
#                                              wav +
#                                              ogg-stream
#                                              + node-
#                                              lame + ...)
#
# Audio codec is a *spec-bound + multi-format*
# axis - each audio container + codec has its
# own spec:
#   - MP3 (MPEG-1/2/2.5 Layer III; ISO/IEC 11172-3
#     + 13818-3)
#   - AAC (MPEG-2/4 Advanced Audio Coding;
#     ISO/IEC 13818-7 + 14496-3)
#   - Ogg Vorbis (Xiph.org; RFC 5334)
#   - FLAC (Free Lossless Audio Codec; Xiph.org;
#     RFC 9639)
#   - Opus (RFC 6716; succeeding Vorbis for
#     low-latency)
#   - ALAC (Apple Lossless Audio Codec;
#     reverse-engineered)
#   - PCM (Pulse Code Modulation; uncompressed
#     baseline)
#
# Each canonical library provides multi-format
# abstraction over the per-codec specs:
#   - Symphonia (Rust): multi-codec multi-
#     container framework
#   - go-audio (Go): per-format-package
#     umbrella (separate sub-packages for WAV +
#     MP3 + Ogg + FLAC)
#   - audio-decode (Node): isomorphic browser-
#     compatible decoder dispatching
#
# Cross-language interop at the audio byte
# level - the same .mp3 + .ogg + .flac + .wav
# file can be decoded across all three
# canonicals into byte-identical PCM samples
# (modulo decoder-specific dithering + sample-
# rate-conversion implementations).
#
# Use case spectrum for this axis (so far):
#   - psst-cli (Rust, Symphonia): Spotify Ogg
#     Vorbis stream decoder + CLI test
#     harness for the psst-gui native Spotify
#     client
#
# Notable that audio-codec libraries are
# especially important in the Rust ecosystem
# given the *Rust-as-only-pure-impl* pattern
# observed at Axis 269 (MIDI) - Symphonia is
# the only major audio codec library that
# replaces libavcodec/FFmpeg for many use
# cases without requiring C/C++ dependencies
# or platform-specific configuration.
#
# Audio codec tooling spans:
#   - Music players (rhythmbox + clementine +
#     foobar2000 + iTunes + Spotify + Apple
#     Music + ...)
#   - Audio editors (Audacity + Reaper + Logic
#     Pro + Pro Tools + ...)
#   - DAW playback engines
#   - Streaming services (Spotify + YouTube
#     Music + ...) for offline storage
#   - Podcast clients (Overcast + Pocket
#     Casts + ...)
#   - Audio analysis tools (waveform display +
#     spectrogram visualization)
#   - Audio format conversion CLIs (ffmpeg +
#     sox + ...)
#
# Axis 271 opens with the Rust slot at
# Deljanov's Symphonia, anchoring his
# specialized-protocol canonical position.
# Subsequent rounds will visit the Go (hajime
# hoshi/oto + go-audio) + TS/Node (audio-
# decode + per-format libraries) canonicals.
# ============================================================================

_psst-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -s -S \
        '(- *)'{-h,--help}'[print help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1:track_id (Spotify base62 ID):'
}

_psst-cli "$@"
