#compdef lout
# Documentation: https://www.mankier.com/1/lout
# Reference accessed: 2026-05-19
# Verified: upstream lout(1) man page at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '-o+[output file]:file:_files' \
  '-e+[error log file]:file:_files' \
  '-a[use alternative error message format]' \
  '-EPS[Encapsulated PostScript output]' \
  '-p[plain text output]' \
  '-P[plain text output with form-feeds between pages]' \
  '-Z[PDF output]' \
  '-PDF[PDF output]' \
  '-t[ignore texture options]' \
  '-s[suppress cross-reference database operations]' \
  '-l[sort cross-references in ASCII order]' \
  '-L[sort cross-references in locale order]' \
  '-S[safe execution mode]' \
  '-U[unsafe execution mode]' \
  '*-i+[option (-i) file]:file:_files' \
  '*-I+[include directory]:dir:_files -/' \
  '*-C+[character mapping directory]:dir:_files -/' \
  '*-F+[font metrics directory]:dir:_files -/' \
  '*-H+[hyphenation patterns directory]:dir:_files -/' \
  '*-D+[database files directory]:dir:_files -/' \
  '-r+[run Lout multiple times]:n:' \
  '-x[initialization run mode]' \
  '-u[print usage information]' \
  '-V[print version information]' \
  '-M[use less memory]' \
  '-w[show word count]' \
  '*: :_files -g "*.lout *.lt"' && ret=0

return ret
