#compdef pcal
# Documentation: https://raw.githubusercontent.com/pmer/tla-bin/master/bin/pcal
# Reference accessed: 2026-05-27
# Verified: upstream pcal.trans.parseAndProcessArguments() in tlaplus/tlaplus
#   tlatools/org.lamport.tlatools/src/pcal/trans.java

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-help[print help and exit]' \
  '-writeAST[write AST file without performing translation]' \
  '-debug[run in debugging mode]' \
  '-unixEOL[force Unix line endings]' \
  '-termination[add termination property to cfg]' \
  '-noold[do not rename original file to .old]' \
  '-nocfg[suppress cfg file writing]' \
  '-noDoneDisjunct[omit stuttering-on-done disjunct]' \
  '-wf[use weak fairness per process]' \
  '-sf[use strong fairness per process]' \
  '-wfNext[use weak fairness for the entire next-state action]' \
  '-nof[no fairness formula]' \
  '-label[add missing labels automatically]' \
  '-reportLabels[print added label names and locations]' \
  '-spec[use TLC with named spec file]:name:' \
  '-myspec[as -spec using current directory]:name:' \
  '-spec2[use TLC2 with named spec file]:name:' \
  '-myspec2[as -myspec with TLC2]:name:' \
  '-labelRoot[prefix used for generated labels]:name:' \
  '-version[required PlusCal version]:version:' \
  '-lineWidth[maximum line width for translation]:width:' \
  '*:file:_files -g "*.tla"' && ret=0

return ret
