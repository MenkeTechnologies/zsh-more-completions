#compdef elasticsearch-shard
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/shard-tool.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  {-s,--silent}'[silent]' \
  {-v,--verbose}'[verbose]' \
  '1:command:(remove-corrupted-data)' \
  '--index=[index name]:index:' \
  '--shard-id=[shard ID]:n:' \
  '--dir=[shard data directory]:dir:_files -/' \
  '--truncate-clean-translog[truncate clean translog]' && ret=0

return ret
