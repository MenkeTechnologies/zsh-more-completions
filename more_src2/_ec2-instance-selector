#compdef ec2-instance-selector
# Documentation: https://github.com/aws/amazon-ec2-instance-selector
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --vcpus)'{-c+,--vcpus=}'[number of vCPUs]:n:' \
  '--vcpus-min=[vCPU minimum]:n:' \
  '--vcpus-max=[vCPU maximum]:n:' \
  '(-m --memory)'{-m+,--memory=}'[memory (e.g. 4)]:gib:' \
  '--memory-min=[memory minimum]:gib:' \
  '--memory-max=[memory maximum]:gib:' \
  '(-a --cpu-architecture)'{-a+,--cpu-architecture=}'[CPU architecture]:arch:(x86_64 i386 arm64 x86_64_mac arm64_mac)' \
  '--cpu-manufacturer=[CPU manufacturer]:vendor:(amd intel aws apple)' \
  '--network-interfaces=[ENI count]:n:' \
  '--network-interfaces-min=[ENI min]:n:' \
  '--network-interfaces-max=[ENI max]:n:' \
  '--network-performance=[network bandwidth in Gbps]:n:' \
  '--network-performance-min=[bandwidth min]:n:' \
  '--network-performance-max=[bandwidth max]:n:' \
  '--instance-storage=[instance store size]:gib:' \
  '--instance-storage-min=[instance store min]:gib:' \
  '--instance-storage-max=[instance store max]:gib:' \
  '(-g --gpus)'{-g+,--gpus=}'[GPU count]:n:' \
  '--gpus-min=[GPU min]:n:' \
  '--gpus-max=[GPU max]:n:' \
  '--gpu-memory-total=[total GPU memory]:gib:' \
  '--gpu-memory-total-min=[GPU memory min]:gib:' \
  '--gpu-memory-total-max=[GPU memory max]:gib:' \
  '--gpu-manufacturer=[GPU manufacturer]:mfr:(nvidia amd habana)' \
  '--gpu-model=[GPU model]:model:' \
  '--inference-accelerators=[accelerator count]:n:' \
  '--inference-accelerator-manufacturer=[accelerator vendor]:mfr:' \
  '--inference-accelerator-model=[accelerator model]:model:' \
  '--current-generation[current-gen instances only]' \
  '--baremetal[bare metal (.metal) instances]' \
  '(-b --burst-support)'{-b,--burst-support}'[burstable performance]' \
  '--hypervisor=[hypervisor]:hv:(xen nitro)' \
  '(-e --ena-support)'{-e,--ena-support}'[ENA support required]' \
  '--ebs-optimized[EBS optimized]' \
  '--root-device-type=[root device type]:type:(ebs instance-store)' \
  '(-u --usage-class)'{-u+,--usage-class=}'[usage class]:class:(spot on-demand)' \
  '(-f --fpga-support)'{-f,--fpga-support}'[FPGA instances]' \
  '--dedicated-hosts[dedicated hosts support]' \
  '--hibernation-support[hibernation supported]' \
  '--auto-recovery[auto-recovery supported]' \
  '--virtualization-type=[virtualization type]:type:(hvm pv)' \
  '--disk-type=[disk type]:type:(hdd ssd)' \
  '--disk-encryption[disk encryption support]' \
  '--nvme[NVMe required]' \
  '--efa-support[Elastic Fabric Adapter support]' \
  '--network-encryption[in-transit encryption]' \
  '--ipv6[IPv6 support]' \
  '--placement-group-strategy=[placement group]:strategy:(cluster partition spread)' \
  '--free-tier[Free Tier eligible]' \
  '--price-per-hour=[USD per hour]:price:' \
  '--price-per-hour-min=[price min]:price:' \
  '--price-per-hour-max=[price max]:price:' \
  '--allow-list=[regex of allowed instance types]:regex:' \
  '--deny-list=[regex of denied instance types]:regex:' \
  '*--instance-types=[exact instance type names]:type:' \
  '--vcpus-to-memory-ratio=[vCPU/memory ratio]:ratio:' \
  '*--service=[service compat (e.g. emr-5.20.0)]:service:' \
  '--base-instance-type=[reference instance type]:type:' \
  '--flexible[multi-gen flexible default]' \
  '*'{-z+,--availability-zones=}'[availability zones]:az:' \
  '(-r --region)'{-r+,--region=}'[AWS region]:region:' \
  '--profile=[AWS profile]:profile:' \
  '(-o --output)'{-o+,--output=}'[output format]:format:(table table-wide one-line interactive)' \
  '--max-results=[result limit]:n:' \
  '--sort-by=[sort field]:field:' \
  '--sort-direction=[sort direction]:dir:(ascending descending)' \
  '--cache-dir=[cache dir]:dir:_files -/' \
  '--cache-ttl=[cache TTL in hours]:n:' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' \
  '--debug[debug logging]' && ret=0

return ret
