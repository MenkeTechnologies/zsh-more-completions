#compdef dh_shlibdeps
# Documentation: https://manpages.debian.org/dh_shlibdeps
# Source: Debian/debhelper dh_shlibdeps — calculate shared library dependencies (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '*'{-L+,--libpackage=}'[library package]:pkg:_default' \
    '--dpkg-shlibdeps-params=-[options for dpkg-shlibdeps]:opts:_default' \
    '-l+[shared-library directories]:dirs:_default' \
    '*-O+[passthrough option]:opt:_default' \
    && ret=0

return ret
