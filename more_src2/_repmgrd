#compdef repmgrd
# Documentation: https://github.com/EnterpriseDB/repmgr
# Reference accessed: 2026-05-29

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-f,--config-file}'[path to configuration file]:config file:_files' \
  '--daemonize[run as a daemon]' \
  '--no-daemonize[do not run as a daemon]' \
  {-p,--pid-file}'[path to PID file]:pid file:_files' \
  {-v,--verbose}'[increase verbosity]' \
  {-t,--monitoring-history}'[enable monitoring history]' \
  '--dry-run[check configuration without starting]'
