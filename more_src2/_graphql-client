#compdef graphql-client
# ============================================================================
# _graphql-client — zsh completion for graphql-rust's `graphql-client` CLI,
#                    the official codegen + schema-introspection driver for
#                    the canonical Rust GraphQL client library
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/graphql-rust/graphql-client
#   Maintainer : graphql-rust (Tom Houlé and contributors)
#   License    : Apache-2.0 OR MIT
#   Stars      : 1255
#   Language   : Rust
#   Crate      : graphql_client_cli  (workspace member)
#   Binary     : graphql-client  (graphql_client_cli/Cargo.toml [[bin]]
#                                  name = "graphql-client",
#                                  path = "src/main.rs")
#   Last push  : 2026-02-20
#
# WHAT IT IS
#   `graphql-client` is "the CLI for graphql-client" — the offline
#   companion driver to the `graphql_client` Rust crate, the canonical
#   typed Rust GraphQL client maintained by the graphql-rust org.
#   It does two complementary things:  (1) connects to a live GraphQL
#   endpoint and runs an introspection query, dumping the response
#   as JSON to stdout or a file;  (2) takes that JSON (or a `.graphql`
#   schema) plus a `.graphql` query document and generates strongly-
#   typed Rust structs for variables and responses via the same
#   `graphql_client_codegen` crate that powers the `#[derive(
#   GraphQLQuery)]` proc-macro at compile time.
#
# CLI ARGUMENT GRAMMAR  (verbatim from graphql_client_cli/src/main.rs
#                       clap-derive `enum Cli` — clap = "^4.0" with
#                       feature "derive")
#   graphql-client <SUBCOMMAND> [OPTIONS]
#
#   Subcommands:
#     introspect-schema <SCHEMA_LOCATION>
#                                  Fetch the schema from a live GraphQL
#                                  API; print JSON to stdout (or
#                                  --output)
#       --output <PATH>              File to write the introspected
#                                    schema JSON to
#       --authorization <VALUE>      Authorization header value
#       --header 'NAME: VALUE'       Add a custom request header
#                                    (repeatable)
#       --no-ssl                     Disable SSL verification
#                                    [default: false]
#       --is-one-of                  Include the @oneOf directive in
#                                    the introspection query
#                                    [default: false]
#       --specify-by-url             Include the @specifiedByURL
#                                    directive in the introspection
#                                    query  [default: false]
#
#     generate <QUERY_PATH>          Generate Rust types from a GraphQL
#                                    query + schema pair
#       -s, --schema-path <PATH>     Path to GraphQL schema
#                                    (.json or .graphql)  [required]
#       --selected-operation <NAME>  Restrict codegen to one query in
#                                    a multi-query file
#       -I, --variables-derives <CSV>
#                                    Extra derives for variable
#                                    structs  (e.g.
#                                    `Serialize,PartialEq`)
#       -O, --response-derives <CSV> Extra derives for response
#                                    structs
#       -d, --deprecation-strategy <STRATEGY>
#                                    Deprecation handling
#                                    [allow|deny|warn — default: warn]
#       --no-formatting              Do not run rustfmt on output
#                                    [default: false]
#       -m, --module-visibility <VIS>
#                                    Generated module visibility
#                                    [pub|private — default: pub]
#       -o, --output-directory <DIR> Directory for generated code
#                                    [default: next to the .graphql
#                                    file]
#       -p, --custom-scalars-module <PATH>
#                                    Rust module path holding custom
#                                    scalar definitions
#                                    (e.g.
#                                    `crate::gql::custom_scalars`)
#       --fragments-other-variant    Emit an "Other" variant on
#                                    fragment union/interface enums
#       --external-enums <NAME>...   Enum types defined outside the
#                                    generated module (matched by
#                                    schema name; repeatable)
#       --custom-variable_types <CSV>
#                                    Custom variable types (note the
#                                    upstream flag name uses an
#                                    underscore: `--custom-variable_
#                                    types`)
#       --custom-response-type <PATH>
#                                    Custom response type
#                                    (e.g.
#                                    `external_crate::MyResponse`)
#
#   Standard clap auto-flags:
#     -h, --help                     Show help
#     -V, --version                  Show version
#
# AXIS / CORPUS POSITION
#   Direct dependency on `graphql_client = { version = "0.16.0",
#   path = "../graphql_client" }` and
#   `graphql_client_codegen = { version = "0.16.0" }` declared in
#   graphql_client_cli/Cargo.toml — the canonical Rust GraphQL client
#   library maintained by the graphql-rust org
#   (graphql-rust/graphql-client).  `graphql_client` is the typed,
#   correct GraphQL request/response crate that pairs a
#   `.graphql` query with strongly-typed Rust structs via the
#   `#[derive(GraphQLQuery)]` proc-macro and a `reqwest`/`async`
#   transport;  it provides the `GraphQLQuery` trait,
#   `Response<ResponseData>`, error machinery, optional features
#   for `reqwest-blocking`, `reqwest`, `web` (browser fetch), and
#   the `graphql_query_derive` proc-macro.  `graphql_client_cli`
#   constructs `reqwest::blocking::Client`, calls
#   `client.post(url).json(&IntrospectionQuery)`, and pipes the
#   response through the same parser stack the proc-macro uses at
#   build time.  Verified via:
#     gh api repos/graphql-rust/graphql-client/contents/
#         graphql_client_cli/Cargo.toml
#       → name = "graphql_client_cli"; [[bin]] name = "graphql-client";
#         path = "src/main.rs"
#       → graphql_client = { version = "0.16.0", path =
#         "../graphql_client" }
#       → clap = { version = "^4.0", features = ["derive"] }
#     gh api repos/graphql-rust/graphql-client/contents/
#         graphql_client_cli/src/main.rs
#       → enum Cli { IntrospectSchema {...}, Generate {...} }
#   This entry is the Rust=138 leader bump that OPENS Axis 83
#   (GraphQL Client Library) at 1/0/0.  Pairing Go and TS-Node
#   bumps will follow at R922 and R923 (Go=138 candidates
#   `Khan/genqlient`, `machinebox/graphql`; TS-Node=138 candidates
#   `graphql-js`, `apollo-client`).
#
#   No completion for `graphql-client` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_graphql-client() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :_graphql-client_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                introspect-schema)
                    _arguments \
                        '--output=[write introspected schema JSON to file]:output:_files' \
                        '--authorization=[Authorization header value]:value:' \
                        '*--header=[custom request header (NAME: VALUE; repeatable)]:header:' \
                        '--no-ssl[disable SSL verification]' \
                        '--is-one-of[include @oneOf directive in introspection query]' \
                        '--specify-by-url[include @specifiedByURL directive in introspection query]' \
                        ':schema URL:' && ret=0 ;;
                generate)
                    _arguments \
                        '(-s --schema-path)'{-s,--schema-path}'=[path to GraphQL schema (.json or .graphql)]:schema:_files' \
                        '--selected-operation=[restrict codegen to one query in multi-query file]:operation name:' \
                        '(-I --variables-derives)'{-I,--variables-derives}'=[extra derives for variable structs]:csv:' \
                        '(-O --response-derives)'{-O,--response-derives}'=[extra derives for response structs]:csv:' \
                        '(-d --deprecation-strategy)'{-d,--deprecation-strategy}'=[deprecation handling]:strategy:(allow deny warn)' \
                        '--no-formatting[do not run rustfmt on output]' \
                        '(-m --module-visibility)'{-m,--module-visibility}'=[generated module visibility]:visibility:(pub private)' \
                        '(-o --output-directory)'{-o,--output-directory}'=[directory for generated code]:dir:_files -/' \
                        '(-p --custom-scalars-module)'{-p,--custom-scalars-module}'=[Rust module path for custom scalars]:module path:' \
                        '--fragments-other-variant[emit Other variant on fragment union/interface enums]' \
                        '*--external-enums=[enum type defined outside generated module (repeatable)]:enum name:' \
                        '--custom-variable_types=[custom variable types (note underscore in flag)]:csv:' \
                        '--custom-response-type=[custom response type path]:type path:' \
                        ':GraphQL query file:_files -g "*.graphql"' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_graphql-client_commands] )) ||
_graphql-client_commands() {
    local -a commands
    commands=(
        'introspect-schema:fetch the schema from a live GraphQL API'
        'generate:generate Rust types from a GraphQL query + schema pair'
    )
    _describe -t commands 'graphql-client command' commands
}

_graphql-client "$@"
