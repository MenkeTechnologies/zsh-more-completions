#compdef dcmcjpeg
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmcjpeg.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmjpeg/apps/dcmcjpeg.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmjpeg/apps/dcmcjpeg.cc OFCommandLine setup + docs/man/dcmcjpeg.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+f --read-file)'{+f,--read-file}'[read file format or data set (default)]' \
  '(+fo --read-file-only)'{+fo,--read-file-only}'[read file format only]' \
  '(-f --read-dataset)'{-f,--read-dataset}'[read data set without file meta information]' \
  '(-t= --read-xfer-auto)'{-t=,--read-xfer-auto}'[use TS recognition (default)]' \
  '(-td --read-xfer-detect)'{-td,--read-xfer-detect}'[ignore TS specified in the file meta header]' \
  '(-te --read-xfer-little)'{-te,--read-xfer-little}'[read with explicit VR little endian TS]' \
  '(-tb --read-xfer-big)'{-tb,--read-xfer-big}'[read with explicit VR big endian TS]' \
  '(-ti --read-xfer-implicit)'{-ti,--read-xfer-implicit}'[read with implicit VR little endian TS]' \
  '(+Ma --accept-acr-nema)'{+Ma,--accept-acr-nema}'[accept ACR-NEMA images without photometric interpretation]' \
  '(+Mp --accept-palettes)'{+Mp,--accept-palettes}'[accept incorrect palette attribute tags]' \
  '(+e1 --encode-lossless-sv1)'{+e1,--encode-lossless-sv1}'[encode lossless sv1 (default)]' \
  '(+el --encode-lossless)'{+el,--encode-lossless}'[encode lossless]' \
  '(+eb --encode-baseline)'{+eb,--encode-baseline}'[encode baseline]' \
  '(+ee --encode-extended)'{+ee,--encode-extended}'[encode extended sequential]' \
  '(+es --encode-spectral)'{+es,--encode-spectral}'[encode spectral selection]' \
  '(+ep --encode-progressive)'{+ep,--encode-progressive}'[encode progressive]' \
  '(+tl --true-lossless)'{+tl,--true-lossless}'[true lossless codec (default)]' \
  '(+pl --pseudo-lossless)'{+pl,--pseudo-lossless}'[old pseudo-lossless codec]' \
  '(+sv --selection-value)'{+sv+,--selection-value=}'[selection value (1..7, default: 6)]:sv:' \
  '(+pt --point-transform)'{+pt+,--point-transform=}'[point transform (0..15, default: 0)]:pt:' \
  '(+q --quality)'{+q+,--quality=}'[JPEG quality (0..100, default: 90)]:q:' \
  '(+sm --smooth)'{+sm+,--smooth=}'[smoothing factor (0..100, default: 0)]:s:' \
  '(+ho --huffman-optimize)'{+ho,--huffman-optimize}'[optimize huffman tables (default)]' \
  '(-ho --huffman-standard)'{-ho,--huffman-standard}'[use standard huffman tables if 8 bits/sample]' \
  '(+ba --bits-auto)'{+ba,--bits-auto}'[choose bits/sample automatically (default)]' \
  '(+be --bits-force-8)'{+be,--bits-force-8}'[force 8 bits/sample]' \
  '(+bt --bits-force-12)'{+bt,--bits-force-12}'[force 12 bits/sample (not with baseline)]' \
  '(+bs --bits-force-16)'{+bs,--bits-force-16}'[force 16 bits/sample (lossless only)]' \
  '(+cy --color-ybr)'{+cy,--color-ybr}'[use YCbCr for color images if lossy (default)]' \
  '(+cr --color-rgb)'{+cr,--color-rgb}'[use RGB for color images if lossy]' \
  '(+cm --monochrome)'{+cm,--monochrome}'[convert color images to monochrome]' \
  '(+cp --conv-photometric)'{+cp,--conv-photometric}'[convert if YCbCr photometric interpretation (default)]' \
  '(+cl --conv-lossy)'{+cl,--conv-lossy}'[convert YCbCr to RGB if lossy JPEG]' \
  '(+cg --conv-guess)'{+cg,--conv-guess}'[convert to RGB if YCbCr is guessed by library]' \
  '(+cgl --conv-guess-lossy)'{+cgl,--conv-guess-lossy}'[convert to RGB if lossy JPEG and YCbCr is guessed]' \
  '(+ca --conv-always)'{+ca,--conv-always}'[always convert YCbCr to RGB]' \
  '(+cn --conv-never)'{+cn,--conv-never}'[never convert color space]' \
  '(+w6 --workaround-pred6)'{+w6,--workaround-pred6}'[enable workaround for predictor 6 overflow]' \
  '(+wi --workaround-incpl)'{+wi,--workaround-incpl}'[enable workaround for incomplete JPEG data]' \
  '(+wc --workaround-cornell)'{+wc,--workaround-cornell}'[enable workaround for 16-bit Cornell Huffman overflow]' \
  '(+s2 --sample-422)'{+s2,--sample-422}'[4:2:2 subsampling with YBR_FULL_422 (default)]' \
  '(+s4 --nonstd-444)'{+s4,--nonstd-444}'[4:4:4 sampling with YBR_FULL]' \
  '(+n2 --nonstd-422-full)'{+n2,--nonstd-422-full}'[4:2:2 subsampling with YBR_FULL]' \
  '(+n1 --nonstd-411-full)'{+n1,--nonstd-411-full}'[4:1:1 subsampling with YBR_FULL]' \
  '(+np --nonstd-411)'{+np,--nonstd-411}'[4:1:1 subsampling with YBR_FULL_422]' \
  '(+ff --fragment-per-frame)'{+ff,--fragment-per-frame}'[encode each frame as one fragment (default)]' \
  '(+fs --fragment-size)'{+fs+,--fragment-size=}'[limit fragment size to s kbytes]:size:' \
  '(+ot --offset-table-create)'{+ot,--offset-table-create}'[create offset table (default)]' \
  '(-ot --offset-table-empty)'{-ot,--offset-table-empty}'[leave offset table empty]' \
  '(-W --no-windowing)'{-W,--no-windowing}'[no VOI windowing (default)]' \
  '(+Wi --use-window)'{+Wi+,--use-window=}'[use n-th VOI window from image file]:n:' \
  '(+Wl --use-voi-lut)'{+Wl+,--use-voi-lut=}'[use n-th VOI look-up table from image file]:n:' \
  '(+Wm --min-max-window)'{+Wm,--min-max-window}'[compute VOI window using min-max algorithm]' \
  '(+Wn --min-max-window-n)'{+Wn,--min-max-window-n}'[compute VOI window using min-max, ignoring extremes]' \
  '(+Wr --roi-min-max-window)'{+Wr+,--roi-min-max-window=}'[compute ROI window using min-max algorithm]:left top width height:' \
  '(+Wh --histogram-window)'{+Wh+,--histogram-window=}'[compute VOI window using Histogram with n%]:n:' \
  '(+Ww --set-window)'{+Ww+,--set-window=}'[compute VOI window using center c and width w]:center width:' \
  '(+sp --scaling-pixel)'{+sp,--scaling-pixel}'[scale using min/max pixel value (default)]' \
  '(+sr --scaling-range)'{+sr,--scaling-range}'[scale using min/max range]' \
  '(+ri --rescale-identity)'{+ri,--rescale-identity}'[encode identity modality rescale (default)]' \
  '(+rm --rescale-map)'{+rm,--rescale-map}'[use modality rescale to scale pixel range]' \
  '(+cd --class-default)'{+cd,--class-default}'[keep SOP Class UID (default)]' \
  '(+cs --class-sc)'{+cs,--class-sc}'[convert to Secondary Capture Image (implies --uid-always)]' \
  '(+ud --uid-default)'{+ud,--uid-default}'[assign new UID if lossy compression (default)]' \
  '(+ua --uid-always)'{+ua,--uid-always}'[always assign new UID]' \
  '(+un --uid-never)'{+un,--uid-never}'[never assign new UID]' \
  '(+u --enable-new-vr)'{+u,--enable-new-vr}'[enable support for new VRs (UN/UT) (default)]' \
  '(-u --disable-new-vr)'{-u,--disable-new-vr}'[disable support for new VRs, convert to OB]' \
  '(+g= --group-length-recalc)'{+g=,--group-length-recalc}'[recalculate group lengths if present (default)]' \
  '(+g --group-length-create)'{+g,--group-length-create}'[always write with group length elements]' \
  '(-g --group-length-remove)'{-g,--group-length-remove}'[always write without group length elements]' \
  '(+e --length-explicit)'{+e,--length-explicit}'[write with explicit lengths (default)]' \
  '(-e --length-undefined)'{-e,--length-undefined}'[write with undefined lengths]' \
  '(-p= --padding-retain)'{-p=,--padding-retain}'[do not change padding (default)]' \
  '(-p --padding-off)'{-p,--padding-off}'[no padding]' \
  '(+p --padding-create)'{+p+,--padding-create=}'[align file and items on specified byte multiples]:file-pad and item-pad:' \
  '1:dcmfile-in:_files' \
  '2:dcmfile-out:_files'
