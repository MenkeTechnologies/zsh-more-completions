#compdef idevice idevice-id
# _idevice — libimobiledevice idevice_id list connected iOS device UDIDs CLI alias (libimobiledevice team, C); custom argparse
# upstream: https://github.com/libimobiledevice/libimobiledevice

_idevice() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--network[connect over network]' \
        '-n[connect over network]' \
        '--list[list devices]' \
        '-l[list devices]' \
        '--debug[debug]' \
        '-d[debug]' \
        '*:device-or-udid:'
}

_idevice "$@"
