#compdef misp misp-cli pymisp
# _misp-cli — CIRCL MISP misp-cli CLI client to the Malware Information Sharing Platform REST API querying creating editing events attributes objects galaxy-clusters sightings warninglists with searches by tag UUID date severity for the de-facto open-source threat intelligence sharing platform (CIRCL team, Python); click
# upstream: https://www.misp-project.org/

_misp-cli() {
    local -a sub=(
        'event:event operations'
        'attribute:attribute operations'
        'object:object operations'
        'tag:tag operations'
        'galaxy:galaxy operations'
        'warninglist:warninglist operations'
        'noticelist:noticelist operations'
        'feed:feed operations'
        'sharing-group:sharing group operations'
        'user:user operations'
        'organisation:organisation operations'
        'role:role operations'
        'sighting:sighting operations'
        'search:full-text search'
        'restsearch:RESTful search'
        'export:bulk export'
        'stix:stix import/export'
        'taxonomy:taxonomy operations'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-u+[url]:str:' \
        '--url=+[url]:str:' \
        '-k+[api key]:str:' \
        '--key=+[key]:str:' \
        '--insecure[ignore TLS errors]' \
        '-f+[format]:f:(json yaml csv table stix1 stix2 misp openioc)' \
        '--format=+[format]:f:(json yaml csv table stix1 stix2 misp openioc)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'misp-cli subcommand' sub ;;
        args)
            case $words[1] in
                event) _arguments '1:op:(list add update delete tag untag get publish unpublish)' '*:uuid:' ;;
                attribute) _arguments '1:op:(list add update delete tag untag get)' '*:uuid:' ;;
                search|restsearch) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_misp-cli "$@"
