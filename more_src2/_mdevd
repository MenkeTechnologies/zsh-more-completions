#compdef mdevd mdevd-coldplug
# Documentation: source-direct extraction from upstream
# skarnet/mdevd src/mdevd/mdevd.c + mdevd-coldplug.c USAGE strings
# + subgetopt_r option-string specs + case-arm decoding for the
# 2-way -n/-N dry-run mutex (mdevd: dryrun=1 print-only-no-act
# xor dryrun=2 verbose-dry-run).
# Reference accessed: 2026-05-30 via gh api.
# Skarnet mdevd R127b — 2-stem multi-binary harvest of the mdevd
# udev replacement. mdevd implements the busybox mdev configuration
# syntax but runs as a long-lived netlink-listener daemon (vs mdev
# which is invoked per-event by the kernel), making it suitable for
# use as the device-management daemon under s6 supervision. Sister
# to the wider Skarnet s6 ecosystem (R117-R126).

case $service in

  mdevd)
    # Long-lived netlink-listening daemon. Reads /etc/mdev.conf
    # rules, creates/destroys /dev nodes on hotplug events.
    _arguments -s -S \
      '-v+[verbosity level (default 1)]:level:' \
      '-D+[notify readiness fd]:fd:' \
      '-I+[intake fd (for forwarded netlink events)]:fd:' \
      '-o+[output fd for forwarded events]:fd:' \
      '-O+[netlink groups bitmask to subscribe to (default 1=kernel)]:bitmask:' \
      '-b+[kernel netlink socket buffer size in bytes]:bytes:' \
      '-f+[mdev.conf configuration file path]:conffile:_files' \
      '(-N)-n[dry-run: print actions but do not modify /dev]' \
      '(-n)-N[verbose dry-run: print every event and every match]' \
      '-s+[/sys mount path (default /sys)]:slashsys:_directories' \
      '-d+[/dev mount path (default /dev)]:slashdev:_directories' \
      '-F+[firmware-loading base directory (default /lib/firmware)]:fwbase:_directories' \
      '-C[coldplug mode: enumerate existing devices then exit]'
    ;;

  mdevd-coldplug)
    # One-shot coldplug helper: walks /sys/devices and forces a
    # netlink uevent for every node currently present. Sends events
    # to the running mdevd via netlink group; useful at boot to
    # process devices that were already present before mdevd
    # started.
    _arguments -s -S \
      '-v+[verbosity level]:level:' \
      '-s+[/sys mount path (default /sys)]:slashsys:_directories' \
      '-O+[netlink group to emit uevents to (default 1)]:group:' \
      '-b+[kernel netlink socket buffer size in bytes]:bytes:'
    ;;

esac
