#compdef fi_strerror
# Documentation: https://ofiwg.github.io/libfabric/main/man/fi_strerror.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fi_strerror: print libfabric error string for a given numeric FI_ERROR_CODE.
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:FI_ERROR_CODE:' && ret=0
return ret
