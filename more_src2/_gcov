#compdef gcov
# Documentation: gcov --help (LLVM)
# Source: LLVM gcov — code-coverage tool (gcov-compatible output).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--color[use colors in output (default autodetect)]' \
    '-a[display all basic blocks]' \
    '(-b)-b[display branch probabilities]' \
    '-c[display branch counts instead of percentages (requires -b)]' \
    '--demangled-names[demangle function names]' \
    '-f[show coverage for each function]' \
    '(-i --intermediate-format)'{-i,--intermediate-format}'[output .gcov in intermediate text]' \
    '-l[prefix filenames with the main file]' \
    '-m[alias for --demangled-names]' \
    '-n[do not output any .gcov files]' \
    '-o+[find objects in DIR or based on FILE]:dir_or_file:_files' \
    '-p[preserve path components]' \
    '-r[only files with relative or prefix-matched paths]' \
    '-s+[source prefix to elide]:string:' \
    '-t[print to stdout]' \
    '-u[display unconditional branch info (requires -b)]' \
    '-x[hash long pathnames]' \
    '(- *)--help[display available options]' \
    '(- *)--help-hidden[show hidden options]' \
    '(- *)--help-list[list available options]' \
    '(- *)--version[show version]' \
    '--dump[dump gcov file to stderr]' \
    '--gcda=[override inferred gcda file]:file:_files' \
    '--gcno=[override inferred gcno file]:file:_files' \
    '*:source file:_files -g "*.{c,cc,cpp,cxx,c++,m,mm}"' \
    && ret=0

return ret
