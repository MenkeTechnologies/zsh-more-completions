#compdef fc-conflist
# Documentation: fc-conflist --help (fontconfig)
# Source: fontconfig fc-conflist — list configuration / ruleset files on the system.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-V,--version}'[display fontconfig version and exit]' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
