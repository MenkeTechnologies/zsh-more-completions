#compdef gh-md-toc
# Documentation: https://github.com/ekalinin/github-markdown-toc
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '--version[version]' \
  '--insert[insert/update TOC inside file between markers]' \
  '--no-backup[skip backup file creation with --insert]' \
  '--hide-footer[omit footer comment]' \
  '*:markdown file:_files -g "*.md"' && return 0
