#compdef llvm-dwarfdump
# _llvm-dwarfdump — LLVM DWARF debug info dumper (LLVM project, C++); print DWARF sections from ELF/Mach-O binaries
# upstream: https://github.com/llvm/llvm-project

_llvm-dwarfdump() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-a[print all DIEs]' \
        '--all[print all DIEs]' \
        '-c[combine all]' \
        '--debug-info[print .debug_info]' \
        '--debug-aranges[print .debug_aranges]' \
        '--debug-abbrev[print .debug_abbrev]' \
        '--debug-addr[print .debug_addr]' \
        '--debug-ranges[print .debug_ranges]' \
        '--debug-rnglists[print .debug_rnglists]' \
        '--debug-loclists[print .debug_loclists]' \
        '--debug-loc[print .debug_loc]' \
        '--debug-frame[print .debug_frame]' \
        '--debug-line[print .debug_line]' \
        '--debug-line-str[print .debug_line_str]' \
        '--debug-pubnames[print .debug_pubnames]' \
        '--debug-pubtypes[print .debug_pubtypes]' \
        '--debug-gnu-pubnames[print .debug_gnu_pubnames]' \
        '--debug-gnu-pubtypes[print .debug_gnu_pubtypes]' \
        '--debug-macro[print .debug_macro]' \
        '--debug-names[print .debug_names]' \
        '--debug-str[print .debug_str]' \
        '--debug-str-offsets[print .debug_str_offsets]' \
        '--debug-types[print .debug_types]' \
        '--apple-names[print .apple_names]' \
        '--apple-types[print .apple_types]' \
        '--apple-namespaces[print .apple_namespaces]' \
        '--apple-objc[print .apple_objc]' \
        '--diff[diff mode]' \
        '--find=+[find]:name:' \
        '-F+[find]:name:' \
        '--ignore-case[ignore case]' \
        '-i[ignore case]' \
        '--lookup=+[lookup address]:addr:' \
        '--name=+[name to find]:name:' \
        '-n+[name to find]:name:' \
        '--no-resolve-fork[no resolve fork]' \
        '--no-resolve-link[no resolve link]' \
        '--output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '--parent-recurse-depth=+[parent recurse depth]:n:' \
        '--quiet[quiet]' \
        '--recurse-depth=+[recurse depth]:n:' \
        '-r+[recurse depth]:n:' \
        '--regex[regex matching]' \
        '-x[regex matching]' \
        '--show-children[show children]' \
        '--show-form[show form]' \
        '--show-parents[show parents]' \
        '--show-sources[show source files]' \
        '--statistics[print statistics]' \
        '--summarize-types[summarize types]' \
        '--targets[print target triple]' \
        '--uuid[print UUID]' \
        '-u[print UUID]' \
        '--verbose[verbose]' \
        '--verify[verify DWARF]' \
        '*:file:_files'
}

_llvm-dwarfdump "$@"
