#compdef doi-cli doi
# _doi-cli — doi-cli CLI Digital Object Identifier resolver fetching metadata from doi.org Crossref DataCite mEDRA EIDR Airiti JaLC OP Korea OP Italy registration agencies output BibTeX RIS Endnote XML CSL-JSON for the DOI handle system following 10. prefix shoulder identification (doi-cli team, Python); custom argparse
# upstream: https://www.doi.org/

_doi-cli() {
    local -a sub=(
        'fetch:fetch DOI metadata'
        'cite:generate citation in CSL'
        'resolve:resolve to landing page URL'
        'agency:detect registration agency'
        'validate:validate DOI syntax'
        'search:search by title/author'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--mailto=+[email]:str:' \
        '--style=+[CSL style]:s:(apa chicago-author-date harvard1 ieee mla nature vancouver chicago-fullnote-bibliography modern-language-association american-medical-association)' \
        '--locale=+[lang]:l:(en-US en-GB de-DE fr-FR es-ES it-IT pt-BR ru-RU ja-JP zh-CN ko-KR pl-PL nl-NL)' \
        '-f+[format]:f:(json bibtex ris csv yaml csl-json citeproc-json table apa chicago harvard ieee mla nature vancouver)' \
        '--format=+[format]:f:(json bibtex ris csv yaml csl-json citeproc-json table apa chicago harvard ieee mla nature vancouver)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doi-cli subcommand' sub ;;
        args)
            case $words[1] in
                fetch|cite|resolve|agency|validate) _arguments '*:doi:' ;;
                search) _arguments '*:query:' ;;
            esac
            ;;
    esac
}

_doi-cli "$@"
