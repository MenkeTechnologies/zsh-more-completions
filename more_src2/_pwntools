#compdef pwntools pwn
# _pwntools — Gallopsled pwntools CTF framework and exploit dev library CLI alias (Gallopsled team, Python); argparse
# upstream: https://github.com/Gallopsled/pwntools

_pwntools() {
    local -a sub=(
        'asm:assemble shellcode'
        'checksec:check ELF security mitigations'
        'constgrep:grep constants from headers'
        'cyclic:cyclic pattern generator'
        'debug:debug binary'
        'disablenx:disable NX'
        'disasm:disassemble bytes'
        'elfdiff:diff two ELF files'
        'elfpatch:patch ELF bytes'
        'errno:lookup errno'
        'hex:hex encode/decode'
        'libcdb:lookup libc by hash'
        'phd:hex dump'
        'pwnstrip:strip exploit'
        'scramble:transform bytes via packing'
        'shellcraft:generate shellcraft'
        'template:generate exploit template'
        'unhex:decode hex'
        'update:update pwntools'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pwn subcommand' sub ;;
        args)
            case $words[1] in
                asm|disasm|shellcraft) _arguments \
                    '-f+[format]:f:(string raw hex elf)' \
                    '--format=+[format]:f:(string raw hex elf)' \
                    '-a+[arch]:a:(i386 amd64 arm aarch64 mips mips64 powerpc powerpc64 sparc thumb)' \
                    '--arch=+[arch]:a:(i386 amd64 arm aarch64 mips mips64 powerpc powerpc64 sparc thumb)' \
                    '-o+[os]:o:(linux freebsd windows android)' \
                    '--os=+[os]:o:(linux freebsd windows android)' \
                    '-c+[context]:str:' \
                    '--context=+[context]:str:' \
                    '*:input:' ;;
                checksec) _arguments '*:file:_files' ;;
                cyclic) _arguments \
                    '-a+[alphabet]:str:' \
                    '-n+[subseq length]:n:' \
                    '-l+[lookup]:str:' \
                    '*:length:' ;;
                debug) _arguments \
                    '-x+[script file]:file:_files' \
                    '--exec=+[exec]:file:_files' \
                    '-p+[pid]:pid:_pids' \
                    '*:binary args:_files' ;;
                template) _arguments \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '--user=+[user]:_users' \
                    '--pass=+[password]:str:' \
                    '--libc=+[libc]:file:_files' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '*:binary:_files' ;;
            esac
            ;;
    esac
}

_pwntools "$@"
