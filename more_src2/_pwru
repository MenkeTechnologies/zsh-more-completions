#compdef pwru
# Documentation: https://github.com/cilium/pwru/blob/main/README.md
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pwru - eBPF-based packet tracing

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--filter-ifname=[filter by interface name]:interface' \
  '--filter-mark=[filter by skb mark with optional mask]:mark' \
  '--filter-netns=[filter by network namespace]:netns' \
  '--filter-func=[filter kernel functions]:function' \
  '--filter-kprobe-batch=[kprobe batch size]:n' \
  '--filter-non-skb-funcs[filter non-skb kernel functions]' \
  '--filter-trace-tc[trace TC eBPF programs]' \
  '--filter-trace-xdp[trace XDP eBPF programs]' \
  '--filter-track-bpf-helpers[trace BPF helper functions]' \
  '--filter-track-skb[track packets through transformations]' \
  '--filter-track-skb-by-stackid[track packets after kfree by stack id]' \
  '--filter-tunnel-pcap-l2=[filter tunnel L2 pcap expression]:expr' \
  '--filter-tunnel-pcap-l3=[filter tunnel L3 pcap expression]:expr' \
  '--output-caller[output caller information]' \
  '--output-file=[write output to file]:file:_files' \
  '--output-file-max-size=[max output file size]:size' \
  '--output-file-max-age=[max output file age]:age' \
  '--output-file-max-backups=[max output file backups]:n' \
  '--output-file-compress[compress output file]' \
  '--output-json[output in JSON format]' \
  '--output-limit-lines=[max output lines]:lines' \
  '--output-meta[output skb metadata]' \
  '--output-skb[output skb data]' \
  '--output-skb-cb[output skb->cb]' \
  '--output-skb-metadata=[custom skb metadata fields]:fields' \
  '--output-skb-shared-info[output skb shared info]' \
  '--output-stack[output kernel stack trace]' \
  '--output-tcp-flags[output TCP flags]' \
  '--output-tunnel[output tunnel info]' \
  '--output-tuple[output 5-tuple info]' \
  '--output-xdp-metadata[output XDP metadata]' \
  '--backend=[tracing backend]:backend:(kprobe kprobe-multi)' \
  '--kernel-btf=[path to kernel BTF]:file:_files' \
  '--timestamp=[timestamp display]:mode:(none relative absolute)' \
  '*:pcap filter expression' && ret=0

return ret
