#compdef elasticsearch-setup-passwords
# Documentation: https://www.elastic.co/guide/en/elasticsearch/reference/current/setup-passwords.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# elasticsearch-setup-passwords: set built-in user passwords (auto/interactive). Deprecated since 8.0; prefer elasticsearch-reset-password.
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-s[silent]' \
  '-v[verbose]' \
  '-b[batch mode]' \
  '--batch[batch mode]' \
  '-u[cluster URL]:url:' \
  '--url=[cluster URL]:url:' \
  '-E[config setting key=value]:kv:' \
  '1:mode:(auto interactive)' && ret=0
return ret
