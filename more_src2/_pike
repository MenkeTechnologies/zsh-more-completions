#compdef pike
# Documentation: https://github.com/JamesWoolfenden/pike
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Pike IAM policy generator completion (JamesWoolfenden/pike)

_pike_subcommands() {
  local -a subcmds=(
    'scan:scan IaC for required permissions'
    's:scan (alias)'
    'make:create IAM policy and role'
    'm:make (alias)'
    'apply:create policy and instantiate IaC'
    'a:apply (alias)'
    'compare:compare deployed policy vs IaC'
    'c:compare (alias)'
    'inspect:compare env credentials vs IaC needs'
    'x:inspect (alias)'
    'invoke:trigger a GitHub workflow'
    'i:invoke (alias)'
    'watch:poll until policy changes propagate'
    'w:watch (alias)'
    'pull:clone and scan a remote repository'
    'l:pull (alias)'
    'readme:update README with required policy'
    'r:readme (alias)'
    'runtime:identify runtime-only permissions'
    'parse:extract provider resources'
    'p:parse (alias)'
    'deprecated:list deprecated resources'
    'help:show help'
    'version:show version'
  )
  _describe -t commands 'pike subcommand' subcmds
}

_pike() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '1:subcommand:_pike_subcommands' \
    '*::arg:->args'

  case $state in
    args)
      case ${line[1]} in
        scan|s)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '(-d --directory)'{-d,--directory}'=[directory to scan]:directory:_directories' \
            '(-o --output)'{-o,--output}'=[output format]:format:(terraform json)' \
            '(-i --init)'{-i,--init}'[run terraform init to download modules]' \
            '(-w --write)'{-w,--write}'[write output to .pike folder]' \
            '-e[enable enhanced mode with AWS auth]'
          ;;
        make|m|apply|a)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '(-d --directory)'{-d,--directory}'=[directory to scan]:directory:_directories' \
            '-region=[AWS region]:region:'
          ;;
        compare|c)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '(-d --directory)'{-d,--directory}'=[directory to scan]:directory:_directories' \
            '-a=[ARN of policy to compare]:arn:'
          ;;
        inspect|x)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '(-d --directory)'{-d,--directory}'=[directory to scan]:directory:_directories'
          ;;
        invoke|i)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '-workflow=[workflow filename]:file:' \
            '-repository=[repository name]:repo:' \
            '-branch=[branch name]:branch:'
          ;;
        watch|w)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '--arn=[policy ARN to monitor]:arn:' \
            '--wait=[wait time in tenths of seconds]:tenths:'
          ;;
        pull|l)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '(-r --repository)'{-r,--repository}'=[repository URL]:url:' \
            '(-d --directory)'{-d,--directory}'=[local directory]:directory:_directories' \
            '(--dest --destination)'{--dest,--destination}'=[clone destination]:dir:_directories' \
            '(-o --output)'{-o,--output}'=[output format]:format:(terraform json)' \
            '(-i --init)'{-i,--init}'[run terraform init]' \
            '(-w --write)'{-w,--write}'[write output to file]'
          ;;
        readme|r)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '(-d --directory)'{-d,--directory}'=[directory to scan]:directory:_directories' \
            '(-o --output)'{-o,--output}'=[output format]:format:(terraform json)'
          ;;
        runtime)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '-d=[directory to scan]:directory:_directories' \
            '-p=[provider]:provider:(aws azure gcp)'
          ;;
        parse|p)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '-d=[provider repository path]:path:_directories' \
            '-name=[provider name]:name:(aws azurerm google)'
          ;;
        deprecated)
          _arguments \
            '(- *)'{-h,--help}'[show help]' \
            '-n=[provider name]:name:' \
            '(-o --output)'{-o,--output}'=[output format]:format:(text json)'
          ;;
      esac
      ;;
  esac
}

_pike "$@"
