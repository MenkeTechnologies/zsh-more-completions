#compdef flanneld
# Documentation: https://github.com/flannel-io/flannel/blob/master/Documentation/configuration.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# flanneld: Flannel networking daemon for Kubernetes.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version and exit]' \
  '--etcd-endpoints=[comma-delimited list of etcd endpoints]:endpoints:' \
  '--etcd-prefix=[etcd prefix path]:prefix:' \
  '--etcd-keyfile=[SSL key file for etcd]:file:_files' \
  '--etcd-certfile=[SSL certificate file for etcd]:file:_files' \
  '--etcd-cafile=[SSL CA file for etcd]:file:_files' \
  '*--iface=[interface (IP or name) for inter-host communication]:interface:_net_interfaces' \
  '*--iface-regex=[regex to match interface]:regex:' \
  '--iface-can-reach=[detect interface based on which IP can be reached]:ip:' \
  '--iptables-forward-rules[add ACCEPT rules to iptables FORWARD chain]' \
  '--iptables-resync=[resync period for iptables rules (seconds)]:seconds:' \
  '--subnet-file=[path to subnet file]:file:_files' \
  '--net-config-path=[path to network configuration file]:file:_files' \
  '--subnet-lease-renew-margin=[subnet lease renewal margin (minutes)]:minutes:' \
  '--ip-masq[setup IP masquerade for traffic outside flannel network]' \
  '--kube-subnet-mgr[use Kubernetes API for subnet assignment instead of etcd]' \
  '--kube-api-url=[Kubernetes API server URL]:url:' \
  '--kubeconfig-file=[path to kubeconfig file]:file:_files' \
  '--public-ip=[public IP for inter-host communication]:ip:' \
  '--public-ipv6=[public IPv6 for inter-host communication]:ipv6:' \
  '--healthz-ip=[IP address for healthz server]:ip:' \
  '--healthz-port=[port for healthz server]:port:' \
  '-v=[log verbosity level]:level:' && ret=0

return ret
