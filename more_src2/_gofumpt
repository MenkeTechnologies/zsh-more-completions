#compdef gofumpt
# Documentation: https://github.com/mvdan/gofumpt
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--version[show version]' \
  '-d[display diffs instead of rewriting]' \
  '-e[report all errors]' \
  '-extra[enable extra formatting rules]' \
  '-l[list files whose formatting differs]' \
  '-w[write result to source file]' \
  '-s[simplify code]' \
  '-lang=[set target Go version]:version' \
  '-modpath=[set module path]:path' \
  '*:file:_files -g "*.go"' && ret=0

return ret
