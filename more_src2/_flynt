#compdef flynt
# Documentation: https://github.com/ikamensh/flynt
# Reference accessed: 2026-06-04

# Zsh completion for flynt - Python f-string converter

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-l --line-length)'{-l,--line-length}'=[line length limit]:length:' \
  '(-tc --transform-concats)'{-tc,--transform-concats}'[transform string concatenations to f-strings]' \
  '(-nm --no-multiline)'{-nm,--no-multiline}'[skip multiline expressions]' \
  '(-q --quiet)'{-q,--quiet}'[suppress output]' \
  '(-v --verbose)'{-v,--verbose}'[increase output verbosity]' \
  '--fail-on-change[return exit code 1 if changes were made]' \
  '--dry-run[print changes but do not modify files]' \
  '(-s --string)'{-s,--string}'=[convert a single string]:string:' \
  '*--exclude=[glob pattern to exclude]:pattern:' \
  '*:file or directory:_files'
