#compdef polari
# Documentation: https://gitlab.gnome.org/GNOME/polari/-/raw/main/src/application.js
# Reference accessed: 2026-05-20
# Verified: upstream src/application.js add_main_option entries.
# Removed from prior file: fabricated --debug (correct name is
# --debugger / -d) and -v alias for --version (not registered).

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--start-client[activate the Telepathy client]' \
  '(-d --debugger)'{-d,--debugger}'[start in debug mode]' \
  '--test-instance[permit multiple instances]' \
  '--quit[close the application]' && ret=0

return ret
