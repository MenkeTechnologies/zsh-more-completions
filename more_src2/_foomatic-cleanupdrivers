#compdef foomatic-cleanupdrivers
# Documentation: https://github.com/OpenPrinting/foomatic-db-engine
# Reference accessed: 2026-05-16
# Verified: upstream OpenPrinting/foomatic-db-engine source. The Perl
# script reads $ARGV[0] only; no -h/--help, no --version, no named
# flags. Single optional positional argument <libdir> (defaults to
# $FOOMATICDB env var or /usr/share/foomatic).
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# foomatic-cleanupdrivers: remove orphaned driver entries from foomatic DB
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:libdir:_files -/' && ret=0
return ret
