#compdef murex
# _murex-bin — murex shell with typed data pipelines (Lammy Light, Go); JSON-aware pipes, embedded test framework
# upstream: https://github.com/lmorg/murex

_murex-bin() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-c+[evaluate string]:code:' \
        '-l[login shell]' \
        '-i[interactive]' \
        '-r+[autoexec rcfile]:file:_files' \
        '-runtests[run unit tests]' \
        '-disabletests[disable tests]' \
        '-rcfile+[rc file]:file:_files' \
        '-modules+[module dir]:dir:_files -/' \
        '-stdin[read from stdin]' \
        '*:script:_files -g "*.mx"'
}

_murex-bin "$@"
