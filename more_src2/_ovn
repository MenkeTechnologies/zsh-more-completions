#compdef ovn
# _ovn — Open vSwitch project ovn CLI top-level OVN Open Virtual Network dispatcher for the OVS-based virtual-network controller managing logical-switch logical-router L2-L3-distributed-gateway-NAT IPsec ACL-DHCP-DNS-mDNS-policy QoS for Open Vswitch OVS overlay-network typical-OpenStack-Neutron-OVN-driver KubeVirt-OVN-Kubernetes integration (OVN team, C); getopt
# upstream: https://www.ovn.org/

_ovn() {
    local -a sub=(
        'nbctl:northbound DB operations'
        'sbctl:southbound DB operations'
        'trace:OVN trace utility'
        'detrace:detrace utility'
        'appctl:application control'
        'docker-overlay-driver:legacy docker overlay driver'
        'sim:OVN simulator'
        'host-bind:host network binding'
        'cluster-state:cluster state diagnostics'
        'check-configuration:check configuration'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[db url]:str:' \
        '--db=+[url]:str:' \
        '--no-leader-only[no leader only]' \
        '--no-shuffle-remotes[no shuffle remotes]' \
        '--leader-only[leader only]' \
        '--no-syslog[no syslog]' \
        '--log-file=+[file]:file:_files' \
        '--private-key=+[file]:file:_files' \
        '--certificate=+[file]:file:_files' \
        '--ca-cert=+[file]:file:_files' \
        '-o+[output]:f:(table list csv json yaml)' \
        '--format=+[format]:f:(table list csv json yaml)' \
        '--pretty[pretty json]' \
        '--timeout=+[sec]:n:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ovn subcommand' sub ;;
    esac
}

_ovn "$@"
