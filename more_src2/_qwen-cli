#compdef qwen-cli
# Documentation: https://github.com/QwenLM/qwen-code
# Reference accessed: 2026-05-23
# Verified: @qwenlm/qwen-code package (binary qwen; see _qwen for full flags).

# Zsh completion for qwen-cli - Qwen Code agent CLI (alternate package/binary name)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '(-p --prompt)'{-p+,--prompt=}'[run single prompt headless]:prompt:' \
  '--yolo[approval-free mode]' \
  '--model[model ID]:model:' \
  '--sandbox[sandbox mode]:mode:' \
  '--resume[resume session]:session:' && ret=0

return ret
