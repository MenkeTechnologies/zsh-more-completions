#compdef gqlfmt
# _gqlfmt — format GraphQL files like gofmt (gqlgo/gqlfmt)
# upstream: https://github.com/gqlgo/gqlfmt
# Flags from main.go.

_gqlfmt() {
    _arguments \
        '-l[list files whose formatting differs]' \
        '-w[write result back to source file]' \
        '-d[display diffs instead of rewriting]' \
        '*:file or directory:_files -g "*.graphql"'
}

_gqlfmt "$@"
