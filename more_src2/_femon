#compdef femon
# _femon — Linux-DVB femon frontend monitor for live signal strength SNR BER UNC FE_HAS_LOCK status reporting with curses-style refresh (linuxtv team, C); getopt
# upstream: https://www.linuxtv.org/wiki/index.php/LinuxTV_dvb-apps

_femon() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-a+[adapter]:n:(0 1 2 3)' \
        '-f+[frontend]:n:(0 1 2 3)' \
        '-c+[refresh count]:n:' \
        '-r+[refresh interval seconds]:n:' \
        '-H[human-readable]' \
        '-d+[debug level]:n:' \
        '-A[abort on no signal]' \
        '-S[short output]' \
        '-l+[log file]:file:_files' \
        '-t+[N samples]:n:' \
        '-x[exit on lock]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-w[wide]' \
        '-n[no clear screen]'
}

_femon "$@"
