#compdef kwalletmanager
# Documentation: https://github.com/KDE/kwalletmanager/blob/master/src/manager/main.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: KDE wallet management GUI; accepts only the KAboutData standard
# options plus --show and --kwalletd compatibility flags from main.cpp.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--help-all[show all options]' \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)--author[show author information]' \
  '(- *)--license[show license information]' \
  '--show[start visible (ignored compatibility flag)]' \
  '--kwalletd[for use by kwalletd only]' \
  '*:wallet name:' && ret=0
return ret
