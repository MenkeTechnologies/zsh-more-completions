#compdef grayskull
# Documentation: https://github.com/conda/grayskull
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'pypi:generate recipe from PyPI package'
  'cran:generate recipe from CRAN package'
)

_arguments -C \
  '(- *)'{-v,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'grayskull subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (pypi)
        _arguments \
          '(-d --download)'{-d,--download}'[download package]' \
          '*'{-m,--maintainers}'=[maintainers]:maintainer:' \
          '(-o --output)'{-o,--output}'=[output dir]:dir:_files -/' \
          '--stdout[print to stdout]' \
          '--list-missing-deps[list missing deps]' \
          '*--package-indexes=[package index]:index:' \
          '--strict-conda-forge[strict conda-forge channels]' \
          '--pypi-metadata-url=[PyPI metadata URL]:url:' \
          '--pypi-mirror-url=[PyPI mirror URL]:url:' \
          '(-r --recursive)'{-r,--recursive}'[recurse into deps]' \
          '*'{-s,--sections}'=[sections]:section:(package source build requirements test about extra)' \
          '--extras-require-test[require test extras]' \
          '(-t --tag)'{-t,--tag}'=[git tag]:tag:' \
          '--extras-require-all[include all extras]' \
          '*--extras-require-include=[include extras]:extra:' \
          '*--extras-require-exclude=[exclude extras]:extra:' \
          '--extras-require-split[split extras into outputs]' \
          '*--licence-exclude-folders=[license exclude folder]:folder:' \
          '(-u --use-v1-format)'{-u,--use-v1-format}'[use v1 recipe format]' \
          '*:package: ' && ret=0
        ;;
      (cran)
        _arguments \
          '--stdout[print to stdout]' \
          '--list-missing-deps[list missing deps]' \
          '*--package-indexes=[package index]:index:' \
          '(-d --download)'{-d,--download}'[download package]' \
          '*'{-m,--maintainers}'=[maintainers]:maintainer:' \
          '(-o --output)'{-o,--output}'=[output dir]:dir:_files -/' \
          '--strict-conda-forge[strict conda-forge channels]' \
          '*'{-s,--sections}'=[sections]:section:(package source build requirements test about extra)' \
          '(-u --use-v1-format)'{-u,--use-v1-format}'[use v1 recipe format]' \
          '*:package: ' && ret=0
        ;;
    esac
    ;;
esac

return ret
