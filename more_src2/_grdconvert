#compdef grdconvert
# Documentation: https://docs.generic-mapping-tools.org/latest/grdconvert.html
# Source: GenericMappingTools/gmt classic-mode grdconvert — convert between grid file formats.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-C+[command-history handling]:opts:(b c n p)' \
    '-N[suppress GMT header in native grid output]' \
    '-R+[region west/east/south/north]:region:_default' \
    '*-V[verbose (stackable)]' \
    '-Z+[scale+offset before write]:opts:_default' \
    '-f+[I/O column data types]:types:_default' \
    '*:input grid file:_files -g "*.(grd|nc|tif|cdf|hgt|jp2|img)(-.)"' \
    && ret=0

return ret
