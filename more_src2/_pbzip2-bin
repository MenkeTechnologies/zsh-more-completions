#compdef pbzip2
# _pbzip2-bin — pbzip2 parallel bzip2 (Jeff Gilchrist); bzip2-compatible multi-threaded compressor
# upstream: https://launchpad.net/pbzip2

_pbzip2-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-d --decompress)'{-d,--decompress}'[decompress]' \
        '(-t --test)'{-t,--test}'[test integrity]' \
        '(-c --stdout)'{-c,--stdout}'[write to stdout]' \
        '(-r --read)'{-r,--read}'[read entire input before compressing]' \
        '(-k --keep)'{-k,--keep}'[keep input]' \
        '(-f --force)'{-f,--force}'[force overwrite]' \
        '(-q --quiet)'{-q,--quiet}'[quiet]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-1)-1[smaller block]' \
        '(-9)-9[best]' \
        '-2[lvl 2]' \
        '-3[lvl 3]' \
        '-4[lvl 4]' \
        '-5[lvl 5]' \
        '-6[lvl 6]' \
        '-7[lvl 7]' \
        '-8[lvl 8]' \
        '-p+[CPU count]:n:' \
        '-m+[memory MiB]:n:' \
        '-l[low CPU priority]' \
        '-S+[buffered file size]:n:' \
        '*:file:_files'
}

_pbzip2-bin "$@"
