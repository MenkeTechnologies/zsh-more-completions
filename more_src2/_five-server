#compdef five-server
# _five-server — modern development server (live-server replacement)
# upstream: https://github.com/nicedoc/five-server

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-p --port)'{-p,--port=}'[set the server port]:port:' \
    '(-H --host)'{-H,--host=}'[set the host address]:host:_hosts' \
    '--open=[open browser to path]:path:' \
    '--no-open[do not open browser]' \
    '--browser=[specify browser]:browser:' \
    '--watch=[files to watch]:glob pattern:' \
    '--ignore=[files to ignore]:glob pattern:' \
    '--wait=[delay before reload in ms]:milliseconds:' \
    '--mount=[set mount rules]:mount point:' \
    '--proxy=[proxy requests]:rule:' \
    '--cors[enable CORS]' \
    '--https=[HTTPS config file]:file:_files' \
    '--no-css-inject[disable CSS injection]' \
    '--no-highlight[disable syntax highlighting]' \
    '--log-level=[log level]:level:(0 1 2 3)' \
    '1:root directory:_directories' \
    && return 0
