#compdef lpadmin
# Documentation: https://manpages.debian.org/lpadmin
# Source: OpenPrinting/cups systemv/lpadmin.c — configure CUPS printers and classes (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[add printer to class]:class:_default' \
    '-d+[set default destination]:dest:_default' \
    '-h+[connect to CUPS server[:port]]:host:_hosts' \
    '-P+[use PPD file]:file:_files -g "*.ppd"' \
    '-i+[use PPD file (interface script)]:file:_files' \
    '-E[enable printer/use encryption]' \
    '-m+[use standard model/PPD/driver URI]:model:_default' \
    '*-o+[set option]:name=value:_default' \
    '-p+[add or modify printer]:printer:_default' \
    '-r+[remove printer from class]:class:_default' \
    '*-R+[remove option]:name:_default' \
    '-U+[username for remote authentication]:user:_users' \
    '*-u+[allow/deny users (allow:user,...)]:spec:_default' \
    '-v+[device URI]:uri:_default' \
    '-x+[delete printer or class]:dest:_default' \
    '-D+[printer-info text]:info:_default' \
    '-I+[supported file types (ignored)]:types:_default' \
    '-L+[printer-location text]:location:_default' \
    && ret=0

return ret
