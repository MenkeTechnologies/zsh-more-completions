#compdef metaflac
# Documentation: https://xiph.org/flac/documentation_tools_metaflac.html
# Reference accessed: 2026-05-19
# Verified: upstream `metaflac --help` from Xiph FLAC 1.5.0 distribution.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output-name)'{-o,--output-name=}'[write changes to new file]:file:_files' \
  '--preserve-modtime[preserve modification time]' \
  '--with-filename[prefix lines with FLAC filename]' \
  '--no-filename[do not prefix with filename]' \
  '--no-utf8-convert[do not convert tags to/from UTF-8]' \
  '--dont-use-padding[do not use existing padding]' \
  '--show-md5sum[show MD5 of unencoded audio]' \
  '--show-min-blocksize[show min block size]' \
  '--show-max-blocksize[show max block size]' \
  '--show-min-framesize[show min frame size]' \
  '--show-max-framesize[show max frame size]' \
  '--show-sample-rate[show sample rate]' \
  '--show-channels[show number of channels]' \
  '--show-bps[show bits per sample]' \
  '--show-total-samples[show total samples]' \
  '--show-vendor-tag[show Vorbis comment vendor string]' \
  '--show-tag=[show value of given tag]:tag name:' \
  '--show-all-tags[alias for --export-tags-to=-]' \
  '--remove-tag=[remove tags matching name]:tag name:' \
  '--remove-first-tag=[remove first tag matching name]:tag name:' \
  '--remove-all-tags[remove all Vorbis comment tags]' \
  '--remove-all-tags-except=[remove all tags except listed names]:names (= separated):' \
  '--set-tag=[set tag (NAME=VALUE)]:NAME=VALUE:' \
  '--set-tag-from-file=[set tag from file (NAME=FILE)]:NAME=FILE:' \
  '--import-tags-from=[import tags from file]:file:_files' \
  '--export-tags-to=[export tags to file]:file:_files' \
  '--import-cuesheet-from=[import cuesheet]:file:_files' \
  '--export-cuesheet-to=[export cuesheet]:file:_files' \
  '--no-cued-seekpoints[do not add seekpoints from cuesheet]' \
  '--import-picture-from=[import picture]:spec:' \
  '--export-picture-to=[export picture]:file:_files' \
  '--add-replay-gain[add ReplayGain analysis]' \
  '--scan-replay-gain[scan ReplayGain only]' \
  '--remove-replay-gain[remove ReplayGain tags]' \
  '--add-seekpoint=[add seekpoint(s) (#|X|#x|#s)]:spec:' \
  '--add-padding=[add padding bytes]:n:' \
  '--list[list metadata blocks]' \
  '--append[insert a metadata block from a file]' \
  '--remove[remove metadata blocks]' \
  '--remove-all[remove all blocks except STREAMINFO]' \
  '--merge-padding[merge adjacent PADDING blocks]' \
  '--sort-padding[move all PADDING blocks to end]' \
  '--block-number=[block numbers (comma separated)]:nums:' \
  '--block-type=[block types (comma separated)]:types:' \
  '--except-block-type=[block types to skip]:types:' \
  '--data-format=[output data format]:fmt:(binary binary-headerless text)' \
  '--application-data-format=[application block data format]:fmt:(hexdump text)' \
  '*:input:_files -g "*.(flac|oga|ogg)"'
