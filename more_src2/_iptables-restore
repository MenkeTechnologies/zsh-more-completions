#compdef iptables-restore ip6tables-restore
# Documentation: https://man.archlinux.org/man/iptables-restore.8.en
# Reference accessed: 2026-05-30
# iptables-restore / ip6tables-restore — restore iptables rules from a file. Multi-stem.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show option summary]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --counters)'{-c,--counters}'[restore packet + byte counter values]' \
  '(-n --noflush)'{-n,--noflush}'[preserve existing table contents (do not flush first)]' \
  '(-t --test)'{-t,--test}'[parse + construct but do not commit ruleset]' \
  '*'{-v,--verbose}'[verbose debugging (stackable)]' \
  '(-w --wait)'{-w,--wait=}'[wait for xtables lock (optional seconds)]:seconds:' \
  '(-M --modprobe)'{-M,--modprobe=}'[path to modprobe (default from kernel config)]:path:_files' \
  '(-T --table)'{-T,--table=}'[restore only this table from input]:table:(filter nat mangle raw security)' \
  '1:file (or stdin):_files' \
  && ret=0

return ret
