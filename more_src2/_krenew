#compdef krenew
# _krenew — Heimdal krenew (renew an existing Kerberos ticket cache; -K renew every N seconds, -L log via syslog, -i ignore errors, -p pidfile, -t track child exit, -b background once authenticated, -K daemon mode, -s/-S signal/SIGUSR1 once renewed)
# upstream: https://github.com/rra/kstart
# Flags from kstart krenew.c on tip.

_krenew() {
    _arguments \
        '-h[show help]' \
        '-v[verbose]' \
        '-H+[max errors before exit]:n:' \
        '-K+[renew every N minutes]:minutes:' \
        '-L[log via syslog]' \
        '-c+[ccache file]:file:_files' \
        '-k+[keytab file]:file:_files' \
        '-i[ignore renewal errors]' \
        '-p+[pid file]:file:_files' \
        '-q[quiet]' \
        '-t[track child exit]' \
        '-b[background after first renewal]' \
        '-s[signal child on renewal failure]' \
        '-S+[signal to send]:signal:(USR1 USR2 HUP TERM KILL)' \
        '-x[abort on error]' \
        '*::command:_command_names -e'
}

_krenew "$@"
