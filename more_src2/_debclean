#compdef debclean
# Documentation: https://manpages.debian.org/debclean
# Source: debian/devscripts scripts/debclean.sh — clean Debian build tree (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '(--nocleandebs --no-cleandebs)--cleandebs[also remove .deb/.changes/.build]' \
    '(--cleandebs)--nocleandebs[do not remove .deb files (default)]' \
    '(--cleandebs)--no-cleandebs[do not remove .deb files (default)]' \
    '--check-dirname-level=-[directory check level]:level:(0 1 2)' \
    '--check-dirname-regex=-[directory regex]:regex:_default' \
    '(--no-conf --noconf)'{--no-conf,--noconf}'[ignore conf files]' \
    && ret=0

return ret
