#compdef flowctl
# _flowctl — Estuary Flow flowctl CLI for managing real-time data pipelines and captures/materializations (estuary team, Rust); clap-derive
# upstream: https://github.com/estuary/flow

_flowctl() {
    local -a sub=(
        'auth:authentication subcommands'
        'catalog:catalog subcommands'
        'collections:collection subcommands'
        'draft:draft subcommands'
        'preview:preview a flow spec'
        'raw:raw API calls'
        'docs:open docs'
        'logs:tail logs'
        'history:run history'
        'check:check a flow spec'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--profile=+[profile]:str:' \
        '--output=+[format]:f:(table json yaml)' \
        '-o+[format]:f:(table json yaml)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--no-color[disable color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'flowctl subcommand' sub ;;
        args)
            case $words[1] in
                auth) _arguments '1:auth cmd:(login logout token roles)' ;;
                catalog) _arguments '1:catalog cmd:(list pull-specs publish delete history test)' ;;
                collections) _arguments '1:collections cmd:(list read-schema journals)' ;;
                draft) _arguments '1:draft cmd:(list select delete create author publish develop describe)' ;;
                preview) _arguments \
                    '--source=+[source]:file:_files -g "*.flow.yaml"' \
                    '--captures=+[name]:str:' \
                    '--materializations=+[name]:str:' \
                    '--collections=+[name]:str:' \
                    '--sessions=+[n]:n:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_flowctl "$@"
