#compdef nnrpd
# Documentation: man nnrpd(8)
# Source: InterNetNews/inn nnrpd/nnrpd.c — NNTP reader daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-4 -b)-4+[bind to IPv4 address]:addr:_default' \
    '(-4 -b)-b+[bind to IPv4 address (alias)]:addr:_default' \
    '-6+[bind to IPv6 address]:addr:_default' \
    '-B[enable blocklistd/blacklistd]' \
    '-c+[alternate readers.conf]:file:_files' \
    '-D[standalone daemon mode]' \
    '-P+[prespawn count in daemon mode]:N:_default' \
    '-f[do not fork in daemon mode]' \
    '-i+[initial command to push back]:cmd:_default' \
    '-I+[instance name]:name:_default' \
    '-n[no DNS lookups]' \
    '-o[offline posting only]' \
    '-p+[TCP port in daemon mode]:port:_default' \
    '-r+[reject connection message]:msg:_default' \
    '-s+[setproctitle placeholder]:title:_default' \
    '-S[force TLS negotiation]' \
    '-t[tracing]' \
    && ret=0

return ret
