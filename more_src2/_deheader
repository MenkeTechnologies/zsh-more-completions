#compdef deheader
# Documentation: https://gitlab.com/esr/deheader
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for deheader (esr/deheader): find/remove unneeded C/C++ includes

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-i --ignore)'{-i,--ignore}'=[ignore headers matching regexp]:regex' \
  '(-m --maker)'{-m,--maker}'=[build command (default: make %s)]:command' \
  '(-b --builddir)'{-b,--builddir}'=[build directory]:dir:_files -/' \
  '(-q --quiet)'{-q,--quiet}'[suppress statistical summary]' \
  '(-r --remove)'{-r,--remove}'[remove identified unneeded headers]' \
  '*'{-v,--verbose}'[verbose output (repeatable)]' \
  '(-x --exclude)'{-x,--exclude}'=[exclude files matching regexp]:regex' \
  '*:file:_files -g "*.(c|cc|cpp|cxx|C|h|hh|hpp|hxx|H)"' && ret=0

return ret
