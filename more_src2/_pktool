#compdef pktool
# _pktool — Solaris / Illumos pktool (PKCS#11 key store admin: subcommands setpin, list, import, export, gencert, gencsr, signcsr, delete, copy, genkey, gencert, tokens; -k token name, -T token vendor, -m mech, -l label, -o output file, -i input file, --version, --help)
# upstream: https://www.illumos.org/man/1/pktool
# Subcommands from Illumos usr/src/cmd/cmd-crypto/pktool/pktool.c on tip.

_pktool() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-h[show help]' \
        '-V[show version]' \
        '-k+[token]:token:' \
        '-T+[token vendor]:vendor:' \
        '-m+[mech]:mech:' \
        '-l+[label]:label:' \
        '-o+[output file]:file:_files' \
        '-i+[input file]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'pktool command' '(setpin list import export gencert gencsr signcsr delete copy genkey tokens inittoken)' ;;
        args) _arguments '*:arg:_files' ;;
    esac
}

_pktool "$@"
