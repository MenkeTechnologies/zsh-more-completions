#compdef gappletviewer
# Documentation: https://www.gnu.org/software/classpath/docs/cp-tools.html
# Reference accessed: 2026-05-16
# Verified: GNU Classpath implementation of Sun appletviewer(1). Only
# three documented options.
# Removed from prior file: fabricated -h/--help/-V/--version flags and
# bogus man.archlinux.org search URL.

# gappletviewer: GNU Classpath Java applet viewer
local curcontext="$curcontext" ret=1
_arguments -C \
  '-debug[start in Java debugger]' \
  '-encoding[input HTML file encoding]:encoding:' \
  '*-J[pass option to JVM]:option:' \
  '*:HTML file or URL:_files' && ret=0
return ret
