#compdef protoc-gen-doc
# Documentation: https://github.com/pseudomuto/protoc-gen-doc
# Reference accessed: 2026-05-20
# Verified: upstream pseudomuto/protoc-gen-doc README. The binary is
# a protoc plugin invoked via `protoc --doc_out=DIR --doc_opt=FMT,FILE`;
# it does not have its own CLI flags beyond a help banner.

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*::args:_default' && return 0
