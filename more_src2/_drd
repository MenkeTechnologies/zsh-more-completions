#compdef drd
# _drd — Valgrind DRD thread error detector (Bart Van Assche, C); pthread race + lock-order + barrier verification
# upstream: https://valgrind.org

_drd() {
    _arguments \
        '--check-stack-var+[check stack var]:bool:(yes no)' \
        '--exclusive-threshold+[exclusive threshold ms]:n:' \
        '--free-is-write+[free is write]:bool:(yes no)' \
        '--report-signal-unlocked+[report signal unlocked]:bool:(yes no)' \
        '--segment-merging+[segment merging]:bool:(yes no)' \
        '--segment-merging-interval+[segment merging interval]:n:' \
        '--shared-threshold+[shared threshold ms]:n:' \
        '--show-confl-seg+[show confl seg]:bool:(yes no)' \
        '--show-stack-usage+[show stack usage]:bool:(yes no)' \
        '--ignore-thread-creation+[ignore thread creation]:bool:(yes no)' \
        '--first-race-only+[first race only]:bool:(yes no)' \
        '--join-list-vol+[join list size]:n:' \
        '--trace-addr+[trace addr]:addr:' \
        '--trace-alloc+[trace alloc]:bool:(yes no)' \
        '--trace-barrier+[trace barrier]:bool:(yes no)' \
        '--trace-cond+[trace cond]:bool:(yes no)' \
        '--trace-fork-join+[trace fork/join]:bool:(yes no)' \
        '--trace-hb+[trace HB]:bool:(yes no)' \
        '--trace-mutex+[trace mutex]:bool:(yes no)' \
        '--trace-rwlock+[trace rwlock]:bool:(yes no)' \
        '--trace-semaphore+[trace semaphore]:bool:(yes no)' \
        '--var-info+[var info]:bool:(yes no)' \
        '*::command:_command_names -e'
}

_drd "$@"
