#compdef eboard
# Documentation: https://linux.die.net/man/6/eboard
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# eboard: graphical chess board interface for chess engines, ICS and PGN files
local curcontext="$curcontext" ret=1

_arguments -C \
  '-log[log network communications to ~/LOG.eboard]' \
  '-debug[write debug info to ~/DEBUG.eboard]' \
  '-dgtport=[device for connected DGT board]:device:_files -g "/dev/*"' \
  '*:PGN file:_files -g "*.pgn"' && ret=0

return ret
