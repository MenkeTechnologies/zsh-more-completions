#compdef gardener-scheduler
# _gardener-scheduler — Gardener shoot scheduler (binds Shoots to Seeds)
# upstream: https://github.com/gardener/gardener
# Flags from cmd/gardener-scheduler/app/options.go on tip.

_gardener-scheduler() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[scheduler config file]:file:_files -g "*.(yaml|yml)"' \
        '--feature-gates=[feature gates (k=v csv)]:csv:' \
        '-v[klog verbosity level]:n:' \
        '--kubeconfig=[kubeconfig file]:file:_files'
}

_gardener-scheduler "$@"
