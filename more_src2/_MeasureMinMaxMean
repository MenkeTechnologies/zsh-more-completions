#compdef MeasureMinMaxMean
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/MeasureMinMaxMean.cxx — report min/max/mean of an image (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:image.nii:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3::log.txt (optional):_files' \
    '4::take-absolute-value (default 0):(0 1)' \
    '5::mask-name:_files -g "*.{nii,nii.gz}"' \
    && ret=0

return ret
