#compdef deskflow-core
# _deskflow-core — combined server/client KVM-over-network (deskflow/deskflow)
# upstream: https://github.com/deskflow/deskflow
# Flags from src/apps/deskflow-core/CoreArgParser.cpp + CoreArgs.h (QCommandLineParser).

_deskflow-core() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-v,--version}'[show version]'
        '--new-instance[skip the running-instance check, always start a new instance]'
        '(-s --settings)'{-s+,--settings=}'[override settings file]:file:_files'
        '1:mode:(server client)'
    )
    _arguments $args
}

_deskflow-core "$@"
