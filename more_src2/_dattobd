#compdef dattobd dbdctl
# _dattobd — Datto Inc dattobd dbdctl CLI for the kernel-module-based block-level live-volume snapshot tool managing block-device snapshots backed by copy-on-write tracking changes for incremental backup integration (datto team, C); getopt
# upstream: https://github.com/datto/dattobd

_dattobd() {
    local -a sub=(
        'setup-snapshot:setup snapshot tracker'
        'reload-snapshot:reload snapshot'
        'reload-incremental:reload as incremental'
        'transition-to-incremental:transition to incremental'
        'transition-to-snapshot:transition to snapshot'
        'destroy:destroy tracker'
        'info:show tracker info'
        'expand-cow-file:expand cow file'
        'reconfigure:reconfigure tracker'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[cache size MB]:n:' \
        '--cache=+[cache size MB]:n:' \
        '-b+[block size bytes]:n:' \
        '--block-size=+[block size bytes]:n:' \
        '-i[ignore errors]' \
        '--ignore-errors[ignore errors]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'dattobd subcommand' sub ;;
        args)
            case $words[1] in
                setup-snapshot) _arguments \
                    '*:source-device cow-file minor:_files' ;;
                reload-snapshot|reload-incremental) _arguments \
                    '*:source-device cow-file minor:_files' ;;
                destroy|info|transition-to-incremental|transition-to-snapshot|reconfigure) _arguments \
                    '*:minor:' ;;
                expand-cow-file) _arguments \
                    '*:minor size-in-MiB:' ;;
            esac
            ;;
    esac
}

_dattobd "$@"
