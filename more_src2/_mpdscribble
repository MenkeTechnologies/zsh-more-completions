#compdef mpdscribble
# Documentation: https://man.archlinux.org/man/extra/mpdscribble/mpdscribble.1.en
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. MPD client that submits
# played tracks to scrobbler services (Last.fm, Libre.fm, ListenBrainz).

# Zsh completion for mpdscribble

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--no-daemon[do not daemonize, run in foreground]' \
  '--pidfile=[write process id to file]:file:_files' \
  '--conf=[configuration file]:file:_files' \
  '--log=[log file (syslog, -, or path)]:file:_files' \
  '--verbose=[log verbosity level]:level:(0 1 2 3)' && ret=0

return ret
