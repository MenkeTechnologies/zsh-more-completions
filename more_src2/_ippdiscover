#compdef ippdiscover ippfind
# Documentation: https://manpages.debian.org/bookworm/cups-ipp-utils/ippfind.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ippfind(1) manpage. NOTE: `ippdiscover` is
# not a separate binary in cups-ipp-utils on Debian/Ubuntu; the
# discovery tool is `ippfind`. This completion targets ippfind and
# accepts the legacy ippdiscover name via #compdef alias.
# Removed from prior file: fabricated -h/-V flags and bogus
# man.archlinux.org search URL.

# ippdiscover/ippfind: find IPP printers via mDNS/DNS-SD
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-4[IPv4 only]' \
  '-6[IPv6 only]' \
  '-T[connection timeout seconds]:seconds:' \
  '-V[IPP version]:version:(1.1 2.0 2.1 2.2)' \
  '(-d --domain)'{-d+,--domain=}'[match service domain]:regex:' \
  '(-h --host)'{-h+,--host=}'[match host name]:regex:' \
  '(-n --name)'{-n+,--name=}'[match service instance name (regex)]:regex:' \
  '(-N --literal-name)'{-N+,--literal-name=}'[match literal name]:name:' \
  '(-P --port)'{-P+,--port=}'[match port]:port:' \
  '(-u --uri)'{-u+,--uri=}'[match URI]:regex:' \
  '(-t --txt)'{-t+,--txt=}'[match TXT key existence]:key:' \
  '--txt-key=[match TXT key=regex]:regex:' \
  '--path=[match request path]:path:' \
  '(-x --exec)'{-x+,--exec=}'[execute command on match]:cmd:_command_names' \
  '(-p --print)'{-p,--print}'[print URI of matched services]' \
  '(-s --print-name)'{-s,--print-name}'[print service instance name]' \
  '(-l --ls)'{-l,--ls}'[list as ipptool would]' \
  '(-q --quiet)'{-q,--quiet}'[no output (use exit code)]' \
  '--local[only local services]' \
  '--remote[only remote services]' \
  '*:service type:' && ret=0
return ret
