#compdef react-scripts
# _react-scripts — Create React App's underlying script runner (facebook/create-react-app)
# upstream: https://github.com/facebook/create-react-app
# Subcommands from packages/react-scripts/scripts/.

_react-scripts() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'start:start the development server'
                'build:build for production'
                'test:run the test runner'
                'eject:eject the configuration'
                'init:initialize project state'
            )
            _describe -t commands command cmds
            ;;
    esac
}

_react-scripts "$@"
