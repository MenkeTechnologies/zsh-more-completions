#compdef pylint
# Documentation: pylint --help and pylint user_guide
# Source: pylint — static analysis for Python code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help and exit]' \
    '(- *)--long-help[show long help]' \
    '(- *)--version[show version]' \
    '--rcfile=[specify configuration file]:file:_files -g "*.{toml,cfg,ini,rc}"' \
    '--init-hook=[Python code to execute at startup]:code:' \
    '(-E --errors-only)'{-E,--errors-only}'[only check for errors]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '--exit-zero[always exit 0]' \
    '--py-version=[target Python version]:version:' \
    '--enable-all-extensions[enable every extension]' \
    '*--ignore=[skip files / dirs (comma-separated)]:patterns:' \
    '*--ignore-paths=[regex paths to skip]:patterns:' \
    '*--ignore-patterns=[regex filenames to skip]:patterns:' \
    '--persistent=[persist results between runs]:y_or_n:(y n)' \
    '*--load-plugins=[checkers to load]:plugins:' \
    '(-j --jobs)'{-j,--jobs=}'[parallel processes (0 = auto)]:n:' \
    '--limit-inference-results=[max inference results]:n:' \
    '--extension-pkg-allow-list=[C extensions allowed to load]:pkgs:' \
    '--suggestion-mode=[show suggestions]:y_or_n:(y n)' \
    '*-d+[disable message]:msg:' \
    '*--disable=[disable messages (comma-separated)]:msgs:' \
    '*-e+[enable message]:msg:' \
    '*--enable=[enable messages (comma-separated)]:msgs:' \
    '--confidence=[only show messages of confidence level]:level:(HIGH CONTROL_FLOW INFERENCE INFERENCE_FAILURE UNDEFINED)' \
    '--msg-template=[message format template]:template:' \
    '(-f --output-format)'{-f,--output-format=}'[reports format]:format:(text parseable colorized json json2 msvs github)' \
    '--output=[write report to file]:file:_files' \
    '(-r --reports)'{-r,--reports=}'[generate full report]:y_or_n:(y n)' \
    '(-s --score)'{-s,--score=}'[show evaluation score]:y_or_n:(y n)' \
    '--fail-under=[fail if score below value]:score:' \
    '--fail-on=[fail if any of these messages emitted]:msgs:' \
    '--recursive=[discover modules recursively]:y_or_n:(y n)' \
    '--from-stdin[parse from stdin]' \
    '--max-line-length=[max characters per line]:n:' \
    '--max-module-lines=[max module length]:n:' \
    '--indent-string=[indentation string]:str:' \
    '--good-names=[always good names list]:names:' \
    '--bad-names=[always bad names list]:names:' \
    '--max-args=[max function args]:n:' \
    '--max-locals=[max local variables]:n:' \
    '--max-returns=[max return statements]:n:' \
    '--max-branches=[max branches]:n:' \
    '--max-statements=[max statements]:n:' \
    '--max-public-methods=[max public methods]:n:' \
    '--generate-rcfile[generate sample configuration]' \
    '--generate-toml-config[generate sample pyproject TOML config]' \
    '*:module or package:_files -g "*.py"' \
    && ret=0

return ret
