#compdef i3cget
# _i3cget — i3c-tools i3cget CLI reader performing private-read SDR/HDR-DDR reads on an I3C device on a Linux /dev/i3c-* character device with byte word block size modes printing GETMRL GETMWL GETPID GETCAPS GETSTATUS CCC response payload for inspection (Boris Brezillon team, C); getopt
# upstream: https://github.com/i3c-tools/i3c-tools

_i3cget() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-y[non-interactive]' \
        '-v[verbose]' \
        '-m+[mode]:m:(b w l s i I3C_PRIV_XFER GETPID GETMRL GETMWL GETCAPS GETSTATUS)' \
        '-r[raw]' \
        '-f[force]' \
        '1:i3c-bus:_files -g "/dev/i3c-*"' \
        '2:address:' \
        '3:data-address:'
}

_i3cget "$@"
