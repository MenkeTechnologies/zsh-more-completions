#compdef esl-compstruct
# Documentation: https://github.com/EddyRivasLab/easel/blob/master/miniapps/esl-compstruct.man.in
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Easel esl-compstruct: compare two RNA secondary-structure alignments
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show brief help]' \
  '-m[Mathews relaxed accuracy rule (pairs within one position)]' \
  '-p[include pseudoknotted base pairs]' \
  '--quiet[suppress header/version output]' \
  '*:two alignment files:_files' && ret=0
return ret
