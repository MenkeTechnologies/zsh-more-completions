#compdef gather-mdbook-anchors
# _gather-mdbook-anchors — print all header-link anchors from an mdbook (ankitects/gather-mdbook-anchors)
# upstream: https://github.com/ankitects/gather-mdbook-anchors
# Usage from src/main.rs.

_gather-mdbook-anchors() {
    _arguments \
        '1:book root dir:_files -/'
}

_gather-mdbook-anchors "$@"
