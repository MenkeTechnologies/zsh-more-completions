#compdef R-CMD-Sweave R-CMD-Stangle
# _R-CMD-Sweave — R Core Team R CMD Sweave and Stangle Sweave noweb literate programming document processing (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Sweave() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--encoding=+[encoding]:str:' \
        '--engine=+[engine]:e:(latex html Knitr utf8)' \
        '--driver=+[driver]:d:(R LaTeX HTML pdf knitr)' \
        '--no-init-file[no init file]' \
        '--clean=+[bool]:b:(yes no)' \
        '--pdf[generate PDF]' \
        '--no-pdf[no PDF]' \
        '--quiet[quiet]' \
        '--syntax=+[syntax]:s:(SweaveSyntaxLatex SweaveSyntaxNoweb)' \
        '--keep-source[keep source]' \
        '--keep-output[keep output]' \
        '--default-encoding=+[encoding]:str:' \
        '*:Sweave file:_files -g "*.Rnw *.snw *.Stex *.Snw *.Rtex *.Rrst *.rst *.tex *.html"'
}

_R-CMD-Sweave "$@"
