#compdef fakeexecutor armada-fakeexecutor
# _fakeexecutor — Armada fake executor for integration testing (mimics a per-cluster executor without driving real Pods)
# upstream: https://github.com/armadaproject/armada
# Flags from cmd/fakeexecutor/main.go on tip; everything else lives in the YAML config (./config/fakeexecutor or --config).

_fakeexecutor() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '*--config=[application configuration file (repeatable; comma-separated paths also accepted)]:file:_files -g "*.yaml"'
}

_fakeexecutor "$@"
