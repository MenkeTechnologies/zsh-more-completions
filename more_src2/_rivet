#compdef rivet
# Documentation: https://github.com/Ironclad/rivet
# Reference accessed: 2026-05-22
# Verified: @ironclad/rivet-cli --help.

# Zsh completion for rivet - Rivet graph runner and REST server CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'rivet command' \
      'run[run graph in project file]' \
      'serve[serve project file as REST API]' && ret=0
    ;;
  args)
    case $line[1] in
      run)
        _arguments \
          '--inputs-stdin[read inputs from stdin as JSON]' \
          '--include-cost[include total cost in output]' \
          '--context[add context value to graph run]:value:' \
          '--input[add input to graph run]:input:' \
          '1:project file:_files' \
          '2:graph name:' && ret=0
        ;;
      serve)
        _arguments '1:project file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
