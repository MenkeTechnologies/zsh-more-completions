#compdef ngircd
# Documentation: https://manpages.debian.org/bookworm/ngircd/ngircd.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream Debian ngircd(8) manpage at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-f --config)'{-f,--config}'+[config file]:file:_files' \
  '(-n --nodaemon)'{-n,--nodaemon}'[do not daemonize, run in foreground]' \
  '(-p --passive)'{-p,--passive}'[passive mode, no autoconnect]' \
  '(-s --sniffer)'{-s,--sniffer}'[enable IRC protocol sniffer]' \
  '(-d --debug)'{-d,--debug}'[debug mode]' \
  '(-t --configtest)'{-t,--configtest}'[test config and exit]' && ret=0

return ret
