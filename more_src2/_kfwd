#compdef kfwd
# Documentation: https://github.com/invisible1988/kfwd
# Reference accessed: 2026-05-19
# Verified: against the upstream README (invisible1988/kfwd, a
# Kubernetes port-forward manager). Corrected from prior file: removed
# the fabricated `forward` subcommand group (bookmark verbs add/list/
# start/stop/remove are top-level), the invented cluster show/use,
# daemon restart/logs, version/help commands, and unverified
# --socket/--config/-v global flags. `setup` is the cluster wizard.

local curcontext="$curcontext" state line ret=1
local -a commands cluster_cmds daemon_cmds

commands=(
  'run:run an ad-hoc port-forward'
  'setup:interactive wizard to register a cluster from kubeconfig'
  'cluster:manage Kubernetes clusters'
  'add:add a new saved forward bookmark'
  'list:list saved forward bookmarks'
  'start:start a saved forward by id'
  'stop:stop a running forward by id'
  'remove:remove a saved forward by id'
  'status:show daemon status and active forwards'
  'daemon:manage the kfwd background daemon'
  'export:export clusters and forwards as JSON'
  'import:import clusters and forwards from JSON'
  'completion:generate shell completion'
)

cluster_cmds=(
  'add:register a cluster definition'
  'list:list registered clusters'
  'remove:remove a cluster by id'
)

daemon_cmds=(
  'start:start the kfwd daemon'
  'stop:stop the kfwd daemon'
  'status:show daemon status'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t cmds 'kfwd command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (cluster)
        _arguments -C \
          '1: :->ccmd' \
          '*::carg:->cargs' && ret=0
        case $state in
          (ccmd) _describe -t ccmds 'cluster command' cluster_cmds && ret=0 ;;
          (cargs)
            case $line[1] in
              (add)
                _arguments \
                  '--kubeconfig=[kubeconfig path]:file:_files' \
                  '--context=[kube context]:context:' && ret=0 ;;
              (remove)
                _arguments '*::id:' && ret=0 ;;
            esac ;;
        esac ;;
      (daemon)
        _arguments -C \
          '1: :->dcmd' && ret=0
        case $state in
          (dcmd) _describe -t dcmds 'daemon command' daemon_cmds && ret=0 ;;
        esac ;;
      (run)
        _arguments \
          '(-n --namespace)'{-n+,--namespace=}'[namespace]:namespace:' \
          '(-c --cluster)'{-c+,--cluster=}'[cluster id or name]:cluster:' \
          '*::resource:' && ret=0 ;;
      (start|stop|remove)
        _arguments '*::id:' && ret=0 ;;
      (completion)
        _arguments '*::shell:(bash zsh fish powershell)' && ret=0 ;;
    esac ;;
esac

return ret
