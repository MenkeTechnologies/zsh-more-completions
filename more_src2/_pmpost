#compdef pmpost upmpost
# Documentation: pmpost --help (pMetaPost 3.00-0.04 TeX Live 2026)
# Source: Japanese-aware pMetaPost (and upMetaPost variant) — MetaPost with kanji support; also dvitomp mode.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-credits[print credits and exit]' \
    '-debug[print debugging info and leave temp files]' \
    '-dvitomp[act as DVI-to-MPX converter only]' \
    '-file-line-error[print error in file:line:error style]' \
    '-no-file-line-error[disable file:line:error style]' \
    '-halt-on-error[stop processing at the first error]' \
    '-ini[be inimpost, for dumping mems]' \
    '-interaction=[interaction mode]:mode:(batchmode nonstopmode scrollmode errorstopmode)' \
    '-jobname=[set job name]:name:' \
    '-kpathsea-debug=[set path searching debug bits]:number:' \
    '-mem=[name of preloaded macro file (&MPNAME equivalent)]:mem:' \
    '-mktex=[enable mktexFMT generation]:fmt:(mp mf tex tfm fmt)' \
    '-no-mktex=[disable mktexFMT generation]:fmt:(mp mf tex tfm fmt)' \
    '-numbersystem=[number system mode]:mode:(scaled double binary interval decimal)' \
    '-output-directory=[directory to write files in]:dir:_files -/' \
    '-progname=[set program name]:name:' \
    '-recorder[enable filename recorder]' \
    '-restricted[be secure: disable tex/troff/etc]' \
    '-s-[STRING=NUMBER or STRING=STRING insert into pool]:assignment:' \
    '-tex=[use TEX as TeX text typesetting program]:program:_command_names -e' \
    '-translate-file=[character translation file]:file:_files' \
    '-troff[set prologues:=1 and assume mpost is used as troff preprocessor]' \
    '-T[same as -troff]' \
    '*:mp file or commands:_files -g "*.mp"' \
    && ret=0

return ret
