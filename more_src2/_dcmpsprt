#compdef dcmpsprt
# Documentation: https://support.dcmtk.org/docs-snapshot/dcmpsprt.html
# Documentation: https://github.com/DCMTK/dcmtk/blob/master/dcmpstat/apps/dcmpsprt.cc
# Reference accessed: 2026-05-27
# Verified: upstream DCMTK dcmpstat/apps/dcmpsprt.cc OFCommandLine setup + dcmpstat/docs/dcmpsprt.man.

local -a _log_levels
_log_levels=(fatal error warn info debug trace)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[print help text and exit]' \
  '--version[print version information and exit]' \
  '--arguments[print expanded command line arguments]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode, print no warnings and errors]' \
  '(-v --verbose)'{-v,--verbose}'[verbose mode, print processing details]' \
  '(-d --debug)'{-d,--debug}'[debug mode, print debug information]' \
  '(-ll --log-level)'{-ll+,--log-level=}'[set logger level]:level:('"${_log_levels[*]}"')' \
  '(-lc --log-config)'{-lc+,--log-config=}'[use logger config file]:file:_files' \
  '(+p --pstate)'{+p+,--pstate=}'[render image with presentation state file]:file:_files' \
  '(-c --config)'{-c+,--config=}'[process using configuration file]:file:_files' \
  '(-p --printer)'{-p+,--printer=}'[select printer with identifier from config file]:name:' \
  '(-s --spool --nospool)'{-s,--spool}'[spool print job to DICOM printer]' \
  '(-s --spool --nospool)--nospool[do not spool print job to DICOM printer (default)]' \
  '(--portrait --landscape --default-orientation)--portrait[set portrait orientation]' \
  '(--portrait --landscape --default-orientation)--landscape[set landscape orientation]' \
  '(--portrait --landscape --default-orientation)--default-orientation[use printer default orientation (default)]' \
  '(--trim --no-trim --default-trim)--trim[set trim on]' \
  '(--trim --no-trim --default-trim)--no-trim[set trim off]' \
  '(--trim --no-trim --default-trim)--default-trim[use printer default trim (default)]' \
  '(--request-decimate --request-crop --request-fail --default-request)--request-decimate[request decimate]' \
  '(--request-decimate --request-crop --request-fail --default-request)--request-crop[request crop]' \
  '(--request-decimate --request-crop --request-fail --default-request)--request-fail[request failure]' \
  '(--request-decimate --request-crop --request-fail --default-request)--default-request[use printer default decimate/crop behavior (default)]' \
  '(--default-plut --identity --lin-od --plut)--default-plut[do not create presentation LUT (default)]' \
  '(--default-plut --identity --lin-od --plut)--identity[set IDENTITY presentation LUT shape]' \
  '(--default-plut --identity --lin-od --plut)--lin-od[set LIN OD presentation LUT shape]' \
  '(--default-plut --identity --lin-od --plut)--plut=[add LUT to print job]:lut identifier:' \
  '--inverse-plut[render inverse presentation LUT into bitmap]' \
  '--illumination=[set illumination in cd/m^2 (0..65535)]:value:' \
  '--reflection=[set reflected ambient light in cd/m^2 (0..65535)]:value:' \
  '--copies=[set number of copies (1..100)]:value:' \
  '--medium-type=[set medium type]:value:' \
  '--destination=[set film destination]:value:' \
  '--label=[set film session label]:value:' \
  '--priority=[set print priority]:value:' \
  '--owner=[set film session owner ID]:value:' \
  '(--no-annotation -a --annotation)--no-annotation[do not create annotation (default)]' \
  '(--no-annotation -a --annotation)'{-a+,--annotation=}'[create annotation with text]:text:' \
  '(+pd --print-date -pd --print-no-date)'{+pd,--print-date}'[prepend date/time to annotation (default)]' \
  '(+pd --print-date -pd --print-no-date)'{-pd,--print-no-date}'[do not prepend date/time to annotation]' \
  '(+pn --print-name -pn --print-no-name)'{+pn,--print-name}'[prepend printer name to annotation (default)]' \
  '(+pn --print-name -pn --print-no-name)'{-pn,--print-no-name}'[do not prepend printer name to annotation]' \
  '(+pl --print-lighting -pl --print-no-lighting)'{+pl,--print-lighting}'[prepend illumination to annotation (default)]' \
  '(+pl --print-lighting -pl --print-no-lighting)'{-pl,--print-no-lighting}'[do not prepend illumination to annotation]' \
  '*'{+O+,--overlay=}'[load overlay data from PBM file and display at position]:filename:_files:x: :y:' \
  '(+Og --ovl-graylevel)'{+Og+,--ovl-graylevel=}'[overlay gray level (0..4095, default: 4095=white)]:value:' \
  '(-l --layout)'{-l+,--layout=}'[use STANDARD\c,r image display format]:columns: :rows:' \
  '--filmsize=[set film size ID]:value:' \
  '--magnification=[set magnification type]:value:' \
  '--smoothing=[set smoothing type]:value:' \
  '--configinfo=[set configuration information]:value:' \
  '--resolution=[set requested resolution ID]:value:' \
  '--border=[set border density]:value:' \
  '--empty-image=[set empty image density]:value:' \
  '--max-density=[set maximum density]:value:' \
  '--min-density=[set minimum density]:value:' \
  '--img-polarity=[set image box polarity (NORMAL or REVERSE)]:value:(NORMAL REVERSE)' \
  '--img-request-size=[set requested image size (width in mm)]:value:' \
  '--img-magnification=[set image box magnification type]:value:' \
  '--img-smoothing=[set image box smoothing type]:value:' \
  '--img-configinfo=[set image box configuration information]:value:' \
  '*:dcmfile-in:_files'
