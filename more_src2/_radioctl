#compdef radioctl
# Documentation: man radioctl(1)
# Source: netbsd/src usr.bin/radioctl — radio tuner control (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[radio tuner device (default /dev/radio)]:file:_files' \
    '-n[suppress variable name printing]' \
    '(- *)-a[print all variables and values]' \
    '-w+[set variable (name=value, +/- relative)]:name=value:_default' \
    '1::variable:_default' \
    && ret=0

return ret
