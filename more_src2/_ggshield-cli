#compdef ggshield-cli ggshield
# _ggshield-cli — GitGuardian ggshield-cli CLI command-line frontend wrapping the GitGuardian Shield CLI for secret detection IaC misconfiguration secret-scanning honeytoken-injection SCA-software-composition-analysis Vulnerability-detection-pre-commit-pre-push-pre-receive hook secret-scan iac-scan sca-scan honeytoken pre-commit pre-push pre-receive ci-cd-mode pre-receive-mode dashboard-API matching strategy false-positives integrations-Slack-Jira-Splunk policy-violation custom-detector (GitGuardian team, Python); click
# upstream: https://github.com/GitGuardian/ggshield

_ggshield-cli() {
    local -a sub=(
        'auth:auth operations'
        'secret:secret scan operations'
        'iac:IaC scan operations'
        'sca:SCA scan operations'
        'honeytoken:honeytoken operations'
        'install:install hooks'
        'config:config operations'
        'api-status:show API status'
        'quota:show quota'
        'status:status'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g ".gitguardian.yml *.yml *.yaml"' \
        '--config-path=+[file]:file:_files -g ".gitguardian.yml *.yml *.yaml"' \
        '--debug[debug]' \
        '--allow-self-signed[allow self-signed]' \
        '--check-for-updates[check for updates]' \
        '--no-check-for-updates[skip update check]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ggshield subcommand' sub ;;
        args)
            case $words[1] in
                secret) _arguments '1:op:(scan path repo commit-range pre-commit pre-push pre-receive ci docker pypi archive)' '*:arg:' ;;
                iac) _arguments '1:op:(scan all diff ci)' '*:arg:' ;;
                sca) _arguments '1:op:(scan all diff ci)' '*:arg:' ;;
                honeytoken) _arguments '1:op:(create list inject)' '*:arg:' ;;
                auth) _arguments '1:op:(login logout)' '*:arg:' ;;
                install) _arguments '1:op:(pre-commit pre-push)' '*:arg:' ;;
                config) _arguments '1:op:(get set list unset migrate)' '*:arg:' ;;
            esac
            ;;
    esac
}

_ggshield-cli "$@"
