#compdef labwc-tweaks
# Documentation: https://github.com/labwc/labwc-tweaks
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# labwc-tweaks: GUI to tweak labwc Wayland compositor settings
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '(- *)-v[show version]' \
  '(- *)--version[show version]' \
  '*::labwc-tweaks args:_files' && ret=0
return ret
