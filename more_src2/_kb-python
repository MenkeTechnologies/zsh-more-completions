#compdef kb kb-python
# _kb-python — Pachter Lab kb-python CLI wrapper around kallisto bustools providing standardized single-cell RNA-seq scRNA-seq processing pipeline from FASTQ inputs through pseudo-alignment to transcripts producing AnnData h5ad MTX BUS matrix loom outputs compatible with scanpy seurat (Pachter Lab team, Python); argparse
# upstream: https://github.com/pachterlab/kb_python

_kb-python() {
    local -a sub=(
        'ref:download or build a reference index'
        'count:count transcripts from FASTQ'
        'extract:extract pseudo-aligned reads'
        'info:show version info'
        'compile:compile kallisto/bustools binaries'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--keep-tmp[keep temp files]' \
        '--tmp=+[dir]:dir:_files -/' \
        '-i+[index file]:file:_files -g "*.idx"' \
        '-g+[t2g file]:file:_files -g "*.txt"' \
        '-x+[technology]:t:(10XV1 10XV2 10XV3 BDWTA CELSEQ CELSEQ2 DROPSEQ INDROPSV1 INDROPSV2 INDROPSV3 SCRUBSEQ SURECELL SMARTSEQ2 SMARTSEQ3)' \
        '-w+[whitelist]:file:_files' \
        '-o+[output dir]:dir:_files -/' \
        '-t+[threads]:n:' \
        '-m+[memory GB]:n:' \
        '--workflow=+[w]:w:(standard lamanno kite nac)' \
        '--filter=+[f]:f:(bustools)' \
        '--h5ad[output h5ad]' \
        '--loom[output loom]' \
        '--mtx[output mtx]' \
        '--report[generate report]' \
        '--gene-names[use gene names]' \
        '--strand=+[s]:s:(forward reverse unstranded)' \
        '--inleaved[interleaved fastqs]' \
        '--genomic-fasta=+[file]:file:_files -g "*.fa *.fasta *.gz"' \
        '--gtf=+[file]:file:_files -g "*.gtf *.gz"' \
        '--include-attribute=+[k:v]:str:' \
        '--exclude-attribute=+[k:v]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kb-python subcommand' sub ;;
        args)
            case $words[1] in
                ref) _arguments \
                    '-d+[workflow]:w:(human mouse linnarsson)' \
                    '--workflow=+[w]:w:(standard lamanno kite nac)' \
                    '*:fasta and gtf:_files' ;;
                count) _arguments \
                    '*:fastq files:_files -g "*.fq *.fastq *.gz"' ;;
            esac
            ;;
    esac
}

_kb-python "$@"
