#compdef gmtset
# Documentation: https://docs.generic-mapping-tools.org/latest/gmtset.html
# Source: GenericMappingTools/gmt classic-mode gmtset — adjust GMT defaults (gmt.conf parameters).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-C[convert .gmtdefaults4 → gmt.conf]' \
    '-D+[system defaults (s=SI / u=US units)]:units:(s u)' \
    '-G+[gmt.conf file to read+modify]:file:_files' \
    '-B+[shorthand B value]:value:_default' \
    '-J+[shorthand J value]:value:_default' \
    '-R+[shorthand R value]:value:_default' \
    '-X+[shorthand X value]:value:_default' \
    '-Y+[shorthand Y value]:value:_default' \
    '-p+[shorthand perspective]:value:_default' \
    '(- *)-\?[show help]' \
    '*:PARAMETER=value:_default' \
    && ret=0

return ret
