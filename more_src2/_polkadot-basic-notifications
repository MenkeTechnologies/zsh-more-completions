# _polkadot-basic-notifications — zsh completion for kianenigma's Polkadot
#                                  multi-transport notification daemon
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/kianenigma/polkadot-basic-notification
#   Author     : Kian Paimani (kianenigma) — Polkadot Fellowship contributor
#   License    : Apache-2.0
#   Stars      : 49
#   Language   : TypeScript
#   npm        : polkadot-basic-notifications v1.0.3
#   Binary     : polkadot-basic-notifications  (package.json bin field)
#   Last push  : 2025-03-27
#
# WHAT IT IS
#   polkadot-basic-notifications is "a basic, account-based, multi-transport
#   notification service for the Polkadot ecosystem".  It subscribes to one
#   or more Substrate-based blockchain RPC endpoints via the @polkadot/api
#   client, filters extrinsics and events by configured account addresses
#   and pallet.method selectors, then dispatches reports through any
#   combination of five reporters loaded from a YAML/JSON config file:
#     - matrix    — post to a Matrix room via matrix-js-sdk
#     - email     — SMTP via nodemailer (optional openpgp encryption)
#     - telegram  — telegraf bot
#     - fs        — JSON lines to a filesystem path
#     - console   — stdout / winston logger
#   Each reporter may optionally be batched (`batch.interval`, `batch.misc`,
#   `batch.leftovers`).  When the matrix reporter is configured, its
#   `userId` and `accessToken` can be overridden at startup by the
#   MATRIX_USERID and MATRIX_ACCESSTOKEN environment variables.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/config.ts yargs(.option) builder)
#   polkadot-basic-notifications -c <CONFIG>
#
#   Options:
#     -c <PATH>            Path to a JSON/YAML file with the AppConfig.
#                          May also be set via the DOT_NOTIF_CONF env var.
#     -h, --help           yargs auto: show help and exit
#     --version            yargs auto: show version and exit
#
#   Environment:
#     DOT_NOTIF_CONF       fallback for -c
#     MATRIX_USERID        override config.reporters.matrix.userId
#     MATRIX_ACCESSTOKEN   override config.reporters.matrix.accessToken
#
# AXIS / CORPUS POSITION
#   Direct dependency on `matrix-js-sdk ^37.1.0` declared in package.json
#   `"dependencies"` block — the canonical TypeScript/JavaScript Matrix
#   client SDK maintained by the matrix-org organization (the same SDK
#   that powers Element Web).  Used in src/reporters/ via `MatrixReporter`
#   which authenticates with the homeserver in `MatrixConfig.server` using
#   `MatrixConfig.userId` / `MatrixConfig.accessToken` and posts notifications
#   into `MatrixConfig.roomId`.  Verified via:
#     gh api repos/kianenigma/polkadot-basic-notification/contents/package.json
#       → "matrix-js-sdk": "^37.1.0"
#   This entry is the TS-Node=113 leader bump that CLOSES Axis 58
#   (Matrix Federated Chat Protocol Library) at 1/1/1 three-language symmetry:
#     Rust   = matrix-sdk 0.16          (R821, `chaz`,  arcuru)
#     Go     = maunium.net/go/mautrix   (R822, `bbctl`, beeper)
#     TS-Node = matrix-js-sdk 37.1.0    (R823, `polkadot-basic-notifications`,
#                                              kianenigma)
#   Reaches the triple-113 landmark Rust=Go=TS-Node=113.
#
#   No completion for `polkadot-basic-notifications` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_polkadot-basic-notifications() {
    _arguments -s \
        '-c+[path to JSON/YAML AppConfig file (env DOT_NOTIF_CONF)]:config file:_files -g "*.(json|yaml|yml)"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]'
}

_polkadot-basic-notifications "$@"
