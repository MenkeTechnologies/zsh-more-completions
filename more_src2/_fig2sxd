#compdef fig2sxd
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/fig2sxd.1.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# fig2sxd: convert xfig figures to OpenOffice Draw (sxd) format
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '--help[show help]' \
  '-o[output file]:file:_files -g "*.sxd"' \
  '*:xfig file:_files -g "*.fig"' && ret=0
return ret
