#compdef gobackup
# Documentation: https://github.com/gobackup/gobackup
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

# Zsh completion for gobackup backup tool

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'perform:execute a backup immediately'
  'start:launch as a daemon with Web UI and scheduler'
  'run:run gobackup without daemon mode'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.{yml,yaml}"' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'gobackup command' commands && ret=0 ;;
esac

return ret
