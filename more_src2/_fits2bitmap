#compdef fits2bitmap
# Documentation: https://docs.astropy.org/en/stable/visualization/scripts.html#fits2bitmap
# Source: astropy/astropy astropy/visualization/scripts/fits2bitmap.py — convert FITS to bitmap image (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-e --ext)'{-e+,--ext=}'[FITS extension to use]:hdu:_default' \
    '-o+[output filename]:file:_files' \
    '--stretch=[stretching function]:func:(linear sqrt power log asinh)' \
    '--power=[power index for stretch=power]:n:_default' \
    '--asinh_a=[asinh a parameter]:n:_default' \
    '--vmin=[manual minimum data value]:n:_default' \
    '--vmax=[manual maximum data value]:n:_default' \
    '--min_percent=[min percent for autoscale]:pct:_default' \
    '--max_percent=[max percent for autoscale]:pct:_default' \
    '--percent=[symmetric autoscale percent]:pct:_default' \
    '--cmap=[matplotlib colormap name]:colormap:_default' \
    '(- *)'{-h,--help}'[show help]' \
    '*:FITS file:_files -g "*.{fits,fit,fts,fits.gz,fit.gz,fts.gz}"' \
    && ret=0

return ret
