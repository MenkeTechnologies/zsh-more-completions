#compdef nghttp
# Documentation: nghttp --help (nghttp2)
# Source: HTTP/2 / HTTP/3 client.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*'{-v,--verbose}'[verbose debug info (stackable)]' \
    {-n,--null-out}'[discard downloaded data]' \
    {-O,--remote-name}'[save to filename derived from URI]' \
    {-t+,--timeout=}'[request timeout duration]:duration:' \
    {-w+,--window-bits=}'[stream initial window 2^N-1]:n:' \
    {-W+,--connection-window-bits=}'[connection initial window 2^N-1]:n:' \
    {-a,--get-assets}'[download linked assets]' \
    {-s,--stat}'[print statistics]' \
    '*'{-H+,--header=}'[add request header]:header:' \
    '*--trailer=[add trailer header]:header:' \
    '--cert=[client certificate]:file:_files' \
    '--key=[client private key]:file:_files' \
    {-d+,--data=}'[request body data file]:file:_files' \
    {-m+,--multiply=}'[N concurrent requests]:n:' \
    {-u,--upgrade}'[try upgrade from HTTP/1.1 over cleartext]' \
    {-p+,--weight=}'[stream weight (default 16)]:n:' \
    {-M+,--peer-max-concurrent-streams=}'[max concurrent streams declared]:n:' \
    {-c+,--header-table-size=}'[HPACK table size]:size:' \
    {-y,--no-verify-peer}'[disable TLS peer verification]' \
    {-b+,--padding=}'[padding bytes]:n:' \
    {-r+,--har=}'[write HAR file]:file:_files -g "*.har"' \
    {-h+,--hexdump=-}'[hexdump TLS payload]::file:_files' \
    {-x,--expect-continue}'[wait for 100-continue]' \
    '--ciphers=[TLS cipher list]:ciphers:' \
    '--tls13-ciphers=[TLS 1.3 cipher list]:ciphers:' \
    '--no-dep[do not send dependency-based priority]' \
    '--no-push[disable server push]' \
    '--max-concurrent-streams=[max concurrent streams]:n:' \
    '*:uri:_urls' \
    && ret=0

return ret
