#compdef euporie
# _euporie — Josiah Outram Halstead Jupyter notebook terminal UI (joouha team, Python); custom argparse
# upstream: https://github.com/joouha/euporie

_euporie() {
    local -a sub=(
        'notebook:open notebooks'
        'console:console front-end'
        'preview:preview notebook'
        'hub:multi-user notebook server'
        'launch:launch a kernel'
        'kernels:list kernels'
        'edit:edit file'
        'files:browse files'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--log-file=+[log file]:file:_files' \
        '--log-level=+[level]:l:(debug info warning error critical)' \
        '--config-file=+[config file]:file:_files' \
        '--no-color[disable color]' \
        '--color-scheme=+[scheme]:s:(default light dark)' \
        '--editing-mode=+[mode]:m:(emacs vi micro)' \
        '--key-bindings=+[file]:file:_files' \
        '--syntax-theme=+[theme]:str:' \
        '--terminal-polling-interval=+[ms]:n:' \
        '--show-status-bar[show status bar]' \
        '--show-cell-borders[show cell borders]' \
        '--external-clipboard[external clipboard]' \
        '--save-widget-state[save widget state]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'euporie subcommand' sub ;;
        args)
            case $words[1] in
                notebook|edit|preview) _arguments '*:file:_files -g "*.ipynb"' ;;
                console|launch) _arguments '--kernel=+[kernel]:str:' ;;
            esac
            ;;
    esac
}

_euporie "$@"
