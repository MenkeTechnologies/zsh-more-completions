#compdef pt-stalk
# Documentation: https://docs.percona.com/percona-toolkit/pt-stalk.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '--collect[collect diagnostic data when triggered]' \
  '--collect-gdb[collect GDB stacktraces]' \
  '--collect-oprofile[collect oprofile data]' \
  '--collect-strace[collect strace data]' \
  '--collect-tcpdump[capture network traffic on MySQL port]' \
  '--config=[comma-separated config files]:files:_files' \
  '--cycles=[cycles variable must exceed threshold]:count:' \
  '--daemonize[fork to background]' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--dest=[destination directory]:directory:_directories' \
  '--disk-bytes-free=[min free disk space]:bytes:' \
  '--disk-pct-free=[min free disk percentage]:percent:' \
  '--function=[trigger function (status/processlist/file)]:function:' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--interval=[check interval seconds]:seconds:' \
  '--iterations=[number of iterations]:count:' \
  '--log=[log file]:log file:_files' \
  '--match=[pattern for PROCESSLIST matching]:pattern:' \
  '--mysql-only[collect only MySQL-related diagnostics]' \
  '--notify-by-email=[send email notification]:email:' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--plugin=[plugin file]:plugin:_files' \
  '--port=[MySQL port]:port:' \
  '--prefix=[filename prefix]:prefix:' \
  '--retention-count=[keep data from last N runs]:n:' \
  '--retention-size=[keep up to N MB of data]:mb:' \
  '--retention-time=[days to retain samples]:days:' \
  '--run-time=[collection duration seconds]:seconds:' \
  '--skip-collection=[skip specified collection types]:list:' \
  '--sleep=[sleep after collection seconds]:seconds:' \
  '--sleep-collect=[sleep between collection cycles]:seconds:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--stalk[watch for trigger before collecting]' \
  '--system-only[collect only OS-related diagnostics]' \
  '--threshold=[trigger threshold]:value:' \
  '--user=[MySQL user]:username:' \
  '--variable=[variable to monitor]:variable:' \
  '--verbose=[verbosity level 0-3]:level:(0 1 2 3)' && ret=0

return ret
