#compdef avifenc avifdec avifgainmaputil libavif
# _libavif — AOMedia AV1 Image File Format avifenc and avifdec reference AVIF encoder and decoder tools (AOMediaCodec team, C); custom argparse
# upstream: https://github.com/AOMediaCodec/libavif

_libavif() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-j+[N CPU jobs]:n:' \
        '--jobs=+[N CPU jobs]:n:' \
        '-q+[quality 0-100]:n:' \
        '--qcolor=+[quality color]:n:' \
        '--qalpha=+[quality alpha]:n:' \
        '--min=+[min QP]:n:' \
        '--max=+[max QP]:n:' \
        '--minalpha=+[min alpha QP]:n:' \
        '--maxalpha=+[max alpha QP]:n:' \
        '--target-size=+[bytes]:n:' \
        '-s+[speed 0-10]:n:' \
        '--speed=+[speed 0-10]:n:' \
        '-c+[codec]:c:(aom rav1e svt libgav1 dav1d)' \
        '--codec=+[codec]:c:(aom rav1e svt libgav1 dav1d)' \
        '-y+[YUV format]:f:(444 422 420 400)' \
        '--yuv=+[YUV format]:f:(444 422 420 400)' \
        '-d+[bit depth]:d:(8 10 12)' \
        '--depth=+[bit depth]:d:(8 10 12)' \
        '-r+[range]:r:(limited full)' \
        '--range=+[range]:r:(limited full)' \
        '--lossless[lossless mode]' \
        '-l[lossless mode]' \
        '--ignore-icc[ignore embedded ICC]' \
        '--ignore-exif[ignore EXIF]' \
        '--ignore-xmp[ignore XMP]' \
        '--ignore-profile[ignore color profile]' \
        '--ignore-gain-map[ignore gain map]' \
        '--cicp=+[CICP triplet]:str:' \
        '--nclx=+[nclx triplet]:str:' \
        '--no-overwrite[no overwrite]' \
        '--no-progress[no progress]' \
        '--progressive[progressive]' \
        '--png-compress=+[level]:n:' \
        '--jpeg-quality=+[quality]:n:' \
        '-i+[input grid index]:n:' \
        '--input-grid=+[NxN]:str:' \
        '--grid=+[NxN]:str:' \
        '--info[show info]' \
        '*:input output:_files -g "*.png *.jpg *.jpeg *.avif *.y4m"'
}

_libavif "$@"
