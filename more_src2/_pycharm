#compdef pycharm
# Documentation: https://www.jetbrains.com/help/pycharm/working-with-the-ide-features-from-command-line.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--help[show help]'
  '--version[show version]'
  '--wait[wait for the files to be closed before returning]'
  'nosplash[suppress splash screen]'
  'dontReopenProjects[show welcome screen, do not reopen projects]'
  'disableNonBundledPlugins[launch without manually installed plugins]'
  'diff[open diff viewer between two files]:file1:_files:file2:_files'
  'merge[open merge dialog]:file1:_files:file2:_files:output:_files'
  'format[apply code style formatting to files]:*:files:_files'
  'inspect[run code inspection on project]:*:args:_files'
  '*:files or directories:_files'
)

_arguments -s -S $arguments
