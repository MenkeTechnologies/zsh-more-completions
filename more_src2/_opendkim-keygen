#compdef opendkim-keygen opendkim-genkey
# Documentation: https://manpages.debian.org/bookworm/opendkim-tools/opendkim-genkey.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm opendkim-genkey(8) manpage. Real binary is
# opendkim-genkey.

# opendkim-genkey: DKIM key generation utility
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-a --append-domain)'{-a,--append-domain}'[append domain name to TXT record label]' \
  '(-b --bits)'{-b,--bits=}'[key size in bits]:n:' \
  '(-d --domain)'{-d,--domain=}'[signing domain]:domain:' \
  '(-D --directory)'{-D,--directory=}'[change to directory before creating files]:dir:_files -/' \
  '(-h --hash-algorithms)'{-h,--hash-algorithms=}'[hash algorithms (colon-separated)]:list:' \
  '(-n --note)'{-n,--note=}'[note text in key record]:text:' \
  '(-r --restrict)'{-r,--restrict}'[restrict key to email signing only]' \
  '(-s --selector)'{-s,--selector=}'[selector name]:name:' \
  '-S[disallow subdomain signing]' \
  '--subdomains[allow subdomain signing]' \
  '--nosubdomains[disallow subdomain signing]' \
  '-t[testmode tag]' \
  '--testmode[testmode tag]' \
  '--notestmode[no testmode tag]' \
  '(-v --verbose)'{-v,--verbose}'[verbose output]' && ret=0
return ret
