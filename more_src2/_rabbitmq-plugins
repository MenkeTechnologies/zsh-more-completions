#compdef rabbitmq-plugins
# Documentation: https://www.rabbitmq.com/docs/man/rabbitmq-plugins.8
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'help:general help'
  'list:list plugins'
  'enable:enable plugins'
  'disable:disable plugins'
  'set:replace entire plugin set'
  'is_enabled:check if plugin enabled'
  'directories:show plugin directories'
  'sign:sign plugin'
  'verify:verify plugin signature'
)

_arguments -C \
  '-n+[node name]:node:' \
  '(-q --quiet)'{-q,--quiet}'[reduce messages]' \
  '(-s --silent)'{-s,--silent}'[suppress messages]' \
  '(-t --timeout)'{-t,--timeout=}'[timeout secs]:secs:' \
  '(-l --longnames)'{-l,--longnames}'[FQDN node names]' \
  '--erlang-cookie=[shared secret]:cookie:' \
  '(- *)--help[show help]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'rabbitmq-plugins subcommand' subcommands && ret=0
    ;;
  (args)
    case $line[1] in
      (list)
        _arguments \
          '-E[explicitly enabled only]' \
          '-e[enabled only]' \
          '-m[names only]' \
          '-v[verbose]' \
          ':pattern:' && ret=0
        ;;
      (enable|disable|set)
        _arguments \
          '--offline[offline mode]' \
          '--online[online mode]' \
          '*:plugin:' && ret=0
        ;;
    esac
    ;;
esac

return ret
