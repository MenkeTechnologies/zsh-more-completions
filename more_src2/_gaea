_gaea_proxy_main() {
    _arguments -s \
        '-config=[gaea config file (default etc/gaea.ini)]:config file:_files -g "*.(ini|toml|conf)"' \
        '-info[show build version information and exit]' \
        '-num-cpu=[how many OS threads can simultaneously execute (default 0 = automaxprocs)]:n:'
}

_gaea_cc_main() {
    _arguments -s \
        '-c=[gaea-cc config file (default ./etc/gaea_cc.ini)]:config file:_files -g "*.(ini|toml|conf)"' \
        '-info[show build version information and exit]'
}

case $service in
    gaea-cc) _gaea_cc_main "$@" ;;
    *) _gaea_proxy_main "$@" ;;
esac
