#compdef mcelog-config
# Documentation: https://manpages.debian.org/testing/mcelog/mcelog.conf.5
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: no canonical mcelog-config CLI; mcelog itself uses --config-file=FILE and
# /etc/mcelog/mcelog.conf (mcelog.conf(5)). Distro helpers vary; provide minimal
# completion deferring to filenames.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*::mcelog-config args:_files' && ret=0
return ret
