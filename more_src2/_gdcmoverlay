#compdef gdcmoverlay
# Documentation: https://gdcm.sourceforge.net
# Source: malaterre/GDCM Applications/Cxx/gdcmoverlay.cxx — dump DICOM overlay planes (C++, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-i --input)'{-i+,--input=}'[input DICOM file]:file:_files -g "*.{dcm,DCM,dicom}"' \
    '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
    '(-d --dict)'{-d,--dict}'[print dict info]' \
    '(-v --verbose)'{-v,--verbose}'[verbose]' \
    '*:DICOM file:_files -g "*.{dcm,DCM,dicom}"' \
    && ret=0

return ret
