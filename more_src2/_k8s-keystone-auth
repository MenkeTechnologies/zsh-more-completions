#compdef k8s-keystone-auth
# _k8s-keystone-auth — Kubernetes Keystone webhook authenticator/authorizer
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from pkg/identity/keystone/config.go + keystone.go (AddExtraFlags) on tip.

_k8s-keystone-auth() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--listen=[bind host\:port]:host\:port:' \
        '--tls-cert-file=[TLS server cert]:file:_files' \
        '--tls-private-key-file=[TLS server key]:file:_files' \
        '--keystone-url=[Keystone API URL]:url:_urls' \
        '--keystone-ca-file=[Keystone CA cert]:file:_files' \
        '--keystone-policy-file=[Keystone policy file]:file:_files' \
        '--policy-configmap-name=[policy ConfigMap name (kube-system ns)]:name:' \
        '--sync-config-file=[Keystone<->K8s sync config file]:file:_files' \
        '--sync-configmap-name=[sync ConfigMap name (kube-system ns)]:name:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '*--user-agent=[extra gophercloud user-agent component]:component:' \
        '-v[klog verbosity level]:n:'
}

_k8s-keystone-auth "$@"
