#compdef fbrun
# Documentation: https://manpages.debian.org/bookworm/fluxbox/fbrun.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm fbrun(1) manpage. X11-style single-dash long
# options, not GNU --form.
# Removed from prior file: fabricated --help/--version flags and bogus
# man.archlinux.org search URL.

# fbrun: Fluxbox run dialog (X11 application launcher)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' \
  '-title[window title]:title:' \
  '-text[default text]:text:' \
  '-w[window width]:pixels:' \
  '-h[window height]:pixels:' \
  '-display[X display]:display:' \
  '-pos[window position (x y)]:x y:' \
  '-nearmouse[position under mouse cursor]' \
  '-fg[foreground color (default black)]:color:' \
  '-bg[background color (default white)]:color:' \
  '-font[font name]:font:' \
  '-na[disable font antialias]' \
  '-hf[history file (default ~/.fluxbox/fbrun_history)]:file:_files' && ret=0
return ret
