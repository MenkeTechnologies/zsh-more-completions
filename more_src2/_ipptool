#compdef ipptool
# Documentation: ipptool --help (CUPS 26)
# Source: send IPP requests to a printer and check responses against a script.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '--ippserver=[produce ippserver attribute file]:file:_files' \
    '--stop-after-include-error[stop tests after a failed INCLUDE]' \
    '(-6)-4[connect using IPv4]' \
    '(-4)-6[connect using IPv6]' \
    '(-L)-C[send requests using chunking (default)]' \
    '(-C)-L[send requests using content-length]' \
    '(-S)-E[encrypt via HTTP Upgrade to TLS]' \
    '(-E)-S[encrypt via HTTPS]' \
    '-I[ignore errors]' \
    '-P+[XML plist output file]:plist:_files -g "*.plist"' \
    '-T+[receive/send timeout in seconds]:seconds:' \
    '-V+[default IPP version]:version:(1.0 1.1 2.0 2.1 2.2)' \
    '(-c -l -t -X)-X[XML plist instead of plain text]' \
    '(-c -l -t -X)-c[CSV output]' \
    '(-c -l -t -X)-l[plain text output]' \
    '(-c -l -t -X)-t[test report]' \
    '*-d+[set named variable to value]:name=value:' \
    '-f+[default request filename]:file:_files' \
    '-h[validate HTTP response headers]' \
    '-i+[repeat last file with interval (s)]:seconds:' \
    '-n+[repeat last file count times]:count:' \
    '-q[run silently]' \
    '-v[verbose]' \
    '1:printer URI:' \
    '*:test file:_files -g "*.test"' \
    && ret=0

return ret
