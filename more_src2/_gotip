#compdef gotip
# _gotip — install and run Go from development tip
# upstream: https://pkg.go.dev/golang.org/dl/gotip

_arguments -s -S \
    '(- *)'{-h,--help}'[show help]' \
    '1:go command:(build clean doc env fix fmt generate get install list mod run test tool version vet)' \
    '*:arguments:_files' \
    && return 0
