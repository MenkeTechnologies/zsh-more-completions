#compdef pak
# _pak — Posit Software pak fast resilient R package manager with system dependencies and parallel installs (r-lib team, R/C); R function
# upstream: https://github.com/r-lib/pak

_pak() {
    local -a sub=(
        'pkg_install:install packages'
        'pkg_remove:remove packages'
        'pkg_status:show package status'
        'pkg_info:show package info'
        'pkg_search:search CRAN'
        'pkg_dep_tree:show dependency tree'
        'pkg_deps:show direct deps'
        'pkg_deps_tree:show all deps tree'
        'pkg_deps_explain:explain deps'
        'pkg_download:download package'
        'pkg_install_local:install local'
        'lib_status:library status'
        'cache_summary:show cache summary'
        'cache_list:list cache'
        'cache_clean:clean cache'
        'cache_delete:delete cache'
        'system_deps:system dependencies'
        'sysreqs:show system requirements'
        'libs_status:libraries status'
        'pak_setup:setup pak'
        'pak_install_extra:install extras'
        'pak_cleanup:cleanup pak'
        'meta_list:list metadata'
        'meta_summary:summarize metadata'
        'meta_clean:clean metadata'
        'meta_update:update metadata'
        'repo_get:show repositories'
        'repo_add:add a repository'
        'repo_status:repository status'
        'lockfile_create:create renv-style lockfile'
        'lockfile_install:install from lockfile'
        'lockfile_lock:lock dependencies'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-V[show version]' \
        '--version[show version]' \
        '--ask=+[bool]:b:(true false)' \
        '--lib=+[library path]:dir:_files -/' \
        '--upgrade=+[bool]:b:(true false)' \
        '--dependencies=+[deps]:str:' \
        '--repos=+[repos csv]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pak subcommand' sub ;;
        args)
            case $words[1] in
                pkg_install|pkg_remove|pkg_status|pkg_info|pkg_deps|pkg_dep_tree|pkg_download) _arguments \
                    '*:package name:' ;;
                pkg_search) _arguments '*:search term:' ;;
                cache_list|cache_clean|cache_delete) _arguments \
                    '--pkg=+[pkg]:str:' \
                    '--version=+[version]:str:' ;;
            esac
            ;;
    esac
}

_pak "$@"
