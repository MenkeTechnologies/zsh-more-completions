#compdef pagekite pagekite.py
# _pagekite — PageKite open-source tunneling proxy (Python); exposes local HTTP/SSH/HTTPS through pagekite.net relay
# upstream: https://github.com/pagekite/PyPagekite

_pagekite() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--clean[do not load any config]' \
        '--signup[interactive signup at pagekite.net]' \
        '--add[add a new kite]' \
        '--save[save runtime config]' \
        '--list[list configured kites]' \
        '--remove[remove a kite]' \
        '--isfrontend[run as frontend (relay) instead of backend]' \
        '--service_on=+[expose service]:proto:kite:lhost:lport:secret:' \
        '--service_cfg=+[per-service config]:key:value:' \
        '--frontend=+[connect through frontend]:host:port:' \
        '--frontends=+[frontends DNS pool]:count:domain:port:' \
        '--ports=+[listen ports]:list:' \
        '--protos=+[protocols]:list:' \
        '--domain=+[domain mapping]:proto:domain:secret:' \
        '--logfile=+[log file]:file:_files' \
        '--daemonize[run as daemon]' \
        '--runas=+[drop privileges to user]:user:_users' \
        '--pidfile=+[pid file]:file:_files' \
        '--debugio[debug IO]' \
        '--noloop[exit after first connection]'
}

_pagekite "$@"
