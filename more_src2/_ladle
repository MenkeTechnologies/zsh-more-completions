#compdef ladle
# Documentation: https://ladle.dev/docs/cli
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'serve:start development server'
  'dev:start development server (alias of serve)'
  'build:build static production app'
  'preview:start a server to preview the build in outDir'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'ladle command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (serve|dev)
        _arguments \
          '(-h --host)'{-h+,--host=}'[host to serve the application]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[port to serve the application]:port:' \
          '--stories=[glob to find stories]:pattern:' \
          '--theme=[UI theme]:theme:(light dark auto)' \
          '--config=[folder where config is located]:dir:_files -/' \
          '--viteConfig=[file with Vite configuration]:file:_files' \
          '--base=[base URL path for build output]:path:' \
          '--mode=[vite mode]:mode:' \
          '--noWatch=[disable file system watcher]:flag:' && ret=0
        ;;
      (build)
        _arguments \
          '(-o --outDir)'{-o+,--outDir=}'[output directory]:directory:_files -/' \
          '--stories=[glob to find stories]:pattern:' \
          '--theme=[UI theme]:theme:(light dark auto)' \
          '--config=[folder where config is located]:dir:_files -/' \
          '--viteConfig=[file with Vite configuration]:file:_files' \
          '--base=[base URL path for build output]:path:' \
          '--mode=[vite mode]:mode:' && ret=0
        ;;
      (preview)
        _arguments \
          '(-o --outDir)'{-o+,--outDir=}'[output directory]:directory:_files -/' \
          '(-h --host)'{-h+,--host=}'[host to serve the application]:host:_hosts' \
          '(-p --port)'{-p+,--port=}'[port to serve the application]:port:' \
          '--config=[folder where config is located]:dir:_files -/' \
          '--viteConfig=[file with Vite configuration]:file:_files' \
          '--base=[base URL path for build output]:path:' \
          '--mode=[vite mode]:mode:' && ret=0
        ;;
    esac
    ;;
esac

return ret
