#compdef gpgv-check gpgcheck
# _gpgcheck — gpgv wrapper helper (small shell wrapper around gpgv(1) used by RPM / dnf hooks to verify signatures against a project-pinned keyring; --keyring path to .gpg keyring, --status-fd numeric status pipe, --homedir alt gpg home, --quiet quiet, --verbose verbose, --version, --help; positional argument is the signed file)
# upstream: https://github.com/gpg/gnupg (gpgv companion helpers)
# Common flag shape from gpg/gnupg gpgv wrappers on tip.

_gpgcheck() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--keyring+[keyring]:file:_files -g "*.gpg"' \
        '--status-fd+[status fd]:fd:' \
        '--homedir+[gpg home]:dir:_files -/' \
        '--quiet[quiet]' \
        '--verbose[verbose]' \
        '1:signed file:_files'
}

_gpgcheck "$@"
