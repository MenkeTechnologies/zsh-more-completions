#compdef mender-auth
# Documentation: source-direct extraction from upstream
# mendersoftware/mender (the C++20 client rewrite).
#   src/mender-auth/cli/cli.cpp lines 46-83 (the
#     opts_bootstrap_daemon vector + CliCommand cmd_bootstrap +
#     cmd_daemon + CliApp cli_mender_auth)
#   src/client_shared/conf/conf_cli_help.cpp lines 44-100 (the
#     common_global_options vector — shared with R213's
#     mender-update)
# Reference accessed: 2026-05-30 via gh api.
#
# mender-auth is the companion to R213's mender-update — handles
# device identity bootstrap, JWT token caching, key generation,
# and the D-Bus IPC interface that mender-update connects to for
# server authentication.  Split out of the legacy Go client in
# the C++20 rewrite.  Both binaries share the
# `common_global_options` set from src/client_shared/conf/.

# Global flags decoded source-direct from common_global_options
# (same as mender-update — shared between both binaries).
local -a global_flags=(
  '(-c --config)'{-c+,--config=}'[configuration FILE path]:file:_files -g "*.conf"'
  '(-b --fallback-config)'{-b+,--fallback-config=}'[fallback configuration FILE path]:file:_files -g "*.conf"'
  '--data=[DEPRECATED alias for --datastore]:dir:_files -/'
  '(-d --datastore)'{-d+,--datastore=}'[Mender state data DIRECTORY path]:dir:_files -/'
  '(-L --log-file)'{-L+,--log-file=}'[FILE to log to]:file:_files'
  '(-l --log-level)'{-l+,--log-level=}'[set logging level]:level:(trace debug info warning error fatal)'
  '(-E --trusted-certs)'{-E+,--trusted-certs=}'[trusted server certificates FILE path]:file:_files -g "*.(pem|crt)"'
  '--skipverify[skip certificate verification (DANGEROUS)]'
  '(-v --version)'{-v,--version}'[print version and exit]'
  '(-h --help)'{-h,--help}'[show help and exit]'
)

# Subcommands decoded source-direct from CliApp cli_mender_auth
# at src/mender-auth/cli/cli.cpp:72-83.
local -a subcommands=(
  'bootstrap:perform device bootstrap (identity + key generation) and exit'
  'daemon:start the mender-auth daemon (provides D-Bus IPC for mender-update)'
)

# Per-subcommand flags decoded source-direct from
# opts_bootstrap_daemon at src/mender-auth/cli/cli.cpp:46-58.
# BOTH bootstrap AND daemon share these — only the action
# differs (bootstrap exits after bootstrapping; daemon stays
# resident as a D-Bus service).
local -a bootstrap_flags=(
  '(-F --forcebootstrap)'{-F,--forcebootstrap}'[force re-bootstrap even if cached keys+identity exist]'
  "--passphrase-file=[passphrase file for decrypting an encrypted private key ('-' loads from stdin)]:file:_files"
  '(-h --help)'{-h,--help}'[show subcommand help and exit]'
)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  $global_flags \
  '1:subcommand:->subcmd' \
  '*::args:->args' && ret=0

case $state in
  subcmd)
    _describe -t subcommands 'mender-auth subcommand' subcommands && ret=0
    ;;
  args)
    case $words[1] in
      bootstrap|daemon)
        _arguments $bootstrap_flags && ret=0
        ;;
    esac
    ;;
esac

return ret
