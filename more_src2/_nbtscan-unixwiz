#compdef nbtscan-unixwiz
# Documentation: https://www.unixwiz.net/tools/nbtscan.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# nbtscan-unixwiz: NetBIOS name scanner (unixwiz)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-v[verbose (print all names from each host)]' \
  '-d[dump packets (print whole packet contents)]' \
  '-e[format output in /etc/hosts format]' \
  '-l[format output in lmhosts format]' \
  '-t[response timeout in seconds]:secs:' \
  '-b[bandwidth limit (bps)]:bps:' \
  '-r[use local port 137 (root)]' \
  '-q[suppress banners and error messages]' \
  '-s[script-friendly output with separator]:char:' \
  '-h[print human-readable service names (use with -v)]' \
  '-m[number of retransmits]:n:' \
  '-f[targets file]:file:_files' \
  '*:targets:' && ret=0
return ret
