# WHAT IT IS
#   **JAM (Join-Accumulate Machine)** is the **next-generation
#   sharded permissionless blockchain protocol** designed by
#   Gavin Wood (Polkadot founder + Ethereum co-founder + Solidity
#   designer) as the architectural successor to the Polkadot
#   Relay Chain.  Key design tenets:
#
#     • **Coreless** — no "core" runtime;  every validator runs
#       the same minimal **JAM protocol kernel**, and all
#       application logic is hosted as **typed Services** that
#       execute inside the **PVM (Polkadot Virtual Machine)**, a
#       deterministic RISC-V-based VM.  This eliminates the
#       Substrate-per-parachain runtime build burden + the
#       benchmarking + the on-chain runtime upgrades.
#     • **Permissionless** — no token-staking permissioning for
#       Services (vs Polkadot parachain auctions);  Services are
#       deployed by any operator who pays for compute time
#     • **In-CoreTime payment** — Services pay for execution by
#       purchasing **CoreTime** (the typed unit of validator-
#       compute the typed economic model is built around)
#     • **Bandersnatch BLS** — the typed cryptography is built
#       on Bandersnatch (a typed BLS-style signature scheme over
#       the Bandersnatch curve, with typed ring-VRF construction
#       enabling typed validator-set anonymity for proof-of-
#       liveness purposes)
#     • **2.5-second block time** — typed slot duration
#     • **6-second finality** — typed Safrole (Sassafras +
#       Aura combined) consensus
#     • **The Gray Paper** — Gavin's typed formal JAM spec
#       (gavwood.com/graypaper.html) defines every typed message
#       format + state transition;  implementations are evaluated
#       against the typed JAM conformance test suite + interop
#       interop matrix
#
#   The Typeberry `jam` CLI implements the typed validator-node
#   surface:
#
#     • `jam` (default)               regular node operation —
#                                     run as a JAM validator,
#                                     connecting to the configured
#                                     bootnodes via @matrixai/quic,
#                                     producing + importing blocks,
#                                     persisting state via LMDB
#     • `jam dev <validator-index>`   development-mode validator
#                                     (deterministic local test
#                                     network with all keys
#                                     known)
#         --fast-forward              generate blocks as fast as
#                                     possible without waiting
#                                     for real time
#     • `jam dev all`                 spawn the entire dev
#                                     validator set in-process
#                                     for typed local interop
#                                     tests
#     • `jam import <bin-or-json-blocks>`
#                                     import blocks from CLI
#                                     and finish (the JAM-spec
#                                     test-vector replayer)
#     • `jam export <output-dir-or-file>`
#                                     export blocks to .bin
#                                     files for typed replay
#                                     + conformance testing
#     • `jam fuzz-target [socket-path]`
#                                     run as a Fuzz Target for
#                                     the typed JAM fuzzing
#                                     harness (the typed
#                                     differential-fuzzing
#                                     infrastructure that
#                                     compares Typeberry's
#                                     state-transition outputs
#                                     against PolkaJam +
#                                     JamixIR cross-impl)
#         --version=1                 fuzz protocol version
#                                     (default 1)
#         --init-genesis-from-ancestry
#                                     skip parent hash + state
#                                     root verification
#
#     Shared options (every command):
#       --name <NAME>                 override node name
#                                     (affects networking key
#                                     + db location;
#                                     default `Typeberry-Node`)
#       --config <DIRECTIVE>          configuration directives
#                                     (repeatable;
#                                     merged left-to-right);
#                                     each directive can be:
#                                       - a path to a config
#                                         file
#                                       - an inline JSON object
#                                       - a pseudo-jq query
#                                         (e.g.
#                                         `.chain_spec+=
#                                         {"bootnodes": []}`)
#                                       - one of the predefined
#                                         configs (`dev` /
#                                         `default`)
#       --pvm <BACKEND>               PVM Backend
#                                     (default `built-in`;
#                                     values: `built-in`
#                                     (typed Typeberry built-in
#                                     interpreter) / `ananas`
#                                     (typed Ananas typed
#                                     external interpreter))
#       --help                        show help
#
# CLI ARGUMENT GRAMMAR  (verbatim from `bin/jam/args.ts`
#                       minimist declarations;  extracted via
#                       raw fetch of `bin/jam/args.ts`;  every
#                       option below is a literal `ARGS.<NAME>`
#                       constant or `Command.<Name>` enum value
#                       from the upstream source)
#
#   jam [OPTIONS] [COMMAND [COMMAND ARGS...]]
#
# AXIS / CORPUS POSITION
#   `FluffyLabs/typeberry`'s `packages/core/networking/package.json`
#   declares a **direct** dependency on `@matrixai/quic@2.0.9`,
#   and the typed `packages/core/networking/quic-stream.ts`
#   module uses typed `QUICServer` /  typed `QUICClient` /
#   typed `QUICConnection` /  typed `QUICStream` primitives
#   for the JAM validator-to-validator wire transport.  The
#   typed `bin/jam/build-for-npm.sh` build script explicitly
#   bundles `@matrixai/quic` as a **runtime npm dependency**
#   (not bundled into the `dist/jam/index.js` ncc bundle)
#   because the typed package ships platform-specific native
#   `.node` binaries that ncc cannot bundle at build time —
#   the matching `@matrixai/quic-{linux-x64-gnu, linux-arm64-gnu,
#   darwin-arm64, darwin-x64, win32-x64}` native addon must be
#   installed at npm-install time on the target machine.
#
#   **@matrixai/quic** (`@matrixai/quic` on npm) is **THE
#   canonical TypeScript-native QUIC 1 implementation** —
#   MatrixAI's reference TS+napi-rs implementation that exposes
#   typed JavaScript bindings over the underlying Rust QUIC
#   stack.  Originally bound over Cloudflare's **quiche** (the
#   Cloudflare production Rust QUIC implementation that powers
#   the Cloudflare edge);  current versions ship typed napi-rs
#   bindings + a typed top-of-stack TypeScript layer that
#   maintains the Node.js `EventTarget` + `WHATWG Streams`
#   integration the Node ecosystem expects.  In active
#   development since 2022 with 200+ ★ on github.com/MatrixAI/
#   js-quic, sponsored by **MatrixAI** (the Sydney-based
#   privacy-focused infrastructure startup that builds Polykey,
#   the decentralized secrets management system, alongside the
#   typed js-quic library that powers Polykey's peer-to-peer
#   sync transport).
#
#   @matrixai/quic ships:
#
#     • Typed `QUICServer`            typed
#                                     `QUICServer({crypto,
#                                     config, socket, logger})`
#                                     constructor + typed
#                                     `.start({host, port})`
#                                     + typed `.stop()`
#                                     server lifecycle
#     • Typed `QUICClient`            typed
#                                     `QUICClient.createQUICClient({
#                                     crypto, socket, config,
#                                     host, port, logger,
#                                     reasonToCode,
#                                     codeToReason })`
#                                     async constructor + typed
#                                     `.destroy()` cleanup
#     • Typed `QUICConnection`        typed `.connect()` /
#                                     `.start()` / `.streamNew(
#                                     'bidi' | 'uni')` /
#                                     `.stop({applicationError,
#                                     errorCode, force})` /
#                                     `.destroy()` operations;
#                                     typed `EventTarget` event
#                                     stream: `connectionError`
#                                     / `connectionStop` /
#                                     `streamError` /
#                                     `streamCreated` etc.
#     • Typed `QUICStream`            typed `WHATWG ReadableStream`
#                                     + `WHATWG WritableStream`
#                                     proxies on a typed QUIC
#                                     stream, with typed
#                                     `.cancel(reason)` +
#                                     `.close()` + `.destroy()`
#                                     operations
#     • Typed `events` enum           typed `EventQUICServerStart`
#                                     / `EventQUICServerStop` /
#                                     `EventQUICClientCreate` /
#                                     `EventQUICClientDestroy` /
#                                     `EventQUICConnectionStart` /
#                                     `EventQUICConnectionStop` /
#                                     `EventQUICStreamCreated`
#                                     etc. typed event classes
#     • Typed `errors` namespace      typed
#                                     `ErrorQUICServerStart` /
#                                     `ErrorQUICClientCreate` /
#                                     `ErrorQUICConnectionStart` /
#                                     `ErrorQUICConnectionStop` /
#                                     `ErrorQUICStreamCreate` /
#                                     `ErrorQUICStreamCancel`
#                                     typed Error subclasses
#                                     with typed structured
#                                     metadata
#     • Typed `crypto` interface      typed `signature` /
#                                     `verify` /  `generateKey` /
#                                     `signPSK` /  `keyExporter`
#                                     typed crypto trait
#                                     (pluggable;  the typed
#                                     library accepts any
#                                     concrete typed crypto
#                                     provider that satisfies
#                                     the interface;  most
#                                     consumers use the
#                                     bundled typed `NodeCrypto`
#                                     impl backed by
#                                     `node:crypto.subtle`)
#     • Typed congestion controllers  typed concrete:
#                                     `Reno`, `Cubic`, `Bbr`
#                                     (the typed config knob
#                                     accepts the string name
#                                     + the typed library
#                                     wires up the concrete
#                                     impl)
#     • Typed 0-RTT resumption        typed `TokenStore` API
#                                     with typed pluggable
#                                     session-ticket
#                                     persistence
#     • Typed connection migration    typed CID rotation +
#                                     typed path migration
#                                     (the QUIC "wifi-to-LTE
#                                     without dropping the
#                                     connection" feature)
#     • Typed Path MTU discovery      typed DPLPMTUD
#                                     implementation
#     • Typed datagram frames         typed RFC 9221 unreliable
#                                     datagrams
#     • Typed retry token + stateless
#       reset
#     • Typed napi-rs Rust bindings   typed
#                                     `@matrixai/quic-darwin-arm64`
#                                     / `@matrixai/quic-darwin-x64`
#                                     / `@matrixai/quic-linux-x64-gnu`
#                                     / `@matrixai/quic-linux-arm64-gnu`
#                                     / `@matrixai/quic-win32-x64-msvc`
#                                     platform-specific native
#                                     addons (the typed
#                                     optionalDependencies
#                                     pattern used by sharp,
#                                     swc, esbuild) with typed
#                                     pure-Wasm fallback
#
#   @matrixai/quic is the QUIC library behind essentially every
#   modern TypeScript-native QUIC + HTTP/3 + WebTransport
#   application (excluding pure-WebTransport-via-Chrome and
#   pure-Cloudflare-Workers cases, which use the browser /
#   runtime built-in QUIC stack):
#
#     • **Polykey** (MatrixAI/Polykey, the canonical user of
#       @matrixai/quic) — decentralized secrets management with
#       typed QUIC-based peer sync (covered as `_polykey`)
#     • **Typeberry** (this very project) — JAM protocol
#       TypeScript reference impl
#     • **Wormhole CLI** — the @tachyon-mesh typed P2P file
#       transfer tool (covered as `_wormhole`)
#     • **Localup** SDK — typed local-dev environment
#       orchestration
#     • **Solana TPU client** — typed Solana high-performance
#       client for the typed gulf-stream TPU transport
#     • **0xfnzero/sol-trade-sdk-nodejs** — typed Solana
#       trading SDK
#     • **agentdb / agent-control-plane** — typed
#       agent-orchestration data plane
#     • **ruflo** — typed federated wire transport ADR
#       references @matrixai/quic
#     • **Koatty** — typed Node.js full-featured framework
#     • **moq-relay / moq-dev/moq** — typed Media-over-QUIC
#       (MoQ) IETF-draft live-streaming protocol
#     • **maceip/appstore** — typed QUIC-based app store
#     • **botocean / l4s-bridge** — typed L4S networking
#       bridge
#     • Plus dozens of internal typed QUIC services in the
#       Node + Bun + Deno ecosystem.
#
#   The @matrixai/quic project is structurally significant
#   because pre-@matrixai/quic, TypeScript QUIC tooling was
#   either:
#     (a) shelling out to a system QUIC binary (`cargo install
#         quiche-tools` + node-call-out — defeats the
#         single-package npm-install deployment),
#     (b) waiting for Node.js core QUIC (Node 18+ shipped
#         experimental QUIC, then removed it in Node 20 due
#         to maintenance burden; still not stable as of Node
#         22),
#     (c) using browser-only WebTransport (no Node
#         compatibility).
#   @matrixai/quic is the first typed pure-TS-API QUIC
#   library that works in every Node 18+ runtime + Bun + Deno
#   without a separate native installation step.
#
#   Verified via:
#     gh api repos/FluffyLabs/typeberry/contents/packages/core/
#                                          networking/package.json
#       → "name": "@typeberry/networking"
#       → "dependencies": { ..., "@matrixai/quic": "2.0.9", ... }
#     gh api repos/FluffyLabs/typeberry/contents/bin/jam/
#                                                  package.json
#       → "name": "@typeberry/jam"
#       → "bin": "./index.ts"
#     raw.githubusercontent.com FluffyLabs/typeberry main
#         bin/jam/args.ts
#       → import minimist from "minimist";
#       → export const ARGS = { NAME: "name", CONFIG: "config",
#         PVM: "pvm", FAST_FORWARD: "fast-forward",
#         INIT_GENESIS_FROM_ANCESTRY: "init-genesis-from-ancestry",
#         VERSION: "version" }
#       → export enum Command { Run = "run", Dev = "dev",
#         Import = "import", Export = "export",
#         FuzzTarget = "fuzz-target" }
#       → HELP usage shows `jam [options] dev
#         <dev-validator-index> [--fast-forward]`
#       → HELP shows `jam [options] import <bin-or-json-blocks>`
#       → HELP shows `jam [options] export
#         <output-directory-or-file>`
#       → HELP shows `jam [options] fuzz-target [--version=1]
#         [--init-genesis-from-ancestry]
#         [socket-path=/tmp/jam_target.sock]`
#     raw.githubusercontent.com FluffyLabs/typeberry main
#         packages/jam/config/pvm-backend.ts
#       → PvmBackendNames = ["built-in", "ananas"]
#       → enum PvmBackend { BuiltIn = 0, Ananas = 1 }
#     raw.githubusercontent.com FluffyLabs/typeberry main
#         bin/jam/build-for-npm.sh
#       → QUIC_VERSION=$(node -p "require('./packages/core/
#                                     networking/package.json'
#                                ).dependencies['@matrixai/quic']")
#       → bails out with explicit "ERROR: could not resolve
#         version" if the typed dep is missing
#       → bundles @matrixai/quic as a runtime npm dep alongside
#         lmdb + @typeberry/native because ncc cannot bundle
#         their native bindings
#
#   This entry is the TS-Node=183 closing pair that **CLOSES** Axis
#   128 (pure-Rust + pure-Go + TS-Node IETF QUIC 1 transport
#   protocol + HTTP/3 + MASQUE proxy implementation taxonomy) at
#   1/1/1, completing the triple-183 round-number landmark
#   (Rust=183 R1082 _iggy on quinn-rs/quinn + Go=183 R1083
#   _masque-plus on quic-go/quic-go + TS-Node=183 R1084 _jam on
#   MatrixAI/js-quic @matrixai/quic) and marking the **121st
#   axis closed** in the corpus.  R1085 on deck: Rust=184 OPENS
#   Axis 129.
#
#   No completion for `jam` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_jam() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--help[show help]' \
        '--name=[override node name (affects networking key + db location)]:name:' \
        '*--config=[configuration directive (path/inline JSON/pseudo-jq/dev/default)]:directive:' \
        '--pvm=[PVM backend]:backend:(built-in ananas)' \
        '--fast-forward[(dev mode only) generate blocks as fast as possible]' \
        '--init-genesis-from-ancestry[(fuzz-target only) skip parent hash + state root verification]' \
        '--version=[(fuzz-target only) fuzz protocol version]:n:(1)' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _jam_cmds=(
                'run:regular node operation (default)'
                'dev:run as a development-mode validator'
                'import:import blocks from CLI and finish'
                'export:export blocks to .bin files'
                'fuzz-target:run as a Fuzz Target (differential fuzzing harness)'
            )
            _describe -t commands 'jam command' _jam_cmds && ret=0
            ;;
        args)
            case $words[1] in
                dev)
                    _arguments \
                        '1:dev-validator-index:(0 1 2 3 4 5 all)' \
                        '--fast-forward[generate blocks as fast as possible]' \
                        '--name=[node name]:name:' \
                        '*--config=[configuration directive]:directive:' \
                        '--pvm=[PVM backend]:backend:(built-in ananas)' && ret=0
                    ;;
                import)
                    _arguments \
                        '*:bin-or-json-blocks:_files -g "*.(bin|json)"' \
                        '--name=[node name]:name:' \
                        '*--config=[configuration directive]:directive:' \
                        '--pvm=[PVM backend]:backend:(built-in ananas)' && ret=0
                    ;;
                export)
                    _arguments \
                        '1:output directory or file:_files' \
                        '--name=[node name]:name:' \
                        '*--config=[configuration directive]:directive:' \
                        '--pvm=[PVM backend]:backend:(built-in ananas)' && ret=0
                    ;;
                fuzz-target)
                    _arguments \
                        '1:socket path:_files' \
                        '--version=[fuzz protocol version]:n:(1)' \
                        '--init-genesis-from-ancestry[skip parent hash + state root verification]' \
                        '--name=[node name]:name:' \
                        '*--config=[configuration directive]:directive:' \
                        '--pvm=[PVM backend]:backend:(built-in ananas)' && ret=0
                    ;;
                run)
                    _arguments \
                        '--name=[node name]:name:' \
                        '*--config=[configuration directive]:directive:' \
                        '--pvm=[PVM backend]:backend:(built-in ananas)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_jam "$@"
