#compdef fisql
# Documentation: man fisql (FreeTDS)
# Source: FreeTDS interactive SQL client (Sybase / MSSQL).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a+[display charset]:charset:' \
    '-A+[packet size]:bytes:' \
    '-c+[command terminator]:cmdend:' \
    '-D+[database name]:database:' \
    '-e[echo SQL input]' \
    '-E+[editor]:editor:_command_names -e' \
    '-F[FIPS mode]' \
    '-g[show brief help]' \
    '-h+[headers count]:headers:' \
    '-H+[hostname]:hostname:_hosts' \
    '-I+[interfaces file]:file:_files' \
    '-i+[input file]:file:_files' \
    '-J+[client charset]:charset:' \
    '-l+[login timeout seconds]:seconds:' \
    '-m+[error level]:level:' \
    '-n[suppress line numbers]' \
    '-o+[output file]:file:_files' \
    '-p[print performance stats]' \
    '-P+[password]:password:' \
    '-s+[column separator]:colseparator:' \
    '-S+[server]:server:' \
    '-t+[command timeout]:timeout:' \
    '-U+[username]:user:_users' \
    '-v[show version]' \
    '-w+[output width]:width:' \
    '-X[encrypted login]' \
    '-y+[sybase directory]:dir:_files -/' \
    '-Y[chained transactions]' \
    '-z+[language]:language:' \
    && ret=0

return ret
