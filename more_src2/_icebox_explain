#compdef icebox_explain
# Documentation: https://github.com/YosysHQ/icestorm
# Source: YosysHQ/icestorm icebox/icebox_explain.py — explain config bits of an iCE40 .asc bitstream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b[print config bit names for each config statement]' \
    '-m[print tile config bitmaps]' \
    '-A[do not skip uninteresting tiles]' \
    '-t[print only the specified tile]:x y:' \
    '*:.asc bitstream:_files' \
    && ret=0

return ret
