#compdef kde-open5 kde-open
# _kde-open5 — KIO kde-open / kde-open5 (open files or URLs through KDE's KIO subsystem; respects KIO slaves for sftp/smb/fish/desktop:/ etc.; --tempfile passes a temp file that gets deleted on close; --noresume opens fresh app instance)
# upstream: https://invent.kde.org/frameworks/kio (src/kioworkers/file/file_unix.cpp etc.)
# Flags from kio src/kioclient/kde-open.cpp on tip.

_kde-open5() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--tempfile[treat argument as temp file]' \
        '--noresume[skip resume of partial download]' \
        '*:file or URL:_files'
}

_kde-open5 "$@"
