#compdef gickup
# Documentation: https://github.com/cooperspencer/gickup
# Reference accessed: 2026-05-18
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-c --config)'{-c,--config}'[path to configuration file]:file:_files' \
  '(-d --dry-run)'{-d,--dry-run}'[perform a dry run without making changes]' \
  '--debug[enable debug logging]' \
  '--info[enable info logging]' \
  '*:config file:_files' && ret=0

return ret
