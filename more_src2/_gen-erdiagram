#compdef gen-erdiagram
# _gen-erdiagram — generate Mermaid ER diagram from a LinkML schema (linkml/linkml)
# upstream: https://github.com/linkml/linkml
# Flags from linkml/generators/erdiagramgen.py (click).

_gen-erdiagram() {
    local -a args
    args=(
        '(-o --output)'{-o+,--output=}'[output file (default stdout)]:file:_files -g "*.(md|mmd)"'
        '(-f --format)'{-f+,--format=}'[output format]:format:(markdown mermaid)'
        '--structural[render only the structural ER diagram]'
        '--no-structural[render the full ER diagram (default)]'
        '--exclude-attributes[omit class attributes from the diagram]'
        '--no-exclude-attributes[include class attributes]'
        '--exclude-abstract-classes[omit abstract classes from the diagram]'
        '--no-exclude-abstract-classes[include abstract classes]'
        '--follow-references[follow references when expanding the diagram]'
        '--no-follow-references[do not follow references]'
        '--max-hops=[maximum number of hops when following references]:n:'
        '*'{-c+,--classes=}'[restrict diagram to the given class(es)]:class:'
        '--include-upstream[include upstream (parent) classes]'
        '--metadata[include schema metadata in output]'
        '--no-metadata[do not include schema metadata]'
        '(-im --importmap)'{-im+,--importmap=}'[import mapping file]:file:_files'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '--mergeimports[merge imports into output]'
        '--no-mergeimports[do not merge imports]'
        '--stacktrace[print full stack traces on error]'
        '--no-stacktrace[suppress stack traces on error]'
        '(- *)'{-V,--version}'[show version]'
        '(- *)--help[show help]'
        '1:LinkML schema YAML:_files -g "*.(yaml|yml)"'
    )
    _arguments -s -S $args
}

_gen-erdiagram "$@"
