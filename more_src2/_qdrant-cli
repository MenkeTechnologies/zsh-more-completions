#compdef qdrant-cli
# Documentation: https://github.com/qdrant/qdrant/blob/master/src/main.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '--bootstrap+[bootstrap node]:url:' \
  '--uri+[bootstrap URI]:url:' \
  '--snapshot+[snapshot URL]:url:' \
  '--storage-snapshot+[storage snapshot]:file:_files' \
  '--config-path+[config file]:file:_files -g "*.yaml *.yml"' \
  '--disable-telemetry[disable telemetry]' \
  '--reinit[reinit cluster]' \
  '--force-snapshot[force snapshot recovery]' \
  '*: :_files' && ret=0

return ret
