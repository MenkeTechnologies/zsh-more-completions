#compdef gtkwave2 gtkwave-3.4
# _gtkwave2 — Tony Bybell GTKWave 2 series CLI for the digital waveform viewer reading VCD FST GHW LXT2 raw VPD evcd opening save files setting marker zoom geometry signal-search highlighting per-trace colors (gtkwave team, C); getopt
# upstream: https://github.com/gtkwave/gtkwave

_gtkwave2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-D[debug]' \
        '--debug-mode[debug mode]' \
        '-A[autoreload]' \
        '--autoreload[autoreload]' \
        '-a+[save file]:file:_files -g "*.sav *.gtkw"' \
        '--save=+[save file]:file:_files -g "*.sav *.gtkw"' \
        '-c[checktime]' \
        '--checktime[checktime]' \
        '-C+[colour table]:file:_files' \
        '--colour-table=+[colour table]:file:_files' \
        '-f+[trace file]:file:_files -g "*.vcd *.fst *.ghw *.lxt2 *.lxt *.evcd *.vpd *.cmt"' \
        '--dump=+[trace file]:file:_files -g "*.vcd *.fst *.ghw *.lxt2 *.lxt *.evcd *.vpd *.cmt"' \
        '-I+[input filter]:file:_files' \
        '--input-filter=+[input filter]:file:_files' \
        '-g[no menus]' \
        '--giga[no menus]' \
        '-H[hierarchy]' \
        '--hierarchy[hierarchy]' \
        '-l[log]' \
        '--logfile=+[log]:file:_files' \
        '-L+[loadtree]:file:_files' \
        '--loadtree=+[loadtree]:file:_files' \
        '-M+[marker]:str:' \
        '--marker=+[marker]:str:' \
        '-N[non-interactive]' \
        '--nogconf[no gconf]' \
        '-o[no overlay]' \
        '--no-overlay[no overlay]' \
        '-O+[output script]:file:_files' \
        '--output=+[output script]:file:_files' \
        '-p[per-trace dumpconfig]' \
        '--per-trace[per-trace dumpconfig]' \
        '-r+[script file]:file:_files -g "*.tcl"' \
        '--rc=+[script file]:file:_files -g "*.tcl"' \
        '-R+[rc-file]:file:_files' \
        '--script=+[script file]:file:_files -g "*.tcl"' \
        '-s+[script-arg]:str:' \
        '-S+[Tcl mode]' \
        '--tcl-init-cmd=+[command]:str:' \
        '-t+[stems file]:file:_files -g "*.stems"' \
        '--stems=+[stems file]:file:_files -g "*.stems"' \
        '-T+[twinwave]' \
        '--twinwave[twinwave]' \
        '-w+[twinwave file]:file:_files' \
        '-W[server mode]' \
        '--wish[server mode]' \
        '*:trace file:_files -g "*.vcd *.fst *.ghw *.lxt2 *.lxt *.evcd *.vpd *.cmt *.gtkw *.sav"'
}

_gtkwave2 "$@"
