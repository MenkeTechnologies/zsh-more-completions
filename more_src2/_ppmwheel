#compdef ppmwheel
# Documentation: man ppmwheel (Netpbm)
# Source: produce a PPM image of a color wheel of given diameter.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-huevalue -huesaturation)-huevalue[hue-vs-value wheel]' \
    '(-huevalue -huesaturation)-huesaturation[hue-vs-saturation wheel]' \
    '-maxval=[max sample value]:N:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:diameter pixels:' \
    && ret=0

return ret
