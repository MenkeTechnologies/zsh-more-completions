#compdef pmstat
# _pmstat — Performance Co-Pilot pmstat (vmstat-like aggregated periodic snapshot of CPU/memory/IO/network from a pmcd(1); -h host, -a archive, -L use local context, -t interval, -s samples, -V verbose, -O start at sample offset, -A align time, -S start time, -T finish time)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmstat/pmstat.c on tip.

_pmstat() {
    _arguments \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-L[local context]' \
        '-t+[interval]:interval:' \
        '-s+[samples]:n:' \
        '-V[verbose]' \
        '-O+[sample offset]:offset:' \
        '-A+[align time]:time:' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-z[use archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-n+[namespace]:file:_files'
}

_pmstat "$@"
