#compdef lpinfo
# Documentation: lpinfo --help (CUPS 26)
# Source: list available CUPS device URIs (-v) or driver models (-m).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-E[encrypt connection to the server]' \
    '-h+[server[:port]]:server:_hosts' \
    '-l[verbose (long) output]' \
    '(-v)-m[show driver models]' \
    '(-m)-v[show devices]' \
    '-U+[username for authentication]:user:_users' \
    '--device-id=[match IEEE 1284 device ID]:device id:' \
    '--exclude-schemes=[URI schemes to exclude]:schemes:' \
    '--include-schemes=[URI schemes to include]:schemes:' \
    '--language=[locale of models to show]:locale:' \
    '--make-and-model=[make and model name]:name:' \
    '--product=[PostScript product name]:name:' \
    '--timeout=[max seconds for device discovery]:seconds:' \
    && ret=0

return ret
