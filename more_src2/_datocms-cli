#compdef datocms-cli
# _datocms-cli — Stefano Verna DatoCMS headless content CMS CLI alias (datocms team, TypeScript); oclif
# upstream: https://github.com/datocms/cli

_datocms-cli() {
    local -a sub=(
        'autocomplete:install autocompletion'
        'environments:destroy:destroy environment'
        'environments:fork:fork environment'
        'environments:index:list environments'
        'environments:primary:set primary environment'
        'environments:promote:promote environment to primary'
        'environments:rename:rename environment'
        'help:show help'
        'maintenance:off:turn off maintenance'
        'maintenance:on:turn on maintenance'
        'migrations:new:scaffold a migration'
        'migrations:run:run migrations'
        'plugins:install:install plugin'
        'plugins:link:link plugin'
        'plugins:list:list plugins'
        'plugins:reset:reset plugins'
        'plugins:uninstall:uninstall plugin'
        'plugins:unlink:unlink plugin'
        'plugins:update:update plugin'
        'profile:remove:remove cli profile'
        'profile:set:set cli profile'
        'profile:settings:show cli profile settings'
        'projects:edit-permissions:open project permissions'
        'projects:index:list projects'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '--profile=+[profile]:str:' \
        '--api-token=+[api token]:str:' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'datocms subcommand' sub ;;
        args)
            case $words[1] in
                environments:fork) _arguments \
                    '1:source environment:' \
                    '2:new environment id:' \
                    '--fast[skip schema copy]' \
                    '--force[delete existing]' ;;
                environments:destroy|environments:promote|environments:rename) _arguments '1:environment id:' '2:new id:' ;;
                migrations:new) _arguments \
                    '1:name:' \
                    '--template=+[template]:file:_files' \
                    '-t+[template]:file:_files' \
                    '--migrations-dir=+[dir]:dir:_files -/' ;;
                migrations:run) _arguments \
                    '--source=+[source env]:str:' \
                    '--destination=+[dest env]:str:' \
                    '--in-place[run in place]' \
                    '--fast-fork[fast fork]' \
                    '--force[force]' \
                    '--migrations-dir=+[dir]:dir:_files -/' ;;
                autocomplete) _arguments '1:shell:(bash zsh)' ;;
            esac
            ;;
    esac
}

_datocms-cli "$@"
