#compdef localectl-cli
# _localectl-cli — systemd localectl control system locale and keyboard layout CLI alias (systemd team, C); custom argparse
# upstream: https://github.com/systemd/systemd

_localectl-cli() {
    local -a sub=(
        'status:show current settings'
        'set-locale:set system locale'
        'list-locales:list available locales'
        'set-keymap:set console keymap'
        'list-keymaps:list available keymaps'
        'set-x11-keymap:set X11 keymap'
        'list-x11-keymap-models:list X11 keymap models'
        'list-x11-keymap-layouts:list X11 keymap layouts'
        'list-x11-keymap-variants:list X11 keymap variants'
        'list-x11-keymap-options:list X11 keymap options'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--no-ask-password[no ask password]' \
        '--no-convert[no convert]' \
        '-H+[host]:host:_hosts' \
        '--host=+[host]:host:_hosts' \
        '-M+[machine]:str:' \
        '--machine=+[machine]:str:' \
        '--no-pager[no pager]' \
        '--json=+[mode]:m:(short pretty off)' \
        '-j[json short]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'localectl subcommand' sub ;;
    esac
}

_localectl-cli "$@"
