#compdef pmdumptext
# _pmdumptext — Performance Co-Pilot pmdumptext (dump one or more PCP metrics in TSV/CSV style for ingestion into spreadsheets and time-series databases; -h host, -a archive, -t interval, -s samples, -d delim, -H header style, -X long header, -G grouping, -o units, -P precision, -m metric list file, -U user; positional metrics)
# upstream: https://github.com/performancecopilot/pcp
# Flags from PCP src/pmdumptext/pmdumptext.cpp on tip.

_pmdumptext() {
    _arguments \
        '-h+[host]:host:_hosts' \
        '-a+[archive]:file:_files' \
        '-L[local context]' \
        '-t+[interval]:interval:' \
        '-s+[samples]:n:' \
        '-d+[delimiter]:delim:' \
        '-c[CSV output]' \
        '-l[long format]' \
        '-H+[header style]:style:' \
        '-X[long header]' \
        '-G+[grouping]:grouping:' \
        '-o+[units]:units:' \
        '-P+[precision]:n:' \
        '-m+[metric list file]:file:_files' \
        '-i+[instance list]:instances:' \
        '-U+[user]:user:_users' \
        '-S+[start time]:time:' \
        '-T+[finish time]:time:' \
        '-O+[sample offset]:offset:' \
        '-A+[align time]:time:' \
        '-z[archive timezone]' \
        '-Z+[timezone]:tz:' \
        '-n+[namespace]:file:_files' \
        '-N[print names with values]' \
        '*:metric:'
}

_pmdumptext "$@"
