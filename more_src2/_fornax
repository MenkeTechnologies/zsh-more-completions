#compdef fornax
# =============================================================================
# fornax — scriptable static site generator using a TYPE-SAFE F# DSL to define
#          page templates.  Written by the ionide team (the F# tooling team
#          behind Ionide for VS Code and FSAutoComplete), Fornax compiles
#          *.fsx scripts at runtime to produce HTML output — every page
#          template is itself a real F# program with full access to FSharp.Core,
#          the .NET BCL, and any NuGet package referenced via `#r "nuget:"`.
#
# Author:  Krzysztof Cieslak / ionide team
# Source:  https://github.com/ionide/Fornax
# CLI:     src/Fornax/Fornax.fs (entry point) — Argu-driven subcommand parser
# Library: Argu (https://github.com/fsprojects/Argu)
#          declarative type-safe F# CLI argument parser
# License: MIT
# Status:  Stable — 256+ stars, used to render fsprojects.github.io, ionide
#          documentation, and a number of community F# blogs.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — F# IS NOW LANGUAGE 42
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy crosses from
# 41 to 42 documented languages.  F# joins the canonical roster alongside:
# Rust, Go, TypeScript-Node, Python, Ruby, Perl, C, C++, Lua, Java, Kotlin,
# Scala, Haskell, OCaml, Elixir, Erlang, Clojure, Common Lisp, Scheme/Racket,
# Julia, Crystal, Pony, Nim, Zig, V, Swift, R, Dart, Fortran, Tcl, Ada, Janet,
# D, Picat, BQN, Frege, Lobster, Curry, Mercury, Wren, Idris2, and now F#.
# fornax is documented as the FIRST F# CLI library variant in the taxonomy
# (Argu) — bringing the total to 195 cross-language CLI library variants.
# -----------------------------------------------------------------------------
#
# WHAT IS F# AND WHY DOES IT WARRANT ITS OWN CLI LIBRARY DOCUMENTATION CATEGORY?
#
# F# is Microsoft's strongly-typed multi-paradigm functional-first language for
# the .NET runtime, originally created by Don Syme at Microsoft Research
# Cambridge in 2005 as a member of the ML family (descended from Standard ML
# and OCaml).  F# runs on the same Common Language Runtime as C# and VB.NET,
# producing IL bytecode that JIT-compiles via RyuJIT or AOT-compiles via the
# .NET Native / ILCompiler / NativeAOT pipelines.  F# is open source under MIT
# license (github.com/dotnet/fsharp), governed by the F# Software Foundation
# (https://fsharp.org) with the language design steered by Don Syme and core
# contributors from Microsoft, Jet.com, G-Research, and the broader community.
#
# F# is distinct from every other language documented in the corpus because:
#
#   * It is the FIRST .NET CLR language documented (C# and VB.NET have CLIs
#     but the corpus has thus far focused on systems and functional ecosystems
#     where the build outputs are not IL bytecode).
#   * It is the FIRST ML-family language with NULL SAFETY BY DEFAULT documented
#     (OCaml and SML allow `option` but allow null via FFI; F# value types are
#     non-null at the language level and reference types require explicit
#     opt-in via Nullable<T> or new F# 9 nullable reference type annotations).
#   * It is the FIRST language documented with TYPE PROVIDERS — compile-time
#     metaprogramming that synthesizes types from external schemas (databases,
#     JSON, XML, CSV, SQL, OData, GraphQL, SwaggerUI) at IDE-cursor time, with
#     full IntelliSense over schemas that change between compilations.
#   * It is the FIRST language documented with COMPUTATION EXPRESSIONS — a
#     general framework for monadic / applicative / monoidal effect tracking
#     that subsumes Haskell's `do`-notation and Scala's `for`-comprehensions
#     while also covering CONTINUATIONS, ASYNC, QUERY, SEQ, RESULT, OPTION,
#     STATE, and arbitrary user-defined CE builders.
#   * It has DISCRIMINATED UNIONS as a first-class concept (sum types via
#     `type Foo = | A | B of int | C of string * int`) — this is what Argu
#     uses to define CLI arguments AS A TYPE.
#
# -----------------------------------------------------------------------------
# THE Argu LIBRARY — F#'S DECLARATIVE CLI ARGUMENT PARSER
# -----------------------------------------------------------------------------
#
# Argu (https://github.com/fsprojects/Argu, 484+ stars) is the DOMINANT F# CLI
# parsing library and the first documented F# CLI library variant in the
# corpus's cross-language taxonomy.  Argu's defining characteristic is that
# the CLI grammar is expressed as a DISCRIMINATED UNION TYPE in F# code:
#
#     type [<CliPrefix(CliPrefix.None)>] Arguments =
#         | New of ParseResults<NewOptions>
#         | Build
#         | Watch of ParseResults<WatchOptions>
#         | Version
#         | Clean
#     with
#         interface IArgParserTemplate with
#             member s.Usage =
#                 match s with
#                 | New _ -> "Create new web site"
#                 | Build -> "Build web site"
#                 | Watch _ -> "Start watch mode rebuilding"
#                 | Version -> "Print version"
#                 | Clean -> "Clean output and temp files"
#
# Each branch of the union represents either a SUBCOMMAND (when payload is
# `ParseResults<SubcommandOptions>`) or a TOP-LEVEL FLAG (when payload is a
# primitive type or unit).  The IArgParserTemplate interface attaches usage
# text to each case via pattern matching.
#
# Argu attributes control CLI surface details:
#   * [<CliPrefix(CliPrefix.None)>]      — subcommand has no -- prefix
#   * [<CliPrefix(CliPrefix.DoubleDash)>] — flags use --long-form (default)
#   * [<CliPrefix(CliPrefix.Dash)>]       — flags use -short-form
#   * [<AltCommandLine("-t", "--tpl")>]   — additional aliases for the same case
#   * [<Mandatory>]                        — flag is required (compile error if omitted)
#   * [<Unique>]                           — flag can be specified at most once
#   * [<EqualsAssignment>]                 — value must be passed via =name=value
#   * [<First>]                            — flag MUST be the first argument
#   * [<Last>]                             — flag MUST be the last argument
#   * [<MainCommand>]                      — flag receives positional arguments
#   * [<NoCommandLine>]                    — case is only usable via config / env
#   * [<NoAppSettings>]                    — case is only usable via CLI
#   * [<CustomAssignment("/")>]            — custom delimiter like /flag/value
#   * [<EnvironmentVariable("MYAPP_FOO")>] — value also read from env var
#   * [<SubCommand>]                       — explicit subcommand marker
#   * [<InheritFromParent>]                — flag is inherited by all subcommands
#
# Argu's TYPE-SAFETY guarantees that:
#   1. The parsed result is statically typed — no string-keyed dict lookups
#   2. Every CLI argument has a corresponding case — adding a CLI flag
#      requires adding a case to the union, which is enforced by exhaustive
#      pattern matching when Usage is implemented
#   3. The CLI grammar is documented IN THE CODE — printing usage is reading
#      the type definition
#
# Argu generates --help text automatically from the union definition.  Usage
# strings come from IArgParserTemplate.Usage; argument types are inferred
# from each case's payload type (int, string, float, bool, FileInfo,
# DirectoryInfo, custom types via `IArgParserTemplate.UsageOfArg`).
#
# THE CONSTRUCTION CALL — `ArgumentParser.Create<Arguments>(programName=...,
#                                                          errorHandler=...)`
#   * The generic type parameter is the discriminated union type
#   * programName is the binary name printed in usage
#   * errorHandler is an `IExiter` implementation controlling exit behavior
#     when parsing fails or --help is requested (fornax implements FornaxExiter)
#
# THE PARSE CALL — `parser.Parse(argv, ?ignoreMissing=, ?ignoreUnrecognized=,
#                                ?raiseOnUsage=)`
#   * Returns `ParseResults<Arguments>`
#   * Subcommand payloads are accessed via `.GetResult(<case>).GetResult(<sub>)`
#   * Flag presence is checked via `.Contains(<case>)`
#   * Positional / multiple values are accessed via `.GetResults(<case>)`
#
# -----------------------------------------------------------------------------
# ARGU VS OTHER F#/.NET CLI LIBRARIES (LANDSCAPE CONTEXT)
# -----------------------------------------------------------------------------
#
# Other .NET CLI parsing libraries that exist and that fornax could have used
# but chose Argu instead:
#
#   * Microsoft.NET.System.CommandLine (dotnet/command-line-api, the official
#     Microsoft .NET CLI parser used by FsAutoComplete, dotnet itself, and
#     `dotnet tool` ecosystem).  System.CommandLine uses RUNTIME builder DSL
#     (`new RootCommand { new Option<bool>("--verbose") }`), NOT compile-time
#     discriminated unions.  More flexible for C# but loses F# type safety
#     benefits.  Will be a SEPARATE entry in the taxonomy when first user
#     binary is documented.
#   * Microsoft.Extensions.CommandLineUtils (deprecated, replaced by
#     System.CommandLine)
#   * CommandLineParser (commandlineparser/commandline) — attribute-driven
#     C# CLI parser; works in F# but loses F# idioms
#   * PowerArgs (adamabdelhamed/PowerArgs) — attribute-driven C# CLI with
#     rich tab completion and TUI rendering
#   * Mono.Options — Mono's classic getopt-style parser, single-file embed
#   * Plossum.CommandLine — older C# parser with attributes
#   * CLAP (Adrotec/CLAP) — convention-based C# CLI dispatch (no relation to
#     Rust clap)
#   * NDesk.Options — predecessor of Mono.Options
#
# Argu's DISCRIMINATED-UNION-AS-CLI-GRAMMAR approach is FUNDAMENTALLY different
# from all of these C#-first libraries because F# discriminated unions don't
# exist in C# at all (record types and class hierarchies are the closest C#
# analogues but both are far more verbose and lack exhaustive pattern matching).
# Argu is to F# what Rust's `clap_derive` is to Rust — a library that
# leverages a feature unique to its host language (DUs / proc-macros) to give
# the CLI parser exhaustiveness checks and zero-boilerplate definition.
#
# -----------------------------------------------------------------------------
# FORNAX'S CLI SURFACE (verbatim from src/Fornax/Fornax.fs)
# -----------------------------------------------------------------------------
#
# Top-level Arguments union (CliPrefix.None — subcommands have no dash prefix):
#
#   | New of ParseResults<NewOptions>      Create new web site
#   | Build                                Build web site
#   | Watch of ParseResults<WatchOptions>  Start watch mode rebuilding
#   | Version                              Print version
#   | Clean                                Clean output and temp files
#
# NewOptions union (CliPrefix.DoubleDash — flags use --long-form):
#
#   | Template of string  -t / --template  Template from HTTPS git repo or local folder
#   | Output of string    -o / --output    Output folder
#
# WatchOptions union (CliPrefix.DoubleDash — flags use --long-form):
#
#   | Port of int         --port           Custom port (default: 8080)
#
# Error handler — FornaxExiter implements IExiter:
#   * If exit code is ErrorCode.HelpText: print msg, exit 0 (clean help exit)
#   * Otherwise: error-log + print msg + exit 1
#
# -----------------------------------------------------------------------------
# WORKFLOW
# -----------------------------------------------------------------------------
#
#   fornax new --template <repo-or-path> --output <dir>
#       Scaffold a new fornax site from a template.  Templates are git repos
#       containing a `loaders/` folder, a `generators/` folder, and a
#       `_public/` output convention.
#
#   fornax build
#       Compile all *.fsx templates against content/ inputs and emit static
#       HTML/CSS/JS to _public/.
#
#   fornax watch [--port 8080]
#       Build once, then serve _public/ on a local HTTP server with WebSocket
#       live-reload triggered by file changes in content/ or templates.
#       Uses Suave for HTTP + Suave.WebSocket for the live-reload signal.
#
#   fornax clean
#       Remove _public/ and clear the generator cache.
#
#   fornax version
#       Print fornax version (from assembly metadata).
#
# =============================================================================

_fornax() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    local -a subcommands

    subcommands=(
        'new:Create new web site from a template'
        'build:Build web site (compile *.fsx templates to _public/)'
        'watch:Start watch mode rebuilding with live-reload'
        'clean:Clean output and temp files'
        'version:Print fornax version'
    )

    _arguments -C \
        '1: :->cmd' \
        '*::arg:->args' && ret=0

    case $state in
        (cmd)
            _describe -t commands 'fornax command' subcommands && ret=0
            ;;
        (args)
            case $line[1] in
                (new)
                    _arguments \
                        '(-t --template)'{-t,--template}'[Template from HTTPS git repo or local folder]:template (git URL or path):' \
                        '(-o --output)'{-o,--output}'[Output folder]:output dir:_directories' \
                        && ret=0
                    ;;
                (watch)
                    _arguments \
                        '--port[Custom port (default: 8080)]:port:_ports' \
                        && ret=0
                    ;;
                (build|clean|version)
                    ;;
                (*)
                    _default && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_fornax "$@"
