#compdef nix-channel
# Documentation: https://nix.dev/manual/nix/stable/command-ref/nix-channel
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--add[add a channel at URL with optional name]:url:' \
  '--remove[remove a channel by name]:name:' \
  '--list[list all subscribed channels]' \
  '--update[update channels (optionally limit to names)]' \
  '--list-generations[list channel profile generations]' \
  '--rollback[rollback to previous channel generation]:generation:' \
  '*:names:' && ret=0

return ret
