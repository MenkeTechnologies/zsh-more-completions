#compdef mem0
# Documentation: https://github.com/mem0ai/mem0/tree/main/cli/python
# Reference accessed: 2026-05-22
# Verified: cli/python/src/mem0_cli/app.py Typer CLI.

# Zsh completion for mem0 - Mem0 memory layer CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--api-key[Mem0 API key]:key:' \
  '--base-url[API base URL]:url:' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mem0 command' \
      'add[add memory]' \
      'search[search memories]' \
      'get[get memory by id]' \
      'list[list memories]' \
      'update[update memory]' \
      'delete[delete memory]' \
      'init[initialize project]' \
      'identify[identify user]' \
      'whoami[show current user]' \
      'status[show status]' \
      'import[import data]' \
      'help[show help]' \
      'config[manage configuration]' \
      'entity[manage entities]' \
      'event[inspect background events]' \
      'agent-rush[agent rush memory commands]' && ret=0
    ;;
  args)
    case $line[1] in
      config)
        if (( CURRENT == 2 )); then
          _values 'config command' 'show[show config]' 'get[get config value]' 'set[set config value]' && ret=0
        fi
        ;;
      entity)
        if (( CURRENT == 2 )); then
          _values 'entity command' 'list[list entities]' 'delete[delete entity]' && ret=0
        fi
        ;;
      event)
        if (( CURRENT == 2 )); then
          _values 'event command' 'list[list events]' 'status[event status]' && ret=0
        fi
        ;;
      agent-rush)
        if (( CURRENT == 2 )); then
          _values 'agent-rush command' 'add[add agent rush memory]' 'search[search agent rush]' && ret=0
        fi
        ;;
    esac
    ;;
esac

return ret
