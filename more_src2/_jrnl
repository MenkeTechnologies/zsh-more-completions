#compdef jrnl
# Documentation: https://jrnl.sh/en/stable/reference-command-line/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version and license]' \
  '--list[list config and journals]' \
  '--encrypt[encrypt journal file]' \
  '--decrypt[decrypt journal file]' \
  '--import[import entries from another journal]' \
  '--file=[import file path]:file:_files' \
  '--format=[output format]:fmt:(boxed calendar dates fancy heatmap json markdown md pretty short tags text txt xml yaml)' \
  '--edit[open selected entries in editor]' \
  '--delete[interactively delete entries]' \
  '--change-time=[change timestamps interactively]:date:' \
  '--tags[list tags and counts]' \
  '--short[show only date and titles]' \
  '--config-override[override config setting]:key:: :value:' \
  '--config-file=[alternate config file]:file:_files' \
  '--debug[print debug info]' \
  '--diagnostic[print diagnostic data]' \
  '-on[entries on date]:date:' \
  '-today-in-history[today over the years]' \
  '-month[entries on this month]:date:' \
  '-day[entries on this day]:date:' \
  '-year[entries of a year]:date:' \
  '-from[entries after/on date]:date:' \
  '-to[entries before/on date]:date:' \
  '-contains[entries containing text]:text:' \
  '-and[match all conditions]' \
  '-starred[only starred entries]' \
  '-tagged[only entries with tags]' \
  '-n[max entries to show]:n:' \
  '-not[exclude entries with tag]:tag:' \
  '*: :' && ret=0

return ret
