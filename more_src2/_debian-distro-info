#compdef debian-distro-info ubuntu-distro-info devuan-distro-info kali-distro-info distro-info
# Documentation: https://manpages.debian.org/distro-info
# Source: deepin-community/distro-info distro-info-util.c — query distribution series metadata (C, getopt_long).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    {-h,--help}'[show help]' \
    '--version[show version]' \
    {-D+,--date=}'[date in YYYY-MM-DD]:date:_default' \
    {-R+,--series=}'[series code name]:series:_default' \
    {-a,--all}'[list all known series]' \
    {-y-,--days=-}'[show days until milestone]::milestone:(created release eol eol-server eol-esm eol-lts eol-elts)' \
    '(-s --stable -S --supported -U --unsupported -e --supported-esm)'{-d,--devel}'[development release]' \
    '(-d --devel -S --supported -U --unsupported -e --supported-esm)'{-s,--stable}'[latest stable release]' \
    '(-d --devel -s --stable -U --unsupported)'{-S,--supported}'[supported releases]' \
    '(-d --devel -s --stable -S --supported)'{-U,--unsupported}'[unsupported releases]' \
    '(-d --devel -s --stable)'{-e,--supported-esm,--elts}'[ESM/ELTS-supported releases]' \
    '(-l --lts -L --latest)'{-l,--lts}'[latest LTS release]' \
    {-o,--oldstable}'[oldstable release]' \
    {-t,--testing}'[testing release]' \
    {-L,--latest}'[latest known release]' \
    '(-f --fullname -r --release)'{-c,--codename}'[show codename (default)]' \
    '(-c --codename -r --release)'{-f,--fullname}'[show full name]' \
    '(-c --codename -f --fullname)'{-r,--release}'[show release version]' \
    {-A+,--alias=}'[alias query]:alias:_default' \
    && ret=0

return ret
