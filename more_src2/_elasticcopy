#compdef elasticcopy
# ============================================================================
# _elasticcopy — zsh completion for datatok/elastic-copy
#                 (`elasticcopy`), a Go bulk Elasticsearch
#                 copy/sample/count/alias CLI built on go-elasticsearch/v7
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/datatok/elastic-copy
#   Maintainer : datatok / ebuildy
#   License    : GPL-3.0
#   Language   : Go
#   Module     : github.com/ebuildy/elastic-copy
#   Binary     : elasticcopy  (cobra rootCmd.Use = "elasticcopy")
#   Last push  : 2022-01-21
#
# WHAT IT IS
#   elastic-copy is "copy data from / to Elasticsearch very fast"
#   — datatok's bulk-IO tool for moving documents between
#   Elasticsearch clusters (or between a cluster and stdout/file).
#   It scrolls the source index in parallel, streams batches through
#   an in-memory pipeline, and writes them to the configured target
#   over the bulk API.  Companion commands count documents, sample a
#   small subset, and replicate alias topology between clusters.
#
# CLI ARGUMENT GRAMMAR  (verbatim from commands/{root,copy,sampler,
#                       count,alias,version}.go spf13/cobra Command
#                       tree)
#   elasticcopy <SUBCOMMAND> [OPTIONS]
#
#   Subcommands:
#     copy | gen                Copy documents from one Elasticsearch
#                               cluster to another (or to stdout)
#       --source <URL>            Source cluster URL
#                                 [default: http://localhost:9200]
#       --target <URL>            Target cluster URL
#                                 [default: stdout]
#       --target_index_type <T>   Target index type (blank → no type)
#       --query <JSON>            JSON-formatted query body
#       --indices <NAME>...       Indices to copy (StringArrayVar,
#                                 repeatable)
#       --count <N>               Document limit (0 = all)
#                                 [default: 0]
#       --read_batch <N>          Scroll batch size
#                                 [default: 100]
#       --write_batch <N>         Bulk write batch size
#                                 [default: 20]
#       --threads <N>             Worker thread count
#                                 [default: 5]
#       --type-override <T>       Force a target type override
#       --fail-fast               Abort on first error
#                                 [default: true]
#
#     sample                    Sample documents from an index
#       --target <URL>            Target cluster URL
#                                 [default: http://localhost:9200]
#       --index <NAME>            Index to sample from
#       --count <N>               Number of sample documents
#                                 [default: 100]
#
#     count                     Count documents
#       --source <URL>            Source cluster URL
#                                 [default: http://localhost:9200]
#       --query <JSON>            JSON-formatted query body
#       --indices <NAME>...       Indices to count (repeatable)
#
#     alias                     Replicate alias topology
#       --source <URL>            Source cluster URL
#                                 [default: http://localhost:9200]
#       --target <URL>            Target cluster URL
#       --filter <REGEX>          Regex to filter aliased indices
#
#     version                   Show version
#
#   Standard cobra auto-flags:
#     -h, --help                Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/elastic/go-elasticsearch/v7
#   v7.16.0` declared in go.mod — the canonical Go Elasticsearch
#   client maintained by Elastic NV (elastic/go-elasticsearch).
#   go-elasticsearch is the auto-generated official client:  typed
#   API-method packages
#   (`esapi.Bulk`, `esapi.Search`, `esapi.Indices*`, `esapi.Cat*`,
#   `esapi.Cluster*`, `esapi.Snapshot*`, …), connection-pool
#   topology discovery with sniffing, BWC matrix for ES 7.x / 8.x
#   / 9.x, and a stdlib-`net/http` transport that supports
#   API-key, basic, and cloud-id authentication.  elastic-copy's
#   `pkg/action/` constructs `elasticsearch.NewClient(cfg)` for
#   both source and target, runs `Search` with `scroll` for the
#   read path, and pipelines batches into a worker pool that
#   issues `Bulk` against the target.  Verified via:
#     gh api repos/datatok/elastic-copy/contents/go.mod
#       → github.com/elastic/go-elasticsearch/v7 v7.16.0
#       → github.com/spf13/cobra v1.3.0
#     gh api repos/datatok/elastic-copy/contents/commands/root.go
#       → rootCmd.Use = "elasticcopy"
#   This entry is the Go=137 leader bump that continues Axis 82
#   (Elasticsearch Client Library) opened at R917 with Rust=
#   elasticsearch (Anaethelion/escli-rs).
#
#   No completion for `elasticcopy` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_elasticcopy() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :_elasticcopy_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                copy|gen)
                    _arguments \
                        '--source=[source cluster URL (default http\://localhost\:9200)]:url:' \
                        '--target=[target cluster URL (default stdout)]:url:' \
                        '--target_index_type=[target index type]:type:' \
                        '--query=[JSON-formatted query body]:query JSON:' \
                        '*--indices=[indices to copy (repeatable)]:index:' \
                        '--count=[document limit (0=all)]:n:' \
                        '--read_batch=[scroll batch size (default 100)]:n:' \
                        '--write_batch=[bulk write batch size (default 20)]:n:' \
                        '--threads=[worker thread count (default 5)]:n:' \
                        '--type-override=[force target type override]:type:' \
                        '--fail-fast[abort on first error (default true)]' && ret=0 ;;
                sample)
                    _arguments \
                        '--target=[target cluster URL]:url:' \
                        '--index=[index to sample from]:index:' \
                        '--count=[number of sample documents (default 100)]:n:' && ret=0 ;;
                count)
                    _arguments \
                        '--source=[source cluster URL]:url:' \
                        '--query=[JSON-formatted query body]:query:' \
                        '*--indices=[indices to count (repeatable)]:index:' && ret=0 ;;
                alias)
                    _arguments \
                        '--source=[source cluster URL]:url:' \
                        '--target=[target cluster URL]:url:' \
                        '--filter=[regex to filter aliased indices]:regex:' && ret=0 ;;
                version)
                    _arguments '(- *)'{-h,--help}'[help]' && ret=0 ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_elasticcopy_commands] )) ||
_elasticcopy_commands() {
    local -a commands
    commands=(
        'copy:copy documents from one Elasticsearch cluster to another'
        'gen:copy (alias)'
        'sample:sample documents from an index'
        'count:count documents'
        'alias:replicate alias topology between clusters'
        'version:show version'
    )
    _describe -t commands 'elasticcopy command' commands
}

_elasticcopy "$@"
