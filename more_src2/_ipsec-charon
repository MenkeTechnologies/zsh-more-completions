  '--debug-net=[debug level for NET subsystem]:level:' \
  '--debug-asn=[debug level for ASN subsystem]:level:' \
  '--debug-enc=[debug level for ENC subsystem]:level:' \
  '--debug-tnc=[debug level for TNC subsystem]:level:' \
  '--debug-imc=[debug level for IMC subsystem]:level:' \
  '--debug-imv=[debug level for IMV subsystem]:level:' \
  '--debug-pts=[debug level for PTS subsystem]:level:' \
  '--debug-tls=[debug level for TLS subsystem]:level:' \
  '--debug-esp=[debug level for ESP subsystem]:level:' \
