#compdef grdselect
# Documentation: https://docs.generic-mapping-tools.org/latest/grdselect.html
# Source: GenericMappingTools/gmt src/grdselect.c — make grid selection based on header info or content (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[area combination]:area:_default' \
    '-C+[point table to filter]:file:_files' \
    '-D+[required increment(s)]:inc:_default' \
    '-E[report as single record (gmt grdselect format)]' \
    '-F+[polygon table to filter]:file:_files' \
    '-G[force download of remote tiled grids]' \
    '-I+[region constraints]:opts:_default' \
    '-L+[line table to filter]:file:_files' \
    '-M+[margins]:margins:_default' \
    '-N+[no-data constraints]:opts:_default' \
    '-R+[region]:region:_default' \
    '-W+[z-range filter]:range:_default' \
    '-Z+[z-min/z-max filter]:range:_default' \
    '*-V[verbose (stackable)]' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-o+[output column selection]:cols:_default' \
    '-r+[grid registration]:reg:(g p)' \
    '*:input grids:_files -g "*.{grd,nc}"' \
    && ret=0

return ret
