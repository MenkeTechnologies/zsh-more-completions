#compdef jaeger-tracegen
# _jaeger-tracegen — Jaeger synthetic trace generator (load testing / smoke test client that emits OTLP spans)
# upstream: https://github.com/jaegertracing/jaeger
# Flags from cmd/tracegen/main.go + internal/tracegen/config.go on tip.

_jaeger-tracegen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-workers=[number of worker goroutines]:n:' \
        '-traces=[number of traces per worker (ignored if -duration is set)]:n:' \
        '-spans=[child spans per trace]:n:' \
        '-attrs=[attributes per child span]:n:' \
        '-attr-keys=[distinct attribute keys]:n:' \
        '-attr-values=[distinct values per attribute]:n:' \
        '-debug[set DEBUG flag on spans to force sampling]' \
        '-firehose[set FIREHOSE flag on spans to skip indexing]' \
        '-pause=[sleep before finishing each span]:dur:' \
        '-duration=[total run duration (overrides -traces if >0)]:dur:' \
        '-service=[service name prefix]:name:' \
        '-services=[number of distinct service-name suffixes]:n:' \
        '-trace-exporter=[trace exporter]:exp:(otlp-http otlp-grpc stdout)' \
        '-adaptive-sampling=[adaptive sampling strategy HTTP endpoint]:url:_urls'
}

_jaeger-tracegen "$@"
