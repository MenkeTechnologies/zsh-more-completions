#compdef okx-cli okx
# _okx-cli — OKX okx-cli CLI command-line frontend wrapping the OKX formerly OKEx cryptocurrency exchange Spot Margin Perpetual Futures Options REST WebSocket API v5 managing accounts orders trades positions balance funding deposit withdrawal transfer asset sub-account market kline tickers depth funding-rate (OKX team, Go); cobra
# upstream: https://www.okx.com/

_okx-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'account:account operations'
        'order:order operations'
        'trade:trade operations'
        'position:position operations'
        'balance:balance operations'
        'funding:funding operations'
        'deposit:deposit operations'
        'withdrawal:withdrawal operations'
        'transfer:transfer operations'
        'asset:asset operations'
        'subaccount:sub-account management'
        'spot:spot operations'
        'margin:margin operations'
        'futures:futures operations'
        'swap:perpetual swap'
        'option:options operations'
        'market:market data'
        'kline:kline candlestick data'
        'ticker:ticker operations'
        'depth:order book depth'
        'instrument:instrument operations'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-key=+[key]:str:' \
        '--api-secret=+[secret]:str:' \
        '--api-passphrase=+[phrase]:str:' \
        '--api-url=+[url]:str:' \
        '--simulated[simulated trading]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'okx-cli subcommand' sub ;;
        args)
            case $words[1] in
                order) _arguments \
                    '1:op:(list place cancel cancel-all amend history mass-cancel batch-place)' \
                    '--inst-id=+[id]:str:' \
                    '--td-mode=+[m]:m:(cash isolated cross spot_isolated)' \
                    '--side=+[s]:s:(buy sell)' \
                    '--ord-type=+[t]:t:(market limit post_only fok ioc optimal_limit_ioc)' \
                    '--sz=+[N]:str:' \
                    '--px=+[N]:str:' \
                    '*:order id:' ;;
                account|trade|position|balance|funding|deposit|withdrawal|transfer|asset|subaccount|spot|margin|futures|swap|option|instrument) _arguments '1:op:(list get create update delete)' '*:id:' ;;
                market|kline|ticker|depth) _arguments \
                    '--inst-id=+[id]:str:' \
                    '--bar=+[b]:b:(1m 3m 5m 15m 30m 1H 2H 4H 6H 12H 1D 1W 1M)' \
                    '--limit=+[N]:n:' ;;
            esac
            ;;
    esac
}

_okx-cli "$@"
