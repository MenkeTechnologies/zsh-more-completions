#compdef kontain
# _kontain — Kontain ultra-lightweight container runtime (Kontain Inc, Go); run microVMs faster than gVisor/Firecracker
# upstream: https://github.com/kontainapp/km

_kontain() {
    local -a sub=(
        'run:run a Kontain payload'
        'build:build a payload'
        'install:install Kontain runtime'
        'config:configure Kontain'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-v --version)'{-v,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'kontain subcommand' sub ;;
    esac
}

_kontain "$@"
