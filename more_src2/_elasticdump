#compdef elasticdump
# Documentation: https://github.com/elasticsearch-dump/elasticsearch-dump
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '--input=[source URL or file]:uri:' \
  '--output=[destination URL or file]:uri:' \
  '--type=[Elasticsearch type]:type:(index settings analyzer mapping data alias template component_template index_template policy)' \
  '--limit=[objects per request]:num:' \
  '--scrollTime=[Elasticsearch scroll time]:time:' \
  '--scrollId=[resume from scroll id]:id:' \
  '--scroll-with-post[use POST instead of GET for scroll]' \
  '--searchBody=[JSON search body]:json:' \
  '--inputTransport=[input transport options]:json:' \
  '--outputTransport=[output transport options]:json:' \
  '--overwrite[overwrite output]' \
  '--debug[enable debug logging]' \
  '--quiet[suppress non-error log output]' \
  '--help[show help]' \
  '*:additional options: _default'
