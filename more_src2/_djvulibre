#compdef djvulibre djview djview4 bzz csepdjvu c44 cjb2 cpaldjvu
# _djvulibre — Léon Bottou DjVuLibre djview reader bzz compressor csepdjvu segmented assembler c44 wavelet encoder cjb2 bitonal encoder cpaldjvu palettized encoder for DjVu document format (djvu team, C++); getopt
# upstream: https://djvu.sourceforge.net/

_djvulibre() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-d+[DPI]:n:' \
        '--dpi=+[DPI]:n:' \
        '-g+[geometry]:str:' \
        '--geometry=+[geometry]:str:' \
        '-page=+[page]:n:' \
        '--page=+[page]:n:' \
        '-zoom=+[zoom]:n:(stretch 25 50 75 100 125 150 200 300)' \
        '--zoom=+[zoom]:n:(stretch 25 50 75 100 125 150 200 300)' \
        '-mode=+[m]:m:(color stencil background foreground black)' \
        '--mode=+[m]:m:(color stencil background foreground black)' \
        '-rotate=+[deg]:n:(0 90 180 270)' \
        '--rotate=+[deg]:n:(0 90 180 270)' \
        '-decode[decode mode]' \
        '--decode[decode mode]' \
        '-encode[encode mode]' \
        '--encode[encode mode]' \
        '-segment+[mode]:m:(plain colour gray dotted dithered halftone fax)' \
        '--segment=+[mode]:m:(plain colour gray dotted dithered halftone fax)' \
        '-format+[fmt]:f:(djvu pnm ppm pgm pbm tiff jpeg ps pdf)' \
        '--format=+[fmt]:f:(djvu pnm ppm pgm pbm tiff jpeg ps pdf)' \
        '-quality=+[1-3]:n:(1 2 3)' \
        '--quality=+[1-3]:n:(1 2 3)' \
        '-slice=+[N+N+N]:str:' \
        '--slice=+[N+N+N]:str:' \
        '-bytes=+[N]:n:' \
        '--bytes=+[N]:n:' \
        '-size=+[N]:n:' \
        '--size=+[N]:n:' \
        '-dpi=+[N]:n:' \
        '-pages=+[range]:str:' \
        '*:file:_files -g "*.djvu *.djv *.djz *.pdf *.ps *.tif *.tiff *.pbm *.pgm *.ppm *.pnm *.jpg *.jpeg *.bmp"'
}

_djvulibre "$@"
