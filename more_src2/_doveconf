#compdef doveconf
# _doveconf — Dovecot config dumper / validator (resolves dovecot.conf, includes, and !include_try directives; prints settings filtered by scope or filter)
# upstream: https://github.com/dovecot/core
# Flags from src/config/doveconf.c (master_service getopt) on tip.

_doveconf() {
    _arguments \
        '-a[dump all settings (default scope, all without hidden)]' \
        '-C[run a full config check (no output if valid)]' \
        '-c+[config file]:file:_files' \
        '-d[dump defaults instead of current values]' \
        '*-f+[dump filter key=value (e.g. service=imap)]:filter:' \
        '-F[full machine-readable output (expand values)]' \
        '-h[hide setting keys (values only)]' \
        '-H[dump human-readable output]' \
        '-I[dump import_environment]' \
        '-n[only non-default settings]' \
        '-N[only set settings]' \
        '-P[do not hide passwords]' \
        '-s[include hidden settings]' \
        '-U[ignore unknown settings]' \
        '-w[hide obsolete-setting warnings]' \
        '-x[expand $variables in output values]' \
        '*:setting-name:'
}

_doveconf "$@"
