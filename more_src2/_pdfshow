#compdef pdfshow
# Documentation: https://manpages.debian.org/testing/mupdf-tools/mutool-show.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream — pdfshow is the mupdf-tools "mutool show" PDF debugging utility.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-p+[use password if file is encrypted]:password:' \
  '-o+[write output to file instead of stdout]:file:_files' \
  '-b[print streams as binary data and omit object header]' \
  '-e[print streams in original encoded (compressed) form]' \
  '1:pdf file:_files -g "*.pdf"' \
  '*:object:(xref trailer encrypt pagetree grep outline)' && ret=0

return ret
