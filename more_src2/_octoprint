#compdef octoprint
# Documentation: https://github.com/OctoPrint/OctoPrint/blob/master/src/octoprint/cli/__init__.py
# Documentation: https://github.com/OctoPrint/OctoPrint/blob/master/src/octoprint/cli/server.py
# Reference accessed: 2026-05-27
# Verified: upstream octoprint Click command group (octoprint.cli) including server.py, systeminfo.py and lazy subgroups

# Zsh completion for OctoPrint (3D printer host server)

local curcontext="$curcontext" state line ret=1

local -a _octoprint_subcommands
_octoprint_subcommands=(
  'serve:start the OctoPrint server'
  'daemon:start, stop, restart or query the daemon (Linux only)'
  'safemode:set the safe mode flag for the next start'
  'systeminfo:collect and print system information'
  'analysis:gcode analysis tools'
  'client:basic OctoPrint API client'
  'config:basic config manipulation'
  'dev:additional commands for development tasks'
  'plugins:additional commands provided by plugins'
  'timelapse:timelapse related commands'
  'user:user management'
)

_arguments -C \
  '(-b --basedir)'{-b+,--basedir=}'[directory for configs, uploads, timelapses, etc.]:basedir:_directories' \
  '(-c --config)'{-c+,--config=}'[config file to use]:config file:_files' \
  '*--overlay=[additional config overlay to use]:overlay file:_files' \
  '*'{-v,--verbose}'[increase logging verbosity]' \
  '--safe[enable safe mode; disables all third-party plugins]' \
  '--no-color[disable colored console output]' \
  '(- *)--version[show OctoPrint version and exit]' \
  '(- *)'{-h,--help}'[show help and exit]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'octoprint subcommand' _octoprint_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      serve)
        _arguments \
          '--host=[host address to bind the server]:host:_hosts' \
          '--port=[port to bind the server]:port:' \
          '-4[bind to IPv4 only (implies --host 0.0.0.0)]' \
          '--ipv4[bind to IPv4 only]' \
          '-6[bind to IPv6 only]' \
          '--ipv6[bind to IPv6 only]' \
          '--logging=[config file to use for configuring logging]:logging config:_files' \
          '--iknowwhatimdoing[allow OctoPrint to run as user root]' \
          '--debug[enable debug mode]' \
          '--ignore-blacklist[disable processing of the plugin blacklist]' \
          '(-b --basedir)'{-b+,--basedir=}'[basedir to use]:basedir:_directories' \
          '(-c --config)'{-c+,--config=}'[config file to use]:config file:_files' \
          '*--overlay=[additional config overlay]:overlay:_files' \
          '*'{-v,--verbose}'[increase logging verbosity]' \
          '--safe[enable safe mode]' \
          '--no-color[disable colored output]' && ret=0
        ;;
      daemon)
        _arguments \
          '--host=[host address to bind the server]:host:_hosts' \
          '--port=[port to bind the server]:port:' \
          '-4[bind to IPv4 only]' \
          '--ipv4[bind to IPv4 only]' \
          '-6[bind to IPv6 only]' \
          '--ipv6[bind to IPv6 only]' \
          '--logging=[logging config file]:logging config:_files' \
          '--iknowwhatimdoing[allow OctoPrint to run as user root]' \
          '--debug[enable debug mode]' \
          '--ignore-blacklist[disable plugin blacklist]' \
          '--pid=[pidfile to use for daemonizing]:pidfile:_files' \
          '(-b --basedir)'{-b+,--basedir=}'[basedir to use]:basedir:_directories' \
          '(-c --config)'{-c+,--config=}'[config file to use]:config file:_files' \
          '*--overlay=[additional config overlay]:overlay:_files' \
          '*'{-v,--verbose}'[increase logging verbosity]' \
          '--safe[enable safe mode]' \
          '--no-color[disable colored output]' \
          '1:command:(start stop restart status)' && ret=0
        ;;
      safemode|systeminfo)
        _arguments \
          '(-b --basedir)'{-b+,--basedir=}'[basedir to use]:basedir:_directories' \
          '(-c --config)'{-c+,--config=}'[config file to use]:config file:_files' \
          '*--overlay=[additional config overlay]:overlay:_files' \
          '*'{-v,--verbose}'[increase logging verbosity]' \
          '--safe[enable safe mode]' \
          '--no-color[disable colored output]' && ret=0
        ;;
      analysis|client|config|dev|plugins|timelapse|user)
        _message "$line[1] subcommand (delegated to lazy-loaded group)" && ret=0
        ;;
      *)
        _files && ret=0
        ;;
    esac
    ;;
esac

return ret
