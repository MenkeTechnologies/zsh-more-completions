#compdef erlfmt
# Documentation: https://github.com/WhatsApp/erlfmt
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# erlfmt: Erlang source code formatter (WhatsApp)

local -a arguments

arguments=(
  '(-h --help)'{-h,--help}'[print help message]'
  '(-v --version)'{-v,--version}'[print version]'
  '(-w --write)'{-w,--write}'[modify formatted files in place]'
  '(-o --out)'{-o+,--out=}'[output directory]:dir:_files -/'
  '(-O --out-full)'{-O+,--out-full=}'[output directory using full paths]:dir:_files -/'
  '--verbose[include debug output]'
  '(-c --check)'{-c,--check}'[verify formatting (exit 1 if unformatted)]'
  '--print-width=[set line length for wrapping]:width:'
  '--require-pragma[require @format pragma in first docblock]'
  '(-i --insert-pragma)'{-i,--insert-pragma}'[insert @format pragma when absent]'
  '--delete-pragma[remove @format pragma from files]'
  '--range=[format specific line range (start-end, inclusive)]:range:'
  '--exclude-files=[exclude specified files from formatting]:pattern:'
  '*:erlang file:_files -g "*.(erl|hrl|escript|app.src)"'
)

_arguments -s $arguments
