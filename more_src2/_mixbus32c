#compdef mixbus32c Mixbus32C
# Documentation: https://github.com/Ardour/ardour/blob/master/gtk2_ardour/opts.cc
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Mixbus32C is built on Ardour and shares its CLI option set.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-a --no-announcements)'{-a,--no-announcements}'[do not contact website for announcements]' \
  '(-A --actions)'{-A,--actions}'[print all possible action names]' \
  '(-b --bindings)'{-b,--bindings}'[print all current key bindings]' \
  '(-B --bypass-plugins)'{-B,--bypass-plugins}'[bypass all plugins]' \
  '(-d --disable-plugins)'{-d,--disable-plugins}'[disable all plugins]' \
  '(-D --debug)'{-D+,--debug=}'[set debug flags]:flag' \
  '(-n --no-splash)'{-n,--no-splash}'[no splash screen]' \
  '(-m --menus)'{-m+,--menus=}'[use menu definitions in FILE]:file:_files' \
  '(-c --name)'{-c+,--name=}'[use this name for the audio backend]:name' \
  '(-N --new)'{-N+,--new=}'[create new session from template]:name' \
  '(-O --no-hw-optimizations)'{-O,--no-hw-optimizations}'[disable hardware optimizations]' \
  '(-S --sync)'{-S,--sync}'[draw the GUI synchronously]' \
  '(-T --template)'{-T+,--template=}'[use template]:tpl' \
  '(-P --no-connect-ports)'{-P,--no-connect-ports}'[do not auto-connect any ports]' \
  '*:session:_files -g "*.ardour"' && ret=0

return ret
