#compdef gazelle
# Documentation: https://github.com/bazel-contrib/bazel-gazelle/blob/master/gazelle-reference.md
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gazelle: BUILD file generator for Bazel (Go and other languages).
_arguments -s -S \
  '-build_file_name=[Bazel build file name]:name:' \
  '-build_tags=[Go build tags]:tags:' \
  '-exclude=[exclude doublestar pattern]:pattern:' \
  '-index=[library indexing mode]:mode:(none lazy all)' \
  '-mode=[output mode]:mode:(fix print diff)' \
  '-repo_root=[repository root]:dir:_files -/' \
  '-remove_noop_keep_comments[remove unnecessary # keep comments]' \
  '-lang=[languages to process]:lang:' \
  '-cpuprofile=[CPU profile output file]:file:_files' \
  '-memprofile=[memory profile output file]:file:_files' \
  '-r[process subdirectories recursively]' \
  '-external=[external dependency mode (Go ext)]:mode:(external vendored static)' \
  '-go_prefix=[import prefix (Go ext)]:prefix:' \
  '-proto=[proto mode (proto ext)]:mode:(default disable disable_global legacy package)' \
  '(-h -help)'{-h,-help}'[show help]' \
  '*:packages or dirs:_files -/'
