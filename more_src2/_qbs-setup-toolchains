#compdef qbs-setup-toolchains
# _qbs-setup-toolchains CLI — Qt Project qbs-setup-toolchains tool detecting installed C C++ Fortran compilers gcc clang msvc mingw iar keil sdcc cosmic xcode-toolchain registering them in qbs settings as named profiles for the qbs build system to pick up without manual JSON editing (Qt Project team, C++); custom argparse
# upstream: https://doc.qt.io/qbs/qbs-setup-toolchains.html

_qbs-setup-toolchains() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--detect[auto-detect toolchains]' \
        '--type=+[type]:t:(gcc clang mingw msvc iar keil sdcc dmc cosmic)' \
        '--compiler-path=+[path]:file:_files' \
        '--profile-name=+[name]:str:' \
        '--system-scope[system scope]' \
        '--user-scope[user scope]' \
        '--settings-dir=+[dir]:dir:_files -/' \
        '*:compiler path:_files'
}

_qbs-setup-toolchains "$@"
