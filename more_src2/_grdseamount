#compdef grdseamount
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/potential/grdseamount.html
# Source: GenericMappingTools/gmt supplements/potential — synthesize bathymetry grid from seamount shape parameters.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-G+[output grid file]:file:_files' \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-A+[mask grid for seamount observations]:file:_files' \
    '-C+[seamount shape]:shape:(c d g p o)' \
    '-D+[Cartesian horizontal distance unit]:unit:_default' \
    '-E[elliptical input format (not circular)]' \
    '-F+[flattening for guyots]:value:_default' \
    '-H+[variable radial density (depth-dependent)]:opts:_default' \
    '-K+[output predicted density cross-section]:file:_files' \
    '-L[list area/volume/mean-height per seamount]' \
    '-M+[write relief grid names + times to file]:file:_files' \
    '-N+[normalize max grid height]:value:_default' \
    '-Q+[construction mode (cumulative/incremental, vol flux)]:opts:_default' \
    '-S+[simulate landslides]:opts:_default' \
    '-T+[time sequence (min/max/inc)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[vertically averaged density grid]:file:_files' \
    '-Z+[background water depth]:depth:_default' \
    '-bi+[binary input format]:format:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-r[pixel registration (default gridline)]' \
    '*:input seamount table:_files' \
    && ret=0

return ret
