#compdef dh_installchangelogs
# Documentation: https://manpages.debian.org/dh_installchangelogs
# Source: Debian/debhelper dh_installchangelogs — install upstream/Debian changelogs (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '(-a --arch)'{-a,--arch}'[only arch-dep packages]' \
    '(-i --indep)'{-i,--indep}'[only arch-indep packages]' \
    '-A[apply files to all -p packages]' \
    '*-p+[apply to package]:pkg:_default' \
    '*-N+[skip package]:pkg:_default' \
    '*-X+[exclude pattern]:pattern:_default' \
    '--name=-[debhelper file suffix]:name:_default' \
    '--no-act[do not act]' \
    '(-k --keep)'{-k,--keep}'[keep changelog with the original name]' \
    '--no-trim[do not trim changelog]' \
    '*-O+[passthrough option]:opt:_default' \
    '*:upstream changelog file:_files' \
    && ret=0

return ret
