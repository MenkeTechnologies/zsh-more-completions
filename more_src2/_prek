#compdef prek
# Documentation: https://github.com/j178/prek
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for prek Git hook runner (pre-commit compatible)

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '1:command:->cmd' \
  '*::args:->args' && ret=0

case $state in
  cmd)
    local -a commands=(
      'install:set up git hooks'
      'install-hooks:install hook dependencies'
      'uninstall:remove git hooks'
      'run:run configured hooks'
      'list:list configured hooks'
      'auto-update:update hook repositories'
      'sample-config:print sample config'
      'validate-config:validate hook config file'
      'validate-manifest:validate hook manifest file'
      'cache:manage prek cache'
      'gc:garbage collect cache'
      'clean:clean prek cache'
      'init-templatedir:init git template dir'
      'try-repo:try a repo as a hook source'
      'util:utility commands'
      'self:manage prek itself'
      'help:print help'
    )
    _describe -t commands 'prek command' commands && ret=0
    ;;
  args)
    _files && ret=0
    ;;
esac

return ret
