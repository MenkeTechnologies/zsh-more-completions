#compdef gat
# Documentation: https://github.com/koki-develop/gat
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# gat: cat alternative with syntax highlighting, written in Go

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-l --lang)'{-l,--lang}'[set language for syntax highlighting]:language' \
  '(-t --theme)'{-t,--theme}'[set color theme]:theme' \
  '(-f --format)'{-f,--format}'[output format]:format' \
  '(-p --pretty)'{-p,--pretty}'[format content prettily]' \
  '(-M --render-markdown)'{-M,--render-markdown}'[render markdown]' \
  '(-b --force-binary)'{-b,--force-binary}'[force binary output]' \
  '(-c --force-color)'{-c,--force-color}'[force colored output]' \
  '(-A --show-all)'{-A,--show-all}'[equivalent to -vET]' \
  '(-E --show-ends)'{-E,--show-ends}'[display $ at line ends]' \
  '(-T --show-tabs)'{-T,--show-tabs}'[display tabs as ^I]' \
  '(-v --show-nonprinting)'{-v,--show-nonprinting}'[display non-printing characters]' \
  '--list-langs[list available languages]' \
  '--list-themes[list available themes]' \
  '--mask-secrets[mask sensitive information]' \
  '--no-resize[do not resize images]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0

return ret
