#compdef diskus
# Documentation: https://github.com/sharkdp/diskus
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# sharkdp/diskus — minimal, fast alternative to `du -sh`.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  {-j+,--threads=}'[thread count]:threads:' \
  '--size-format=[byte size style]:format:(decimal binary)' \
  {-v,--verbose}'[surface filesystem errors]' \
  '--directories=[count directory metadata sizes]:mode:(auto included excluded)' \
  {-b,--apparent-size}'[sum file sizes instead of allocated blocks]' \
  '*:path:_files -/' && ret=0

return ret
