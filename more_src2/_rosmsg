#compdef rosmsg rossrv
# Documentation: http://wiki.ros.org/rosmsg
# Source: ros/ros_comm noetic-devel tools/rosmsg/src/rosmsg/__init__.py — ROS1 message/service definition CLI.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '1:subcommand:((
        show\:"show message/service description"
        info\:"alias for show"
        list\:"list all messages/services"
        md5\:"display md5 sum"
        package\:"list messages/services in a package"
        packages\:"list packages that contain messages/services"
    ))' \
    '*::args:_default' \
    && ret=0

return ret
