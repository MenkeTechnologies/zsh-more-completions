#compdef rbac-tool
# Documentation: https://github.com/alcideio/rbac-tool
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S -C \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    local -a cmds=(
      'analysis:analyze RBAC permissions and highlight overly permissive principals'
      'auditgen:generate RBAC policy from Kubernetes audit events'
      'bash-completion:generate bash completion'
      'generate:generate Role or ClusterRole and reduce use of wildcards'
      'gen:alias for generate'
      'lookup:RBAC lookup by subject (user/group/serviceaccount)'
      'policy-rules:list policy rules for subject'
      'show:generate ClusterRole with all available permissions'
      'visualize:RBAC visualizer'
      'viz:alias for visualize'
      'who-can:show which subjects have permissions to perform an action'
      'whoami:show subject for current context'
      'version:print rbac-tool version'
      'help:help about any command'
    )
    _describe -t commands 'rbac-tool command' cmds && ret=0
    ;;
  args)
    _arguments -s -S \
      '(-h --help)'{-h,--help}'[show help]' \
      '--kubeconfig=[kubeconfig path]:file:_files' \
      '*: : _default' \
      && ret=0
    ;;
esac

return ret
