#compdef packit
# Documentation: https://manpages.debian.org/testing/packit/packit.8.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# packit: packet analysis and injection tool

local curcontext="$curcontext" ret=1

_arguments -C \
  '-m[run mode]:mode:(capture inject trace)' \
  '-t[packet type]:type:(TCP UDP ICMP ARP RARP)' \
  '-i[network interface]:if:_net_interfaces' \
  '-c[packet count]:n:' \
  '-w[write packets to file / wait interval]:value:' \
  '-r[read packets from pcap file]:file:_files -g "*.pcap"' \
  '-s[source address / snaplen]:value:' \
  '-d[destination address]:ip:' \
  '-S[source port]:port:' \
  '-D[destination port]:port:' \
  '-p[payload]:payload:' \
  '-Z[packet length]:bytes:' \
  '-T[TTL]:n:' \
  '-o[type of service]:tos:' \
  '-V[IP protocol number]:proto:' \
  '-F[TCP flags]:flags:' \
  '-W[TCP window size]:n:' \
  '-q[TCP sequence number]:n:' \
  '-a[ACK number]:n:' \
  '-u[urgent pointer]:n:' \
  '-f[set dont-fragment flag]' \
  '-e[source MAC / display link-layer]:addr:' \
  '-E[destination MAC]:addr:' \
  '-A[ARP operation]:op:(1 2 3 4 5 6)' \
  '-y[ARP target IP]:ip:' \
  '-Y[ARP target MAC]:mac:' \
  '-x[ARP sender IP]:ip:' \
  '-X[hex dump / ARP sender MAC]:value:' \
  '-K[ICMP type]:t:' \
  '-C[ICMP code]:c:' \
  '-N[ICMP id]:n:' \
  '-Q[ICMP sequence]:n:' \
  '-g[ICMP redirect gateway]:ip:' \
  '-b[burst rate]:n:' \
  '-n[disable DNS lookups / IP id]:value:' \
  '-G[show timestamp in GMT / network mask]:value:' \
  '-v[verbose]' \
  '-h[host response mode]' \
  '*: :' && ret=0

return ret
