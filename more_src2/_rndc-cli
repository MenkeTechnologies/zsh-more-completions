#compdef rndc-cli
# _rndc-cli — ISC rndc remote name daemon control utility CLI alias (ISC team, C); custom argparse
# upstream: https://github.com/isc-projects/bind9

_rndc-cli() {
    local -a sub=(
        'addzone:add zone to view'
        'delzone:delete zone from view'
        'dnstap:dnstap operations'
        'dumpdb:dump cache to file'
        'flush:flush cache'
        'flushname:flush specific name from cache'
        'flushtree:flush tree from cache'
        'freeze:freeze updates to dynamic zone'
        'thaw:thaw dynamic zone'
        'sync:sync journal to zone file'
        'managed-keys:managed keys operations'
        'modzone:modify zone'
        'showzone:show zone configuration'
        'querylog:enable/disable query log'
        'recursing:show recursing queries'
        'reconfig:reload config and new zones'
        'refresh:refresh zone'
        'reload:reload config and all zones'
        'retransfer:retransfer zone'
        'sec-roots:show secure roots'
        'serve-stale:serve stale operations'
        'showcontrol:show control configuration'
        'sign:sign zone'
        'signing:show signing operations'
        'stats:write stats to file'
        'status:show server status'
        'stop:stop server'
        'tcp-timeouts:show/set TCP timeouts'
        'trace:increase debug level'
        'tsig-list:list TSIG keys'
        'tsig-delete:delete TSIG key'
        'validation:enable/disable validation'
        'view:view operations'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b+[source address]:str:' \
        '-c+[config file]:file:_files -g "rndc.conf"' \
        '-k+[key file]:file:_files -g "rndc.key"' \
        '-s+[server]:host:_hosts' \
        '-p+[port]:port:' \
        '-q[quiet]' \
        '-r[show result code]' \
        '-V[verbose]' \
        '-y+[key]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'rndc subcommand' sub ;;
    esac
}

_rndc-cli "$@"
