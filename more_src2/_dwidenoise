#compdef dwidenoise
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dwidenoise.html
# Source: MRtrix3/mrtrix3 cmd/dwidenoise.cpp — random matrix theory PCA denoising (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask+[binary mask of voxels to process]:file:_files -g "*.{nii,nii.gz,mif}"' \
    '-extent+[denoising patch window size]:window:_default' \
    '-noise+[output noise (sigma) map]:file:_files' \
    '-datatype+[eigenvalue datatype]:dtype:(float32 float64)' \
    '-estimator+[noise estimator]:est:(Exp1 Exp2)' \
    '1:dwi (input):_files -g "*.{nii,nii.gz,mif}"' \
    '2:out (denoised DWI):_files' \
    && ret=0

return ret
