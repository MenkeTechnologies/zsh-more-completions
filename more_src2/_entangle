#compdef entangle
# Documentation: https://manpages.debian.org/bookworm/entangle/entangle.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm entangle(1) manpage OPTIONS.
# Removed from prior file: fabricated -h/-V flags (uses --help only) and
# bogus man.archlinux.org search URL.

# entangle: tethered camera capture via libgphoto2
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show command line option summary]' \
  '--help-all[show all command line options]' \
  '--help-gtk[show GTK+ command line options]' \
  '--help-entangle[show Entangle-specific command line options]' \
  '--debug-entangle[enable debugging of Entangle application code]' \
  '--debug-gphoto[enable debugging of gphoto library code]' && ret=0
return ret
