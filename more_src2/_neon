#compdef neon
# Documentation: https://github.com/neondatabase/neonctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. The 'neon' binary is the
# standalone Neon CLI distribution; functionally identical to 'neonctl'.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'auth:authenticate with Neon'
  'me:show current user info'
  'projects:manage projects'
  'ip-allow:manage IP allow list'
  'branches:manage branches'
  'databases:manage databases'
  'roles:manage roles'
  'operations:manage operations'
  'connection-string:get connection string'
  'cs:alias for connection-string'
  'set-context:set CLI context'
  'completion:generate shell completions'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--api-key=[Neon API key]:key:' \
  '(-o --output)'{-o,--output}'=[output format]:format:(json yaml table)' \
  '--project-id=[project ID]:id:' \
  '--config-dir=[config directory]:dir:_directories' \
  '--analytics[enable analytics]' \
  '--no-analytics[disable analytics]' \
  '--color=[color mode]:mode:(auto always never)' \
  '1:command:->commands' \
  '*:: :->args' && ret=0

case $state in
  (commands)
    _describe -t commands 'neonctl command' commands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (projects)
        local -a project_cmds=(
          'list:list projects'
          'create:create a project'
          'get:get project details'
          'update:update a project'
          'delete:delete a project'
        )
        _describe -t commands 'project command' project_cmds && ret=0
        ;;
      (branches)
        local -a branch_cmds=(
          'list:list branches'
          'create:create a branch'
          'get:get branch details'
          'rename:rename a branch'
          'set-default:set default branch'
          'set-primary:set primary branch'
          'add-compute:add compute to branch'
          'delete:delete a branch'
          'reset:reset a branch'
          'restore:restore a branch'
        )
        _describe -t commands 'branch command' branch_cmds && ret=0
        ;;
      (databases)
        local -a db_cmds=(
          'list:list databases'
          'create:create a database'
          'delete:delete a database'
        )
        _describe -t commands 'database command' db_cmds && ret=0
        ;;
      (roles)
        local -a role_cmds=(
          'list:list roles'
          'create:create a role'
          'delete:delete a role'
        )
        _describe -t commands 'role command' role_cmds && ret=0
        ;;
      (connection-string)
        _arguments \
          '--branch-name[branch name]:name:' \
          '--database-name[database name]:name:' \
          '--role-name[role name]:name:' \
          '--pooled[use pooled connection]' \
          '--prisma[Prisma format]' \
          '--extended[show extended info]' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
