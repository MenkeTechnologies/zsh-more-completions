#compdef kubectl-actuator
# Documentation: https://github.com/deviceinsight/kubectl-actuator/blob/main/internal/cmd/base.go
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# kubectl-actuator interacts with Spring Boot Actuator endpoints of pods.

local curcontext="$curcontext" state line ret=1

local -a persistent_flags=(
  '*'{-p+,--pod=}'[select target pod(s)]:pod:'
  '*'{-d+,--deployment=}'[select target deployment(s)]:deployment:'
  '*'{-l+,--selector=}'[select target pod(s) by label selector]:selector:'
  '--port=[override actuator port]:port:'
  '--base-path=[override actuator base path]:path:'
  '(-n --namespace)'{-n+,--namespace=}'[namespace scope]:namespace:'
  '--kubeconfig=[path to the kubeconfig file]:file:_files'
  '--context=[kubeconfig context]:context:'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  $persistent_flags \
  '1:command:->commands' \
  '*::arg:->args' && ret=0

case $state in
  commands)
    local -a commands=(
      'logger:list loggers or change a logger level'
      'health:show application health'
      'info:show application info'
      'metrics:list or show metrics'
      'env:show environment properties'
      'beans:list application beans'
      'scheduled-tasks:show scheduled tasks'
      'threaddump:show a thread dump'
      'raw:call a raw actuator endpoint'
      'version:print version'
    )
    _describe -t commands 'kubectl-actuator command' commands && ret=0
    ;;
  args)
    case $line[1] in
      logger)
        _arguments -s -S $persistent_flags \
          '--all-loggers[show all loggers]' && ret=0
        ;;
      health|scheduled-tasks)
        _arguments -s -S $persistent_flags \
          '(-o --output)'{-o+,--output=}'[output format]:format:(wide)' && ret=0
        ;;
      metrics)
        _arguments -s -S $persistent_flags \
          '(-f --filter)'{-f+,--filter=}'[filter metrics by name pattern]:pattern:' && ret=0
        ;;
      env)
        _arguments -s -S $persistent_flags \
          '(-f --filter)'{-f+,--filter=}'[filter properties by name pattern]:pattern:' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(name)' && ret=0
        ;;
      beans)
        _arguments -s -S $persistent_flags \
          '(-f --filter)'{-f+,--filter=}'[filter beans by name pattern]:pattern:' \
          '(-o --output)'{-o+,--output=}'[output format]:format:(wide name)' && ret=0
        ;;
      threaddump)
        _arguments -s -S $persistent_flags \
          '(-o --output)'{-o+,--output=}'[output format]:format:(wide)' \
          '--state=[filter by thread state]:state:(BLOCKED WAITING RUNNABLE TIMED_WAITING NEW TERMINATED)' \
          '--name=[filter by thread name pattern]:pattern:' \
          '--summary[show only thread state summary]' && ret=0
        ;;
    esac
    ;;
esac

return ret
