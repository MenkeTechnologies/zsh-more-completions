#compdef dnsline
# ============================================================================
# _dnsline — zsh completion for AlfredBerg's dnsline, a Go DNS
#             pipeline tool (resolve / soa / statusdiff / responsediff)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/AlfredBerg/dnsline
#   Author     : Alfred Berg
#   Language   : Go
#   Module     : github.com/AlfredBerg/dnsline
#   Binary     : dnsline  (built from root main.go)
#   Last push  : 2024-08-14
#
# WHAT IT IS
#   dnsline is "a tool for making it easy to collect DNS results
#   from the CLI" — a pipeline-friendly bulk DNS resolver that reads
#   domains line-by-line from stdin or a file, fans them out across
#   a worker-pool, and prints one structured result line per domain.
#   Four operating modes are available:  `resolve` (full CNAME chain
#   + final A/AAAA), `soa` (closest Start-Of-Authority FQDN),
#   `statusdiff` (detect status divergence between an authoritative
#   nameserver set), and `responsediff` (detect address divergence
#   between authoritative nameservers).  Internally each worker
#   uses a `miekg/dns` client and a `patrickmn/go-cache` cache for
#   nameserver records.
#
# CLI ARGUMENT GRAMMAR  (verbatim from main.go `flag` package
#                       definitions)
#   dnsline [OPTIONS]    (reads domains from stdin or `-i <FILE>`)
#
#   Options:
#     -q                Query for AAAA records instead of A records
#     -x                Disable the nameserver cache (every query
#                       starts from the DNS ROOT)
#     -c <N>            Number of goroutines that try to resolve
#                       domains  [default: 10]
#     -i <FILE>         File to read input from (if stdin is not
#                       used)
#     -m <MODE>         Operating mode  [default: resolve]
#                         resolve       Resolve domains;  output
#                                       full CNAME chain and all
#                                       IPs
#                         soa           Print FQDN of the closest
#                                       Start-Of-Authority
#                         statusdiff    Detect status divergence
#                                       between authoritative
#                                       nameservers
#                         responsediff  Detect resolved-address
#                                       divergence between
#                                       authoritative nameservers
#
#   Standard Go flag-package auto-flags:
#     -h, --help        Show help
#
# AXIS / CORPUS POSITION
#   Direct dependency on `github.com/miekg/dns v1.1.62` declared in
#   go.mod — the canonical Go DNS protocol library maintained by
#   Miek Gieben (miekg/dns).  miekg/dns is the de-facto Go DNS
#   implementation:  full RR-type coverage (A, AAAA, CNAME, NS,
#   MX, TXT, SOA, SRV, DNSKEY, RRSIG, NSEC, NSEC3, DS, TLSA, SVCB,
#   HTTPS, CAA, ...), DNSSEC signing + validation, TSIG message
#   authentication, an async `Client`, a `ServeMux` server with
#   pluggable transports (UDP, TCP, DNS-over-TLS, DNS-over-HTTPS,
#   DNS-over-QUIC), and zone-file parsing/marshaling.  dnsline's
#   `resolver/` package and `main.go` import the library directly,
#   constructing `new(dns.Client)` instances per worker and
#   selecting RR types via `dns.TypeA` / `dns.TypeAAAA`.  Verified
#   via:
#     gh api repos/AlfredBerg/dnsline/contents/go.mod
#       → github.com/miekg/dns v1.1.62
#     gh api repos/AlfredBerg/dnsline/contents/main.go
#       → import "github.com/miekg/dns"
#         recordType := dns.TypeA
#         client := new(dns.Client)
#   This entry is the Go=131 leader bump that continues Axis 76
#   (DNS Protocol Library) opened at R893 with Rust=hickory-resolver
#   + hickory-server (hickory-dns/hickory-dns).
#
#   No completion for `dnsline` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_dnsline() {
    _arguments -s \
        '-q[query for AAAA records instead of A records]' \
        '-x[disable the nameserver cache (queries start from DNS root)]' \
        '-c+[number of goroutines (default 10)]:concurrency:' \
        '-i+[input file (default: read from stdin)]:input file:_files' \
        '-m+[operating mode (default resolve)]:mode:(resolve soa statusdiff responsediff)' \
        '(- *)'{-h,--help}'[show help]'
}

_dnsline "$@"
