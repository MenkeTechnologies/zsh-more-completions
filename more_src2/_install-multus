#compdef install-multus install_multus
# _install-multus — Multus CNI install-binary helper (k8snetworkplumbingwg/multus-cni)
# upstream: https://github.com/k8snetworkplumbingwg/multus-cni
# Flags from cmd/install_multus/main.go on tip.

_install-multus() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-t --type)'{-t,--type=}'[installer type]:type:(thick thin)' \
        '(-d --dest-dir)'{-d,--dest-dir=}'[destination CNI bin directory]:dir:_files -/'
}

_install-multus "$@"
