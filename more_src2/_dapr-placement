#compdef dapr-placement
# _dapr-placement — Dapr Actor placement service (dapr/dapr)
# upstream: https://github.com/dapr/dapr
# Flags from cmd/placement/options/options.go on tip.

_dapr-placement() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--id=[placement server ID]:id:' \
        '*--initial-cluster=[raft cluster peers (id=host:port,...)]:list:' \
        '--inmem-store-enabled=[enable in-memory raft store]:bool:(true false)' \
        '--raft-logstore-path=[on-disk raft log store path]:dir:_files -/' \
        '--port=[placement gRPC bind port]:port:' \
        '--listen-address=[placement gRPC bind address]:ip:' \
        '--healthz-port=[healthz bind port]:port:' \
        '--healthz-listen-address=[healthz bind address]:ip:' \
        '--tls-enabled=[enable TLS on placement gRPC]:bool:(true false)' \
        '--metadata-enabled=[expose placement tables on healthz]:bool:(true false)' \
        '--replicationFactor=[actor distribution replication factor]:n:' \
        '--keepalive-time=[gRPC keepalive ping interval (1-10s)]:dur:' \
        '--keepalive-timeout=[gRPC keepalive response timeout (1-10s)]:dur:' \
        '--disseminate-timeout=[max time a dissemination round may take]:dur:' \
        '--disseminate-coalesce-window=[post-round coalesce window (0 disables)]:dur:' \
        '--trust-domain=[control plane trust domain]:domain:' \
        '--trust-anchors-file=[control plane trust anchors file]:file:_files' \
        '--sentry-address=[Dapr Sentry host\:port]:host\:port:' \
        '--mode=[runtime mode]:mode:(kubernetes standalone)' \
        '--log-level=[log level]:level:(debug info warn error fatal panic)' \
        '--log-as-json[log as JSON]' \
        '--enable-metrics[enable Prometheus metrics endpoint]' \
        '--metrics-port=[Prometheus metrics bind port]:port:'
}

_dapr-placement "$@"
