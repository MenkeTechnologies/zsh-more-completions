#compdef grub-btrfs
# Zsh completion for grub-btrfs - Include btrfs snapshots in GRUB boot menu
# https://github.com/Antynea/grub-btrfs

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '-e[exclude specific snapshots]:snapshot path:_files -/' \
  '-b[specify path to grub directory]:grub directory:_files -/' \
  '-g[specify path to grub.cfg]:grub.cfg path:_files' \
  '-l[limit number of snapshots]:number:' \
  '-o[set snapshot search offset]:offset:' \
  '-t[show snapshots from specific timeframe]' \
  '-v[verbose output]' \
  '--timeshift-auto[auto-detect Timeshift snapshots]'
