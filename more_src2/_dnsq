#compdef dnsq
# Documentation: https://manpages.debian.org/testing/djbdns/dnsq.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# dnsq from djbdns: sends a non-recursive DNS query.
# Synopsis: dnsq type fqdn server

local curcontext="$curcontext" ret=1

_arguments -C \
  '1:type:(a aaaa ns mx cname ptr txt soa srv hinfo any axfr)' \
  '2:fqdn:_hosts' \
  '3:server:_hosts' && ret=0

return ret
