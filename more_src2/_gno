#compdef gno
# ============================================================================
# gno - Gno language CLI for the Gno
#        blockchain VM + smart contract dev
#        toolchain (Go, NOASSERTION/permissive)
#
# Author : Jae Kwon + the gnolang
#           organization
# Upstream: https://github.com/gnolang/gno
# Website: https://gno.land
#
# `gno` is the developer CLI for Gno, an
# interpreted variant of Go that runs inside
# a deterministic virtual machine on the
# gno.land blockchain. Gno smart contracts
# ("realms") are written in Gno syntax (a
# subset/variant of Go) and deployed to the
# chain. The CLI mirrors the structure of the
# `go` toolchain (gno fmt + gno test + gno
# run + gno doc + gno mod + ...) to provide
# familiar workflows for Go developers
# transitioning to blockchain smart contract
# development.
#
# Architecture:
#   - **Gno language**: Go-like syntax with
#     deterministic semantics (no goroutines
#     + no networking + no filesystem in
#     contract context; replaced with realm-
#     specific primitives)
#   - **GnoVM**: stack-based interpreter
#     embedded in the validator nodes;
#     deterministic execution for consensus
#   - **gno.land blockchain**: built on
#     Tendermint v2 (tm2) for BFT
#     consensus
#   - **Realms**: stateful smart contracts
#     (analogous to Ethereum contracts but
#     written in Gno)
#   - **Pure packages**: stateless utility
#     libraries (analogous to standard
#     libraries; importable by realms)
#
# Distinguishing features vs alternatives
# (Solidity + Move + Rust-based smart
# contract chains):
#   - **Go-syntax familiarity** (lowest
#     onboarding cost for the world's ~2M
#     Go developers)
#   - **Interpreted at the VM** (no
#     compilation to bytecode; source is
#     stored on-chain + executed by an
#     interpreter; means contract source is
#     always available + auditable)
#   - **Generics + Interfaces** (Gno has
#     Go 1.18+ generics + Go interfaces;
#     more expressive than Solidity)
#   - **Deterministic by construction**
#     (no non-deterministic primitives like
#     time.Now() or rand.Float64() in
#     realm context)
#   - **Open-source first** (entire stack
#     including blockchain + CLI + VM is
#     open source)
#
# Use cases:
#   - Developer tooling for writing + testing
#     + deploying Gno smart contracts
#   - Linting Gno source files (gno lint)
#   - Formatting Gno source code (gno fmt)
#   - Testing realm code locally (gno test)
#   - Inspecting Gno package documentation
#     (gno doc)
#   - Running Gno scripts locally without
#     deploying to chain (gno run)
#   - Interactive Gno REPL (gno repl)
#   - Package management (gno mod)
#   - Migration tooling for Gno language
#     changes (gno fix)
#
# Usage:
#   gno [-C <dir>] <subcommand> [args]
#
# Global flag:
#   -C <dir>                       - change to
#                                     directory
#                                     before
#                                     running
#                                     command
#                                     (similar
#                                     to make
#                                     -C)
#
# Top-level subcommands (mirrors `go`
# toolchain):
#   bug                            - report a
#                                     gno bug
#                                     to the
#                                     issue
#                                     tracker
#   clean                          - remove
#                                     build
#                                     artifacts
#                                     +
#                                     cached
#                                     test
#                                     results
#   doc                            - show
#                                     documentation
#                                     for
#                                     package
#                                     or symbol
#                                     (analogous
#                                     to go
#                                     doc)
#   env                            - print Gno
#                                     environment
#                                     variables
#                                     (GOROOT
#                                     equivalent
#                                     for Gno)
#   fix                            - update
#                                     Gno
#                                     source
#                                     to use
#                                     newer
#                                     APIs
#                                     after
#                                     language
#                                     changes
#   fmt                            - format
#                                     Gno
#                                     source
#                                     (analogous
#                                     to
#                                     gofmt)
#   list                           - list
#                                     packages
#                                     under a
#                                     path
#                                     (analogous
#                                     to go
#                                     list)
#   lint                           - lint
#                                     Gno
#                                     source
#   mod                            - module
#                                     maintenance
#                                     (init +
#                                     download
#                                     + tidy +
#                                     verify)
#   repl                           - start
#                                     interactive
#                                     Gno REPL
#   run                            - run Gno
#                                     scripts
#                                     locally
#                                     (without
#                                     chain
#                                     deployment)
#   test                           - run Gno
#                                     package
#                                     tests
#   tool                           - run a
#                                     gno
#                                     internal
#                                     tool
#                                     (transpile
#                                     + ...)
#   version                        - show
#                                     gno + Go
#                                     toolchain
#                                     versions
#
# `doc` flags:
#   -all                           - show all
#                                     documentation
#                                     for
#                                     package
#   -src                           - show
#                                     source
#                                     code
#                                     instead
#                                     of just
#                                     summary
#   -u                             - include
#                                     unexported
#                                     identifiers
#   -short                         - one-line
#                                     summary
#                                     only
#   -root-dir <path>               - clone
#                                     location
#                                     of
#                                     github.com/
#                                     gnolang/
#                                     gno
#
# `fmt` flags:
#   -w                             - write
#                                     formatted
#                                     content
#                                     back to
#                                     source
#                                     file
#   -v                             - verbose
#                                     output
#   -q                             - quiet
#                                     output
#   -imports                       - also fix
#                                     imports
#                                     (like
#                                     goimports)
#   -diff                          - show diff
#                                     instead
#                                     of
#                                     writing
#                                     files
#
# `test` flags:
#   -v                             - verbose
#                                     output
#   -failfast                      - stop on
#                                     first
#                                     test
#                                     failure
#   -update-golden-tests           - update
#                                     golden
#                                     test
#                                     files
#   -root-dir <path>               - clone
#                                     location
#                                     of
#                                     github.com/
#                                     gnolang/
#                                     gno
#   -auto-gnomod                   - auto-
#                                     generate
#                                     gnomod
#                                     .toml
#                                     if not
#                                     present
#                                     (default
#                                     true)
#   -run <regex>                   - run only
#                                     tests
#                                     matching
#                                     regex
#   -print-runtime-metrics         - print VM
#                                     runtime
#                                     metrics
#                                     after
#                                     each
#                                     test
#   -print-events                  - print
#                                     emitted
#                                     events
#                                     during
#                                     tests
#   -debug                         - enable
#                                     debugger
#                                     at start
#   -debug-addr <addr>             - debugger
#                                     server
#                                     address
#
# `lint` flags:
#   -v                             - verbose
#                                     output
#   -root-dir <path>               - clone
#                                     location
#                                     of
#                                     github.com/
#                                     gnolang/
#                                     gno
#   -auto-gnomod                   - auto-
#                                     generate
#                                     gnomod
#                                     .toml
#                                     if not
#                                     present
#                                     (default
#                                     true)
#
# `run` flags:
#   -v                             - verbose
#                                     output
#   -root-dir <path>               - clone
#                                     location
#                                     of
#                                     github.com/
#                                     gnolang/
#                                     gno
#   -expr <expression>             - expression
#                                     to run
#                                     in the
#                                     package
#                                     context
#
# Example invocations:
#   # Show available subcommands
#   gno
#
#   # Format a Gno file in place
#   gno fmt -w realm.gno
#
#   # Run all tests in current package
#   gno test ./...
#
#   # Run specific test with verbose output
#   gno test -v -run TestMyContract
#
#   # Show docs for a Gno standard package
#   gno doc -all gno.land/p/demo/avl
#
#   # Lint a project
#   gno lint ./...
#
#   # Migrate source after language change
#   gno fix ./...
#
#   # Initialize a new Gno module
#   gno mod init gno.land/r/myname/realm
#
#   # Interactive REPL
#   gno repl
#
#   # Run a Gno script (no chain interaction)
#   gno run examples/hello.gno
#
#   # Show Gno environment
#   gno env
#
#   # Show versions
#   gno version
#
# The yuin/goldmark lane is built on
# `github.com/yuin/goldmark v1.7.16` +
# `github.com/yuin/goldmark-highlighting/v2
# v2.0.0-20230729083705-37449abec8cc`
# (declared verbatim at upstream go.mod HEAD
# as direct deps, imported by `gno.land/
# pkg/gnoweb/` for rendering Gno documentation
# + realm source code on the gnoweb portal
# at gno.land), the canonical Go CommonMark
# parser by Yusuke Inuzuka (yuin) -
# github.com/yuin/goldmark.
#
# yuin/goldmark is the de-facto canonical
# Go CommonMark parser:
#   - **CommonMark v0.30 spec compliant**
#     (passes the official CommonMark test
#     suite at github.com/commonmark/
#     commonmark-spec)
#   - **GFM extensions** (tables +
#     strikethrough + tasklists +
#     autolinks + footnotes per the
#     GitHub Flavored Markdown spec)
#   - **Pure-Go implementation** (no CGO)
#   - **Extensible architecture**
#     (pluggable extensions via the
#     Extension interface; goldmark-
#     highlighting + goldmark-mermaid +
#     goldmark-wikilink + goldmark-meta
#     + many community extensions)
#   - **Used by Hugo** (THE most-deployed
#     static site generator; Hugo's
#     default markdown renderer is
#     goldmark since v0.62 + 2020)
#   - **3,200+ stars on github.com/
#     yuin/goldmark**
#   - **~9,000 reverse-deps on
#     pkg.go.dev (one of the most-
#     imported Go libraries in the
#     documentation + static-site
#     space)**
#
# yuin/goldmark's distinguishing position
# vs Go markdown alternatives:
#   - yuin/goldmark (Inuzuka): canonical;
#     CommonMark v0.30; pluggable
#     extensions; THIS AXIS
#   - russross/blackfriday: older
#     canonical (pre-goldmark);
#     CommonMark-compatible but
#     non-spec; archived 2022
#   - gomarkdown/markdown (mmark fork):
#     blackfriday continuation; used by
#     mmark (Axis 283 user)
#   - microcosm-cc/bluemonday: HTML
#     sanitizer (paired with markdown
#     renderers for safe HTML
#     generation; smaller scope)
#
# Yusuke Inuzuka (yuin) is a Japanese Go
# engineer specializing in language
# implementation + interpreters:
#   - **goldmark canonical Go CommonMark
#     parser** (THIS AXIS)
#   - **gopher-lua** (canonical pure-Go
#     Lua 5.1 interpreter; ~5,800 stars;
#     embedded in many Go applications
#     for scripting support)
#
# Inuzuka's role in Go is *language
# implementation + parser infrastructure*.
# Both his canonical libraries are
# implementations of well-defined external
# languages/formats (Lua + CommonMark) -
# this language-implementation focus is
# his distinctive contribution pattern.
#
# Multi-axis canonical-Go author/org cohort
# extension (now spanning 24 distinct
# individuals/orgs after R1551):
#   - + Yusuke Inuzuka (yuin/goldmark +
#     yuin/gopher-lua; THIS AXIS;
#     canonical Go CommonMark parser +
#     canonical Go Lua interpreter)
#
# Inuzuka's joining the canonical-Go
# cohort at the *language-implementation +
# parser infrastructure* level extends
# the pattern of *spec-implementer
# canonical authors* documented across
# the corpus.
#
# Notable: Hugo's adoption of goldmark
# (replacing the previously-canonical
# blackfriday) drove goldmark's status
# from a clean-room alternative to the
# de-facto canonical Go CommonMark
# parser. The static-site-generator
# ecosystem's choice often determines
# canonical status in markdown-related
# verticals.
#
# gno uses goldmark for:
#   - Rendering Gno realm documentation
#     comments (the `doc.go` style
#     package documentation) to HTML
#     for the gnoweb portal at gno.land
#   - Rendering markdown README files in
#     realm packages
#   - Code-highlighting in rendered
#     markdown (via goldmark-highlighting
#     paired with chroma)
#
# This is the canonical use case for
# goldmark in Go applications: rendering
# user-authored markdown content for web
# display, with extensions for syntax-
# highlighted code blocks (a common
# requirement for documentation +
# technical blog rendering).
#
# ----------------------------------------------------------------------------
# AXIS 284 :: Markdown / CommonMark parsing
#              libraries
#              (CommonMark v0.30 spec
#              compliant parsers; GFM
#              extension support; AST
#              vs event-stream parsers)
# Round 1551 :: Go slot 2 of 4 :: continues Axis 284
#
# Cross-language canonical library family
# for this axis:
#   Rust    : pulldown-cmark/pulldown-cmark [R1550 _mdbook-epub]
#             (Raph Levien + Marcus Klaas;
#              canonical Rust CommonMark;
#              event-stream API)
#   Go      : yuin/goldmark              [R1551 THIS FILE]
#             (Yusuke Inuzuka; canonical
#              Go CommonMark; used by Hugo;
#              extensible architecture)
#   TS/Node : markedjs/marked            [R1552 closing]
#             (Christopher Jeffrey + Tony
#              Brix; canonical Node
#              markdown; ~17M weekly npm
#              downloads)
#
# Use-case spectrum across the lanes (so far):
#   - mdbook-epub (Rust, pulldown-cmark):
#     EPUB rendering for mdbook
#     technical books + Rust documentation
#   - gno (Go, goldmark): Gno blockchain
#     smart contract developer CLI;
#     goldmark used for rendering realm
#     documentation + source comments on
#     the gnoweb portal
#
# Both use cases share the *technical
# documentation rendering* pattern -
# markdown source maintained alongside
# code, rendered to a presentation
# format (EPUB book / HTML page) for
# human consumption. This is the
# canonical CommonMark deployment
# pattern in production Rust + Go
# infrastructure.
# ============================================================================

_gno() {
    local context state state_descr line
    typeset -A opt_args
    local curcontext="$curcontext" ret=1

    _arguments -C \
        '-C+[change to directory before running]:dir:_files -/' \
        '1: :_gno_cmds' \
        '*::arg:->args' \
    && ret=0

    case $state in
        args)
            case $words[1] in
                doc)
                    _arguments \
                        '-all[show all documentation]' \
                        '-src[show source code]' \
                        '-u[include unexported identifiers]' \
                        '-short[one-line summary only]' \
                        '-root-dir=[gno root dir]:path:_files -/' \
                        '*:package:'
                    ;;
                fmt)
                    _arguments \
                        '-w[write formatted content back to file]' \
                        '-v[verbose output]' \
                        '-q[quiet output]' \
                        '-imports[also fix imports]' \
                        '-diff[show diff instead of writing files]' \
                        '*:file:_files -g "*.gno"'
                    ;;
                test)
                    _arguments \
                        '-v[verbose output]' \
                        '-failfast[stop on first failure]' \
                        '-update-golden-tests[update golden test files]' \
                        '-root-dir=[gno root dir]:path:_files -/' \
                        '-auto-gnomod[auto-generate gnomod.toml]' \
                        '-run=[run only tests matching regex]:regex:' \
                        '-print-runtime-metrics[print VM runtime metrics]' \
                        '-print-events[print emitted events]' \
                        '-debug[enable debugger]' \
                        '-debug-addr=[debugger server address]:addr:' \
                        '*:package:'
                    ;;
                lint)
                    _arguments \
                        '-v[verbose output]' \
                        '-root-dir=[gno root dir]:path:_files -/' \
                        '-auto-gnomod[auto-generate gnomod.toml]' \
                        '*:package:'
                    ;;
                run)
                    _arguments \
                        '-v[verbose output]' \
                        '-root-dir=[gno root dir]:path:_files -/' \
                        '-expr=[expression to run in package context]:expr:' \
                        '*:file:_files -g "*.gno"'
                    ;;
                mod)
                    _arguments \
                        '1: :(init download tidy verify graph why edit)' \
                        '*::mod-arg:'
                    ;;
                env)
                    _arguments \
                        '*:env var:'
                    ;;
                list)
                    _arguments \
                        '*:package:'
                    ;;
                tool)
                    _arguments \
                        '1: :(transpile)' \
                        '*::tool-arg:'
                    ;;
            esac
            ;;
    esac

    return ret
}

_gno_cmds() {
    local -a cmds
    cmds=(
        'bug:report a gno bug'
        'clean:remove build artifacts + cached test results'
        'doc:show documentation for package or symbol'
        'env:print Gno environment variables'
        'fix:update Gno source to use newer APIs'
        'fmt:format Gno source'
        'list:list packages under a path'
        'lint:lint Gno source'
        'mod:module maintenance (init + download + tidy + verify)'
        'repl:start interactive Gno REPL'
        'run:run Gno scripts locally'
        'test:run Gno package tests'
        'tool:run a gno internal tool'
        'version:show gno + Go toolchain versions'
    )
    _describe -t commands 'gno command' cmds
}

_gno "$@"
