#compdef mailwrapper
# Documentation: https://man.freebsd.org/cgi/man.cgi?query=mailwrapper&sektion=8
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. STUB — mailwrapper has no
# command-line options; it dispatches to an MTA chosen via argv[0] and
# /etc/mail/mailer.conf, then forwards remaining arguments to that MTA.

local curcontext="$curcontext" ret=1
_arguments -C '*::mailwrapper args:_files' && ret=0
return ret
