#compdef esedbexport
# Documentation: https://github.com/libyal/libesedb
# Source: libyal/libesedb esedbtools/esedbexport.c — export tables from an ESE database (Windows.edb, Exchange Mailbox.edb).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a codepages=(ascii windows-874 windows-932 windows-936 windows-1250 windows-1251 windows-1252 windows-1253 windows-1254 windows-1255 windows-1256 windows-1257 windows-1258)

_arguments -s \
    "-c[codepage of ASCII strings]:codepage:($codepages)" \
    '-h[show help]' \
    '-l[log file for info about exported items]:log:_files' \
    '-m[export mode]:mode:(all tables)' \
    '-t[basename of target directory (suffix .export added)]:basename:' \
    '-T[export only a specific table]:table name:' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:ESE database file:_files' \
    && ret=0

return ret
