#compdef firo-cli
# _firo-cli — Firo formerly Zcoin firo-cli JSON-RPC client CLI for the privacy-focused Lelantus Spark MTP daemon issuing wallet getbalance sendtoaddress listunspent mint spend lelantus spark znode listznodes znodesync (firoorg team, C++); custom argparse
# upstream: https://github.com/firoorg/firo

_firo-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf firo.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-named[use named JSON-RPC]' \
        '-rpcconnect=+[host]:h:_hosts' \
        '-rpcport=+[port]:n:' \
        '-rpcwait[wait for RPC server]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcclienttimeout=+[seconds]:n:' \
        '-rpccookiefile=+[file]:file:_files' \
        '-stdin[read input from stdin]' \
        '-stdinrpcpass[read RPC password from stdin]' \
        '-getinfo[print info]' \
        '*:rpc command:(getblockchaininfo getblockcount getblockhash getblock getnetworkinfo getmempoolinfo getbalance listunspent listtransactions sendtoaddress getnewaddress dumpprivkey importprivkey generate generatetoaddress getrawtransaction sendrawtransaction mintlelantus spendlelantus listlelantusmints lelantusbalance autoMintLelantus mintSparkAddresses spendSpark sparkbalance listsparkmints lelantusJSplit znodelist znodelistconf znodesync znodecommand)'
}

_firo-cli "$@"
