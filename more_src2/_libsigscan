#compdef sigscantool
# _libsigscan — libyal binary signature scanner; reads a signatures.def file and scans an input image for matching magic bytes at known offsets
# upstream: https://github.com/libyal/libsigscan

_libsigscan() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-c+[config]:signatures.def:_files -g "*.def"' \
        '-o+[image offset]:bytes:' \
        '-X[exclusive]' \
        '*:image file:_files'
}

_libsigscan "$@"
