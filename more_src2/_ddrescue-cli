#compdef ddrescue-cli
# _ddrescue-cli — Antonio Diaz Diaz GNU ddrescue data recovery tool CLI alias (GNU team, C++); custom argparse
# upstream: https://www.gnu.org/software/ddrescue/

_ddrescue-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-a+[min read rate bytes/s]:n:' \
        '--min-read-rate=+[min read rate bytes/s]:n:' \
        '-A[try again]' \
        '--try-again[try again]' \
        '-b+[sector size bytes]:n:' \
        '--sector-size=+[sector size bytes]:n:' \
        '-B[binary prefixes]' \
        '--binary-prefixes[binary prefixes]' \
        '-c+[cluster size sectors]:n:' \
        '--cluster-size=+[cluster size sectors]:n:' \
        '-C[complete mapfile]' \
        '--complete-only[complete mapfile only]' \
        '-d[direct disc access]' \
        '--idirect[direct disc access for input]' \
        '-D[direct disc access for output]' \
        '--odirect[direct disc access for output]' \
        '-e+[max bad areas]:n:' \
        '--max-bad-areas=+[max bad areas]:n:' \
        '-E+[max error rate bytes/s]:str:' \
        '--max-error-rate=+[max error rate bytes/s]:str:' \
        '-f[force overwrite]' \
        '--force[force overwrite]' \
        '-F+[fill mode]:m:(? +)' \
        '--fill-mode=+[fill mode]:m:(? +)' \
        '-G[generate mapfile]' \
        '--generate-mode[generate mapfile]' \
        '-H+[bad area cutoff fraction]:str:' \
        '--test-mode=+[file]:file:_files' \
        '-i+[input position bytes]:n:' \
        '--input-position=+[input position bytes]:n:' \
        '-I[reverse direction]' \
        '--verify-input-size[verify input size]' \
        '-J+[max retry passes]:n:' \
        '--verify-on-error[verify on error]' \
        '-K+[skip size bytes]:str:' \
        '--skip-size=+[skip size bytes]:str:' \
        '-L[loose domain mapfile]' \
        '--loose-domain[loose domain mapfile]' \
        '-m+[domain mapfile]:file:_files' \
        '--domain-mapfile=+[domain mapfile]:file:_files' \
        '-M[retrim mapfile]' \
        '--retrim[retrim mapfile]' \
        '-n[no scrape]' \
        '--no-scrape[no scrape]' \
        '-N[no trim]' \
        '--no-trim[no trim]' \
        '-o+[output position bytes]:n:' \
        '--output-position=+[output position bytes]:n:' \
        '-O[reopen on error]' \
        '--reopen-on-error[reopen on error]' \
        '-p+[preallocate output]:n:' \
        '--preallocate=+[preallocate output]:n:' \
        '-P[data preview]' \
        '--data-preview=+[lines]:n:' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-r+[max retry passes]:n:' \
        '--retry-passes=+[max retry passes]:n:' \
        '-R[reverse direction]' \
        '--reverse[reverse direction]' \
        '-s+[max input size bytes]:str:' \
        '--size=+[max input size bytes]:str:' \
        '-S[sparse output]' \
        '--sparse[sparse output]' \
        '-t[truncate output]' \
        '--truncate[truncate output]' \
        '-T+[timeout seconds]:n:' \
        '--timeout=+[timeout seconds]:n:' \
        '-u[unidirectional]' \
        '--unidirectional[unidirectional]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-w[ignore write errors]' \
        '--ignore-write-errors[ignore write errors]' \
        '-x+[extend output by bytes]:n:' \
        '--extend-outfile=+[extend output by bytes]:n:' \
        '-X+[max read errors]:n:' \
        '--max-read-errors=+[max read errors]:n:' \
        '-y+[synchronous writes]' \
        '--synchronous[synchronous writes]' \
        '-Z+[max read rate bytes/s]:n:' \
        '--max-read-rate=+[max read rate bytes/s]:n:' \
        '*:input output mapfile:_files'
}

_ddrescue-cli "$@"
