#compdef llc
# _llc — LLVM static compiler (LLVM project, C++); compile LLVM bitcode to assembly / object
# upstream: https://github.com/llvm/llvm-project

_llc() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '-f[force overwrite]' \
        '-o+[output file]:file:_files' \
        '-O+[optimization level]:level:(0 1 2 3)' \
        '-filetype=+[file type]:type:(asm obj null)' \
        '-march=+[arch]:arch:' \
        '-mcpu=+[cpu]:cpu:' \
        '-mtriple=+[triple]:triple:' \
        '-mattr=+[mattr]:str:' \
        '-relocation-model=+[reloc model]:model:(static pic dynamic-no-pic ropi rwpi ropi-rwpi)' \
        '-code-model=+[code model]:model:(tiny small kernel medium large)' \
        '-thread-model=+[thread model]:model:(posix single)' \
        '-mc-relax-all[relax all fixups]' \
        '-stack-realign[force stack realignment]' \
        '-stop-after=+[stop after pass]:pass:' \
        '-stop-before=+[stop before pass]:pass:' \
        '-start-after=+[start after pass]:pass:' \
        '-start-before=+[start before pass]:pass:' \
        '-print-after=+[print IR after pass]:pass:' \
        '-print-before=+[print IR before pass]:pass:' \
        '-print-after-all[print IR after each]' \
        '-print-before-all[print IR before each]' \
        '-debug[debug]' \
        '-debug-pass=+[debug pass]:val:(None Arguments Structure Executions Details)' \
        '-time-passes[time passes]' \
        '-stats[print stats]' \
        '-print-machineinstrs[print machine instrs]' \
        '-asm-show-inst[asm show inst]' \
        '-asm-verbose[asm verbose]' \
        '-data-sections[data sections]' \
        '-function-sections[function sections]' \
        '-relax-elf-relocations[relax elf relocations]' \
        '-frame-pointer=+[frame pointer]:val:(all non-leaf reserved none)' \
        '-show-mc-encoding[show mc encoding]' \
        '-show-mc-inst[show mc inst]' \
        '-x=+[input file kind]:kind:(ir mir)' \
        '*:file:_files'
}

_llc "$@"
