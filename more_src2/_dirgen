#compdef dirgen
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/dirgen.html
# Source: MRtrix3/mrtrix3 cmd/dirgen.cpp — uniformly distributed DWI directions via electrostatic repulsion (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-power+[repulsion-law exponent (power of 2)]:n:_default' \
    '-niter+[max iterations]:n:_default' \
    '-restarts+[number of restarts]:n:_default' \
    '-unipolar[use unipolar electrostatic model]' \
    '-cartesian[output Cartesian [x y z] instead of [az el]]' \
    '1:ndir:_default' \
    '2:dirs (output text file):_files -g "*.txt"' \
    && ret=0

return ret
