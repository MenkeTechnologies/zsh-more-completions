#compdef funccount funccount-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/funccount.py argparse)
# Reference accessed: 2026-05-29
# funccount — count kernel/user/library function calls (BCC/eBPF). Matches kprobes, uprobes, USDT, tracepoints.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[trace this PID only]:pid:_pids' \
  '(-i --interval)'{-i,--interval=}'[summary interval, seconds]:sec:' \
  '(-d --duration)'{-d,--duration=}'[total duration of trace, seconds]:sec:' \
  '(-T --timestamp)'{-T,--timestamp}'[include timestamp on output]' \
  '(-r --regexp)'{-r,--regexp}'[use regular expressions (default is "*" wildcards only)]' \
  '(-D --debug)'{-D,--debug}'[print BPF program before starting (debug)]' \
  '(-c --cpu)'{-c,--cpu=}'[trace this CPU only]:cpu:' \
  '1:pattern (search expression for events e.g. "vfs_*" or "p\:do_sys_open"):' \
  && ret=0

return ret
