#compdef ovs-test
# _ovs-test — Open vSwitch ovs-test bandwidth and throughput testing utility for Open vSwitch tunnels (openvswitch team, Python); argparse
# upstream: https://github.com/openvswitch/ovs

_ovs-test() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-s+[server port]:port:_ports' \
        '--server=+[server port]:port:_ports' \
        '-c+[client mode IP1,IP2,port]:str:' \
        '--client=+[client mode IP1,IP2,port]:str:' \
        '-b+[bandwidth limit Mbps]:n:' \
        '--bandwidth=+[bandwidth limit Mbps]:n:' \
        '-i+[interval seconds]:n:' \
        '--interval=+[interval seconds]:n:' \
        '-t+[duration seconds]:n:' \
        '--duration=+[duration seconds]:n:' \
        '-d+[debug level]:n:' \
        '--debug-level=+[debug level]:n:' \
        '-T+[tunnel mode]:m:(L2 L3 L2GRE VXLAN STT)' \
        '--tunnel-modes=+[modes csv]:str:' \
        '--direct-flows[direct flows]' \
        '--vlan-tag=+[vlan tag]:n:'
}

_ovs-test "$@"
