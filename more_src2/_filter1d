#compdef filter1d
# Documentation: https://docs.generic-mapping-tools.org/latest/filter1d.html
# Source: GenericMappingTools/gmt classic-mode filter1d — time-series filter (boxcar/cosine/gaussian/median/mode/min/max).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-F+[filter type + width (+h for high-pass)]:spec:_default' \
    '-D+[abscissae resolution for uneven sampling]:inc:_default' \
    '-E[include ends of series (no edge loss)]' \
    '-L+[suppress output across data gaps wider than]:width:_default' \
    '-N+[independent (time) column index]:col:_default' \
    '-Q+[quality threshold (mean weight 0..1)]:q:_default' \
    '-S+[symmetry-check threshold]:value:_default' \
    '-T+[evenly spaced time steps (min/max/inc or file/list)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-a+[aspatial column associations]:opts:_default' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-d+[nodata replacement]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-f+[I/O column data types]:types:_default' \
    '-g+[data gap mode]:mode:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-j+[distance computation mode]:mode:_default' \
    '-o+[output column selection]:cols:_default' \
    '-q+[row selection]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
