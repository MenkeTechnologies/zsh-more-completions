# Reference accessed: 2026-05-30 via gh api.
# CtrlSpice otel-desktop-viewer R152a — local-development OTel
# Collector distribution that ships a DuckDB-backed exporter +
# web UI for visualizing OpenTelemetry traces/metrics/logs
# locally. Sister tool to the heavily-covered otel-cli/otelcol/
# otelcol-contrib/jaeger/zipkin/beyla observability family.

_arguments -s -S \
  '--http=[OTLP/HTTP listen port (default 4318)]:port:' \
  '--grpc=[OTLP/gRPC listen port (default 4317)]:port:' \
  '--browser-port=[port to expose the UI on (default 8000)]:port:' \
  '--host=[host to bind all endpoints (default localhost; use :: or 0.0.0.0 for all interfaces)]:host:_hosts' \
  '--db=[DuckDB file path (omit for in-memory mode with no persistence)]:file:_files' \
  '--open-browser=[open the browser automatically on launch (default true)]:bool:(true false)'
