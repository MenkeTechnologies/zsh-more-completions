#compdef flux-operator-mcp
# _flux-operator-mcp — ControlPlane Flux Operator Model Context Protocol server
# upstream: https://github.com/controlplaneio-fluxcd/flux-operator
# Flags from cmd/mcp/main.go on tip.

_flux-operator-mcp() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--timeout=[operation timeout]:dur:' \
        '--mask-secrets=[mask Secret values in responses]:bool:(true false)' \
        '--read-only=[run in read-only mode]:bool:(true false)' \
        '--transport=[MCP transport]:transport:(stdio http sse)' \
        '--port=[MCP HTTP/SSE listen port]:port:' \
        '--kubeconfig=[kubeconfig file]:file:_files' \
        '--kube-context=[kubeconfig context]:context:' \
        '--kube-as=[impersonate user]:user:' \
        '*--kube-as-group=[impersonate group (repeatable)]:group:' \
        '--kube-as-uid=[impersonate UID]:uid:' \
        '--kube-token=[bearer token]:token:' \
        '--kube-server=[Kubernetes API server URL]:url:_urls' \
        '--kube-tls-server-name=[TLS SNI server name]:name:' \
        '--kube-client-certificate=[client cert file]:file:_files' \
        '--kube-client-key=[client key file]:file:_files' \
        '--kube-certificate-authority=[CA cert file]:file:_files' \
        '--kube-insecure-skip-tls-verify[skip TLS verification]' \
        '(-n --namespace)'{-n,--namespace=}'[namespace]:ns:' \
        '--version[print version and exit]'
}

_flux-operator-mcp "$@"
