#compdef erd et
# Documentation: https://github.com/solidiquis/erdtree
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.
# Zsh completion for erdtree
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-L --level)'{-L,--level}'[maximum depth to display]:depth:' \
  '(-s --sort)'{-s,--sort}'[sorting method]:order:(name size rsize access create mod none)' \
  '--dir-order[sort directories relative to files]:order:(none first last)' \
  '--dirs-only[only show directories]' \
  '(-. --hidden)'{-.,--hidden}'[include hidden files]' \
  '--no-git[disable git integration]' \
  '(-i --no-ignore)'{-i,--no-ignore}'[disregard .gitignore rules]' \
  '(-T --threads)'{-T,--threads}'[number of threads]:N:' \
  '(-d --disk-usage)'{-d,--disk-usage}'[disk usage metric]:method:(logical physical line word block)' \
  '(-H --human)'{-H,--human}'[human-readable sizes]' \
  '(-u --unit)'{-u,--unit}'[unit prefix style]:unit:(bin si)' \
  '--glob[glob pattern to filter]:pattern:' \
  '--iglob[case-insensitive glob filter]:pattern:' \
  '(-t --file-type)'{-t,--file-type}'[filter by file type]:type:(file dir symlink)' \
  '(-p --pattern)'{-p,--pattern}'[regex/glob pattern to filter]:pattern:' \
  '(-I --icons)'{-I,--icons}'[display file icons]' \
  '--suppress-size[omit disk usage]' \
  '--truncate[truncate output to fit terminal]' \
  '(-f --follow)'{-f,--follow}'[follow symbolic links]' \
  '(-l --long)'{-l,--long}'[show extended metadata (Unix-only)]' \
  '--group[show file group]' \
  '--ino[display inode numbers]' \
  '--nlink[show hardlink count]' \
  '--octal[use octal permission notation]' \
  '--time[timestamp type]:field:(create access mod)' \
  '--time-format[timestamp format]:format:(default relative iso iso-strict short)' \
  '(-c --config)'{-c,--config}'[use named configuration table]:table:' \
  '(-C --color)'{-C,--color}'[coloring mode]:mode:(none auto force)' \
  '(-P --prune)'{-P,--prune}'[remove empty directories]' \
  '(-x --one-file-system)'{-x,--one-file-system}'[prevent cross-filesystem traversal]' \
  '(-y --layout)'{-y,--layout}'[output layout]:layout:(regular inverted flat iflat)' \
  '--no-config[ignore configuration file]' \
  '--no-progress[hide progress indicator]' \
  '--completions[generate shell completions]:shell:(bash elvish fish powershell zsh)' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:directory:_directories' && ret=0
return ret
