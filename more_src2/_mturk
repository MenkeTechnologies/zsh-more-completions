#compdef mturk
# Documentation: https://chbrown.github.io/mturk/cli
# Reference accessed: 2026-05-19
# Verified: chbrown mturk CLI source (argparse subparsers inspected directly).

# mturk: chbrown's argparse-based MTurk CLI (uses boto). Subcommands
# enumerated from the installed script's argparse subparser definitions.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'bal:show account balance'
  'hit:show details of a HIT'
  'hits:list 10 most recently created HITs'
  'new:create a new HIT from a config file'
  'extend:extend a HIT (more assignments or lifetime)'
  'expire:expire a HIT'
  'rm:delete a HIT'
  'as:list assignments for a HIT'
  'approve:approve assignments'
  'reject:reject assignments'
  'unreject:approve previously rejected assignments'
  'bonus:give workers a bonus'
  'notify:send workers a notification email'
  'give-qual:grant a qualification to a worker'
  'revoke-qual:revoke a qualification from a worker'
)

_arguments -s -S \
  '(-P --production)'{-P,--production}'[use the production site (default sandbox)]' \
  '--nicknames=[path to HIT nickname store]:file:_files' \
  '(- *)'{-h,--help}'[show help]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'mturk command' commands && ret=0
    ;;
  args)
    case ${line[1]} in
      (approve|reject|unreject)
        _arguments \
          '(-m --message)'{-m,--message}'[feedback message]:text:' \
          '*:assignment id:' && ret=0
        ;;
    esac
    ;;
esac

return ret
