#compdef kamaji
# Documentation: https://github.com/clastix/kamaji/blob/master/cmd/manager/cmd.go
# Reference accessed: 2026-05-19
# Verified: upstream main.go + cmd/manager/cmd.go at the URLs above.

# Kamaji control plane manager. Corrected from prior flat-flag file:
# kamaji has subcommands (manager, migrate, kubeconfig-generator) per
# main.go; manager flags taken verbatim from cmd/manager/cmd.go.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    local -a commands=(
      'manager:run the Kamaji controller manager'
      'migrate:migrate a TenantControlPlane to a new datastore'
      'kubeconfig-generator:generate a kubeconfig'
    )
    _describe -t commands 'kamaji command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (manager)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--metrics-bind-address=[metrics endpoint bind address]:addr:' \
          '--health-probe-bind-address=[probe endpoint bind address]:addr:' \
          '--leader-elect[enable leader election]' \
          '--tmp-directory=[temporary files directory]:dir:_directories' \
          '--kine-image=[Kine sidecar container image]:image:' \
          '--datastore=[default DataStore name]:name:' \
          '--migrate-image=[image launched on TCP migration]:image:' \
          '--max-concurrent-tcp-reconciles=[TCP controller worker count]:n:' \
          '--pod-namespace=[namespace the operator runs in]:namespace:' \
          '--webhook-service-name=[Kamaji webhook Service name]:name:' \
          '--serviceaccount-name=[operator service account name]:name:' \
          '--webhook-ca-path=[path to webhook server CA]:file:_files' \
          '--controller-reconcile-timeout=[reconcile request timeout]:duration:' \
          '--cache-resync-period=[manager cache resync period]:duration:' \
          '--disable-telemetry[disable analytics traces collection]' \
          '--certificate-expiration-deadline=[cert renewal deadline]:duration:' && ret=0
        ;;
      (*)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' '*: : _default' && ret=0
        ;;
    esac
    ;;
esac

return ret
