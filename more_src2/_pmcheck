#compdef pmcheck
# _pmcheck — check/report/enable/disable PCP components (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmcheck/pmcheck.sh (pmgetopt usage block).

_pmcheck() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(-a --activate)'{-a,--activate}'[activate component(s)]' \
        '(-c --file)'{-c+,--file=}'[alternate component script]:file:_files' \
        '(-d --deactivate)'{-d,--deactivate}'[deactivate component(s)]' \
        '(-l --list)'{-l,--list}'[list components]' \
        '(-n --show-me)'{-n,--show-me}'[dry run]' \
        '(-s --state)'{-s,--state}'[report state of component(s)]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-x --trace)'{-x,--trace}'[run component script with sh -x]' \
        '*:component:'
}

_pmcheck "$@"
