#compdef podboat
# Documentation: https://newsboat.org/releases/2.40/docs/podboat.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[display help]' \
  {-C+,--config-file=}'[use alternative configuration file]:config file:_files' \
  {-q+,--queue-file=}'[use alternative queue file]:queue file:_files' \
  {-a,--autodownload}'[automatic download of queued files on startup]' \
  {-l+,--log-level=}'[log level]:level:(1 2 3 4 5 6)' \
  {-d+,--log-file=}'[log file for debug messages]:log file:_files' && ret=0

return ret
