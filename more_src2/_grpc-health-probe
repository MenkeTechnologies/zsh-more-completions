#compdef grpc-health-probe
# _grpc-health-probe — kubelet-style health-probe client for gRPC Health Checking Protocol (grpc.health.v1)
# upstream: https://github.com/grpc-ecosystem/grpc-health-probe
# Flags from main.go on tip (also shipped inside aws/amazon-vpc-cni-k8s cmd/grpc-health-probe).

_grpc-health-probe() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-v[verbose logs]' \
        '-addr=[(required) tcp host:port to connect]:addr:' \
        '-service=[service name to check (default empty)]:name:' \
        '-user-agent=[user-agent header value]:ua:' \
        '-connect-timeout=[timeout for establishing connection]:duration:' \
        '-rpc-timeout=[timeout for health check rpc]:duration:' \
        '-tls[use TLS]' \
        '-tls-no-verify[skip TLS server cert verification]' \
        '-tls-ca-cert=[TLS CA cert file]:file:_files' \
        '-tls-client-cert=[TLS client cert]:file:_files' \
        '-tls-client-key=[TLS client key]:file:_files' \
        '-tls-server-name=[TLS SNI host]:host:' \
        '-spiffe[use SPIFFE Workload API for TLS]' \
        '-gzip[use gzip compression]'
}

_grpc-health-probe "$@"
