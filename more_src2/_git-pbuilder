# Source: agx/git-buildpackage bin/git-pbuilder — wrapper around cowbuilder/qemubuilder for gbp buildpackage (shell).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '(-h --help -?)'{-h,--help,-\?}'[show help]' \
    '1::action:(update create login)' \
    '*::pbuilder/cowbuilder/qemubuilder options:_default' \
    && ret=0

return ret
