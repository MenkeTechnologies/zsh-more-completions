#compdef lightstep-cli lightstep
# _lightstep-cli — Lightstep observability CLI (Lightstep/ServiceNow, Go); spf13/cobra
# upstream: https://github.com/lightstep/lightstep-cli

_lightstep-cli() {
    local -a sub=(
        'login:login to lightstep'
        'logout:logout'
        'config:manage cli config'
        'organization:manage organizations'
        'project:manage projects'
        'service:manage services'
        'stream:manage streams'
        'condition:manage conditions'
        'dashboard:manage dashboards'
        'notebook:manage notebooks'
        'snapshot:manage snapshots'
        'event-query:event query helpers'
        'access-token:manage access tokens'
        'invite:manage invitations'
        'membership:manage memberships'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--api-key=+[lightstep API key]:str:' \
        '--api-base-url=+[api base url]:url:_urls' \
        '--organization=+[organization]:org:' \
        '--project=+[project]:proj:' \
        '--config=+[config file]:file:_files' \
        '--format=+[output format]:fmt:(table json yaml)' \
        '-o+[output format]:fmt:(table json yaml)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'lightstep subcommand' sub ;;
        args)
            case $words[1] in
                organization|project|service|stream|condition|dashboard|notebook|snapshot|access-token|invite|membership) _arguments \
                    '1:cmd:(list get create update delete)' \
                    '*:arg:' ;;
                event-query) _arguments \
                    '1:cmd:(run save list show delete)' \
                    '--query=+[query string]:str:' \
                    '--start=+[start]:str:' \
                    '--end=+[end]:str:' ;;
                config) _arguments \
                    '1:cmd:(get set list reset)' \
                    '*:arg:' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_lightstep-cli "$@"
