#compdef qbs
# _qbs — Qt Project qbs CLI Qt Build Suite declarative cross-platform build tool driving multi-configuration multi-product .qbs project files for C C++ Qt Quick Android iOS WASM Windows builds with profile-driven toolchain selection deterministic incremental builds (Qt Project team, C++); custom argparse
# upstream: https://doc.qt.io/qbs/index.html

_qbs() {
    local -a sub=(
        'build:build a project'
        'resolve:resolve a project'
        'clean:remove build artifacts'
        'install:install a project'
        'run:run a built product'
        'shell:run a shell with build environment'
        'status:report files matched / unmatched'
        'list-products:list products in a project'
        'config:configure qbs settings'
        'config-ui:graphical settings ui'
        'help:show help'
        'generate:generate output for another IDE'
        'setup-toolchains:detect toolchains'
        'setup-qt:detect Qt installations'
        'setup-android:set up Android SDK'
        'create-project:create a qbs project file'
        'init:initialize a new project'
        'dump-nodes-tree:dump dependency tree'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-q[quiet]' \
        '-d+[build dir]:dir:_files -/' \
        '--build-directory=+[dir]:dir:_files -/' \
        '-f+[project file]:file:_files -g "*.qbs"' \
        '--file=+[project file]:file:_files -g "*.qbs"' \
        '-p+[product]:str:' \
        '--products=+[products]:str:' \
        '-j+[jobs]:n:' \
        '--jobs=+[jobs]:n:' \
        '-k[keep going]' \
        '--keep-going[keep going]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-c+[config name]:str:' \
        '--build-configuration=+[name]:str:' \
        '--profile=+[profile]:str:' \
        '--changed-files=+[files]:str:' \
        '--log-level=+[l]:l:(error warning info debug trace)' \
        '--log-time[log time]' \
        '--more-verbose[increase verbosity]' \
        '--less-verbose[decrease verbosity]' \
        '--show-progress[show progress]' \
        '--no-build[skip build]' \
        '--no-install[skip install]' \
        '--settings-dir=+[dir]:dir:_files -/' \
        '--track-external-changes[track external changes]' \
        '--show-command-lines[print command lines]' \
        '--check-timestamps[check timestamps]' \
        '--check-outputs[check outputs]' \
        '--install-root=+[dir]:dir:_files -/' \
        '--no-install-prefix[no install prefix]' \
        '--remove-first[remove install root first]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'qbs subcommand' sub ;;
    esac
}

_qbs "$@"
