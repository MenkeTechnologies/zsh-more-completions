#compdef fuzz-introspector
# _fuzz-introspector — fuzzer harness coverage and reachability introspector (ossf/fuzz-introspector)
# upstream: https://github.com/ossf/fuzz-introspector
# Subcommands from src/fuzz_introspector/cli.py (argparse).

_fuzz-introspector() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                light:'light analysis (no compilation)'
                full:'analyse folder and generate HTML report'
                report:'generate fuzz-introspector HTML report'
                correlate:'correlate executables with introspector logs'
                diff:'diff two reports for improvements/regressions'
                analyse:'run a standalone analyser'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                light)
                    _arguments \
                        '--language=[project language]:lang:(c-cpp python jvm rust go)' ;;
                full)
                    _arguments \
                        '--target-dir=[source directory to analyse]:dir:_files -/' \
                        '--language=[programming language]:lang:(c-cpp python jvm rust go)' \
                        '--out-dir=[output directory for results]:dir:_files -/' \
                        '--name=[report name]:name:' \
                        '--coverage-url=[coverage base URL]:url:_urls' \
                        '--module-only[dump analysis even without harness]' ;;
                report)
                    _arguments \
                        '--target-dir=[directory holding data files]:dir:_files -/' ;;
                analyse)
                    _arguments \
                        '1:analyser:(SourceCodeLineAnalyser FarReachLowCoverageAnalyser PublicCandidateAnalyser FrontendAnalyser)' \
                        '*::analyser args:_files' ;;
            esac
            ;;
    esac
}

_fuzz-introspector "$@"
