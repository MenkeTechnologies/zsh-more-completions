#compdef poethepoet poe
# _poethepoet — Nathan Hjelm poethepoet Python task runner CLI alias (Nat Noordanus / nat-n, Python); custom argparse
# upstream: https://github.com/nat-n/poethepoet

_poethepoet() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[increase verbosity]' \
        '-q[decrease verbosity]' \
        '--dry-run[dry run]' \
        '-d[dry run]' \
        '--root=+[project root]:dir:_files -/' \
        '-C+[project root]:dir:_files -/' \
        '--executor=+[executor]:e:(auto poetry uv virtualenv simple)' \
        '-e+[executor]:e:(auto poetry uv virtualenv simple)' \
        '--ansi[force ansi]' \
        '--no-ansi[no ansi]' \
        '*:task-and-args:'
}

_poethepoet "$@"
