#compdef lighthouse-agent
# _lighthouse-agent — Submariner Lighthouse multi-cluster service discovery agent (mirrors ServiceExports to the broker + materialises ServiceImports + EndpointSlices)
# upstream: https://github.com/submariner-io/lighthouse
# Flags from pkg/agent/main.go on tip; deeper config via env vars (SUBMARINER_NAMESPACE, SUBMARINER_CLUSTERID, BROKER_K8S_*).

_lighthouse-agent() {
    _arguments \
        '(- *)'{-h,--help}'[print usage options]' \
        '--version[show version]' \
        '--kubeconfig=[path to kubeconfig (out-of-cluster only)]:file:_files' \
        '--master=[Kubernetes API URL]:url:_urls' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:'
}

_lighthouse-agent "$@"
