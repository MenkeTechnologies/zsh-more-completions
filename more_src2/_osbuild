#compdef osbuild
# _osbuild — build OS artifacts from a JSON manifest (osbuild/osbuild)
# upstream: https://github.com/osbuild/osbuild
# Flags from osbuild/main_cli.py (argparse).

_osbuild() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)--version[show osbuild version]'
        '--cache=[directory for sources/intermediate trees]:dir:_files -/'
        '--store=[alias for --cache]:dir:_files -/'
        '(-l --libdir)'{-l+,--libdir=}'[directory containing stages/assemblers/lib]:dir:_files -/'
        '--cache-max-size=[max cache size (bytes or "unlimited")]:size:'
        '*--checkpoint=[object ID(s) to checkpoint]:id:'
        '*--export=[object(s) to export]:id:'
        '*--in-vm=[pipeline(s) to run in a VM]:id:'
        '--json[output results in JSON]'
        '--output-directory=[directory for result objects]:dir:_files -/'
        '--inspect[return the manifest including all ids]'
        '--monitor=[monitor name]:name:'
        '--monitor-fd=[file descriptor for the monitor]:fd:'
        '--stage-timeout=[max seconds per stage]:seconds:'
        '--break=[open debug shell on stage (name / id / "*")]::stage:'
        '(-q --quiet)'{-q,--quiet}'[suppress normal output]'
        '1:manifest path (or -):_files -g "*.json"'
    )
    _arguments -s $args
}

_osbuild "$@"
