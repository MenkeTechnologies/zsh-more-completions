#compdef R-CMD-Rd2pdf
# _R-CMD-Rd2pdf — R Core Team R CMD Rd2pdf convert R Rd documentation files to PDF manual (rcore team, C); getopt
# upstream: https://cran.r-project.org/

_R-CMD-Rd2pdf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-o+[output file]:file:_files -g "*.pdf"' \
        '--output=+[output file]:file:_files -g "*.pdf"' \
        '--force[force]' \
        '--batch[batch mode]' \
        '--no-clean[no clean]' \
        '--no-preview[no preview]' \
        '--internals[include internals]' \
        '--title=+[title]:str:' \
        '--encoding=+[encoding]:str:' \
        '--no-index[no index]' \
        '--no-description[no description]' \
        '--no-toc[no TOC]' \
        '--RdMacros=+[macros pkgs]:str:' \
        '*:Rd or pkg:_files -g "*.Rd *.tar.gz"'
}

_R-CMD-Rd2pdf "$@"
