#compdef nix-build-uncached
# _nix-build-uncached — Nix build wrapper that skips substituters (Mic92/nix-build-uncached)
# upstream: https://github.com/Mic92/nix-build-uncached
# Flags from main.go.

_nix-build-uncached() {
    _arguments \
        '-build-flags=[extra flags forwarded to nix-build]:flags:' \
        '*:installable:_files'
}

_nix-build-uncached "$@"
