#compdef fastify-cli
# _fastify-cli — Tomas Della Vedova fastify-cli run Fastify apps from the command line CLI alias (fastify team, JavaScript); commander
# upstream: https://github.com/fastify/fastify-cli

_fastify-cli() {
    local -a sub=(
        'start:start fastify server'
        'generate:generate fastify project'
        'generate-plugin:generate plugin scaffold'
        'eject:eject from fastify-cli'
        'print-routes:print routes'
        'print-plugins:print plugins'
        'print-config:print config'
        'inspect:start with inspect'
        'restart:restart server'
        'stop:stop server'
        'readme:print readme'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'fastify subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '1:script file:_files' \
                    '--port=+[port]:port:' \
                    '-p+[port]:port:' \
                    '--address=+[address]:str:' \
                    '-a+[address]:str:' \
                    '--socket=+[socket]:file:_files' \
                    '-s+[socket]:file:_files' \
                    '--log-level=+[level]:l:(fatal error warn info debug trace silent)' \
                    '-l+[level]:l:(fatal error warn info debug trace silent)' \
                    '--prefix=+[prefix]:str:' \
                    '-r+[prefix]:str:' \
                    '--pretty-logs[pretty logs]' \
                    '-P[pretty logs]' \
                    '--options[show options]' \
                    '-o[show options]' \
                    '--watch[watch mode]' \
                    '-w[watch mode]' \
                    '--watch-ignore-pattern=+[pattern]:str:' \
                    '--ignore-watch=+[pattern]:str:' \
                    '--debug[debug mode]' \
                    '-d[debug mode]' \
                    '--debug-port=+[port]:port:' \
                    '-D+[port]:port:' \
                    '--debug-host=+[host]:host:_hosts' \
                    '--lang=+[language]:l:(ts js)' \
                    '-L+[language]:l:(ts js)' \
                    '--require=+[module]:str:' \
                    '-i+[module]:str:' \
                    '--import=+[esm module]:str:' \
                    '-I+[esm module]:str:' \
                    '--logging-module=+[module]:str:' \
                    '--standardlog[standard log]' \
                    '--verbose-watch[verbose watch]' \
                    '--ignore-watch-changes=+[paths]:str:' \
                    '--body-limit=+[bytes]:n:' \
                    '--method=+[methods csv]:str:' ;;
                generate) _arguments \
                    '1:dir:_files -/' \
                    '--lang=+[language]:l:(ts js)' \
                    '--integrate[integrate with existing]' ;;
                generate-plugin) _arguments \
                    '1:dir:_files -/' \
                    '--lang=+[language]:l:(ts js)' ;;
                print-routes|print-plugins|print-config) _arguments \
                    '1:script file:_files' \
                    '--options[show options]' \
                    '--commonPrefix[common prefix]' ;;
                eject) ;;
            esac
            ;;
    esac
}

_fastify-cli "$@"
