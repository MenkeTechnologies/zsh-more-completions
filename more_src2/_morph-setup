#compdef morph-setup
# Documentation: https://www.npmjs.com/package/@morphllm/morph-setup
# Reference accessed: 2026-05-22
# Verified: package README and @morphllm/morph-setup flags.

# Zsh completion for morph-setup - Morph MCP and skills installer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-y --yes)'{-y,--yes}'[non-interactive install]' \
  '--morph-api-key[Morph API key]:key:' \
  '--a2a-review[set up AI twin code review]' \
  '--github-username[GitHub username for a2a-review]:user:' \
  '*--claude-md[CLAUDE.md paths for a2a-review]:file:_files' && ret=0

return ret
