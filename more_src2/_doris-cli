#compdef doris-cli doris2
# _doris-cli — Apache Doris doris-cli CLI command-line frontend wrapping the Apache Doris real-time analytical MPP database providing fe-frontend be-backend broker mysql-client connector load stream-load broker-load routine-load mini-load show-frontends show-backends ALTER-CLUSTER ADMIN-SHOW-CONFIG admin-set-config show-replica-status colocate-group materialized-view stored-procedure (ASF Doris team Baidu, C++/Java); custom argparse
# upstream: https://doris.apache.org/

_doris-cli() {
    local -a sub=(
        'fe:run frontend'
        'be:run backend'
        'broker:run broker'
        'mysql:open MySQL client'
        'load:load data'
        'stream-load:stream load'
        'broker-load:broker load'
        'routine-load:routine load'
        'mini-load:mini load'
        'show:show command'
        'admin:admin command'
        'alter:alter command'
        'create:create command'
        'drop:drop command'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--host=+[host]:_hosts' \
        '-H+[host]:_hosts' \
        '--port=+[port]:n:' \
        '-P+[port]:n:' \
        '--user=+[user]:_users' \
        '-u+[user]:_users' \
        '--password=+[password]:str:' \
        '-p+[password]:str:' \
        '--database=+[db]:str:' \
        '-d+[db]:str:' \
        '--table=+[name]:str:' \
        '-t+[table]:str:' \
        '--label=+[name]:str:' \
        '--columns=+[cols]:str:' \
        '--column-separator=+[sep]:str:' \
        '--line-delimiter=+[delim]:str:' \
        '--format=+[fmt]:f:(csv json orc parquet)' \
        '--max-filter-ratio=+[N]:n:' \
        '--timeout=+[sec]:n:' \
        '-c+[config file]:file:_files -g "fe.conf be.conf *.conf"' \
        '--config=+[file]:file:_files -g "fe.conf be.conf *.conf"' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'doris subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_doris-cli "$@"
