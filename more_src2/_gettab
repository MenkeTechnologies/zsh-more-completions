#compdef gettab
# _gettab — extract values from tab-table FITS files (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from gettab.c (single-letter getopt-style).

_gettab() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a[list file even if no keywords are found]' \
        '-e[output as KEY=VALUE assignments]' \
        '-v[verbose output]' \
        '-h[output column headings]' \
        '-n+[decimal places]:n:' \
        '-o[OR conditions instead of ANDing]' \
        '-p[output column headings]' \
        '-t[output tab table]' \
        '1:tab-table FITS file:_files -g "*.(tab|fits|fit|fts)"' \
        '*:column or condition:'
}

_gettab "$@"
