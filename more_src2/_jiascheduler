# WHAT IT IS
#   jiascheduler is "a high-performance, scalable, dynamically
#   configured job scheduler developed with Rust" — iwannay's
#   distributed scheduler with a three-tier architecture:
#     * jiascheduler-console — HTTP REST + WebUI control plane that
#       reads/writes job definitions, schedules, instance assignments,
#       and execution logs through a MySQL + Redis backend.
#     * jiascheduler-comet   — WebSocket coordinator that fans out
#       scheduled tasks to connected agents and brokers RPC over a
#       Redis pub/sub channel.
#     * jiascheduler-agent   — worker daemon that connects outbound
#       to one or more comet endpoints, executes jobs locally (or
#       over SSH against assigned hosts), and streams output back.
#   `jiascheduler` is the all-in-one binary that boots all three
#   roles in a single process for development.
#
# CLI ARGUMENT GRAMMAR  (verbatim from src/bin/{console,agent,comet,
#                       jiascheduler}.rs clap-derive `*Args` structs)
#
#   ─── jiascheduler-console (Webapi)
#     -d, --debug                 Enable debug mode
#         --bind-addr <ADDR>        HTTP server listen address
#                                   (e.g. "0.0.0.0:9090")
#         --log-level <LEVEL>     trace/debug/info/warn/error
#                                 [default: error]
#         --config <FILE>         Config file
#                                 [default: ~/.jiascheduler/
#                                           console.toml]
#         --redis-url <URL>       Redis connection URL — overrides
#                                 the value in the config file
#         --database-url <URL>    MySQL connection URL — overrides
#                                 the value in the config file
#
#   ─── jiascheduler-agent
#     -b, --bind <ADDR>           Agent local bind address
#                                   [default: 0.0.0.0:3001]
#         --comet-addr <URL>...   Comet WebSocket endpoint(s) to
#                                 dial (repeatable)
#                                   [default: ws://127.0.0.1:3000]
#         --output-dir <DIR>      Directory for saving job execution
#                                 logs                [default: ./log]
#         --comet-secret <SECRET> Comet shared secret
#                                   [default: rYzBYE+cXbtdMg==]
#     -n, --namespace <NAME>      Logical namespace this agent
#                                 belongs to        [default: default]
#         --ssh-user <USER>       SSH login user for the instance
#                                 (used when comet asks the agent
#                                 to run a command via SSH against
#                                 the host this agent runs on)
#         --ssh-password <PASS>   SSH login password
#         --ssh-port <PORT>       SSH port
#         --assign-username <U>   Assign this instance to a user
#                                 (username)
#         --assign-password <P>   Assign this instance to a user
#                                 (password)
#         --log-level <LEVEL>     trace/debug/info/warn/error
#                                 [default: error]
#
#   ─── jiascheduler-comet
#     -d, --debug                 Enable debug mode
#     -b, --bind <ADDR>           HTTP/WebSocket bind address
#                                 [default: 0.0.0.0:3000]
#     -r, --redis-url <URL>       Redis connection URL
#                                 [default: redis://:wang@127.0.0.1]
#         --secret <SECRET>       Shared secret for agent auth
#                                 [default: rYzBYE+cXbtdMg==]
#         --log-level <LEVEL>     trace/debug/info/warn/error
#                                 [default: error]
#
#   ─── jiascheduler (all-in-one)
#     -d, --debug
#         --console-bind-addr <ADDR>  HTTP console listen address
#                                       (e.g. 0.0.0.0:9090)
#         --log-level <LEVEL>     [default: error]
#     -c, --comet-bind-addr <ADDR>    Comet listen address
#                                       [default: 0.0.0.0:3000]
#     -n, --namespace <NAME>          [default: default]
#         --output-dir <DIR>          [default: ./log]
#         --ssh-user <USER>           Local SSH login user
#         --ssh-password <PASS>       Local SSH login password
#         --ssh-port <PORT>           Local SSH port
#         --assign-username <U>       Assign this instance to user
#         --assign-password <P>       Assign this instance to user
#         --config <FILE>             Config file
#                                       [default: ~/.jiascheduler/
#                                                 console.toml]
#
#   Standard clap auto-flags:
#     -h, --help                  Show help
#     -V, --version               Show version
#
#   Environment:
#     RUST_LOG                    Each binary's `main` sets this to
#                                 the `--log-level` value before
#                                 initializing `tracing_subscriber`.
#
# AXIS / CORPUS POSITION
#   Direct dependency on `redis = "0.27"` (with tokio + connection-
#   manager features) declared in workspace Cargo.toml — the
#   canonical Rust Redis client maintained by Armin Ronacher and
#   the redis-rs community (redis-rs/redis-rs).  redis-rs is the
#   reference Rust Redis client:  typed `Cmd` + `Pipeline` builders,
#   `aio::ConnectionManager` with automatic reconnect, RESP2 + RESP3
#   wire protocol, Cluster + Sentinel topology support, pub/sub
#   subscriptions, MULTI/EXEC transactions, and JSON / Search /
#   Streams / TimeSeries module bindings.  jiascheduler's
#   `crates/service/` constructs `redis::Client::open(url)` then
#   `client.get_multiplexed_async_connection()`, uses `redis::cmd("...")`
#   for direct commands, and `redis-macros` for typed
#   serialize/deserialize of Rust structs into RedisJSON values.
#   Verified via:
#     gh api repos/jiawesoft/jiascheduler/contents/Cargo.toml
#       → redis = { version = "0.27", features = [...] }
#       → redis-macros = "0.5.1"
#     gh api repos/jiawesoft/jiascheduler/contents/src/bin/comet.rs
#       → struct CometArgs { redis_url: String, ... }
#         CometOptions { redis_url: args.redis_url, ... }
#   This entry is the Rust=134 leader bump that OPENS Axis 79
#   (Redis Client Library), pairing with future Go=go-redis/redis
#   and TS-Node=ioredis / node-redis poles to close the axis at
#   1/1/1.
#
#   No completion for `jiascheduler` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_jiascheduler-console() {
    _arguments -s \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '--bind-addr=[HTTP server listen address (e.g. 0.0.0.0\:9090)]:addr:' \
        '--log-level=[log level]:level:(trace debug info warn error)' \
        '--config=[config file (default ~/.jiascheduler/console.toml)]:config file:_files -g "*.toml"' \
        '--redis-url=[Redis connection URL (overrides config)]:redis URL:' \
        '--database-url=[MySQL connection URL (overrides config)]:database URL:' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_jiascheduler-agent() {
    _arguments -s \
        '(-b --bind)'{-b+,--bind=}'[agent local bind address (default 0.0.0.0\:3001)]:addr:' \
        '*--comet-addr=[comet WebSocket endpoint(s) to dial]:url:' \
        '--output-dir=[job execution log directory (default ./log)]:dir:_files -/' \
        '--comet-secret=[comet shared secret]:secret:' \
        '(-n --namespace)'{-n+,--namespace=}'[logical namespace (default "default")]:namespace:' \
        '--ssh-user=[SSH login user for this instance]:user:_users' \
        '--ssh-password=[SSH login password]:password:' \
        '--ssh-port=[SSH port]:port:' \
        '--assign-username=[assign instance to user (username)]:user:' \
        '--assign-password=[assign instance to user (password)]:password:' \
        '--log-level=[log level]:level:(trace debug info warn error)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_jiascheduler-comet() {
    _arguments -s \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '(-b --bind)'{-b+,--bind=}'[HTTP/WebSocket bind (default 0.0.0.0\:3000)]:addr:' \
        '(-r --redis-url)'{-r+,--redis-url=}'[Redis URL (default redis\://\:wang@127.0.0.1)]:redis URL:' \
        '--secret=[shared secret for agent auth]:secret:' \
        '--log-level=[log level]:level:(trace debug info warn error)' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

_jiascheduler() {
    _arguments -s \
        '(-d --debug)'{-d,--debug}'[enable debug mode]' \
        '--console-bind-addr=[HTTP console listen address]:addr:' \
        '--log-level=[log level]:level:(trace debug info warn error)' \
        '(-c --comet-bind-addr)'{-c+,--comet-bind-addr=}'[comet listen address (default 0.0.0.0\:3000)]:addr:' \
        '(-n --namespace)'{-n+,--namespace=}'[namespace (default "default")]:namespace:' \
        '--output-dir=[job execution log dir (default ./log)]:dir:_files -/' \
        '--ssh-user=[SSH login user]:user:_users' \
        '--ssh-password=[SSH login password]:password:' \
        '--ssh-port=[SSH port]:port:' \
        '--assign-username=[assign instance to user (username)]:user:' \
        '--assign-password=[assign instance to user (password)]:password:' \
        '--config=[config file (default ~/.jiascheduler/console.toml)]:config file:_files -g "*.toml"' \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]'
}

case "${service:-$0}" in
    *-console) _jiascheduler-console "$@" ;;
    *-agent)   _jiascheduler-agent "$@" ;;
    *-comet)   _jiascheduler-comet "$@" ;;
    *)         _jiascheduler "$@" ;;
esac
