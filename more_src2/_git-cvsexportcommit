#compdef git-cvsexportcommit
# Documentation: https://git-scm.com/docs/git-cvsexportcommit
# Source: git/git git-cvsexportcommit.perl — apply a Git commit to a CVS checkout (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-p[force --use-textmode/CRLF newlines]' \
    '-v[verbose output]' \
    '-c[commit the CVS changes (cvs commit)]' \
    '-f[force using merge commit parent for diff]' \
    '-u[update existing CVS files even on conflict]' \
    '-k[reverse CVS keyword expansion]' \
    '-w+[CVS working directory]:cvsworkdir:_files -/' \
    '-W[use cvsexportcommit.cvsdir config]' \
    '-m+[commit-message prefix]:msgprefix:_default' \
    '-a[add Authored-by/Committed-by/Reviewed-by]' \
    '-d+[CVSROOT override]:cvsroot:_default' \
    '-P[push (commit) immediately after applying]' \
    '*:[parent] commit:_default' \
    && ret=0

return ret
