#compdef go-cleanarch
# _go-cleanarch — Robert C. Martin clean architecture layer checker for Go (Robert Lacroix); enforces inward-only deps
# upstream: https://github.com/roblaszczak/go-cleanarch

_go-cleanarch() {
    _arguments \
        '-application+[application layer dir]:dir:_files -/' \
        '-domain+[domain layer dir]:dir:_files -/' \
        '-infrastructure+[infrastructure layer dir]:dir:_files -/' \
        '-interfaces+[interfaces layer dir]:dir:_files -/' \
        '-ignore-tests[skip test files]' \
        '-debug[debug log]' \
        '*:dir:_files -/'
}

_go-cleanarch "$@"
