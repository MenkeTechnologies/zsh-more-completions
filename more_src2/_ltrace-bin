#compdef ltrace
# _ltrace-bin — ltrace library call tracer for Linux (Juan Cespedes); traces dynamic library + syscall calls
# upstream: https://gitlab.com/cespedes/ltrace

_ltrace-bin() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-a --align)'{-a,--align}'+[column align]:n:' \
        '(-A --arrays)'{-A,--arrays}'+[max array dump]:n:' \
        '(-b --no-signals)'{-b,--no-signals}'[no signals]' \
        '(-c --count)'{-c,--count}'[count time/calls]' \
        '(-C --demangle)'{-C,--demangle}'[demangle C++]' \
        '(-D --debug)'{-D,--debug}'+[debug mask]:mask:' \
        '(-e --expr)'{-e,--expr}'+[filter expr]:expr:' \
        '(-f --follow)'{-f,--follow}'[follow forks]' \
        '(-F --config)'{-F,--config}'+[config file]:file:_files' \
        '(-i --instruction-pointer)'{-i,--instruction-pointer}'[print IP]' \
        '(-l --library)'{-l,--library}'+[library]:file:_files' \
        '(-L --no-signature-handler)'{-L,--no-signature-handler}'[no signal lib calls]' \
        '(-n --indent)'{-n,--indent}'+[indent n spaces]:n:' \
        '(-o --output)'{-o,--output}'+[output file]:file:_files' \
        '(-p --pid)'{-p,--pid}'+[attach PID]:pid:_pids' \
        '(-r --relative-time)'{-r,--relative-time}'[relative time]' \
        '(-s --strsize)'{-s,--strsize}'+[max string size]:n:' \
        '(-S --syscalls)'{-S,--syscalls}'[trace syscalls too]' \
        '(-t --time)'{-t,--time}'[print absolute time]' \
        '(-tt)-tt[time with usec]' \
        '(-ttt)-ttt[seconds since epoch]' \
        '(-T --time-syscalls)'{-T,--time-syscalls}'[time syscalls]' \
        '(-u --user)'{-u,--user}'+[run as user]:user:_users' \
        '(-w --where)'{-w,--where}'+[stack depth]:n:' \
        '(-x --func-list)'{-x,--func-list}'+[function name]:func:' \
        '*::command:_command_names -e'
}

_ltrace-bin "$@"
