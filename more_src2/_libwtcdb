#compdef wtcdbinfo wtcdbexport
# _libwtcdb — libyal Windows thumbnail cache db (thumbcache_*.db, iconcache_*.db, Vista+) parser; extracts cached thumbnails by PNG/JPG/BMP entries
# upstream: https://github.com/libyal/libwtcdb

_libwtcdb() {
    _arguments \
        '-h[show help]' \
        '-V[show version]' \
        '-v[verbose]' \
        '-t+[target dir]:dir:_files -/' \
        '-X[exclusive]' \
        '*:thumbcache db:_files -g "(thumbcache|iconcache)_*.db"'
}

_libwtcdb "$@"
