#compdef loki
# Documentation: https://grafana.com/docs/loki/latest/configure/
# Reference accessed: 2026-05-17
# Verified: grafana/loki upstream — Go flag-package single-dash
# long flags. Real surface: -config.file, -config.expand-env,
# -config.ballast-bytes, -target (all/read/write/backend/ingester/
# distributor/querier/query-frontend/query-scheduler/ruler/compactor/
# index-gateway/bloom-gateway), -print-config-stderr,
# -log-config-reverse-order, -list-targets, -shutdown-delay,
# -auth.enabled, -ui.enabled, -ui.debug, plus per-component config
# flags (-server.*, -log.level, -validation.*, etc.).
# Removed from prior file: bogus man.archlinux.org search URL.

_arguments -s \
  '*-config.file=[config file(s)]:file:_files -g "*.(yaml|yml)"' \
  '-config.expand-env[enable env var expansion]' \
  '-print-config-stderr[dump config to stderr]' \
  '-log-config-reverse-order[reverse config order]' \
  '-list-targets[list available targets]' \
  '-target=[components to run]:target:(all read write querier distributor ingester compactor query-frontend query-scheduler ruler index-gateway bloom-builder bloom-compactor bloom-gateway pattern-ingester table-manager)' \
  '-auth.enabled[require X-Scope-OrgID]' \
  '-shutdown-delay=[shutdown delay]:duration:' \
  '-metrics-namespace=[metrics namespace]:ns:' \
  '-ui.enabled[experimental UI]' \
  '-ui.debug[UI debug logging]' \
  '-ui.goldfish.enable[Goldfish query comparison]' \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)-version[show version]'
