#compdef nomad
# _nomad-bin — HashiCorp Nomad workload orchestrator (HashiCorp, Go); schedule containers/binaries/VMs at scale
# upstream: https://github.com/hashicorp/nomad

_nomad-bin() {
    local -a sub=(
        'acl:ACL commands'
        'agent:run a Nomad agent'
        'agent-info:show agent info'
        'alloc:allocation commands'
        'config:config commands'
        'deployment:deployment commands'
        'eval:evaluation commands'
        'exec:exec inside an alloc'
        'fmt:format jobspec'
        'job:job commands'
        'license:license commands'
        'login:login via OIDC'
        'monitor:tail agent logs'
        'namespace:namespace commands'
        'node:node commands'
        'operator:operator commands'
        'plugin:plugin commands'
        'quota:quota commands'
        'recommendation:recommendation commands'
        'run:alias for job run'
        'sentinel:sentinel commands'
        'server:server commands'
        'service:service commands'
        'setup:setup commands'
        'status:show job/alloc/server status'
        'stop:alias for job stop'
        'system:system commands'
        'tls:TLS helpers'
        'ui:open UI'
        'var:variable commands'
        'version:show version'
        'volume:volume commands'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-version[show version]' \
        '-autocomplete-install[install autocomplete]' \
        '-autocomplete-uninstall[uninstall autocomplete]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nomad subcommand' sub ;;
        args)
            case $words[1] in
                job) _arguments '1:job cmd:(deployments dispatch eval history init inspect plan promote restart revert run scaling-events status stop validate)' '*:job:' ;;
                alloc) _arguments '1:alloc cmd:(exec fs logs restart signal status stop)' '*:alloc id:' ;;
                node) _arguments '1:node cmd:(config drain eligibility meta status)' '*:node id:' ;;
                volume) _arguments '1:volume cmd:(claim create delete deregister detach init register status)' '*:args:' ;;
                var) _arguments '1:var cmd:(get init list lock purge put unlock)' '*:args:' ;;
                operator) _arguments '1:operator cmd:(api autopilot debug gossip metrics raft scheduler snapshot)' '*:args:' ;;
            esac
            ;;
    esac
}

_nomad-bin "$@"
