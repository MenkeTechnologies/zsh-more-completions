#compdef devbox-shell devbox-init
# _devbox-shell — Jetify Devbox portable dev environments shell+init subcommand alias (Jetify / Khan Engineering, Go); spf13/cobra
# upstream: https://github.com/jetify-com/devbox

_devbox-shell() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config=+[devbox.json]:file:_files -g "devbox.json"' \
        '-c+[devbox.json]:file:_files -g "devbox.json"' \
        '--env-file=+[env file]:file:_files' \
        '-e+[env file]:file:_files' \
        '--env=+[env var key=value]:list:' \
        '--print-env[print env script]' \
        '--pure[pure environment]' \
        '-p[pure environment]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--debug[debug]' \
        '--log-level=+[log level]:level:(debug info warning error)' \
        '--single-shell[single shell]' \
        '--no-update[no update]' \
        '--init-hook=+[init hook command]:str:' \
        '--include-go[include go]' \
        '--allow-insecure=+[allow insecure packages]:list:' \
        '*:packages-or-cmd:'
}

_devbox-shell "$@"
