#compdef openxr-explorer openxrexplorer
# Documentation: https://github.com/maluoi/openxr-explorer
# Reference accessed: 2026-05-27
# Verified: upstream src/openxrexplorer/app_cli.cpp argv parsing (case-insensitive
# match against -help/-h//h plus xr_tables entries by function or type name).

local curcontext="$curcontext" state line ret=1

# Only -help/-h/ /h are recognized as flags; every other argument is treated as
# a function or type name to dump (case-insensitive). Provide a few common
# OpenXR symbol prefixes as hints but allow free-form input.
local -a _oxr_hints
_oxr_hints=(
  'xrEnumerateInstanceExtensionProperties:list instance extensions'
  'xrEnumerateApiLayerProperties:list API layers'
  'xrGetSystem:dump system properties'
  'xrGetInstanceProperties:dump instance properties'
  'XrInstanceProperties:type dump'
  'XrSystemProperties:type dump'
  'XrViewConfigurationProperties:type dump'
)

_arguments -C \
  '(- *)'{-h,-help,/h}'[show usage and list available functions and types]' \
  '*: :->name' && ret=0

case $state in
  name)
    _describe -t names 'openxr function or type' _oxr_hints && ret=0
    ;;
esac

return ret
