#compdef fantomas
# Documentation: https://github.com/fsprojects/fantomas/blob/main/src/Fantomas/Program.fs
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Zsh completion for fantomas - F# source code formatter (Argu CLI)

local -a arguments

arguments=(
  '--help[show help information]'
  '--version[show fantomas version]'
  '--force[print output even if invalid F# code]'
  '--profile[print performance profiling information]'
  '--check[check if files need formatting (exit 0 ok, 1 changes needed, 99 error)]'
  '--daemon[launch LSP-like daemon for editor tooling]'
  '--out=[output file or directory]:path:_files'
  '(-v --verbosity)'{-v,--verbosity}'=[verbosity level]:level:(n normal d detailed)'
  '*:path:_files -g "*.(fs|fsi|fsx|ml|mli)"'
)

_arguments -s $arguments
