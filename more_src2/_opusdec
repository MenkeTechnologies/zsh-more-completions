#compdef opusdec
# Documentation: https://manpages.debian.org/testing/opus-tools/opusdec.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--quiet[suppress output]' \
  '--rate=[force decoding at given sample rate Hz]:rate:' \
  '--force-stereo[force decoding to stereo]' \
  '--gain=[adjust output gain dB (negative is quieter)]:db:' \
  '--no-dither[do not dither 16-bit output]' \
  '--float[output 32-bit float samples]' \
  '--force-wav[force RIFF wav header on output]' \
  '--packet-loss=[simulate packet loss percent]:pct:' \
  '--save-range=[save range coder data]:file:_files' \
  '*:input:_files'
