#compdef debbisect
# Documentation: https://manpages.debian.org/debbisect
# Source: debian/devscripts scripts/debbisect — bisect Debian snapshots to find a breaking package (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-d --debug)'{-d,--debug}'[show debug messages]' \
    '(-v --verbose)'{-v,--verbose}'[verbose output]' \
    '--cache=-[cache directory]:dir:_files -/' \
    '--nocache[disable cache]' \
    '--port=-[apt cache port]:port:_default' \
    '--depends=-[comma-separated dependencies]:list:_default' \
    '--qemu=-[create QEMU VM and pass ssh config]:ssh-config:_files' \
    '--architecture=-[chroot architecture]:arch:_default' \
    '--suite=-[chroot suite]:suite:_default' \
    '--components=-[comma/whitespace separated components]:components:(main contrib non-free non-free-firmware)' \
    '--no-find-exact-package[do not search for exact source package]' \
    '1:good (date or snapshot):_default' \
    '2:bad (date or snapshot):_default' \
    '3:test script:_files' \
    && ret=0

return ret
