#compdef resolvectl
# _resolvectl — systemd resolvectl (control + introspect systemd-resolved; subcommands: query/service/openpgp/tlsa/statistics/reset-statistics/flush-caches/reset-server-features/dns/domain/llmnr/mdns/nta/dnssec/dnsovertls/revert/log-level/monitor/show-cache/show-server-state; -t/-c DNS class/type filters, -p protocol, -i interface)
# upstream: https://github.com/systemd/systemd (src/resolve/resolvectl.c)
# Subcommands from systemd src/resolve/resolvectl.c on tip.

_resolvectl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '--help[show help]' \
        '--version[show version]' \
        '--no-pager[no pager]' \
        '--no-legend[no legend]' \
        '-4[IPv4 only]' \
        '-6[IPv6 only]' \
        '-i+[interface]:interface:_net_interfaces' \
        '--interface+[interface]:interface:_net_interfaces' \
        '-p+[protocol]:protocol:(dns llmnr mdns)' \
        '--protocol+[protocol]:protocol:(dns llmnr mdns)' \
        '-c+[DNS class]:class:(IN CH HS)' \
        '-t+[DNS type]:type:(A AAAA MX NS PTR TXT SRV CNAME CAA SOA TLSA OPENPGPKEY SVCB HTTPS)' \
        '--type+[DNS type]:type:' \
        '--service-address=*[show A/AAAA]:bool:(yes no)' \
        '--service-txt=*[show TXT]:bool:(yes no)' \
        '--cname=*[follow CNAME]:bool:(yes no)' \
        '--validate=*[DNSSEC]:bool:(yes no)' \
        '--synthesize=*[synthesize]:bool:(yes no)' \
        '--cache=*[cache]:bool:(yes no)' \
        '--zone=*[zone]:bool:(yes no)' \
        '--trust-anchor=*[trust anchor]:bool:(yes no)' \
        '--network=*[network]:bool:(yes no)' \
        '--search=*[search]:bool:(yes no)' \
        '-j[JSON output]' \
        '--json=*[json mode]:mode:(short pretty off)' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd) _describe -t commands 'resolvectl command' '(query service openpgp tlsa statistics reset-statistics flush-caches reset-server-features dns domain default-route llmnr mdns nta dnssec dnsovertls revert log-level monitor show-cache show-server-state status)' ;;
        args) _arguments '*:argument:' ;;
    esac
}

_resolvectl "$@"
