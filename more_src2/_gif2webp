#compdef gif2webp
# Documentation: gif2webp -h (libwebp)
# Source: Google libwebp gif2webp — convert animated GIF to WebP.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,-help}'[show help]' \
    '(-lossy -mixed)-lossy[encode using lossy compression]' \
    '(-lossy -mixed)-mixed[choose lossy/lossless per frame]' \
    '-near_lossless+[near-lossless preprocessing 0..100]:int:' \
    '-sharp_yuv[sharper RGB->YUV conversion (lossy)]' \
    '-q+[quality 0..100]:float:' \
    '-m+[compression method 0..6]:int:' \
    '-min_size[minimize output size]' \
    '-kmin+[min distance between key frames]:int:' \
    '-kmax+[max distance between key frames]:int:' \
    '-f+[filter strength 0..100]:int:' \
    '-metadata+[metadata copy list]:list:(all none icc xmp)' \
    '-loop_compatibility[Chrome <M62 compatibility]' \
    '-mt[multi-threaded]' \
    '(- *)-version[show version]' \
    '-v[verbose]' \
    '-quiet[suppress output]' \
    '-o+[output WebP]:file:_files -g "*.webp"' \
    '1:input GIF:_files -g "*.gif"' \
    && ret=0

return ret
