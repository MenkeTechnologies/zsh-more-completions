#compdef l2ping
# _l2ping — BlueZ l2ping (send L2CAP echo requests to a Bluetooth peer; -i hciX source, -c count, -d delay seconds, -s payload size, -t timeout, -f flood, -r request id, -v verbose, positional argument is the target BD_ADDR (XX:XX:XX:XX:XX:XX))
# upstream: https://github.com/bluez/bluez (tools/l2ping.c)
# Flags from bluez tools/l2ping.c on tip.

_l2ping() {
    _arguments \
        '-h[show help]' \
        '-i+[hciX source]:device:' \
        '-c+[ping count]:n:' \
        '-d+[delay seconds]:seconds:' \
        '-s+[payload bytes]:bytes:' \
        '-t+[timeout seconds]:seconds:' \
        '-f[flood ping]' \
        '-r[reverse: request id]' \
        '-v[verbose]' \
        '1:BD_ADDR:'
}

_l2ping "$@"
