#compdef grib_split
# Documentation: https://confluence.ecmwf.int/display/ECC/grib_split
# Source: ecmwf/eccodes tools/grib_split.pl — split GRIB2 multi-field messages into single-field (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '-d[debug output]' \
    '*:in or out file:_files' \
    && ret=0

return ret
