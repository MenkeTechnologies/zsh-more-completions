#compdef flowise
# Documentation: https://github.com/FlowiseAI/Flowise/tree/main/packages/server/src/commands
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# Flowise CLI (oclif-based). Most flags are env-var names accepted as
# --FLAG=value pairs (see base.ts). The full set is huge; common ones below.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'start:Start the Flowise server'
  'worker:Start a Flowise queue worker'
  'user:List users or reset a user password'
)

_arguments -s -S \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'flowise command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (start|worker)
        _arguments -s -S \
          '--PORT=[server port]:port:' \
          '--DEBUG=[enable debug mode]:bool:(true false)' \
          '--LOG_PATH=[log file path]:path:_files -/' \
          '--LOG_LEVEL=[log level]:level:(error warn info debug)' \
          '--DATABASE_TYPE=[database type]:type:(sqlite mysql postgres mariadb)' \
          '--DATABASE_PATH=[sqlite database path]:path:_files -/' \
          '--DATABASE_HOST=[database host]:host:_hosts' \
          '--DATABASE_PORT=[database port]:port:' \
          '--DATABASE_NAME=[database name]:name:' \
          '--DATABASE_USER=[database user]:user:' \
          '--DATABASE_PASSWORD=[database password]:password:' \
          '--CORS_ORIGINS=[allowed CORS origins]:origins:' \
          '--STORAGE_TYPE=[storage backend]:type:(local s3 gcs azure)' \
          '--FLOWISE_FILE_SIZE_LIMIT=[max upload file size]:limit:' \
          '--MODE=[runtime mode]:mode:(main queue)' \
          '--REDIS_URL=[Redis URL]:url:' && ret=0
        ;;
      (user)
        _arguments -s -S \
          '--email=[user email]:email:' \
          '--password=[new password]:password:' && ret=0
        ;;
    esac
    ;;
esac

return ret
