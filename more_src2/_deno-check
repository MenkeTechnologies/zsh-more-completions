#compdef deno-check
# Documentation: https://docs.deno.com/runtime/reference/cli/check/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--all[type check all modules including remote/npm]' \
  '(-I --allow-import)'{-I,--allow-import=}'[allow importing from remote hosts]:hosts' \
  '--deny-import=[deny importing from remote hosts]:hosts' \
  '--cert=[CA certificate PEM file]:file:_files' \
  '--check-js[enable type-checking of JavaScript]' \
  '--conditions=[custom conditions for npm exports]:conditions' \
  '(-c --config)'{-c,--config=}'[config file]:config:_files -g "deno.json*(-.)"' \
  '--no-config[do not use config file]' \
  '--doc[type-check JSDoc code blocks]' \
  '--doc-only[type-check JSDoc/Markdown code blocks only]' \
  '--frozen[error if lockfile is out of date]' \
  '--import-map=[import map file]:file:_files' \
  '--lock=[lock file]:file:_files' \
  '--no-lock[do not use lock file]' \
  '--no-npm[do not resolve npm modules]' \
  '--no-remote[do not resolve remote modules]' \
  '--node-modules-dir=[node_modules management mode]:mode' \
  '--minimum-dependency-age=[dependency age threshold]:duration' \
  '--no-code-cache[disable V8 code cache]' \
  '(-r --reload)'{-r,--reload=}'[reload source code cache]:cache blocklist' \
  '--v8-flags=[V8 engine flags]:flags' \
  '--vendor=[toggle local vendor folder]:mode' \
  '*:file:_files -g "*.(ts|tsx|js|jsx|mts|mjs)(-.)"' && return 0
