#compdef in-toto-sign
# _in-toto-sign — sign or verify an in-toto layout / link file (in-toto/in-toto)
# upstream: https://github.com/in-toto/in-toto
# Flags from in_toto/in_toto_sign.py + common_args.py.

_in-toto-sign() {
    local -a args
    args=(
        '(-f --file)'{-f+,--file=}'[input layout or link file]:file:_files'
        '*'{-k+,--key=}'[signing key path (repeatable)]:file:_files'
        '(-p --prompt)'{-p,--prompt}'[prompt for the signing-key password]'
        '*'{-g+,--gpg=}'[GPG key id(s) for signing (omit value to use the default key)]:gpg ids:'
        '--gpg-home=[GPG home directory]:dir:_files -/'
        '(-o --output)'{-o+,--output=}'[output path for the (re)signed file]:file:_files'
        '(-a --append)'{-a,--append}'[append the new signature instead of replacing existing signatures]'
        '--verify[verify signatures using --key / --gpg public keys]'
        '(-v --verbose)'{-v,--verbose}'[verbose output]'
        '(-q --quiet)'{-q,--quiet}'[quiet output]'
        '(- *)--version[show version]'
        '(- *)'{-h,--help}'[show help]'
    )
    _arguments -s -S $args
}

_in-toto-sign "$@"
