# ─── man_src overall quality ──────────────────────────────────────────────────

@test 'majority of man_src files reference a man page path' {
    local count_auto count_total
    count_auto=$(grep -rl 'Autogenerated from man page' "$msrc/" | wc -l | tr -d ' ')
    count_total=$(ls "$msrc/" | wc -l | tr -d ' ')
    local pct=$(( count_auto * 100 / count_total ))
    assert $pct is_greater_than 50
}

@test 'man_src files all use _arguments' {
    local bad=0
    for f in "$msrc/"_*; do
        grep -qF '_arguments' "$f" || (( bad += 1 )) || true
    done
    assert $bad equals 0
}

@test 'vast majority of man_src files end with _arguments -s call' {
    local match=0 total=0
    for f in "$msrc/"_*; do
        (( total += 1 ))
        grep -qF '_arguments -s $arguments' "$f" && (( match += 1 )) || true
    done
    local pct=$(( match * 100 / total ))
    assert $pct is_greater_than 95
}

@test 'vast majority of man_src files declare local arguments' {
    local match=0 total=0
    for f in "$msrc/"_*; do
        (( total += 1 ))
        grep -qF 'local arguments' "$f" && (( match += 1 )) || true
    done
    local pct=$(( match * 100 / total ))
    assert $pct is_greater_than 95
}

@test 'all man_src files pass syntax check' {
    local bad=0
    for f in "$msrc/"_*; do
        zsh -n "$f" 2>/dev/null || (( bad += 1 )) || true
    done
    assert $bad equals 0
}
