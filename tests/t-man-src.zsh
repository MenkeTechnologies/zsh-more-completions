@setup {
    unset -m "ZPWR_*"
    0="${${0:#$ZSH_ARGZERO}:-${(%):-%N}}"
    0="${${(M)0:#/*}:-$PWD/$0}"
    pluginDir="${0:h:A}"
    msrc="$pluginDir/man_src"
}

