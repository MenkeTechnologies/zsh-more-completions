#compdef maradns maradns.authoritative
# _maradns — MaraDNS authoritative server (Sam Trenholme's tiny secure authoritative DNS; -f config file (mararc), -t test config, -v verbose, -q quiet, --help; reads mararc syntax declaring per-zone csv2 files; the recursive companion is Deadwood)
# upstream: https://github.com/samboy/MaraDNS
# Flags from MaraDNS src/MaraDns.c on tip.

_maradns() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '-f+[config file]:file:_files -g "*.conf"' \
        '-t[test config + exit]' \
        '-v[verbose]' \
        '-q[quiet]'
}

_maradns "$@"
