#compdef nuke
# Documentation: https://github.com/rebuy-de/aws-nuke
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nuke - aws-nuke (remove all resources in an AWS account)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'resource-types:display all available resource types'
  'help:show help for a command'
  'version:show version'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-c --config)'{-c,--config}'=[path to config file]:config:_files -g "*.{yml,yaml}"' \
  '--profile=[AWS profile to use]:profile' \
  '--access-key-id=[AWS access key ID]:key-id' \
  '--secret-access-key=[AWS secret access key]:secret-key' \
  '--session-token=[AWS session token]:token' \
  '--default-region=[default AWS region]:region:(us-east-1 us-east-2 us-west-1 us-west-2 eu-west-1 eu-west-2 eu-west-3 eu-central-1 eu-north-1 ap-southeast-1 ap-southeast-2 ap-northeast-1 ap-northeast-2 ap-south-1 sa-east-1 ca-central-1)' \
  '--no-dry-run[actually delete resources (no dry run)]' \
  '--quiet[suppress output]' \
  '--no-prompt[do not prompt for confirmation]' \
  '*--target=[limit deletion to specified resource types]:resource-type' \
  '*--exclude=[exclude specified resource types from deletion]:resource-type' \
  '*--cloud-control=[enable additional Cloud Control API resources]:resource-type' \
  '1: :->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _describe -t commands 'nuke command' commands && ret=0
    ;;
esac

return ret
