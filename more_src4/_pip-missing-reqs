#compdef pip-missing-reqs pip-extra-reqs
# _pip-missing-reqs — find missing/extra requirements (r1chardj0n3s/pip-check-reqs)
# upstream: https://github.com/r1chardj0n3s/pip-check-reqs
# Flags from pip_check_reqs/find_missing_reqs.py (argparse).

_pip-missing-reqs() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '(-d --debug)'{-d,--debug}'[debug logging]' \
        '(-v --verbose)'{-v,--verbose}'[verbose logging]' \
        '--requirements-file=[requirements file]:file:_files -g "*.txt"' \
        '*'{-f+,--ignore-file=}'[file glob to ignore]:glob:' \
        '*'{-m+,--ignore-module=}'[module name to ignore]:module:' \
        '*:path:_files'
}

_pip-missing-reqs "$@"
