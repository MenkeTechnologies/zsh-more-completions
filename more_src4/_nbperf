#compdef nbperf
# Documentation: man nbperf(1)
# Source: netbsd/src usr.bin/nbperf — minimal perfect hash generator (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f[fast mode]' \
    '-p[stable seeding for reproducible output]' \
    '-s[make generated hash function static]' \
    '-a+[algorithm (default chm)]:algorithm:(chm chm3 bpz)' \
    '-c+[space utilisation parameter]:utilisation:_default' \
    '-h+[hash function]:hash:(mi_vector_hash)' \
    '-i+[iteration limit]:iterations:_default' \
    '-m+[write key mapping to file]:map-file:_files' \
    '-n+[generated function name]:name:_default' \
    '-o+[output file (default stdout)]:output:_files' \
    '1::input key file (default stdin):_files' \
    && ret=0

return ret
