#compdef menuconfig kconfig-mconf kconfig-nconf kconfig-conf nconfig xconfig gconfig
# _menuconfig — Linux Kconfig kconfig-mconf menuconfig CLI for the ncurses-based kernel configuration menu navigating Kconfig symbol selection set save load defconfig oldconfig olddefconfig allnoconfig allyesconfig (kernel team, C); getopt
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/torvalds/linux.git/tree/scripts/kconfig

_menuconfig() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-s[silent]' \
        '--silent[silent]' \
        '--oldaskconfig[old ask config]' \
        '--oldconfig[old config]' \
        '--olddefconfig[old default config]' \
        '--silentoldconfig[silent old config]' \
        '--syncconfig[sync config]' \
        '--defconfig=+[file]:file:_files -g "*defconfig"' \
        '--savedefconfig=+[file]:file:_files -g "*defconfig"' \
        '--allyesconfig[all-yes config]' \
        '--allnoconfig[all-no config]' \
        '--allmodconfig[all-mod config]' \
        '--alldefconfig[all-default config]' \
        '--randconfig[random config]' \
        '--listnewconfig[list new config]' \
        '--helpnewconfig[help new config]' \
        '--writedepend[write depend]' \
        '--menuconfig[ncurses menu]' \
        '--nconfig[ncurses panel]' \
        '--xconfig[Qt menu]' \
        '--gconfig[GTK menu]' \
        '--randconfig=+[seed]:n:' \
        '*:Kconfig file:_files -g "Kconfig* *.cfg"'
}

_menuconfig "$@"
