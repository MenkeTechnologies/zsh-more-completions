#compdef memtier_benchmark memtier-benchmark

_arguments -s -S \
  '(- *)'{-h,--help}'[display help and exit]' \
  '(- *)'{-v,--version}'[display version and exit]' \
  {-s,--server=}'[server address]:host:' \
  {-p,--port=}'[server port]:port:' \
  {-S,--socket=}'[UNIX socket path]:socket:_files' \
  {-P,--protocol=}'[protocol to use]:protocol:(redis memcache_text memcache_binary)' \
  {-a,--authenticate=}'[authentication password]:password:' \
  '--tls[enable TLS/SSL]' \
  '--tls-cert-file=[TLS certificate file]:file:_files' \
  '--tls-key-file=[TLS key file]:file:_files' \
  '--tls-ca-cert-file=[TLS CA certificate file]:file:_files' \
  {-x,--run-count=}'[number of full-test iterations]:count:' \
  {-D,--data-size=}'[data size in bytes]:size:' \
  '--data-size-range=[data size range]:min-max:' \
  '--data-size-pattern=[data size pattern]:pattern:(S R)' \
  {-R,--random-data}'[use random data]' \
  '--data-verify[verify data integrity]' \
  '--data-import=[import data from file]:file:_files' \
  {-c,--clients=}'[number of clients per thread]:count:' \
  {-t,--threads=}'[number of threads]:count:' \
  '--ratio=[SET:GET ratio]:ratio:' \
  '--pipeline=[number of pipelined requests]:count:' \
  {-n,--requests=}'[number of requests per client]:count:' \
  '--test-time=[test duration in seconds]:seconds:' \
  {-d,--debug}'[enable debug output]' \
  '--out-file=[output file]:file:_files' \
  '--json-out-file=[JSON output file]:file:_files' \
  '--hdr-file-prefix=[HDR file prefix]:prefix:' \
  '--print-percentiles=[percentiles to print]:list:' \
  '--cluster-mode[enable cluster mode]' \
  '--hide-histogram[hide latency histogram]' \
  '--distinct-client-seed[use distinct random seed per client]' \
  '--randomize[randomize order of commands]' \
  '--key-prefix=[key prefix]:prefix:' \
  '--key-minimum=[minimum key index]:number:' \
  '--key-maximum=[maximum key index]:number:' \
  '--key-pattern=[key access pattern]:pattern:(R S G P)' \
  '--key-stddev=[key Gaussian standard deviation]:number:' \
  '--key-median=[key Gaussian median]:number:' \
  '--command=[arbitrary command to send]:command:' \
  '--command-key-pattern=[key pattern for custom commands]:pattern:' \
  '--command-ratio=[ratio for custom commands]:ratio:' \
  '--reconnect-interval=[reconnect interval]:interval:' \
  '--multi-key-get=[number of keys per GET]:count:' \
  '--select-db=[database number]:db:' \
  '--wait-ratio=[SET:GET wait ratio]:ratio:'
