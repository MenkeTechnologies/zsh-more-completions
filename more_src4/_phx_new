#compdef phx_new phx.new
# Documentation: https://github.com/phoenixframework/phoenix/blob/main/installer/lib/mix/tasks/phx.new.ex
# Reference accessed: 2026-05-27
# Verified: upstream @switches list in Mix.Tasks.Phx.New and @moduledoc options block.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '--app=[name of the OTP application]:app:' \
  '--module=[base module name of the generated skeleton]:module:' \
  '--web-module=[web module name (umbrella projects)]:module:' \
  '--database=[Ecto database adapter]:adapter:(postgres mysql mssql sqlite3)' \
  '--adapter=[HTTP adapter]:adapter:(cowboy bandit)' \
  '--prefix=[project namespace prefix]:prefix:' \
  '--umbrella[generate an umbrella project]' \
  '--no-html[do not generate HTML views]' \
  '--no-ecto[do not generate Ecto files]' \
  '--no-assets[shortcut for --no-esbuild --no-tailwind]' \
  '--no-tailwind[do not include Tailwind dependencies and assets]' \
  '--no-esbuild[do not include esbuild dependencies and assets]' \
  '--no-dashboard[do not include Phoenix.LiveDashboard]' \
  '--live[generate a LiveView skeleton with auth]' \
  '--no-live[disable LiveView socket setup in Endpoint]' \
  '--no-mailer[do not generate Swoosh mailer files]' \
  '--no-gettext[do not generate gettext files]' \
  '--binary-id[use binary_id as primary key type in Ecto schemas]' \
  '--install[fetch and install dependencies after generation]' \
  '--no-install[skip fetching and installing dependencies]' \
  '--verbose[use verbose output]' \
  '--from-elixir-install[invoked by the elixir installer]' \
  '--no-version-check[skip latest phx_new version check]' \
  '--no-agents-md[do not generate AGENTS.md]' \
  '(-v --version)'{-v,--version}'[print the Phoenix installer version]' \
  '1:path:_files -/' && ret=0

return ret
