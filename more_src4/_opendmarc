#compdef opendmarc
# Documentation: https://manpages.debian.org/bookworm/opendmarc/opendmarc.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm opendmarc(8) manpage OPTIONS.
# Removed from prior file: fabricated --help/--version long flags (opendmarc
# uses single-letter opts only) and bogus man.archlinux.org search URL.

# opendmarc: DMARC milter for MTAs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[automatically re-start on failure]' \
  '-c[configuration file]:file:_files' \
  '-f[run in foreground (do not fork)]' \
  '-l[log activity via syslog]' \
  '-n[parse config and CLI args, report errors, then exit]' \
  '-p[milter socket for receiving connections from sendmail]:spec:' \
  '-P[process ID file]:file:_files' \
  '-t[read email messages from named files as test input]:files:_files' \
  '-u[become this userid (optionally\:group) before operations]:user:_users' \
  '-v[increase verbose output during test mode (repeatable)]' \
  '-V[print version and supported algorithms, then exit]' && ret=0
return ret
