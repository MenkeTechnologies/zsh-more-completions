#compdef padthv1 padthv1_jack padthv1_lv2
# _padthv1 — Rui Nuno Capela padthv1 polyphonic additive PADsynth-based pad synthesizer with LV2 plugin and standalone JACK app (rncbc team, C++/Qt); Qt argparse
# upstream: https://padthv1.sourceforge.io/

_padthv1() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-n+[client name]:str:' \
        '--client-name=+[client name]:str:' \
        '-J+[jack server name]:str:' \
        '--jack-server=+[jack server name]:str:' \
        '-A[no auto connect]' \
        '--no-auto-connect[no auto connect]' \
        '-G[no GUI]' \
        '--no-gui[no GUI]' \
        '-p+[preset]:str:' \
        '--preset=+[preset]:str:' \
        '--style=+[Qt style]:s:(fusion windows windowsvista gtk2 macintosh)' \
        '--platform=+[platform]:p:(xcb wayland cocoa windows direct2d)' \
        '*:padthv1 preset file:_files -g "*.padthv1 *.lv2"'
}

_padthv1 "$@"
