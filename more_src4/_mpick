#compdef mpick
# Documentation: https://manpages.ubuntu.com/manpages/jammy/man1/mpick.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Advanced message filter.
# Real flags: -F file (read expr from file), -T (include whole thread),
# -t test (filter by expression), -v (print stats).
# Removed from prior file: fabricated -t/-T semantics.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-F+[read expression from file]:file:_files' \
  '-T[include whole thread]' \
  '-t+[only show messages matching expression]:expression:' \
  '-v[print number tested and picked to stderr]' \
  '*:maildir:_files -/' && ret=0

return ret
