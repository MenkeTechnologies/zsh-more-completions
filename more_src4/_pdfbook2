#compdef pdfbook2
# Documentation: pdfbook2 --help
# Source: reorder a PDF into booklet form (pdfjam-based).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-p --paper)'{-p+,--paper=}'[paper format keyword]:keyword:(a4paper a3paper a5paper a6paper b4paper b5paper b6paper letterpaper legalpaper executivepaper)' \
    '(-s --short-edge)'{-s,--short-edge}'[booklet for short-edge double-sided printing]' \
    '(-n --no-crop)'{-n,--no-crop}'[prevent cropping to the content area]' \
    '(-o --outer-margin)'{-o+,--outer-margin=}'[outer margin (default 40)]:int:' \
    '(-i --inner-margin)'{-i+,--inner-margin=}'[inner margin between pages (default 150)]:int:' \
    '(-t --top-margin)'{-t+,--top-margin=}'[top margin (default 30)]:int:' \
    '(-b --bottom-margin)'{-b+,--bottom-margin=}'[bottom margin (default 30)]:int:' \
    '--signature=[signature for booklet (multiple of 4)]:int:' \
    '--signature\\*=[same as --signature]:int:' \
    '--resolution=[ghostscript resolution in bp (default 72)]:int:' \
    '*:pdf file:_files -g "*.pdf"' \
    && ret=0

return ret
