#compdef nwg-bar
# Documentation: https://github.com/nwg-piotr/nwg-launchers
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nwg-bar - GTK3 button bar for Wayland (nwg-launchers)

_arguments \
  '(- *)-h[show help]' \
  '-v[arrange buttons vertically]' \
  '-ha+[horizontal alignment]:alignment:(l r)' \
  '-va+[vertical alignment]:alignment:(t b)' \
  '-t+[template file name (default: bar.json)]:file:_files -g "*.json"' \
  '-c+[CSS file name (default: style.css)]:file:_files -g "*.css"' \
  '-o+[background opacity (0.0-1.0, default 0.9)]:opacity:' \
  '-b+[background colour in RRGGBB or RRGGBBAA]:color:' \
  '-s+[button image size (default: 72)]:size:' \
  '-g+[GTK theme name]:theme:' \
  '-wm+[window manager name if not detected]:wm:' \
  '-layer-shell-layer+[layer-shell layer]:layer:(BACKGROUND BOTTOM TOP OVERLAY)' \
  '-layer-shell-exclusive-zone+[exclusive zone]:zone:'
