#compdef pc1toppm
# Documentation: man pc1toppm (Netpbm)
# Source: convert an Atari Degas PC1 compressed image to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pc1 file:_files -g "*.pc1"' \
    && ret=0

return ret
