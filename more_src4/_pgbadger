#compdef pgbadger
# Documentation: https://github.com/darold/pgbadger
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments \
  '(-a --average)'{-a,--average}'[average queries duration]:minutes' \
  '(-A --histo-average)'{-A,--histo-average}'[histogram average for hourly report]:minutes' \
  '(-b --begin)'{-b,--begin}'[start date/time for log parsing]:datetime' \
  '(-c --dbclient)'{-c,--dbclient}'[only report for given client]:host' \
  '(-C --nocomment)'{-C,--nocomment}'[remove comments from normalized queries]' \
  '(-d --dbname)'{-d,--dbname}'[only report for given database]:dbname' \
  '(-D --dns-resolv)'{-D,--dns-resolv}'[resolve IP addresses to hostnames]' \
  '(-e --end)'{-e,--end}'[end date/time for log parsing]:datetime' \
  '(-E --explode)'{-E,--explode}'[explode the report by day]' \
  '(-f --format)'{-f,--format}'[log file format]:format:(syslog syslog2 stderr jsonlog cvs pgbouncer logplex rds redshift)' \
  '(-G --nograph)'{-G,--nograph}'[disable graphs in HTML output]' \
  '(-h --help)'{-h,--help}'[show help message]' \
  '(-H --html-outdir)'{-H,--html-outdir}'[directory where HTML report is written]:dir:_files -/' \
  '(-i --ident)'{-i,--ident}'[programname used in syslog lines]:ident' \
  '(-I --incremental)'{-I,--incremental}'[incremental mode]' \
  '(-j --jobs)'{-j,--jobs}'[number of jobs to run at once]:jobs' \
  '(-J --Jobs)'{-J,--Jobs}'[number of log files to parse in parallel]:jobs' \
  '(-l --last-parsed)'{-l,--last-parsed}'[file to store last parsed position]:file:_files' \
  '(-L --logfile-list)'{-L,--logfile-list}'[file containing list of log files to parse]:file:_files' \
  '(-m --maxlength)'{-m,--maxlength}'[max length of a query]:length' \
  '(-M --no-multiline)'{-M,--no-multiline}'[do not collect multiline statements]' \
  '(-n --nohighlight)'{-n,--nohighlight}'[disable SQL syntax highlighting]' \
  '(-N --appname)'{-N,--appname}'[only report for given application name]:appname' \
  '(-o --outfile)'{-o,--outfile}'[output file]:file:_files' \
  '(-O --outdir)'{-O,--outdir}'[output directory for incremental mode]:dir:_directories' \
  '(-p --prefix)'{-p,--prefix}'[log line prefix]:prefix' \
  '(-P --no-prettify)'{-P,--no-prettify}'[disable SQL pretty-printing]' \
  '(-q --quiet)'{-q,--quiet}'[do not print anything to stdout]' \
  '(-Q --query-numbering)'{-Q,--query-numbering}'[add numbering to queries]' \
  '(-r --remote-host)'{-r,--remote-host}'[parse log files on remote host]:host' \
  '(-R --retention)'{-R,--retention}'[number of weeks to retain in incremental mode]:weeks' \
  '(-s --sample)'{-s,--sample}'[number of query samples to show]:number' \
  '(-S --select-only)'{-S,--select-only}'[only report SELECT queries]' \
  '(-t --top)'{-t,--top}'[number of queries to show]:number' \
  '(-T --title)'{-T,--title}'[report title]:title' \
  '(-u --dbuser)'{-u,--dbuser}'[only report for given user]:user' \
  '(-U --exclude-user)'{-U,--exclude-user}'[exclude given user from report]:user' \
  '(-v --verbose)'{-v,--verbose}'[enable verbose mode]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-w --watch-mode)'{-w,--watch-mode}'[only report errors]' \
  '(-W --wide-char)'{-W,--wide-char}'[encode HTML output of queries into UTF-8]' \
  '(-x --extension)'{-x,--extension}'[output format]:format:(text html bin json tsung)' \
  '(-X --extra-files)'{-X,--extra-files}'[write CSS and JS to separate files]' \
  '(-z --zcat)'{-z,--zcat}'[full path to decompression program]:program:_command_names -e' \
  '(-Z --timezone)'{-Z,--timezone}'[timezone offset in hours]:hours' \
  '--pie-limit[limit pie chart entries]:number' \
  '*--exclude-query=[regex to exclude queries]:regex' \
  '*--exclude-db=[databases to exclude]:dbname' \
  '--anonymize[anonymize literals in queries]' \
  '--noreport[disable reports in incremental mode]' \
  '--journalctl=[parse output of journalctl]:command' \
  '--pid-dir=[directory for the pid file]:dir:_files -/' \
  '--pid-file=[pid file path]:file:_files' \
  '--rebuild[rebuild HTML reports]' \
  '--start-monday[start week on Monday]' \
  '--iso-week-number[use ISO 8601 week numbers]' \
  '--no-week[disable weekly reports]' \
  '--normalized-only[only dump normalized queries]' \
  '--keep-comments[preserve query comments]' \
  '--disable-error[disable error report]' \
  '--disable-hourly[disable hourly report]' \
  '--disable-type[disable query type report]' \
  '--disable-query[disable query report]' \
  '--disable-session[disable session report]' \
  '--disable-connection[disable connection report]' \
  '--disable-lock[disable lock report]' \
  '--disable-temporary[disable temporary file report]' \
  '--disable-checkpoint[disable checkpoint report]' \
  '--disable-autovacuum[disable autovacuum report]' \
  '*:log file:_files'
