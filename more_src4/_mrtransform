#compdef mrtransform
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrtransform.html
# Source: MRtrix3/mrtrix3 cmd/mrtransform.cpp — apply linear/non-linear spatial transformations (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-linear+[linear transform file (4x4)]:transform:_files' \
    '-flip+[flip along comma-separated axes]:axes:_default' \
    '-inverse[invert the linear transform]' \
    '-half[apply half the linear transform]' \
    '-replace+[replace header transform with one from file]:file:_files' \
    '-identity[set header transform to identity]' \
    '-template+[reslice to this template image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-midway_space[reslice to midway space between input and template]' \
    '-interp+[interpolation method]:method:(nearest linear cubic sinc)' \
    '-oversample+[oversampling factor(s)]:factor:_default' \
    '-warp+[warp image to apply]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-warp_full+[full 5D warp image]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-from+[take half/inverse from this image (1 or 2)]:n:(1 2)' \
    '-modulate+[intensity modulation method]:method:(fod jac)' \
    '-directions+[directions file [az el]]:file:_files' \
    '-reorient_fod+[reorient FODs (true/false)]:bool:(true false)' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-strides+[output data strides]:strides:_default' \
    '-datatype+[output datatype]:dtype:(float16 cfloat16 float32 cfloat32 float64 cfloat64 int8 uint8 int16 uint16 int32 uint32 int64 uint64 bit)' \
    '1:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '2:output image:_files' \
    && ret=0

return ret
