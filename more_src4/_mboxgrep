#compdef mboxgrep
# Documentation: man mboxgrep(1)
# Source: dspiljar/mboxgrep src/info.c — search MAILBOX for messages matching PATTERN (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[help screen]' \
    '(- *)'{-V,--version}'[version, copyright, compile-time options]' \
    {-r,--recursive}'[descend into directories recursively]' \
    {-c,--count}'[print count of matching messages]' \
    {-d,--delete}'[delete matching messages]' \
    {-nd,--no-duplicates}'[ignore duplicate messages]' \
    {-o+,--output=}'[write messages to mailbox]:mailbox:_files' \
    {-p+,--pipe=}'[pipe each found message to command]:command:_command_names -e' \
    {-s,--no-messages}'[suppress most error messages]' \
    '--debug[debug messages]' \
    '(-E -G -P)'{-E,--extended-regexp}'[extended regex]' \
    '(-E -G -P)'{-G,--basic-regexp}'[basic regex]' \
    '(-E -G -P)'{-P,--perl-regexp}'[Perl regex]' \
    {-e+,--regexp=}'[pattern]:pattern:_default' \
    {-i,--ignore-case}'[ignore case]' \
    {-v,--invert-match}'[select non-matching messages]' \
    '(-B)'{-H,--headers}'[match against headers]' \
    '(-H)'{-B,--body}'[match against body]' \
    {-nl,--no-file-lock}'[do not lock files]' \
    {-l+,--file-lock=}'[locking method]:method:(fcntl flock none)' \
    {-m+,--mailbox-format=}'[mailbox type]:type:(mbox zmbox bz2mbox mh nnml nnmh maildir)' \
    '1:pattern:_default' \
    '*:mailbox:_files' \
    && ret=0

return ret
