#compdef pamtohtmltbl
# Documentation: man pamtohtmltbl (Netpbm)
# Source: render a Netpbm image as an HTML table of colored cells.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-transparent=[color treated as transparent]:color:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
