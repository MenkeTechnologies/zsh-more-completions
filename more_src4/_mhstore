#compdef mhstore
# Documentation: man mhstore(1)
# Source: nmh uip/mhstore.c (master) — store MIME message parts to files (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-auto -noauto)-auto[auto-store using filename hints]' \
    '(-auto -noauto)-noauto[interactive store]' \
    '(-check -nocheck)-check[check MIME structure]' \
    '(-check -nocheck)-nocheck[no check]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '-file+[message file]:file:_files' \
    '-outfile+[output file]:file:_files' \
    '*-part+[part number]:N:_default' \
    '*-type+[content type filter]:type:_default' \
    '-rcache+[read cache policy]:policy:(public private never ask)' \
    '-wcache+[write cache policy]:policy:(public private never ask)' \
    '-version[show version]' \
    '-help[show help]' \
    '-clobber+[overwrite policy]:policy:(always auto suffix ask never)' \
    '-debug[debug output]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
