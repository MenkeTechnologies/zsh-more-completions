#compdef plasma-windowed plasmawindowed
# _plasma-windowed — KDE Plasma plasma-windowed CLI launching a single Plasma containment widget inside a standalone window for development testing isolated invocation of clock-widget weather-widget kicker-applet etc. outside the panel desktop shell context (KDE team, C++); Qt argparse
# upstream: https://invent.kde.org/plasma/plasma-workspace

_plasma-windowed() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-a+[applet args]:str:' \
        '--args=+[args]:str:' \
        '-s[hide statusbar]' \
        '--statusbar[show statusbar]' \
        '--hide-systray[hide system tray]' \
        '--show-systray[show system tray]' \
        '--help-all[show all options]' \
        '--help-qt[show Qt options]' \
        '--help-kde[show KDE options]' \
        '*:applet:'
}

_plasma-windowed "$@"
