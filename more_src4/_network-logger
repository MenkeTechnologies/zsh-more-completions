#compdef network-logger
# _network-logger — containerd NRI sample plugin that logs container network-namespace + interface events
# upstream: https://github.com/containerd/nri
# Flags from plugins/network-logger/plugin.go on tip.

_network-logger() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--socket=[path to NRI socket]:socket:_files'
}

_network-logger "$@"
