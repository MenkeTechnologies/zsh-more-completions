#compdef mocha
# Documentation: https://mochajs.org/
# Source: mochajs/mocha test runner — common CLI flags from default `.mocharc.json` + `mocha --help`.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-A --async-only)'{-A,--async-only}'[require all tests use a callback / return a Promise]' \
    '(-b --bail)'{-b,--bail}'[stop after first test failure]' \
    '(-c --color --no-color)'{-c,--color}'[force color output]' \
    '(-c --color --no-color)--no-color[disable color output]' \
    '*'{-f,--fgrep=}'[only run tests whose name includes string]:str:' \
    '(-g --grep)'{-g+,--grep=}'[only run tests whose name matches regex]:regex:' \
    '*--global=[allow leak of named global]:name:' \
    '--inspect=-[debugger inspect (port)]:port:' \
    '--inspect-brk=-[break on first line of script (port)]:port:' \
    '--retries=[retry failed tests N times]:n:' \
    '(-R --reporter)'{-R+,--reporter=}'[output reporter]:reporter:(spec dot nyan tap landing list progress json min doc markdown xunit junit)' \
    '--reporter-option=[reporter option (key=value)]:key=value:' \
    '*'{-r,--require=}'[require module (pretest)]:module:' \
    '(-u --ui)'{-u+,--ui=}'[test interface]:ui:(bdd tdd qunit exports)' \
    '(-w --watch)'{-w,--watch}'[watch files for changes]' \
    '--watch-files=[files/globs to watch (comma-separated)]:globs:' \
    '*--watch-ignore=[files to ignore in watch mode]:glob:' \
    '*--exclude=[file(s) to exclude]:glob:' \
    '*--extension=[file extension(s) to load]:ext:' \
    '--ignore-leaks[ignore global variable leaks]' \
    '--check-leaks[check for global variable leaks]' \
    '--forbid-only[fail on use of .only]' \
    '--forbid-pending[fail on use of .skip]' \
    '--full-trace[show full stack trace on failure]' \
    '--inline-diffs[display diffs inline]' \
    '--invert[invert --grep / --fgrep]' \
    '--reporter-option-color=-[reporter option]:option:' \
    '(-s --slow)'{-s+,--slow=}'[slow-test threshold (ms)]:ms:' \
    '(-S --sort)'{-S,--sort}'[sort test files]' \
    '(-t --timeout)'{-t+,--timeout=}'[test timeout (ms)]:ms:' \
    '*'{-p,--parallel}'[run tests in parallel]' \
    '--jobs=[parallel worker count]:n:' \
    '--package=[path to package.json]:file:_files' \
    '--config=[path to config file]:file:_files' \
    '--no-config[skip config-file lookup]' \
    '--diff[show diff on failure]' \
    '--no-diff[do not show diff on failure]' \
    '--dry-run[report tests without running them]' \
    '--fail-zero[fail when no tests are encountered]' \
    '--recursive[recurse into subdirectories]' \
    '--reporters[list available reporters]' \
    '*:test file or glob:_files' \
    && ret=0

return ret
