#compdef promql
# _promql-cli — query Prometheus from the command line (nalbury/promql-cli)
# upstream: https://github.com/nalbury/promql-cli
# Subcommands from cmd/ (cobra).

_promql-cli() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--config=[config file (default $HOME/.promql-cli.yaml)]:file:_files' \
        '--host=[Prometheus server URL]:url:' \
        '--step=[results step duration (e.g. 1m)]:duration:' \
        '--start=[range start (lookback duration or ISO 8601)]:start:' \
        '--end=[range end (now or ISO 8601)]:end:' \
        '--time=[time for instant queries (now or ISO 8601)]:time:' \
        '--output=[output format override]:format:(json csv)' \
        '--no-headers[disable table headers]' \
        '--timeout=[query timeout (seconds)]:seconds:' \
        '--auth-type=[HTTP auth scheme (Basic/Bearer)]:type:(Basic Bearer)' \
        '--auth-credentials=[HTTP auth credentials]:credentials:' \
        '--auth-credentials-file=[file containing HTTP auth credentials]:file:_files' \
        '--tls_config.ca_cert_file=[CA cert file]:file:_files' \
        '--tls_config.cert_file=[client cert file]:file:_files' \
        '--tls_config.key_file=[client key file]:file:_files' \
        '--tls_config.servername=[TLS server name]:name:' \
        '--tls_config.insecure_skip_verify[skip TLS verification]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'labels:list labels for a given query'
                'meta:show type and help metadata for a metric'
                'metrics:list Prometheus metric names matching query'
            )
            _describe -t commands command cmds || _message 'PromQL query'
            ;;
    esac
}

_promql-cli "$@"
