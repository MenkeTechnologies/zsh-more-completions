#compdef phantasia
# Documentation: man phantasia(6)
# Source: openbsd/src games/phantasia/main.c — interterminal fantasy game (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-s[short — no title page]' \
    '-H[print Header only and exit]' \
    '-a[list active users and exit]' \
    '-p[purge old players and exit]' \
    '-S[set Wizard mode (uid 0 only)]' \
    '-x[examine character stats]' \
    '-m[list monsters and exit]' \
    '-b[show scoreboard and exit]' \
    && ret=0

return ret
