autoload -U is-at-least

_nix-forecast() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'()-c+[Flake reference pointing to a NixOS or nix-darwin configuration]:CONFIGURATION:_default' \
'()--configuration=[Flake reference pointing to a NixOS or nix-darwin configuration]:CONFIGURATION:_default' \
'(-c --configuration)-o+[Flake reference pointing to a standalone home-manager configuration]:HOME:_default' \
'(-c --configuration)--home=[Flake reference pointing to a standalone home-manager configuration]:HOME:_default' \
'*-b+[URLs of the substituters to check (can be passed more than once)]:BINARY_CACHES:_default' \
'*--binary-caches=[URLs of the substituters to check (can be passed more than once)]:BINARY_CACHES:_default' \
'-f+[Flake reference of nixpkgs (or other package repository)]:FLAKE:_default' \
'--flake=[Flake reference of nixpkgs (or other package repository)]:FLAKE:_default' \
'-s[Show a list of store paths not found in the substituter]' \
'--show-missing[Show a list of store paths not found in the substituter]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
'*::installables -- A list of Nix installables to look for. If not given, all paths in nixpkgs are checked:_default' \
&& ret=0
}

(( $+functions[_nix-forecast_commands] )) ||
_nix-forecast_commands() {
    local commands; commands=()
    _describe -t commands 'nix-forecast commands' commands "$@"
}

if [ "$funcstack[1]" = "_nix-forecast" ]; then
    _nix-forecast "$@"
else
    compdef _nix-forecast nix-forecast
fi
