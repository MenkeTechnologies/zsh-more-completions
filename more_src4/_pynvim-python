#compdef pynvim-python
# Documentation: https://docs.python.org/3/using/cmdline.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pynvim-python is a thin wrapper that delegates to the system Python
# interpreter, so it accepts the standard CPython command-line options.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-c+[program passed in as string]:cmd:' \
  '-m+[run library module as script]:module:' \
  '-V[print version (also --version)]' \
  '--version[print version]' \
  '(- *)'{-h,--help}'[show help]' \
  '*:script:_files -g "*.py"' && ret=0

return ret
