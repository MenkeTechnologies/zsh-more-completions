#compdef mtail
# Documentation: https://github.com/google/mtail/blob/main/docs/Deploying.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mtail: extract metrics from log files (Google).
# Uses Go's flag package: single-dash long flags are also accepted but the
# canonical form documented upstream is double-dash long flag with '='.

_arguments -s -S \
  '*--logs=[log file(s) glob or path to tail]:log:_files' \
  '--progs=[directory of mtail programs (.mtail)]:directory:_directories' \
  '--port=[HTTP listen port for metrics UI (default 3903)]:port:' \
  '--address=[listen address (default all)]:address:' \
  '--poll_interval=[poll interval for active logs (default 250ms)]:duration:' \
  '--poll_log_interval=[poll interval for new/deleted logs (default 250ms)]:duration:' \
  '--expired_metrics_gc_interval=[expired metrics GC interval (default 1h)]:duration:' \
  '--stale_log_gc_interval=[stale log file GC interval (default 1h)]:duration:' \
  '--one_shot[oneshot mode for debugging]' \
  '--override_timezone=[timezone for timestamps]:tz:' \
  '--collectd_socketpath=[unix socket for collectd integration]:path:_files' \
  '--graphite_host_port=[host:port for Graphite/carbon]:hostport:' \
  '--statsd_hostport=[host:port for StatsD]:hostport:' \
  '--metric_push_interval_seconds=[push frequency]:seconds:' \
  '--vm_logs_runtime_errors[log runtime errors from VM]' \
  '--logtostderr[also log to stderr]' \
  '--vmodule=[per-module verbosity spec]:spec:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*::arguments: _default'
