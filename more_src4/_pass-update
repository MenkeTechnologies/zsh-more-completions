#compdef pass-update
# Documentation: https://github.com/roddhjav/pass-update
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pass-update - pass extension for updating passwords

_arguments \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-V --version)'{-V,--version}'[show version]' \
  '(-c --clip)'{-c,--clip}'[copy password to clipboard]' \
  '(-n --no-symbols)'{-n,--no-symbols}'[exclude non-alphanumeric characters]' \
  '(-l --length)'{-l,--length}'=[generated password length]:length:' \
  '(-a --auto-length)'{-a,--auto-length}'[match previous password length]' \
  '(-p --provide)'{-p,--provide}'[manually enter password]' \
  '(-m --multiline)'{-m,--multiline}'[update all lines, not just the first]' \
  '(-i --include)'{-i,--include}'=[only update entries matching regex]:pattern:' \
  '(-e --exclude)'{-e,--exclude}'=[skip entries matching regex]:pattern:' \
  '(-E --edit)'{-E,--edit}'[open in editor]' \
  '(-f --force)'{-f,--force}'[skip confirmation prompts]' \
  '*:pass-name:' \
  && return 0
