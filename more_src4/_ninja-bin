#compdef ninja
# _ninja-bin — Ninja small fast build system (Evan Martin / Google, C++); build files generated by CMake/Meson/gn
# upstream: https://github.com/ninja-build/ninja

_ninja-bin() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--quiet[quiet]' \
        '-C+[change to dir]:dir:_files -/' \
        '-f+[build file]:file:_files -g "build.ninja"' \
        '-j+[jobs]:n:' \
        '-k+[keep going N failures]:n:' \
        '-l+[max load avg]:f:' \
        '-n[dry run]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[debug mode]:mode:(stats explain keepdepfile keeprsp nostatcache)' \
        '-t+[tool]:tool:(browse clean commands compdb deps graph inputs list missingdeps query recompact restat rules targets)' \
        '-w+[warnings]:str:' \
        '*:target:'
}

_ninja-bin "$@"
