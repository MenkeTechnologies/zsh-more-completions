#compdef openskills
# Documentation: https://github.com/numman-ali/openskills
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for openskills - Anthropic skills CLI

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'install:add skills from GitHub, local paths, or private repos'
  'sync:refresh the AGENTS.md file with installed skills'
  'list:display currently installed skills'
  'read:load a skill content for agent invocation'
  'update:refresh installed skills from their sources'
  'manage:interactively remove skills'
  'remove:delete a specific skill'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--global[install to user home directory instead of project]' \
  '--universal[use .agent/skills/ instead of .claude/skills/]' \
  '(-y --yes)'{-y,--yes}'[skip confirmation prompts]' \
  '(-o --output)'{-o+,--output=}'[custom output file path]:file:_files' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'openskills command' commands && ret=0 ;;
esac

return ret
