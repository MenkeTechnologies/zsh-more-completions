#compdef papermill2
# _papermill2 — nteract papermill2 CLI command-line frontend wrapping the Papermill notebook parameterization execution analysis tool providing input output parameters parameters-file kernel cwd progress-bar log-output engine-name version no-execution prepare-only report-mode start-timeout request-save-on-cell-execute (nteract team, Python); click
# upstream: https://papermill.readthedocs.io/

_papermill2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-p+[parameter]:str:' \
        '--parameters=+[k v]:str:' \
        '-r+[raw parameter]:str:' \
        '--parameters_raw=+[k v]:str:' \
        '-f+[parameters file]:file:_files -g "*.yaml *.yml *.json"' \
        '--parameters_file=+[file]:file:_files -g "*.yaml *.yml *.json"' \
        '-y+[parameters YAML]:str:' \
        '--parameters_yaml=+[yaml]:str:' \
        '-b+[parameters base64]:str:' \
        '--parameters_base64=+[base64]:str:' \
        '--inject-input-path[inject input path]' \
        '--inject-output-path[inject output path]' \
        '--inject-paths[inject paths]' \
        '--engine=+[name]:str:' \
        '--request-save-on-cell-execute=+[bool]:s:(true false)' \
        '--prepare-only[prepare only]' \
        '-k+[kernel name]:str:' \
        '--kernel=+[name]:str:' \
        '-l+[language]:l:(python r julia bash)' \
        '--language=+[lang]:l:(python r julia bash)' \
        '--cwd=+[dir]:dir:_files -/' \
        '--progress-bar[show progress bar]' \
        '--no-progress-bar[no progress bar]' \
        '--log-output[log output]' \
        '--no-log-output[no log output]' \
        '--log-level=+[l]:l:(NOTSET DEBUG INFO WARNING ERROR CRITICAL)' \
        '--start-timeout=+[sec]:n:' \
        '--execution-timeout=+[sec]:n:' \
        '--report-mode[report mode]' \
        '--no-report-mode[no report mode]' \
        '--stdout-file=+[file]:file:_files' \
        '--stderr-file=+[file]:file:_files' \
        '-S+[server URI]:str:' \
        '--server=+[uri]:str:' \
        '--autosave-cell-every=+[sec]:n:' \
        '*:input output:_files -g "*.ipynb"'
}

_papermill2 "$@"
