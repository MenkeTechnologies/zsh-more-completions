#compdef mistralrs-server
# _mistralrs-server — Mistral.rs LLM inference server (EricLBuehler/mistral.rs)
# upstream: https://github.com/EricLBuehler/mistral.rs
# Flags from mistralrs-server/src/main.rs (clap derive); model selector is its own subcommand.

_mistralrs-server() {
    local -a args
    args=(
        '--serve-ip=[IP to serve on (default 0.0.0.0)]:ip:'
        '(-s --seed)'{-s+,--seed=}'[RNG seed for reproducible generation]:seed:'
        '(-p --port)'{-p+,--port=}'[port to serve on]:port:'
        '(-l --log)'{-l+,--log=}'[log all requests / responses to this file]:file:_files'
        '--max-seqs=[maximum running sequences at any time]:n:'
        '--no-kv-cache[disable the KV cache]'
        '(-c --chat-template)'{-c+,--chat-template=}'[chat template JSON / JINJA file]:file:_files -g "*.(json|jinja)"'
        '(-j --jinja-explicit)'{-j+,--jinja-explicit=}'[explicit JINJA chat template (overrides all)]:file:_files -g "*.jinja"'
        '--token-source=[HuggingFace token source]:source:(literal env path cache none)'
        '(-i --interactive-mode)'{-i,--interactive-mode}'[run an interactive chat instead of serving HTTP]'
        '--prefix-cache-n=[device prefix-cache slots (rest evicted to CPU LRU)]:n:'
        '(-n --num-device-layers)'{-n+,--num-device-layers=}'[GPU layer count or ORD:NUM;... pattern]:layers:'
        '--isq=[apply in-situ quantization]:quant:(Q4_0 Q4_1 Q5_0 Q5_1 Q8_0 Q8_1 Q2K Q3K Q4K Q5K Q6K Q8K)'
        '--pa-gpu-mem=[KV-cache GPU memory in MB (PagedAttention)]:mb:'
        '--pa-gpu-mem-usage=[KV-cache GPU memory fraction (0-1)]:fraction:'
        '--pa-ctxt-len=[total KV-cache context length in tokens]:tokens:'
        '--pa-cache-type=[PagedAttention KV-cache type]:type:(auto f8e4m3)'
        '--pa-blk-size=[PagedAttention block size in tokens]:tokens:'
        '--no-paged-attn[disable PagedAttention on CUDA]'
        '--paged-attn[enable PagedAttention on Metal]'
        '--cpu[CPU only inference]'
        '--enable-search[enable OpenAI-compatible web_search_options]'
        '--search-embedding-model=[built-in reranking embedding model]:model:'
        '--thinking=[force thinking mode on/off (default = chat template)]:bool:(true false)'
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '1: :_mistralrs-server_models' \
        '*::model args:->model'
    )

    _arguments -C $args && ret=0

    case $state in
        model)
            _arguments '*::flags:_files' && ret=0 ;;
    esac
}

(( $+functions[_mistralrs-server_models] )) ||
_mistralrs-server_models() {
    local -a models
    models=(
        'plain:plain HF model (text-only)'
        'x-lora:X-LoRA adapter set on top of a plain model'
        'lora:single LoRA adapter on top of a plain model'
        'gguf:GGUF quantized model'
        'x-lora-gguf:X-LoRA adapter set on top of a GGUF model'
        'lora-gguf:single LoRA adapter on top of a GGUF model'
        'ggml:GGML quantized model'
        'x-lora-ggml:X-LoRA adapter set on top of a GGML model'
        'lora-ggml:single LoRA adapter on top of a GGML model'
        'vision-plain:plain vision-language model'
        'diffusion-plain:plain diffusion model'
        'speech:speech model'
        'mcp:start the model behind an MCP server'
        'toml:read full model config from a TOML file'
        'run:auto-detect / pick model from a HuggingFace ID'
    )
    _describe -t models 'mistralrs-server model selector' models
}

_mistralrs-server "$@"
