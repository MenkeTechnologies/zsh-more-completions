#compdef phpstorm
# Documentation: https://www.jetbrains.com/help/phpstorm/working-with-the-ide-features-from-command-line.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local -a arguments

arguments=(
  '--help[show help]'
  '--version[show version]'
  '--wait[wait for the files to be closed before returning]'
  '--line[open file at specified line]:line number:'
  '--column[open file at specified column]:column number:'
  '--temp-project[create a temporary project from specified directory]'
  'nosplash[do not show splash screen]'
  'dontReopenProjects[skip reopening previous projects]'
  'disableNonBundledPlugins[launch without manually installed plugins]'
  'diff[open diff viewer between two files]'
  'merge[open merge dialog for files]'
  'format[apply code style formatting]'
  'inspect[run code inspection]'
  '-e[edit specified file in the current project window]'
  '-p[open specified project]'
  '*:files or directories:_files'
)

_arguments -s -S $arguments
