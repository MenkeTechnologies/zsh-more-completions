#compdef prettyplot
# Documentation: https://emboss.sourceforge.net/apps/release/6.6/emboss/apps/prettyplot.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# EMBOSS prettyplot: render multiple aligned sequences with coloured columns
local curcontext="$curcontext" ret=1
_arguments -C \
  '-help[show help]' '-auto[no prompts]' '-stdout[stdout]' '-filter[stdin/stdout]' \
  '-options[prompts]' '-debug[debug]' '-verbose[verbose]' '-warning[warnings]' \
  '-error[errors]' '-fatal[fatal]' '-die[dying]' '-version[version]' \
  '-sequences=[aligned sequence set]:alignment USA:_files' \
  '-graph=[graph output format]:format:(ps hpgl hp7470 hp7580 meta cps x11 tek tekt none data xterm png gif pdf svg)' \
  '-matrixfile=[scoring matrix file]:matrix:_files' \
  '-residuesperline=[residues per output line]:n:' \
  '-blocksperline=[blocks per output line]:n:' \
  '-ccolours[colour by consensus value]' \
  '-cidentity=[colour for identical residues]:colour:' \
  '-csimilarity=[colour for similar residues]:colour:' \
  '-cother=[colour for non-similar residues]:colour:' \
  '-docolour[colour by residue property]' \
  '-shade=[shading scheme letters (BPLW)]:scheme:' \
  '-pair=[pair-similarity score values]:values:' \
  '-identity=[identity threshold]:n:' \
  '-doboxes[display boxes]' \
  '-boxcol[colour box backgrounds]' \
  '-boxuse=[colour for box drawing]:colour:' \
  '-name[show sequence names]' \
  '-maxnamelen=[max sequence name length]:n:' \
  '-number[display residue numbers]' \
  '-listoptions[list option settings]' \
  '-ratio=[plurality ratio for consensus]:ratio:' \
  '-consensus[show consensus row]' \
  '-collision[allow consensus collisions]' \
  '-alternative=[collision check method]:method:(0 1 2 3)' \
  '-showscore=[print residue scores every N positions]:n:' \
  '-portrait[portrait page orientation]' \
  '*:alignment USA:_files' && ret=0
return ret
