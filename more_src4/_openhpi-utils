#compdef openhpi-utils
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/hpitop.1.html
# Reference accessed: 2026-05-16
# Verified: Ubuntu openhpi-clients package binaries (real upstream
# package is `openhpi-clients`, not `openhpi-utils`). Common flag set
# below is the shared pattern across hpi* binaries (hpitop, hpiinv,
# hpisensor, hpipower, hpiel, etc.).
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated subcommand list — these are separate binaries, not
# subcommands of one `openhpi-utils` executable.

# openhpi-utils: see hpi* binaries (hpitop/hpiinv/hpisensor/hpiel/etc.)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-D --domain)'{-D+,--domain=}'[HPI domain ID]:nn:' \
  '(-N --host)'{-N+,--host=}'[daemon URL]:host\:port:' \
  '(-C --cfgfile)'{-C+,--cfgfile=}'[client config file]:file:_files' \
  '(-X --debug)'{-X,--debug}'[enable debug output]' && ret=0
return ret
