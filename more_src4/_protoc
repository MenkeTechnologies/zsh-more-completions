#compdef protoc
# Documentation: https://manpages.debian.org/protoc.1
# Source: protocolbuffers/protobuf — protobuf compiler.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*'{-I+,--proto_path=}'[search directory for imports (repeatable)]:dir:_directories' \
    '--cpp_out=[generate C++ bindings into directory]:dir:_directories' \
    '--java_out=[generate Java bindings into directory]:dir:_directories' \
    '--python_out=[generate Python bindings into directory]:dir:_directories' \
    '--go_out=[generate Go bindings into directory]:dir:_directories' \
    '--csharp_out=[generate C# bindings into directory]:dir:_directories' \
    '--objc_out=[generate Objective-C bindings into directory]:dir:_directories' \
    '--js_out=[generate JavaScript bindings into directory]:dir:_directories' \
    '--php_out=[generate PHP bindings into directory]:dir:_directories' \
    '--ruby_out=[generate Ruby bindings into directory]:dir:_directories' \
    '--dart_out=[generate Dart bindings into directory]:dir:_directories' \
    '--kotlin_out=[generate Kotlin bindings into directory]:dir:_directories' \
    '--rust_out=[generate Rust bindings into directory]:dir:_directories' \
    '--descriptor_set_out=[write FileDescriptorSet]:file:_files' \
    '--encode=[parse text-format message and serialize binary to stdout]:msg-type:' \
    '--decode=[read binary message from stdin and write text-format to stdout]:msg-type:' \
    '--decode_raw[read arbitrary protobuf from stdin and decode without schema]' \
    '--print_free_field_numbers[print unused field numbers]' \
    '--include_imports[include all imports in --descriptor_set_out]' \
    '--include_source_info[include source-code info in descriptor]' \
    '--allow_proto3_optional[allow proto3 optional fields]' \
    '--experimental_allow_proto3_optional[allow proto3 optional fields (experimental)]' \
    '--error_format=[error message format]:fmt:(gcc msvs)' \
    '--plugin=[plugin executable (name=path)]:plugin:_files' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:.proto file:_files -g "*.proto"' \
    && ret=0

return ret
