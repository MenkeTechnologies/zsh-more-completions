#compdef mount_puffs
# Documentation: man mount_puffs(8)
# Source: netbsd/src sbin/mount_puffs — mount puffs/refuse file servers (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[options passed to program (getargs queries kernel args)]:options:_default' \
    '1:file server program(#source):_files' \
    '2:mount point:_files -/' \
    && ret=0

return ret
