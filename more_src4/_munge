#compdef munge unmunge munged
# _munge — MUNGE munge / unmunge / munged (UID/GID authentication service mostly used by Slurm; munge encodes a credential from stdin (-c cipher, -m mac, -z zip, -t TTL seconds, -u user, -g group, -o origin ip, -i identity, -n no input, -s socket path, -B base64 output); unmunge decodes; munged is the daemon (-f force, -F foreground, --socket path, --key-file, --num-threads N))
# upstream: https://github.com/dun/munge
# Flags from MUNGE src/munge + src/unmunge + src/munged on tip.

_munge() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-c+[cipher]:cipher:(none default aes128 aes256 blowfish)' \
        '--cipher+[cipher]:cipher:(none default aes128 aes256 blowfish)' \
        '-m+[mac]:mac:(none default md5 sha1 sha256 sha512 ripemd160)' \
        '--mac+[mac]:mac:(none default md5 sha1 sha256 sha512 ripemd160)' \
        '-z+[zip]:zip:(none default bzlib zlib)' \
        '--zip+[zip]:zip:(none default bzlib zlib)' \
        '-t+[TTL seconds]:seconds:' \
        '--ttl+[TTL seconds]:seconds:' \
        '-u+[restricted user]:user:_users' \
        '--restrict-uid+[restricted user]:user:_users' \
        '-g+[restricted group]:group:_groups' \
        '--restrict-gid+[restricted group]:group:_groups' \
        '-o+[origin ip]:ip:' \
        '--origin+[origin ip]:ip:' \
        '-i+[input file]:file:_files' \
        '--input+[input file]:file:_files' \
        '-n[no input]' \
        '--no-input[no input]' \
        '-s+[socket path]:file:_files' \
        '--socket+[socket path]:file:_files' \
        '-B[base64 output]' \
        '-S[strip whitespace]' \
        '--length+[input bytes]:n:' \
        '-f[force]' \
        '-F[foreground]' \
        '--key-file+[key file]:file:_files' \
        '--num-threads+[threads]:n:'
}

_munge "$@"
