#compdef mysqlrouter_keyring
# Documentation: https://dev.mysql.com/doc/mysql-router/8.4/en/mysqlrouter_keyring.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'init:initialize keyring with master-key-file'
  'list:list usernames or properties of a user'
  'get:get a property of a user'
  'export:export keyring entries as JSON'
  'set:add or overwrite an account'
  'delete:delete a user (or specific key)'
  'master-key-list:list keyring-ids from master-key-file'
  'master-key-delete:delete a master-key from master-key-file'
  'master-key-rename:rename a keyring-id in master-key-file'
)

_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '--master-key-file=[master key file]:file:_files' \
  '--master-key-reader=[command to read master key]:command:' \
  '--master-key-writer=[command to write master key]:command:' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'mysqlrouter_keyring subcommand' subcommands && ret=0
    ;;
esac

return ret
