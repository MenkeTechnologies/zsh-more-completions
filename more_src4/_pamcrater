#compdef pamcrater
# Documentation: man pamcrater (Netpbm)
# Source: synthesise a cratered-landscape PAM image (multi-plane height/color).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-number+[number of craters]:n:' \
    '-height+[output height pixels]:pixels:' \
    '-width+[output width pixels]:pixels:' \
    '-randomseed=[random seed]:integer:' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    && ret=0

return ret
