#compdef pdns_recursor pdns-recursor pdnsrec
# _pdnsrec — PowerDNS pdns_recursor recursive DNS server resolver with DNSSEC validation and Lua scripting (PowerDNS team, C++); custom argparse
# upstream: https://github.com/PowerDNS/pdns

_pdnsrec() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-name=+[config name]:str:' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--config[print effective config]' \
        '--no-config[no config file]' \
        '--daemon=+[bool]:b:(yes no)' \
        '-d+[bool]:b:(yes no)' \
        '--quiet=+[bool]:b:(yes no)' \
        '--socket-dir=+[control socket dir]:dir:_files -/' \
        '--socket-owner=+[user]:user:_users' \
        '--socket-group=+[group]:group:_groups' \
        '--socket-mode=+[mode]:str:' \
        '--local-address=+[bind addresses]:str:' \
        '--local-port=+[port]:port:_ports' \
        '--allow-from=+[CIDRs]:str:' \
        '--allow-notify-from=+[CIDRs]:str:' \
        '--forward-zones=+[zones]:str:' \
        '--forward-zones-file=+[file]:file:_files' \
        '--forward-zones-recurse=+[zones]:str:' \
        '--auth-zones=+[zones]:str:' \
        '--dnssec=+[mode]:m:(off process-no-validate process log-fail validate)' \
        '--dnssec-log-bogus=+[bool]:b:(yes no)' \
        '--query-local-address=+[ip]:host:_hosts' \
        '--query-local-address6=+[ip]:host:_hosts' \
        '--max-cache-entries=+[N]:n:' \
        '--max-cache-ttl=+[seconds]:n:' \
        '--max-negative-ttl=+[seconds]:n:' \
        '--threads=+[N]:n:' \
        '--distributor-threads=+[N]:n:' \
        '--pdns-distributes-queries=+[bool]:b:(yes no)' \
        '--reuseport=+[bool]:b:(yes no)' \
        '--webserver=+[bool]:b:(yes no)' \
        '--webserver-address=+[bind address]:host:_hosts' \
        '--webserver-port=+[port]:port:_ports' \
        '--webserver-password=+[password]:str:' \
        '--webserver-allow-from=+[CIDRs]:str:' \
        '--api-key=+[api key]:str:' \
        '--lua-config-file=+[file]:file:_files -g "*.lua"' \
        '--lua-dns-script=+[file]:file:_files -g "*.lua"' \
        '--loglevel=+[level]:n:' \
        '--log-common-errors=+[bool]:b:(yes no)' \
        '--logging-facility=+[N]:n:' \
        '--quiet=+[bool]:b:(yes no)' \
        '--statistics-interval=+[seconds]:n:' \
        '--max-tcp-clients=+[N]:n:' \
        '--max-mthreads=+[N]:n:' \
        '--client-tcp-timeout=+[seconds]:n:' \
        '--network-timeout=+[ms]:n:' \
        '--root-nx-trust=+[bool]:b:(yes no)' \
        '--qname-minimization=+[bool]:b:(yes no)'
}

_pdnsrec "$@"
