#compdef prerelease-lifecycle-gen
# _prerelease-lifecycle-gen — Kubernetes prerelease-lifecycle accessor generator (kubernetes/code-generator)
# upstream: https://github.com/kubernetes/code-generator
# Flags from cmd/prerelease-lifecycle-gen/args/args.go on tip.

_prerelease-lifecycle-gen() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--output-file=[generated file basename]:file:_files' \
        '--go-header-file=[Go header file prepended to generated files]:file:_files' \
        '-v[klog verbosity level]:n:' \
        '*:input-package:'
}

_prerelease-lifecycle-gen "$@"
