#compdef pdns_server pdns-server pdnsauth
# _pdnsauth — PowerDNS pdns_server authoritative DNS server modular nameserver with many backends (PowerDNS team, C++); custom argparse
# upstream: https://github.com/PowerDNS/pdns

_pdnsauth() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--config-name=+[config name]:str:' \
        '--config-dir=+[config dir]:dir:_files -/' \
        '--config[print effective config]' \
        '--no-config[no config file]' \
        '--daemon=+[bool]:b:(yes no)' \
        '-d+[bool]:b:(yes no)' \
        '--guardian=+[bool]:b:(yes no)' \
        '--socket-dir=+[control socket dir]:dir:_files -/' \
        '--launch=+[backends csv]:str:' \
        '--master=+[bool]:b:(yes no)' \
        '--slave=+[bool]:b:(yes no)' \
        '--primary=+[bool]:b:(yes no)' \
        '--secondary=+[bool]:b:(yes no)' \
        '--server-id=+[id]:str:' \
        '--local-address=+[bind addresses]:str:' \
        '--local-port=+[port]:port:_ports' \
        '--webserver=+[bool]:b:(yes no)' \
        '--webserver-address=+[bind address]:host:_hosts' \
        '--webserver-port=+[port]:port:_ports' \
        '--webserver-password=+[password]:str:' \
        '--webserver-allow-from=+[CIDRs]:str:' \
        '--api=+[bool]:b:(yes no)' \
        '--api-key=+[api key]:str:' \
        '--dnsupdate=+[bool]:b:(yes no)' \
        '--allow-dnsupdate-from=+[CIDRs]:str:' \
        '--allow-axfr-ips=+[CIDRs]:str:' \
        '--also-notify=+[ips csv]:str:' \
        '--cache-ttl=+[seconds]:n:' \
        '--negquery-cache-ttl=+[seconds]:n:' \
        '--query-cache-ttl=+[seconds]:n:' \
        '--loglevel=+[level]:n:' \
        '--log-dns-queries=+[bool]:b:(yes no)' \
        '--log-dns-details=+[bool]:b:(yes no)' \
        '--receiver-threads=+[N]:n:' \
        '--distributor-threads=+[N]:n:' \
        '--max-queue-length=+[N]:n:' \
        '--max-tcp-connections=+[N]:n:' \
        '--max-tcp-connections-per-client=+[N]:n:' \
        '--soa-minimum-ttl=+[seconds]:n:' \
        '--soa-refresh-default=+[seconds]:n:' \
        '--query-logging=+[bool]:b:(yes no)' \
        '--module-dir=+[module dir]:dir:_files -/' \
        '--load-modules=+[modules csv]:str:'
}

_pdnsauth "$@"
