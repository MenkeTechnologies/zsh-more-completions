#compdef otf2feature
# _otf2feature — Adobe afdko otf2feature CLI for decompiling OpenType OTF binary layout tables GSUB GPOS GDEF back to AFDKO .fea feature-file source code with class group lookup statement extraction (adobe-type-tools team, Python); argparse
# upstream: https://github.com/adobe-type-tools/afdko

_otf2feature() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-o+[output feature file]:file:_files -g "*.fea"' \
        '--output=+[output feature file]:file:_files -g "*.fea"' \
        '-t+[csv tables]:str:' \
        '--tables=+[csv tables]:str:' \
        '--no-gsub[no GSUB]' \
        '--no-gpos[no GPOS]' \
        '--no-gdef[no GDEF]' \
        '--ignore-anchors[ignore anchors]' \
        '--ignore-marks[ignore marks]' \
        '--full[full output]' \
        '--minimal[minimal output]' \
        '--report[report only]' \
        '--no-class-names[no class names]' \
        '--no-comments[no comments]' \
        '*:OTF font:_files -g "*.otf *.ttf *.cff"'
}

_otf2feature "$@"
