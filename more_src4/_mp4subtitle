#compdef mp4subtitle
# _mp4subtitle — manage subtitles in MP4 files (enzo1982/mp4v2)
# upstream: https://github.com/enzo1982/mp4v2
# Flags from util/mp4subtitle.cpp (_actionGroup).

_mp4subtitle() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '--list[list available subtitles]' \
        '--export=[export subtitles to TXT file]:file:_files -g "*.(txt|srt)"' \
        '--import=[import subtitles from TXT file]:file:_files -g "*.(txt|srt)"' \
        '--remove[remove all subtitles]' \
        '*:MP4 file:_files -g "*.(m4a|m4v|mp4)"'
}

_mp4subtitle "$@"
