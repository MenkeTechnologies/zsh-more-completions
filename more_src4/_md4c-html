#compdef md2html md4c-html
# Documentation: https://github.com/mity/md4c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above and `md2html --help` on macOS.

_arguments -s \
  '(-o --output)'{-o+,--output=}'[output file]:file:_files' \
  '(-f --full-html)'{-f,--full-html}'[output full HTML document]' \
  '(-x --xhtml)'{-x,--xhtml}'[XHTML output]' \
  '(-s --stat)'{-s,--stat}'[measure time of input parsing]' \
  '--commonmark[CommonMark dialect (default)]' \
  '--github[GitHub Flavored Markdown dialect]' \
  '--fcollapse-whitespace[collapse non-trivial whitespace]' \
  '--flatex-math[LaTeX math support]' \
  '--fpermissive-atx-headers[allow ATX headers without delimiting space]' \
  '--fpermissive-url-autolinks[allow URL autolinks without delimiters]' \
  '--fpermissive-www-autolinks[allow WWW autolinks without scheme]' \
  '--fpermissive-email-autolinks[allow email autolinks without delimiters]' \
  '--fpermissive-autolinks[enable all permissive autolinks]' \
  '--fhard-soft-breaks[force soft breaks to act as hard breaks]' \
  '--fstrikethrough[strikethrough spans]' \
  '--ftables[tables]' \
  '--ftasklists[task lists]' \
  '--funderline[underline spans]' \
  '--fwiki-links[wiki-style links]' \
  '--fno-html-blocks[disable raw HTML blocks]' \
  '--fno-html-spans[disable raw HTML spans]' \
  '--fno-html[disable all raw HTML]' \
  '--fno-indented-code[disable indented code blocks]' \
  '--fverbatim-entities[do not translate entities]' \
  '--html-title=[set HTML document title]:title:' \
  '--html-css=[CSS URL in full/XHTML mode]:url:' \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*:input:_files -g "*.(md|markdown)"'
