#compdef npppctl
# _npppctl — OpenBSD npppctl (control + introspect npppd(8); session brief/all/packets snapshots, monitor, and clear by filter expressions over ppp-id/username/realm/protocol/interface/address)
# upstream: https://github.com/openbsd/src (usr.sbin/npppctl)
# Flags + commands from usr.sbin/npppctl/npppctl.8 on tip.

_npppctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-n[show numeric IPs instead of hostnames]' \
        '-s+[control socket (default /var/run/npppd.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'npppctl command' \
                '(session:show PPP session list (brief|all|packets) monitor:stream session events clear:disconnect sessions matching a filter)'
            ;;
        args)
            case $line[1] in
                session) _describe -t commands 'session view' '(brief all packets)' ;;
                monitor) _describe -t commands 'monitor target' '(all)' ;;
                clear) _describe -t commands 'clear target' '(all ppp-id username realm protocol interface address)' ;;
            esac
            ;;
    esac
}

_npppctl "$@"
