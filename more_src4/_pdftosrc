#compdef pdftosrc
# Documentation: pdftosrc usage (TeX Live 2026)
# Source: pdftex pdftosrc — extract embedded source files from a PDF (pdftex extension).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:PDF file:_files -g "*.pdf"' \
    '2:object number (or omit for embedded source):' \
    && ret=0

return ret
