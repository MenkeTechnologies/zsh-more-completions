#compdef makeinfo texi2any
# Documentation: makeinfo --help (Texinfo)
# Source: translate Texinfo source to Info / HTML / LaTeX / Docbook / etc.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '--document-language=[locale for translation]:locale:' \
    '--error-limit=[quit after N errors]:n:' \
    '--force[preserve output even on errors]' \
    '--no-validate[suppress node cross-reference validation]' \
    '--no-warn[suppress warnings (not errors)]' \
    '--conf-dir=[also search DIR for init files]:dir:_files -/' \
    '--init-file=[load FILE to modify default behavior]:file:_files' \
    '*'{-c,--set-customization-variable=}'[set customization variable VAR=VAL]:var=value:' \
    '--trace-includes[print names of included files]' \
    {-v,--verbose}'[verbose]' \
    '(--html --epub3 --latex --plaintext --xml --dvi --dvipdf --ps --pdf)--docbook[output Docbook XML]' \
    '(--docbook --epub3 --latex --plaintext --xml --dvi --dvipdf --ps --pdf)--html[output HTML]' \
    '(--docbook --html --latex --plaintext --xml --dvi --dvipdf --ps --pdf)--epub3[output EPUB 3]' \
    '(--docbook --html --epub3 --plaintext --xml --dvi --dvipdf --ps --pdf)--latex[output LaTeX]' \
    '(--docbook --html --epub3 --latex --xml --dvi --dvipdf --ps --pdf)--plaintext[output plain text]' \
    '(--docbook --html --epub3 --latex --plaintext --dvi --dvipdf --ps --pdf)--xml[output Texinfo XML]' \
    '--dvi[generate DVI via texi2dvi]' \
    '--dvipdf[generate DVI then PDF via texi2dvi]' \
    '--ps[generate PostScript via texi2dvi]' \
    '--pdf[generate PDF via texi2dvi]' \
    {-E+,--macro-expand=}'[output macro-expanded source]:file:_files' \
    '--no-headers[suppress node separators]' \
    '--no-split[do not split large files]' \
    '--split=[split unit]:unit:(chapter section node)' \
    '--number-sections[output chapter and section numbers]' \
    {-o+,--output=}'[output to FILE]:file:_files' \
    {-D+,--define-variable=}'[define VAR]:var:' \
    '*'{-I+,--include=}'[append DIR to include path]:dir:_files -/' \
    '*-P+[prepend DIR to include path]:dir:_files -/' \
    '*:texinfo file:_files -g "*.(texi|texinfo|txi)"' \
    && ret=0

return ret
