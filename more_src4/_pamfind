#compdef pamfind
# Documentation: man pamfind (Netpbm)
# Source: find pixels in a PAM image whose tuple matches a target.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-target -color)-target=[target tuple samples (comma-separated)]:samples:' \
    '(-target -color)-color=[target color name/spec]:color:' \
    '-machine[machine-readable output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
