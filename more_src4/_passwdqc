#compdef pwqcheck pwqgen pwqfilter
# _passwdqc — Openwall passwdqc (pwqcheck checks password quality against a stdin or arg policy, pwqgen generates a passphrase, pwqfilter filters wordlists; shared flags drive --min/--max length, character classes, similarity thresholds)
# upstream: https://github.com/openwall/passwdqc
# Flags from passwdqc pwqcheck.c / pwqgen.c on tip.

_passwdqc() {
    _arguments \
        '--config=[config file]:file:_files' \
        '--multi[allow multiple passphrases]' \
        '--min=[N0,N1,N2,N3,N4 minimum lengths per class]:N0\,N1\,N2\,N3\,N4:' \
        '--max=[max passphrase length]:max:' \
        '--passphrase=[min words]:words:' \
        '--match=[similarity threshold]:length:' \
        '--similar=[deny|permit similar previous]:mode:(deny permit)' \
        '--random=[random bits]:bits:' \
        '--random-only[require random]' \
        '--enforce=[mode]:mode:(none users everyone)' \
        '--retry=[N attempts]:n:'
}

_passwdqc "$@"
