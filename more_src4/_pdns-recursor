#compdef pdns-recursor
# _pdns-recursor — PowerDNS pdns_recursor recursive DNS resolver CLI alias (PowerDNS team, C++); custom argparse
# upstream: https://github.com/PowerDNS/pdns

_pdns-recursor() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--config-name=+[name]:str:' \
        '--config-dir=+[dir]:dir:_files -/' \
        '--socket-dir=+[dir]:dir:_files -/' \
        '--config=+[mode]:m:(diff)' \
        '--daemon=+[bool]:b:(yes no)' \
        '--no-config[no config]' \
        '--quiet=+[bool]:b:(yes no)' \
        '--write-pid=+[bool]:b:(yes no)' \
        '--local-address=+[addresses]:str:' \
        '--local-port=+[port]:port:' \
        '--allow-from=+[netmasks]:str:' \
        '--allow-from-file=+[file]:file:_files' \
        '--threads=+[n]:n:' \
        '--max-cache-entries=+[n]:n:' \
        '--max-mthreads=+[n]:n:' \
        '--minimum-ttl-override=+[seconds]:n:' \
        '--query-local-address=+[address]:str:' \
        '--root-nx-trust=+[bool]:b:(yes no)' \
        '--server-id=+[id]:str:' \
        '--setgid=+[group]:_groups' \
        '--setuid=+[user]:_users' \
        '--stats-interval=+[seconds]:n:' \
        '--security-poll-suffix=+[suffix]:str:' \
        '--trace=+[mode]:m:(yes no fail)' \
        '--api-config-dir=+[dir]:dir:_files -/' \
        '--api-key=+[key]:str:' \
        '--webserver=+[bool]:b:(yes no)' \
        '--webserver-address=+[address]:str:' \
        '--webserver-port=+[port]:port:' \
        '--webserver-password=+[password]:str:' \
        '--webserver-allow-from=+[netmasks]:str:' \
        '--lua-config-file=+[file]:file:_files' \
        '--forward-zones=+[zones]:str:' \
        '--forward-zones-file=+[file]:file:_files' \
        '--auth-zones=+[zones]:str:' \
        '--dnssec=+[level]:l:(off process-no-validate process validate log-fail)' \
        '*:arg:'
}

_pdns-recursor "$@"
