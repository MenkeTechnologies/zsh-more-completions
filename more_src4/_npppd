#compdef npppd
# _npppd — OpenBSD npppd (PPP and tunneling daemon supporting L2TP, PPTP, and PPPoE; works with pipex(4) for accelerated IP forwarding; controlled at runtime by npppctl(8))
# upstream: https://github.com/openbsd/src (usr.sbin/npppd)
# Flags from usr.sbin/npppd/npppd/npppd.8 on tip.

_npppd() {
    _arguments \
        '-d[debug (foreground + stderr)]' \
        '-n[validate config + exit]' \
        '-f+[config file (default /etc/npppd/npppd.conf)]:file:_files'
}

_npppd "$@"
