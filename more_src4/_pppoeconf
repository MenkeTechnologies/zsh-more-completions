#compdef pppoeconf
# _pppoeconf — Debian pppoeconf (interactive helper that scans every Ethernet interface for a PPPoE access concentrator, asks for the ISP credentials, then writes /etc/ppp/peers/dsl-provider so pon dsl-provider brings the link up; --help shows usage; positional argument is an optional interface to skip auto-detection)
# upstream: https://salsa.debian.org/debian/pppoeconf
# Argument shape from pppoeconf pppoeconf on tip.

_pppoeconf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '--version[show version]' \
        '1::interface:_net_interfaces'
}

_pppoeconf "$@"
