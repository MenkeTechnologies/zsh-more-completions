#compdef pax-cli
# _pax-cli — POSIX pax portable archive interchange CLI alias (POSIX standard, varies); custom argparse
# upstream: https://github.com/MirBSD/mksh

_pax-cli() {
    _arguments \
        '--help[show help]' \
        '-r[read archive]' \
        '-w[write archive]' \
        '-a[append to archive]' \
        '-b+[block size]:n:' \
        '-c[match all patterns except]' \
        '-d[match only filename]' \
        '-f+[archive file]:file:_files' \
        '-G+[group]:_groups' \
        '-H[follow command-line symlinks]' \
        '-i[interactive rename]' \
        '-k[do not overwrite existing]' \
        '-l[link instead of copy]' \
        '-L[follow all symlinks]' \
        '-n[match first occurrence]' \
        '-o+[options]:str:' \
        '-p+[preserve options]:str:' \
        '-s+[replacement]:str:' \
        '-T+[time range]:str:' \
        '-t[preserve atime]' \
        '-U+[user]:_users' \
        '-u[update]' \
        '-v[verbose]' \
        '-X[do not cross fs]' \
        '-x+[archive format]:f:(cpio bcpio sv4cpio sv4crc tar ustar)' \
        '-z[gzip compression]' \
        '-Z[compress]' \
        '*:files:_files'
}

_pax-cli "$@"
