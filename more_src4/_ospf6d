#compdef ospf6d
# Documentation: https://manpages.debian.org/testing/frr/frr-ospf6d.8.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --daemon)'{-d,--daemon}'[daemonize]' \
  '(-f --config_file)'{-f,--config_file}'+[config file]:file:_files' \
  '(-i --pid_file)'{-i,--pid_file}'+[pid file]:file:_files' \
  '(-z --socket)'{-z,--socket}'+[zebra socket]:file:_files' \
  '(-A --vty_addr)'{-A,--vty_addr}'+[VTY address]:addr:' \
  '(-P --vty_port)'{-P,--vty_port}'+[VTY port]:port:' \
  '(-r --retain)'{-r,--retain}'[retain routes after exit]' \
  '(-N --pathspace)'{-N,--pathspace}'+[namespace]:ns:' \
  '(-K --graceful_restart)'{-K,--graceful_restart}'+[graceful restart sec]:sec:' \
  '(-u --user)'{-u,--user}'+[user]:user:_users' \
  '(-g --group)'{-g,--group}'+[group]:group:_groups' && ret=0

return ret
