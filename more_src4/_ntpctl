#compdef ntpctl
# _ntpctl — OpenBSD ntpctl (display state of the running ntpd(8): peers list, sensor readings, status snapshot, or full dump)
# upstream: https://github.com/openbsd/src (usr.sbin/ntpd)
# Flags from usr.sbin/ntpd/ntpctl.8 on tip.

_ntpctl() {
    _arguments \
        '-s+[show subsystem state]:what:(all peers Sensors status)'
}

_ntpctl "$@"
