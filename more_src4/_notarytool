#compdef notarytool
# Documentation: https://keith.github.io/xcode-man-pages/notarytool.1.html
# Source: Apple — `xcrun notarytool` Developer ID notary CLI (App Store Connect API).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -C -s \
    '--version[print version + build number]' \
    '(-v --verbose)'{-v,--verbose}'[stream DEBUG-level logs to stderr]' \
    '(--progress --no-progress)--progress[show progress indicators]' \
    '(--progress --no-progress)--no-progress[hide progress indicators]' \
    '(-f --output-format)'{-f+,--output-format=}'[output format]:fmt:(normal json plist)' \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd)
        local -a subcmds=(
            'help:summary usage'
            'store-credentials:save auth credentials to the keychain'
            'submit:submit archive to Apple notary service'
            'info:status info for a previous submission'
            'log:fetch notarization log JSON for one submission'
            'history:list previous submissions for the team'
            'wait:wait for completion of a previous submission'
        )
        _describe -t subcmds 'notarytool command' subcmds && ret=0
        ;;
    args)
        local -a auth=(
            '(-k --key)'{-k+,--key=}'[App Store Connect API private key path]:file:_files'
            '(-d --key-id)'{-d+,--key-id=}'[App Store Connect API Key ID]:keyid:'
            '(-i --issuer)'{-i+,--issuer=}'[App Store Connect API Issuer UUID]:uuid:'
            '--apple-id=[Apple ID login username]:email:'
            '--password=[app-specific password]:password:'
            '--team-id=[Developer Team identifier]:teamid:'
            '(-p --keychain-profile)'{-p+,--keychain-profile=}'[auth via keychain profile]:profile:'
            '--keychain=[keychain file path]:file:_files'
        )
        case $words[1] in
            submit)
                _arguments "${auth[@]}" \
                    '(--wait --no-wait)--wait[wait for completion]' \
                    '(--wait --no-wait)--no-wait[do not wait]' \
                    '--timeout=[exit after polling for given duration]:duration:' \
                    '(--s3-acceleration --no-s3-acceleration)--s3-acceleration[enable S3 Transfer Acceleration]' \
                    '(--s3-acceleration --no-s3-acceleration)--no-s3-acceleration[disable S3 Transfer Acceleration]' \
                    '--force[upload despite pre-flight validation issues]' \
                    '*:archive (.zip / .pkg / .dmg):_files' \
                    && ret=0
                ;;
            store-credentials)
                _arguments "${auth[@]}" \
                    '(--validate --no-validate)--validate[verify credentials before saving]' \
                    '(--validate --no-validate)--no-validate[skip verification]' \
                    '--sync[sync profile via iCloud Keychain]' \
                    '1:profile name:' \
                    && ret=0
                ;;
            info|log|wait|history)
                _arguments "${auth[@]}" \
                    '*:submission id:' \
                    && ret=0
                ;;
            *)
                _default
                ;;
        esac
        ;;
esac

return ret
