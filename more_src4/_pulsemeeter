#compdef pulsemeeter
# _pulsemeeter — PipeWire/PulseAudio virtual routing GUI + CLI (theRealCarneiro/pulsemeeter)
# upstream: https://github.com/theRealCarneiro/pulsemeeter
# Subcommands from src/pulsemeeter/clients/cli/cli_client.py (argparse).

_pulsemeeter() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'init:create virtual devices and connections'
                'cleanup:remove all virtual devices and connections'
                'volume:set the volume of a device'
                'mute:set the mute state of a device'
                'primary:set primary device'
                'connect:set connection state input → output'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                volume)
                    _arguments \
                        '1:device type:(hi vi a b)' \
                        '2:device id:' \
                        '3:volume %:'
                    ;;
                mute|primary)
                    _arguments \
                        '1:device type:(hi vi a b)' \
                        '2:device id:' \
                        ':state:(on off true false 1 0)'
                    ;;
                connect)
                    _arguments \
                        '1:input type:(hi vi)' \
                        '2:input id:' \
                        '3:output type:(a b)' \
                        '4:output id:' \
                        ':state:(on off true false 1 0)'
                    ;;
            esac
            ;;
    esac
}

_pulsemeeter "$@"
