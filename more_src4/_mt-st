#compdef mt-st mt
# Documentation: https://manpages.debian.org/bookworm/mt-st/mt.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mt-st: control magnetic tape drive operation (mt-st flavour of mt).

local -a operations

operations=(
  'fsf' 'fsfm' 'bsf' 'bsfm' 'asf' 'fsr' 'bsr' 'fss' 'bss'
  'eod' 'seod' 'rewind' 'offline' 'rewoffl' 'eject' 'retension'
  'weof' 'eof' 'wset' 'erase'
  'status' 'densities'
  'seek' 'tell' 'setpartition' 'partseek' 'mkpartition' 'load' 'lock' 'unlock'
  'setblk' 'setdensity' 'drvbuffer' 'compression' 'stoptions' 'stsetoptions'
  'stclearoptions' 'stshowoptions' 'stwrthreshold' 'defblksize' 'defdensity'
  'defdrvbuffer' 'defcompression' 'sttimeout' 'stlongtimeout' 'stsetcln'
)

_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-f -t)'{-f,-t}'+[tape device]:device:_files -g "/dev/*"' \
  "1:operation:($operations)" \
  ':count:'
