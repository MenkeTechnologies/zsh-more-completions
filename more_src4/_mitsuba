#compdef mitsuba
# Documentation: https://github.com/mitsuba-renderer/mitsuba/blob/master/src/mitsuba/mitsuba.cpp
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Note: mitsuba 0.6 src/mitsuba/mitsuba.cpp getopt string.
# Mitsuba 3 is a Python-first renderer with a different surface; this
# completion targets the Mitsuba 0.x binary.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -m/--mode/-n/--no-render/-u/--update/-w/--warn flags
# (none in upstream getopt string); -v/--verbose takes no value.

# mitsuba: Mitsuba 0.x renderer
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '*-D[define scene constant key=val]:k=v:' \
  '-o[output image file]:file:_files' \
  '-a[add resource search paths (p1;p2;..)]:paths:' \
  '-p[processor count override]:n:' \
  '-q[quiet (suppress stdout log)]' \
  '-c[network rendering hosts]:hosts:' \
  '-s[load servers from file]:file:_files' \
  '-j[schedule multiple scenes simultaneously]:n:' \
  '-n[node name]:name:' \
  '-x[skip render if output exists]' \
  '-r[write partial output every N sec]:sec:' \
  '-b[block resolution (default 32)]:n:' \
  '*-v[verbose (repeatable)]' \
  '-L[log level]:level:(trace debug info warn error)' \
  '-w[warnings as errors]' \
  '-z[disable progress bars]' \
  '-t[test mode]' \
  '*:scene:_files -g "*.xml(-.)"' && ret=0
return ret
