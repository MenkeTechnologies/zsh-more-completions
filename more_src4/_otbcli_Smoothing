#compdef otbcli_Smoothing
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Smoothing.html
# Source: orfeotoolbox/OTB Smoothing — mean / Gaussian / anisotropic-diffusion smoothing.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[smoothed output image]:image:_files' \
    '-type+[smoothing method]:type:(mean gaussian anidif)' \
    '-type.mean.radius+[mean filter kernel radius (px, default 2)]:n:_default' \
    '-type.gaussian.stdev+[Gaussian std-dev (default 2)]:value:_default' \
    '-type.gaussian.maxerror+[max kernel truncation error (default 0.01)]:value:_default' \
    '-type.gaussian.maxwidth+[max kernel width (px, default 32)]:n:_default' \
    '-type.anidif.timestep+[anidiff timestep (default 0.125)]:value:_default' \
    '-type.anidif.nbiter+[anidiff iterations (default 10)]:n:_default' \
    '-type.anidif.conductance+[anidiff conductance (default 1)]:value:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
