#compdef plenti
# Documentation: https://plenti.co/docs/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'new:create a new plenti project or type'
  'build:build the static site'
  'serve:start a local development server'
  'theme:manage themes (add/enable/disable/remove/update)'
  'eject:eject core files to local project'
  'type:manage content types'
  'help:show help'
)

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'plenti command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (build)
        _arguments -s -S \
          '--benchmark[print build speed statistics]' \
          '--bundle[bundle SPA into a single file with esbuild]' \
          '--config=[path to a non-default config file]:file:_files' \
          '--minify[condense JavaScript output]' \
          '--output=[output directory name]:dir:_directories' \
          '--verbose[verbose logging]' && ret=0
        ;;
      (serve)
        _arguments -s -S \
          '--build=[also build when starting server]:bool:(true false)' \
          '--local=[run as local environment]:bool:(true false)' \
          '--port=[server port]:port:' \
          '--ssl[serve localhost over HTTPS]' && ret=0
        ;;
      (theme)
        local -a theme_cmds=(
          'add:add a theme'
          'enable:enable a theme'
          'disable:disable a theme'
          'remove:remove a theme'
          'update:update a theme'
        )
        _describe -t theme 'theme subcommand' theme_cmds && ret=0
        ;;
      (type)
        _arguments -s -S \
          '--endpoint=[endpoint route flag]:endpoint:' \
          '--single=[create single-file type]:bool:(true false)' && ret=0
        ;;
      (*)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
