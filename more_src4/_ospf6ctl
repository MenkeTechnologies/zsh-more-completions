#compdef ospf6ctl
# _ospf6ctl — OpenBSD ospf6ctl (control + introspect the running ospf6d(8) OSPFv3/IPv6 daemon; show neighbors/interfaces/database/rib/fib, fib couple/decouple/reload, reload, log level)
# upstream: https://github.com/openbsd/src (usr.sbin/ospf6ctl)
# Flags + commands from usr.sbin/ospf6ctl/ospf6ctl.8 on tip.

_ospf6ctl() {
    local context state line
    typeset -A opt_args
    _arguments -C \
        '-s+[control socket (default /var/run/ospf6d.sock)]:file:_files' \
        '1: :->cmd' \
        '*::arg:->args'
    case $state in
        cmd)
            _describe -t commands 'ospf6ctl command' \
                '(show:show subsystem state fib:fib couple/decouple/reload reload:reload ospf6d config log:log level (brief|verbose))'
            ;;
        args)
            case $line[1] in
                show) _describe -t commands 'show target' '(summary neighbor interfaces database rib fib)' ;;
                fib) _describe -t commands 'fib subcommand' '(couple decouple reload)' ;;
                log) _describe -t commands 'log level' '(brief verbose)' ;;
            esac
            ;;
    esac
}

_ospf6ctl "$@"
