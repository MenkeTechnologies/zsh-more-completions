#compdef mdz
# Documentation: https://github.com/wflixu/mdz
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mdz: Markdown Zip - portable archive format for markdown with embedded media

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'pack:pack a markdown file and its assets into an MDZ archive'
  'unpack:unpack an MDZ archive'
  'help:show help for a subcommand'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*:: :->args' && ret=0

case $state in
  (command)
    _describe -t commands 'mdz command' commands && ret=0
    ;;
  (args)
    case $words[1] in
      (pack)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'=-[output MDZ file]:file:_files' \
          '*:markdown file:_files -g "*.{md,markdown}"' && ret=0
        ;;
      (unpack)
        _arguments -s -S \
          '(-o --output)'{-o,--output}'=-[output directory]:dir:_directories' \
          '*:mdz archive:_files -g "*.mdz"' && ret=0
        ;;
    esac
    ;;
esac

return ret
