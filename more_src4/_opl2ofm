#compdef opl2ofm
# Documentation: opl2ofm --help (TeX Live 2026)
# Source: translate Omega Property List (OPL) back to Omega Font Metrics (OFM).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[display help]' \
    '(- *)-version[output version information]' \
    '-verbose[display progress reports]' \
    '1:opl input:_files -g "*.opl"' \
    '2:ofm output:_files -g "*.ofm"' \
    && ret=0

return ret
