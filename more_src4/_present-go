#compdef present
# _present-go — Go x/tools present (Andrew Gerrand, Go team); slide/article presentations server using .slide/.article files
# upstream: https://pkg.go.dev/golang.org/x/tools/cmd/present

_present-go() {
    _arguments \
        '-base+[base dir]:dir:_files -/' \
        '-content+[content dir]:dir:_files -/' \
        '-http+[bind addr]:addr:' \
        '-nacl[NaCl playground]' \
        '-notes[enable notes]' \
        '-orighost+[original host]:host:_hosts' \
        '-play+[playground mode]:bool:(true false)' \
        '-use_playground[use go.dev playground]' \
        '*:dir:_files -/'
}

_present-go "$@"
