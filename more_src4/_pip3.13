#compdef pip3.13 pip3.12 pip3.11 pip3.10 pip3 pip
# Documentation: pip --help (pip.pypa.io)
# Source: pip — Python package installer (top-level + 16 subcommands).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a verbs
verbs=(
    'install:install packages'
    'download:download packages'
    'uninstall:uninstall packages'
    'freeze:list installed packages in requirements format'
    'inspect:inspect the python environment'
    'list:list installed packages'
    'show:show information about installed packages'
    'check:verify installed packages have compatible dependencies'
    'config:manage pip configuration'
    'search:search PyPI for packages'
    'cache:manage pip cache'
    'index:query package index'
    'wheel:build wheel archives'
    'hash:compute hashes of package archives'
    'completion:install shell completion script'
    'debug:show debug information'
    'help:show help for a command'
)

local -a top_opts
top_opts=(
    '(- *)'{-h,--help}'[show help and exit]'
    '--debug[enable debug logging]'
    '(- *)'{-V,--version}'[show version and exit]'
    '--isolated[ignore env vars and user config]'
    '--require-virtualenv[require venv; exit otherwise]'
    '--python=[run with specified interpreter]:python:'
    '*'{-v,--verbose}'[verbose (use up to 3 times)]'
    '*'{-q,--quiet}'[quiet (use up to 3 times)]'
    '--log=[appending log file]:file:_files'
    '--no-input[disable prompts]'
    '--keyring-provider=[keyring provider]:provider:(disabled subprocess import auto)'
    '--proxy=[proxy URL]:url:'
    '--retries=[max retries (default 5)]:n:'
    '--timeout=[socket timeout (default 15s)]:secs:'
    '--exists-action=[action on existing files]:action:(s i w b a)'
    '*--trusted-host=[trusted host without HTTPS verification]:host:_hosts'
    '--cert=[CA bundle file]:file:_files'
    '--client-cert=[SSL client cert]:file:_files'
    '--cache-dir=[cache directory]:dir:_files -/'
    '--no-cache-dir[disable cache]'
    '--disable-pip-version-check[skip pip update check]'
    '--no-color[suppress color output]'
    '--no-python-version-warning[hide Python EOL warning]'
    '*--use-feature=[enable a future feature]:feature:'
    '*--use-deprecated=[enable deprecated feature]:feature:'
    '--resume-retries=[retries on connection loss]:n:'
)

_arguments -C \
    $top_opts \
    '1: :->cmd' \
    '*:: :->args' \
    && ret=0

case $state in
    cmd) _describe -t pip-verbs 'pip subcommand' verbs && ret=0 ;;
    args)
        case $line[1] in
            install)
                _arguments \
                    $top_opts \
                    '*'{-r,--requirement=}'[requirements file]:file:_files -g "*.txt"' \
                    '*'{-c,--constraint=}'[constraints file]:file:_files -g "*.txt"' \
                    '--no-deps[skip installing dependencies]' \
                    '--pre[allow pre-release versions]' \
                    '*'{-e,--editable=}'[editable install (VCS URL or local path)]:path:_files' \
                    '*'{-t,--target=}'[install into directory]:dir:_files -/' \
                    '--platform=[target platform]:platform:' \
                    '*--python-version=[target Python version]:version:' \
                    '--implementation=[target implementation]:impl:(cp pp jy)' \
                    '*--abi=[target Python ABI]:abi:' \
                    '*--user[install to user site-packages]' \
                    '--root=[treat DIR as root for prefix]:dir:_files -/' \
                    '--prefix=[install prefix]:dir:_files -/' \
                    '*'{-U,--upgrade}'[upgrade packages]' \
                    '--upgrade-strategy=[upgrade strategy]:strategy:(eager only-if-needed)' \
                    '--force-reinstall[reinstall all dependencies]' \
                    '*'{-I,--ignore-installed}'[ignore already-installed]' \
                    '--ignore-requires-python[ignore Python-version requirements]' \
                    '--no-build-isolation[disable PEP 517 build isolation]' \
                    '--use-pep517[force PEP 517 build]' \
                    '--check-build-dependencies[check build dependencies before build]' \
                    '--break-system-packages[override externally-managed]' \
                    '*--config-settings=[config setting (KEY=VALUE)]:setting:' \
                    '--global-option=[extra build options]:opt:' \
                    '--compile[compile .pyc bytecode after install]' \
                    '--no-compile[do not compile .pyc bytecode]' \
                    '--no-warn-script-location[hide non-PATH script warning]' \
                    '--no-warn-conflicts[hide conflict warnings]' \
                    '--no-binary=[avoid binary packages]:pkg:' \
                    '--only-binary=[only binary packages]:pkg:' \
                    '--prefer-binary[prefer binary wheels]' \
                    '*--src=[source code directory (with --editable)]:dir:_files -/' \
                    '--require-hashes[require hashes]' \
                    '--progress-bar=[progress bar style]:style:(on off ascii pretty raw)' \
                    '--root-user-action=[root-user action]:action:(warn ignore)' \
                    '--no-clean[do not clean build directories on success]' \
                    '*-i+[index URL]:url:' \
                    '*--index-url=[base PyPI URL]:url:' \
                    '*--extra-index-url=[extra index URL]:url:' \
                    '--no-index[ignore package index]' \
                    '*'{-f,--find-links=}'[location to look for archives]:url-or-path:_files' \
                    '*:package or path:_files' \
                    && ret=0
                ;;
            uninstall)
                _arguments \
                    '*'{-r,--requirement=}'[requirements file]:file:_files -g "*.txt"' \
                    '(-y --yes)'{-y,--yes}'[do not ask for confirmation]' \
                    '--break-system-packages[override externally-managed]' \
                    '*:package:' \
                    && ret=0
                ;;
            list)
                _arguments \
                    '(-o --outdated -u --uptodate)'{-o,--outdated}'[list outdated packages]' \
                    '(-o --outdated -u --uptodate)'{-u,--uptodate}'[list up-to-date packages]' \
                    '(-e --editable)'{-e,--editable}'[list editable installs only]' \
                    '(-l --local)'{-l,--local}'[skip globally-installed]' \
                    '--user[only user-site installs]' \
                    '--pre[include pre-release versions]' \
                    '--format=[output format]:format:(columns freeze json)' \
                    '--not-required[list deps that nothing requires]' \
                    '--exclude-editable[skip editable installs]' \
                    '--include-editable[include editable installs]' \
                    && ret=0
                ;;
            show|inspect|hash|check|freeze|search|wheel|cache|config|index|download|completion|debug|help)
                _arguments '*:argument:_files' && ret=0
                ;;
        esac
        ;;
esac

return ret
