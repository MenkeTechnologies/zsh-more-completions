#compdef pi3topbm
# Documentation: man pi3topbm (Netpbm)
# Source: convert an Atari Degas PI3 image to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pi3 file:_files -g "*.pi3"' \
    && ret=0

return ret
