#compdef netperf
# Documentation: https://hewlettpackard.github.io/netperf/doc/netperf.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for netperf - network performance benchmark

_arguments -s -S \
  '-a[set local send/recv alignment]:alignment:' \
  '-A[set remote send/recv alignment]:alignment:' \
  '-b[burst N transactions]:burst:' \
  '-B[set local IP address]:local address:' \
  '-c[set local CPU rate]:CPU rate:' \
  '-C[set remote CPU rate]:CPU rate:' \
  '-d[enable debug output]' \
  '-D[set demo mode interval]:interval:' \
  '-f[output format]:format:(k m g K M G)' \
  '-F[fill file]:fill file:_files' \
  '-H[remote host]:remote host:_hosts' \
  '-I[confidence level]:confidence:' \
  '-i[max confidence iterations]:iterations:' \
  '-j[keep additional timing statistics]' \
  '-l[test length in seconds]:seconds:' \
  '-L[local IP TOS value]:TOS value:' \
  '-n[do not establish a control connection]' \
  '-N[set TCP_NODELAY on data socket]' \
  '-o[output selector list]:output selector:' \
  '-O[output selector list with headers]:output selector:' \
  '-p[remote port]:port:' \
  '-P[local port]:port:' \
  '-s[set socket buffer sizes]:sizes:' \
  '-S[set remote socket buffer sizes]:sizes:' \
  '-t[test type]:test type:(TCP_STREAM TCP_MAERTS TCP_SENDFILE TCP_RR TCP_CC TCP_CRR UDP_STREAM UDP_RR XTI_TCP_STREAM XTI_TCP_RR XTI_TCP_CC XTI_TCP_CRR XTI_UDP_STREAM XTI_UDP_RR SCTP_STREAM SCTP_RR DLCO_STREAM DLCO_RR DLCL_STREAM DLCL_RR OMNI)' \
  '-T[processor affinity]:processor:' \
  '-v[verbosity level]:verbosity:(0 1 2)' \
  '-w[wait interval between bursts]:interval:' \
  '-W[send/recv ring buffers]:rings:' \
  '-4[use IPv4 only]' \
  '-6[use IPv6 only]' \
  '(- *)-V[show version]' \
  '(- *)-h[show help]'
