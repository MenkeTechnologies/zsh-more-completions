#compdef mktextfm
# Documentation: mktextfm --help (TeX Live kpathsea)
# Source: TeX mktextfm — create a TFM (TeX font metric) for FONT on demand.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--destdir+[install root directory]:dir:_files -/' \
    '1:font name:' \
    && ret=0

return ret
