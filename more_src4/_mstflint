#compdef mstflint flint
# Documentation: https://www.mankier.com/1/mstflint
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mstflint: Mellanox firmware burn/query tool.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'b:burn firmware'
  'burn:burn firmware'
  'q:query firmware'
  'query:query firmware'
  'v:verify entire flash'
  'verify:verify entire flash'
  'swreset:software reset switch device'
  'brom:burn ROM file'
  'drom:remove ROM section'
  'rrom:read ROM section'
  'bb:burn block, no checks'
  'sg:set GUIDs'
  'sv:set VSD'
  'ri:read firmware image'
  'dc:dump configuration'
  'dh:dump hash'
  'set_key:set HW access key'
  'hw_access:enable/disable HW access'
  'hw:query HW info'
  'e:erase sector'
  'erase:erase sector'
  'rw:read dword from flash'
  'ww:write dword to flash'
  'wwne:write dword without erase'
  'wbne:write block without erase'
  'wb:write block'
  'rb:read block'
  'clear_semaphore:clear flash semaphore'
  'qrom:query ROM image'
  'checksum:MD5 checksum'
  'cs:MD5 checksum'
  'timestamp:firmware timestamping'
  'ts:firmware timestamping'
  'cache_image:cache firmware image'
  'ci:cache firmware image'
  'sign:sign firmware image'
  'sign_with_hmac:sign with HMAC'
  'set_public_keys:set public keys'
  'set_forbidden_versions:set forbidden versions'
  'image_reactivate:reactivate previous image'
  'ir:reactivate previous image'
  'binary_compare:binary compare device vs file'
  'bc:binary compare device vs file'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d,--device}'[device specification]:dev:' \
  '(-i --image)'{-i,--image}'[firmware image]:file:_files -g "*.(bin|mfa|mfa2)"' \
  '(-y --yes)'{-y,--yes}'[answer yes to all prompts]' \
  '--no[answer no to all prompts]' \
  '--guid=[base GUID]:guid:' \
  '--guids=[four GUIDs]:list:' \
  '--mac=[base MAC]:mac:' \
  '--macs=[two MACs]:list:' \
  '--uid=[device UID derivation]:uid:' \
  '--blank_guids[burn with blank GUIDs/MACs]' \
  '--clear_semaphore[force clear semaphore]' \
  '--qq[quick query]' \
  '--low_cpu[reduce CPU usage]' \
  '(-s --silent)'{-s,--silent}'[no progress display]' \
  '--vsd=[write VSD string]:string:' \
  '--log=[log burning status]:file:_files' \
  '--private_key=[PEM private key]:file:_files' \
  '--hmac_key=[HMAC key file]:file:_files' \
  '--allow_psid_change[allow PSID change]' \
  '--override_cache_replacement[override cache replacement mode]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mstflint command' commands && ret=0 ;;
esac
return ret
