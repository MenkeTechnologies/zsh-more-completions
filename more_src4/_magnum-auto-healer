#compdef magnum-auto-healer
# _magnum-auto-healer — OpenStack Magnum cluster node auto-healing daemon
# upstream: https://github.com/kubernetes/cloud-provider-openstack
# Flags from pkg/autohealing/cmd/root.go on tip.

_magnum-auto-healer() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--config=[auto-healer config file (default \$HOME/.kube_autohealer_config.yaml)]:file:_files' \
        '-v[klog verbosity level]:n:'
}

_magnum-auto-healer "$@"
