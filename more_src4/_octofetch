#compdef octofetch
# Documentation: https://github.com/azur1s/octofetch
# Source: azur1s/octofetch src/main.rs — GitHub user info terminal display (Rust).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)-v[show version]' \
    '(- *)-h[show help]' \
    '-c+[config path]:file:_files' \
    '1::github user:_default' \
    && ret=0

return ret
