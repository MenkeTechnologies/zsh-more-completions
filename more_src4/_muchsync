#compdef muchsync
# Documentation: https://www.muchsync.org/muchsync.html
# Reference accessed: 2026-05-30
# muchsync — bidirectional sync of notmuch maildirs + tag DB between machines. By Joey Hess.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-C --config)'{-C,--config=}'[notmuch config file (default $NOTMUCH_CONFIG or ~/.notmuch-config)]:file:_files' \
  '-F[check for modified files (default assumes maildir files never edited)]' \
  '-r+[path to muchsync on the server (for non-standard install locations)]:path:' \
  '-s+[ssh command line passed to /bin/sh (default "ssh -CTaxq")]:cmd:' \
  '*-v[increase verbosity (stackable)]' \
  '--init=[clone existing remote mailbox into local maildir]:maildir:_directories' \
  '--nonew[do not run "notmuch new" before syncing]' \
  '(--noup --noupload)--noup[receive only: download from server, do not upload]' \
  '(--noup --noupload)--noupload[alias for --noup]' \
  '--upbg[download in foreground, fork background to upload client files]' \
  '(- *)--self[print the 64-bit replica ID of local maildir replica and exit]' \
  '--newid[change replica identifier (use after copying databases to avoid conflicts)]' \
  '*:remote (e.g. host or user@host):_hosts' \
  && ret=0

return ret
