#compdef pgwatch2
# Documentation: https://github.com/cybertec-postgresql/pgwatch2
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show build version]' \
  '(-c --config)'{-c,--config=}'[config file/folder]:file:_files' \
  '(-m --metrics-folder)'{-m,--metrics-folder=}'[metrics folder]:dir:_files -/' \
  '--host=[PG config DB host]:host:_hosts' \
  '(-p --port)'{-p,--port=}'[PG config DB port]:port:' \
  '(-d --dbname)'{-d,--dbname=}'[PG config DB name]:db:' \
  '(-u --user)'{-u,--user=}'[PG config DB user]:user:' \
  '--password=[PG config DB password]:pw:' \
  '--pg-require-ssl=[require SSL for config DB]:bool:(true false)' \
  '(-g --group)'{-g,--group=}'[group filter]:group:' \
  '--datastore=[datastore type]:type:(influx postgres prometheus graphite json)' \
  '--pg-metric-store-conn-str=[PG metric store conn str]:conn:' \
  '--pg-retention-days=[PG retention days]:days:' \
  '--prometheus-port=[Prometheus port]:port:' \
  '--prometheus-listen-addr=[Prometheus listen addr]:addr:' \
  '--prometheus-namespace=[Prometheus namespace]:ns:' \
  '--prometheus-async-mode=[async gathering]:bool:(true false)' \
  '--ihost=[InfluxDB host]:host:_hosts' \
  '--iport=[InfluxDB port]:port:' \
  '--idbname=[InfluxDB database]:db:' \
  '--iuser=[InfluxDB user]:user:' \
  '--ipassword=[InfluxDB password]:pw:' \
  '--issl=[InfluxDB SSL]:bool:(true false)' \
  '--issl-skip-verify=[skip SSL verify]:bool:(true false)' \
  '--ihost2=[InfluxDB host II]:host:_hosts' \
  '--iport2=[InfluxDB port II]:port:' \
  '--idbname2=[InfluxDB db II]:db:' \
  '--iuser2=[InfluxDB user II]:user:' \
  '--ipassword2=[InfluxDB pw II]:pw:' \
  '--issl2=[InfluxDB SSL II]:bool:(true false)' \
  '--iretentiondays=[retention days]:days:' \
  '--iretentionname=[retention policy name]:name:' \
  '--graphite-host=[Graphite host]:host:_hosts' \
  '--graphite-port=[Graphite port]:port:' \
  '--json-storage-file=[JSON storage file]:file:_files' \
  '--batching-delay-ms=[batching delay ms]:ms:' \
  '--adhoc-conn-str=[ad-hoc connection string]:conn:' \
  '--adhoc-dbtype=[ad-hoc db type]:type:(postgres postgres-continuous-discovery)' \
  '--adhoc-config=[ad-hoc preset or JSON config]:cfg:' \
  '--adhoc-create-helpers=[try auto-create helpers]:bool:(true false)' \
  '--adhoc-name=[ad-hoc unique name]:name:' \
  '--internal-stats-port=[internal stats port]:port:' \
  '--direct-os-stats=[direct OS stats]:val:(on off)' \
  '--conn-pooling=[connection pooling]:val:(on off)' \
  '--aes-gcm-keyphrase=[AES-GCM keyphrase]:key:' \
  '--aes-gcm-keyphrase-file=[AES-GCM keyphrase file]:file:_files' \
  '--aes-gcm-password-to-encrypt=[password to encrypt]:pw:' \
  '--testdata-multiplier=[test data multiplier]:n:' \
  '--testdata-days=[test data days]:days:' \
  '--add-real-dbname=[add real DB name]:bool:(true false)' \
  '--real-dbname-field=[real DB name tag]:field:' \
  '--add-system-identifier=[add system identifier]:bool:(true false)' \
  '--system-identifier-field=[system identifier tag]:field:' \
  '--servers-refresh-loop-seconds=[servers refresh sec]:sec:' \
  '--instance-level-cache-max-seconds=[cache max seconds]:sec:' \
  '--min-db-size-mb=[min DB size MB]:n:' \
  '--max-parallel-connections-per-db=[max parallel conn per db]:n:' \
  '--ping[ping configured DBs and exit]' \
  '--emergency-pause-triggerfile=[emergency pause file]:file:_files' \
  '--no-helper-functions=[ignore helper functions]:bool:(true false)' \
  '--try-create-listed-exts-if-missing=[extensions to auto-create]:list:' \
  '(-v --verbose)'{-v,--verbose=}'[chat level]:level:(DEBUG INFO WARN)' && ret=0

return ret
