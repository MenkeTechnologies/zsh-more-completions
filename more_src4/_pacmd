#compdef pacmd
# Documentation: https://manpages.debian.org/pacmd.1
# Source: PulseAudio — interactive command shell, accepts default.pa syntax (pulse-cli-syntax(5)).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '*:command:' \
    && ret=0

return ret
