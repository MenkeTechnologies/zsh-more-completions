#compdef neovide
# Documentation: https://neovide.dev/command-line-reference.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_neovide() {
  _arguments \
    '--fork[detach from terminal]' \
    '--frame=[window decoration mode]:frame:(full none transparent buttonless)' \
    '--grid=[grid size COLSxLINES]:grid' \
    '--icon=[path to custom application icon]:file:_files' \
    '--log[enable debug logging]' \
    '--maximized[start maximized]' \
    '--mouse-cursor-icon=[mouse cursor icon]:icon:(arrow i-beam)' \
    '--neovim-bin=[path to neovim binary]:binary:_files' \
    '--no-idle[render continuously instead of on demand]' \
    '--no-multigrid[disable multigrid]' \
    '--no-srgb[disable sRGB support]' \
    '--no-tabs[disable file tabs]' \
    '--no-vsync[disable vertical sync]' \
    '--no-system-native-tabs[disable native macOS tabs]' \
    '--opengl[force the OpenGL renderer]' \
    '--server=[connect to an existing Neovim server]:addr' \
    '--size=[initial window dimensions in pixels]:size' \
    '--srgb[request sRGB support]' \
    '--system-native-tabs[use macOS native tabs]' \
    '--tabs[enable file tabs]' \
    '--title-hidden[hide window title (macOS)]' \
    '--vsync[enable vertical sync]' \
    '--wsl[launch Neovim from WSL]' \
    '--chdir=[set working directory]:dir:_directories' \
    '--reuse-instance[forward file requests to existing instance (macOS)]' \
    '--new-window[create a new window when reusing instance (macOS)]' \
    '--wayland-app-id=[Wayland application identifier]:id' \
    '--x11-wm-class=[X11 WM class]:class' \
    '--x11-wm-class-instance=[X11 WM class instance]:instance' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '*:file:_files'
}

_neovide "$@"
