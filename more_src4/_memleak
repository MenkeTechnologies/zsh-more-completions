#compdef memleak memleak-bpfcc
# Documentation: https://github.com/iovisor/bcc (tools/memleak.py argparse)
# Reference accessed: 2026-05-29
# memleak — trace and aggregate outstanding memory allocations (BCC/eBPF). Detects leaks.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(-p --pid)'{-p,--pid=}'[PID to trace (default: trace kernel allocs)]:pid:_pids' \
  '(-t --trace)'{-t,--trace}'[print trace messages for each alloc/free call]' \
  '(-a --show-allocs)'{-a,--show-allocs}'[show allocation addresses and sizes plus call stacks]' \
  '(-o --older)'{-o,--older=}'[prune allocations younger than this age in ms (default 500)]:ms:' \
  '(-c --command)'{-c,--command=}'[execute and trace the specified command]:cmd:_command_names' \
  '--combined-only[show combined allocation statistics only]' \
  '--wa-missing-free[workaround when free() is missing]' \
  '(-s --sample-rate)'{-s,--sample-rate=}'[sample every N-th allocation (default 1)]:N:' \
  '(-T --top)'{-T,--top=}'[display only this many top allocating stacks by size (default 10)]:N:' \
  '(-z --min-size)'{-z,--min-size=}'[capture only allocations >= this size]:bytes:' \
  '(-Z --max-size)'{-Z,--max-size=}'[capture only allocations <= this size]:bytes:' \
  '(-O --obj)'{-O,--obj=}'[attach to allocator functions in the specified object (default c)]:lib:' \
  '--percpu[trace percpu allocations]' \
  '--sort=[report sort key (default size)]:key:(size count)' \
  '--symbols-prefix=[memory allocator symbols prefix]:prefix:' \
  '1:interval (seconds, default 5):' \
  '2:count (number of reports, default unlimited):' \
  && ret=0

return ret
