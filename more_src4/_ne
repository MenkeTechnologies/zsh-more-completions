#compdef ne
# Documentation: https://manpages.ubuntu.com/manpages/xenial/man1/ne.1.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# ne - the nice editor, by Sebastiano Vigna. https://github.com/vigna/ne

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '--ansi[use built-in ANSI sequences]' \
  '--no-ansi[do not use built-in ANSI sequences]' \
  '--no-config[do not read config files]' \
  '--no-syntax[disable syntax highlighting]' \
  '*--binary[load files as binary]' \
  '--utf8[enable UTF-8 I/O]' \
  '--no-utf8[disable UTF-8 I/O]' \
  '--keys=[keyboard configuration file]:key file:_files' \
  '--menus=[menu configuration file]:menu file:_files' \
  '--macro=[execute macro file]:macro file:_files' \
  '*+[go to line (optionally column) in next file]:line[,col]:' \
  '*:files:_files' && ret=0

return ret
