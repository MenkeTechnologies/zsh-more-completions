#compdef ppmdist
# Documentation: man ppmdist (Netpbm)
# Source: convert a PPM image to grayscale by mapping its color distribution.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-intensity -frequency)-intensity[map by color intensity]' \
    '(-intensity -frequency)-frequency[map by color frequency]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
