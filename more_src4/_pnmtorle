#compdef pnmtorle
# Documentation: man pnmtorle (Netpbm)
# Source: convert a Netpbm image to Utah Raster Toolkit RLE format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-header[only write header]' \
    '-verbose[verbose output]' \
    '-alpha[include alpha channel]' \
    '-outfile=[output RLE file]:file:_files -g "*.rle"' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
