#compdef mktexpk mktexmf
# Documentation: mktexpk --help (TeX Live kpathsea)
# Source: TeX mktexpk / mktexmf — create PK bitmap fonts / Metafont sources on demand.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--dpi+[resolution (dpi)]:dpi:' \
    '--bdpi+[base resolution]:bdpi:' \
    '--mag+[METAFONT magnification]:mag:' \
    '--mfmode+[METAFONT mode]:mode:' \
    '--destdir+[install root directory]:dir:_files -/' \
    '1:font name:' \
    '2:redirect (>&n FD):' \
    && ret=0

return ret
