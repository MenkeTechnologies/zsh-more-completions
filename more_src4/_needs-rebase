#compdef needs-rebase
# _needs-rebase — Prow external plugin labelling PRs that need a rebase (kubernetes-sigs/prow)
# upstream: https://github.com/kubernetes-sigs/prow
# Flags from cmd/external-plugins/needs-rebase/main.go (flag).

_needs-rebase() {
    _arguments \
        '-port=[listen port]:port:' \
        '-dry-run=[dry run for testing]:val:(true false)' \
        '-update-period=[period between full PR scans]:duration:' \
        '-hmac-secret-file=[GitHub HMAC secret file]:file:_files' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-cache-valid-time=[do not re-check mergeability within (s)]:s:' \
        '-github-token-path=[GitHub token file]:file:_files' \
        '-github-endpoint=[GitHub API endpoint]:url:_urls'
}

_needs-rebase "$@"
