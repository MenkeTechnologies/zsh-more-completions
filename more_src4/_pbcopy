#compdef pbcopy
# Documentation: macOS man pbcopy(1)
# Source: Apple macOS pasteboard utility (Objective-C, getopt).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '-help[show help]' \
    '-pboard+[target pasteboard]:pboard:(general ruler find font)' \
    && ret=0

return ret
