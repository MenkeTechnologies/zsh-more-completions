#compdef mshowfat
# Documentation: https://www.gnu.org/software/mtools/manual/html_node/mshowfat.html
# Reference accessed: 2026-05-17
# Verified: GNU mtools mshowfat upstream manual — show FAT cluster
# chain for a file on a DOS volume. Flags: -o OFFSET, -i IMAGE,
# -V (version), -v (verbose), -h.
# Removed from prior file: bogus man.archlinux.org search URL.

local ret=1
_arguments -s -S \
  '(- *)-h[show help]' \
  '(- *)-V[show version]' \
  '-v[verbose]' \
  '-o+[print cluster at byte offset only]:offset:' \
  '-i+[image file]:file:_files' \
  '*:MS-DOS file path (e.g. a:foo.txt):_files' && ret=0
return ret
