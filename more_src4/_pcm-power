#compdef pcm-power
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-power.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-power: Intel PCM event-based power monitoring
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-m[IMC profile (0-4 or -1)]:imc_profile:' \
  '-p[PCU profile (0-8 or -1)]:pcu_profile:' \
  '-a[frequency minimum for band 0 in 100MHz units]:freq:' \
  '-b[frequency minimum for band 1 in 100MHz units]:freq:' \
  '-c[frequency minimum for band 2 in 100MHz units]:freq:' \
  '-i=-[number of iterations]:n:' \
  '*::pcm-power args:_files' && ret=0
return ret
