#compdef ovirt-populator
# _ovirt-populator — CDI populator that streams an oVirt-engine disk image into a PVC
# upstream: https://github.com/kubevirt/containerized-data-importer
# Flags from cmd/ovirt-populator/ovirt-populator.go on tip.

_ovirt-populator() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--engine-url=[ovirt-engine URL]:url:_urls' \
        '--disk-id=[ovirt-engine disk ID]:id:' \
        '--volume-path=[volume path to populate]:path:_files' \
        '--secret-name=[secret containing oVirt credentials]:name:' \
        '--cr-name=[custom resource instance name]:name:' \
        '--cr-namespace=[custom resource instance namespace]:ns:' \
        '--owner-uid=[owner UID (usually PVC UID)]:uid:' \
        '--pvc-size=[size of pvc (bytes)]:n:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr[log to stderr and files]' \
        '--stderrthreshold=[stderr threshold level]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files'
}

_ovirt-populator "$@"
