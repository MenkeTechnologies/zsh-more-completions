#compdef pt-kill
# Documentation: https://docs.percona.com/percona-toolkit/pt-kill.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--busy-time=[match queries running longer than]:seconds:' \
  '--any-busy-time=[match class if any query runs longer than]:seconds:' \
  '--each-busy-time=[match class if each query runs longer than]:seconds:' \
  '--charset=[default character set]:charset:' \
  '--config=[comma-separated config files]:files:_files' \
  '--create-log-table[create log table if missing]' \
  '--daemonize[run as daemon]' \
  '--database=[default database]:db:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--execute-command=[command to execute on match]:cmd:' \
  '--filter=[Perl filter expression]:expr:' \
  '--fingerprint[display fingerprint instead of original query]' \
  '--group-by=[group queries by]:attribute:(fingerprint user host db state command info)' \
  '--host=[MySQL host]:hostname:_hosts' \
  '--idle-time=[match idle connections longer than]:seconds:' \
  '--ignore-command=[ignore commands]:commands:' \
  '--ignore-db=[ignore databases]:databases:' \
  '--ignore-host=[ignore hosts]:hosts:' \
  '--ignore-info=[ignore query patterns]:pattern:' \
  '(--ignore-self --no-ignore-self)'{--ignore-self,--no-ignore-self}'[do not kill own connection]' \
  '--ignore-state=[ignore states]:states:' \
  '--ignore-user=[ignore users]:users:' \
  '--interval=[check interval]:seconds:' \
  '--json[output killed queries as JSON]' \
  '--json-fields=[extra JSON key:value pairs]:fields:' \
  '--kill[kill matching connections]' \
  '--kill-busy-commands=[commands to consider busy]:commands:' \
  '--kill-query[kill query but not connection]' \
  '--log=[log file when daemonized]:log file:_files' \
  '--log-dsn=[log killed queries to this DSN]:dsn:' \
  '--match-all[match all non-ignored queries]' \
  '--match-command=[match commands]:commands:' \
  '--match-db=[match databases]:databases:' \
  '--match-host=[match hosts]:hosts:' \
  '--match-info=[match query patterns]:pattern:' \
  '--match-state=[match states]:states:' \
  '--match-user=[match users]:users:' \
  '--mysql_ssl=[create SSL MySQL connection]:n:' \
  '--password=[MySQL password]:password:' \
  '--pid=[PID file]:pid file:_files' \
  '--port=[MySQL port]:port:' \
  '--print[print KILL statement without killing]' \
  '--query-count=[min number of matching queries]:count:' \
  '--query-id[print query digest ID]' \
  '--replication-threads[allow matching replication threads]' \
  '--run-time=[max run time]:duration:' \
  '--sentinel=[sentinel file]:file:_files' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:socket file:_files' \
  '--stop[stop running instances]' \
  '(--strip-comments --no-strip-comments)'{--strip-comments,--no-strip-comments}'[remove SQL comments]' \
  '--test-matching=[test matching against processlist snapshots]:files:_files' \
  '--user=[MySQL user]:username:' \
  '--verbose[print info about what is being done]' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '--victims=[how to select victims]:method:(oldest all all-but-oldest)' \
  '--wait-after-kill=[wait after killing]:seconds:' \
  '--wait-before-kill=[wait before killing]:seconds:' && ret=0

return ret
