#compdef ossec-agent ossec-agentd
# Documentation: https://www.ossec.net/docs/docs/programs/ossec-agentd.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# OSSEC agent daemon (the canonical binary is `ossec-agentd`).
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-V[show version]' \
  '-c[config file]:file:_files' \
  '-d[debug]' \
  '-f[run in foreground]' \
  '-t[test config]' \
  '-u[user]:user:_users' \
  '-g[group]:group:_groups' \
  '-D[runtime directory]:dir:_files -/' \
  '*::ossec-agent args:_files' && ret=0
return ret
