#compdef py2app
# _py2app — package Python apps as .app bundles on macOS (ronaldoussoren/py2app)
# upstream: https://github.com/ronaldoussoren/py2app
# Flags from py2app docs (options.html).

_py2app() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-A --alias)'{-A,--alias}'[build alias mode (debug)]' \
        '--arch=[architecture(s)]:arch:(arm64 x86_64 i386 universal2 fat)' \
        '--argv-emulation[emulate sys.argv from file open events]' \
        '--argv-inject=[additional argv values]:argv:' \
        '--bdist-base=[temporary build directory]:dir:_files -/' \
        '--datamodels=[xcdatamodel paths]:paths:' \
        '--debug-modulegraph[print modulegraph debug info]' \
        '--debug-skip-macholib[skip macholib processing]' \
        '--dist-dir=[output bundle directory]:dir:_files -/' \
        '*--dylib-excludes=[dylib excludes]:list:' \
        '--emulate-shell-environment[set up shell environment]' \
        '*--excludes=[exclude modules]:modules:' \
        '--extension=[bundle extension (.app, .plugin, .bundle)]:ext:(app plugin bundle)' \
        '*--extra-script=[extra entry point script]:file:_files -g "*.py"' \
        '--force-system-tk[use system Tk]' \
        '*--frameworks=[Mac framework paths]:paths:' \
        '--graph[generate modulegraph .dot]' \
        '--iconfile=[application icon]:file:_files -g "*.icns"' \
        '*--include-plugins=[plugin paths to include]:paths:' \
        '*--includes=[modules to include]:modules:' \
        '*--mappingmodels=[mapping models]:paths:' \
        '--matplotlib-backends=[matplotlib backends]:backends:' \
        '--no-chdir[do not chdir to bundle dir]' \
        '--no-report-missing-conditional-import[do not report missing conditional imports]' \
        '--no-strip[do not strip executables]' \
        '(-O --optimize)'{-O+,--optimize=}'[optimize level (0/1/2)]:n:(0 1 2)' \
        '*--packages=[packages to copy whole]:packages:' \
        '--plist=[Info.plist file]:file:_files' \
        '--prefer-ppc[prefer PowerPC]' \
        '*--qt-plugins=[Qt plugin paths]:paths:' \
        '--redirect-stdout-to-asl[redirect stdout/stderr to ASL]' \
        '--report-missing-from-imports[report from-imports that are missing]' \
        '*--resources=[bundle resource paths]:paths:' \
        '--semi-standalone[standalone except for system Python]' \
        '--site-packages[include site-packages]' \
        '--use-faulthandler[install faulthandler in bundle]' \
        '--use-pythonpath[use PYTHONPATH for module locations]' \
        '--xref[generate cross-reference HTML]' \
        '*:setup script:_files -g "setup.py"'
}

_py2app "$@"
