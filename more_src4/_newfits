#compdef newfits
# _newfits — write a new FITS file with WCS keywords (olebole/wcstools)
# upstream: https://github.com/olebole/wcstools
# Flags from newfits.c (single-letter getopt-style).

_newfits() {
    _arguments \
        '(- *)-help[show help]' \
        '(- *)-version[show version]' \
        '-a+[initial rotation angle (deg)]:deg:' \
        '-b+[reference pixel coords (B1950)]:coords:' \
        '-d[set CDELTn/CROTAn instead of CD matrix]' \
        '-e[make an extended FITS file]' \
        '-g+[reference pixel coords (Galactic)]:coords:' \
        '-i+[input pixel file]:file:_files' \
        '-j+[reference pixel coords (J2000)]:coords:' \
        '-o+[bits per pixel]:bits:(8 16 32 -32 -64)' \
        '-p+[initial plate scale (arcsec/pixel)]:scale:' \
        '-s+[size of image in X and Y pixels]:size:' \
        '-t+[FITS projection code]:proj:(TAN SIN ARC STG ZEA AIT NCP CAR MER MOL TSC PCO BON COE COD COO COP HPX)' \
        '-v[verbose output]' \
        '-w+[input FITS WCS file]:file:_files -g "*.(fits|fit|fts)"' \
        '-x+[reference pixel X and Y coords]:xy:' \
        '-z[use AIPS classic WCS]' \
        '1:output FITS file:_files -g "*.(fits|fit|fts)"'
}

_newfits "$@"
