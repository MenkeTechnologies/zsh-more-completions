#compdef neu
# Documentation: https://neutralino.js.org/docs/cli/neu-cli/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'create:create a new Neutralino app'
  'build:build the application'
  'run:execute the application'
  'update:update Neutralino binaries and client library'
  'version:show version information'
  'plugins:manage CLI plugins'
)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'neu command' commands && ret=0
    ;;
  (args)
    case ${line[1]} in
      (create)
        _arguments \
          '--template=[application template via GitHub identifier]:template:' \
          '1:project name:' && ret=0
        ;;
      (build)
        _arguments \
          '--release[create portable ZIP of the bundle]' \
          '--embed-resources[create single-file executable]' \
          '--copy-storage[copy current Neutralinojs storage snapshot]' \
          '--macos-bundle[create minimal macOS .app bundle]' \
          '--config-file=[custom app config for packaging]:file:_files' && ret=0
        ;;
      (run)
        _arguments \
          '--disable-auto-reload[turn off automatic reloading]' \
          '--arch=[target CPU architecture]:arch:(x64 arm64 armhf ia32)' \
          '*::extra:_default' && ret=0
        ;;
      (update)
        _arguments \
          '--latest[fetch latest framework version]' && ret=0
        ;;
      (plugins)
        _arguments \
          '--add[register a new plugin]' \
          '--remove[unregister an existing plugin]' \
          '1:plugin:' && ret=0
        ;;
    esac
    ;;
esac

return ret
