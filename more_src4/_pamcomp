#compdef pamcomp pnmcomp
# Documentation: man pamcomp (Netpbm)
# Source: compose an overlay Netpbm image on top of an underlying one with optional alpha.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-align=[horizontal alignment]:align:(left center right beyondleft beyondright)' \
    '-valign=[vertical alignment]:valign:(top middle bottom above below)' \
    '-xoff=[horizontal pixel offset]:x:' \
    '-yoff=[vertical pixel offset]:y:' \
    '-alpha=[alpha-channel PGM file]:file:_files -g "*.(pgm|pnm|pam)"' \
    '-invert[invert the alpha values]' \
    '-opacity=[overlay opacity 0..1]:opacity:' \
    '-mixtransparency[mix transparency-channel values]' \
    '-linear[treat samples as linear, not gamma-corrected]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:overlay file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '2:underlying file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '3:output file:_files' \
    && ret=0

return ret
