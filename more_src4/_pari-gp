#compdef pari-gp gp
# Documentation: https://manpages.ubuntu.com/manpages/focal/en/man1/gp.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# PARI/GP: computer algebra system (number theory)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[print command-line options summary]' \
  '(- *)--version[show version banner and exit]' \
  '(- *)--version-short[show version number and exit]' \
  '(-f --fast)'{-f,--fast}'[do not read .gprc on startup]' \
  '(-q --quiet)'{-q,--quiet}'[quiet mode]' \
  '(-D --default)'{-D+,--default=}'[set default key=val on startup]:key=val:' \
  '-s+[stack size in bytes]:bytes:' \
  '(-p --primelimit)'{-p+,--primelimit=}'[primelimit (deprecated)]:n:' \
  '--emacs[Emacs mode]' \
  '--test[run in test mode]' \
  '--texmacs[TeXmacs mode]' \
  '*:gp script:_files -g "*.gp"' && ret=0
return ret
