#compdef pilon
# Documentation: https://github.com/broadinstitute/pilon
# Source: broadinstitute/pilon src/main/scala/org/broadinstitute/pilon/Pilon.scala — genome assembly polisher (Scala).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '*--bam=[BAM file (multiple allowed)]:file:_files -g "*.bam"' \
    '--changes[output a separate changes file]' \
    '--chunksize=[chunk size for parallel processing]:n:_default' \
    '--debug[verbose debug output]' \
    '--defaultqual=[default base quality]:n:_default' \
    '--diploid[treat genome as diploid]' \
    '--dumpreads[dump reads contributing to assembly fixes]' \
    '--duplicates[include duplicate reads]' \
    '--iupac[output IUPAC ambiguity codes for heterozygous SNPs]' \
    '--fix=[items to fix]:items:(snps indels gaps local bases breaks circles novel all none)' \
    '--flank=[flank length around indels]:n:_default' \
    '*--frags=[fragment library BAM]:file:_files -g "*.bam"' \
    '--gapmargin=[gap margin]:n:_default' \
    '--genome=[input genome FASTA]:file:_files -g "*.{fa,fasta,fna,fa.gz,fasta.gz}"' \
    '*--jumps=[jump library BAM]:file:_files -g "*.bam"' \
    '--mindepth=[minimum depth threshold]:n:_default' \
    '--mingap=[minimum gap size to fill]:n:_default' \
    '--minmq=[minimum mapping quality]:n:_default' \
    '--minqual=[minimum base quality]:n:_default' \
    '--nanopore=[nanopore long-read BAM]:file:_files -g "*.bam"' \
    '--nonpf[include non-PF reads]' \
    '--output=[output basename]:basename:_default' \
    '--outdir=[output directory]:dir:_files -/' \
    '--pacbio=[PacBio long-read BAM]:file:_files -g "*.bam"' \
    '--targets=[restrict to genome region(s)]:targets:_default' \
    '--threads=[number of threads]:n:_default' \
    '--tracks[output tracks files (wiggle/bedgraph)]' \
    '*--unpaired=[unpaired BAM]:file:_files -g "*.bam"' \
    '--variant[heuristics for variant calling instead of polishing]' \
    '--vcf[emit a VCF file]' \
    '--vcfqe[VCF quality scoring tweak]' \
    '--verbose[verbose output]' \
    '--nostrays[disable stray-read heuristic]' \
    && ret=0

return ret
