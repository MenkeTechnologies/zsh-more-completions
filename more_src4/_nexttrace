#compdef nexttrace
# Documentation: https://github.com/nxtrace/NTrace-core
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nexttrace / NTrace (argparse; github.com/nxtrace/NTrace-core)

local curcontext="$curcontext" ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[help]' \
  '(-V --version)'{-V,--version}'[version]' \
  '(-4 --ipv4)'{-4,--ipv4}'[IPv4 only]' \
  '(-6 --ipv6)'{-6,--ipv6}'[IPv6 only]' \
  '(-T --tcp)'{-T,--tcp}'[TCP SYN trace]' \
  '(-U --udp)'{-U,--udp}'[UDP trace]' \
  '(-p --port)'{-p,--port}'[destination port]:port' \
  '(-m --max-hops)'{-m,--max-hops}'[max TTL/hops]:hops' \
  '(-d --data-provider)'{-d,--data-provider}'[geo provider]:provider:(LeoMoeAPI IP.SB IPInfo ipinfo chunzhen disable-geoip)' \
  '(-n --no-rdns)'{-n,--no-rdns}'[no reverse DNS]' \
  '(-a --always-rdns)'{-a,--always-rdns}'[always reverse DNS]' \
  '(-j --json)'{-j,--json}'[JSON output]' \
  '(--deploy)--deploy[web console]' \
  '*:target:_hosts' && ret=0

return ret
