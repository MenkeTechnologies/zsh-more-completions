#compdef oxenstored
# Documentation: https://github.com/xen-project/xen/blob/master/tools/ocaml/xenstored/parse_arg.ml
# Reference accessed: 2026-05-17
# Verified: xen-project/xen tools/ocaml/xenstored/parse_arg.ml.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated -h (real binary only has --help) and --pidfile (real flag
# is --pid-file); missing -T tracefile, --no-access-log, --live,
# --config-test.

# oxenstored: OCaml Xenstore daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--no-domain-init[do not init domain]' \
  '--config-file=[config file]:file:_files' \
  '--no-fork[do not fork]' \
  '--reraise-top-level[reraise top-level exceptions]' \
  '--no-access-log[disable access log]' \
  '--pid-file=[PID file]:file:_files' \
  '-T[trace file]:file:_files' \
  '--restart[restart from existing state]' \
  '--live[live update]' \
  '--config-test[only test config]' \
  '--disable-socket[disable unix socket]' && ret=0
return ret
