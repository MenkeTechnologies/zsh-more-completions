#compdef pen
# Documentation: https://manpages.debian.org/bookworm/pen/pen.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-a[ascii communication dumps with -dd]' \
  '-b+[blacklist unavailable servers sec]:sec:' \
  '-c+[max clients]:n:' \
  '-C+[control port or socket]:port-or-socket:' \
  '-d[debug (repeat for more)]' \
  '-e+[emergency server host:port]:host\:port:' \
  '-f[stay in foreground]' \
  '-F+[config file (penctl format)]:file:_files' \
  '-h[hash client IP for initial server selection]' \
  '-H[add X-Forwarded-For header]' \
  '-i+[Windows: install as service]:service:' \
  '-j+[chroot directory]:dir:_directories' \
  '-l+[log file]:file:_files' \
  '-m+[multi accept count]:n:' \
  '-o+[penctl format option]:option:' \
  '-p+[pid file]:file:_files' \
  '-q+[connection backlog size]:n:' \
  '-r[round-robin (no client tracking)]' \
  '-s[stubborn mode: close if initial server unavailable]' \
  '-S+[max ssl session ids]:n:' \
  '-t+[connection timeout sec]:sec:' \
  '-T+[client tracking sec]:sec:' \
  '-u+[POSIX: run as user / Windows: uninstall service]:user-or-service:' \
  '-w+[status report HTML file]:file:_files' \
  '-W[weight mode]' \
  '-x+[max simultaneous connections]:n:' \
  '-X[add exit command to control interface]' \
  '-E+[SSL certificate PEM file]:file:_files' \
  '-K+[SSL key PEM file]:file:_files' \
  '-G+[CA certificate file]:file:_files' \
  '-A+[CA certificate hashed dir]:dir:_directories' \
  '-Z[SSL compatibility mode]' \
  '-R[require valid peer certificate]' \
  '-L+[SSL protocol]:proto:(ssl23 ssl3 tls1)' \
  '-U[UDP protocol]' \
  '-P[use poll for event notification]' \
  '1:listen host\:port or socket:' \
  '*:server (host[:port[:maxc[:hard[:weight[:prio]]]]]):_hosts' && ret=0

return ret
