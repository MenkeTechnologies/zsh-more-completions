#compdef md2pdf
# Documentation: https://github.com/solworktech/md2pdf
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# md2pdf is a Go program using single-dash flags from the flag package.
_arguments -s \
  '-help[show help]' \
  '-version[show version and build info]' \
  '-i+[input file, directory, or URL]:input:_files' \
  '-o+[output PDF filename]:output:_files' \
  '-author+[author name (for footer)]:author:' \
  '-title+[title text]:title:' \
  '-font-file+[path to a font file]:file:_files' \
  '-font-name+[font name id (e.g. Helvetica-1251)]:name:' \
  '-generate-toc[auto-generate table of contents]' \
  '-log-file+[log file path]:file:_files' \
  '-new-page-on-hr[treat HR as a new page]' \
  '-orientation+[page orientation]:o:(portrait landscape)' \
  '-page-size+[page size]:s:(A3 A4 A5)' \
  '-s+[syntax highlighting files path]:path:_files -/' \
  '-theme+[theme: light, dark, or path to JSON]:theme:' \
  '-unicode-encoding+[character encoding (e.g. cp1251)]:enc:' \
  '-with-footer[print document footer]'
