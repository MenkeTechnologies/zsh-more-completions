#compdef picamera
# _picamera — Dave Jones picamera CLI for the original deprecated Python 2/3 Raspberry Pi camera-module library supporting still capture video recording preview overlay exposure mode timelapse circular buffer streaming (waveform80 team, Python); argparse
# upstream: https://github.com/waveform80/picamera

_picamera() {
    local -a sub=(
        'capture:capture still image'
        'record:record video'
        'preview:show live preview'
        'timelapse:capture timelapse'
        'status:show camera status'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--led=+[b]:b:(on off)' \
        '--sensor-mode=+[N]:n:(0 1 2 3 4 5 6 7)' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'picamera subcommand' sub ;;
        args)
            case $words[1] in
                capture) _arguments \
                    '--format=+[f]:f:(jpg png bmp gif yuv rgb rgba bgr bgra raw)' \
                    '--resolution=+[WxH]:str:' \
                    '--quality=+[N]:n:' \
                    '--rotation=+[deg]:n:(0 90 180 270)' \
                    '--hflip[horizontal flip]' \
                    '--vflip[vertical flip]' \
                    '--shutter-speed=+[us]:n:' \
                    '--iso=+[N]:n:(0 100 200 320 400 500 640 800)' \
                    '--exposure-mode=+[mode]:m:(auto night nightpreview backlight spotlight sports snow beach verylong fixedfps antishake fireworks)' \
                    '--awb-mode=+[mode]:m:(off auto sunlight cloudy shade tungsten fluorescent incandescent flash horizon)' \
                    '--brightness=+[N]:n:' \
                    '--contrast=+[N]:n:' \
                    '--saturation=+[N]:n:' \
                    '--sharpness=+[N]:n:' \
                    '--ev=+[F]:f:' \
                    '--meter-mode=+[m]:m:(average backlit matrix spot)' \
                    '--image-effect=+[e]:e:(none negative solarize sketch denoise emboss oilpaint hatch gpen pastel watercolor film blur saturation colorswap washedout posterise colorpoint colorbalance cartoon)' \
                    '-o+[output file]:file:_files' ;;
                record) _arguments \
                    '--format=+[f]:f:(h264 mjpeg yuv rgb rgba bgr bgra)' \
                    '--bitrate=+[bps]:n:' \
                    '--quality=+[N]:n:' \
                    '--profile=+[p]:p:(baseline main high)' \
                    '--level=+[N]:n:(3 3.1 3.2 4 4.1 4.2 5 5.1)' \
                    '--intra-period=+[N]:n:' \
                    '--duration=+[seconds]:f:' \
                    '--resolution=+[WxH]:str:' \
                    '--framerate=+[F]:f:' \
                    '-o+[output file]:file:_files' ;;
            esac
            ;;
    esac
}

_picamera "$@"
