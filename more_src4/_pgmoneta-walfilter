#compdef pgmoneta-walfilter
# _pgmoneta-walfilter — apply pgmoneta WAL filters (pgmoneta/pgmoneta)
# upstream: https://github.com/pgmoneta/pgmoneta
# Flags from src/walfilter.c (getopt_long).

_pgmoneta-walfilter() {
    _arguments \
        '(- *)'{-?,--help}'[show help]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.conf"' \
        '(-q --quiet)'{-q,--quiet}'[quiet mode]'
}

_pgmoneta-walfilter "$@"
