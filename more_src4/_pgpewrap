#compdef pgpewrap
# Documentation: https://manpages.debian.org/unstable/mutt/pgpewrap.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# pgpewrap is a tiny mutt helper that munges command line arguments for PGP/GPG;
# the only special syntax is a literal "--" followed by a prefix and recipients.

local curcontext="$curcontext" state line ret=1

_arguments \
  '*:command and recipients:_default' && ret=0

return ret
