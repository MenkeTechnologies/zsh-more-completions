#compdef obex-server-tool
# Documentation: https://github.com/bluez/bluez/blob/master/tools/obex-server-tool.c
# Source: BlueZ — OBEX server-side test harness over UNIX socket / Bluetooth RFCOMM/L2CAP.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-u --unix -b --bluetooth)'{-u,--unix}'[use a UNIX socket]' \
    '(-u --unix -b --bluetooth)'{-b,--bluetooth}'[use Bluetooth]' \
    '(-c --channel)'{-c+,--channel=}'[transport channel]:channel:' \
    '(-p --packet -s --stream)'{-p,--packet}'[packet-based transport]' \
    '(-p --packet -s --stream)'{-s,--stream}'[stream-based transport]' \
    '(-r --root)'{-r+,--root=}'[root directory]:dir:_directories' \
    '(-i --input-mtu)'{-i+,--input-mtu=}'[transport input MTU]:mtu:' \
    '(-o --output-mtu)'{-o+,--output-mtu=}'[transport output MTU]:mtu:' \
    && ret=0

return ret
