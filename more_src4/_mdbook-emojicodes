#compdef mdbook-emojicodes
# _mdbook-emojicodes — translate :shortcode: → emoji in mdbook (blyxyas/mdbook-emojicodes)
# upstream: https://github.com/blyxyas/mdbook-emojicodes
# Subcommands from src/main.rs via mdbook_preprocessor_boilerplate.

_mdbook-emojicodes() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-emojicodes "$@"
