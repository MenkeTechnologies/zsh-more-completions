#compdef mdls
# Documentation: https://www.unix.com/man-page/osx/1/mdls/
# Source: Apple macOS — list metadata attributes Spotlight stores for a file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-name[print only the matching metadata attribute]:attribute:(kMDItemDisplayName kMDItemContentType kMDItemContentTypeTree kMDItemKind kMDItemFSSize kMDItemFSName kMDItemFSCreationDate kMDItemFSContentChangeDate kMDItemContentCreationDate kMDItemContentModificationDate kMDItemLastUsedDate kMDItemUseCount kMDItemAuthors kMDItemTitle kMDItemKeywords kMDItemComment kMDItemFinderComment kMDItemUserTags kMDItemPixelWidth kMDItemPixelHeight kMDItemBitsPerSample kMDItemColorSpace kMDItemImageDirection kMDItemEXIFGPSVersion kMDItemEXIFVersion kMDItemAcquisitionMake kMDItemAcquisitionModel kMDItemAperture kMDItemExposureTimeSeconds kMDItemISOSpeed kMDItemFocalLength kMDItemAlbum kMDItemMusicalGenre kMDItemRecordingYear kMDItemContentSource kMDItemHasAlphaChannel kMDItemWhereFroms kMDItemDownloadedDate kMDItemFSInvisible kMDItemFSIsExtensionHidden kMDItemFSLabel kMDItemFSOwnerUserID kMDItemFSOwnerGroupID kMDItemFSNodeCount kMDItemPath)' \
    '-raw[print raw attribute data, NUL-separated (for xargs -0)]' \
    '-nullMarker[marker string when attribute is null (with -raw)]:marker:' \
    '*:file:_files' \
    && ret=0

return ret
