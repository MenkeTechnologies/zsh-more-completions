#compdef pgstats
# Documentation: https://github.com/gleu/pgstats
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# STUB: gleu/pgstats project ships several binaries (pgstat, pgcsvstat,
# pgreport, pgwaitevent, pgdisplay); there is no canonical "pgstats" CLI.
# This stub falls back to file completion so completions still work for the
# common case where users alias the name to one of the real tools.

local ret=1
_arguments -s \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '*:file:_files' && ret=0
return ret
