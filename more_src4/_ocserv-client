#compdef ocserv-client ocserv
# Documentation: https://manpages.debian.org/bookworm/ocserv/ocserv.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm ocserv(8) manpage. Note: ocserv is the SERVER;
# the actual VPN client is `openconnect`.

# ocserv: OpenConnect VPN server (despite "client" in package name)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-f --foreground)'{-f,--foreground}'[do not fork into background]' \
  '(-d --debug)'{-d,--debug=}'[debug verbosity 0-9999]:level:' \
  '(-c --config)'{-c,--config=}'[config file]:file:_files' \
  '(-t --test-config)'{-t,--test-config}'[test config file and exit]' \
  '(-p --pid-file)'{-p,--pid-file=}'[PID file]:file:_files' && ret=0
return ret
