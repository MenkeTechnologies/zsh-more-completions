#compdef pamflip pnmflip
# Documentation: man pamflip (Netpbm)
# Source: flip / rotate / reflect / transpose a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)'{-leftright,-lr}'[flip left-to-right]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)'{-topbottom,-tb}'[flip top-to-bottom]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)'{-transpose,-xy}'[transpose along x=y]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)-reflect[reflect along the other diagonal]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)'{-rotate90,-r90,-cw}'[rotate 90 clockwise]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)'{-rotate270,-r270,-ccw}'[rotate 270 (counter-clockwise)]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)'{-rotate180,-r180}'[rotate 180]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)-null[null transformation (copy)]' \
    '(-leftright -lr -topbottom -tb -transpose -xy -reflect -rotate90 -r90 -cw -rotate270 -r270 -ccw -rotate180 -r180 -null -xform)-xform=[compound transform list]:list:' \
    '-inverse[apply inverse transformation]' \
    '-memsize=[in-RAM size limit in MiB]:mebibytes:' \
    '-pagesize=[disk-page size for buffering]:bytes:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
