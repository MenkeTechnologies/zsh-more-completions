#compdef mount_nfs
# Documentation: man mount_nfs (macOS 26)
# Source: mount an NFS file system.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a optvals
optvals=(
    bg fg soft hard intr nointr resvport noresvport rdirplus nordirplus
    locallocks nolocks lockd nolockd nfc noac noatime noexec nosuid nodev
    nordma rdma quota noquota
    rsize wsize readahead maxgroups mountport mounttimeo retrycnt timeo retrans
    actimeo acregmin acregmax acdirmin acdirmax dsize deadtimeout
    nfsvers vers proto sec callback principal realm srvprincipal srvrealm
    inet inet4 inet6 nfsv2 nfsv3 nfsv4 mntudp mnttcp tcp udp
)

_arguments -s \
    '*-o+[NFS / mount options (comma-separated)]:options:('"$optvals"')' \
    '1:server\:/path:' \
    '2:mount point:_files -/' \
    && ret=0

return ret
