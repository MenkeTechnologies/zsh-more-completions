#compdef poe
# _poe — Poe the Poet task runner for Python projects (nat-n/poethepoet)
# upstream: https://github.com/nat-n/poethepoet

_poe() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '--root=[project root]:dir:_files -/' \
        '--ansi[force ANSI output]' \
        '--no-ansi[disable ANSI output]' \
        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
        '(-q --quiet)'{-q,--quiet}'[quiet output]' \
        '--dry-run[dry run without executing]' \
        '(-C --directory)'{-C,--directory}'=[working directory]:dir:_files -/' \
        '(-e --executor)'{-e,--executor}'=[task executor]:executor:(auto simple virtualenv poetry)' \
        '1: :_poe_tasks' \
        '*:task args:' && ret=0

    return ret
}

_poe_tasks() {
    local -a tasks
    if [[ -f pyproject.toml ]]; then
        tasks=(${(f)"$(grep -oP '^\[tool\.poe\.tasks\.\K[^]]+' pyproject.toml 2>/dev/null)"})
        if (( ${#tasks} )); then
            _describe -t tasks 'poe task' tasks
            return
        fi
    fi
    _message 'task name'
}

_poe "$@"
