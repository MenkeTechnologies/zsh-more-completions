#compdef postmark
# Documentation: https://github.com/ActiveCampaign/postmark-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'email:send an email'
  'servers:manage servers'
  'templates:pull/push/preview templates'
  'help:show help'
  'version:show CLI version'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'postmark command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (email)
        local -a email_subs=(
          'raw:send a raw HTML/text email'
          'template:send a templated email'
        )
        _describe -t ecmds 'email subcommand' email_subs && ret=0
        case $words[2] in
          (raw)
            _arguments \
              '(-s --source-server)'{-s+,--source-server=}'[source server token]:token:' \
              '(-f --from)'{-f+,--from=}'[from address]:from:' \
              '(-t --to)'{-t+,--to=}'[to address]:to:' \
              '(-c --cc)'{-c+,--cc=}'[cc address]:cc:' \
              '(-b --bcc)'{-b+,--bcc=}'[bcc address]:bcc:' \
              '--subject=[subject line]:subject:' \
              '--html=[HTML body]:html:' \
              '--text=[plain-text body]:text:' \
              '--reply-to=[reply-to address]:address:' \
              '--tag=[message tag]:tag:' \
              '--track-opens[track opens]' \
              '--track-links=[track links]:option:(None HtmlAndText HtmlOnly TextOnly)' \
              '--metadata=[metadata key=value]:meta:' \
              '*--header=[custom header]:header:' \
              '*--attachment=[file to attach]:file:_files' && ret=0 ;;
          (template)
            _arguments \
              '(-s --source-server)'{-s+,--source-server=}'[source server token]:token:' \
              '(-i --id)'{-i+,--id=}'[template id]:id:' \
              '(-a --alias)'{-a+,--alias=}'[template alias]:alias:' \
              '(-f --from)'{-f+,--from=}'[from address]:from:' \
              '(-t --to)'{-t+,--to=}'[to address]:to:' \
              '(-c --cc)'{-c+,--cc=}'[cc address]:cc:' \
              '(-b --bcc)'{-b+,--bcc=}'[bcc address]:bcc:' \
              '--subject=[subject (overrides template)]:subject:' \
              '--reply-to=[reply-to address]:address:' \
              '(-m --model)'{-m+,--model=}'[template model JSON]:json:' \
              '--tag=[message tag]:tag:' && ret=0 ;;
        esac ;;
      (servers)
        local -a server_subs=(
          'list:list servers'
          'create:create a server'
          'edit:edit a server'
          'delete:delete a server'
        )
        _describe -t scmds 'servers subcommand' server_subs && ret=0
        _arguments \
          '(-x --account-token)'{-x+,--account-token=}'[Postmark account token]:token:' \
          '--count=[max records]:n:' \
          '--offset=[record offset]:n:' \
          '--name=[filter by name]:name:' \
          '(-j --json)'{-j,--json}'[output as JSON]' \
          '--show-tokens[show server tokens]' && ret=0 ;;
      (templates)
        local -a tpl_subs=(
          'pull:pull templates from server to disk'
          'push:push templates from disk to server'
          'preview:preview templates locally'
          'list:list templates'
        )
        _describe -t tcmds 'templates subcommand' tpl_subs && ret=0
        _arguments \
          '(-s --source-server)'{-s+,--source-server=}'[server token]:token:' \
          '(-p --port)'{-p+,--port=}'[preview server port]:port:' \
          '--confirmation=[push confirmation]:level:(0 1 2)' && ret=0 ;;
    esac ;;
esac

return ret
