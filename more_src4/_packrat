#compdef packrat packrat-cli
# _packrat — RStudio packrat R package dependency manager CLI alias (RStudio, R); custom argparse via R wrapper (deprecated in favor of renv)
# upstream: https://github.com/rstudio/packrat

_packrat() {
    local -a sub=(
        'init:initialize a packrat project'
        'snapshot:save state to packrat.lock'
        'restore:restore packages from packrat.lock'
        'clean:remove unused packages'
        'status:show project status'
        'unused-packages:list unused packages'
        'install:install packages into project library'
        'on:enable packrat in session'
        'off:disable packrat in session'
        'bundle:bundle project as tar archive'
        'unbundle:unbundle project'
        'set-default-mirror:set default mirror'
        'set-default-cran-mirror:set default CRAN mirror'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--project=+[project dir]:dir:_files -/' \
        '-p+[project dir]:dir:_files -/' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'packrat subcommand' sub ;;
        args)
            case $words[1] in
                snapshot|restore) _arguments \
                    '--ignore-stale[ignore stale]' \
                    '--prompt[prompt]' \
                    '--dry-run[dry run]' \
                    '--ignore-suggests[ignore Suggests]' ;;
                install) _arguments '*:package:' ;;
                bundle) _arguments \
                    '--file=+[output file]:file:_files' \
                    '--include-src[include sources]' \
                    '--include-lib[include library]' \
                    '--include-vcs-history[include VCS history]' \
                    '--omit-cran-src[omit CRAN sources]' ;;
                unbundle) _arguments \
                    '*:bundle-file:_files -g "*.tar.gz"' ;;
                clean) _arguments '*:arg:' ;;
                set-default-mirror|set-default-cran-mirror) _arguments \
                    '*:url:_urls' ;;
            esac
            ;;
    esac
}

_packrat "$@"
