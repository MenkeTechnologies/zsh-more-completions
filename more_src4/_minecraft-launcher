#compdef minecraft-launcher
# Documentation: https://minecraft.fandom.com/wiki/Minecraft_Launcher
# Reference accessed: 2026-05-19
# Verified: community wiki + Mojang bug tracker (MCL-20059, MCL-14155).
# Note: official launcher accepts only a small set of CLI args; prior file
# contained invented flags (--launcherUrl, --username, --accessToken,
# --launcherVersion, --lang, --launchInGame). Removed.
# STUB: official Mojang launcher is not open source, so only the args
# documented externally are surfaced here.

local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '(-w --workDir)'{-w,--workDir=}'[set .minecraft working directory]:dir:_files -/' \
  '(-l --lockDir)'{-l,--lockDir=}'[restrict installation directory]:dir:_files -/' \
  '--tmpDir=[set temporary directory]:dir:_files -/' \
  '*::extra args:_files' && ret=0
return ret
