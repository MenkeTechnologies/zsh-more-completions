#compdef ovdb_init
# Documentation: man ovdb_init(8)
# Source: InterNetNews/inn frontends/ovdb_init.c — recover/upgrade ovdb Berkeley DB (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r -u)-r[recover-only mode]' \
    '(-r -u)-u[upgrade database]' \
    && ret=0

return ret
