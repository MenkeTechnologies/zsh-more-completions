#compdef promtool
# Documentation: https://prometheus.io/docs/prometheus/latest/command-line/promtool/
# Reference accessed: 2026-05-20
# Verified: upstream Prometheus promtool command-line reference.

# Zsh completion for promtool - Prometheus CLI utility

local curcontext="$curcontext" state line ret=1

local -a subcommands
subcommands=(
  'check:Check resources for validity'
  'query:Run queries against a Prometheus server'
  'debug:Fetch debug information'
  'push:Push metrics to a push gateway'
  'test:Unit test rule files'
  'tsdb:Run TSDB commands'
  'help:Show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--experimental[enable experimental commands]' \
  '*--enable-feature=[enable feature]:feature:(promql-experimental-functions promql-delayed-name-removal promql-duration-expr promql-extended-range-selectors)' \
  '1:subcommand:->subcmd' \
  '*:: :->args'

case $state in
  subcmd)
    _describe -t subcommands 'promtool subcommand' subcommands
    ;;
  args)
    case $words[1] in
      check)
        local -a check_cmds
        check_cmds=(
          'config:Check if a config file is valid'
          'rules:Check if a rule file is valid'
          'metrics:Check if metric names follow best practices'
          'web-config:Check if a web config file is valid'
          'service-discovery:Check service discovery configurations'
          'healthy:Check if a Prometheus server is healthy'
          'ready:Check if a Prometheus server is ready'
        )
        _arguments -C \
          '--syntax-only[check syntax only]' \
          '--lint=[lint rules]:lints:' \
          '--lint-fatal[treat lint warnings as errors]' \
          '--ignore-unknown-fields[ignore unknown YAML fields]' \
          '--agent[check as agent mode config]' \
          '--http.config.file=[http client config]:file:_files' \
          '--url=[Prometheus URL]:url:' \
          '1:check subcommand:->check_sub' \
          '*:: :->check_args'
        case $state in
          check_sub)
            _describe -t check_cmds 'check subcommand' check_cmds
            ;;
          check_args)
            case $words[1] in
              config|rules|web-config)
                _arguments '*:file:_files'
                ;;
              *)
                _arguments '*:argument'
                ;;
            esac
            ;;
        esac
        ;;
      query)
        local -a query_cmds
        query_cmds=(
          'instant:Run an instant query'
          'range:Run a range query'
          'labels:Run a labels query'
          'series:Run a series query'
          'analyze:Analyze metric usage'
        )
        _arguments -C \
          {-o,--format}'=[output format]:fmt:(promql json)' \
          '--http.config.file=[http client config]:file:_files' \
          '--time=[query at evaluation time]:time' \
          '--start=[range start]:time' \
          '--end=[range end]:time' \
          '--step=[query step]:duration' \
          '*--header=[extra HTTP header]:header' \
          '*--match=[label matcher]:matcher' \
          '1:query subcommand:->query_sub'
        case $state in
          query_sub)
            _describe -t query_cmds 'query subcommand' query_cmds
            ;;
        esac
        ;;
      debug)
        local -a debug_cmds
        debug_cmds=(
          'pprof:Fetch profiling debug information'
          'metrics:Fetch metrics debug information'
          'all:Fetch all debug information'
        )
        _arguments -C \
          '1:debug subcommand:->debug_sub'
        case $state in
          debug_sub)
            _describe -t debug_cmds 'debug subcommand' debug_cmds
            ;;
        esac
        ;;
      push)
        _arguments -C \
          '*--label=[push label]:label:' \
          '--timeout=[push timeout]:duration' \
          '*--header=[extra HTTP header]:header' \
          '--protobuf_message=[push body protobuf message]:message' \
          '1:push subcommand:(metrics)'
        ;;
      test)
        _arguments -C \
          '--junit=[junit XML output]:file:_files' \
          '--run=[regex to filter tests]:regex' \
          '--debug[debug output]' \
          '--diff[show diff on failure]' \
          '--ignore-unknown-fields[ignore unknown YAML fields]' \
          '1:test subcommand:(rules)' \
          '*:rules file:_files'
        ;;
      tsdb)
        local -a tsdb_cmds
        tsdb_cmds=(
          'bench:Run benchmarks against storage'
          'analyze:Analyze TSDB blocks'
          'list:List TSDB blocks'
          'dump:Dump samples from a TSDB'
          'dump-openmetrics:Dump samples as OpenMetrics'
          'create-blocks-from:Create TSDB blocks from input'
        )
        _arguments -C \
          '--out=[output directory]:dir:_files -/' \
          '--metrics=[metrics names regex]:regex' \
          '--scrapes=[number of scrapes]:n' \
          '--limit=[sample limit]:n' \
          '--extended[extended output]' \
          '*--match=[label matcher]:matcher' \
          '--min-time=[minimum sample time]:time' \
          '--max-time=[maximum sample time]:time' \
          '--sandbox-dir-root=[sandbox dir root]:dir:_files -/' \
          '--format=[output format]:fmt:' \
          '1:tsdb subcommand:->tsdb_sub'
        case $state in
          tsdb_sub)
            _describe -t tsdb_cmds 'tsdb subcommand' tsdb_cmds
            ;;
        esac
        ;;
      *)
        _arguments '*:arguments'
        ;;
    esac
    ;;
esac

return ret
