#compdef mapFields
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/preProcessing/mapFields — map fields between source and target meshes (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-sourceTime+[source time to map from]:time:_default' \
    '-sourceRegion+[source region]:word:_default' \
    '-targetRegion+[target region]:word:_default' \
    '-parallelSource[treat source case as parallel]' \
    '-parallelTarget[treat target case as parallel]' \
    '-consistent[source and target have matching boundary patches]' \
    '-mapMethod+[mapping method]:word:(direct mapNearest cellVolumeWeight)' \
    '1:source case directory:_files -/' \
    && ret=0

return ret
