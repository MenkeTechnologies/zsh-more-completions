#compdef ndk-build
# _ndk-build — Android NDK ndk-build wrapper script (Google AOSP, GNU Make); make targets via Android.mk
# upstream: https://android.googlesource.com/platform/ndk/

_ndk-build() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-B[force rebuild]' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[parallel jobs]:n:' \
        '-C+[change dir]:dir:_files -/' \
        '--directory=+[change dir]:dir:_files -/' \
        '-k[keep going]' \
        '--keep-going[keep going]' \
        '-n[dry run]' \
        '--dry-run[dry run]' \
        '-s[silent]' \
        '--silent[silent]' \
        'NDK_DEBUG=+[debug build]:n:(0 1)' \
        'NDK_PROJECT_PATH=+[project path]:dir:_files -/' \
        'APP_BUILD_SCRIPT=+[Android.mk path]:file:_files -g "Android.mk *.mk"' \
        'NDK_APPLICATION_MK=+[Application.mk path]:file:_files -g "Application.mk *.mk"' \
        'APP_ABI=+[ABIs]:abi:(armeabi-v7a arm64-v8a x86 x86_64 all)' \
        'APP_PLATFORM=+[min platform]:str:' \
        'APP_STL=+[STL]:stl:(c++_shared c++_static none system)' \
        'APP_CFLAGS=+[CFLAGS]:str:' \
        'APP_CPPFLAGS=+[CPPFLAGS]:str:' \
        'APP_LDFLAGS=+[LDFLAGS]:str:' \
        'V=+[verbose]:n:(0 1)' \
        '*:target:'
}

_ndk-build "$@"
