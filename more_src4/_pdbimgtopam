#compdef pdbimgtopam
# Documentation: man pdbimgtopam (Netpbm)
# Source: convert a Palm OS PDB image to PAM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-notefile=[write metadata notes to file]:file:_files' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pdb image file:_files -g "*.(pdb|prc)"' \
    && ret=0

return ret
