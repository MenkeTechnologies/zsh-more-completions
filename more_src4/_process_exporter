#compdef process-exporter
# Documentation: https://github.com/ncabatoff/process-exporter
# Reference accessed: 2026-05-29

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'-help'[show help]' \
  '-config.path=[path to config file]:file:_files' \
  '-procfs=[path to procfs mount point]:path:_directories' \
  '-children[include child process metrics]' \
  '-threads[include thread metrics]' \
  '-gather-smaps[gather smaps metrics]' \
  '-recheck[recheck process names on each scrape]' \
  '-debug[enable debug logging]' \
  '-namemapping=[mapping of process names]:mapping:' \
  '-web.listen-address=[address to listen on]:address:' \
  '-web.telemetry-path=[path for metrics]:path:' && ret=0

return ret
