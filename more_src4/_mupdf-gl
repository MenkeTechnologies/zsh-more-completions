#compdef mupdf-gl mupdf-x11 mupdf-x11-curl
# Documentation: https://manpages.debian.org/testing/mupdf/mupdf-gl.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-p+[password to open password-protected PDF]:pw:' \
  '-c+[ICC color profile for display]:file:_files' \
  '-r+[initial zoom level in DPI]:dpi:' \
  '-A+[anti-aliasing level]:level:(0 2 4 8 9 10)' \
  '-W+[EPUB page width in points]:px:' \
  '-H+[EPUB page height in points]:px:' \
  '-S+[EPUB default font size in points]:px:' \
  '-U+[CSS file for EPUB user styles]:file:_files -g "*.css"' \
  '-X[ignore publisher styles for EPUB]' \
  '-J[disable JavaScript in PDF forms]' \
  '-I[start in inverted color mode]' \
  '-B+[black tint color]:hex:' \
  '-C+[white tint color]:hex:' \
  '-Y+[UI scaling factor]:factor:' \
  '*:file:_files -g "*.{pdf,epub,xps,oxps,fb2,cbz,jpg,jpeg,png,svg,tif,tiff}"' && ret=0

return ret
