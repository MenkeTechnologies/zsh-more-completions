#compdef marked-cli
# Documentation: https://github.com/markedjs/marked/blob/master/bin/main.js
# Reference accessed: 2026-05-19
# Verified: markedjs/marked bin/main.js argument switch. Some distros
# alias the markedjs `marked` binary as `marked-cli`; this file targets
# that name. The standalone `marked` binary has its own _marked file.
# A1rPun/marked-cli (npm) documents no CLI flag surface.
# Removed from prior file: duplicate `marked` compdef (now in _marked);
# real short for --no-clobber is -n per upstream main.js parser.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-s --string)'{-s,--string}'+[markdown string]:str:' \
  '(-i --input)'{-i,--input}'+[input file]:file:_files -g "*.{md,markdown}"' \
  '(-o --output)'{-o,--output}'+[output file]:file:_files' \
  '(-t --tokens)'{-t,--tokens}'[output tokens]' \
  '(-c --config)'{-c,--config}'+[config file]:file:_files' \
  '--breaks[gfm linebreaks]' \
  '--no-breaks[disable linebreaks]' \
  '--gfm[gfm extensions]' \
  '--no-gfm[disable gfm]' \
  '--pedantic[pedantic mode]' \
  '--no-pedantic[disable pedantic]' \
  '--silent[silent mode]' \
  '--smartypants[smart punctuation]' \
  '--no-smartypants[disable smartypants]' \
  '--no-clobber[do not overwrite]' \
  '*:markdown:_files -g "*.{md,markdown}"' && ret=0

return ret
