#compdef polyDualMesh
# Documentation: https://cfd.direct/openfoam/user-guide/
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/polyDualMesh — create dual polyhedral mesh (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[OpenFOAM case directory]:dir:_files -/' \
    '-fileHandler+[file handler]:handler:(uncollated collated masterUncollated)' \
    '-parallel[run in parallel]' \
    '-noFunctionObjects[disable function objects]' \
    '-overwrite[overwrite existing mesh]' \
    '-splitAllFaces[split all faces irrespective of edge length]' \
    '-concaveMultiCells[allow concave multi-cell decomposition]' \
    '-doNotPreserveFaceZones[do not preserve faceZones]' \
    '-region+[region name]:region:_default' \
    '1:feature angle (0-180):_default' \
    && ret=0

return ret
