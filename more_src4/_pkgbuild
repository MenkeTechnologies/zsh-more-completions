#compdef pkgbuild
# Documentation: https://keith.github.io/xcode-man-pages/pkgbuild.1.html
# Reference accessed: 2026-05-20
# Verified: upstream macOS pkgbuild(1) man page.

local -a arguments

arguments=(
    '--root[root directory of payload]:root directory:_directories'
    '*--component[bundle to add to package]:component path:_files'
    '--component-plist[component property list]:plist:_files -g "*.plist"'
    '--install-location[default install location]:install path:_directories'
    '--scripts[scripts directory]:scripts directory:_directories'
    '--nopayload[create scripts-only package]'
    '--identifier[package identifier]:identifier'
    '--version[package version]:version'
    '--ownership[ownership behavior]:behavior:(recommended preserve preserve-other)'
    '--sign[sign with identity]:identity'
    '--keychain[keychain for signing identity]:keychain:_files'
    '--cert[intermediate certificate to embed]:certificate'
    '--timestamp[include trusted timestamp]'
    '--timestamp=-[trusted timestamp control (use =none to disable)]:opt:(none)'
    '*--filter[exclude files matching extended regex]:filter pattern'
    '--compression[compression mode]:mode:(legacy latest)'
    '--min-os-version[minimum macOS version]:version'
    '--large-payload[allow files \>=8 GiB (requires macOS 12+)]'
    '--info[package info file (deprecated)]:info file:_files'
    '--analyze[analyze root, output component plist]'
    '--prior[copy id/version/install-location from prior package]:prior pkg:_files -g "*.pkg"'
    '--quiet[suppress non-error output]'
    '*:output package:_files -g "*.pkg"'
)

_arguments -s -S $arguments
