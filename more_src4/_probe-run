#compdef probe-run
# Documentation: https://github.com/knurling-rs/probe-run/blob/main/src/cli.rs
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '--backtrace=[backtrace mode]:mode:(auto always never)' \
  '--backtrace-limit=[number of lines before backtrace gets cut off]:n' \
  '--chip=[the chip to program]:chip' \
  '--chip-description-path=[path to chip description YAML file]:file:_files -g "*.(yaml|yml)"' \
  '--connect-under-reset[connect to device when NRST is pressed]' \
  '--disable-double-buffering[disable double-buffering while downloading flash]' \
  '--erase-all[mass-erase all nonvolatile memory before flash]' \
  '--json[output logs as structured json]' \
  '--list-chips[list supported chips and exit]' \
  '--list-probes[list connected probes and exit]' \
  '--log-format=[log output format]:format' \
  '--host-log-format=[host log output format]:format' \
  '--measure-stack[measure the program stack consumption]' \
  '--no-flash[skip writing the application binary to flash]' \
  '--probe=[probe selector (VID:PID[:SERIAL] or Serial)]:probe' \
  '--shorten-paths[shorten paths in backtraces and logs]' \
  '--speed=[probe clock frequency in kHz]:speed' \
  '*'{-v,--verbose}'[enable more verbose output]' \
  '--verify[verify the written program]' \
  '(- *)'{-V,--version}'[print version information]' \
  '(- *)--help[show help]' \
  '1:elf:_files' \
  '*::argv'
