#compdef ppmmix
# Documentation: man ppmmix (Netpbm)
# Source: blend two PPM images by a fade factor.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:fade factor (0.0..1.0):' \
    '2:ppm file 1:_files -g "*.(ppm|pnm|pam)"' \
    '3:ppm file 2:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
