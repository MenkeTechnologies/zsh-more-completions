#compdef mount
# _mount-bin — util-linux mount filesystem; canonical Linux mount command
# upstream: https://github.com/util-linux/util-linux

_mount-bin() {
    _arguments \
        '(-a --all)'{-a,--all}'[mount all in fstab]' \
        '(-B --bind)'{-B,--bind}'[bind mount]' \
        '(-c --no-canonicalize)'{-c,--no-canonicalize}'[do not canonicalize paths]' \
        '(-F --fork)'{-F,--fork}'[fork off for each device]' \
        '(-f --fake)'{-f,--fake}'[dry run]' \
        '(-i --internal-only)'{-i,--internal-only}'[no /sbin/mount.<type>]' \
        '(-L --label)'{-L,--label}'+[label]:label:' \
        '(-l --show-labels)'{-l,--show-labels}'[show labels]' \
        '(-M --move)'{-M,--move}'[move tree]' \
        '(-n --no-mtab)'{-n,--no-mtab}'[do not write /etc/mtab]' \
        '(-O --test-opts)'{-O,--test-opts}'+[restrict by options]:opts:' \
        '(-o --options)'{-o,--options}'+[mount options]:opts:' \
        '(-R --rbind)'{-R,--rbind}'[recursive bind]' \
        '(-r --read-only)'{-r,--read-only}'[read only]' \
        '(-s --sloppy)'{-s,--sloppy}'[allow ignored options]' \
        '(-T --fstab)'{-T,--fstab}'+[alternate fstab]:file:_files' \
        '(-t --types)'{-t,--types}'+[fs type]:type:(ext4 ext3 ext2 btrfs xfs vfat exfat ntfs ntfs-3g nfs nfs4 cifs tmpfs proc sysfs squashfs)' \
        '(-U --uuid)'{-U,--uuid}'+[uuid]:uuid:' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-v --verbose)'{-v,--verbose}'[verbose]' \
        '(-w --rw)'{-w,--rw}'[read-write]' \
        '(-h --help)'{-h,--help}'[show help]' \
        '--make-shared[make shared]' \
        '--make-private[make private]' \
        '--make-slave[make slave]' \
        '--make-unbindable[make unbindable]' \
        '--make-rshared[recursively make shared]' \
        '--make-rprivate[recursively make private]' \
        '--make-rslave[recursively make slave]' \
        '--make-runbindable[recursively make unbindable]' \
        '--source+[source]:source:' \
        '--target+[target]:dir:_files -/' \
        '--bind-device[bind mount with device meta]' \
        '*:device or dir:_files'
}

_mount-bin "$@"
