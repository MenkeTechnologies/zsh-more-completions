#compdef otbcli_Mosaic
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_Mosaic.html
# Source: orfeotoolbox/OTB Mosaic — feather + radiometric-harmonize multiple images into one mosaic.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-il+[input images to mosaic]:images:_files' \
    '-out+[output mosaic image]:image:_files' \
    '-vdcut+[vector cut files (per-image footprints)]:vectors:_files' \
    '-vdstats+[vector files for harmonization statistics]:vectors:_files' \
    '-comp.feather+[feathering method]:method:(none large slim)' \
    '-comp.feather.slim.exponent+[slim transition smoothness (default 1)]:value:_default' \
    '-comp.feather.slim.length+[slim transition length (map units)]:value:_default' \
    '-harmo.method+[harmonization]:method:(none band rgb)' \
    '-harmo.cost+[harmonization cost function]:cost:(rmse musig mu)' \
    '-output.spacingx+[output X pixel size]:value:_default' \
    '-output.spacingy+[output Y pixel size]:value:_default' \
    '-interpolator+[interpolation]:method:(nn bco linear)' \
    '-interpolator.bco.radius+[bicubic filter size (default 2)]:n:_default' \
    '-tmpdir+[temporary file directory]:dir:_directories' \
    '-distancemap.sr+[distance map sampling ratio (default 10)]:n:_default' \
    '-nodata+[no-data value (default 0)]:value:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
