#compdef nvidia-xconfig
# Documentation: https://manpages.debian.org/testing/nvidia-xconfig/nvidia-xconfig.1.en.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-o --output-xconfig)'{-o,--output-xconfig}'+[output xorg.conf]:file:_files' \
  '(-d --xconfig)'{-d,--xconfig}'+[input xorg.conf]:file:_files' \
  '(-s --silent)'{-s,--silent}'[silent]' \
  '(-V --verbose)'{-V,--verbose}'[verbose]' \
  '(-t --tree)'{-t,--tree}'[print xconfig as tree]' \
  '(-Z --post-tree)'{-Z,--post-tree}'[print modified xconfig as tree]' \
  '--keyboard-list[list available keyboard layouts]' \
  '--mouse-list[list available mouse types]' \
  '--keyboard=[keyboard model]:model:' \
  '--mouse=[mouse type]:type:' \
  '--enable-all-gpus[enable all GPUs]' \
  '--separate-x-screens[separate X screen per GPU]' \
  '--composite[enable composite]' \
  '--no-composite[disable composite]' \
  '--cool-bits=[cool bits]:bits:' \
  '--allow-empty-initial-configuration[allow empty initial config]' \
  '--no-logo[disable NVIDIA logo]' \
  '--render-accel[enable rendering acceleration]' \
  '--use-display-device=[display device]:device:' \
  '--metamodes=[metamodes]:metamodes:' \
  '--sli=[SLI mode]:mode:(Off Auto AFR SFR AA AFRofSFR Mosaic)' \
  '--multigpu=[multi-GPU mode]:mode:(Off AFR SFR AA)' \
  '--virtual=[virtual screen WxH]:WxH:' \
  '--mode=[X mode]:mode:' \
  '--screen=[screen index]:n:' && ret=0

return ret
