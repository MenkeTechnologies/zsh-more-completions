#compdef oggz-chop oggz-codecs oggz-comment oggz-diff oggz-dump oggz-info oggz-merge oggz-rip oggz-scan oggz-sort oggz-validate
# Documentation: upstream src/tools/oggz-*.c at xiph.org liboggz
# Reference accessed: 2026-05-30 via gh api inspection of evpobr/oggz
# mirror's struct option long_options[] tables.
# Xiph liboggz R70 — 11-stem multi-binary harvest covering the entire
# oggz-* sister-binary family from the liboggz toolkit. Common
# helpers: every binary supports -h/--help and -v/--version. .ogg files
# accepted as positional arguments.

local curcontext="$curcontext" state line ret=1

case $service in

  oggz-chop)
    # Extract part of an Ogg file between given start and/or end times.
    _arguments -s -S \
      '(-s --start)'{-s,--start}'=[start time]:time (HH\:MM\:SS.s):' \
      '(-e --end)'{-e,--end}'=[end time]:time (HH\:MM\:SS.s):' \
      '(-o --output)'{-o,--output}'=[output filename]:file:_files' \
      '(-k --no-skeleton)'{-k,--no-skeleton}'[do not output a Skeleton bitstream]' \
      '(-n --dry-run)'{-n,--dry-run}'[run without writing output]' \
      '(-V --verbose)'{-V,--verbose}'[verbose output]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-codecs)
    # Report codecs found in Ogg files.
    _arguments -s -S \
      '(-a --all)'{-a,--all}'[show codec for all logical bitstreams]' \
      '(-m --mime)'{-m,--mime}'[output MIME type for the file]' \
      '(-1 --one-line)'{-1,--one-line}'[output one line per file]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-comment)
    # Manage Vorbis-style metadata comments in Ogg files.
    _arguments -s -S \
      '(-l --list)'{-l,--list}'[list comments]' \
      '(-d --delete)'{-d,--delete}'[delete the named comments]' \
      '(-a --all)'{-a,--all}'[apply to all logical bitstreams]' \
      '(-o --output)'{-o,--output}'=[output filename (rewrite mode)]:file:_files' \
      '(-c --content-type)'{-c,--content-type}'=[limit to comments matching content-type]:content-type:' \
      '(-s --serialno)'{-s,--serialno}'=[limit to a specific logical bitstream]:serialno:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file/key=value:_files' && ret=0
    ;;

  oggz-diff)
    # Hex-diff of two Ogg files via oggz-dump pipeline.
    _arguments -s -S \
      '--verbose[verbose output]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '(-b --binary)'{-b,--binary}'[dump packets as binary]' \
      '(-x --hexadecimal)'{-x,--hexadecimal}'[dump packets as hexadecimal]' \
      '(-O --hide-offset)'{-O,--hide-offset}'[hide offset column]' \
      '(-S --hide-serialno)'{-S,--hide-serialno}'[hide serialno column]' \
      '(-G --hide-granulepos)'{-G,--hide-granulepos}'[hide granulepos column]' \
      '(-P --hide-packetno)'{-P,--hide-packetno}'[hide packetno column]' \
      '(-s --serialno)'{-s,--serialno}'=[limit to a specific logical bitstream]:serialno:' \
      '(-c --content-type)'{-c,--content-type}'=[limit to comments matching content-type]:content-type:' \
      ':first ogg file:_files -g "*.ogg"' \
      ':second ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-dump)
    # Hex-dump Ogg file packets, or reconstruct an Ogg file from a dump.
    _arguments -s -S \
      '(-b --binary)'{-b,--binary}'[dump packets as binary]' \
      '(-x --hexadecimal)'{-x,--hexadecimal}'[dump packets as hexadecimal]' \
      '(-n --new)'{-n,--new}'[generate new Ogg file from a dump]' \
      '(-r --revert)'{-r,--revert}'[revert a dump to its original Ogg file]' \
      '(-o --output)'{-o,--output}'=[output filename]:file:_files' \
      '(-s --serialno)'{-s,--serialno}'=[limit to a specific logical bitstream]:serialno:' \
      '(-c --content-type)'{-c,--content-type}'=[limit to bitstreams matching content-type]:content-type:' \
      '(-O --hide-offset)'{-O,--hide-offset}'[hide offset column]' \
      '(-S --hide-serialno)'{-S,--hide-serialno}'[hide serialno column]' \
      '(-G --hide-granulepos)'{-G,--hide-granulepos}'[hide granulepos column]' \
      '(-P --hide-packetno)'{-P,--hide-packetno}'[hide packetno column]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file or dump:_files' && ret=0
    ;;

  oggz-info)
    # Show Ogg file info / bitstream statistics.
    _arguments -s -S \
      '(-l --length)'{-l,--length}'[show playback length]' \
      '(-b --bitrate)'{-b,--bitrate}'[show overall bitrate]' \
      '(-g --page-stats)'{-g,--page-stats}'[show page-level statistics]' \
      '(-p --packet-stats)'{-p,--packet-stats}'[show packet-level statistics]' \
      '(-k --skeleton)'{-k,--skeleton}'[show skeleton-track information]' \
      '(-a --all)'{-a,--all}'[show all available information]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-merge)
    # Merge multiple Ogg files into one with interleaved pages.
    _arguments -s -S \
      '(-o --output)'{-o,--output}'=[output filename (default stdout)]:file:_files' \
      '(-V --verbose)'{-V,--verbose}'[verbose output]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-rip)
    # Extract individual logical bitstreams from an Ogg file.
    _arguments -s -S \
      '(-o --output)'{-o,--output}'=[output filename]:file:_files' \
      '(-V --verbose)'{-V,--verbose}'[verbose output]' \
      '(-s --serialno)'{-s,--serialno}'=[serialno of the bitstream to extract]:serialno:' \
      '(-i --stream-index)'{-i,--stream-index}'=[stream index to extract]:index:' \
      '(-c --content-type)'{-c,--content-type}'=[content-type of the bitstream to extract]:content-type:' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-scan)
    # Identify structural landmarks in an Ogg file.
    _arguments -s -S \
      '(-o --output)'{-o,--output}'=[output filename]:file:_files' \
      '(-f --format)'{-f,--format}'=[output format]:format:(srt yaml plain)' \
      '(-k --keyframe)'{-k,--keyframe}'[output keyframe-only landmarks]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-sort)
    # Sort an Ogg file (pages chronologically by presentation time).
    _arguments -s -S \
      '(-o --output)'{-o,--output}'=[output filename (default stdout)]:file:_files' \
      '(-V --verbose)'{-V,--verbose}'[verbose output]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

  oggz-validate)
    # Check the integrity of Ogg framing in a file.
    _arguments -s -S \
      '(-M --max-errors)'{-M,--max-errors}'=[stop after N errors]:N:' \
      '(-p --prefix)'{-p,--prefix}'[interpret input file as a prefix of a stream]' \
      '(-s --suffix)'{-s,--suffix}'[interpret input file as a suffix of a stream]' \
      '(-P --partial)'{-P,--partial}'[do not report errors at start/end of file]' \
      '(-E --help-errors)'{-E,--help-errors}'[show help for all error codes]' \
      '(- *)'{-h,--help}'[show help]' \
      '(- *)'{-v,--version}'[show version]' \
      '*:ogg file:_files -g "*.ogg"' && ret=0
    ;;

esac

return ret
