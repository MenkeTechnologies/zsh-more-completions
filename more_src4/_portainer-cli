#compdef portainer-cli
# _portainer-cli — Portainer container management UI CLI alias (portainer team, Python/Go); custom argparse
# upstream: https://github.com/portainer/portainer

_portainer-cli() {
    local -a sub=(
        'configure:configure connection'
        'login:login to portainer'
        'logout:logout'
        'endpoint:list:list endpoints'
        'endpoint:create:create endpoint'
        'endpoint:update:update endpoint'
        'endpoint:delete:delete endpoint'
        'endpoint:inspect:inspect endpoint'
        'stack:list:list stacks'
        'stack:create:create stack'
        'stack:get:get stack'
        'stack:update:update stack'
        'stack:remove:remove stack'
        'stack:start:start stack'
        'stack:stop:stop stack'
        'stack:file:get compose file'
        'team:list:list teams'
        'team:create:create team'
        'team:delete:delete team'
        'team:membership:list:list members'
        'team:membership:add:add member'
        'team:membership:remove:remove member'
        'user:list:list users'
        'user:create:create user'
        'user:delete:delete user'
        'user:update:update user'
        'registry:list:list registries'
        'registry:create:create registry'
        'registry:delete:delete registry'
        'tag:list:list tags'
        'tag:create:create tag'
        'tag:delete:delete tag'
        'edgejob:list:list edge jobs'
        'edgejob:create:create edge job'
        'edgejob:delete:delete edge job'
        'edgegroup:list:list edge groups'
        'edgegroup:create:create edge group'
        'edgestack:list:list edge stacks'
        'edgestack:create:create edge stack'
        'edgestack:delete:delete edge stack'
        'status:show status'
        'settings:get:get settings'
        'settings:update:update settings'
        'webhook:list:list webhooks'
        'webhook:create:create webhook'
        'webhook:delete:delete webhook'
        'webhook:execute:execute webhook'
        'completion:generate completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--url=+[portainer url]:url:_urls' \
        '--user=+[username]:user:_users' \
        '--password=+[password]:str:' \
        '--api-key=+[api key]:str:' \
        '--config=+[config file]:file:_files' \
        '--json[json output]' \
        '--insecure[skip tls verification]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'portainer subcommand' sub ;;
        args)
            case $words[1] in
                stack:create) _arguments \
                    '--name=+[name]:str:' \
                    '--endpoint-id=+[endpoint id]:n:' \
                    '--swarm-id=+[swarm id]:str:' \
                    '--type=+[type]:t:(swarm compose kubernetes)' \
                    '--file=+[compose file]:file:_files -g "*.{yml,yaml}"' \
                    '--repo-url=+[git repo]:url:_urls' \
                    '--repo-ref=+[git ref]:str:' \
                    '--env=+[env vars]:str:' ;;
                endpoint:create) _arguments \
                    '--name=+[name]:str:' \
                    '--url=+[endpoint url]:url:_urls' \
                    '--type=+[type]:t:(docker agent edge kubernetes azure)' \
                    '--tls-skip-verify[skip tls]' \
                    '--tls-cacert=+[ca cert]:file:_files' \
                    '--tls-cert=+[cert]:file:_files' \
                    '--tls-key=+[key]:file:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_portainer-cli "$@"
