#compdef pw-dot
# Documentation: https://docs.pipewire.org/page_man_pw-dot_1.html
# Source: PipeWire — emit Graphviz .dot of the current node/port/link graph.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --remote)'{-r+,--remote=}'[remote instance name]:name:' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-a --all)'{-a,--all}'[show all object types]' \
    '(-s --smart)'{-s,--smart}'[show linked objects only]' \
    '(-d --detail)'{-d,--detail}'[show all object properties]' \
    '(-o --output)'{-o+,--output=}'[output file (default pw.dot, - for stdout)]:file:_files' \
    '(-L --lr)'{-L,--lr}'[lay graph left-to-right (vs default top-to-bottom)]' \
    '(-9 --90)'{-9,--90}'[lay graph using 90-degree edges]' \
    && ret=0

return ret
