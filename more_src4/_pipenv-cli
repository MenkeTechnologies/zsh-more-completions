#compdef pipenv-cli
# _pipenv-cli — pipenv Python virtualenv + dependency manager CLI alias (PyPA, Python); click
# upstream: https://github.com/pypa/pipenv

_pipenv-cli() {
    local -a sub=(
        'check:run safety security check'
        'clean:remove packages not in lockfile'
        'graph:show dependency graph'
        'install:install packages'
        'lock:update lockfile'
        'open:open a package in editor'
        'requirements:export requirements.txt'
        'run:run command in venv'
        'scripts:show defined scripts'
        'shell:spawn venv shell'
        'sync:sync from lockfile'
        'uninstall:uninstall packages'
        'update:update packages'
        'verify:verify hash of Pipfile.lock'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--where[show working dir]' \
        '--venv[show venv]' \
        '--py[show python interpreter]' \
        '--envs[show env vars]' \
        '--rm[remove venv]' \
        '--bare[bare output]' \
        '--man[show man page]' \
        '--support[show support info]' \
        '--site-packages[give access to site packages]' \
        '--python=+[python version]:str:' \
        '--three[use python3]' \
        '--two[use python2]' \
        '--clear[clear cache]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--pypi-mirror=+[pypi mirror]:url:_urls' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pipenv subcommand' sub ;;
        args)
            case $words[1] in
                install) _arguments \
                    '--dev[dev dep]' \
                    '-d[dev dep]' \
                    '--system[system install]' \
                    '--ignore-pipfile[ignore Pipfile]' \
                    '--skip-lock[skip lock]' \
                    '--deploy[deploy]' \
                    '--keep-outdated[keep outdated]' \
                    '--selective-upgrade[selective upgrade]' \
                    '--pre[prerelease]' \
                    '--editable[editable]' \
                    '-e[editable]' \
                    '--code=+[code]:str:' \
                    '--extra-index-url=+[extra index url]:url:_urls' \
                    '--requirements=+[requirements file]:file:_files' \
                    '-r+[requirements file]:file:_files' \
                    '--categories=+[categories]:list:' \
                    '*:package:' ;;
                uninstall) _arguments \
                    '--all[uninstall all]' \
                    '--all-dev[uninstall all dev]' \
                    '--skip-lock[skip lock]' \
                    '*:package:' ;;
                run) _arguments '*:cmd:_command_names -e' ;;
                shell) _arguments \
                    '--fancy[fancy shell]' \
                    '--anyway[force shell]' ;;
                lock) _arguments \
                    '--dev[include dev]' \
                    '-d[include dev]' \
                    '--clear[clear cache]' \
                    '--pre[prerelease]' \
                    '--categories=+[categories]:list:' ;;
                graph) _arguments \
                    '--bare[bare]' \
                    '--json[json]' \
                    '--json-tree[json tree]' \
                    '--reverse[reverse]' ;;
                requirements) _arguments \
                    '--dev[include dev]' \
                    '--dev-only[only dev]' \
                    '--hash[include hashes]' \
                    '--exclude-markers[exclude markers]' \
                    '--categories=+[categories]:list:' ;;
                check) _arguments \
                    '--system[system check]' \
                    '--unused=+[unused threshold]:f:' \
                    '--db=+[security db]:str:' \
                    '--ignore=+[ignore CVE]:str:' \
                    '-i+[ignore CVE]:str:' \
                    '--output=+[output format]:fmt:(default json bare full screen text)' \
                    '--key=+[api key]:str:' ;;
                clean|sync|update|scripts|verify|open) _arguments '*:arg:' ;;
            esac
            ;;
    esac
}

_pipenv-cli "$@"
