#compdef pcap-config
# Documentation: man pcap-config (libpcap)
# Source: print cflags/libs needed to compile against libpcap.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--static[print static-link flags]' \
    '(--cflags --libs --additional-libs)--cflags[print compile flags]' \
    '(--cflags --libs --additional-libs)--libs[print link flags]' \
    '(--cflags --libs --additional-libs)--additional-libs[print additional link libraries]' \
    && ret=0

return ret
