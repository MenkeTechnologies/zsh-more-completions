#compdef nova-cli
# _nova-cli — David Hemphill Laravel Nova admin panel CLI alias (laravel team, PHP); artisan-based
# upstream: https://nova.laravel.com

_nova-cli() {
    local -a sub=(
        'nova:install:install nova'
        'nova:user:create nova user'
        'nova:publish:publish nova assets'
        'nova:action:scaffold action'
        'nova:base-resource:scaffold base resource'
        'nova:dashboard:scaffold dashboard'
        'nova:field:scaffold field'
        'nova:filter:scaffold filter'
        'nova:lens:scaffold lens'
        'nova:partition:scaffold partition metric'
        'nova:progress:scaffold progress metric'
        'nova:resource:scaffold resource'
        'nova:resource-tool:scaffold resource tool'
        'nova:table:scaffold table metric'
        'nova:tool:scaffold tool'
        'nova:trend:scaffold trend metric'
        'nova:value:scaffold value metric'
        'nova:repeater:scaffold repeater'
        'nova:translate:translate file'
        'nova:check-license:check license'
        'nova:check-translations:check translations'
        'nova:check-mfa-secret:check mfa secret'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nova subcommand' sub ;;
        args)
            case $words[1] in
                nova:install) _arguments \
                    '--composer=+[composer path]:file:_files' ;;
                nova:resource|nova:action|nova:dashboard|nova:filter|nova:lens|nova:tool) _arguments \
                    '1:name:' \
                    '--force[force overwrite]' \
                    '--model=+[model]:str:' ;;
                nova:user) _arguments \
                    '1:email:' \
                    '2:name:' \
                    '3:password:' ;;
                nova:publish) _arguments \
                    '--force[force overwrite]' ;;
            esac
            ;;
    esac
}

_nova-cli "$@"
