#compdef pto_merge
# Documentation: https://wiki.panotools.org/Pto_merge
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pto_merge: merge multiple Hugin .pto project files
local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-o --output)'{-o+,--output=}'[output pto filename]:file:_files -g "*.pto"' \
  '*:pto_files:_files -g "*.pto"' && ret=0

return ret
