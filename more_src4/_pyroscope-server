#compdef pyroscope-server
# Documentation: https://grafana.com/docs/pyroscope/latest/configure-server/reference-configuration-parameters/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pyroscope-server: profile aggregation HTTP server
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-c[config file]:file:_files' \
  '--config=[config file]:file:_files' \
  '--storage-path=[storage path]:dir:_files -/' \
  '--api-bind-addr=[API bind addr]:addr:' \
  '--analytics-opt-out[opt out of analytics]' \
  '--cache-evict-threshold=[cache evict threshold]:percent:' \
  '--cache-evict-volume=[cache evict volume]:percent:' \
  '--storage-bucket=[s3 bucket]:bucket:' \
  '--admin-socket-path=[admin socket]:file:_files' \
  '--log-level=[log level]:level:(error warn info debug trace)' \
  '--retention=[retention]:duration:' \
  '--max-nodes-render=[max nodes on flame graph]:n:' \
  '--max-nodes-serialization=[max nodes serialized]:n:' \
  '*::pyroscope-server args:_files' && ret=0
return ret
