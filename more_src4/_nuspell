#compdef nuspell
# Documentation: https://github.com/nuspell/nuspell/blob/master/docs/nuspell.1.md
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d+[use dictionary]:dictionary' \
  '-D[list search paths for dictionaries]' \
  '-l[print only misspelled words]' \
  '-G[accept words also from personal dictionary]' \
  '-s[print suggestions for misspelled words]' \
  '-S[use stdin for input]' \
  '--encoding=[set both input and output encoding]:encoding:' \
  '--input-encoding=[set input encoding]:encoding:' \
  '--output-encoding=[set output encoding]:encoding:' \
  '*:file:_files' && ret=0

return ret
