#compdef ncc-cli
# _ncc-cli — Vercel ncc Node.js single-file bundler CLI alias (vercel team, TypeScript); custom argparse
# upstream: https://github.com/vercel/ncc

_ncc-cli() {
    local -a sub=(
        'build:bundle a file with all dependencies'
        'run:build and execute file'
        'cache:cache commands'
        'cache clean:clean cache'
        'cache dir:print cache dir'
        'cache size:print cache size'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ncc subcommand' sub ;;
        args)
            case $words[1] in
                build|run) _arguments \
                    '1:input file:_files' \
                    '--out=+[dir]:dir:_files -/' \
                    '-o+[dir]:dir:_files -/' \
                    '--external=+[mod csv]:str:' \
                    '-e+[mod csv]:str:' \
                    '--source-map[generate source map]' \
                    '-s[generate source map]' \
                    '--source-map-register=+[bool]:b:(true false)' \
                    '--asset-builds[handle asset references]' \
                    '--license=+[file]:file:_files' \
                    '--no-cache[disable cache]' \
                    '-C[disable cache]' \
                    '--cache-dir=+[dir]:dir:_files -/' \
                    '--no-source-map-register[disable source map register]' \
                    '--quiet[quiet]' \
                    '-q[quiet]' \
                    '--target=+[target]:t:(es5 es2015 es2016 es2017 es2018 es2019 es2020 esnext)' \
                    '-t+[target]:t:(es5 es2015 es2016 es2017 es2018 es2019 es2020 esnext)' \
                    '--watch[watch]' \
                    '-w[watch]' \
                    '--debug[debug]' \
                    '-d[debug]' \
                    '--v8-cache[v8 code cache]' \
                    '-m[minify]' \
                    '--minify[minify]' \
                    '--transpile-only[transpile only]' ;;
            esac
            ;;
    esac
}

_ncc-cli "$@"
