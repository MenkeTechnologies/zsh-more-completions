#compdef pdfsig
# Documentation: https://manpages.debian.org/pdfsig.1
# Source: poppler-utils — inspect / create digital signatures on PDFs.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-nssdir[NSS certificate+key DB directory]:dir:_files' \
    '-nss-pwd[NSS database password]:password:' \
    '-nocert[do not validate the certificate]' \
    '-no-ocsp[do not do online OCSP check]' \
    '-no-appearance[no signer name/date appearance]' \
    '-aia[fetch missing certificates via AIA]' \
    '-dump[dump all signatures to cwd]' \
    '-add-signature[add a new signature]' \
    '-new-signature-field-name[name for new signature field]:name:' \
    '-sign[sign existing unsigned field]:field:' \
    '-nick[signing-certificate nickname (NSS)]:nick:' \
    '-backend[cryptographic-signature backend]:backend:(NSS GPGME)' \
    '-kpw[signing-key password]:password:' \
    '-digest[digest algorithm (default SHA256)]:algo:(SHA1 SHA256 SHA384 SHA512)' \
    '-reason[reason string for signature]:reason:' \
    '-etsi[create ETSI.CAdES.detached signature]' \
    '(- *)-list-nicks[list NSS nicknames]' \
    '(- *)-list-backends[list available backends]' \
    '(- *)-v[print version]' \
    '(- *)-h[print usage]' \
    '*:PDF file:_files -g "*.pdf"' \
    && ret=0

return ret
