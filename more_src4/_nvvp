#compdef nvvp
# Documentation: https://docs.nvidia.com/cuda/profiler-users-guide/index.html
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

# nvvp: NVIDIA Visual Profiler (deprecated; replaced by Nsight Systems)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '-data[Eclipse workspace data dir]:dir:_files -/' \
  '-vm[JRE path]:path:_files' \
  '-vmargs[JVM args]:opts:' \
  '*::nvvp args:_files' && ret=0
return ret
