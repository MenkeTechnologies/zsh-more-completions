#compdef pamfile
# Documentation: man pamfile (Netpbm)
# Source: Netpbm pamfile — describe a Netpbm (PAM or PNM) file.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-allimages[describe every image in each input file]' \
    '-comments[print PAM/PNM comments]' \
    '-count[print count of images in each input file]' \
    '-machine[machine-readable single-line output]' \
    '-size[print only width and height]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
