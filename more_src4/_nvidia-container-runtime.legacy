#compdef nvidia-container-runtime.legacy
# _nvidia-container-runtime.legacy — runc-compatible OCI runtime variant locked to legacy hook mode (uses nvidia-container-runtime-hook prestart hook, never CDI)
# upstream: https://github.com/NVIDIA/nvidia-container-toolkit
# Shares internal/runtime/runtime.go CLI surface with _nvidia-container-runtime; --version is handled locally, everything else is passed through to runc.

_nvidia-container-runtime.legacy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[print NVIDIA Container Runtime (legacy) version]' \
        '--debug[passed through to runc]' \
        '--log=[passed through to runc]:file:_files' \
        '--log-format=[passed through to runc]:fmt:(text json)' \
        '--root=[passed through to runc]:dir:_files -/' \
        '--systemd-cgroup[passed through to runc]' \
        '--rootless=[passed through to runc]:mode:(true false auto)' \
        '1: :->cmd' \
        '*::arg:->args'
}

_nvidia-container-runtime.legacy "$@"
