#compdef prog8c
# ============================================================================
# _prog8c — zsh completion for `prog8c`, the Prog8 compiler.  Prog8 is "a
#            high-level programming language targeting 6502/65c02
#            microprocessors" (Commodore 64/128/PET, Commander X16, etc.)
#            (169th programming language entry)
# ============================================================================
#
# UPSTREAM
#   Repository : https://github.com/irmen/prog8
#   Docs       : https://prog8.readthedocs.io/
#   Maintainer : Irmen de Jong
#   License    : GNU GPL 3.0 (compiler + libs;  generated code is
#                 explicitly excluded — free to use commercially)
#   Stars      : 196
#   Language   : Kotlin (compiler — Gradle build to a JVM jar)
#   Module     : prog8 (gradle group `prog8`)
#   Binary     : prog8c  (compiler/build/install/compiler-shadow/
#                          bin/prog8c — Gradle shadowJar wrapper
#                          around CompilerMain.kt)
#   Source ext : .p8
#   IR ext     : .p8ir  (used by --vm to run inside the embedded VM)
#   Last push  : 2026-06-01
#
# WHAT IT IS
#   Prog8 is "a structured programming language for the 8-bit
#   6502/6510/65c02 microprocessor from the late 1970's and
#   1980's, as used in many home computers from that era".  It is
#   a medium-to-low-level language with structured control flow,
#   typed variables, subroutines (with arg/return registers),
#   pointer arithmetic, and an extensive macro-assembler-like
#   feature set that targets the Commodore 64 / 128 / PET, the
#   Commander X16 (Cx16), and a virtual machine.  The compiler
#   emits assembler source (or skips that with `-noasm`),
#   optionally invokes the 64tass assembler, and can directly
#   spawn a target emulator after a successful build.
#
# CLI ARGUMENT GRAMMAR  (verbatim from compiler/src/prog8/
#                       CompilerMain.kt `ArgParser("prog8c",
#                       prefixStyle = JVM)` — note `prefixStyle =
#                       JVM` means every option uses a SINGLE
#                       leading dash, not a double dash)
#   prog8c [OPTIONS] <module>.p8 [<module>.p8 ...]
#
#   Mode flags (single-dash JVM style — no `--`):
#     -version                       Print version and exit
#     -check                         Quickly check program for
#                                    errors (no output produced)
#     -daemon                        Use the prog8c compilation
#                                    daemon (auto-starts it if
#                                    not running)
#     -daemon-server                 Run as the compilation
#                                    daemon (UNIX socket)
#     -watch                         Continuous compilation mode
#                                    (watch for file changes)
#     -vm                            Run a .p8ir IR source file
#                                    in the embedded VM
#     -emu                           Auto-start emulator after a
#                                    successful compilation
#     -emu2                          Same as -emu but use the
#                                    alternative emulator
#
#   Compilation target:
#     -target <NAME>                 Compilation target (required
#                                    unless using -vm)
#                                    Built-in names: c64 | c128 |
#                                                    cx16 | pet |
#                                                    virtual
#                                    Plus any custom .target
#                                    properties file path
#
#   Output / file management:
#     -out <DIR>                     Output directory
#                                    [default: . (current dir)]
#     -noasm                         Don't create assembly code
#     -nosourcelines                 Omit original Prog8 source
#                                    lines from generated asm
#     -asmlist                       Make the assembler produce
#                                    a listing file
#     -nostdlib                      Disable loading of bundled
#                                    standard library files
#     -srcdirs <PATHS>               Extra paths to search for
#                                    imported modules
#                                    (path-separator delimited)
#
#   Code generation:
#     -noopt                         Don't run optimizations
#     -expericodegen                 Use experimental codegen
#     -profiling                     Add subroutine-profiling
#                                    instrumentation (Cx16 only)
#     -breakinstr <brk|stp>          CPU instruction for
#                                    `%breakpoint`
#     -slabsgolden                   Put memory() slabs in golden
#                                    RAM ($0400-$07FF on Cx16)
#     -slabshigh <BANK>              Put slabs in high memory
#                                    (Cx16 HIRAM bank)
#     -varsgolden                    Put uninitialized vars in
#                                    golden RAM (Cx16 only)
#     -varshigh <BANK>               Put vars in high memory
#                                    (Cx16 HIRAM bank)
#
#   Assembler symbols:
#     -D <SYMBOL=VALUE>              Define assembly symbol
#                                    (repeatable)
#
#   Diagnostics / introspection:
#     -dumpsymbols                   Dump variable + subroutine
#                                    signatures
#     -dumpvars                      Dump program variables
#     -printast1                     Print the internal AST
#     -printast2                     Print the simplified AST
#                                    used for codegen
#     -timings                       Show internal compiler
#                                    timings
#     -plaintext                     Plain-text output (no colors)
#     -quiet                         Silence compiler + assembler
#                                    output (except warnings/
#                                    errors)
#     -quietasm                      Silence only assembler
#                                    messages
#     -warnshadow                    Show symbol-shadowing
#                                    warnings
#     -warnimplicitcasts             Show implicit-cast warnings
#     -ignorefootguns                Suppress "footgun" warnings
#
#   IR / VM tooling:
#     -vmtrace                       Trace VM execution
#                                    instruction-by-instruction
#                                    (with -vm or -emu)
#     -compareir <FILE>              Compare generated .p8ir with
#                                    existing .p8ir
#
#   Library introspection (skip the build):
#     -libsearch <REGEX>             Search regex in embedded
#                                    library files
#     -libdump <DIR>                 Dump every embedded library
#                                    file into <DIR>
#
#   Numeric format helpers (need -target + a dummy module file):
#     -bytes2float <CSV_BYTES>       Convert bytes to a target-
#                                    system float value
#     -float2bytes <FLOAT>           Convert a float to the
#                                    target-system byte sequence
#
#   Positional:
#     <module.p8>...                 One or more main module
#                                    files
#
# LANGUAGE-CORPUS POSITION
#   Prog8 is the 169th programming language entry in this
#   completion corpus, completing the 3+1 micro-cycle that began
#   at R945 (_iam-policy-autopilot / AWS Labs Rust=144 OPENS Axis
#   89 AWS SDK / aws-sdk-rust) and continued through R946
#   (_acra-server / Cossack Labs Go=144) and R947 (_cloudypad /
#   PierreBeucher TS-Node=144 CLOSES Axis 89 at 1/1/1 three-
#   language symmetry — triple-144 landmark and 82nd axis
#   closed).  Prog8 joins Objeck (R944 168th), Feral (R940 167th
#   — R940 round-number commit landmark), Biscuit/BL (R936
#   166th), Rux (R932 165th), Jule (R928 164th), Nevalang (R924
#   163rd), Corvid (R920 162nd — round-number R920 commit
#   landmark), Soppo (R916 161st), Cyrus (R912 160th — round-
#   number language milestone), Lumina (R908 159th), Penne
#   (R904 158th), EndBASIC (R900 157th — R900 TRIPLE-9 commit
#   landmark), goboscript (R896 156th), Alan (R892 155th), Mech
#   (R888 154th — triple-8 landmark), Lisette (R884 153rd),
#   Bril (R880 152nd), Vyxal (R876 151st), EYG (R872 150th —
#   round-number language milestone), Roto (R868 149th),
#   Pipefish (R864 148th), Mochi (R860 147th), Oden (R856
#   146th), Hop (R852 145th), Lustre via Kind 2 (R848 144th),
#   Ravi (R844 143rd), ZetZ (R840 142nd), Granule (R836 141st),
#   Sixten (R832 140th), Imba (R828 139th), Tao (R824 138th),
#   Dada (R820 137th), Acton (R816 136th), and Stanza (R812
#   135th).
#
#   No completion for `prog8c` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_prog8c() {
    _arguments -s \
        '-version[print compiler version and exit]' \
        '-check[quick error check without producing output]' \
        '-daemon[use the prog8c compilation daemon]' \
        '-daemon-server[run as the compilation daemon]' \
        '-watch[continuous compilation mode]' \
        '-vm[run a .p8ir IR file in the embedded VM]' \
        '-emu[auto-start emulator after successful compilation]' \
        '-emu2[auto-start alternative emulator]' \
        '-target=[compilation target (required)]:target:(c64 c128 cx16 pet virtual)' \
        '-out=[output directory]:dir:_files -/' \
        '-noasm[do not create assembly code]' \
        '-nosourcelines[omit Prog8 source lines from generated asm]' \
        '-asmlist[produce assembler listing file]' \
        '-nostdlib[disable bundled stdlib loading]' \
        '*-srcdirs=[extra paths for imported modules (path-separator delimited)]:paths:' \
        '-noopt[do not run optimizations]' \
        '-expericodegen[use experimental codegen]' \
        '-profiling[add subroutine profiling (Cx16 only)]' \
        '-breakinstr=[CPU instruction for %breakpoint]:instr:(brk stp)' \
        '-slabsgolden[memory() slabs in golden RAM (Cx16)]' \
        '-slabshigh=[memory() slabs in high memory (Cx16 HIRAM bank)]:bank:' \
        '-varsgolden[uninitialized vars in golden RAM (Cx16)]' \
        '-varshigh=[uninitialized vars in high memory (Cx16 HIRAM bank)]:bank:' \
        '*-D[define assembly symbol]:symbol\=value:' \
        '-dumpsymbols[dump variable + subroutine signatures]' \
        '-dumpvars[dump program variables]' \
        '-printast1[print internal AST]' \
        '-printast2[print simplified AST]' \
        '-timings[show internal compiler timings]' \
        '-plaintext[plain-text output (no colors)]' \
        '-quiet[silence compiler/asm output except warnings+errors]' \
        '-quietasm[silence only assembler messages]' \
        '-warnshadow[show symbol-shadowing warnings]' \
        '-warnimplicitcasts[show implicit-cast warnings]' \
        '-ignorefootguns[suppress footgun warnings]' \
        '-vmtrace[trace VM execution instruction-by-instruction]' \
        '-compareir=[compare generated .p8ir with existing]:file:_files -g "*.p8ir"' \
        '-libsearch=[search regex in embedded library files]:pattern:' \
        '-libdump=[dump embedded library files into directory]:dir:_files -/' \
        '-bytes2float=[convert bytes to target float value (CSV)]:csv:' \
        '-float2bytes=[convert float to target byte sequence]:float:' \
        '*:Prog8 module file:_files -g "*.p8"'
}

_prog8c "$@"
