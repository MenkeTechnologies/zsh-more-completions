#compdef pivxd
# _pivxd — PIVX Project pivxd daemon CLI for the privacy-focused Bitcoin fork running a full node maintaining the blockchain validating transactions network sync RPC API memory pool wallet zPIV minting masternodes budget governance staking (PIVX-Project team, C++); custom argparse
# upstream: https://github.com/PIVX-Project/PIVX

_pivxd() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-?[show help]' \
        '-conf=+[file]:file:_files -g "*.conf pivx.conf"' \
        '-datadir=+[dir]:dir:_files -/' \
        '-daemon[run as daemon]' \
        '-pid=+[file]:file:_files' \
        '-testnet[use testnet]' \
        '-regtest[use regtest]' \
        '-printtoconsole[print to console]' \
        '-debug=+[category]:c:(net mempool http bench zmq rpc walletdb estimatefee addrman selectcoins reindex cmpctblock rand prune libevent coindb leveldb staking masternode budget all)' \
        '-loglevel=+[level]:l:(info debug trace)' \
        '-shrinkdebugfile[shrink debug]' \
        '-logips[log IPs]' \
        '-rpcuser=+[user]:str:' \
        '-rpcpassword=+[password]:str:' \
        '-rpcport=+[port]:n:' \
        '-rpcbind=+[addr]:str:' \
        '-rpcallowip=+[cidr]:str:' \
        '-rpcserver[enable RPC server]' \
        '-rpcwait[wait for RPC server]' \
        '-listen[enable inbound]' \
        '-port=+[port]:n:' \
        '-bind=+[host]:str:' \
        '-externalip=+[ip]:str:' \
        '-onion=+[host:port]:str:' \
        '-proxy=+[host:port]:str:' \
        '-blocksonly[only blocks]' \
        '-maxconnections=+[N]:n:' \
        '-paytxfee=+[PIV/kB]:f:' \
        '-reindex[reindex]' \
        '-rescan[rescan]' \
        '-wallet=+[file]:file:_files' \
        '-staking=+[b]:b:(0 1)' \
        '-masternode=+[b]:b:(0 1)' \
        '-masternodeprivkey=+[key]:str:' \
        '-masternodeaddr=+[host:port]:str:' \
        '-enablezeromint=+[b]:b:(0 1)' \
        '-zeromintpercentage=+[N]:n:' \
        '-mintpiv[mint PIV]' \
        '-budgetvotemode=+[m]:m:(no auto suggest)' \
        '-zmqpubrawblock=+[address]:str:' \
        '-zmqpubrawtx=+[address]:str:' \
        '-zmqpubhashblock=+[address]:str:' \
        '-zmqpubhashtx=+[address]:str:'
}

_pivxd "$@"
