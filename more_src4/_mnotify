_mnotify() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '*'{-v,--verbose}'[increase verbosity (repeatable)]' \
        '*'{-q,--quiet}'[decrease verbosity (repeatable)]' \
        '(-f --full-state)'{-f,--full-state}'[request the full state during sync]' \
        '(-p --presense)'{-p,--presense}'=[presence value while syncing (default online)]:state:(online offline unavailable)' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _mn_cmds=(
                'clean:delete session store and secrets'
                'homeserver:get info about your homeserver and login'
                'hs:get info about your homeserver and login (alias for homeserver)'
                'login:log in to a homeserver and create a session store'
                'logout:log out and delete all state'
                'messages:dump messages of a room'
                'redact:redact a specific event'
                'rooms:query room information'
                'send:send a message to a room'
                'sync:run a sync and print all events'
                'typing:send typing notifications'
                'verify:react to emoji verification requests'
                'whoami:ask the homeserver who we are'
            )
            _describe -t commands 'mnotify command' _mn_cmds && ret=0
            ;;
        args)
            case $words[1] in
                clean)
                    _arguments '1:Matrix user_id (@alice\:example.org):' && ret=0
                    ;;
                homeserver|hs)
                    _arguments \
                        '(-f --force)'{-f,--force}'[really print the token]' \
                        '(-t --token)'{-t,--token}'[include the bearer token]' && ret=0
                    ;;
                login)
                    _arguments \
                        '1:user_id:' \
                        '(-p --password)'{-p,--password}'=[password (prompted if absent)]:pw:' \
                        '(-d --device-name)'{-d,--device-name}'=[device name (default mnotify)]:name:' && ret=0
                    ;;
                messages)
                    _arguments \
                        '(-r --room-id)'{-r,--room-id}'=[room_id]:room:' \
                        '(-l --limit)'{-l,--limit}'=[number of events (default 10)]:n:' && ret=0
                    ;;
                redact)
                    _arguments \
                        '(-r --room-id)'{-r,--room-id}'=[room_id]:room:' \
                        '(-e --event-id)'{-e,--event-id}'=[event_id]:event:' \
                        '--reason=[redaction reason]:reason:' && ret=0
                    ;;
                rooms)
                    _arguments \
                        '--room-id=[query only this room]:room:' && ret=0
                    ;;
                send)
                    _arguments \
                        '(-r --room-id)'{-r,--room-id}'=[room_id]:room:' \
                        '(-m --markdown)'{-m,--markdown}'[enable markdown formatting]' \
                        '(-n --notice -e --emote)'{-n,--notice}'[send as a notice]' \
                        '(-e --emote -n --notice)'{-e,--emote}'[send as an emote]' \
                        '(-a --attachment)'{-a,--attachment}'=[file to attach]:path:_files' \
                        '--reply-to=[reply to event_id]:event:' \
                        '1:message text (stdin if omitted):' && ret=0
                    ;;
                sync)
                    _arguments \
                        '--room-id=[limit to a single room]:room:' \
                        '--receipt[mark all received messages as read]' \
                        '--raw[print raw sync events]' && ret=0
                    ;;
                typing)
                    _arguments \
                        '--room-id=[room_id]:room:' \
                        '--disable[disable typing instead of enabling]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_mnotify "$@"
