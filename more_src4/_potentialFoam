#compdef potentialFoam
# Documentation: https://www.openfoam.com/documentation/guides/latest/api/
# Source: OpenFOAM/OpenFOAM-12 applications/solvers/potentialFoam/potentialFoam.C — potential flow solver.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-parallel[run in parallel]' \
    '-roots+[slave root directories]:dirs:_default' \
    '-hostRoots+[per-host slave root directories]:dirs:_default' \
    '-noFunctionObjects[do not execute functionObjects]' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-region+[mesh region]:region:_default' \
    '-pName+[pressure field name]:name:_default' \
    '-initialiseUBCs[initialise U boundary conditions]' \
    '-writePhi[write velocity potential field]' \
    '-writep[calculate and write pressure field]' \
    && ret=0

return ret
