#compdef overmind
# Documentation: https://github.com/DarthSim/overmind
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Flags sourced from overmind README usage section.

_overmind_start() {
  _arguments \
    '(-f --procfile)'{-f,--procfile}'[Procfile path]:file:_files' \
    '(-p --port)'{-p,--port}'[base port]:port:' \
    '(-P --port-step)'{-P,--port-step}'[port increment]:step:' \
    '(-l --processes)'{-l,--processes}'[only run these processes]:processes:' \
    '(-x --ignored-processes)'{-x,--ignored-processes}'[exclude processes]:processes:' \
    '(-m --formation)'{-m,--formation}'[process formation]:formation:' \
    '(-c --can-die)'{-c,--can-die}'[processes that may die]:processes:' \
    '--any-can-die[allow any process to die]' \
    '(-r --auto-restart)'{-r,--auto-restart}'[processes to auto-restart]:processes:' \
    '(-b --colors)'{-b,--colors}'[xterm color codes]:colors:' \
    '(-T --timestamps)'{-T,--timestamps}'[show timestamps]' \
    '(-D --daemonize)'{-D,--daemonize}'[run as daemon]' \
    '(-s --socket)'{-s,--socket}'[socket path]:socket:_files' \
    '(-S --network)'{-S,--network}'[network type]:network:(tcp unix)' \
    '(-N --no-port)'{-N,--no-port}'[do not assign PORT]' \
    '(-F --tmux-config)'{-F,--tmux-config}'[tmux config file]:file:_files'
}

_overmind_run() {
  _arguments \
    '(-f --procfile)'{-f,--procfile}'[Procfile path]:file:_files' \
    '(-s --socket)'{-s,--socket}'[socket path]:socket:_files' \
    '(-S --network)'{-S,--network}'[network type]:network:(tcp unix)' \
    '*::command:_command_names'
}

_overmind() {
  local -a commands
  commands=(
    'start:start processes'
    'restart:restart a process'
    'stop:stop a process'
    'connect:connect to a process'
    'quit:quit overmind'
    'run:run a command in the process environment'
    'echo:echo process output'
    'kill:kill overmind and all processes'
    'help:show help'
  )

  _arguments \
    '(- *)--help[show help]' \
    '(- *)--version[show version]' \
    '1:command:->command' \
    '*::arguments:->arguments'

  case "$state" in
    command)
      _describe -t commands 'overmind command' commands
      ;;
    arguments)
      case "$words[1]" in
        start) _overmind_start ;;
        run) _overmind_run ;;
        restart|stop|connect|echo) _arguments ':process name:' ;;
      esac
      ;;
  esac
}

_overmind "$@"
