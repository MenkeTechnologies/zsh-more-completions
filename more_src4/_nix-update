#compdef nix-update
# Documentation: https://github.com/Mic92/nix-update
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for nix-update

_arguments \
  '--version=[specify target version]:version:(stable unstable)' \
  '--version-regex=[regex to extract version]:regex:' \
  '--commit[automatically create a git commit]' \
  '--build[run nix-build after updating]' \
  '--test[run packages internal tests]' \
  '--run[run the package after updating]' \
  '--shell[drop into a nix-shell for the updated package]' \
  '--format[format the modified Nix file]' \
  '--review[run nixpkgs-review to check for regressions]' \
  '--url=[override the source URL]:url:_urls' \
  '--override-filename=[manually specify the .nix file to update]:file:_files' \
  '--flake[update a package in a flake]' \
  '*--subpackage=[update a specific subpackage]:name:' \
  '--use-update-script[run the package passthru.updateScript]' \
  '--update-script-args=[arguments forwarded to updateScript]:args:' \
  '*--custom-dep=[custom dependency fetcher]:dep:' \
  '--system=[system to use]:system:' \
  '--generate-lockfile[regenerate lockfile (Cargo.lock, package-lock.json)]' \
  '--lockfile-metadata-path=[path to lockfile metadata]:path:_files' \
  '1:attribute name' && return 0
