#compdef pngfix
# Documentation: pngfix --help (libpng)
# Source: test, optimize, and optionally fix the zlib header in PNG files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-o --optimize)'{-o,--optimize}'[find smallest deflate window size]' \
    '--strip=[strip chunks]:level:(none crc unsafe unused transform color all)' \
    '--max=[use IDAT chunks of given size]:bytes:' \
    '*'{-q,--quiet}'[suppress summaries (repeatable)]' \
    '(-e --errors)'{-e,--errors}'[output libpng errors]' \
    '(-w --warnings)'{-w,--warnings}'[output libpng warnings]' \
    '*:png file:_files -g "*.png"' \
    && ret=0

return ret
