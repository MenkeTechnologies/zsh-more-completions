#compdef pamsumm
# Documentation: man pamsumm (Netpbm)
# Source: Netpbm pamsumm — summarize the samples in a Netpbm image arithmetically.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-sum -mean -min -max)-sum[sum of all samples]' \
    '(-sum -mean -min -max)-mean[mean of all samples]' \
    '(-sum -mean -min -max)-min[minimum sample]' \
    '(-sum -mean -min -max)-max[maximum sample]' \
    '-normalize[normalize result to 0..1]' \
    '-brief[print only the result number]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm image file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
