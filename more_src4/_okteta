#compdef okteta
# Documentation: https://docs.kde.org/stable5/en/okteta/okteta/index.html
# Reference accessed: 2026-05-19
# Verified: upstream KDE Okteta handbook at the URL above.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '(- *)--help[show help]' \
  '--help-all[show all options]' \
  '--help-qt[show Qt options]' \
  '--help-kde[show KDE options]' \
  '-v[show version]' \
  '--version[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--desktopfile=[desktop file name]:file:_files' \
  '*:file:_files' && ret=0
return ret
