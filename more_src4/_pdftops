#compdef pdftops
# Documentation: https://manpages.debian.org/bookworm/poppler-utils/pdftops.1.en.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)-v[show version]' \
  '(- *)-h[show help]' \
  '(- *)-help[show help]' \
  '(- *)--help[show help]' \
  '-f[first page]:n:' \
  '-l[last page]:n:' \
  '-eps[generate Encapsulated PostScript]' \
  '-level1[level 1 PostScript]' \
  '-level1sep[level 1 separable PostScript]' \
  '-level2[level 2 PostScript]' \
  '-level2sep[level 2 separable PostScript]' \
  '-level3[level 3 PostScript]' \
  '-level3sep[level 3 separable PostScript]' \
  '-origpagesizes[use original page sizes]' \
  '-paper[paper size]:size:(A4 A3 letter legal match)' \
  '-paperw[paper width in points]:px:' \
  '-paperh[paper height in points]:px:' \
  '-r[resolution DPI]:dpi:' \
  '-binary[write binary PostScript]' \
  '-noembt1[do not embed Type 1 fonts]' \
  '-noembtt[do not embed TrueType fonts]' \
  '-noembcidps[do not embed CID PostScript fonts]' \
  '-noembcidtt[do not embed CID TrueType fonts]' \
  '-passfonts[pass fonts through]' \
  '-preload[preload images and forms]' \
  '-expand[expand to paper size]' \
  '-noshrink[do not shrink to fit]' \
  '-nocenter[do not center on paper]' \
  '-nocrop[do not crop pages to CropBox]' \
  '-duplex[print duplex]' \
  '-opi[generate OPI comments]' \
  '-opw[owner password]:password:' \
  '-upw[user password]:password:' \
  '-optimizecolorspace[convert gray RGB images to grayscale]' \
  '-processcolorformat[process color format]:format:' \
  '-processcolorprofile[process color profile]:profile:_files' \
  '-defaultgrayprofile[default gray profile]:profile:_files' \
  '-defaultrgbprofile[default RGB profile]:profile:_files' \
  '-defaultcmykprofile[default CMYK profile]:profile:_files' \
  '-overprint[enable overprint]' \
  '-q[do not print errors]' \
  '*:input:_files -g "*.pdf"'
