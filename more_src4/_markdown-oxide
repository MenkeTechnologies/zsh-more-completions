#compdef markdown-oxide
# Documentation: https://github.com/Feel-ix-343/markdown-oxide
# Reference accessed: 2026-05-19
# Verified: Feel-ix-343/markdown-oxide src/cli.rs (clap derive).
# Removed from prior file: bogus man.archlinux.org URL; fabricated
# --stdio flag (LSP mode is the default when no subcommand is given,
# not a flag). Added real daily/config subcommands.

# Zsh completion for markdown-oxide (Markdown LSP server for PKM)

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'daily:open a daily note in your editor'
  'config:open the configuration file in your editor'
)

_arguments -s -S -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  (command)
    _describe -t commands 'markdown-oxide command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (daily)
        _arguments \
          '*:date:' && ret=0
        ;;
    esac
    ;;
esac

return ret
