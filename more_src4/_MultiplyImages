#compdef MultiplyImages
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/MultiplyImages.cxx — voxel-wise image product (C++, positional).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments \
    '(- *)'{-h,--help}'[show help]' \
    '1:ImageDimension:(2 3 4)' \
    '2:img1.nii:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '3:img2.nii (or numeric scalar):_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '4:product.nii:_files' \
    '5::smoothing (default 0):_default' \
    && ret=0

return ret
