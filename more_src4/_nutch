#compdef nutch
# Documentation: https://github.com/apache/nutch
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'readdb:read crawl db'
  'mergedb:merge crawl dbs'
  'readlinkdb:read link db'
  'inject:inject seed URLs'
  'generate:generate fetch list'
  'freegen:generate from URL list file'
  'fetch:fetch URLs'
  'parse:parse fetched segments'
  'readseg:read segment'
  'mergesegs:merge segments'
  'updatedb:update crawl db'
  'invertlinks:invert links'
  'mergelinkdb:merge link dbs'
  'index:run indexer'
  'dedup:deduplicate'
  'dump:dump segments'
  'commoncrawldump:dump in CommonCrawl format'
  'clean:clean indexer of deleted/orphaned'
  'parsechecker:check parser'
  'indexchecker:check indexer'
  'filterchecker:check URL filters'
  'normalizerchecker:check URL normalizers'
  'robotsparser:parse robots.txt'
  'domainstats:gather domain statistics from crawldb'
  'protocolstats:gather protocol statistics from crawldb'
  'crawlcomplete:show crawl completion stats'
  'webgraph:generate webgraph'
  'linkrank:run linkrank scoring'
  'scoreupdater:update scores from webgraph'
  'nodedumper:dump nodes from webgraph'
  'sitemap:process sitemaps for host db'
  'showproperties:show conf properties'
  'plugin:run a plugin'
  'junit:run JUnit tests'
  'startserver:start REST server'
  'webapp:start REST server (web)'
  'warc:export to WARC'
  'updatehostdb:update host db'
  'readhostdb:read host db'
)

_arguments -C \
  '(- *)-h[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'nutch command' commands && ret=0 ;;
esac

return ret
