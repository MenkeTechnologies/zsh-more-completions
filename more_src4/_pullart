local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '1:cyclic buffer file:_files' \
    '2:output file prefix:_default' \
    '3::header field name filter:_default' \
    '4::match string in header:_default' \
    && ret=0

return ret
