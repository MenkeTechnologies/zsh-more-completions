#compdef pgmtost4
# Documentation: man pgmtost4 (Netpbm)
# Source: convert a PGM image to SBIG ST-4 CCD camera format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
