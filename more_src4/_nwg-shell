#compdef nwg-shell nwg-shell-config
# Documentation: https://github.com/nwg-piotr/nwg-shell-config
# Reference accessed: 2026-05-16
# Verified: nwg_shell_config/main.py argparse. nwg-shell itself is a
# meta-package installer; the configurator binary nwg-shell-config has the
# documented flag set.

# nwg-shell: nwg-shell configurator and meta-package
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-v,--version}'[show version information]' \
  '(-r --restore)'{-r,--restore}'[restore default presets]' \
  '(-b --restore_backup)'{-b,--restore_backup=}'[restore configs from backup file]:file:_files' \
  '(-s --save)'{-s,--save}'[load settings & save includes]' && ret=0
return ret
