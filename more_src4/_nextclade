#compdef nextclade
# Documentation: https://docs.nextstrain.org/projects/nextclade
# Source: nextstrain/nextclade packages/nextclade-cli/src/cli/nextclade_cli.rs — viral genome alignment + clade assignment (Rust, clap).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _nc_cmds
_nc_cmds=(
    'completions:generate shell completion script'
    'run:run sequence analysis (alignment, mutation calling, clade assignment, QC, placement)'
    'dataset:list and download available Nextclade datasets (pathogens)'
    'sort:sort sequences according to inferred Nextclade dataset'
    'read-annotation:read genome annotation and present in internal formats'
    'help-markdown:print command-line reference docs in Markdown'
    'schemas:write JSON schema definitions for Nextclade file formats'
)

_arguments -C \
    '*'{-v,--verbose}'[make output more verbose]' \
    '*'{-q,--quiet}'[make output more quiet]' \
    '--verbosity=[verbosity level]:level:(off error warn info debug trace)' \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '1: :->command' \
    '*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'nextclade command' _nc_cmds && ret=0
        ;;
    args)
        case $line[1] in
            dataset)
                _values 'dataset action' \
                    'list[list available datasets]' \
                    'get[download an available dataset]' \
                    && ret=0
                ;;
            completions)
                _values 'shell' bash fish zsh elvish powershell && ret=0
                ;;
        esac
        ;;
esac

return ret
