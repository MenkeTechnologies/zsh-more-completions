#compdef mmgs mmgs_O3 mmgs_O3d mmgs_debug
# Documentation: https://www.mmgtools.org/
# Source: MmgTools/mmg src/mmgs/libmmgs_tools.c (MMGS_usage + MMGS_parsar) +
#         src/common/libtools.c (MMG5_mmgUsage + MMG5_paramUsage1/2 + MMG5_advancedUsage).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[print help]' \
    '-v[verbosity level -1..10]:n:' \
    '-m[maximal memory size in Mbytes]:n:' \
    '-d[turn on debug mode]' \
    '-val[print default parameter values]' \
    '-default[save local parameters file for default parameters]' \
    '-in[input surface triangulation]:file:_files' \
    '-out[output surface triangulation]:file:_files' \
    '-o[output surface triangulation (alias)]:file:_files' \
    '-sol[load solution or metric file]:file:_files' \
    '-met[load metric file]:file:_files' \
    '-f[load parameter file]:file:_files' \
    '-ls[create mesh of isovalue val (default 0)]:val:' \
    '-lssurf[split mesh boundaries on isovalue val (default 0)]:val:' \
    '-A[enable anisotropy (without metric file)]' \
    '-ar[ridge angle detection value]:val:' \
    '-nr[no angle detection]' \
    '-hausd[control Hausdorff distance]:val:' \
    '-hgrad[control gradation]:val:' \
    '-hmax[maximal mesh size]:val:' \
    '-hmin[minimal mesh size]:val:' \
    '-hsiz[constant mesh size]:val:' \
    '-rmc[remove components with volume fraction less than val]:val:' \
    '-noinsert[no point insertion/deletion]' \
    '-nomove[no point relocation]' \
    '-noswap[no edge or face flipping]' \
    '-nreg[normal regularization]' \
    '-xreg[vertex regularization]' \
    '-nsd[save the subdomain number val (0 = all)]:val:' \
    '-optim[mesh optimization]' \
    '-keep-ref[preserve initial domain references in level-set mode]' \
    '-rn[turn on/off SCOTCH renumbering (0/1)]:n:(0 1)' \
    '*:input mesh:_files' \
    && ret=0

return ret
