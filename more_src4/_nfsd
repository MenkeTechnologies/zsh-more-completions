#compdef nfsd
# _nfsd — OpenBSD nfsd (kernel-side NFS server worker; spawns per-protocol threads (UDP/TCP) that pick up incoming RPC NFS requests; defaults to 4 UDP servers)
# upstream: https://github.com/openbsd/src (sbin/nfsd)
# Flags from sbin/nfsd/nfsd.8 on tip.

_nfsd() {
    _arguments \
        '-r[reregister with portmapper, then exit]' \
        '-t[serve TCP]' \
        '-u[serve UDP]' \
        '-n+[number of server threads]:n:'
}

_nfsd "$@"
