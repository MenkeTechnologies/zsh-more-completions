#compdef pvfs2-server
# Documentation: https://www.mankier.com/1/pvfs2-server
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pvfs2-server: PVFS2 file-serving daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-d[run in foreground]' \
  '-f[create file system storage space and exit]' \
  '1:global config file:_files' \
  '2:local config file:_files' && ret=0
return ret
