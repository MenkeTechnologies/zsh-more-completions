#compdef ocaml-top
# Documentation: https://github.com/OCamlPro/ocaml-top/blob/master/src/main.ml
# Reference accessed: 2026-05-19
# Verified: ocaml-top upstream src/main.ml. Real options:
# -ocaml COMMAND, -font FONT, -light, -datadir PATH, --- ARGS.
# Corrected from prior file: was just -h/--help/--version (none
# of which exist); ocaml-top uses single-dash options.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-ocaml[OCaml toplevel command]:command:_command_names' \
  '-font[monospace font for editor (Gtk naming)]:font:' \
  '-light[use light color theme]' \
  '-datadir[resource files directory]:dir:_files -/' \
  '*:file:_files -g "*.{ml,mli}"' && ret=0

return ret
