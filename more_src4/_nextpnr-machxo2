#compdef nextpnr-machxo2
# _nextpnr-machxo2 — YosysHQ nextpnr-machxo2 CLI place-and-route portable open-source FPGA P&R tool targeting Lattice MachXO2 MachXO3 small CPLD-style FPGAs packed JSON netlist from Yosys producing bitstream for xo2tools ecpprog (David Shah team, C++); custom argparse
# upstream: https://github.com/YosysHQ/nextpnr

_nextpnr-machxo2() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '--debug[debug]' \
        '--log=+[log file]:file:_files' \
        '--json=+[json netlist]:file:_files -g "*.json"' \
        '--lpf=+[lpf constraints]:file:_files -g "*.lpf"' \
        '--textcfg=+[config output]:file:_files -g "*.config"' \
        '--write=+[json output]:file:_files -g "*.json"' \
        '--device=+[d]:d:(LCMXO2-256HC-4SG32C LCMXO2-640HC-4TG100C LCMXO2-1200HC-4TG100C LCMXO2-2000HC-4TG100C LCMXO2-4000HC-4TG144C LCMXO2-7000HC-4TG144C LCMXO3LF-640E-5MG121C LCMXO3LF-1300E-5MG121C LCMXO3LF-2100E-5MG121C LCMXO3LF-4300E-5MG121C LCMXO3LF-6900E-5MG121C LCMXO3LF-9400E-5MG121C)' \
        '--family=+[f]:f:(MachXO2 MachXO3 MachXO3LF MachXO3D)' \
        '--no-iobs[disable IO buffers]' \
        '--package=+[p]:p:(QFN32 QFN84 TQFP100 TQFP144 caBGA256 caBGA324 caBGA400 caBGA484 caBGA672 csBGA56 csBGA132 ucBGA64 ucBGA132 ucBGA181)' \
        '--speed=+[s]:s:(1 2 3 4 5 6)' \
        '--freq=+[MHz]:n:' \
        '--seed=+[seed]:n:' \
        '--placer=+[p]:p:(heap sa)' \
        '--router=+[r]:r:(router1 router2)' \
        '--no-route[skip routing]' \
        '--no-place[skip placement]' \
        '--no-pack[skip packing]' \
        '--placer-heap-alpha=+[alpha]:n:' \
        '--placer-heap-beta=+[beta]:n:' \
        '--threads=+[N]:n:' \
        '--gui[gui mode]' \
        '--report=+[file]:file:_files -g "*.json"' \
        '--detailed-timing-report[detailed timing report]' \
        '--no-tmdriv[disable timing-driven]' \
        '--ignore-loops[ignore combinational loops]' \
        '--randomize-seed[randomize seed]' \
        '*:json file:_files -g "*.json"'
}

_nextpnr-machxo2 "$@"
