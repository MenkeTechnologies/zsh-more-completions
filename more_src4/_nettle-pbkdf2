#compdef nettle-pbkdf2
# Documentation: nettle-pbkdf2 --help
# Source: PBKDF2 password-derived key generator (libnettle).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-i --iterations)'{-i+,--iterations=}'[iteration count (default 10000)]:count:' \
    '(-l --length)'{-l+,--length=}'[output length octets (default 16)]:length:' \
    '--raw[raw binary output]' \
    '--hex-salt[treat SALT as hex]' \
    '1:salt:' \
    && ret=0

return ret
