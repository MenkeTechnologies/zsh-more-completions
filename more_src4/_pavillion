#                                    federation patterns
#     • `@fedify/create`             project initializer
#     • `@fedify/init`               sub-init helper
#
#   Fedify exposes the typed `Federation` builder:
#
#     const federation = createFederation<MyContextData>({
#       kv: new MemoryKvStore(),
#       queue: new InProcessMessageQueue(),
#       documentLoader: ...,
#       userAgent: ...,
