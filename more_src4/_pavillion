#
#     federation.setInboxListeners("/users/{handle}/inbox",
#                                    "/inbox")
#       .on(Follow, async (ctx, follow) => { ... })
#       .on(Undo, async (ctx, undo) => { ... })
#       .on(Create, async (ctx, create) => { ... })
#       .on(Like, async (ctx, like) => { ... });
#
#     federation.setOutboxDispatcher("/users/{handle}/outbox",
#       async (ctx, handle, cursor) => { return { items, nextCursor }; });
#
#     federation.setFollowersDispatcher("/users/{handle}/followers",
#       async (ctx, handle, cursor, filter) => {...});
#
#     federation.setFollowingDispatcher(...);
#     federation.setNodeInfoDispatcher(...);
#     federation.setObjectDispatcher(Note, "/posts/{id}", ...);
#
#   `@fedify/fedify` powers the fastest-growing slice of TS/JS-
#   based fediverse software:  **Hollo** (the federated single-
