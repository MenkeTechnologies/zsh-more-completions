_pavillion() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _pv_cmds=(
                'backup:backup management commands'
                'housekeeping:view housekeeping system status'
                'import\:sync:manually sync an ICS import source'
            )
            _describe -t commands 'pavillion command' _pv_cmds && ret=0
            ;;
        args)
            case $words[1] in
                backup)
                    if (( CURRENT == 2 )); then
                        local -a _b=(
                            'create:queue an immediate backup job'
                            'list:list all available backups'
                            'status:show backup system health and statistics'
                            'restore:restore database from a backup'
                        )
                        _describe -t sub 'backup sub' _b && ret=0
                    elif [[ $words[2] == restore ]]; then
                        _arguments '1:backup ID to restore:' && ret=0
                    fi
                    ;;
                import:sync)
                    _arguments \
                        '--source-id=[import source UUID to sync]:uuid:' \
                        '--calendar-id=[calendar UUID (sync all verified sources for this calendar)]:uuid:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_pavillion "$@"
