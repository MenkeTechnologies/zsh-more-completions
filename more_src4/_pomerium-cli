#compdef pomerium-cli
# Documentation: https://github.com/pomerium/cli/tree/main/cmd/pomerium-cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for Pomerium CLI client

local curcontext="$curcontext" state line ret=1

local -a pomerium_cli_commands
pomerium_cli_commands=(
  'api:expose API on local socket'
  'auth:authenticate against pomerium'
  'cache:manage the local cache'
  'databroker:databroker commands'
  'k8s:connect to a Kubernetes cluster through Pomerium'
  'kubernetes:connect to a Kubernetes cluster through Pomerium'
  'proxy:proxy a connection through Pomerium'
  'routes:list routes'
  'tcp:create a TCP tunnel through Pomerium'
  'udp:create a UDP tunnel through Pomerium'
  'version:display version information'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmds' \
  '*::args:->args' && ret=0

case "$state" in
  cmds)
    _describe -t commands 'pomerium-cli command' pomerium_cli_commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      tcp|udp)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          '--pomerium-url=[URL of the Pomerium proxy]:url:' \
          '--listen=[local address to start a listener on]:address:' \
          '--disable-tls-verification[disable TLS verification]' \
          '--ca=[custom CA file]:file:_files' \
          '--ca-text=[custom CA text]:text:' \
          '--client-cert=[client certificate]:file:_files' \
          '--client-key=[client certificate key]:file:_files' \
          '--browser-command=[command for opening browser]:command:' \
          '--service-account=[service account JWT]:jwt:' \
          '--service-account-file=[file containing service account JWT]:file:_files' \
          '1:destination:' \
          && ret=0
        ;;
      k8s|kubernetes)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      cache)
        _arguments -s -S \
          '(-h --help)'{-h,--help}'[show help]' \
          && ret=0
        ;;
      *)
        _arguments -s -S '(-h --help)'{-h,--help}'[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
