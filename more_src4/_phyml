#compdef phyml phyml-mpi
# _phyml — Stéphane Guindon phyml CLI maximum-likelihood phylogenetic tree estimator for DNA RNA protein sequence alignments with NNI SPR rate-class GTR HKY85 JC69 K80 F81 F84 TN93 WAG JTT LG Dayhoff DCMut MtREV RtREV CpREV gamma+invariant rate heterogeneity bootstrap aLRT statistical support (Stéphane Guindon team, C); getopt
# upstream: http://www.atgc-montpellier.fr/phyml/

_phyml() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-i+[alignment file]:file:_files -g "*.phy *.fasta *.fas *.aln *.nex"' \
        '--input=+[file]:file:_files -g "*.phy *.fasta *.fas *.aln *.nex"' \
        '-q+[seq format]:f:(interleaved sequential)' \
        '--quiet[quiet]' \
        '-d+[data type]:t:(nt aa generic)' \
        '--datatype=+[t]:t:(nt aa generic)' \
        '-n+[ndata]:n:' \
        '-b+[boot]:str:' \
        '--bootstrap=+[N]:str:' \
        '-m+[model]:m:(HKY85 JC69 K80 F81 F84 TN93 GTR JTT MtREV Dayhoff DCMut WAG RtREV CpREV VT Blosum62 LG HIVw HIVb)' \
        '--model=+[m]:m:(HKY85 JC69 K80 F81 F84 TN93 GTR JTT MtREV Dayhoff DCMut WAG RtREV CpREV VT Blosum62 LG HIVw HIVb)' \
        '-f+[freq]:f:(empirical optimized e m d)' \
        '-t+[ts/tv]:str:' \
        '-v+[prop invariant]:str:' \
        '-a+[gamma shape]:str:' \
        '-c+[ncatgamma]:n:' \
        '--free-rates[free rates]' \
        '--alpha=+[alpha]:str:' \
        '-o+[opt]:str:(tlr tl t r n l)' \
        '--optimize=+[w]:str:' \
        '-s+[search]:s:(NNI SPR BEST)' \
        '--search=+[s]:s:(NNI SPR BEST)' \
        '--rand_start[random starting tree]' \
        '--n_rand_starts=+[N]:n:' \
        '--r_seed=+[seed]:n:' \
        '-u+[user tree]:file:_files -g "*.tree *.nwk *.tre"' \
        '--inputtree=+[file]:file:_files' \
        '--quiet[quiet]' \
        '--no_memory_check[do not check memory]' \
        '--leave_duplicates[keep duplicate sequences]' \
        '--print_site_lnl[print site likelihoods]' \
        '--print_trace[print trace]' \
        '--print_mat_and_exit[print matrices and exit]' \
        '*::'
}

_phyml "$@"
