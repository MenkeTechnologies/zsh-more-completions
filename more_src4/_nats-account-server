#compdef nats-account-server
# _nats-account-server — NATS account JWT host/distribution server (nats-io/nats-account-server)
# upstream: https://github.com/nats-io/nats-account-server
# Flags from main.go (flag).

_nats-account-server() {
    _arguments \
        '-c+[configuration file]:file:_files' \
        '-dir+[directory to store/host accounts]:dir:_files -/' \
        '-operator+[operator JWT path]:file:_files' \
        '-nats+[NATS server URL for notifications]:url:_urls' \
        '-creds+[NATS credentials file]:file:_files' \
        '-primary+[primary server URL]:url:_urls' \
        '-D[turn on debug logging]' \
        '-V[turn on verbose logging]' \
        '-DV[debug and verbose logging]' \
        '-hp+[HTTP host:port (default localhost:9090)]:host:port:' \
        '-nsc+[(deprecated) nsc folder]:dir:_files -/' \
        '-ro[(deprecated) read-only mode]' \
        '-dump[print config]'
}

_nats-account-server "$@"
