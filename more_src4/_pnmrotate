#compdef pnmrotate
# Documentation: man pnmrotate (Netpbm)
# Source: rotate a Netpbm image by an arbitrary angle.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-noantialias[disable supersampling antialiasing]' \
    '-background=[background color for empty corners]:color:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:angle in degrees:' \
    '2:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
