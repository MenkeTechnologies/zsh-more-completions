#compdef mastra
# Documentation: https://github.com/mastra-ai/mastra/tree/main/packages/cli
# Reference accessed: 2026-05-22
# Verified: packages/cli/src/index.ts Commander program definitions.

# Zsh completion for mastra - Mastra AI framework CLI

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'mastra command' \
      'create[create new Mastra project]' \
      'init[initialize project]' \
      'lint[lint project]' \
      'dev[start dev server]' \
      'build[build project]' \
      'start[start project]' \
      'worker[standalone worker bundles]' \
      'studio[studio deploy commands]' \
      'scorers[manage evaluation scorers]' \
      'auth[authentication]' \
      'server[Mastra Server deployments]' \
      'migrate[run migrations]' \
      'api[API utilities]' && ret=0
    ;;
  args)
    case $line[1] in
      create)
        _arguments '1:project-name:' && ret=0
        ;;
      worker)
        _values 'worker action' build start dev && ret=0
        ;;
      studio)
        _values 'studio action' deploy list status logs suggestions projects && ret=0
        case $line[2] in
          deploy)
            _arguments '1:directory:directory:_directories' && ret=0
            ;;
          status|logs|suggestions)
            _arguments '1:deploy-id:' && ret=0
            ;;
          projects)
            _values 'projects action' list create && ret=0
            ;;
        esac
        ;;
      scorers)
        _values 'scorers action' add list && ret=0
        case $line[2] in
          add)
            _arguments '1:scorer-name:' && ret=0
            ;;
        esac
        ;;
      auth)
        _values 'auth action' login logout whoami orgs tokens && ret=0
        case $line[2] in
          orgs)
            _values 'orgs action' list switch && ret=0
            ;;
          tokens)
            _values 'tokens action' list create revoke && ret=0
            case $line[3] in
              create)
                _arguments '1:token name:' && ret=0
                ;;
              revoke)
                _arguments '1:token-id:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
      server)
        _values 'server action' deploy pause restart env suggestions && ret=0
        case $line[2] in
          deploy)
            _arguments '1:directory:directory:_directories' && ret=0
            ;;
          env)
            _values 'env action' list set unset import pull && ret=0
            case $line[3] in
              set)
                _arguments '1:key:' '2:value:' && ret=0
                ;;
              unset)
                _arguments '1:key:' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
