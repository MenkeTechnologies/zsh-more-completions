#compdef pungi pungi-koji
# Documentation: man pungi(1)
# Source: bcl/pungi src/bin/pungi.py (master) — Fedora distribution compose tool (Python optparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '--version[show version]' \
    '--name=[distribution name]:name:_default' \
    '--ver=[distribution version]:version:_default' \
    '--flavor=[distribution flavor]:flavor:_default' \
    '--destdir=[destination directory]:dir:_files -/' \
    '--cachedir=[package cache directory]:dir:_files -/' \
    '--bugurl=[bug system URL]:url:_default' \
    '--workdirbase=[work directory base]:dir:_files -/' \
    '--arch=[target architecture]:arch:(x86_64 i386 ppc64le aarch64 armhfp s390x)' \
    '--isfinal[mark as final compose]' \
    '--full-archlist[include all archs]' \
    '--multilib=[multilib]:methods:_default' \
    '--lookaside-repo=[lookaside repo URL]:url:_default' \
    '--lorax-conf=[Lorax config file]:file:_files' \
    '--all-stages[run all stages]' \
    '--selfhosting[self-hosting build]' \
    '--fulltree[include all packages built from source RPMs]' \
    '--nosource[do not gather source packages]' \
    '--nodebuginfo[do not gather debuginfo packages]' \
    '--nodownload[print URLs instead of downloading]' \
    '--norelnotes[disable release notes (deprecated)]' \
    '(--greedy --nogreedy)--greedy[pull all dep providers]' \
    '(--greedy --nogreedy)--nogreedy[do not pull all dep providers]' \
    '--nohash[disable hashes]' \
    '--nodeps[disable dep resolving]' \
    '--no-dvd[no DVD image]' \
    '--nomacboot[no Mac boot config]' \
    '--sourceisos[generate source ISO images]' \
    '--relnotefilere=[release notes file regex]:regex:_default' \
    '--relnotepkgs=[release notes package list]:pkgs:_default' \
    '--force[force overwrite of existing trees]' \
    '*:config file:_files -g "*.{ks,kickstart,conf}"' \
    && ret=0

return ret
