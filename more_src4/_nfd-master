#compdef nfd-master
# _nfd-master — Node Feature Discovery master server (kubernetes-sigs/node-feature-discovery)
# upstream: https://github.com/kubernetes-sigs/node-feature-discovery
# Flags from cmd/nfd-master/main.go on tip.

_nfd-master() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-instance=[NFD master instance name]:name:' \
        '-config=[nfd-master configuration file]:file:_files' \
        '-kubeconfig=[kubeconfig file]:file:_files' \
        '-port=[gRPC server bind port]:port:' \
        '-prune[remove obsolete NFD labels/extended-resources/taints then exit]' \
        '-options=[inline JSON config overrides]:json:' \
        '-enable-leader-election[enable leader election]' \
        '*-extra-label-ns=[allowed extra label namespace]:ns:' \
        '*-label-whitelist=[regex label whitelist]:re:' \
        '-enable-taints[enable nfd-master to set Node taints]' \
        '-no-publish[disable Node updates]' \
        '*-deny-label-ns=[denied label namespace]:ns:' \
        '-resync-period=[informer resync period]:dur:' \
        '-nfd-api-parallelism=[max goroutines updating Nodes]:n:' \
        '-informer-page-size=[informer list-watch page size]:n:' \
        '-v[klog verbosity level]:n:' \
        '-logtostderr[log to stderr]'
}

_nfd-master "$@"
