#compdef otbcli_ExtractROI
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ExtractROI.html
# Source: orfeotoolbox/OTB ExtractROI — crop a raster to a sub-region.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image]:image:_files' \
    '-out+[output image]:image:_files' \
    '-mode+[extraction method]:mode:(standard fit extent radius)' \
    '-startx+[ROI upper-left X (px)]:n:_default' \
    '-starty+[ROI upper-left Y (px)]:n:_default' \
    '-sizex+[ROI width (px)]:n:_default' \
    '-sizey+[ROI height (px)]:n:_default' \
    '-mode.fit.im+[reference image for ROI]:image:_files' \
    '-mode.fit.vect+[reference vector for ROI]:vector:_files' \
    '-mode.extent.ulx+[upper-left X coordinate]:value:_default' \
    '-mode.extent.uly+[upper-left Y coordinate]:value:_default' \
    '-mode.extent.lrx+[lower-right X coordinate]:value:_default' \
    '-mode.extent.lry+[lower-right Y coordinate]:value:_default' \
    '-mode.extent.unit+[coordinate units]:unit:(pxl phy lonlat)' \
    '-mode.radius.r+[radius value]:value:_default' \
    '-mode.radius.unitr+[radius unit]:unit:(pxl phy)' \
    '-mode.radius.cx+[circle center X]:value:_default' \
    '-mode.radius.cy+[circle center Y]:value:_default' \
    '-mode.radius.unitc+[center coord unit]:unit:(pxl phy lonlat)' \
    '-cl+[output channels selection]:channels:_default' \
    '-elev.dem+[DEM directory or VRT]:path:_files' \
    '-elev.geoid+[geoid file]:file:_files' \
    '-elev.default+[default elevation (m)]:m:_default' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
