# Zsh completion for mlx-lm - Apple MLX language model CLI suite

_arguments \
  '--model[model path or HuggingFace ID]:model:' \
  '--prompt[text prompt for generation]:prompt:' \
  '--max-kv-size[rotating key-value cache size]:size:' \
  '--prompt-cache-file[path to prompt cache file]:path:_files' \
