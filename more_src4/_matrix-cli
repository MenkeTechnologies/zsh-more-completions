#compdef matrix-cli matrix-commander
# _matrix-cli — Matrix.org matrix-commander client CLI alias (8go team, Python); argparse
# upstream: https://github.com/8go/matrix-commander

_matrix-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--login=+[login method]:l:(password sso)' \
        '--logout=+[scope]:s:(me all)' \
        '--credentials=+[credentials file]:file:_files' \
        '--store=+[store dir]:dir:_files -/' \
        '--config=+[config file]:file:_files' \
        '--homeserver=+[homeserver]:url:_urls' \
        '--user-login=+[user id]:str:' \
        '--password=+[password]:str:' \
        '--device=+[device name]:str:' \
        '--room-default=+[default room]:str:' \
        '--access-token=+[access token]:str:' \
        '--no-ssl[skip ssl]' \
        '--ssl-certificate=+[ssl cert]:file:_files' \
        '--verify=+[verify]:v:(emoji manual)' \
        '--proxy=+[proxy]:url:_urls' \
        '--message=+[message]:str:' \
        '-m+[message]:str:' \
        '*--image=+[image]:file:_files' \
        '*--audio=+[audio]:file:_files' \
        '*--file=+[file]:file:_files' \
        '*--event=+[event]:str:' \
        '--html[html message]' \
        '--markdown[markdown message]' \
        '--code[code message]' \
        '--emojize[emojize]' \
        '*--room=+[room]:str:' \
        '*--room-create=+[room name]:str:' \
        '*--room-leave=+[room]:str:' \
        '*--room-forget=+[room]:str:' \
        '*--room-invite=+[user]:str:' \
        '*--room-join=+[room]:str:' \
        '*--room-ban=+[user]:str:' \
        '*--room-unban=+[user]:str:' \
        '*--room-kick=+[user]:str:' \
        '--listen=+[listen mode]:l:(forever once tail all)' \
        '--listen-self[include self]' \
        '--tail=+[tail count]:n:' \
        '--rooms[list rooms]' \
        '--joined-rooms[list joined rooms]' \
        '--joined-members=+[room]:str:' \
        '--mxc-to-http=+[mxc]:str:' \
        '--devices[list devices]' \
        '--whoami[show whoami]' \
        '--get-display-name[get display name]' \
        '--set-display-name=+[name]:str:' \
        '--get-avatar[get avatar]' \
        '--set-avatar=+[mxc]:str:' \
        '--export-keys=+[file]:file:_files' \
        '--import-keys=+[file]:file:_files' \
        '--get-room-info=+[room]:str:' \
        '--upload=+[file]:file:_files' \
        '--download=+[mxc]:str:' \
        '--delete-mxc=+[mxc]:str:' \
        '--debug[debug]' \
        '-d[debug]' \
        '--log-level=+[log level]:l:(debug info warning error critical)' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--json[json output]' \
        '*:arg:'
}

_matrix-cli "$@"
