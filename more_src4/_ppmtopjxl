#compdef ppmtopjxl
# Documentation: man ppmtopjxl (Netpbm)
# Source: convert a PPM image to HP PaintJet XL printer commands.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-nopack[disable run-length packing]' \
    '-gamma+[gamma correction]:n:' \
    '-presentation[presentation quality]' \
    '-dark[darker print]' \
    '-diffuse[error-diffusion dither]' \
    '-cluster[cluster dither]' \
    '-dither[basic dither]' \
    '-xshift+[horizontal shift]:s:' \
    '-yshift+[vertical shift]:s:' \
    '(-xsize -width -xscale)'{-xsize+,-width+,-xscale+}'[output width or scale]:s:' \
    '(-ysize -height -yscale)'{-ysize+,-height+,-yscale+}'[output height or scale]:s:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
