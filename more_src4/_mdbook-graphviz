#compdef mdbook-graphviz
# Documentation: https://github.com/dylanowen/mdbook-graphviz
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '1:command:(supports)' \
  '2:renderer:' && ret=0

return ret
