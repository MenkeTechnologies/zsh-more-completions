#compdef plotxy
# Documentation: https://manpages.debian.org/bookworm/astrometry.net/plotxy.1.en.html
# Source: dstndstn/astrometry.net blind/plotxy.c — plot XY catalogue markers over an image (PPM/PNG/PDF).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input xylist]:file:_files' \
    '-o+[output file (default stdout)]:file:_files' \
    '-I+[input image (PPM by default)]:file:_files -g "*.(ppm|png)(-.)"' \
    '-p[input image is PNG (not PPM)]' \
    '-P[write PPM output (not PNG)]' \
    '-J[write PDF output]' \
    '-W+[output image width]:px:_default' \
    '-H+[output image height]:px:_default' \
    '-x+[X offset of bottom-left pixel (default 1)]:value:_default' \
    '-y+[Y offset of bottom-left pixel (default 1)]:value:_default' \
    '-X+[X column name]:name:_default' \
    '-Y+[Y column name]:name:_default' \
    '-n+[first object index (default 0)]:n:_default' \
    '-N+[number of objects to plot (default all)]:n:_default' \
    '-r+[marker size (default 5.0)]:value:_default' \
    '-w+[linewidth (default 1.0)]:value:_default' \
    '-s+[marker shape]:shape:(circle crosshair square diamond X Xcrosshair)' \
    '-C+[marker color]:color:(red blue white black cyan magenta yellow green orange)' \
    '-b+[background marker color]:color:(red blue white black cyan magenta yellow green orange)' \
    '-S+[xylist scale factor]:value:_default' \
    '-e+[FITS extension (default 0)]:n:_default' \
    && ret=0

return ret
