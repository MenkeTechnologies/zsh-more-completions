#compdef osnadmin peer
# Documentation: upstream docs at hyperledger-fabric.readthedocs.io/en/latest/commands/{peer,peerchaincode,peerchannel,peernode,peerlifecycle,osnadminchannel}.html
# Reference accessed: 2026-05-30
# Hyperledger Fabric multi-binary harvest R45 — orderer-admin + peer
# nodes from fabric/cmd/. Continues R44 (configtxgen/configtxlator/
# cryptogen).

local curcontext="$curcontext" state line ret=1

case $service in

  osnadmin)
    # hyperledger/fabric osnadmin — orderer-service-node admin tool.
    # Top-level only carries `channel` group; nested 5-action enum.
    local -a _toplevel
    _toplevel=(
      'channel:manage channels on an OSN'
    )
    local -a _chactions
    _chactions=(
      'join:join OSN to a channel (creates it if needed)'
      'list:list channel info for an OSN'
      'remove:remove channel from an OSN'
      'update:modify channel configuration on an OSN'
      'fetch:fetch a block + save to file'
    )
    _arguments -C -s -S \
      '(-): :->topcmd' \
      '(-)*:: :->topcmd_args' \
      && ret=0
    case $state in
      topcmd)
        _describe -t commands 'osnadmin subcommand' _toplevel && ret=0
        ;;
      topcmd_args)
        case $words[1] in
          channel)
            _arguments -C \
              '(-): :->chcmd' \
              '(-)*:: :->chcmd_args' \
              '(-o --orderer-address)-o+[admin endpoint address]:address:' \
              '(-o --orderer-address)--orderer-address=[admin endpoint address]:address:' \
              '--ca-file=[TLS CA certificate file]:file:_files' \
              '--client-cert=[mutual-TLS X509 public key file]:file:_files' \
              '--client-key=[mutual-TLS private key file]:file:_files' \
              '--no-status[suppress HTTP status messages]' \
              '--help[show help]' && ret=0
            case $state in
              chcmd)
                _describe -t commands 'osnadmin channel action' _chactions && ret=0
                ;;
              chcmd_args)
                case $words[1] in
                  join)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' \
                      '(-b --config-block)-b+[config block file]:file:_files' \
                      '(-b --config-block)--config-block=[config block file]:file:_files' && ret=0
                    ;;
                  list)
                    _arguments \
                      '(-c --channelID)-c+[channel ID (for detail)]:channel:' \
                      '(-c --channelID)--channelID=[channel ID (for detail)]:channel:' && ret=0
                    ;;
                  remove)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' && ret=0
                    ;;
                  update)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' \
                      '(-e --config-update-envelope)-e+[config-update envelope]:file:_files' \
                      '(-e --config-update-envelope)--config-update-envelope=[config-update envelope]:file:_files' \
                      '(-t --tlsHandshakeTimeShift)-t+[TLS handshake time-shift]:duration:' \
                      '(-t --tlsHandshakeTimeShift)--tlsHandshakeTimeShift=[TLS handshake time-shift]:duration:' && ret=0
                    ;;
                  fetch)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' \
                      '(-b --blockID)-b+[block ID]:block:' \
                      '(-b --blockID)--blockID=[block ID]:block:' \
                      '(-f --outputfile)-f+[output file]:file:_files' \
                      '(-f --outputfile)--outputfile=[output file]:file:_files' \
                      '(-t --tlsHandshakeTimeShift)-t+[TLS handshake time-shift]:duration:' \
                      '(-t --tlsHandshakeTimeShift)--tlsHandshakeTimeShift=[TLS handshake time-shift]:duration:' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;

  peer)
    # hyperledger/fabric peer — main Fabric peer-node client.
    local -a _toplevel
    _toplevel=(
      'chaincode:deploy + manage smart contract chaincode (invoke/query)'
      'channel:manage channel operations'
      'node:manage peer node operations'
      'lifecycle:chaincode lifecycle operations'
      'version:show version'
    )
    local -a _chaincode_subs
    _chaincode_subs=(
      'invoke:invoke a chaincode (commit endorsed tx)'
      'query:get endorsed result of a chaincode function call'
    )
    local -a _channel_subs
    _channel_subs=(
      'create:create a channel (DEPRECATED)'
      'fetch:fetch a block'
      'getinfo:get blockchain info'
      'join:join the peer to a channel'
      'joinbysnapshot:join the peer to a channel by snapshot'
      'joinbysnapshotstatus:query if joinbysnapshot is running'
      'list:list channels the peer has joined'
      'signconfigtx:sign a configtx update'
      'update:send a configtx update'
    )
    local -a _node_subs
    _node_subs=(
      'pause:pause the peer on a channel'
      'rebuild-dbs:rebuild databases'
      'reset:reset peer node databases'
      'resume:resume the peer on a channel'
      'rollback:roll back to a target block'
      'start:start the peer node'
      'unjoin:unjoin from a channel'
      'upgrade-dbs:upgrade databases'
    )
    local -a _lifecycle_subs
    _lifecycle_subs=(
      'chaincode:chaincode lifecycle (10-action group)'
    )
    local -a _lifecycle_cc_actions
    _lifecycle_cc_actions=(
      'package:package a chaincode'
      'install:install a chaincode'
      'queryinstalled:query installed chaincodes'
      'getinstalledpackage:get an installed chaincode package'
      'calculatepackageid:calculate the package ID'
      'approveformyorg:approve chaincode definition for my org'
      'queryapproved:query approved chaincode definitions'
      'checkcommitreadiness:check chaincode commit-readiness'
      'commit:commit chaincode definition on the channel'
      'querycommitted:query committed chaincode definitions'
    )
    local -a _global_flags
    _global_flags=(
      '--cafile=[PEM trusted certificate for orderer]:file:_files'
      '--certfile=[PEM X509 public key for mutual TLS]:file:_files'
      '--clientauth[mutual TLS with orderer]'
      '--connTimeout=[connection timeout (default 3s)]:duration:'
      '--keyfile=[PEM private key for mutual TLS]:file:_files'
      '(-o --orderer)-o+[ordering service endpoint]:address:'
      '(-o --orderer)--orderer=[ordering service endpoint]:address:'
      '--ordererTLSHostnameOverride=[TLS hostname override]:hostname:'
      '--tls[enable TLS with orderer]'
      '--tlsHandshakeTimeShift=[TLS handshake time shift]:duration:'
      '--help[show help]'
    )
    _arguments -C -s -S \
      '(-): :->topcmd' \
      '(-)*:: :->topcmd_args' \
      && ret=0
    case $state in
      topcmd)
        _describe -t commands 'peer subcommand' _toplevel && ret=0
        ;;
      topcmd_args)
        case $words[1] in
          chaincode)
            _arguments -C \
              '(-): :->cccmd' \
              '(-)*:: :->cccmd_args' \
              "${_global_flags[@]}" && ret=0
            case $state in
              cccmd)
                _describe -t commands 'peer chaincode subcommand' _chaincode_subs && ret=0
                ;;
              cccmd_args)
                case $words[1] in
                  invoke)
                    _arguments \
                      '(-C --channelID)-C+[channel ID]:channel:' \
                      '(-C --channelID)--channelID=[channel ID]:channel:' \
                      '(-c --ctor)-c+[constructor message (JSON)]:json:' \
                      '(-c --ctor)--ctor=[constructor message (JSON)]:json:' \
                      '(-n --name)-n+[chaincode name]:name:' \
                      '(-n --name)--name=[chaincode name]:name:' \
                      '*--peerAddresses=[peer connection addresses (repeatable)]:address:' \
                      '--waitForEvent[wait for commit confirmation]' && ret=0
                    ;;
                  query)
                    _arguments \
                      '(-C --channelID)-C+[channel ID]:channel:' \
                      '(-C --channelID)--channelID=[channel ID]:channel:' \
                      '(-c --ctor)-c+[constructor message (JSON)]:json:' \
                      '(-c --ctor)--ctor=[constructor message (JSON)]:json:' \
                      '(-n --name)-n+[chaincode name]:name:' \
                      '(-n --name)--name=[chaincode name]:name:' \
                      '*--peerAddresses=[peer connection addresses (repeatable)]:address:' \
                      '(-x --hex)-x[output as hex]' \
                      '(-x --hex)--hex[output as hex]' \
                      '(-r --raw)-r[output as raw bytes]' \
                      '(-r --raw)--raw[output as raw bytes]' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          channel)
            _arguments -C \
              '(-): :->chcmd' \
              '(-)*:: :->chcmd_args' \
              "${_global_flags[@]}" && ret=0
            case $state in
              chcmd)
                _describe -t commands 'peer channel subcommand' _channel_subs && ret=0
                ;;
              chcmd_args)
                case $words[1] in
                  join)
                    _arguments \
                      '(-b --blockpath)-b+[genesis block file]:file:_files' \
                      '(-b --blockpath)--blockpath=[genesis block file]:file:_files' && ret=0
                    ;;
                  joinbysnapshot)
                    _arguments \
                      '--snapshotpath=[snapshot directory]:directory:_directories' && ret=0
                    ;;
                  fetch)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' \
                      '--bestEffort[ignore errors]' && ret=0
                    ;;
                  create)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' \
                      '(-f --file)-f+[configtx file]:file:_files' \
                      '(-f --file)--file=[configtx file]:file:_files' \
                      '(-t --timeout)-t+[timeout]:duration:' \
                      '(-t --timeout)--timeout=[timeout]:duration:' && ret=0
                    ;;
                  getinfo|signconfigtx|update)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' \
                      '(-f --file)-f+[file]:file:_files' \
                      '(-f --file)--file=[file]:file:_files' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          node)
            _arguments -C \
              '(-): :->ncmd' \
              '(-)*:: :->ncmd_args' && ret=0
            case $state in
              ncmd)
                _describe -t commands 'peer node subcommand' _node_subs && ret=0
                ;;
              ncmd_args)
                case $words[1] in
                  pause|resume|unjoin)
                    _arguments \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' && ret=0
                    ;;
                  rollback)
                    _arguments \
                      '(-b --blockNumber)-b+[target block number]:N:' \
                      '(-b --blockNumber)--blockNumber=[target block number]:N:' \
                      '(-c --channelID)-c+[channel ID]:channel:' \
                      '(-c --channelID)--channelID=[channel ID]:channel:' && ret=0
                    ;;
                  start)
                    _arguments \
                      '--peer-chaincodedev[enable chaincode development mode]' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
          lifecycle)
            _arguments -C \
              '(-): :->lcmd' \
              '(-)*:: :->lcmd_args' \
              "${_global_flags[@]}" && ret=0
            case $state in
              lcmd)
                _describe -t commands 'peer lifecycle subcommand' _lifecycle_subs && ret=0
                ;;
              lcmd_args)
                case $words[1] in
                  chaincode)
                    _arguments \
                      '1:lifecycle chaincode action:(($_lifecycle_cc_actions))' && ret=0
                    ;;
                esac
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;

esac

return ret
