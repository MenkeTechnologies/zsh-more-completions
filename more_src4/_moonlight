#compdef moonlight
# Documentation: https://github.com/moonlight-stream/moonlight-qt/blob/master/app/cli/commandlineparser.cpp
# Reference accessed: 2026-05-19
# Verified: upstream commandlineparser.cpp defines actions and flags.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'pair:pair a new host'
  'stream:start streaming an app'
  'list:list the available apps on a host'
  'quit:quit the currently running app'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '1:command:->command' \
  '*::arg:->args' && ret=0

case $state in
  command)
    _describe -t commands 'moonlight command' commands && ret=0
    ;;
  args)
    case $words[1] in
      pair)
        _arguments \
          '--pin=[4-digit pairing PIN]:pin:' \
          '1:host:_hosts' && ret=0
        ;;
      list)
        _arguments \
          '--csv[output as CSV]' \
          '--verbose[display additional information]' \
          '1:host:_hosts' && ret=0
        ;;
      quit)
        _arguments \
          '1:host:_hosts' && ret=0
        ;;
      stream)
        _arguments \
          '--720[use 1280x720 resolution]' \
          '--1080[use 1920x1080 resolution]' \
          '--1440[use 2560x1440 resolution]' \
          '--4K[use 3840x2160 resolution]' \
          '--resolution=[custom WxH resolution]:WxH:' \
          '--fps=[target FPS]:fps:' \
          '--bitrate=[bitrate in Kbps]:bitrate' \
          '--packet-size=[video packet size]:size' \
          '--audio-config=[audio configuration]:cfg:(stereo 5.1-surround 7.1-surround)' \
          '--video-codec=[video codec]:codec:(auto H.264 HEVC AV1)' \
          '--video-decoder=[video decoder]:decoder:(auto software hardware)' \
          '--hdr[enable HDR streaming]' \
          '--no-hdr[disable HDR streaming]' \
          '--yuv444[enable YUV 4:4:4]' \
          '--no-yuv444[disable YUV 4:4:4]' \
          '--display-mode=[display mode]:mode:(fullscreen windowed borderless)' \
          '--vsync[enable vsync]' \
          '--no-vsync[disable vsync]' \
          '--multi-controller[enable multiple controllers]' \
          '--no-multi-controller[disable multiple controllers]' \
          '--absolute-mouse[absolute mouse mode]' \
          '--no-absolute-mouse[relative mouse mode]' \
          '--mouse-buttons-swap[swap mouse buttons]' \
          '--no-mouse-buttons-swap[do not swap mouse buttons]' \
          '--touchscreen-trackpad[trackpad mode for touchscreen]' \
          '--no-touchscreen-trackpad[disable trackpad mode]' \
          '--background-gamepad[allow background gamepad input]' \
          '--no-background-gamepad[disable background gamepad input]' \
          '--swap-gamepad-buttons[Nintendo-style button layout]' \
          '--no-swap-gamepad-buttons[standard button layout]' \
          '--reverse-scroll-direction[invert scroll]' \
          '--no-reverse-scroll-direction[do not invert scroll]' \
          '--capture-system-keys=[when to capture system keys]:when:(never fullscreen always)' \
          '--quit-after[quit app after streaming]' \
          '--no-quit-after[do not quit app after streaming]' \
          '--audio-on-host[play audio on host PC]' \
          '--no-audio-on-host[play audio on client]' \
          '--game-optimization[enable game optimizations]' \
          '--no-game-optimization[disable game optimizations]' \
          '--frame-pacing[enable frame pacing]' \
          '--no-frame-pacing[disable frame pacing]' \
          '--mute-on-focus-loss[mute audio on focus loss]' \
          '--no-mute-on-focus-loss[keep audio on focus loss]' \
          '--keep-awake[prevent display sleep]' \
          '--no-keep-awake[allow display sleep]' \
          '--performance-overlay[show performance overlay]' \
          '--no-performance-overlay[hide performance overlay]' \
          '--app=[app name]:app' \
          '1:host:_hosts' && ret=0
        ;;
    esac
    ;;
esac

return ret
