#compdef ppmhist
# Documentation: man ppmhist (Netpbm)
# Source: print a histogram of the colors in a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-map -nomap)-map[output as a PPM colormap]' \
    '(-map -nomap)-nomap[text output (default)]' \
    '(-hexcolor -float -colorname)-hexcolor[hex color output]' \
    '(-hexcolor -float -colorname)-float[float color output]' \
    '(-hexcolor -float -colorname)-colorname[symbolic color names]' \
    '-noheader[omit header]' \
    '-sort=[sort order]:order:(frequency rgb)' \
    '-forensic[forensic-style detailed report]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
