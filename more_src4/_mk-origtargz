#compdef mk-origtargz
# Documentation: https://manpages.debian.org/mk-origtargz
# Source: debian/devscripts scripts/mk-origtargz.pl — rename upstream tarball to dpkg-buildpackage format (Perl).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--help[show help]' \
    '--version[show version]' \
    '--package=-[override source package name]:package:_default' \
    '*--exclude-file=-[additional exclude glob]:glob:_default' \
    '*--include-file=-[additional include glob]:glob:_default' \
    '--copyright-file=-[copyright file]:file:_files' \
    '--signature=-[signature mode]:mode:(0 1 2 3)' \
    '--signature-file=-[signature file]:file:_files -g "*.{asc,sig}"' \
    '(--copy --rename)--symlink[use symlinks (default)]' \
    '(--symlink --rename)--copy[copy file instead of symlinking]' \
    '(--symlink --copy)--rename[rename file]' \
    '(--force-repack)--repack[repack tarball]' \
    '(--repack)--force-repack[repack even when uncompressing only]' \
    '--compression=-[compression]:method:(gzip bzip2 lzma xz default)' \
    '--unzipopt=-[options for unzip]:opts:_default' \
    '*--directory=-[output directory]:dir:_files -/' \
    '1:upstream tarball:_files -g "*.{tar.gz,tgz,tar.bz2,tbz,tar.xz,txz,tar.lzma,zip,jar,xpi}"' \
    && ret=0

return ret
