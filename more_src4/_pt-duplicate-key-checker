#compdef pt-duplicate-key-checker
# Documentation: https://docs.percona.com/percona-toolkit/pt-duplicate-key-checker.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[show help]' \
  '--version[show version]' \
  '--all-structs[compare indexes with different structures]' \
  '--ask-pass[prompt for password]' \
  '(--buffer-stdout --no-buffer-stdout)'{--buffer-stdout,--no-buffer-stdout}'[enable/disable STDOUT buffering]' \
  '--charset=[default character set]:charset:' \
  '(--clustered --no-clustered)'{--clustered,--no-clustered}'[detect PK columns appended to secondary keys]' \
  '--config=[comma-separated config files]:files:_files' \
  '--databases=[examine only these databases]:dbs:' \
  '--defaults-file=[MySQL defaults file]:file:_files' \
  '--engines=[check only these storage engines]:engines:' \
  '--host=[MySQL host]:host:_hosts' \
  '--ignore-databases=[skip these databases]:list:' \
  '--ignore-engines=[skip these storage engines]:list:' \
  '--ignore-order[treat KEY(a,b) and KEY(b,a) as duplicates]' \
  '--ignore-tables=[skip these tables]:list:' \
  '--invisible[mark indexes INVISIBLE instead of dropping]' \
  '--key-types=[key types to check]:types:(f k fk)' \
  '--mysql_ssl=[create SSL MySQL connection]:n:' \
  '--password=[MySQL password]:pw:' \
  '--pid=[PID file]:file:_files' \
  '--port=[MySQL port]:port:' \
  '--set-vars=[set MySQL variables]:vars:' \
  '--socket=[MySQL socket]:file:_files' \
  '(--sql --no-sql)'{--sql,--no-sql}'[print DROP KEY statements]' \
  '(--summary --no-summary)'{--summary,--no-summary}'[print summary of indexes at end]' \
  '--tables=[examine only these tables]:tables:' \
  '--user=[MySQL user]:user:' \
  '--verbose[output all keys/foreign keys not just redundant ones]' \
  '(--version-check --no-version-check)'{--version-check,--no-version-check}'[check for latest versions]' \
  '*:DSN:' && ret=0

return ret
