#compdef osquery-cli
# _osquery-cli — Facebook Meta osquery-cli CLI command-line frontend wrapping the osquery open-source-Linux-Origin endpoint-visibility-as-SQL operating-system-instrumentation framework SQL-tables for OS state CIS-CI-CD security-incident-response and compliance auditing platform CLI providing osqueryi osqueryd osqueryctl interactive-prompt query pack remote-server tls config file flag log-result decorators platform-arch-os-system-info SCAP YARA process-events-block-protected_hashes virtual-tables (Facebook osquery team, C++); custom argparse
# upstream: https://osquery.io/

_osquery-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--flagfile=+[file]:file:_files -g "*.flags *.txt"' \
        '--config_path=+[file]:file:_files -g "osquery.conf *.conf *.json"' \
        '--config_plugin=+[name]:str:' \
        '--config_refresh=+[sec]:n:' \
        '--logger_plugin=+[name]:str:' \
        '--logger_path=+[dir]:dir:_files -/' \
        '--logger_min_status=+[N]:n:' \
        '--logger_min_stderr=+[N]:n:' \
        '--logger_syslog_facility=+[N]:n:' \
        '--database_path=+[dir]:dir:_files -/' \
        '--pidfile=+[file]:file:_files -g "*.pid"' \
        '--watchdog_level=+[N]:n:' \
        '--watchdog_memory_limit=+[MB]:n:' \
        '--watchdog_utilization_limit=+[N]:n:' \
        '--worker_threads=+[N]:n:' \
        '--enable_extensions_watchdog[enable extensions watchdog]' \
        '--extensions_socket=+[path]:_files' \
        '--extensions_autoload=+[file]:file:_files' \
        '--extensions_timeout=+[sec]:n:' \
        '--extensions_interval=+[sec]:n:' \
        '--extensions_default_index=+[N]:n:' \
        '--audit_allow_config[allow audit config]' \
        '--audit_allow_process_events[allow process events]' \
        '--audit_allow_sockets[allow socket events]' \
        '--audit_allow_user_events[allow user events]' \
        '--audit_allow_apparmor_events[allow apparmor events]' \
        '--audit_allow_selinux_events[allow selinux events]' \
        '--enable_file_events[enable file events]' \
        '--enable_syslog[enable syslog]' \
        '--syslog_pipe_path=+[path]:_files' \
        '--syslog_rate_limit=+[N]:n:' \
        '--schedule_default_interval=+[sec]:n:' \
        '--schedule_splay_percent=+[N]:n:' \
        '--utc[force UTC]' \
        '--json[JSON output]' \
        '--A+[table or column]:str:' \
        '--header[show header]' \
        '--separator=+[char]:str:' \
        '--line[line mode]' \
        '--list[list tables]' \
        '--S[single mode]' \
        '*:sql query:'
}

_osquery-cli "$@"
