#compdef mstprivhost mlxprivhost
# Documentation: https://docs.nvidia.com/networking/display/MFT/mlxprivhost+-+NIC+Configuration+by+the+Host+Restriction+Tool+(Zero+Trust+Mode)
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'r:restrict the host'
  'restrict:restrict the host'
  'p:privilege (un-restrict) the host'
  'privilege:privilege (un-restrict) the host'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --device)'{-d+,--device=}'[mst device]:dev:' \
  '--disable_rshim[disable rshim on host]' \
  '--disable_tracer[disable tracer on host]' \
  '--disable_counter_rd[disable counter read on host]' \
  '--disable_port_owner[disable port ownership on host]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mlxprivhost command' commands && ret=0 ;;
esac
return ret
