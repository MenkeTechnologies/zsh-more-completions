#compdef packagekit-cli pkcon
# _packagekit-cli — Freedesktop PackageKit distribution-agnostic package manager CLI alias (Freedesktop / Richard Hughes, C); custom argparse
# upstream: https://github.com/PackageKit/PackageKit

_packagekit-cli() {
    local -a sub=(
        'accept-eula:accept EULA'
        'backend-details:show backend details'
        'depends-on:show dependencies'
        'download:download packages'
        'get-categories:list categories'
        'get-distro-upgrades:list distro upgrades'
        'get-files:show files'
        'get-files-local:get files local'
        'get-roles:get roles'
        'get-time:get time'
        'get-update-detail:show update details'
        'get-updates:list available updates'
        'help:show help'
        'install:install packages'
        'install-local:install local file'
        'install-package:install package by id'
        'list-create:create catalog'
        'offline-get-prepared:get prepared offline transaction'
        'offline-status:get offline transaction status'
        'offline-trigger:trigger offline update'
        'refresh:refresh package cache'
        'remove:remove packages'
        'repo-list:list repos'
        'repo-disable:disable repo'
        'repo-enable:enable repo'
        'repo-remove:remove repo'
        'repo-set-data:set repo data'
        'required-by:show dependents'
        'resolve:resolve package'
        'search:search packages'
        'update:update packages'
        'upgrade-system:upgrade distribution'
        'what-provides:show what provides'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--background[background]' \
        '--noninteractive[non interactive]' \
        '-y[assume yes]' \
        '--allow-untrusted[allow untrusted]' \
        '--filter=+[filter]:list:(arch ~arch basename ~basename collections ~collections devel ~devel downloaded ~downloaded free ~free gui ~gui installed ~installed newest ~newest source ~source supported ~supported visible ~visible)' \
        '--root=+[root]:dir:_files -/' \
        '--no-color[no color]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pkcon subcommand' sub ;;
        args)
            case $words[1] in
                install|remove|update|search|resolve|depends-on|required-by|download|get-files|get-update-detail|install-package|install-local|what-provides|accept-eula) _arguments '*:package-or-file:_files' ;;
                repo-enable|repo-disable|repo-remove|repo-set-data) _arguments '*:repo-id:' ;;
            esac
            ;;
    esac
}

_packagekit-cli "$@"
