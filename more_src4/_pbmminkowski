#compdef pbmminkowski
# Documentation: man pbmminkowski (Netpbm)
# Source: compute Minkowski functionals (area, perimeter, Euler characteristic) for a PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pbm file:_files -g "*.(pbm|pnm|pam)"' \
    && ret=0

return ret
