#compdef pbmtext
# Documentation: man pbmtext (Netpbm)
# Source: render text into a PBM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-wchar[wide-character (Unicode) mode]' \
    '-font=[BDF font file]:font:_files' \
    '-builtin=[built-in font]:font:(bdf fixed)' \
    '-space=[inter-character spacing in pixels]:pixels:' \
    '-lspace=[line spacing in pixels]:pixels:' \
    '-nomargins[omit margins around text]' \
    '-width=[maximum line width in pixels]:pixels:' \
    '-load-entire-font[load whole font (faster for many chars)]' \
    '-verbose[verbose output]' \
    '-dry-run[do not render image]' \
    '-text-dump[print text instead of image]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:text:' \
    && ret=0

return ret
