#compdef ppmtoilbm
# Documentation: man ppmtoilbm (Netpbm)
# Source: convert a PPM image to Amiga IFF ILBM (with HAM and 24-bit support).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-maxplanes -mp)'{-maxplanes+,-mp+}'[max bit planes]:n:' \
    '(-fixplanes -fp)'{-fixplanes+,-fp+}'[fixed bit planes]:n:' \
    '(-ham6 -ham8)-ham6[6-plane HAM]' \
    '(-ham6 -ham8)-ham8[8-plane HAM]' \
    '(-dcbits -dcplanes)'{-dcbits+,-dcplanes+}'[DirectColor bit-planes r g b]:r:' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-normal[normal palette ILBM]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-hamif[HAM if input is true color]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-hamforce[force HAM output]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-24if[24-bit if true color]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-24force[force 24-bit ILBM]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-dcif[DirectColor if true color]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-dcforce[force DirectColor]' \
    '(-normal -hamif -hamforce -24if -24force -dcif -dcforce -cmaponly)-cmaponly[output only the colormap]' \
    '(-ecs -aga)-ecs[ECS color limits]' \
    '(-ecs -aga)-aga[AGA color limits]' \
    '(-compress -nocompress)-compress[ByteRun1 compression]' \
    '(-compress -nocompress)-nocompress[no compression]' \
    '-cmethod+[compression method]:method:(none byterun1)' \
    '-map+[external colormap file]:file:_files -g "*.(ppm|pnm|pam)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
