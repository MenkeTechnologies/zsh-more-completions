#   Binary     : percli  (the Perses CLI; alongside the
#                 separately-built `perses` daemon at cmd/perses/
#                 which is the Perses API server)
#   Last push  : 2026-06-02
#
# WHAT IT IS
#   Perses is the **CNCF Sandbox project for observability
#   dashboarding** — positioned as the Kubernetes-native +
#   GitOps-native successor to Grafana for cloud-native
#   deployments.  Architectural differences vs. Grafana:
#
#     • **Dashboards as Code** — every dashboard is a typed
#       Cuelang or YAML manifest committed to git.  The
#       Perses API server is the runtime; the source of
#       truth is the file in your monorepo.
#     • **Typed schema** — every dashboard, datasource,
#       variable, panel, and project is a typed CRD-style
#       Kubernetes resource with strict JSON Schema
#       validation (`percli lint -f`)
#     • **API-first** — every operation is REST-driven; the
#       web UI is a thin frontend over the same REST API
#       that `percli` talks to
#     • **Kubernetes-native** — runs as a single statically-
#       linked Go binary, deploys as a Kubernetes Operator
#       with Custom Resource Definitions
#     • **Multi-tenant** — typed Projects scope every
#       resource; users have per-project RBAC
#     • **OIDC SSO** — every admin action is authenticated
#       against an external IdP via the zitadel/oidc client
#       library (no built-in user database other than for
#       service accounts)
#
#   The `percli` CLI is the GitOps-style operator entry point:
#
#     • `percli login`              authenticate to a Perses
#                                    server (interactive
#                                    browser-based OIDC flow,
#                                    or non-interactive
#                                    `--username` / `--password`
#                                    for the local-database
#                                    auth provider, or
#                                    `--token` for direct
#                                    Bearer-token use)
#     • `percli apply -f dashboard.yaml`  push a typed
#                                          dashboard to the
#                                          API server (the
#                                          canonical "kubectl
#                                          apply" pattern)
#     • `percli get dashboards`     list dashboards
#     • `percli describe dashboard <name>`  describe a typed
#                                            dashboard
#     • `percli delete dashboard <name>`    delete a dashboard
#     • `percli refresh`            refresh local credentials
#     • `percli whoami`             print authenticated user
#                                    info
#     • `percli lint -f`            JSON Schema validate a
#                                    YAML dashboard before
#                                    committing
#     • `percli migrate -f grafana.json`  convert a Grafana
#                                          dashboard JSON
#                                          export to a Perses
#                                          dashboard YAML
#     • `percli dac`                Dashboards-as-Code Cuelang
#                                    primitives (build,
#                                    preview, generate)
#     • `percli plugin`             Perses plugin management
#     • `percli project`            Project (multi-tenant
#                                    scope) management
#     • `percli conf`               local CLI config
#                                    management
#     • `percli version`            print version
#
# CLI ARGUMENT GRAMMAR  (verbatim from cmd/percli/main.go cobra
#                       `newRootCommand()` + each
#                       `internal/cli/cmd/<sub>/cmd.go`'s
#                       `NewCMD()` function;  extracted via
#                       raw.githubusercontent.com fetch of
#                       cmd/percli/main.go)
#
#   percli [GLOBAL OPTIONS] <COMMAND> [SUBCOMMAND] [ARGS...]
#
#   Global options:
#     -h, --help                     Show help
#     --percliconfig <PATH>          Path to the percliconfig
#                                    file (the OS-canonical
#                                    `~/.config/perses/
#                                    percliconfig.yaml` is the
#                                    default)
#     --log.level <LEVEL>            Log verbosity
#                                    [default: info]
#                                    [values: panic, fatal,
#                                             error, warning,
#                                             info, debug,
#                                             trace]
#
#   Commands:
#     apply                          Apply a Perses resource
#                                    from a YAML/JSON file
#                                    (canonical "kubectl apply"
#                                    pattern)
#         -f, --file <PATH>          Resource file to apply
#                                    (repeatable; supports
#                                    YAML or JSON)
#         -d, --directory <DIR>      Apply all YAML/JSON files
#                                    in directory
#     conf                           Manage local percli config
#     dac                            Dashboards-as-Code (Cuelang)
#         build                      Build DAC sources
#         preview                    Preview the rendered
#                                    dashboard
#         generate                   Generate DAC sources from
#                                    an existing dashboard
#     describe                       Describe a Perses resource
#                                    in detail
#         <KIND> <NAME>              e.g. `percli describe
#                                    dashboard my-dashboard`
#     get                            List Perses resources
#                                    (the "kubectl get" pattern)
#         <KIND> [NAME]              e.g. `percli get
#                                    dashboards`, `percli get
#                                    datasource prometheus`
#     lint                           Lint Perses resource files
#                                    (JSON Schema validation)
#         -f, --file <PATH>          Resource file to lint
#         -d, --directory <DIR>      Lint all files in directory
#     login                          Log in to a Perses server
#         <URL>                      Perses server URL
#         -u, --username <USER>      Username (local-database
#                                    auth)
#         -p, --password <PASS>      Password
#         -t, --token <TOKEN>        Bearer token (skip OIDC
#                                    flow)
#         --insecure-tls-skip-verify Skip TLS cert verification
#     migrate                        Migrate a Grafana
#                                    dashboard to a Perses
#                                    dashboard
#         -f, --file <PATH>          Grafana JSON file
#     plugin                         Manage Perses plugins
#     project                        Manage Perses projects
#                                    (multi-tenant scope)
#     refresh                        Refresh local credentials
#     remove                         Remove a Perses resource
#                                    (alias for `delete`)
#         <KIND> <NAME>              e.g. `percli remove
#                                    dashboard my-dashboard`
#     version                        Print version
#     whoami                         Print info about the
#                                    authenticated user
#
# AXIS / CORPUS POSITION
#   `perses/perses` declares a **direct** dependency on
#   `github.com/zitadel/oidc/v3 v3.47.5` in its `go.mod`
#   (verified via `gh api repos/perses/perses/contents/go.mod`).
#   The `internal/api/auth/oidc/` module and the per-route
#   middleware import the typed primitives via `use
#   "github.com/zitadel/oidc/v3/pkg/client/rp"` for the typed
#   Relying Party flow.
#
#   `zitadel/oidc` (`github.com/zitadel/oidc/v3`) is **THE
#   canonical Go OIDC library** — the ZITADEL team's reference
#   pure-Go implementation of the entire OAuth 2.0 + OpenID
#   Connect 1.0 protocol stack, in continuous active
#   development since 2021 with 850+ ★ on GitHub and millions
#   of all-time go.dev downloads.  It is the dominant Go OIDC
#   dependency by an order of magnitude — the alternatives are
#   either `coreos/go-oidc` (still maintained but with a
#   smaller surface; only the client + verifier paths, no
#   server side), `golang.org/x/oauth2` (plain OAuth 2.0
#   without OIDC), or `oauth2-proxy/oauth2-proxy`'s internal
#   helpers (vendor-locked).
#
#   zitadel/oidc/v3 ships:
#
#     • `pkg/oidc`                   the typed OIDC primitives —
#                                    typed `Tokens[IDTokenClaims]`
#                                    /  `IDTokenClaims`
#                                    /  `UserInfo`
#                                    /  `IntrospectionResponse`
#                                    typed claim envelopes;
#                                    every standard claim with
#                                    typed `claims.Subject` /
#                                    `claims.Audience` /
#                                    `claims.Issuer` /
#                                    `claims.Expiration` /
#                                    `claims.IssuedAt` /
#                                    `claims.AuthTime` /
#                                    `claims.Nonce` /  `claims.
#                                    AuthenticationContextClassReference`
#                                    /  `claims.Authentication
#                                    MethodsReferences` /
#                                    `claims.AuthorizedParty` /
#                                    `claims.Email` /  `claims.
#                                    EmailVerified` /  `claims.
#                                    PreferredUsername` /
#                                    `claims.Name` /
#                                    `claims.FamilyName` /
#                                    `claims.GivenName` /
#                                    `claims.MiddleName` /
#                                    `claims.Nickname` /
#                                    `claims.Profile` /
#                                    `claims.Picture` /
#                                    `claims.Website` /
#                                    `claims.Gender` /
#                                    `claims.Birthdate` /
#                                    `claims.Zoneinfo` /
#                                    `claims.Locale` /
#                                    `claims.PhoneNumber` /
#                                    `claims.PhoneNumberVerified`
#                                    /  `claims.Address` /
#                                    `claims.UpdatedAt`
#                                    typed accessors
#     • `pkg/op`                     the **server side** —
#                                    typed `OpenIDProvider`
#                                    /  `Provider` /  `Storage`
#                                    /  `AuthRequest`
#                                    /  `TokenRequest` /
#                                    `TokenIntrospectionResponse`
#                                    typed primitives for
#                                    implementing a typed OIDC
#                                    Provider (this is what
#                                    powers ZITADEL itself,
#                                    plus dex, Boruta, Logto,
#                                    Authelia, and other Go
#                                    OIDC providers)
#     • `pkg/client`                 the typed **client** /
#                                    Relying Party (RP) side
#     • `pkg/client/rp`              typed `rp.NewRelyingPartyOIDC
#                                    (issuer, clientID,
#                                    clientSecret, redirectURI,
#                                    scopes, options...)` typed
#                                    constructor;  typed
#                                    `rp.AuthURLHandler` /
#                                    `rp.CodeExchangeHandler` /
#                                    `rp.UserinfoCallback` typed
#                                    HTTP handler factories;
#                                    typed `rp.PKCE` (RFC 7636
#                                    Proof Key for Code
#                                    Exchange) /  `rp.WithSign
#                                    Algorithm` /  `rp.WithSign
#                                    edRequestObject` /
#                                    `rp.WithCustomDiscoveryUrl`
#                                    /  `rp.WithCustomScopes` /
#                                    `rp.WithVerifierOpts`
#                                    typed builder options
#     • `pkg/client/rs`              typed **resource server**
#                                    side (token introspection
#                                    for API gateways)
#     • Typed RFC 8628 Device
#       Authorization Grant         (the canonical "device
#                                    flow" for terminals,
#                                    smart TVs, IoT devices —
#                                    e.g. `aws sso login`)
#     • Typed RFC 7591 Dynamic
#       Client Registration         + RFC 7592 Configuration
#                                    Endpoint
#     • Typed RFC 7636 PKCE         mandatory for any modern
#                                    OAuth 2.0 public-client
#                                    flow
#     • Typed RFC 8252 OAuth 2.0
#       for Native Apps             with the typed PKCE +
#                                    typed
#                                    `urn:ietf:wg:oauth:2.0:oob`
#                                    out-of-band redirect URI
#                                    handling
#     • Typed RFC 9068 JWT Bearer
#       Tokens
#     • Typed RFC 9126 Pushed
#       Authorization Requests (PAR)
#     • Typed RFC 9207 Authorization
#       Server Issuer Identification (the iss-mismatch
#                                    detection that prevents
#                                    cross-IdP confused-deputy
#                                    attacks)
#     • Typed OIDC Discovery 1.0
#       endpoint (`/.well-known/
#       openid-configuration`)       client + server
#                                    implementations
#     • Typed OIDC Dynamic Client
#       Registration 1.0           via the typed Storage
#                                    interface
#     • Typed JWT validation
#       chain (JWS, RS256, RS384,
#       RS512, PS256, PS384, PS512,
#       ES256, ES384, EdDSA,
#       HS256, HS384, HS512)
#     • Typed JWKS rotation         via the typed `JwkSetUrl`
#                                    discovery + caching layer
#     • Typed OAuth 2.0 Form-Post
#       Response Mode               (RFC 6749 + draft-ietf-
#                                    oauth-form-post-response-
#                                    mode)
#
#   `zitadel/oidc` is the OIDC library behind essentially every
#   modern Go OIDC integration in production:
#
#     • **ZITADEL** — the canonical open-source IdP that
#       sponsors zitadel/oidc (12,000+ ★ on github.com/zitadel/
#       zitadel)
#     • **Gravitational Teleport** — the identity-aware access
#       proxy (covered in this corpus on a prior axis)
#     • **Gitpod** — the cloud development environment
#       (8,000+ ★)
#     • **Photoprism** — AI-powered photos app (39,737+ ★;
#       covered as `_photoprism`)
#     • **Gotify** — push notification server (15,079+ ★;
#       covered as `_gotify`)
#     • **InfluxData Telegraf** — observability data pipeline
#     • **Gardener** — Kubernetes-as-a-Service control plane
#     • **OpenZiti zrok** — secure internet sharing (4,451+ ★;
#       covered as `_zrok`)
#     • **OpenZiti ziti** — programmable zero-trust
#       networking control plane
#     • **SigNoz** — open-source observability platform
#     • **Yopass** — secure secret sharing (2,813+ ★)
#     • **Perses** (this very project; the CNCF Sandbox
#       observability dashboarding platform)
#     • **Lxc/Incus-OS** — the Incus container/VM management
#       platform's OS image
#     • **Common Fate** — the IAM platform
#     • **EdgeX Foundry App Service Configurable** — IoT edge
#       platform
#     • **Project PLATEAU** — Japan's national 3D urban data
#       platform
#     • **MAAS (Metal as a Service)** — Canonical's bare-metal
#       provisioner
#     • **Viam Labs 3D Segmentation Visualizer** — robotics
#       perception
#     • Plus thousands of community SSO gateways, identity
#       brokers, and OIDC-protected microservices.
#
#   OAuth 2.0 + OpenID Connect (OIDC) collectively form **the
#   universal identity and authorization protocol of the modern
#   web** — standardized by the IETF (OAuth 2.0: RFC 6749 base
#   + RFC 6750 Bearer Token + RFC 7009 Revocation + RFC 7591
#   Dynamic Client Registration + RFC 7592 + RFC 7636 PKCE +
#   RFC 7662 Token Introspection + RFC 8252 OAuth 2.0 for
#   Native Apps + RFC 9068 JWT Bearer + RFC 9126 PAR + RFC
#   9207 Issuer Identification + the OAuth 2.1 consolidation
#   draft) and the OpenID Foundation (OIDC Core 1.0 + OIDC
#   Discovery 1.0 + OIDC Dynamic Client Registration 1.0 +
#   OIDC Session Management 1.0 + OIDC Front-Channel Logout
#   + OIDC Back-Channel Logout + OIDC RP-Initiated Logout +
#   OIDC CIBA + OIDC Federation 1.0 + FAPI 1.0/2.0 profiles).
#
#   Every major identity provider speaks OIDC:  Auth0, Okta,
#   Microsoft Entra ID, Google Identity Platform, Sign in
#   with Apple, GitHub OAuth, GitLab OIDC, AWS Cognito,
#   Keycloak, Authentik, PingFederate, ForgeRock, CyberArk
#   Identity, OneLogin, JumpCloud, Cloudflare Access,
#   Tailscale SSO, WorkOS, Stytch, Clerk, FusionAuth, Logto,
#   ZITADEL, Ory Hydra, dex.
#
#   Verified via:
#     gh api repos/perses/perses/contents/go.mod
#       → module github.com/perses/perses
#       → require github.com/zitadel/oidc/v3 v3.47.5  (DIRECT)
#       → require github.com/zitadel/logging v0.7.0 (indirect)
#       → require github.com/zitadel/schema v1.3.2 (indirect)
#     raw.githubusercontent.com perses/perses main cmd/percli/
#         main.go
#       → package main
#       → import "github.com/perses/perses/internal/cli/cmd/
#                  {apply,conf,dac,describe,get,lint,login,
#                   migrate,plugin,project,refresh,remove,
#                   version,whoami}"
#       → import "github.com/spf13/cobra"
#       → cmd := &cobra.Command{Use: "percli",
#         Short: "Command line interface to interact with the
#                 Perses API"}
#       → cmd.AddCommand(apply.NewCMD(), conf.NewCMD(),
#         dac.NewCMD(), describe.NewCMD(), get.NewCMD(),
#         lint.NewCMD(), login.NewCMD(), migrate.NewCMD(),
#         plugin.NewCMD(), project.NewCMD(),
#         refresh.NewCMD(), remove.NewCMD(),
#         version.NewCMD(), whoami.NewCMD())
#       → cmd.PersistentFlags().StringVar(&configPath,
#         "percliconfig", config.GetDefaultPath(),
#         "Path to the percliconfig file ...")
#       → cmd.PersistentFlags().StringVar(&logLevel,
#         "log.level", "info", ...
#         "Possible values: panic, fatal, error, warning,
#          info, debug, trace")
#
#   This entry is the Go=179 leader bump that continues Axis 124
#   (OAuth 2.0 / OpenID Connect 1.0 / IETF RFC 6749 + RFC 8252
#   + RFC 7636 PKCE + OIDC Discovery + OIDC Dynamic Client
#   Registration identity protocol) at 2/0/0 following R1070
#   _calrs (Rust=179 OPENED via olivierlambert/calrs on
#   ramosbugs/openidconnect-rs;  R1070 round-number commit
#   landmark).  TS-Node=179 closing pair on deck for R1072 via
#   the canonical Node.js OIDC library `panva/node-openid-
#   client` (Filip Skokan's reference Node.js OIDC
#   implementation, the dominant Node-side OIDC dependency used
#   by Next-Auth, Auth.js, Strapi, Keycloak's Node.js admin
#   tooling, and every production Node SSO integration).
#
#   No completion for `percli` ships with Apple zsh
#   (/usr/share/zsh/*/functions) or Homebrew zsh-completions
#   (/opt/homebrew/share/zsh/site-functions) — confirmed absent.
# ============================================================================

_percli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--percliconfig=[path to percliconfig file]:path:_files -g "*.yaml *.yml"' \
        '--log.level=[log verbosity (default info)]:level:(panic fatal error warning info debug trace)' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _pc_cmds=(
                'apply:apply a Perses resource from a YAML/JSON file'
                'conf:manage local percli config'
                'dac:Dashboards-as-Code (Cuelang) operations'
                'describe:describe a Perses resource in detail'
                'get:list Perses resources'
                'lint:lint Perses resource files (JSON Schema validation)'
                'login:log in to a Perses server'
                'migrate:migrate a Grafana dashboard to a Perses dashboard'
                'plugin:manage Perses plugins'
                'project:manage Perses projects (multi-tenant scope)'
                'refresh:refresh local credentials'
                'remove:remove a Perses resource'
                'version:print version'
                'whoami:print authenticated user info'
            )
            _describe -t commands 'percli command' _pc_cmds && ret=0
            ;;
        args)
            case $words[1] in
                apply|lint)
                    _arguments \
                        '(-f --file)*'{-f,--file}'=[resource file]:path:_files -g "*.yaml *.yml *.json"' \
                        '(-d --directory)'{-d,--directory}'=[resource directory]:dir:_files -/' && ret=0
                    ;;
                login)
                    _arguments \
                        '1:Perses server URL:' \
                        '(-u --username)'{-u,--username}'=[username]:user:' \
                        '(-p --password)'{-p,--password}'=[password]:pass:' \
                        '(-t --token)'{-t,--token}'=[Bearer token]:token:' \
                        '--insecure-tls-skip-verify[skip TLS cert verification]' && ret=0
                    ;;
                migrate)
                    _arguments \
                        '(-f --file)'{-f,--file}'=[Grafana JSON file]:path:_files -g "*.json"' && ret=0
                    ;;
                dac)
                    if (( CURRENT == 2 )); then
                        _describe -t sub 'dac action' '(build preview generate)' && ret=0
                    fi
                    ;;
                describe|remove)
                    _arguments \
                        '1:kind:(dashboard datasource variable project user plugin)' \
                        '2:name:' && ret=0
                    ;;
                get)
                    _arguments \
                        '1:kind:(dashboards datasources variables projects users plugins)' \
                        '2:name:' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_percli "$@"
