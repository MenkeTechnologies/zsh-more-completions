#compdef packer
# _packer-bin — HashiCorp Packer machine image builder (HashiCorp, Go); build identical machine images across cloud providers
# upstream: https://github.com/hashicorp/packer

_packer-bin() {
    local -a sub=(
        'build:build images'
        'console:run console'
        'fix:fix legacy templates'
        'fmt:format HCL2 files'
        'hcl2_upgrade:upgrade JSON to HCL2'
        'init:initialize plugins'
        'inspect:inspect template'
        'plugins:plugin commands'
        'validate:validate template'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '-v[show version]' \
        '-version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'packer subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '-color+[color]:bool:(true false)' \
                    '-debug[debug build]' \
                    '-except+[builders to skip]:str:' \
                    '-force[force overwrite output]' \
                    '-machine-readable[machine-readable output]' \
                    '-on-error+[on-error behavior]:behavior:(cleanup abort ask run-cleanup-provisioner)' \
                    '-only+[builders to run]:str:' \
                    '-parallel-builds+[parallelism]:n:' \
                    '-timestamp-ui[timestamps in UI]' \
                    '-var+[variable]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' \
                    '*:template:_files -g "*.(json|pkr.hcl|pkr.json)"' ;;
                init|validate|inspect|fmt|console) _arguments \
                    '-machine-readable[machine readable]' \
                    '-upgrade[upgrade plugins]' \
                    '-recursive[recursive]' \
                    '-syntax-only[syntax only]' \
                    '-evaluate-datasources[evaluate datasources]' \
                    '-var+[var]:KEY=VAL:' \
                    '-var-file+[var file]:file:_files' \
                    '*:file:_files' ;;
                plugins) _arguments '1:plugin cmd:(install list installed remove required)' '*:plugin:' ;;
            esac
            ;;
    esac
}

_packer-bin "$@"
