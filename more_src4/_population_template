#compdef population_template
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/population_template.html
# Source: MRtrix3/mrtrix3 bin/population_template — unbiased group-average template via iterative registration (Python).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mc_weight_initial_alignment+[multi-contrast initial alignment weights]:weights:_default' \
    '-mc_weight_rigid+[multi-contrast rigid weights]:weights:_default' \
    '-mc_weight_affine+[multi-contrast affine weights]:weights:_default' \
    '-mc_weight_nl+[multi-contrast non-linear weights]:weights:_default' \
    '-linear_no_pause[do not pause on implausible linear registration]' \
    '-linear_estimator+[intensity diff estimator]:type:(l1 l2 lp)' \
    '-rigid_scale+[rigid multi-resolution scale factors]:factors:_default' \
    '-rigid_lmax+[rigid lmax per scale]:lmax:_default' \
    '-rigid_niter+[rigid iterations per scale]:n:_default' \
    '-affine_scale+[affine multi-resolution scale factors]:factors:_default' \
    '-affine_lmax+[affine lmax per scale]:lmax:_default' \
    '-affine_niter+[affine iterations per scale]:n:_default' \
    '-nl_scale+[non-linear multi-resolution scale factors]:factors:_default' \
    '-nl_lmax+[non-linear lmax per scale]:lmax:_default' \
    '-nl_niter+[non-linear iterations per scale]:n:_default' \
    '-nl_update_smooth+[gradient update Gaussian stdev]:value:_default' \
    '-nl_disp_smooth+[displacement field Gaussian stdev]:value:_default' \
    '-nl_grad_step+[non-linear gradient step]:value:_default' \
    '-type+[registration stages]:type:(rigid affine nonlinear rigid_affine rigid_nonlinear affine_nonlinear rigid_affine_nonlinear)' \
    '-voxel_size+[template voxel size mm]:size:_default' \
    '-initial_alignment+[initial alignment method]:method:(mass robust_mass geometric none)' \
    '-mask_dir+[per-input masks directory]:dir:_files -/' \
    '-warp_dir+[output warps directory]:dir:_files -/' \
    '-transformed_dir+[output transformed images directory]:dir:_files -/' \
    '-linear_transformations_dir+[output linear transforms directory]:dir:_files -/' \
    '-template_mask+[output template mask image]:image:_files' \
    '-noreorientation[disable FOD reorientation]' \
    '-leave_one_out+[leave-one-out registration]:choice:(0 1 auto)' \
    '-aggregate+[aggregation measure]:measure:(mean median)' \
    '-aggregation_weights+[weights file]:file:_files' \
    '-nanmask[apply NaN masks to inputs]' \
    '-copy_input[copy inputs to scratch]' \
    '-scratch+[scratch directory]:dir:_files -/' \
    '-continue+[continue from a previous scratch dir]:dir:_files -/' \
    '-nocleanup[do not clean up scratch directory]' \
    '-nthreads+[number of threads]:n:_default' \
    '*:input_dir(s) and template output(s):_files' \
    && ret=0

return ret
