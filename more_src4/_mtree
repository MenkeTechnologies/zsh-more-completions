#compdef mtree
# _mtree — OpenBSD mtree (compare a directory tree against an mtree(5) spec read from stdin; -c emits a spec instead, -u/-U updates owner/mode/flags/links to match the spec, -k/-K controls which keywords are compared)
# upstream: https://github.com/openbsd/src (usr.sbin/mtree)
# Flags from usr.sbin/mtree/mtree.8 on tip.

_mtree() {
    _arguments \
        '-c[emit spec for the current hierarchy]' \
        '-d[only check directory type files]' \
        '-e[ignore extra files in hierarchy]' \
        '-i[do not descend]' \
        '-l[loose permission checks]' \
        '-n[do not emit comments]' \
        '-q[quiet]' \
        '-r[remove files not in spec]' \
        '-t[touch matched files to spec mtime]' \
        '-U[update + dont fail on differences]' \
        '-u[update owner/group/mode/flags/links to match spec]' \
        '-x[do not cross mountpoints]' \
        '-f+[read spec from file]:file:_files' \
        '-K+[add keywords to compare]:keywords:' \
        '-k+[set keywords to compare]:keywords:' \
        '-p+[base path]:dir:_files -/' \
        '-s+[seed for crc]:seed:'
}

_mtree "$@"
