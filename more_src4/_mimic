#compdef mimic mimic3 mimic3-server mimic3-server-cli
# _mimic — Mycroft AI Mimic neural text-to-speech engine fork of Festival with on-device synthesis (MycroftAI team, Python); argparse
# upstream: https://github.com/MycroftAI/mimic3

_mimic() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '--voice=+[voice key]:str:' \
        '-V+[voice key]:str:' \
        '--voice-name=+[voice]:str:' \
        '--list-voices[list available voices]' \
        '-l[list available voices]' \
        '--speaker=+[speaker name]:str:' \
        '-s+[speaker name]:str:' \
        '--length-scale=+[F]:f:' \
        '--noise-scale=+[F]:f:' \
        '--noise-w=+[F]:f:' \
        '--text=+[text]:str:' \
        '-t+[text]:str:' \
        '--file=+[input file]:file:_files -g "*.txt *.ssml"' \
        '-f+[input file]:file:_files -g "*.txt *.ssml"' \
        '--output=+[output WAV]:file:_files -g "*.wav"' \
        '-o+[output WAV]:file:_files -g "*.wav"' \
        '--output-dir=+[output dir]:dir:_files -/' \
        '--output-naming=+[scheme]:s:(text id time)' \
        '--csv-output[CSV output]' \
        '--play[play audio]' \
        '-p[play audio]' \
        '--sample-rate=+[Hz]:n:' \
        '--ssml[parse SSML]' \
        '--no-ssml[plain text]' \
        '--stdout[write WAV to stdout]' \
        '--interactive[interactive mode]' \
        '--csv[CSV input]' \
        '--cuda[enable CUDA]' \
        '--cuda-device=+[device id]:n:' \
        '--quality=+[quality]:q:(x_low low medium high)' \
        '--download-voice=+[voice key]:str:' \
        '--voices-dir=+[voices dir]:dir:_files -/' \
        '--debug[debug logging]'
}

_mimic "$@"
