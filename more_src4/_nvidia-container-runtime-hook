#compdef nvidia-container-runtime-hook
# _nvidia-container-runtime-hook — OCI prestart hook (legacy mode) that injects NVIDIA devices/libraries before container start
# upstream: https://github.com/NVIDIA/nvidia-container-toolkit
# Flags from cmd/nvidia-container-runtime-hook/main.go on tip; positional "command" is the lifecycle event (prestart, poststart, poststop).

_nvidia-container-runtime-hook() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--debug[enable debug output]' \
        '--version[print version and exit]' \
        '--config=[configuration file]:file:_files' \
        '1::command:(prestart poststart poststop)'
}

_nvidia-container-runtime-hook "$@"
