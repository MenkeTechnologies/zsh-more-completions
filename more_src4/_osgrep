_osgrep() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '--store=[store to use (env OSGREP_STORE)]:store:' \
        '--version[show version]' \
        '--help[show help]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _og_cmds=(
                'search:natural-language semantic search (default subcommand)'
                'index:manually index the repository'
                'list:list all indexed repositories (stores)'
                'skeleton:compressed file skeleton (signatures + types + class structure)'
                'symbols:list all extracted symbols (functions/types/classes)'
                'trace:call-graph trace (who calls vs what is called)'
                'setup:download embedding models (~150MB)'
                'serve:HTTP server with live file watching for hot searches'
                'mcp:run as Model Context Protocol stdio server'
                'install-claude-code:install the Claude Code plugin'
                'install-codex:install the OpenAI Codex CLI plugin'
                'install-droid:install the factory.ai Droid plugin'
                'install-opencode:install the OpenCode plugin'
                'uninstall-opencode:uninstall the OpenCode plugin'
                'doctor:installation health check'
                'help:show help for command'
            )
            _describe -t commands 'osgrep command' _og_cmds && ret=0
            ;;
        args)
            case $words[1] in
                search)
                    _arguments \
                        '1:query:' \
                        '-m+[max total results (default 25)]:n:' \
                        '--per-file=[max matches per file (default 1)]:n:' \
                        '(-c --content)'{-c,--content}'[show full chunk content vs snippets]' \
                        '--scores[show relevance scores (0-1)]' \
                        '--min-score=[filter results below score threshold]:n:' \
                        '--compact[file paths only (grep -l style)]' \
                        '(-s --sync)'{-s,--sync}'[force re-index changed files before searching]' \
                        '(-r --reset)'{-r,--reset}'[reset index and re-index from scratch]' \
                        '--help[show help]' && ret=0
                    ;;
                index)
                    _arguments \
                        '(-d --dry-run)'{-d,--dry-run}'[see what would be indexed]' \
                        '(-p --path)'{-p,--path}'=[path to index (default .)]:dir:_files -/' \
                        '(-r --reset)'{-r,--reset}'[full re-index from scratch]' \
                        '(-v --verbose)'{-v,--verbose}'[detailed progress with file names]' \
                        '--allow-fallback[index files without TreeSitter grammar]' \
                        '--help[show help]' && ret=0
                    ;;
                serve)
                    if (( CURRENT == 2 )) && [[ $words[2] != -* ]]; then
                        _describe -t sub 'serve sub-command' \
                          '(status\:"server status for cwd" stop\:"stop server in cwd")' && ret=0
                    else
                        _arguments \
                            '(-p --port)'{-p,--port}'=[listen port (auto-increments from 4444)]:port:' \
                            '(-b --background)'{-b,--background}'[run server in background + exit]' \
                            '--all[apply to all servers (for stop)]' \
                            '--help[show help]' && ret=0
                    fi
                    ;;
                skeleton)
                    _arguments \
                        '1:file/symbol/query:_files' \
                        '--help[show help]' && ret=0
                    ;;
                trace)
                    _arguments \
                        '1:function name:' \
                        '--help[show help]' && ret=0
                    ;;
                list|symbols|setup|mcp|doctor|install-claude-code|install-codex|install-droid|install-opencode|uninstall-opencode)
                    _arguments '--help[show help]' && ret=0
                    ;;
                help)
                    _arguments '1:command:(search index list skeleton symbols trace setup serve mcp install-claude-code install-codex install-droid install-opencode uninstall-opencode doctor)' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_osgrep "$@"
