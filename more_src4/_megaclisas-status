#compdef megaclisas-status megasasctl
# Documentation: https://github.com/omame/megaclisas-status
# Reference accessed: 2026-05-19
# Verified: upstream README. Only --nagios is documented upstream;
# previously invented --csv, --badlist, --debug, --version were removed.

# megaclisas-status: human-readable wrapper for MegaCli status
local curcontext="$curcontext" ret=1
_arguments -C \
  '--nagios[nagios-style status output]' \
  '*::megaclisas-status args:_files' && ret=0
return ret
