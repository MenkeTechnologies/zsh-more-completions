#compdef pampick
# Documentation: man pampick (Netpbm)
# Source: pick out specific images by sequence number from a multi-image stream.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '*:image sequence number:' \
    && ret=0

return ret
