#compdef mmseqs mmseqs2
# Documentation: upstream src/MMseqsBase.cpp at
# github.com/soedinglab/MMseqs2
# Reference accessed: 2026-05-30 via gh api inspection of the
# full 121-subcommand registry. Common usage matches the README +
# tutorial workflows; the multi-stem registers both `mmseqs` (the
# canonical binary name) and `mmseqs2` (the alternate package name).
# MMseqs2 R99 — Many-against-Many sequence searching: ultra-fast,
# sensitive protein sequence search + clustering across huge data sets.

local curcontext="$curcontext" state line ret=1

local -a _easy_subs _wf_subs _db_subs _alignment_subs _profile_subs _taxo_subs _format_subs _set_subs _util_subs _all
_easy_subs=(
  'easy-search:run search against a sequence FASTA database'
  'easy-linsearch:run linsearch against a sequence FASTA database'
  'easy-cluster:cluster sequences in a FASTA/FASTQ file'
  'easy-linclust:cluster a FASTA/FASTQ file by linear-time alg (huge sets)'
  'easy-rbh:reciprocal-best-hit search between two FASTA files'
  'easy-taxonomy:assign taxonomic labels to FASTA sequences'
  'easy-proteomecluster:cluster proteomes'
  'easy-proteomesearch:search proteomes against each other'
)
_wf_subs=(
  'search:core MMseqs2 search workflow'
  'linsearch:linear-time search workflow'
  'cluster:cascaded clustering workflow'
  'linclust:linear-time clustering workflow'
  'rbh:reciprocal-best-hit workflow'
  'taxonomy:taxonomy-assignment workflow'
  'multihitsearch:multi-hit search workflow'
  'proteomecluster:proteome-clustering workflow'
)
_db_subs=(
  'createdb:create an MMseqs2 database from sequence files'
  'createindex:precompute an index for faster repeated searches'
  'createlinindex:create a linear-time-friendly index'
  'createtaxdb:create a sequence database with taxonomic info'
  'createdmptaxonomy:create a taxonomy database from NCBI dmp files'
  'makepaddedseqdb:prepare a GPU-compatible database format'
  'databases:download and set up public reference databases'
  'createsubdb:create a sub-database from existing one'
  'createbintaxonomy:create a binary taxonomy database'
  'createbintaxmapping:create a binary taxonomy mapping'
  'createseqfiledb:create a sequence-file database'
  'createclusearchdb:create a database for cluster search'
  'concatdbs:concatenate databases'
  'splitdb:split a database'
  'mergedbs:merge databases'
  'subtractdbs:subtract one database from another'
  'aliasdb:create an alias for a database'
  'lndb:link a database (symlink-style)'
  'cpdb:copy a database'
  'mvdb:move a database'
  'rmdb:remove a database'
  'compress:compress a database'
  'decompress:decompress a database'
  'dbtype:get the type of a database'
  'diffseqdbs:diff two sequence databases'
  'view:view contents of a database'
  'touchdb:touch a database (force load)'
  'unpackdb:unpack a database into individual files'
  'indexdb:create an index'
  'appenddbtoindex:append a database to an existing index'
  'kmerindexdb:create a kmer-index database'
)
_alignment_subs=(
  'prefilter:fast k-mer prefilter step'
  'align:align prefilter hits with Smith-Waterman'
  'alignall:align all-vs-all (no prefilter)'
  'alignbykmer:align by k-mer'
  'ungappedprefilter:ungapped prefilter'
  'gappedprefilter:gapped prefilter'
  'kmermatcher:k-mer matching for linclust'
  'kmersearch:k-mer-based search'
  'lcaalign:LCA-aware alignment'
  'rescorediagonal:rescore alignment diagonals'
  'transitivealign:transitive alignment'
  'pairaln:pair-end alignment'
  'expandaln:expand alignments'
  'fwbw:forward-backward alignment'
  'extractalignedregion:extract aligned regions'
)
_profile_subs=(
  'convertprofiledb:convert a profile database'
  'convertmsa:convert MSA to MMseqs2 format'
  'convertblastdb:convert a BLAST database'
  'convertalis:convert alignment results to BLAST-like / SAM / etc.'
  'convertkb:convert a kmer-based DB'
  'createtsv:create a TSV from an MMseqs2 result'
  'parseproteomealignments:parse proteome alignments'
)
_taxo_subs=(
  'taxonomyreport:generate a taxonomy report'
  'addtaxonomy:add taxonomy to results'
  'aggregatetax:aggregate taxonomy assignments'
  'aggregatetaxweights:weighted aggregate of taxonomy'
  'lca:lowest-common-ancestor analysis'
  'majoritylca:majority-vote LCA'
  'filtertaxdb:filter a taxonomy database'
  'filtertaxseqdb:filter a taxonomy-sequence database'
  'nrtotaxmapping:NCBI nr→taxonomy mapping'
)
_format_subs=(
  'extractorfs:extract ORFs from nucleotide sequences'
  'extractframes:extract translation frames'
  'extractdomains:extract domains from alignments'
  'translatenucs:translate nucleotide → protein'
  'translateaa:translate amino-acid sequence (back-translate)'
  'reverseseq:reverse-complement a sequence database'
  'masksequence:mask a sequence database'
  'maskbygff:mask sequences by a GFF file'
  'recoverlongestorf:recover the longest ORF'
  'orftocontig:map ORFs to contigs'
  'splitsequence:split a sequence'
  'summarizealis:summarize alignment results'
  'summarizeheaders:summarize headers'
  'summarizeresult:summarize result database'
  'summarizetabs:summarize TSVs'
)
_set_subs=(
  'besthitperset:best hit per set'
  'combinepvalperset:combine p-values per set'
  'enrich:enrichment analysis'
  'filterdb:filter a database'
  'filterresult:filter results'
  'mergeresultsbyset:merge result databases by set'
  'mergeclusters:merge cluster results'
  'sortresult:sort result database'
  'offsetalignment:offset alignment coordinates'
)
_util_subs=(
  'apply:apply a command to a database'
  'calculatelambda:calculate lambda parameter'
  'clust:cluster results from a search'
  'clusterupdate:incrementally update a cluster DB'
  'clusthash:cluster by hash (initial)'
  'countkmer:count k-mers in a database'
  'diskspaceavail:check available disk space'
  'gpuserver:start a GPU server'
  'multihitdb:create a multi-hit database'
  'pickconsensusrep:pick consensus representative'
  'prefixid:add prefix to IDs'
  'suffixid:add suffix to IDs'
  'renamedbkeys:rename database keys'
  'setextendeddbtype:set extended database type'
  'swapdb:swap (transpose) a database'
  'swapresults:swap result database'
  'selection:run a selection on the database'
  'map:run map workflow'
  'version:show version'
)
_all=( $_easy_subs $_wf_subs $_db_subs $_alignment_subs $_profile_subs $_taxo_subs $_format_subs $_set_subs $_util_subs )

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'mmseqs subcommand' _all && ret=0
    ;;
  subcmd_args)
    _arguments \
      '--threads=[number of threads (default 1)]:N:' \
      '--compressed=[compress output (0/1)]:bool:(0 1)' \
      '-v+[verbosity level (0-3)]:level:(0 1 2 3)' \
      '--remove-tmp-files[remove tmp files after run]' \
      '--force-reuse[force reuse of intermediate results]' \
      '--mpi-runner=[MPI runner command (e.g. mpirun -np 4)]:cmd:' \
      '*:positional (DB / FASTA / dir):_files' && ret=0
    ;;
esac

return ret
