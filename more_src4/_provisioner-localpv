#compdef provisioner-localpv
# _provisioner-localpv — OpenEBS dynamic Local PV provisioner (hostpath + device-localpv volumes)
# upstream: https://github.com/openebs/dynamic-localpv-provisioner
# Flags from cmd/provisioner-localpv/app/start.go on tip (cobra + klog v2); env vars OPENEBS_NAMESPACE, OPENEBS_IO_BASE_PATH, OPENEBS_SERVICE_ACCOUNT, OPENEBS_IO_K8S_MASTER, OPENEBS_IO_KUBE_CONFIG, OPENEBS_IO_IMAGE_PULL_SECRETS, OPENEBS_IO_HELPER_IMAGE drive runtime behaviour.

_provisioner-localpv() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--node-deployment[deploy provisioner with a CSI driver to manage node-local volumes]' \
        '--log-flush-frequency=[delay between log flushes]:duration:' \
        '--analytics-lease-duration=[analytics leader-election lease duration]:duration:' \
        '--analytics-renew-deadline=[analytics leader-election renew deadline]:duration:' \
        '--analytics-retry-period=[analytics leader-election retry period]:duration:' \
        '-v[klog verbosity level]:n:' \
        '--logtostderr=[log to stderr instead of files]:bool:(true false)' \
        '--alsologtostderr=[log to stderr and files]:bool:(true false)' \
        '--stderrthreshold=[stderr threshold]:level:(INFO WARNING ERROR FATAL)' \
        '--vmodule=[csv of pattern=N for verbose logging]:csv:' \
        '--log-file=[log file destination]:file:_files' \
        '--log-dir=[directory to write logs to]:dir:_files -/'
}

_provisioner-localpv "$@"
