#compdef nl-cli
# _nl-cli — GNU coreutils nl number lines of files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_nl-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-b+[body style]:b:(a t n p)' \
        '--body-numbering=+[body style]:b:(a t n p)' \
        '-d+[section delimiter]:str:' \
        '--section-delimiter=+[section delimiter]:str:' \
        '-f+[footer style]:b:(a t n p)' \
        '--footer-numbering=+[footer style]:b:(a t n p)' \
        '-h+[header style]:b:(a t n p)' \
        '--header-numbering=+[header style]:b:(a t n p)' \
        '-i+[increment]:n:' \
        '--line-increment=+[increment]:n:' \
        '-l+[join blank lines]:n:' \
        '--join-blank-lines=+[join blank lines]:n:' \
        '-n+[format]:f:(ln rn rz)' \
        '--number-format=+[format]:f:(ln rn rz)' \
        '-p[do not reset count]' \
        '--no-renumber[do not reset count]' \
        '-s+[separator]:str:' \
        '--number-separator=+[separator]:str:' \
        '-v+[start number]:n:' \
        '--starting-line-number=+[start number]:n:' \
        '-w+[width]:n:' \
        '--number-width=+[width]:n:' \
        '*:files:_files'
}

_nl-cli "$@"
