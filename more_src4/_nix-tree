#compdef nix-tree
# Documentation: https://github.com/utdemir/nix-tree
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '--store=[URL of the Nix store]:store:' \
  '--file=[file with Nix expression for installables]:file:_files' \
  '--derivation[operate on the store derivation instead of outputs]' \
  '--dot[print dependency graph in Graphviz dot format]' \
  '--impure[allow access to mutable paths and repositories]' \
  '--version[show version]' \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:installable' && ret=0
return ret
