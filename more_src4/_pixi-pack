#compdef pixi-pack
# _pixi-pack — pack conda envs for offline sharing (Quantco/pixi-pack)
# upstream: https://github.com/Quantco/pixi-pack
# Flags from src/bin/pixi-pack.rs (clap).

_pixi-pack() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[show version]' \
        '(-e --environment)'{-e+,--environment=}'[environment to pack]:env:' \
        '(-p --platform)'{-p+,--platform=}'[platform target]:platform:(linux-64 linux-aarch64 osx-64 osx-arm64 win-64)' \
        '--auth-file=[authentication file for fetching packages]:file:_files' \
        '(-o --output-file)'{-o+,--output-file=}'[output pack file]:file:_files' \
        '--use-cache=[use a cache directory for downloaded packages]:dir:_files -/' \
        '*'{-i+,--inject=}'[inject an additional conda package into the prefix]:file:_files -g "*.{conda,tar.bz2}"' \
        '--ignore-pypi-non-wheel[allow packing when PyPI sdists are present]' \
        '--create-executable[create a self-extracting executable]' \
        '--directory-only[create the pack as a folder instead of a tar]' \
        '--pixi-unpack-source=[URL/path to a pixi-unpack executable]:source:' \
        '(-c --config)'{-c+,--config=}'[rattler config (mirror / S3)]:file:_files' \
        '*'{-v,--verbose}'[increase verbosity]' \
        '*'{-q,--quiet}'[decrease verbosity]' \
        '1:manifest path (pixi.toml / pyproject.toml / dir):_files' \
        '*::arg:->args' && ret=0

    case "$state" in
        args)
            case "$words[1]" in
                completion)
                    _arguments \
                        '(-s --shell)'{-s+,--shell=}'[shell]:shell:(bash zsh fish powershell elvish)'
                    ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_pixi-pack_commands] )) ||
_pixi-pack_commands() {
    local -a commands
    commands=(
        'completion:generate a shell completion script'
    )
    _describe -t commands 'pixi-pack command' commands
}

_pixi-pack "$@"
