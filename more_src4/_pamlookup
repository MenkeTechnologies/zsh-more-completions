#compdef pamlookup
# Documentation: man pamlookup (Netpbm)
# Source: Netpbm pamlookup — map an image to a new image by using it as indices into a table.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-lookupfile=[lookup-table PAM file]:file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    '-byplane[per-plane indexing (vs whole-tuple)]' \
    '-missingcolor=[color used when index has no entry]:color:' \
    '-fit[scale index values to fit lookup table dimensions]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:index PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
