#compdef pw-dump
# Documentation: https://docs.pipewire.org/page_man_pw-dump_1.html
# Source: PipeWire — JSON dump of the daemon's globals and properties.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(-r --remote)'{-r+,--remote=}'[remote instance name]:name:' \
    '(-m --monitor)'{-m,--monitor}'[monitor state changes, emit JSON arrays]' \
    '(-N --no-colors -C --color)'{-N,--no-colors}'[disable color output]' \
    '(-N --no-colors -C --color)'{-C+,--color=}'[color support]:when:(never always auto)' \
    && ret=0

return ret
