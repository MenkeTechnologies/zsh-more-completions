#compdef nai
# Documentation: https://github.com/LittleSound/nai
# Reference accessed: 2026-05-23
# Verified: upstream README (@rizumu/nai install and flags).

# Zsh completion for nai - interactive npm/pnpm/yarn/bun package installer

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-D --save-dev)'{-D,--save-dev}'[install as devDependency]' \
  '--peer[install as peerDependency]' \
  '(-C --catalog)'{-C+,--catalog=}'[catalog name]:catalog:' \
  '*:package:' && ret=0

return ret
