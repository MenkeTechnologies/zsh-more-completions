#compdef getent
# _nss — glibc getent (Name Service Switch lookup tool that prints /etc/nsswitch.conf-routed entries from any NSS database: aliases, ahosts, ahostsv4, ahostsv6, ethers, group, gshadow, hosts, initgroups, netgroup, networks, passwd, protocols, rpc, services, shadow; -s service override, -i ignore canonicalize, -V version)
# upstream: https://sourceware.org/git/glibc.git (nss/getent.c)
# Flags from glibc nss/getent.c on tip.

_nss() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-s+[service override]:service:' \
        '--service+[service override]:service:' \
        '-i[no canonicalize]' \
        '--no-idn[no IDN]' \
        '1:database:(aliases ahosts ahostsv4 ahostsv6 ethers group gshadow hosts initgroups netgroup networks passwd protocols rpc services shadow)' \
        '*:key:'
}

_nss "$@"
