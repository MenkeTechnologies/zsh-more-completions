#compdef pd-tso-bench
# _pd-tso-bench — TiKV PD TSO (timestamp oracle) benchmark
# upstream: https://github.com/tikv/pd
# Flags from tools/pd-tso-bench/main.go on tip.

_pd-tso-bench() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-pd=[PD address]:host\:port:' \
        '-client=[PD clients per benchmark]:n:' \
        '-c=[concurrent goroutines]:n:' \
        '-count=[benchmark run count]:n:' \
        '-duration=[benchmark duration]:dur:' \
        '-v[output per-interval stats + final metrics]' \
        '-interval=[stats output interval]:dur:' \
        '-cacert=[trusted CA cert file (PEM)]:file:_files' \
        '-cert=[client X509 cert file (PEM)]:file:_files' \
        '-key=[client X509 key file (PEM)]:file:_files' \
        '-batch-interval=[max batch wait interval]:dur:' \
        '-enable-tso-follower-proxy[enable TSO follower proxy]' \
        '-enable-fault-injection[enable fault injection]' \
        '-fault-injection-rate=[fault injection rate (0.0001-1)]:f:' \
        '-max-send-interval-ms=[max TSO send interval (ms)]:ms:'
}

_pd-tso-bench "$@"
