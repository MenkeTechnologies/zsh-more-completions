#compdef neko nekoc nekoml nekotools
# Documentation: https://nekovm.org/doc/tools/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Neko virtual machine, compilers and tools.

local curcontext="$curcontext" state line ret=1

case $service in
  (neko)
    _arguments -C \
      '-version[show version]' \
      '*:bytecode file:_files -g "*.n"' && ret=0 ;;
  (nekoc)
    _arguments -C \
      '-version[show version]' \
      '-v[verbose]' \
      '-link+[join bytecode files into a single output]:output file:_files' \
      '-console[open a read-execute-print loop]' \
      '-d[dump bytecode from a compiled file]' \
      '-z[strip debug info and global names from bytecode]' \
      '-p[create a formatted version of the source code]' \
      '-doc[generate HTML documentation from source comments]' \
      '-o+[output directory]:dir:_directories' \
      '*: :_files -g "*.neko *.n"' && ret=0 ;;
  (nekoml)
    _arguments -C \
      '-version[show version]' \
      '-v[verbose]' \
      '-p+[output directory]:dir:_directories' \
      '*: :_files -g "*.nml"' && ret=0 ;;
  (nekotools)
    _arguments -C \
      '-version[show version]' \
      '1:command:(server boot)' \
      '*: :->subargs' && ret=0
    case $state in
      (subargs)
        case ${words[2]} in
          (server)
            _arguments -C \
              '-h+[hostname]:host:_hosts' \
              '-p+[port]:port:' \
              '-d+[base directory]:dir:_directories' \
              '-log+[log file]:file:_files' \
              '-rewrite[enable mod-rewrite style URLs]' && ret=0 ;;
          (boot)
            _arguments -C \
              '*:bytecode file:_files -g "*.n"' && ret=0 ;;
        esac
        ;;
    esac
    ;;
esac

return ret
