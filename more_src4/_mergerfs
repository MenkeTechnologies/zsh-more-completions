#compdef mergerfs
# Documentation: https://trapexit.github.io/mergerfs/latest/config/options/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '-o+[mount options]:options:' \
  '-f[run in foreground]' \
  '-d[enable debug mode]' \
  '-s[run single-threaded]' \
  '*:branches\:mountpoint:_files -/' && ret=0

return ret
