#compdef ossec ossec-cli
# _ossec — OSSEC Project Trend Micro ossec CLI Open Source Security Event Correlator file integrity monitoring HIDS host-based intrusion detection system managing agents rules decoders monitor log-collector rootcheck active-response notifications syscheck mail-output to-do-tasks audit policy compliance reporting for syslog Windows Linux macOS (OSSEC team, C); getopt
# upstream: https://www.ossec.net/

_ossec() {
    local -a sub=(
        'start:start ossec daemons'
        'stop:stop ossec daemons'
        'restart:restart ossec daemons'
        'status:show daemon status'
        'enable:enable a component'
        'disable:disable a component'
        'list-agents:list registered agents'
        'add-agent:register a new agent'
        'remove-agent:remove an agent'
        'agent-config:show agent config'
        'rules:list installed rules'
        'decoders:list installed decoders'
        'syscheck:start syscheck scan'
        'rootcheck:start rootcheck scan'
        'active-response:show active responses'
        'reload:reload configuration'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-f+[config file]:file:_files -g "*.conf"' \
        '--config=+[file]:file:_files -g "*.conf"' \
        '--ossec-dir=+[dir]:dir:_files -/' \
        '--component=+[c]:c:(analysisd remoted dbd csyslogd execd logcollector syscheckd monitord agentd authd integratord modulesd wmodulesd)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'ossec subcommand' sub ;;
        args)
            case $words[1] in
                enable|disable) _arguments '1:component:(monitor logcollector remoted syscheck rootcheck execd active-response csyslogd dbd agentless integrator firewall-drop)' ;;
                add-agent|remove-agent|agent-config) _arguments '*:agent name or id:' ;;
            esac
            ;;
    esac
}

_ossec "$@"
