#compdef okta-cli
# _okta-cli — Okta IDaaS CLI alias (okta team, Java); jbang/quarkus
# upstream: https://github.com/okta/okta-cli

_okta-cli() {
    local -a sub=(
        'help:show help'
        'login:login or save tokens'
        'register:create new Okta org'
        'apps:list:list apps'
        'apps:create:create app'
        'apps:delete:delete app'
        'apps:get:get app'
        'apps:update:update app'
        'apps:groups:list:list groups assigned'
        'apps:groups:add:assign group'
        'apps:groups:remove:remove group'
        'apps:users:list:list users assigned'
        'apps:users:add:assign user'
        'apps:users:remove:remove user'
        'apps:tokens:revoke:revoke token'
        'authorizationservers:list:list AS'
        'authorizationservers:create:create AS'
        'authorizationservers:delete:delete AS'
        'authorizationservers:get:get AS'
        'authorizationservers:update:update AS'
        'authorizationservers:scopes:list:list scopes'
        'authorizationservers:scopes:create:create scope'
        'authorizationservers:scopes:delete:delete scope'
        'authorizationservers:claims:list:list claims'
        'authorizationservers:claims:create:create claim'
        'authorizationservers:claims:delete:delete claim'
        'authorizationservers:policies:list:list policies'
        'authorizationservers:policies:create:create policy'
        'authorizationservers:policies:delete:delete policy'
        'config:list:list profiles'
        'config:current:show current profile'
        'config:use:use profile'
        'config:add:add profile'
        'config:remove:remove profile'
        'groups:list:list groups'
        'groups:create:create group'
        'groups:delete:delete group'
        'groups:get:get group'
        'groups:update:update group'
        'groups:users:list:list users in group'
        'groups:users:add:add user'
        'groups:users:remove:remove user'
        'profile:logout:logout profile'
        'start:scaffold app and configure okta'
        'users:list:list users'
        'users:create:create user'
        'users:delete:delete user'
        'users:get:get user'
        'users:update:update user'
        'users:activate:activate user'
        'users:deactivate:deactivate user'
        'users:suspend:suspend user'
        'users:reset-password:reset password'
        'users:reset-factors:reset MFA factors'
        'users:groups:list:list groups for user'
        'users:groups:add:add user to group'
        'users:groups:remove:remove user from group'
        'completion:generate completion'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--config=+[config file]:file:_files' \
        '--profile=+[profile]:str:' \
        '--no-color[no color]' \
        '--json[json output]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'okta subcommand' sub ;;
        args)
            case $words[1] in
                start) _arguments \
                    '1:framework:(angular vue spring spring-boot spring-boot-thymeleaf spring-boot-react react reactnative nodejs express vanilla-js android ios xamarin generic)' \
                    '--branch=+[branch]:str:' \
                    '--app-name=+[app name]:str:' ;;
                login) _arguments \
                    '--profile=+[profile]:str:' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_okta-cli "$@"
