#compdef memory-policy
# _memory-policy — containers/nri-plugins NRI memory-policy plugin (sets per-container Linux NUMA memory policy via mpolset)
# upstream: https://github.com/containers/nri-plugins
# Flags from cmd/plugins/memory-policy/main.go on tip.

_memory-policy() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--name=[plugin name to register to NRI]:name:' \
        '--idx=[plugin index to register to NRI]:n:' \
        '--config=[configuration file]:file:_files' \
        '-v[verbose output]' \
        '-vv[very verbose output (also injects mpolset -vv into containers)]'
}

_memory-policy "$@"
