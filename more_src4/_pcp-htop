#compdef pcp-htop
# Documentation: man pcp-htop(1) / man htop(1)
# Source: performancecopilot/pcp src/pcp/htop (main) — PCP-enabled htop process viewer (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '(-d --delay)'{-d+,--delay=}'[delay between updates (deciseconds)]:delay:_default' \
    '(-C --no-color --no-colour)'{-C,--no-color,--no-colour}'[monochrome]' \
    '(-F --filter)'{-F+,--filter=}'[filter processes by command]:filter:_default' \
    '(-p --pid)'{-p+,--pid=}'[show only these PIDs]:pids:_default' \
    '(-s --sort-key)'{-s+,--sort-key=}'[sort key]:column:_default' \
    '(-u --user)'{-u+,--user=}'[show user processes]::user:_users' \
    '(-U --no-unicode)'{-U,--no-unicode}'[disable unicode]' \
    '(-M --no-mouse)'{-M,--no-mouse}'[disable mouse]' \
    '(-t --tree)'{-t,--tree}'[tree view]' \
    '(-H --highlight-changes)'{-H+,--highlight-changes=}'[highlight changed metrics]::delay:_default' \
    '(--host)--host=[PCP collector host or archive]:host:_hosts' \
    '(--origin)--origin=[archive origin time]:time:_default' \
    '(--samples)--samples=[number of samples]:count:_default' \
    '(--timezone)--timezone=[PCP timezone]:tz:_default' \
    '(--hostzone)--hostzone[use timezone from host]' \
    && ret=0

return ret
