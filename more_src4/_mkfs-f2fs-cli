#compdef mkfs-f2fs-cli mkfs.f2fs-cli mkfs.f2fs
# _mkfs-f2fs-cli — Kim Jaegeuk f2fs-tools mkfs.f2fs Flash-Friendly FS creator CLI alias (jaegeuk team, C); custom argparse
# upstream: https://git.kernel.org/pub/scm/linux/kernel/git/jaegeuk/f2fs-tools.git

_mkfs-f2fs-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-a+[heap based allocation 0/1]:n:(0 1)' \
        '-c+[device]:_files' \
        '-d+[debug level]:n:' \
        '-e+[extension list]:str:' \
        '-E+[extension list (alt)]:str:' \
        '-f[force overwrite]' \
        '-g+[support android sdcardfs]:str:' \
        '-i[overprovision conservatively]' \
        '-l+[volume label]:str:' \
        '-m+[force mount fail safe]:str:' \
        '-o+[overprovision ratio %]:str:' \
        '-O+[features]:str:' \
        '-r[reserve sections for nat blocks]' \
        '-R+[root_owner uid:gid]:str:' \
        '-q[quiet]' \
        '-s+[section count]:n:' \
        '-S+[sparse size]:str:' \
        '-t+[discard 0/1]:n:(0 1)' \
        '-T+[volume timestamp]:n:' \
        '-w+[wanted sector size]:n:' \
        '-z+[zone count]:n:' \
        '-Z+[zone start blkaddr]:n:' \
        '-U+[uuid]:str:' \
        '--checkpoint=+[disable checkpoint]:n:(0 1)' \
        '--no-discard[no discard]' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper,mmcblk}*"'
}

_mkfs-f2fs-cli "$@"
