#compdef podgrab

local curcontext="$curcontext" state line ret=1

_arguments \
  '(--help)--help[show help]' \
  '(--verbose)--verbose[enable verbose output]' \
  '1:command:->commands' \
  '*::arg:->args' \
  && ret=0

case $state in
  commands)
    local -a commands=(
      'add:add a podcast'
      'list:list podcasts'
      'remove:remove a podcast'
      'download:download episodes'
      'serve:run web server'
      'update:update podcast feeds'
    )
    _describe -t commands 'podgrab command' commands && ret=0
    ;;
  args)
    case ${words[1]} in
      add)
        _arguments \
          '--name[podcast name]:name' \
          '--url[podcast RSS feed URL]:url' \
          '--dir[download directory]:directory:_directories' \
          '--help[show help]' \
          && ret=0
        ;;
      list)
        _arguments \
          '--help[show help]' \
          && ret=0
        ;;
      remove)
        _arguments \
          '--name[podcast name to remove]:name' \
          '--help[show help]' \
          && ret=0
        ;;
      download)
        _arguments \
          '--name[podcast name]:name' \
          '--output[output directory]:directory:_directories' \
          '--help[show help]' \
          && ret=0
        ;;
      serve)
        _arguments \
          '--port[web server port]:port' \
          '--help[show help]' \
          && ret=0
        ;;
      update)
        _arguments \
          '--name[podcast name]:name' \
          '--help[show help]' \
          && ret=0
        ;;
    esac
    ;;
esac

return ret
