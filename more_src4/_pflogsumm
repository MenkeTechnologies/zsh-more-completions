#compdef pflogsumm
# Documentation: https://manpages.debian.org/bookworm/pflogsumm/pflogsumm.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm pflogsumm(1) manpage OPTIONS.
# Removed from prior file: bogus man.archlinux.org search URL.

# pflogsumm: Postfix log analyzer/summarizer
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '-d[generate report for just today or yesterday]:when:(today yesterday)' \
  '-e[extended (extreme) detail]' \
  '-h[top N hosts/domains for senders/recipients reports]:count:' \
  '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive email address handling]' \
  '(-m --uucp-mung)'{-m,--uucp-mung}'[modify UUCP-style bang-paths]' \
  '-q[quiet - do not print headings for empty reports]' \
  '-u[top N users for senders/recipients reports]:count:' \
  '--bounce-detail=[limit bounce detail entries]:count:' \
  '--deferral-detail=[limit deferral detail entries]:count:' \
  '--detail=[set bounce, deferral, reject, smtp, smtpd-warning details]:count:' \
  '--reject-detail=[limit reject detail entries]:count:' \
  '--smtp-detail=[limit SMTP detail entries]:count:' \
  '--smtpd-warning-detail=[limit smtpd warning detail entries]:count:' \
  '--iso-date-time[use ISO 8601 format for dates]' \
  '--mailq[append output of mailq]' \
  '--no-no-msg-size[do not show "Messages with no size data"]' \
  '--no-smtpd-warnings[do not show smtpd warnings]' \
  '--problems-first[show problem reports before normal reports]' \
  '--rej-add-from[add From: address to reject reports where available]' \
  '--smtpd-stats[generate smtpd connection statistics]' \
  '--syslog-name=[syslog program name]:name:' \
  '--verbose-msg-detail[show message-id, size, from in detail reports]' \
  '--verp-mung[separate VERP recipient addresses]' \
  '--zero-fill[zero-fill date holes in graph]' \
  '*:logfile:_files' && ret=0
return ret
