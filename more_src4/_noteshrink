#compdef noteshrink
# Documentation: https://github.com/mzucker/noteshrink
# Source: mzucker/noteshrink noteshrink.py — handwritten-notes scanner shrinker (Python, argparse).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-q[reduce program output]' \
    '-b+[output PNG filename base (default page)]:basename:_default' \
    '-o+[output PDF filename (default output.pdf)]:file:_files' \
    '-v+[background value threshold percent (default 25)]:pct:_default' \
    '-s+[background saturation threshold percent (default 20)]:pct:_default' \
    '-n+[number of output colors (default 8)]:n:_default' \
    '-p+[pixel sample fraction percent (default 5)]:pct:_default' \
    '-w[make background white]' \
    '-g[use one global palette for all pages]' \
    '-S[do not saturate colors]' \
    '-K[keep filenames ordered as specified]' \
    '-P+[postprocessing command (see -O, -C, -Q)]:cmd:_default' \
    '-e+[postprocess filename suffix (default _post.png)]:ext:_default' \
    '-O[postprocess with optipng]' \
    '-C[postprocess with pngcrush]' \
    '-Q[postprocess with pngquant]' \
    '-c+[PDF command (default convert %i %o)]:cmd:_default' \
    '*:image file:_files' \
    && ret=0

return ret
