#compdef ossec-control
# Documentation: https://www.ossec.net/docs/docs/programs/ossec-control.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ossec-control: control script for OSSEC daemons
local curcontext="$curcontext" state line ret=1
_arguments -C \
  '(- *)-h[show help]' \
  '1:action:(start stop status restart reload enable disable help)' \
  '2:option:->opt' && ret=0
case $state in
  (opt)
    case $line[1] in
      (enable|disable)
        _values 'feature' database client-syslog agentless debug && ret=0
        ;;
    esac
    ;;
esac
return ret
