#compdef ovn-controller-vtep
# _ovn-controller-vtep — OVN ovn-controller-vtep daemon connecting hardware VTEPs to the OVN logical network via OVSDB hardware-vtep schema (ovn-org team, C); custom argparse
# upstream: https://github.com/ovn-org/ovn

_ovn-controller-vtep() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose modules]:str:' \
        '--verbose=+[verbose modules]:str:' \
        '--vtep-db=+[VTEP DB connection]:str:' \
        '--ovnsb-db=+[OVN SB DB connection]:str:' \
        '--unixctl=+[unixctl socket]:file:_files' \
        '--log-file=+[log file]:file:_files' \
        '--pidfile=+[pid file]:file:_files' \
        '--detach[run as background process]' \
        '--no-chdir[do not chdir to /]' \
        '--monitor[run with monitor]' \
        '--syslog-method=+[method]:m:(libc syslog null udp)' \
        '--syslog-target=+[target]:str:' \
        '--bootstrap-ca-cert=+[ca cert]:file:_files' \
        '--ca-cert=+[ca cert]:file:_files' \
        '--certificate=+[cert]:file:_files' \
        '--private-key=+[key]:file:_files' \
        '--ssl-protocols=+[protocols]:str:' \
        '--ssl-ciphers=+[ciphers]:str:'
}

_ovn-controller-vtep "$@"
