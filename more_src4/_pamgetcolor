#compdef pamgetcolor
# Documentation: man pamgetcolor (Netpbm)
# Source: report the colors at given regions of a PAM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-format+[output color format]:format:(decimal hex normalised float)' \
    '-radius+[averaging radius in pixels]:radius:' \
    '-linear[treat samples as linear rather than gamma]' \
    '-infile+[input pam file]:file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:region (x,y or x,y,w,h):' \
    && ret=0

return ret
