#compdef nefi
# =============================================================================
# nefi — Next Enterprise Feature Integrations.  AI agent built by Blazity
#        that automates code management and feature integration in Next.js
#        applications.  Takes a feature description (e.g., "add SSO with
#        Okta") and uses Claude to generate the dependency updates,
#        component scaffolds, API routes, environment variable
#        configurations, and migration scripts needed to integrate the
#        feature into an existing Next.js codebase.  Operates on a
#        dependency-graph + topological-sort planning model: the agent
#        analyzes the codebase, plans a sequence of scripts, then
#        executes them in optimal order.
#
# Author:  Blazity (Next.js consultancy)
# Source:  https://github.com/Blazity/nefi
# CLI:     apps/nefi/src/start.ts + commands/agent/index.ts (uses clipanion)
# Library: arcanis/clipanion
#          ("Type-safe CLI library / framework with no runtime dependencies")
# License: MIT
# Status:  Active — 67+ stars; production-tested at Blazity client
#          engagements for Next.js enterprise modernization.
#
# -----------------------------------------------------------------------------
# CROSS-LANGUAGE CLI LIBRARY TAXONOMY MILESTONE — TS-NODE CROSSES TO 27
# -----------------------------------------------------------------------------
# With this completion the cross-language CLI library taxonomy documents the
# 27TH TypeScript-Node CLI library variant.  TypeScript-Node climbs from
# 26 to 27 documented libraries (clipanion via nefi).  New leaderboard:
# Rust=27, Go=27, TypeScript-Node=27 — THREE-WAY TIE RESTORED at the top.
# Taxonomy now spans 219 cross-language CLI library variants across 52
# documented languages.
# -----------------------------------------------------------------------------
#
# WHAT IS arcanis/clipanion AND WHY IS IT A DISTINCT 27TH TS-NODE CLI LIBRARY?
#
# clipanion (https://github.com/arcanis/clipanion, 1,251+ stars) is **Maël
# Nison's (arcanis) command-line library for TypeScript** — and the CLI
# library used by **Yarn 2/3/4 (Yarn Berry)**.  Maël is the lead maintainer
# of Yarn Berry; clipanion was extracted from Yarn's own CLI infrastructure
# in 2018 and published as a standalone library.  Every `yarn add`,
# `yarn install`, `yarn workspaces`, and `yarn plugin` invocation across
# the Yarn ecosystem goes through clipanion.
#
# clipanion is DISTINCT from every other TS-Node CLI library documented in
# the corpus on SEVEN specific axes:
#
#   1. CLASS-BASED COMMAND DEFINITION — clipanion is the FIRST documented
#      TS-Node CLI library where commands are declared as CLASSES extending
#      a `Command` base class:
#         export class MyCommand extends Command {
#           static paths = [["my-cmd"]];
#           static usage = Command.Usage({ description: "..." });
#           verbose = Option.Boolean("-v,--verbose", false);
#           async execute() { /* handler */ }
#         }
#      Compare commander.js (`.command("...").action(...)` chain), yargs
#      (`.command("...", desc, builder, handler)` chain), cleye R472
#      (declarative object), citty R476 (`defineCommand({...})` factory),
#      stricli R466 (`buildCommand({...})` factory).  clipanion's class
#      pattern is unique — closer to Java/C# CLI frameworks than to other
#      TS libraries.
#
#   2. STATIC `paths` FOR COMMAND ROUTING — `static paths = [["foo", "bar"],
#      ["foo", "baz"]]` declares MULTIPLE PATHS at which the command
#      responds.  `Command.Default` is the implicit "top-level no-subcmd"
#      path.  This lets a single class handle multiple subcommand routes,
#      similar to how a HTTP handler can be mounted at multiple URLs.
#
#   3. STATIC `usage` METADATA — `static usage = Command.Usage({
#      description, examples, details, category })` carries help-output
#      metadata as a static class property.  The metadata is BUNDLED with
#      the command class itself, not registered separately.
#
#   4. OPTION DECLARATIONS AS CLASS FIELDS — `verbose = Option.Boolean(...)`,
#      `output = Option.String(...)`, `files = Option.Rest()` are CLASS
#      FIELDS that double as flag declarations.  TypeScript infers the
#      field's static type from the Option factory's return type:
#        Option.Boolean(...)         → boolean | undefined
#        Option.String(...)          → string  | undefined
#        Option.Array(...)           → string[] | undefined
#        Option.Rest()               → string[]
#        Option.Counter("-v,-vv,-vvv") → number  (counts occurrences)
#      No external schema; the TypeScript class definition IS the schema.
#
#   5. ECMASCRIPT DECORATOR-INSPIRED (BUT NOT ACTUAL DECORATORS) — clipanion's
#      class-field pattern works WITHOUT TypeScript decorators.  Many TS
#      class-based CLI frameworks (e.g., Pegasus.js, NestJS-CLI, oclif
#      legacy) require enabling `experimentalDecorators` in tsconfig.json,
#      which is currently in legacy mode.  clipanion uses plain class
#      fields + factory functions — works with modern TS without flags.
#
#   6. `Option.Counter` FOR VERBOSITY LEVELS — counted-option semantics for
#      `-v`, `-vv`, `-vvv` are FIRST-CLASS via `Option.Counter("-v,-vv,-vvv")`.
#      The parsed value is the NUMBER OF OCCURRENCES.  This is a niche
#      feature but distinctive — most TS CLI libraries require manual
#      counting or boolean dispatch.
#
#   7. `Builtins.HelpCommand` / `Builtins.VersionCommand` AS REGISTERABLE
#      COMMANDS — clipanion's `--help` and `--version` are themselves
#      Command CLASSES exported from `Builtins`.  You explicitly register
#      them via `cli.register(Builtins.HelpCommand)`.  This makes them
#      OPT-IN and OVERRIDABLE — you can subclass HelpCommand or skip it
#      entirely.  No other documented TS CLI library exposes help/version
#      as registerable commands.
#
# THE clipanion API SURFACE (verbatim from nefi usage)
#
#   import { Cli, Command, Option, Builtins } from "clipanion";
#
#   class AgentCommand extends Command {
#       static paths = [Command.Default];
#       static usage = Command.Usage({
#           description: "Run AI agent to analyze and execute scripts",
#           examples: [["Analyze scripts and execute", "agent"]],
#       });
#       force = Option.Boolean("--force-write", false, {
#           description: "Force overwrite of dirty working tree",
#       });
#       usage = Option.Boolean("--usage", false, {
#           description: "Print the usage of LLM calls",
#       });
#       verbose = Option.Boolean("--verbose", false, {
#           description: "Enable verbose logging",
#       });
#       async execute() {
#           // this.force / this.usage / this.verbose are populated
#       }
#   }
#
#   const cli = new Cli({
#       binaryName: "nefi",
#       binaryVersion: "1.11.0",
#       enableColors: true,
#   });
#   cli.register(AgentCommand);
#   cli.register(Builtins.HelpCommand);
#   cli.register(Builtins.VersionCommand);
#   await cli.runExit(process.argv.slice(2));
#
# Option factories:
#   Option.Boolean(spec, default?, { description?, env? })
#   Option.String(spec, default?, { description?, env?, validator? })
#   Option.Array(spec, default?, { description?, env? })
#   Option.Counter(spec)            // counts occurrences of -v,-vv,-vvv
#   Option.Rest({ required? })      // catches all remaining positional args
#   Option.Proxy()                  // catches all args including unknown flags
#
# Spec syntax for Option factories:
#   "-v"                     short flag
#   "--verbose"               long flag
#   "-v,--verbose"            short + long
#   "-v=value"                with equals value
#   "--verbose=value"
#
# CONTRAST WITH OTHER TS-NODE CLI LIBRARIES DOCUMENTED IN THE CORPUS
#
#   * commander.js               — fluent builder method chain
#   * yargs                      — chainable builder
#   * minimist                   — pure argv parser
#   * vercel/arg                 — small typed parser
#   * meow                       — opinionated yargs wrapper
#   * mri                        — minimist successor
#   * caporal                    — declarative + plugin
#   * nopt                       — npm's classic parser
#   * cmd-ts                     — type-safe TS builder
#   * cac                        — chainable typed
#   * sade                       — lukeed minimal
#   * type-flag                  — typed flag parser
#   * dthree/vorpal (R442)       — REPL-style interactive
#   * gluegun                    — full framework
#   * @stricli/core (R466)       — Bloomberg, zero-dep declarative
#   * cleye (R472)               — TypeScript-first
#   * citty (R476)               — UnJS defineCommand
#   * clipanion (THIS)           — class-based, Yarn Berry's library
#
# clipanion is CLOSEST TO oclif (Heroku/Salesforce) which also uses
# class-based commands.  But oclif requires substantial framework
# scaffolding (oclif generate), produces .npmrc/.bashrc plugin
# installation hooks, and packages CLI as multiple commands across
# multiple npm packages.  clipanion is FLATTER: one Cli instance, one
# class per command, no plugin system, no install hooks.  Where oclif
# is a CLI FRAMEWORK with a heavyweight runtime, clipanion is a CLI
# LIBRARY with zero runtime dependencies (per its README tagline).
#
# REAL-WORLD clipanion USERS:
#
#   * yarnpkg/berry — Yarn 2/3/4 itself (the canonical user; every yarn
#     subcommand is a clipanion Command class)
#   * Blazity/nefi — AI agent for Next.js modernization (THIS, 67*)
#   * allure-framework/allure3 — Allure test reporter (296*)
#   * fabien0102/openapi-codegen — TS OpenAPI codegen (631*)
#   * microsoft/rnx-kit — Microsoft React Native kit (1720*)
#   * tscircuit/winterspec — Winter Spec test framework
#   * tmkn/packageanalyzer — Node.js package introspection
#   * arthuro555/gdmod — GDevelop game mod loader
#   * stephank/yarn-plugin-nixify — Yarn Nix plugin
#   * felipecrs/docker-meta — Docker bake metadata generator
#   * snuggery/snuggery — Snuggery monorepo tool
#   * Hundreds of independent Yarn-Berry-ecosystem CLIs
#
# -----------------------------------------------------------------------------
# NEFI'S CLI SURFACE (verbatim from src/commands/agent/index.ts)
# -----------------------------------------------------------------------------
#
# USAGE:
#   nefi [OPTIONS]
#
# Top-level (default command — runs the AI agent):
#   --force-write             Force overwrite of the dirty working tree
#                             (skip the git-clean-state check; useful
#                             when running on a feature branch with WIP)
#   --usage                   Print the usage of LLM calls
#                             (token count, request count, cost estimate)
#   --verbose                 Enable verbose logging including LLM calls
#                             usage (per-tool-call breakdown)
#   --skip-date-check         Skip the release-date gate (bypasses the
#                             "Coming soon..." stub that's only present
#                             in development builds)
#
# Built-in (registered via clipanion Builtins):
#   --help                    Show help and exit
#   --version                 Show version and exit
#
# Environment variables:
#   ANTHROPIC_API_KEY         Required — Anthropic API key for Claude
#                             (nefi calls Claude Sonnet for codebase
#                             analysis and script generation)
#
# nefi expects to be run from the root of a Next.js project (looks for
# next.config.js, package.json with "next" dependency, etc.).  The agent
# will analyze the existing codebase, plan a sequence of feature-
# integration scripts (component scaffolds, API routes, env vars,
# migrations), and execute them in optimal order via topological sort.
#
# =============================================================================

_nefi() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -s \
        '--force-write[force overwrite of dirty working tree]' \
        '--usage[print usage of LLM calls (tokens/requests/cost)]' \
        '--verbose[enable verbose logging including LLM call breakdown]' \
        '--skip-date-check[skip release-date gate (dev builds only)]' \
        '--help[show help and exit]' \
        '--version[show version and exit]' \
        && ret=0

    return ret
}

_nefi "$@"
