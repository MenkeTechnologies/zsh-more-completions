#compdef ov
# Documentation: https://github.com/noborus/ov
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ov - feature-rich terminal pager (noborus/ov). Flags from README usage table.
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '(-l --align)'{-l,--align}'[align output columns]' \
  '(-C --alternate-rows)'{-C,--alternate-rows}'[alternate row coloring]' \
  '--caption=[custom caption]:caption:' \
  '(-i --case-sensitive)'{-i,--case-sensitive}'[case-sensitive search]' \
  '(-d --column-delimiter)'{-d,--column-delimiter}'=[column delimiter]:delim:' \
  '(-c --column-mode)'{-c,--column-mode}'[column mode]' \
  '--column-rainbow[column rainbow mode]' \
  '--column-width[column-mode width]' \
  '--completion=[generate completion script]:shell:(bash zsh fish powershell)' \
  '--config=[config file]:file:_files' \
  '--converter=[input converter]:type:(es raw align wordwrap)' \
  '--debug[debug mode]' \
  '--disable-column-cycle[disable column cycling]' \
  '--disable-mouse[disable mouse]' \
  '(-e --exec)'{-e,--exec}'[command execution result instead of file]' \
  '(-X --exit-write)'{-X,--exit-write}'[print current screen on exit]' \
  '(-a --exit-write-after)'{-a,--exit-write-after}'=[lines after current to print]:n:' \
  '(-b --exit-write-before)'{-b,--exit-write-before}'=[lines before current to print]:n:' \
  '--filter=[filter search pattern]:pattern:' \
  '(-A --follow-all)'{-A,--follow-all}'[follow multiple files]' \
  '(-f --follow-mode)'{-f,--follow-mode}'[follow mode]' \
  '--follow-name[follow by file name]' \
  '--follow-section[section-by-section follow]' \
  '--force-screen[display screen when output is redirected]' \
  '(-H --header)'{-H,--header}'=[header line count]:n:' \
  '(-Y --header-column)'{-Y,--header-column}'=[vertical header column count]:n:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '--help-key[display key bindings]' \
  '--hide-other-section[hide other section]' \
  '--hscroll-width=[horizontal scroll width]:width:' \
  '--incsearch[incremental search]' \
  '(-j --jump-target)'{-j,--jump-target}'=[jump target]:target:' \
  '(-n --line-number)'{-n,--line-number}'[line number mode]' \
  '--list-view-modes[list config view modes]' \
  '--memory-limit=[chunks limit in memory]:n:' \
  '--memory-limit-file=[chunks limit in memory per file]:n:' \
  '(-M --multi-color)'{-M,--multi-color}'=[words to color]:words:' \
  '--non-match-filter=[filter non-matching pattern]:pattern:' \
  '--notify-eof=[notify at EOF count]:n:' \
  '--pattern=[search pattern]:pattern:' \
  '(-p --plain)'{-p,--plain}'[disable original decoration]' \
  '(-F --quit-if-one-screen)'{-F,--quit-if-one-screen}'[quit if output fits one screen]' \
  '(-r --raw)'{-r,--raw}'[raw escape sequences]' \
  '--regexp-search[regex search]' \
  '--ruler=[ruler mode]:n:(0 1 2)' \
  '--section-delimiter=[section delimiter regexp]:regexp:' \
  '--section-header[section delimiter line as header]' \
  '--section-header-num=[number of section header lines]:n:' \
  '--section-start=[section start position]:n:' \
  '--set-terminal-title[set terminal title]' \
  '--sidebar-mode=[sidebar mode]:mode:' \
  '--skip-extract[skip extracting compressed files]' \
  '--skip-lines=[skip line count]:n:' \
  '--smart-case-sensitive[smart case-sensitive search]' \
  '--status-line[show status line]' \
  '(-x --tab-width)'{-x,--tab-width}'=[tab width]:n:' \
  '(-v --version)'{-v,--version}'[show version]' \
  '(-y --vertical-header)'{-y,--vertical-header}'=[vertical header char count]:n:' \
  '(-m --view-mode)'{-m,--view-mode}'=[view mode]:mode:' \
  '(-T --watch)'{-T,--watch}'=[watch interval]:seconds:' \
  '(-w --wrap)'{-w,--wrap}'=[wrap mode]:mode:(char word)' \
  '*:file:_files' && ret=0
return ret
