#compdef openvsp vsp
# Documentation: https://github.com/OpenVSP/OpenVSP
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above (src/vsp/common.cpp ProcessCommandLine usage banner).

# OpenVSP: NASA Vehicle Sketch Pad - parametric aircraft geometry
local curcontext="$curcontext" ret=1
_arguments -C \
  '-script[run a vspscript file]:file:_files -g "*.vspscript(-.)"' \
  '-des[set variables from a .des file]:file:_files -g "*.des(-.)"' \
  '-xddm[set variables from an .xddm file]:file:_files -g "*.xddm(-.)"' \
  '-exp[export design variables]:file:_files' \
  '(- *)'{-h,-help,--help}'[show help]' \
  '*:VSP file:_files -g "*.vsp3(-.)"' && ret=0
return ret
