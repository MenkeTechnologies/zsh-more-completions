#compdef mdbook-drawio
# _mdbook-drawio — embed draw.io diagrams in mdbook (QBayLogic/mdbook-drawio)
# upstream: https://github.com/QBayLogic/mdbook-drawio
# Subcommands from src/main.rs.

_mdbook-drawio() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'supports:check whether a renderer is supported'
                'preprocess:run the preprocessor over stdin'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                supports) _arguments '1:renderer:(html epub markdown)' ;;
            esac
            ;;
    esac
}

_mdbook-drawio "$@"
