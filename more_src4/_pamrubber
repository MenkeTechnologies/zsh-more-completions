#compdef pamrubber
# Documentation: man pamrubber (Netpbm)
# Source: stretch a Netpbm image via control-point morphing (triangular or quadrilateral).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-tri -quad)-tri[3-point (triangle) morph]' \
    '(-tri -quad)-quad[4-point (quadrilateral) morph]' \
    '-linear[use linear (bilinear) interpolation]' \
    '-frame[draw a frame around output]' \
    '-randomseed=[random seed]:n:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:control points + image:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
