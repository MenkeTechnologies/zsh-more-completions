#compdef ppmlabel
# Documentation: man ppmlabel (Netpbm)
# Source: draw text labels onto a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '*-angle+[label rotation angle in degrees]:angle:' \
    '*-background+[background color or transparent]:bg:(transparent)' \
    '*-color+[label color]:color:' \
    '*-file+[file with one label per line]:file:_files' \
    '*-size+[text size]:textsize:' \
    '*-text+[label text]:text:' \
    '*-x+[anchor column]:column:' \
    '*-y+[anchor row]:row:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
