#compdef minify-html minhtml
# Documentation: https://github.com/wilsonzlin/minify-html/blob/master/minhtml/src/main.rs
# Reference accessed: 2026-05-19
# Verified: upstream source at the URL above. Removed invented
# --minify-css-level-1/2/3 flags; added the real
# --allow-noncompliant-unquoted-attribute-values,
# --allow-optimal-entities,
# --allow-removing-spaces-between-attributes, --minify-doctype,
# --remove-bangs, --remove-processing-instructions.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-o --output)'{-o,--output=}'[output file]:file:_files' \
  '--allow-noncompliant-unquoted-attribute-values[allow noncompliant unquoted attribute values]' \
  '--allow-optimal-entities[use shortest possible entity encodings]' \
  '--allow-removing-spaces-between-attributes[remove spaces between attributes]' \
  '--keep-closing-tags[keep closing tags]' \
  '--keep-comments[preserve comments]' \
  '--keep-html-and-head-opening-tags[keep <html> and <head> opening tags]' \
  '--keep-input-type-text-attr[keep type=text on input]' \
  '--keep-ssi-comments[keep SSI comments]' \
  '--minify-css[minify inline CSS]' \
  '--minify-doctype[minify the doctype]' \
  '--minify-js[minify inline JS]' \
  '--preserve-brace-template-syntax[preserve {{...}} template syntax]' \
  '--preserve-chevron-percent-template-syntax[preserve <% %> template syntax]' \
  '--remove-bangs[remove bang elements]' \
  '--remove-processing-instructions[remove processing instructions]' \
  '*:html:_files -g "*.{html,htm}"' && ret=0

return ret
