#compdef pamdice
# Documentation: man pamdice (Netpbm)
# Source: Netpbm pamdice — slice a Netpbm image into many horizontally and/or vertically.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-outstem=[output filename stem]:stem:' \
    '-outsuffix=[output filename suffix]:suffix:' \
    '-width=[tile width (pixels)]:width:' \
    '-height=[tile height (pixels)]:height:' \
    '-hoverlap=[horizontal overlap between tiles]:pixels:' \
    '-voverlap=[vertical overlap between tiles]:pixels:' \
    '-numberwidth=[digits to use in filename numbers]:N:' \
    '-listfile=[write tile-filename list to file]:file:_files' \
    '-indexfile=[write tile-index PAM image]:file:_files' \
    '-dry-run[do not write output (compute only)]' \
    '-verbose[print progress messages]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
