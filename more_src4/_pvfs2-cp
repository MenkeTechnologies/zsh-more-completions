#compdef pvfs2-cp
# Documentation: https://www.mankier.com/1/pvfs2-cp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pvfs2-cp: copy between PVFS2 and local fs
local curcontext="$curcontext" ret=1
_arguments -C \
  '-s+[strip size for dst file (OrangeFS only)]:size:' \
  '-n+[number of datafiles for dst (OrangeFS only)]:n:' \
  '-b+[intermediate buffer size in bytes]:bytes:' \
  '-t[report timing information]' \
  '-v[print version and exit]' \
  '*:files:_files' && ret=0
return ret
