#compdef powercli
# _powercli — VMware PowerCLI PowerShell modules for vSphere/VMC/NSX/SRM/etc. CLI alias (VMware team, PowerShell); PowerShell
# upstream: https://developer.vmware.com/web/tool/vmware-powercli

_powercli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-Command+[PowerShell command]:str:' \
        '-File+[script]:file:_files -g "*.ps1"' \
        '-ConfigurationName+[config name]:str:' \
        '-EncodedCommand+[base64 command]:str:' \
        '-ExecutionPolicy=+[policy]:p:(Restricted RemoteSigned AllSigned Unrestricted Bypass Undefined)' \
        '-InputFormat=+[format]:f:(Text XML)' \
        '-NoExit[no exit after running]' \
        '-NoLogo[no logo]' \
        '-NonInteractive[non interactive]' \
        '-NoProfile[no profile]' \
        '-OutputFormat=+[format]:f:(Text XML)' \
        '-PSConsoleFile+[file]:file:_files' \
        '-Sta[single threaded apartment]' \
        '-Mta[multi-threaded apartment]' \
        '-WindowStyle=+[style]:s:(Normal Minimized Maximized Hidden)' \
        '*:args:'
}

_powercli "$@"
