#compdef opencode
# Documentation: https://opencode.ai/docs/cli
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for opencode - AI coding agent built for the terminal

local curcontext="$curcontext" state line ret=1

_opencode_commands() {
  local -a commands=(
    'run:run opencode with a message in non-interactive mode'
    'auth:manage credentials and provider logins'
    'agent:manage agents for opencode'
    'session:manage opencode sessions'
    'serve:start a headless opencode API server'
    'web:start a headless opencode server with web interface'
    'attach:attach a terminal to a running opencode backend'
    'models:list available models'
    'upgrade:upgrade opencode to the latest version'
    'github:manage the GitHub agent for repository automation'
    'help:show help'
  )
  _describe -t commands 'opencode command' commands
}

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--print-logs[print logs to stderr]' \
  '--log-level=[log level]:level:(DEBUG INFO WARN ERROR)' \
  '1: :_opencode_commands' \
  '*:: :->args' && ret=0

case $state in
  args)
    case $words[1] in
      run)
        _arguments \
          '(-c --continue)'{-c,--continue}'[continue last session]' \
          '(-s --session)'{-s,--session=}'[session ID]:session id:' \
          '(-m --model)'{-m,--model=}'[model (provider/model)]:model:' \
          '(-f --file)'{-f,--file=}'[attach file]:file:_files' \
          '(-u --username)'{-u,--username=}'[basic auth username]:user:' \
          '(-p --password)'{-p,--password=}'[basic auth password]:password:' \
          '--agent=[agent to run]:agent:' \
          '--format=[output format]:format:(default json)' \
          '--fork[fork when continuing]' \
          '--share[share the session]' \
          '--title=[session title]:title:' \
          '--attach=[attach to running server URL]:url:' \
          '--dir=[working directory]:dir:_directories' \
          '--port=[local server port]:port:' \
          '--variant=[model variant]:variant:' \
          '--thinking[display thinking blocks]' \
          '--dangerously-skip-permissions[auto-approve permissions]' \
          '*:message:' && ret=0
        ;;
      auth)
        _arguments \
          '1:subcommand:((login\:authenticate\ with\ provider list\:show\ authenticated\ providers ls\:show\ authenticated\ providers logout\:remove\ provider\ credentials))' \
          '(-p --provider)'{-p,--provider=}'[provider]:provider:' \
          '(-m --method)'{-m,--method=}'[auth method]:method:' && ret=0
        ;;
      agent)
        _arguments \
          '1:subcommand:((create\:build\ new\ agent list\:show\ available\ agents))' \
          '--path=[agent path]:path:_files' \
          '--description=[description]:text:' \
          '--mode=[mode]:mode:' \
          '--permissions=[permissions]:perms:' \
          '(-m --model)'{-m,--model=}'[model]:model:' && ret=0
        ;;
      session)
        _arguments \
          '1:subcommand:((list\:show\ sessions delete\:remove\ a\ session))' \
          '(-n --max-count)'{-n,--max-count=}'[max sessions]:n:' \
          '--format=[output format]:format:' && ret=0
        ;;
      serve|web)
        _arguments \
          '(-p --port)'{-p,--port=}'[port to listen on]:port:' \
          '(-H --hostname)'{-H,--hostname=}'[hostname to bind]:hostname:' \
          '--mdns[enable mDNS discovery]' \
          '--mdns-domain=[mDNS domain]:domain:' \
          '--cors=[additional CORS origins]:origin:' && ret=0
        ;;
      attach)
        _arguments \
          '(-c --continue)'{-c,--continue}'[continue last session]' \
          '(-s --session)'{-s,--session=}'[session ID]:session id:' \
          '(-u --username)'{-u,--username=}'[basic auth user]:user:' \
          '(-p --password)'{-p,--password=}'[basic auth password]:password:' \
          '--fork[fork when continuing]' \
          '--dir=[working directory]:dir:_directories' \
          '*:url:' && ret=0
        ;;
      models)
        _arguments \
          '--refresh[refresh cached model list]' \
          '--verbose[extended metadata]' \
          '*:provider:' && ret=0
        ;;
      upgrade)
        _arguments \
          '(-m --method)'{-m,--method=}'[install method]:method:(curl npm pnpm bun brew)' && ret=0
        ;;
      github)
        _arguments \
          '1:subcommand:((install\:set\ up\ GitHub\ agent run\:execute\ agent))' \
          '--event=[GitHub event]:event:' \
          '--token=[token]:token:' && ret=0
        ;;
    esac
    ;;
esac

return ret
