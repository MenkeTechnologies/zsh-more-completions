#compdef ppmrainbow
# Documentation: man ppmrainbow (Netpbm)
# Source: generate a PPM image of a multi-color horizontal rainbow gradient.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[image width]:n:' \
    '-height=[image height]:n:' \
    '-tmpdir=[temporary directory]:dir:_files -/' \
    '-norepeat[do not repeat first color at end]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:color:' \
    && ret=0

return ret
