#compdef ontop
# ============================================================================
#  _ontop — Ontop: query relational databases as Virtual RDF Knowledge
#           Graphs using SPARQL
#
#  Source-direct extraction from
#    https://github.com/ontop/ontop/blob/master/client/cli/src/main/java/it/unibz/inf/ontop/cli/Ontop.java
#    https://github.com/ontop/ontop/blob/master/client/cli/src/main/java/it/unibz/inf/ontop/cli/Ontop*.java
#    https://github.com/rvesse/airline (the Airline library)
#
#  Maintained by the Ontop team (Free University of Bozen-Bolzano /
#  ontop/ontop).  852 GH stars.  Ontop is an OBDA (Ontology-Based Data
#  Access) platform that translates SPARQL queries into SQL against a
#  relational database — enables querying RDBMS as Virtual RDF Knowledge
#  Graphs.  Sister tools: Apache Jena (Java RDF framework), Stardog
#  (commercial RDF DB), Virtuoso (multi-paradigm DB), GraphDB (Ontotext).
#
#  CLI library taxonomy update: 4th Java CLI library — rvesse/airline.
#  Java ecosystem now has 4 documented CLI libraries (R276 picocli +
#  R322 JCommander + R323 args4j + R353 airline) joining the multi-
#  library leaders.  Airline (originally airlift/airline by Martin
#  Traverso, now maintained as rvesse/airline by Rob Vesse) is the
#  Java CLI framework used by Apache Cassandra's `nodetool`, Apache
#  Druid CLI, Confluent ksqlDB, Apache Pinot, Graylog, and many other
#  large Java systems.  450+ GH stars on rvesse/airline.
#
#  Airline distinctive features (vs picocli R276 / JCommander R322 /
#  args4j R323):
#    - `@Command(name = "X", description = "Y")` ANNOTATION on COMMAND CLASS
#    - `@Option(type = OptionType.COMMAND, name = {"--long"}, title = "X",
#       description = "Y")` ANNOTATION with EXPLICIT SCOPE TYPE
#      (OptionType.COMMAND/GLOBAL/GROUP) — distinguishes COMMAND-LEVEL,
#       GROUP-LEVEL, and GLOBAL flags AT THE ANNOTATION
#    - `@Env("VAR_NAME")` ANNOTATION for env var fallback
#    - `@BashCompletion(behaviour = CompletionBehaviour.FILENAMES)`
#       BUILT-IN COMPLETION HINTS (no separate completion-generation)
#    - `@RequiredOnlyIf(names = {"--other-flag"})` CONDITIONAL REQUIRED
#       constraint
#    - `@RequiredUnlessEnvironment(vars = {"X"})` env-var-fallback for
#       required validation
#    - `Cli.<T>builder("name").withDescription("X").withCommands(Cls.class,
#       ...).withGroup("verb").withDescription("Y").withCommand(SubCls.class)
#       .build()` — BUILDER-BASED top-level CLI with EXPLICIT COMMAND-CLASS
#       LIST (vs picocli's `@Command(subcommands = {...})` static enumeration
#       on class)
#    - `ParseCommandMissingException` / `ParseArgumentsUnexpectedException`
#       / `ParseOptionMissingException` / `ParseArgumentsIllegalValueException`
#       — RICH ERROR HIERARCHY for granular dispatch
#  Brings cross-language CLI library taxonomy variant count to 92; Java
#  ecosystem now has 4 documented CLI libraries.
#
#  Surface (verbatim from Ontop.java + sub-command classes):
#
#  Top-level subcommands:
#    version                   Show Ontop version
#    help                      Show help (default action on parse error)
#    query                     Execute SPARQL query against mapping
#    materialize               Materialize triples to file
#    bootstrap                 Bootstrap mapping from DB schema
#    validate                  Validate mapping file
#    endpoint                  Start SPARQL endpoint (HTTP server)
#    extract-db-metadata       Extract DB metadata to file
#
#  Mapping subcommand group (`ontop mapping <verb>`):
#    mapping obda-to-r2rml     Convert .obda mapping to R2RML
#    mapping r2rml-to-obda     Convert R2RML to .obda mapping
#    mapping r2rml-prettify    Pretty-print R2RML
#    mapping mapping-v1-to-v3  Convert v1 .obda to v3 .obda
#
#  Common endpoint flags (from OntopEndpoint.java):
#    --portal FILE             Endpoint portal file
#                              (env: ONTOP_PORTAL_FILE)
#    --port N                  SPARQL endpoint port (default 8080)
#    --cors-allowed-origins OR CORS allowed origins
#                              (env: ONTOP_CORS_ALLOWED_ORIGINS)
#    --lazy                    Lazy initialization
#                              (env: ONTOP_LAZY_INIT)
#    --dev                     Development mode
#                              (env: ONTOP_DEV_MODE)
#    --predefined-config FILE  Predefined query JSON config
#                              (env: ONTOP_PREDEFINED_CONFIG)
#    --predefined-queries FILE Predefined SPARQL queries TOML
#                              (env: ONTOP_PREDEFINED_QUERIES)
#    --contexts FILE           JSON-LD contexts for predefined queries
#                              (env: ONTOP_CONTEXTS)
#    --disable-portal-page     Disable /index.html
#                              (env: ONTOP_DISABLE_PORTAL_PAGE)
#    --enable-download-ontology Allow /ontology download
#                              (env: ONTOP_ENABLE_DOWNLOAD_ONTOLOGY)
#
#  Dup-skipped neighbors during hunt (smaller surface or in corpus):
#    - druid (apache/druid — IN CORPUS, Apache Druid CLI uses Airline)
#    - ksql (confluentinc/ksql 303 stars — uses Airline; check corpus)
#    - cassandra-nodetool (apache/cassandra — IN CORPUS)
#    - neptune-export (aws/neptune-export 15 stars — uses Airline,
#      AWS Labs niche tool)
#    - graylog (Graylog2/graylog2-server — IN CORPUS)
# ============================================================================

_ontop() {
  local context state state_descr line curcontext=$curcontext
  typeset -A opt_args

  _arguments -C \
    '1: :->cmd' \
    '*:: :->subargs'

  case $state in
    cmd)
      local -a verbs
      verbs=(
        'version:show Ontop version'
        'help:show help'
        'query:execute SPARQL query against mapping'
        'materialize:materialize triples to file'
        'bootstrap:bootstrap mapping from DB schema'
        'validate:validate mapping file'
        'endpoint:start SPARQL endpoint (HTTP server)'
        'extract-db-metadata:extract DB metadata to file'
        'mapping:manipulate mapping files (subcommand group)'
      )
      _describe -t commands 'ontop subcommand' verbs
      ;;
    subargs)
      case $line[1] in
        mapping)
          if [[ $CURRENT == 2 ]]; then
            local -a sub=(
              'obda-to-r2rml:convert .obda mapping to R2RML'
              'r2rml-to-obda:convert R2RML to .obda mapping'
              'r2rml-prettify:pretty-print R2RML'
              'mapping-v1-to-v3:convert v1 .obda to v3 .obda'
            )
            _describe -t subcommands 'mapping subcommand' sub
          fi
          ;;
        endpoint)
          _arguments -s -S \
            '--portal=[endpoint portal file]:file:_files' \
            '--port=[SPARQL endpoint port (default 8080)]:port' \
            '--cors-allowed-origins=[CORS allowed origins]:origins' \
            '--lazy[lazy initialization]' \
            '--dev[development mode]' \
            '--predefined-config=[predefined query JSON config]:file:_files -g "*.json"' \
            '--predefined-queries=[predefined SPARQL queries TOML]:file:_files -g "*.toml"' \
            '--contexts=[JSON-LD contexts for predefined queries]:file:_files' \
            '--disable-portal-page[disable /index.html portal page]' \
            '--enable-download-ontology[allow /ontology download]' \
            '--mapping=[mapping file (.obda or R2RML)]:file:_files -g "*.(obda|ttl|r2rml)"' \
            '--ontology=[ontology file]:file:_files -g "*.(owl|ttl|nt)"' \
            '--properties=[properties file (.properties)]:file:_files -g "*.properties"'
          ;;
        query|materialize|bootstrap|validate|extract-db-metadata)
          _arguments -s -S \
            '--mapping=[mapping file (.obda or R2RML)]:file:_files -g "*.(obda|ttl|r2rml)"' \
            '--ontology=[ontology file]:file:_files -g "*.(owl|ttl|nt)"' \
            '--properties=[properties file (.properties)]:file:_files -g "*.properties"' \
            '--output=[output file]:file:_files'
          ;;
      esac
      ;;
  esac
}

_ontop "$@"
