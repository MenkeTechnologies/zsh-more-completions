#compdef pio
# _pio — PlatformIO pio shorter alias for platformio CLI managing embedded development boards libraries projects upload monitor debug test cross-platform build for Arduino ESP-IDF Mbed Zephyr STM32Cube freeRTOS (platformio team, Python); click
# upstream: https://github.com/platformio/platformio-core

_pio() {
    local -a sub=(
        'access:access ACL management'
        'account:account operations'
        'boards:list available boards'
        'check:run static code analysis'
        'ci:run unit-test continuous integration'
        'debug:start debug session'
        'device:device list monitor'
        'home:open Home dashboard'
        'init:initialize project'
        'lib:library management'
        'org:organization management'
        'package:package management'
        'pkg:package management alias'
        'platform:platform management'
        'project:project commands'
        'remote:remote development'
        'run:run project build upload monitor'
        'settings:show settings'
        'system:system maintenance'
        'team:team management'
        'test:run tests'
        'update:update tools'
        'upgrade:upgrade core'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '-c+[caller]:str:' \
        '--caller=+[caller]:str:' \
        '--no-ansi[no ANSI]' \
        '--force[force]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pio subcommand' sub ;;
        args)
            case $words[1] in
                run) _arguments \
                    '-e+[environment]:str:' \
                    '--environment=+[environment]:str:' \
                    '-t+[target]:t:(buildfs build clean compiledb erase nobuild size upload uploadfs program upload upload-and-monitor monitor exec test)' \
                    '--target=+[target]:t:(buildfs build clean compiledb erase nobuild size upload uploadfs program upload upload-and-monitor monitor exec test)' \
                    '-d+[project dir]:dir:_files -/' \
                    '--project-dir=+[project dir]:dir:_files -/' \
                    '-c+[project config]:file:_files -g "platformio.ini"' \
                    '--project-conf=+[project config]:file:_files -g "platformio.ini"' \
                    '-j+[jobs]:n:' \
                    '--jobs=+[jobs]:n:' \
                    '--silent[silent]' \
                    '--list-targets[list targets]' ;;
                init) _arguments \
                    '-b+[board]:str:' \
                    '--board=+[board]:str:' \
                    '-d+[project dir]:dir:_files -/' \
                    '--ide=+[ide]:i:(atom clion eclipse emacs netbeans qtcreator sublimetext visualstudio vscode codeblocks)' \
                    '--no-install-dependencies[no install dependencies]' ;;
                test) _arguments \
                    '-e+[environment]:str:' \
                    '--environment=+[environment]:str:' \
                    '-f+[test filter]:str:' \
                    '--filter=+[test filter]:str:' \
                    '--ignore=+[pattern]:str:' \
                    '--upload-port=+[port]:str:' \
                    '--test-port=+[port]:str:' \
                    '--without-uploading[no upload]' \
                    '--without-testing[no testing]' \
                    '--without-building[no build]' \
                    '--verbose[verbose]' ;;
            esac
            ;;
    esac
}

_pio "$@"
