#compdef mrhistmatch
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrhistmatch.html
# Source: MRtrix3/mrtrix3 cmd/mrhistmatch.cpp — match histogram of one image to another (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-mask_input+[binary mask defining input histogram region]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-mask_target+[binary mask defining target histogram region]:image:_files -g "*.{nii,nii.gz,mif}"' \
    '-bins+[number of histogram bins]:n:_default' \
    '1:type:(scale linear nonlinear)' \
    '2:input image:_files -g "*.{nii,nii.gz,mif}"' \
    '3:target image:_files -g "*.{nii,nii.gz,mif}"' \
    '4:output image:_files' \
    && ret=0

return ret
