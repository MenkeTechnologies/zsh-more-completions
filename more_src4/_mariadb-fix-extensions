#compdef mariadb-fix-extensions
# Documentation: https://mariadb.com/docs/server/clients-and-utilities/table-tools/mariadb-fix-extensions
# Reference accessed: 2026-05-19
# Verified: upstream MariaDB docs document only the data_dir positional
# argument; no CLI flags are documented.
# Removed from prior file: bogus man.archlinux.org URL and unverified
# -?/--help/-V option entries.

# mariadb-fix-extensions: rename .ISM/.ISD to .MYI/.MYD for old MyISAM tables
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:data directory:_files -/' && ret=0
return ret
