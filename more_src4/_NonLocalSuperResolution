#compdef NonLocalSuperResolution
# Documentation: https://github.com/ANTsX/ANTs
# Source: ANTsX/ANTs Examples/NonLocalSuperResolution.cxx — non-local patch super-resolution (C++, itk parser).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '(-d --image-dimensionality)'{-d+,--image-dimensionality=}'[image dimensionality]:n:(2 3 4)' \
    '(-i --input-image)'{-i+,--input-image=}'[low-resolution input image]:file:_files -g "*.{nii,nii.gz,mha,nrrd}"' \
    '(-j --interpolated-image)'{-j+,--interpolated-image=}'[pre-interpolated input image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-k --reference-image)'{-k+,--reference-image=}'[high-resolution reference image]:file:_files -g "*.{nii,nii.gz}"' \
    '(-p --patch-radius)'{-p+,--patch-radius=}'[patch radius (e.g. 1 or 1x1x1)]:radius:_default' \
    '(-r --search-radius)'{-r+,--search-radius=}'[search radius (e.g. 3 or 3x3x3)]:radius:_default' \
    '(-g --intensity-difference-sigma)'{-g+,--intensity-difference-sigma=}'[intensity difference sigma]:n:_default' \
    '(-t --patch-similarity-sigma)'{-t+,--patch-similarity-sigma=}'[patch similarity sigma]:n:_default' \
    '(-o --output)'{-o+,--output=}'[output super-resolved image]:file:_files' \
    '(- *)'{-v,--version}'[print version]' \
    '--verbose=[verbosity level]:n:(0 1 2)' \
    '(- *)'{-h,--help}'[show help]' \
    && ret=0

return ret
