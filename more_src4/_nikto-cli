#compdef nikto-cli
# _nikto-cli — Chris Sullo Nikto web server scanner CLI alias (sullo team, Perl); custom argparse
# upstream: https://github.com/sullo/nikto

_nikto-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-Help[long help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-host=+[target host]:host:_hosts' \
        '-h+[target host]:host:_hosts' \
        '-port=+[target port]:port:' \
        '-p+[target port]:port:' \
        '-ssl[force SSL]' \
        '-nossl[no SSL]' \
        '-vhost=+[virtual host header]:str:' \
        '-id=+[id:pass for basic auth]:str:' \
        '-Format=+[format]:f:(csv htm txt xml sql nbe json)' \
        '-output=+[output file]:file:_files' \
        '-o+[output file]:file:_files' \
        '-Save=+[dir]:dir:_files -/' \
        '-Plugins=+[plugins]:str:' \
        '-Tuning=+[scan tuning]:str:' \
        '-T+[scan tuning]:str:' \
        '-evasion=+[ids evasion]:str:' \
        '-e+[ids evasion]:str:' \
        '-mutate=+[mutation]:str:' \
        '-m+[mutation]:str:' \
        '-config=+[config file]:file:_files' \
        '-c+[config file]:file:_files' \
        '-Cgidirs=+[cgi dirs]:str:' \
        '-cookies[print cookies found]' \
        '-Display=+[display]:str:' \
        '-D+[display]:str:' \
        '-Pause=+[pause between tests]:str:' \
        '-P+[pause between tests]:str:' \
        '-list-plugins[list plugins]' \
        '-no404[no 404 checking]' \
        '-nointeractive[no interactive features]' \
        '-nolookup[no DNS lookups]' \
        '-nocache[do not cache]' \
        '-useragent=+[user agent]:str:' \
        '-update[update database]' \
        '-dbcheck[check syntax of databases]' \
        '-followredirects[follow redirects]' \
        '-Single[single test]' \
        '-RSAcert=+[RSA cert]:file:_files' \
        '-key=+[client key]:file:_files' \
        '-CAcert=+[CA cert]:file:_files' \
        '-timeout=+[seconds]:n:' \
        '-maxtime=+[max minutes]:n:' \
        '-Userdbs=+[dbs]:str:' \
        '-Pause=+[seconds]:n:' \
        '-ask=+[ask]:m:(yes no auto)' \
        '*:url:_urls'
}

_nikto-cli "$@"
