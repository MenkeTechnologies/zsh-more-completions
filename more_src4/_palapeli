#compdef palapeli
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man6/palapeli.6.html
# Reference accessed: 2026-05-20
# Verified: upstream manpage at the URL above. -i/--import is documented.

# palapeli: KDE jigsaw puzzle game
local curcontext="$curcontext" ret=1
_arguments -C \
  '--help[show help]' \
  '--help-qt[show Qt-specific options]' \
  '--help-kde[show KDE-specific options]' \
  '--help-all[show all options]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '(-i --import)'{-i+,--import=}'[import puzzle into local collection (no main window)]:file:_files -g "*.puzzle(-.)"' && ret=0
return ret
