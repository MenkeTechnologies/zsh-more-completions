#compdef policy-controller-tester
# _policy-controller-tester — sigstore policy-controller offline ClusterImagePolicy tester
# upstream: https://github.com/sigstore/policy-controller
# Flags from cmd/tester/main.go on tip.

_policy-controller-tester() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-policy=[path or URL of ClusterImagePolicy]:src:_files' \
        '-version=[print version and exit]:bool:(true false)' \
        '-image=[image to compare against the policy]:image:' \
        '-resource=[Kubernetes resource file for includeSpec/includeObjectMeta]:file:_files' \
        '-trustroot=[TrustRoot resource file]:file:_files' \
        '-log-level=[log level]:level:(debug info warn error)' \
        '-enable-oci11=[enable experimental OCI 1.1 referrers attestation discovery]:bool:(true false)'
}

_policy-controller-tester "$@"
