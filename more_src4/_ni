#compdef ni
# Documentation: https://github.com/antfu-collective/ni
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '-g[install globally]' \
  '-D[save as dev dependency]' \
  '-P[production only (omit dev)]' \
  '-i[interactive mode]' \
  '-C+[change directory]:directory:_directories' \
  '(-w --workspace)'{-w,--workspace}'[target workspace root]' \
  '--frozen[frozen lockfile install]' \
  '\?[print the command that would run]' \
  '*:package name' && ret=0

return ret
