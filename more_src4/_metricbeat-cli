#compdef metricbeat-cli metricbeat
# _metricbeat-cli — Elastic Beats metricbeat-cli CLI command-line frontend to the Metricbeat lightweight shipper collecting metrics from system services like Apache Docker Kubernetes MySQL PostgreSQL Redis Nginx Linux process system Prometheus shipping to Elasticsearch Logstash Kafka Redis with modular metricsets keystore-management config-test setup-templates (Elastic team, Go); cobra
# upstream: https://www.elastic.co/beats/metricbeat

_metricbeat-cli() {
    local -a sub=(
        'run:run beat'
        'test:test config or output'
        'export:export config templates dashboards'
        'keystore:keystore management'
        'modules:module enable/disable/list'
        'setup:setup index templates dashboards'
        'version:show version'
        'completion:generate shell completion'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d+[selectors]:str:' \
        '-c+[config file]:file:_files -g "*.yml *.yaml"' \
        '--c=+[config file]:file:_files -g "*.yml *.yaml"' \
        '-e[log to stderr]' \
        '--path.config=+[dir]:dir:_files -/' \
        '--path.data=+[dir]:dir:_files -/' \
        '--path.home=+[dir]:dir:_files -/' \
        '--path.logs=+[dir]:dir:_files -/' \
        '-E+[k=v]:str:' \
        '-M+[module setting]:str:' \
        '--strict.perms=+[bool]:s:(true false)' \
        '--system.hostfs=+[dir]:dir:_files -/' \
        '-N[do not publish events]' \
        '--once[publish once and exit]' \
        '--memprofile=+[file]:file:_files' \
        '--httpprof=+[host:port]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'metricbeat-cli subcommand' sub ;;
        args)
            case $words[1] in
                modules) _arguments '1:op:(enable disable list)' '*:module:' ;;
                setup) _arguments '1:op:(index-management dashboards machine-learning pipelines)' ;;
            esac
            ;;
    esac
}

_metricbeat-cli "$@"
