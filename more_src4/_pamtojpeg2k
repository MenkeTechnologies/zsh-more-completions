#compdef pamtojpeg2k
# Documentation: man pamtojpeg2k (Netpbm)
# Source: convert a Netpbm image to JPEG 2000 (.jp2).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-imgareatlx=[image-area top-left x]:column:' \
    '-imgareatly=[image-area top-left y]:row:' \
    '-tilegrdtlx=[tile-grid top-left x]:column:' \
    '-tilegrdtly=[tile-grid top-left y]:row:' \
    '-tilewidth=[tile width]:columns:' \
    '-tileheight=[tile height]:rows:' \
    '-prcwidth=[precinct width]:columns:' \
    '-prcheight=[precinct height]:rows:' \
    '-cblkwidth=[code-block width]:columns:' \
    '-cblkheight=[code-block height]:rows:' \
    '-mode=[arithmetic mode]:mode:(integer int real)' \
    '-compression=[compression ratio]:ratio:' \
    '-size=[target output bytes]:bytes:' \
    '-ilyrrates=[intermediate-layer bit rates (csv)]:list:' \
    '-numrlvls=[number of resolution levels]:number:' \
    '-progression=[progression order]:order:(lrcp rlcp rpcl pcrl cprl)' \
    '-numgbits=[number of guard bits]:number:' \
    '-nomct[no multi-component transform]' \
    '-sop[emit Start-Of-Packet markers]' \
    '-eph[emit End-of-Packet-Header markers]' \
    '-lazy[lazy mode]' \
    '-termall[terminate all coding passes]' \
    '-segsym[segmentation symbols]' \
    '-vcausal[vertically-causal coding]' \
    '-pterm[predictable termination]' \
    '-resetprob[reset MQ probability at each pass]' \
    '-verbose[verbose output]' \
    '-debuglevel=[libjasper debug level]:number:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
