#compdef postman
# _postman-cli — Postman CLI (postmanlabs/postman-cli)
# upstream: https://github.com/postmanlabs/postman-cli

_postman-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '1: :_postman_commands' \
        '*::arg:->args' && ret=0

    case $state in
        args)
            case $words[1] in
                login)
                    _arguments \
                        '--with-api-key=[Postman API key]:key:' && ret=0 ;;
                run)
                    _arguments \
                        '(-e --environment)'{-e,--environment}'=[environment file or ID]:env:_files -g "*.json"' \
                        '(-g --globals)'{-g,--globals}'=[global variables file]:file:_files -g "*.json"' \
                        '(-n --iteration-count)'{-n,--iteration-count}'=[number of iterations]:count:' \
                        '(-d --iteration-data)'{-d,--iteration-data}'=[data file for iterations]:file:_files -g "*.json *.csv"' \
                        '--delay-request=[delay between requests in ms]:ms:' \
                        '--timeout=[global timeout in ms]:ms:' \
                        '--timeout-request=[per-request timeout in ms]:ms:' \
                        '--bail[stop on first failure]' \
                        '(-r --reporters)'{-r,--reporters}'=[reporters to use]:reporters:_values -s , reporter cli json junit html' \
                        '--reporter-json-export=[JSON reporter output file]:file:_files' \
                        '--reporter-junit-export=[JUnit reporter output file]:file:_files' \
                        '--reporter-html-export=[HTML reporter output file]:file:_files' \
                        '--color=[enable or disable color]:mode:(on off auto)' \
                        '1:collection:_files -g "*.json"' && ret=0 ;;
                collection)
                    local -a coll_subs=(
                        'run:run a collection'
                    )
                    _describe -t cmds 'collection subcommand' coll_subs && ret=0 ;;
                api)
                    local -a api_subs=(
                        'lint:lint an API definition'
                    )
                    _describe -t cmds 'api subcommand' api_subs && ret=0 ;;
                logout) ;;
            esac
            ;;
    esac

    return ret
}

(( $+functions[_postman_commands] )) ||
_postman_commands() {
    local -a commands
    commands=(
        'login:log in to Postman'
        'logout:log out of Postman'
        'collection:manage collections'
        'api:manage API definitions'
        'run:run a collection'
    )
    _describe -t commands 'postman command' commands
}

_postman-cli "$@"
