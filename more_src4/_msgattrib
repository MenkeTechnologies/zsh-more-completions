#compdef msgattrib
# Documentation: msgattrib --help (GNU gettext)
# Source: filter or manipulate attributes of PO catalog messages.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '*'{-D+,--directory=}'[search directory for input files]:dir:_files -/' \
    {-o+,--output-file=}'[write output to FILE]:file:_files' \
    '(--untranslated)--translated[keep translated, remove untranslated]' \
    '(--translated)--untranslated[keep untranslated, remove translated]' \
    '(--only-fuzzy)--no-fuzzy[remove fuzzy messages]' \
    '(--no-fuzzy)--only-fuzzy[keep fuzzy messages]' \
    '(--only-obsolete)--no-obsolete[remove obsolete messages]' \
    '(--no-obsolete)--only-obsolete[keep obsolete messages]' \
    '--set-fuzzy[set all messages fuzzy]' \
    '--clear-fuzzy[set all messages non-fuzzy]' \
    '--set-obsolete[set all messages obsolete]' \
    '--clear-obsolete[set all messages non-obsolete]' \
    '--previous[keep previous msgids of fuzzy-set messages]' \
    '--clear-previous[remove previous msgid from all messages]' \
    '--empty[set msgstr empty when removing fuzzy]' \
    '--only-file=[manipulate only entries listed in FILE.po]:file:_files -g "*.po"' \
    '--ignore-file=[manipulate only entries NOT listed in FILE.po]:file:_files -g "*.po"' \
    '--fuzzy[synonym for --only-fuzzy --clear-fuzzy]' \
    '--obsolete[synonym for --only-obsolete --clear-obsolete]' \
    {-P,--properties-input}'[input is Java .properties]' \
    '--stringtable-input[input is NeXTstep/GNUstep .strings]' \
    '--color=-[colorize output]::when:(always never auto html)' \
    '--style=[CSS style rule file]:file:_files -g "*.css"' \
    {-e,--no-escape}'[no C escapes in output (default)]' \
    {-E,--escape}'[use C escapes, no extended chars]' \
    '--force-po[write PO file even if empty]' \
    {-i,--indent}'[indented output style]' \
    '--no-location[suppress #: lines]' \
    {-n,--add-location=-}'[generate #: lines]::value:(full file never)' \
    '--strict[strict Uniforum output]' \
    {-p,--properties-output}'[output Java .properties]' \
    '--stringtable-output[output NeXTstep/GNUstep .strings]' \
    {-w+,--width=}'[page width]:cols:' \
    '--no-wrap[do not wrap long message lines]' \
    {-s,--sort-output}'[sort output and remove duplicates]' \
    {-F,--sort-by-file}'[sort output by file location]' \
    ':input file:_files -g "*.po"' \
    && ret=0

return ret
