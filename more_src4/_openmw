#compdef openmw openmw-launcher openmw-iniimporter openmw-essimporter openmw-wizard
# Documentation: https://manpages.debian.org/testing/openmw/openmw.6.en.html
# Reference accessed: 2026-05-20
# Verified: openmw(6) Debian manpage - option set matches Debian/upstream
# openmw binary. Removed: fabricated --user-data, --bsa, --groundcover,
# --no-sound, --no-grab, --export-fonts, --script-blacklist, --load-savegame,
# --skip-menu, --debug; corrected --fs-strict to flag-arg form.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)--help[print help message]' \
  '(- *)--version[print version information and quit]' \
  '--data=[data directories (later directories higher priority)]:dir:_files -/' \
  '--data-local=[local data directory (highest priority)]:dir:_files -/' \
  '--fallback-archive=[fallback BSA archives (later higher priority)]:archive:' \
  '--resources=[resources directory]:dir:_files -/' \
  '--start=[set initial cell]:cell:' \
  '--content=[content file(s): esm/esp, or omwgame/omwaddon]:file:_files -g "*.{esm,esp,omwgame,omwaddon}"' \
  '--anim-verbose=[output animation indices files]:flag:(0 1)' \
  '--nosound=[disable all sounds]:flag:(0 1)' \
  '--script-verbose=[verbose script output]:flag:(0 1)' \
  '--script-all=[compile all scripts (excluding dialogue scripts) at startup]:flag:(0 1)' \
  '--script-console=[enable console-only script functionality]:flag:(0 1)' \
  '--script-run=[file with console commands executed at startup]:file:_files' \
  '--new-game=[activate char gen / new game mechanics]:flag:(0 1)' \
  '--fs-strict=[strict file system handling (no case folding)]:flag:(0 1)' \
  '--encoding=[character encoding for game messages]:enc:(win1250 win1251 win1252 win1253 win1254 win1255 win1256 win1257 win1258)' \
  '--fallback=[Morrowind.ini fallback values]:opt:' \
  '--activate-dist=[activation distance override]:dist:' && ret=0

return ret
