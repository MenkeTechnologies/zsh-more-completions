#compdef oleobj

_oleobj() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(-r --recursive)'{-r,--recursive}'[scan files recursively in directories]' \
        '(-z --zip)'{-z,--zip}'[zip password for encrypted files]:password:' \
        '(-d --output-dir)'{-d,--output-dir}'[output directory for extracted objects]:directory:_directories' \
        '(-l --log-level)'{-l,--log-level}'[set logging level]:level:(DEBUG INFO WARNING ERROR CRITICAL)' \
        '*:file:_files' && ret=0

    return ret
}

_oleobj "$@"
