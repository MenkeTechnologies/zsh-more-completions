#compdef mediainfo
# Documentation: https://manpages.debian.org/bookworm/mediainfo/mediainfo.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for mediainfo - media file info (MediaArea)
# Note: mediainfo CLI option names are documented in CamelCase but are
# accepted case-insensitively.

_arguments -s -S \
  '(- *)'{-h,--Help}'[show help]' \
  '(- *)--Version[show version]' \
  '--Help-Inform[show help for --Inform option]' \
  '--Info-Parameters[show list of --Inform parameters]' \
  '(-f --Full)'{-f,--Full}'[full information display]' \
  '--Output=[output format]:format:(HTML XML JSON PBCore PBCore2 EBUCore EBUCore_JSON FIMS_1_1 FIMS_1_2 FIMS_1_3 MPEG-7 NISO_Z39.87)' \
  '--Inform=[custom output template]:template:' \
  '--Language=[output language]:language:' \
  '--Details=[detail level]:level:(0 1)' \
  '--BOM[add BOM to output]' \
  '--LogFile=[log file]:file:_files' \
  '--Ssl_CertificateFileName=[SSL certificate file]:file:_files' \
  '--Ssl_CertificateFormat=[SSL certificate format]:format:' \
  '--Ssl_PrivateKeyFileName=[SSL private key file]:file:_files' \
  '--Ssl_PrivateKeyFormat=[SSL private key format]:format:' \
  '--Ssl_CertificateAuthorityFileName=[SSL CA file]:file:_files' \
  '--Ssl_CertificateAuthorityPath=[SSL CA path]:path:_directories' \
  '--Ssl_CertificateRevocationListFileName=[SSL CRL file]:file:_files' \
  '--Ssl_IgnoreSecurity[ignore SSL security]' \
  '--ssh-publickey=[SSH public key]:file:_files' \
  '--ssh-privatekey=[SSH private key]:file:_files' \
  '--ssh-knownhostsfilename=[SSH known hosts file]:file:_files' \
  '--ssh-ignoresecurity[ignore SSH security]' \
  '*:media file:_files'
