#compdef nilfs_cleanerd
# Documentation: https://manpages.debian.org/unstable/nilfs-tools/nilfs_cleanerd.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

_arguments -s \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-h,--help}'[show help]' \
  '(-c --conf)'{-c,--conf=}'[config file]:file:_files' \
  '(-p --protection-period)'{-p,--protection-period=}'[protection period seconds]:secs:' \
  ':device:_files'
