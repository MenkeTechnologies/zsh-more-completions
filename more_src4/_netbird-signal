#compdef netbird-signal
# _netbird-signal — NetBird signal server daemon (netbirdio/netbird)
# upstream: https://github.com/netbirdio/netbird
# Flags from signal/cmd/{root,run}.go (cobra).

_netbird-signal() {
    local context state state_descr line
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '--log-level=[log level]:level:(panic fatal error warn info debug trace)' \
        '--log-file=[log file path or "console"]:file:_files' \
        '1: :->cmd' \
        '*:: :->args'

    case $state in
        cmd)
            local -a cmds=(
                'run:start NetBird Signal Server daemon'
            )
            _describe -t commands command cmds
            ;;
        args)
            case $words[1] in
                run)
                    _arguments \
                        '--port=[server port]:port:' \
                        '--metrics-port=[metrics HTTP port]:port:' \
                        '--letsencrypt-data-dir=[Let'\''s Encrypt data dir]:dir:_files -/' \
                        '--ssl-dir=[(deprecated) Let'\''s Encrypt data dir]:dir:_files -/' \
                        '--letsencrypt-domain=[domain for Let'\''s Encrypt cert]:domain:' \
                        '--letsencrypt-email=[email for Let'\''s Encrypt registration]:email:' \
                        '--cert-file=[SSL cert file]:file:_files' \
                        '--cert-key=[SSL cert private key]:file:_files'
                    ;;
            esac
            ;;
    esac
}

_netbird-signal "$@"
