#compdef oats
# Documentation: upstream README at github.com/grafana/oats
# Reference accessed: 2026-05-30
# Grafana OATs R54 — OpenTelemetry Acceptance Tests. Declarative YAML
# test framework for the LGTM stack (Loki + Grafana + Tempo + Mimir).
# Sister-binary to existing _xk6 (R53) coverage within Grafana family.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '-timeout=[test-case timeout (default 30s)]:duration:' \
  '-absent-timeout=[absence-assertion timeout (default 10s)]:duration:' \
  '-lgtm-version=[docker-otel-lgtm version (default latest)]:version:' \
  '-manual-debug[keep containers running for debugging]' \
  '-lgtm-log-all[enable logging for all LGTM containers]' \
  '-lgtm-log-grafana[enable logging for Grafana container]' \
  '-lgtm-log-loki[enable logging for Loki container]' \
  '-lgtm-log-tempo[enable logging for Tempo container]' \
  '-lgtm-log-prometheus[enable logging for Prometheus container]' \
  '-lgtm-log-pyroscope[enable logging for Pyroscope container]' \
  '-lgtm-log-collector[enable logging for OpenTelemetry Collector]' \
  '-host=[host override (default localhost)]:host:' \
  '-log-limit=[max log output length per entry]:N:' \
  '*:test YAML file or directory:_files -g "*.yaml *.yml"' \
  && ret=0

return ret
