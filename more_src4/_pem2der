#compdef pem2der
# Documentation: pem2der --help (Nettle utility shipped with sslh tests)
# Reference accessed: 2026-05-20
# Verified: pem2der --help output. Accepts filename= and output_file= params.

local curcontext="$curcontext" state line ret=1
local -a params

params=(
  'filename=:input PEM file'
  'output_file=:output DER file'
)

_arguments -s -S \
  '*:param=value:->params' && ret=0

case $state in
  (params)
    if compset -P 'filename='; then
      _files -g "*.pem" && ret=0
    elif compset -P 'output_file='; then
      _files -g "*.der" && ret=0
    else
      _describe -t params 'param' params -S '' && ret=0
    fi
    ;;
esac

return ret
