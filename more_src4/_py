_py() {
    local context state state_descr line ret=1
    typeset -A opt_args

    _arguments -C \
        '(-h --help --list)'{-h,--help}'[show launcher help + the selected Python -h output]' \
        '(-h --help)--list[list installed python{X.Y} binaries detected on $PATH (comfy-table output)]' \
        '(-h --help --list)-2[run latest Python 2.x]' \
        '(-h --help --list)-3[run latest Python 3.x]' \
        '(-h --help --list)-3.0[run latest Python 3.0.x]' \
        '(-h --help --list)-3.1[run latest Python 3.1.x]' \
        '(-h --help --list)-3.2[run latest Python 3.2.x]' \
        '(-h --help --list)-3.3[run latest Python 3.3.x]' \
        '(-h --help --list)-3.4[run latest Python 3.4.x]' \
        '(-h --help --list)-3.5[run latest Python 3.5.x]' \
        '(-h --help --list)-3.6[run latest Python 3.6.x]' \
        '(-h --help --list)-3.7[run latest Python 3.7.x]' \
        '(-h --help --list)-3.8[run latest Python 3.8.x]' \
        '(-h --help --list)-3.9[run latest Python 3.9.x]' \
        '(-h --help --list)-3.10[run latest Python 3.10.x]' \
        '(-h --help --list)-3.11[run latest Python 3.11.x]' \
        '(-h --help --list)-3.12[run latest Python 3.12.x]' \
        '(-h --help --list)-3.13[run latest Python 3.13.x]' \
        '(-h --help --list)-3.14[run latest Python 3.14.x]' \
        '(-h --help --list)-3.15[run latest Python 3.15.x]' \
        '*::python args:->pyargs' && ret=0

    case $state in
        pyargs)
            _arguments \
                '-c[program passed in as string (terminates option list)]:command:' \
                '-m[run library module as a script (terminates option list)]:module:' \
                '-O[remove assert and __debug__-dependent statements]' \
                '-OO[do -O changes and discard docstrings]' \
                '-q[quiet -- do not print version and copyright on interactive startup]' \
                '-v[verbose (trace import statements)]' \
                '-i[inspect interactively after running script]' \
                '-u[force the stdout and stderr streams to be unbuffered]' \
                '-E[ignore PYTHON* environment variables (such as PYTHONPATH)]' \
                '-s[do not add user site directory to sys.path]' \
                '-S[do not run "import site" on initialization]' \
                '-I[isolate Python from the user environment (-E + -s)]' \
                '-B[do not write .pyc files on import]' \
                '-X[set implementation-specific option]:option:' \
                '-W[warning control: action:message:category:module:lineno]:warning:' \
                '1:script or -:_files -g "*.py"' \
                '*:script args:_files' && ret=0
            ;;
    esac
    return ret
}

_py "$@"
