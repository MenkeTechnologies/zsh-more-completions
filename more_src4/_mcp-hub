#compdef mcp-hub
# Documentation: https://github.com/ravitemer/mcp-hub
# Reference accessed: 2026-05-22
# Verified: npm mcp-hub package CLI options and README.

# Zsh completion for mcp-hub - MCP server manager and tool router

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--port[port to run the hub server]:port:' \
  '*--config[path to MCP config JSON file]:file:_files' \
  '--watch[watch config files and reload affected servers]' \
  '--auto-shutdown[shutdown when no clients are connected]' \
  '--shutdown-delay[delay before auto-shutdown in ms]:ms:' && ret=0

return ret
