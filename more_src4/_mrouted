#compdef mrouted
# Documentation: man mrouted(8)
# Source: netbsd/src usr.sbin/mrouted — DVMRP multicast routing daemon (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-c+[configuration file (default /etc/mrouted.conf)]:config file:_files' \
    '-d+[debug level (0-3, default 2)]:debug level:(0 1 2 3)' \
    '-p[non-pruning mode for testing]' \
    && ret=0

return ret
