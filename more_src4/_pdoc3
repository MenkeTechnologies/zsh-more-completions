#compdef pdoc3
# _pdoc3 — auto-generate API docs for Python modules (pdoc3/pdoc)
# upstream: https://github.com/pdoc3/pdoc
# Flags from pdoc/cli.py (argparse).

_pdoc3() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)--version[show version]' \
        '*'{-c+,--config=}'[override template option (OPTION=VALUE)]:opt:' \
        '--filter=[comma-separated identifier filters]:patterns:' \
        '(-f --force)'{-f,--force}'[overwrite existing output]' \
        '(--html --pdf)--html[output HTML formatted docs]' \
        '(--html --pdf)--pdf[output Markdown for PDF conversion]' \
        '(-o --output-dir)'{-o+,--output-dir=}'[output directory]:dir:_files -/' \
        '--external-links[treat all link references as external]' \
        '--template-dir=[template directory]:dir:_files -/' \
        '--link-prefix=[link URL prefix]:prefix:' \
        '--close-stdin[close stdin after parsing]' \
        '--http=[serve docs over HTTP (HOST\:PORT)]:hostport:' \
        '--skip-errors[continue on import errors]' \
        '*:Python module:'
}

_pdoc3 "$@"
