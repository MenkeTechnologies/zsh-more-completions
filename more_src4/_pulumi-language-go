#compdef pulumi-language-go
# _pulumi-language-go — Pulumi language plugin for Go (pulumi/pulumi)
# upstream: https://github.com/pulumi/pulumi
# Flags from sdk/go/pulumi-language-go/main.go (flag).

_pulumi-language-go() {
    _arguments \
        '-version[print plugin version and exit]' \
        '-tracing=[Zipkin tracing endpoint]:endpoint:' \
        '1:engine address:'
}

_pulumi-language-go "$@"
