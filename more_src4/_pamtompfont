#compdef pamtompfont
# Documentation: man pamtompfont (Netpbm)
# Source: convert a Netpbm image to MetaPost font glyph code.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:netpbm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
