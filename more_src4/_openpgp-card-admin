#compdef openpgp-card-admin
# Documentation: https://codeberg.org/openpgp-card/openpgp-card-tools
# Reference accessed: 2026-05-20
# Verified: openpgp-card-tools package upstream installs `oct` (and
# historically `opgpcard`); there is no canonical `openpgp-card-admin`
# binary. Admin functionality is exposed via `oct admin` / `opgpcard admin`
# subcommands.
# STUB: minimal completion retained per "do not delete files" directive.

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands
commands=(
  'status:show card status'
  'list:list connected cards'
  'pin:manage PIN / admin PIN'
  'admin:admin operations (name/url/import/generate)'
  'sign:sign data with signing slot'
  'decrypt:decrypt data with encryption slot'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)-V[show version]' \
  '--card=[card identifier]:ident:' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'openpgp-card-admin command' commands && ret=0 ;;
esac
return ret
