#compdef pcre2grep
# Documentation: pcre2grep --help
# Source: PCRE2 — Perl-compatible regex grep.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--help[show help]' \
    '(- *)'{-V,--version}'[print version]' \
    '(-A --after-context)'{-A,--after-context=}'[after-context lines]:n:' \
    '(-B --before-context)'{-B,--before-context=}'[before-context lines]:n:' \
    '(-C --context)'{-C,--context=}'[context lines (before+after)]:n:' \
    '(-a --text)'{-a,--text}'[treat binary files as text]' \
    '--binary-files=[binary file treatment]:word:(binary text without-match)' \
    '--buffer-size=[buffer start size]:n:' \
    '--max-buffer-size=[buffer max size]:n:' \
    '(--color --colour)'{--color,--colour=-}'[matched text color]::when:(auto always never)' \
    '(-c --count)'{-c,--count}'[print count of matching lines]' \
    '(-D --devices)'{-D,--devices=}'[device/FIFO/socket handling]:action:(read skip)' \
    '(-d --directories)'{-d,--directories=}'[directory handling]:action:(read skip recurse)' \
    '--posix-digit[\\d always matches [0-9] in UTF/UCP mode]' \
    '(-E --case-restrict)'{-E,--case-restrict}'[restrict case matching]' \
    '*'{-e,--regex=,--regexp=}'[specify pattern]:pattern:' \
    '(-F --fixed-strings)'{-F,--fixed-strings}'[fixed strings (newline-separated)]' \
    '*'{-f,--file=}'[read patterns from file]:file:_files' \
    '--posix-pattern-file[POSIX semantics for pattern files]' \
    '--file-list=[read files to search from file]:file:_files' \
    '--file-offsets[output file offsets, not text]' \
    '--group-separator=[separator between groups]:text:' \
    '(-H --with-filename -h --no-filename)'{-H,--with-filename}'[force file-name prefix]' \
    '(-H --with-filename -h --no-filename)'{-h,--no-filename}'[suppress file-name prefix]' \
    '-I[treat binary files as not matching]' \
    '(-i --ignore-case)'{-i,--ignore-case}'[case-insensitive]' \
    '(-l --files-with-matches)'{-l,--files-with-matches}'[print only file names with matches]' \
    '(-L --files-without-match)'{-L,--files-without-match}'[print only file names without matches]' \
    '--label=[name for standard input]:name:' \
    '--line-buffered[use line buffering]' \
    '--line-offsets[output line numbers and offsets]' \
    '--locale=[use named locale]:locale:' \
    '--heap-limit=[PCRE2 heap limit (KiB)]:n:' \
    '--match-limit=[PCRE2 match limit]:n:' \
    '--depth-limit=[PCRE2 depth limit]:n:' \
    '--recursion-limit=[obsolete depth-limit synonym]:n:' \
    '(-M --multiline)'{-M,--multiline}'[multiline mode]' \
    '(-m --max-count)'{-m,--max-count=}'[stop after N matched lines]:n:' \
    '(-N --newline)'{-N,--newline=}'[newline type]:type:(CR LF CRLF ANYCRLF ANY NUL)' \
    '(-n --line-number)'{-n,--line-number}'[print line numbers]' \
    '--no-jit[disable JIT optimization]' \
    '--no-group-separator[suppress group separators]' \
    '(-O --output)'{-O,--output=}'[show only this text]:text:' \
    '(-o --only-matching)'{-o,--only-matching=-}'[show only matching part]::n:' \
    '--om-separator=[separator for multiple -o output]:text:' \
    '--om-capture=[capture count for --only-matching]:n:' \
    '(-P --no-ucp)'{-P,--no-ucp}'[do not enable UCP mode with Unicode]' \
    '(-q --quiet)'{-q,--quiet}'[suppress output (set return code only)]' \
    '(-r --recursive)'{-r,--recursive}'[recursive subdir scan]' \
    '*--exclude=[exclude file pattern when recursing]:pattern:' \
    '*--include=[include file pattern when recursing]:pattern:' \
    '*--exclude-dir=[exclude dir pattern when recursing]:pattern:' \
    '*--include-dir=[include dir pattern when recursing]:pattern:' \
    '--exclude-from=[read exclude list from file]:file:_files' \
    '--include-from=[read include list from file]:file:_files' \
    '(-s --no-messages)'{-s,--no-messages}'[suppress error messages]' \
    '(-t --total-count)'{-t,--total-count}'[print total count of matching lines]' \
    '(-u --utf -U --utf-allow-invalid)'{-u,--utf}'[UTF/Unicode]' \
    '(-u --utf -U --utf-allow-invalid)'{-U,--utf-allow-invalid}'[UTF/Unicode allow invalid]' \
    '(-v --invert-match)'{-v,--invert-match}'[invert match]' \
    '(-w --word-regex --word-regexp)'{-w,--word-regex,--word-regexp}'[whole-word match]' \
    '(-x --line-regex --line-regexp)'{-x,--line-regex,--line-regexp}'[whole-line match]' \
    '--allow-lookaround-bsk[allow \\K in lookarounds]' \
    '(-Z --null)'{-Z,--null}'[NUL after filenames]' \
    '*:pattern + files:_files' \
    && ret=0

return ret
