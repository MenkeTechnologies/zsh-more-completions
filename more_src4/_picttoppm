#compdef picttoppm
# Documentation: man picttoppm (Netpbm)
# Source: convert a Macintosh PICT raster image to PPM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-verbose=[verbosity level]:n:' \
    '-fullres[use full-resolution opcodes]' \
    '-noheader[no 512-byte header]' \
    '-quickdraw[QuickDraw fallback rendering]' \
    '-fontdir+[font directory]:file:_files -/' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pict file:_files -g "*.(pict|pct)"' \
    && ret=0

return ret
