#compdef nrepl
# Documentation: https://nrepl.org/nrepl/usage/server.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-i --interactive)'{-i,--interactive}'[start nREPL and connect with built-in client]' \
  '(-c --connect)'{-c,--connect}'[connect to a running nREPL with built-in client]' \
  '(-C --color)'{-C,--color}'[use colors in output]' \
  '(-b --bind)'{-b+,--bind=}'[bind address]:address:_hosts' \
  '(-h --host)--host=[connect host]:host:_hosts' \
  '(-p --port)'{-p+,--port=}'[server port (0 = random)]:port:' \
  '(-s --socket)'{-s+,--socket=}'[start on a filesystem socket]:file:_files' \
  '--ack=[acknowledge port to another nREPL server]:ack-port:' \
  '(-n --handler)'{-n+,--handler=}'[message handler]:fn:' \
  '*'{-m+,--middleware=}'[middleware var to inject]:middleware:' \
  '(-t --transport)'{-t+,--transport=}'[transport]:transport:' \
  '*::extra:' && ret=0

return ret
