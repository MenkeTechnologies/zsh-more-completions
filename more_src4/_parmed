#compdef parmed
# Documentation: https://parmed.github.io/ParmEd/html/_modules/parmed/scripts.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# ParmEd: parameter/topology file editor (Amber, CHARMM, GROMACS, OpenMM)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '*'{-i+,--input=}'[script with ParmEd commands]:file:_files' \
  '*'{-p+,--parm=}'[topology file(s) to load]:file:_files' \
  '*'{-c+,--inpcrd=}'[inpcrd file(s) to load]:file:_files' \
  '(-O --overwrite)'{-O,--overwrite}'[overwrite output files]' \
  '(-l --logfile)'{-l+,--logfile=}'[log file]:file:_files' \
  '--prompt=[command prompt string]:prompt:' \
  '(-n --no-splash)'{-n,--no-splash}'[suppress greeting logo]' \
  '(-e --enable-interpreter)'{-e,--enable-interpreter}'[allow single Python commands]' \
  '(-s --strict)'{-s,--strict}'[abort on unrecognized input]' \
  '(-r --relaxed)'{-r,--relaxed}'[ignore unrecognized input]' \
  '*::parmed script and args:_files' && ret=0
return ret
