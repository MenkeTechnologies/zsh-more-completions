#compdef novalyn
# Documentation: https://github.com/nanodelabs/novalyn
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Source: cargo binstall novalyn@0.1.1
# Probed via: completions zsh

autoload -U is-at-least

_novalyn() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-c+[Working directory to use (defaults to current directory)]:CWD:_default' \
'--cwd=[Working directory to use (defaults to current directory)]:CWD:_default' \
'*-v[Increase verbosity (-v, -vv, -vvv)]' \
'*--verbose[Increase verbosity (-v, -vv, -vvv)]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_novalyn_commands" \
"*::: :->novalyn" \
&& ret=0
    case $state in
    (novalyn)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:novalyn-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
':shell -- The shell to generate completions for (e.g. bash, zsh, fish, powershell):((bash\:"Bourne Again \`SHell\` (bash)"
elvish\:"Elvish shell"
fish\:"Friendly Interactive \`SHell\` (fish)"
powershell\:"\`PowerShell\`"
zsh\:"Z \`SHell\` (zsh)"
nushell\:"Nushell"))' \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
'-f+[From tag version range]:FROM:_default' \
'--from=[From tag version range]:FROM:_default' \
'-t+[To tag version range]:TO:_default' \
'--to=[To tag version range]:TO:_default' \
'-n+[Override the inferred next version (e.g. "1.2.3")]:SEMVER:_default' \
'--new-version=[Override the inferred next version (e.g. "1.2.3")]:SEMVER:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(generate)
_arguments "${_arguments_options[@]}" : \
'-o+[Output path for changelog file (implies --write if path is CHANGELOG.md)]:PATH:_default' \
'--output=[Output path for changelog file (implies --write if path is CHANGELOG.md)]:PATH:_default' \
'-f+[From tag version range]:FROM:_default' \
'--from=[From tag version range]:FROM:_default' \
'-t+[To tag version range]:TO:_default' \
'--to=[To tag version range]:TO:_default' \
'-n+[Override the inferred next version (e.g. "1.2.3")]:SEMVER:_default' \
'--new-version=[Override the inferred next version (e.g. "1.2.3")]:SEMVER:_default' \
'*-e+[Exclude specific authors by name or email (repeatable)]:NAME_OR_EMAIL:_default' \
'*--exclude-author=[Exclude specific authors by name or email (repeatable)]:NAME_OR_EMAIL:_default' \
'-g+[GitHub token for API access (reads from GITHUB_TOKEN or GH_TOKEN env vars)]:GITHUB_TOKEN:_default' \
'--github-token=[GitHub token for API access (reads from GITHUB_TOKEN or GH_TOKEN env vars)]:GITHUB_TOKEN:_default' \
'-w[Write the changelog to CHANGELOG.md (default\: print to stdout)]' \
'--write[Write the changelog to CHANGELOG.md (default\: print to stdout)]' \
'-N[Exclude contributors section from changelog]' \
'--no-authors[Exclude contributors section from changelog]' \
'-E[Hide authors emails]' \
'--hide-author-email[Hide authors emails]' \
'-c[]' \
'--clean[]' \
'-s[Sign release]' \
'--sign[Sign release]' \
'-y[Automatically confirm all prompts (non-interactive mode)]' \
'--yes[Automatically confirm all prompts (non-interactive mode)]' \
'-G[Disable GitHub aliasing (enabled by default, converts email addresses to @handles)]' \
'--no-github-alias[Disable GitHub aliasing (enabled by default, converts email addresses to @handles)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(release)
_arguments "${_arguments_options[@]}" : \
'-f+[From tag version range]:FROM:_default' \
'--from=[From tag version range]:FROM:_default' \
'-t+[To tag version range]:TO:_default' \
'--to=[To tag version range]:TO:_default' \
'--new-version=[Override the inferred next version (e.g. "1.2.3")]:SEMVER:_default' \
'*--exclude-author=[Exclude specific authors by name or email (repeatable)]:NAME_OR_EMAIL:_default' \
'-g+[GitHub token for API access (reads from GITHUB_TOKEN or GH_TOKEN env vars)]:GITHUB_TOKEN:_default' \
'--github-token=[GitHub token for API access (reads from GITHUB_TOKEN or GH_TOKEN env vars)]:GITHUB_TOKEN:_default' \
'-d[Simulate the release process without making changes (preview only)]' \
'--dry-run[Simulate the release process without making changes (preview only)]' \
'-n[Exclude contributors section from changelog]' \
'--no-authors[Exclude contributors section from changelog]' \
'-E[Hide authors emails]' \
'--hide-author-email[Hide authors emails]' \
'-c[]' \
'--clean[]' \
'-s[Sign release]' \
'--sign[Sign release]' \
'-y[Automatically confirm all prompts (non-interactive mode)]' \
'--yes[Automatically confirm all prompts (non-interactive mode)]' \
'-G[Disable GitHub aliasing (enabled by default, converts email addresses to @handles)]' \
'--no-github-alias[Disable GitHub aliasing (enabled by default, converts email addresses to @handles)]' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(github)
_arguments "${_arguments_options[@]}" : \
'-t+[The git tag to sync as a GitHub release]:TAG:_default' \
'--tag=[The git tag to sync as a GitHub release]:TAG:_default' \
'-b+[Path to file containing release body (defaults to changelog block)]:BODY_PATH:_default' \
'--body-path=[Path to file containing release body (defaults to changelog block)]:BODY_PATH:_default' \
'-h[Print help]' \
'--help[Print help]' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_novalyn__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:novalyn-help-command-$line[1]:"
        case $line[1] in
            (completions)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(show)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(generate)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(release)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(github)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_novalyn_commands] )) ||
_novalyn_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'show:Show the next inferred version based on commit history and semver rules' \
'generate:Generate a changelog release block for the specified commit range' \
'release:Run a full release\: bump version, generate changelog, create git tag, and optionally sign/tag' \
'github:Synchronize GitHub releases with local changelog data' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'novalyn commands' commands "$@"
}
(( $+functions[_novalyn__completions_commands] )) ||
_novalyn__completions_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn completions commands' commands "$@"
}
(( $+functions[_novalyn__generate_commands] )) ||
_novalyn__generate_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn generate commands' commands "$@"
}
(( $+functions[_novalyn__github_commands] )) ||
_novalyn__github_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn github commands' commands "$@"
}
(( $+functions[_novalyn__help_commands] )) ||
_novalyn__help_commands() {
    local commands; commands=(
'completions:Generate shell completions' \
'show:Show the next inferred version based on commit history and semver rules' \
'generate:Generate a changelog release block for the specified commit range' \
'release:Run a full release\: bump version, generate changelog, create git tag, and optionally sign/tag' \
'github:Synchronize GitHub releases with local changelog data' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'novalyn help commands' commands "$@"
}
(( $+functions[_novalyn__help__completions_commands] )) ||
_novalyn__help__completions_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn help completions commands' commands "$@"
}
(( $+functions[_novalyn__help__generate_commands] )) ||
_novalyn__help__generate_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn help generate commands' commands "$@"
}
(( $+functions[_novalyn__help__github_commands] )) ||
_novalyn__help__github_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn help github commands' commands "$@"
}
(( $+functions[_novalyn__help__help_commands] )) ||
_novalyn__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn help help commands' commands "$@"
}
(( $+functions[_novalyn__help__release_commands] )) ||
_novalyn__help__release_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn help release commands' commands "$@"
}
(( $+functions[_novalyn__help__show_commands] )) ||
_novalyn__help__show_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn help show commands' commands "$@"
}
(( $+functions[_novalyn__release_commands] )) ||
_novalyn__release_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn release commands' commands "$@"
}
(( $+functions[_novalyn__show_commands] )) ||
_novalyn__show_commands() {
    local commands; commands=()
    _describe -t commands 'novalyn show commands' commands "$@"
}

if [ "$funcstack[1]" = "_novalyn" ]; then
    _novalyn "$@"
else
    compdef _novalyn novalyn
fi
