#compdef pulp-admin
# Documentation: https://docs.pulpproject.org/en/2.21/user-guide/admin-client/introduction.html
# Reference accessed: 2026-05-20
# Verified: upstream Pulp 2 admin client documentation at the URL above.

# pulp-admin: Pulp v2 administrative CLI
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'rpm:manage RPM-related content and features'
  'puppet:manage Puppet-related content and features'
  'iso:manage ISO repositories'
  'docker:manage Docker registries'
  'ostree:manage OSTree repositories'
  'python:manage Python repositories'
  'deb:manage Debian repositories'
  'auth:authentication (user/role/permission)'
  'consumer:consumer management'
  'consumer-group:consumer group management'
  'event:event listener management'
  'login:log into the Pulp server'
  'logout:log out of the Pulp server'
  'nodes:Pulp node management'
  'orphan:orphan content management'
  'repo:repository management (cross-type)'
  'server:server configuration and capabilities'
  'tasks:server task management'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(-u --username)'{-u+,--username=}'[server username]:user:' \
  '(-p --password)'{-p+,--password=}'[server password]:pass:' \
  '--config=[configuration file]:file:_files' \
  '--map[display CLI map of commands]' \
  '-v[verbose output (INFO level)]' \
  '-vv[debug output (DEBUG level)]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'pulp-admin command' commands && ret=0 ;;
esac
return ret
