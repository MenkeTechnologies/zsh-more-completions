#compdef py2dsc
# _py2dsc — convert Python sdist into Debian source package (astraw/stdeb)
# upstream: https://github.com/astraw/stdeb
# Flags from py2dsc(1) man page.

_py2dsc() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-d --dist-dir)'{-d+,--dist-dir=}'[output directory (default deb_dist)]:dir:_files -/' \
        '(-a --patch-already-applied)'{-a,--patch-already-applied}'[patch already applied]' \
        '(-z --suite)'{-z+,--suite=}'[distribution name]:suite:(unstable testing stable bookworm trixie)' \
        '(-m --maintainer)'{-m+,--maintainer=}'[maintainer Name <email>]:str:' \
        '--debian-version=[Debian version (default 1)]:ver:' \
        '(-x --extra-cfg-file)'{-x+,--extra-cfg-file=}'[additional .cfg file]:file:_files' \
        '(-p --patch-file)'{-p+,--patch-file=}'[patch file before setup.py]:file:_files' \
        '(-l --patch-level)'{-l+,--patch-level=}'[patch level]:n:' \
        '(-q --patch-posix)'{-q,--patch-posix}'[apply patch in POSIX mode]' \
        '(-r --remove-expanded-source-dir)'{-r,--remove-expanded-source-dir}'[remove expanded source]' \
        '(-i --ignore-install-requires)'{-i,--ignore-install-requires}'[ignore install_requires]' \
        '--guess-conflicts-provides-replaces[guess Conflicts/Provides/Replaces]' \
        '--with-python2[build for Python 2]' \
        '--with-python3[build for Python 3]' \
        '*:source distfile:_files -g "*.{zip,tar.gz}"'
}

_py2dsc "$@"
