#compdef openalex
# _openalex — OurResearch openalex CLI client to the OpenAlex REST API querying open-access aggregated scholarly catalog of works authors institutions sources concepts publishers funders by OpenAlex ID DOI ORCID ROR ISSN Wikidata filtering by year cited-by works-count fields-of-study (OurResearch team, Python); custom argparse
# upstream: https://openalex.org/

_openalex() {
    local -a sub=(
        'works:query scholarly works'
        'authors:query authors'
        'sources:query journals/sources'
        'institutions:query institutions'
        'concepts:query concepts'
        'topics:query topics'
        'publishers:query publishers'
        'funders:query funders'
        'random:fetch random entity'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--mailto=+[email]:str:' \
        '--api-key=+[key]:str:' \
        '--per-page=+[N]:n:' \
        '--page=+[N]:n:' \
        '--cursor=+[cursor]:str:' \
        '--sort=+[s]:s:(relevance_score cited_by_count works_count publication_date)' \
        '--filter=+[k:v]:str:' \
        '--search=+[query]:str:' \
        '--group-by=+[field]:str:' \
        '--select=+[fields]:str:' \
        '--sample=+[N]:n:' \
        '--seed=+[seed]:n:' \
        '-f+[format]:f:(json bibtex ris csv yaml table)' \
        '--format=+[format]:f:(json bibtex ris csv yaml table)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'openalex subcommand' sub ;;
        args)
            case $words[1] in
                works|authors|sources|institutions|concepts|topics|publishers|funders) _arguments '*:id-or-query:' ;;
            esac
            ;;
    esac
}

_openalex "$@"
