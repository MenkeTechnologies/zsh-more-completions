#compdef pycui
# Documentation: https://github.com/hhatto/genzshcomp
# Reference accessed: 2026-05-20
# Verified: genzshcomp upstream repo at the URL above.
# Source: https://github.com/hhatto/genzshcomp/blob/e841ec01b7a035cda68f848387ada277c0bd57a0/zshfunc/_pycui
# STUB: generic genzshcomp wrapper that derives options from `pycui --help`.

_func() {
    _arguments -s -S \
        ":::_get_helplist" \
        "*::args:_files"
}

(( $+functions[_get_helplist] )) ||
_get_helplist() {
    local opts
    local cache_policy
    local cache_name="${service}_options"
    zstyle -s ":completion:${curcontext}:" cache-policy cache_policy
    if [[ -z "$cache_policy" ]]; then
        zstyle ":completion:${curcontext}:" cache-policy _opts_caching_policy
    fi

    if ( [[ ${+_opts} -eq 0 ]] || _cache_invalid ${cache_name} ) \
        && ! _retrieve_cache ${cache_name}; then
        opts=(${${(f)"$(${service} --help | genzshcomp -f list)"}})
        _store_cache ${cache_name} opts
    fi

    _describe 'options' opts
}

_opts_caching_policy() {
    local -a oldp
    oldp=( "$1"(Nmw+1) )
    (( $#oldp ))
}

_func "$@"
