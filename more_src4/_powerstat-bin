#compdef powerstat
# _powerstat-bin — powerstat power-usage measurement (Colin Ian King, C); measure CPU/power via battery dis discharge or RAPL
# upstream: https://github.com/ColinIanKing/powerstat

_powerstat-bin() {
    _arguments \
        '-c+[duration]:sec:' \
        '-C[only CSV output at end]' \
        '-d+[delay seconds]:n:' \
        '-D[show idle stats]' \
        '-f[force]' \
        '-g[gather stats]' \
        '-h[show help]' \
        '-H[show histogram]' \
        '-i+[start sleep seconds]:n:' \
        '-l[smooth output]' \
        '-n[no headings]' \
        '-o+[output file]:file:_files' \
        '-p[redundant prefix]' \
        '-r[redundant suffix]' \
        '-R+[reads]:n:' \
        '-s+[samples]:n:' \
        '-S+[stop after N samples]:n:' \
        '-t[CPU thermal info]' \
        '-T+[temperature output]:cel/fah:(c f)' \
        '-y[use RAPL/MSR]' \
        '-Y+[zone for RAPL]:zone:' \
        '-z[no zero results]' \
        '-V[show version]'
}

_powerstat-bin "$@"
