#compdef ods-ksmutil
# Documentation: https://wiki.opendnssec.org/display/DOCS20/ods-ksmutil
# Reference accessed: 2026-05-16
# Verified: OpenDNSSEC wiki. OpenDNSSEC 1.x tool; 2.x uses ods-enforcer.

# ods-ksmutil: OpenDNSSEC 1.x KASP management utility
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'setup:initial setup'
  'update:update kasp/zonelist/conf/all'
  'zone:add/delete/list zones'
  'zonelist:import/export zonelist'
  'key:generate/import/export/list/purge/rollover/ksk-retire/ds-seen/delete'
  'rollover:rollover list'
  'policy:export/import/purge policy'
  'repository:repository list'
  'backup:list/prepare/commit/rollback/done backups'
  'database:database backup'
  'start:start enforcer'
  'stop:stop enforcer'
  'notify:notify enforcer'
)
_arguments -C \
  '1: :->cmd' \
  '*::arg:_files' && ret=0
case $state in
  cmd) _describe -t commands 'ods-ksmutil command' commands && ret=0 ;;
esac
return ret
