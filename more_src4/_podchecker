#compdef podchecker
# Documentation: podchecker --help
# Source: Perl POD podchecker — POD syntax checker.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)-help[show help]' \
    '(- *)-man[show manual page]' \
    '-quiet[do not print success messages]' \
    '*(-warnings -nowarnings)-warnings[print warnings (repeat for higher level)]' \
    '*(-warnings -nowarnings)-nowarnings[do not print warnings]' \
    '*:POD file:_files -g "*.{pod,pm,pl}"' \
    && ret=0

return ret
