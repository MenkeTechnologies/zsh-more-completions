#compdef pcm-tsx
# Documentation: https://github.com/intel/pcm/blob/master/src/pcm-tsx.cpp
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcm-tsx: Intel PCM Intel TSX event monitor
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-silent[suppress informational output]' \
  '-csv[CSV output to stdout]' \
  '-csv=-[CSV output to file]:file:_files' \
  '-F[force execution despite missing RTM support]' \
  '-f[force execution despite missing RTM support]' \
  '-force[force execution despite missing RTM support]' \
  '-pid[restrict to PID]:pid:' \
  '*-e[TSX event to monitor (up to 4)]:event:' \
  '-i=-[number of iterations]:n:' \
  '*::pcm-tsx args:_files' && ret=0
return ret
