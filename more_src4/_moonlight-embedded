#compdef moonlight
# Documentation: https://github.com/moonlight-stream/moonlight-embedded
# Reference accessed: 2026-05-27
# Verified: upstream src/main.c help() and src/config.c long_options table
# (moonlight-stream/moonlight-embedded). NOTE: moonlight-embedded uses single-dash
# long-options (e.g. -fps, -bitrate); actions are positional keywords (pair,
# stream, list, quit, map, unpair, help), not flags. The task list mentioned
# -server/-cert/-key/-pair/-list/-quit/-keytype — those are not in upstream and
# are omitted; the canonical equivalents are positional actions plus -keydir.

local curcontext="$curcontext" state line ret=1

local -a _ml_actions
_ml_actions=(
  'pair:pair device with computer'
  'unpair:unpair device with computer'
  'stream:stream computer to device'
  'list:list available games and applications'
  'quit:quit the application or game being streamed'
  'map:create mapping for gamepad'
  'help:show help'
)

_arguments -C \
  '-config[load configuration file]:file:_files' \
  '-save[save configuration file]:file:_files' \
  '-verbose[enable verbose output]' \
  '-debug[enable verbose and debug output]' \
  '-720[use 1280x720 resolution (default)]' \
  '-1080[use 1920x1080 resolution]' \
  '-4k[use 3840x2160 resolution]' \
  '-width[horizontal resolution]:width:' \
  '-height[vertical resolution]:height:' \
  '-rotate[display rotation angle]:angle:(0 90 180 270)' \
  '-fps[frames per second]:fps:(30 60 90 120)' \
  '-bitrate[bitrate in Kbps]:kbps:' \
  '-packetsize[max packet size in bytes]:bytes:' \
  '-codec[video codec]:codec:(auto h264 h265 hevc av1)' \
  '-hdr[enable HDR streaming]' \
  '-remote[WAN streaming optimizations]:mode:(yes no auto)' \
  '-app[name of app to stream]:app:' \
  '-nosops[do not allow GFE to modify game settings]' \
  '-localaudio[play audio locally on the host computer]' \
  '-surround[surround sound mode]:mode:(5.1 7.1)' \
  '-keydir[directory holding encryption keys]:directory:_files -/' \
  '-mapping[gamepad mapping configuration file]:file:_files' \
  '-platform[system for audio/video/input]:system:(pi imx aml rk x11 x11_vdpau sdl fake)' \
  '-nounsupported[refuse unsupported resolutions]' \
  '-quitappafter[send quit app request after session]' \
  '-viewonly[disable all input processing]' \
  '-nomouseemulation[disable gamepad mouse emulation]' \
  '-windowed[display screen in a window]' \
  '*-input[input device (repeatable)]:device:_files -g "/dev/input/*"' \
  '-audio[audio output device]:device:' \
  '-pin[pairing PIN]:pin:' \
  '-port[server port]:port:' \
  '1: :->action' \
  '*:: :->rest' && ret=0

case $state in
  action)
    _describe -t commands 'moonlight action' _ml_actions && ret=0
    ;;
  rest)
    _arguments \
      '*:host:_hosts' && ret=0
    ;;
esac

return ret
