#compdef nia-wizard
# Documentation: https://github.com/nozomio-labs/nia-wizard
# Reference accessed: 2026-05-22
# Verified: src/bin.ts yargs command definitions.

# Zsh completion for nia-wizard - install Nia CLI/skills/MCP for coding agents

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--local[use local mode via pipx]' \
  '--remote[use remote Nia cloud MCP]' \
  '--debug[enable debug logging]' \
  '--ci[CI mode skip prompts]' \
  '--agent[print agent-facing onboarding prompt]' \
  '1:command:->cmds' \
  '*:: :->args' && ret=0

case $state in
  cmds)
    _values 'nia-wizard command' \
      'mcp[manage MCP setup]' \
      'skill[manage skill installation]' && ret=0
    ;;
  args)
    case $line[1] in
      mcp)
        _values 'mcp action' add remove && ret=0
        case $line[2] in
          add)
            _arguments \
              '--api-key[Nia API key]:key:' \
              '--local[local mode]' \
              '--remote[remote mode]' \
              '--debug[debug logging]' \
              '--ci[CI mode]' && ret=0
            ;;
          remove)
            _arguments '--debug[debug logging]' && ret=0
            ;;
        esac
        ;;
      skill)
        case $line[2] in
          add)
            _arguments \
              '--api-key[Nia API key]:key:' \
              '--repo[skill repo]:repo:' \
              '--agent[target agent]:agent:' \
              '--global[install to global skills dirs]' \
              '--yes[auto-confirm prompts]' \
              '--debug[debug logging]' && ret=0
            ;;
          *)
            _values 'skill action' add && ret=0
            ;;
        esac
        ;;
      *)
        _arguments '1:api-key:' && ret=0
        ;;
    esac
    ;;
esac

return ret
