#compdef pmcpp
# _pmcpp — PCP-aware C-style preprocessor (performancecopilot/pcp)
# upstream: https://github.com/performancecopilot/pcp
# Flags from src/pmcpp/pmcpp.c (pmgetopt opts).

_pmcpp() {
    _arguments \
        '(- *)-?[show help]' \
        '*'{-D+,--define=}'[define macro name[=value]]:macro:' \
        '*'{-I+,--include=}'[include search directory]:dir:_files -/' \
        '-P[suppress # lineno marker output]' \
        '(-r --restrict)'{-r,--restrict}'[restrict macro expansion to #name]' \
        '(-s --shell)'{-s,--shell}'[use % control syntax instead of #]' \
        '-d[enable debug mode]' \
        '1:input file:_files' \
        '2:output file:_files'
}

_pmcpp "$@"
