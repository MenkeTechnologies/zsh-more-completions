#compdef multipass-cli
# _multipass-cli — Canonical Multipass orchestrates virtual Ubuntu instances CLI alias (Canonical, C++); custom argparse
# upstream: https://github.com/canonical/multipass

_multipass-cli() {
    local -a sub=(
        'alias:create command aliases'
        'aliases:list aliases'
        'authenticate:authenticate to manager'
        'auth:authenticate to manager (alias)'
        'clone:clone an instance'
        'delete:delete instance'
        'exec:run command in instance'
        'find:list available images'
        'gen-id:generate instance ID'
        'get:get configuration'
        'help:show help'
        'image:image management'
        'info:show instance info'
        'launch:create and start instance'
        'list:list instances'
        'mount:mount host path into instance'
        'networks:list networks'
        'prefer:set preferred image hash'
        'purge:remove deleted instances'
        'recover:restore deleted instance'
        'restart:restart instance'
        'restore:restore instance from snapshot'
        'set:set configuration value'
        'shell:open shell in instance'
        'snapshot:take snapshot'
        'start:start instance'
        'stop:stop instance'
        'suspend:suspend instance'
        'transfer:transfer files'
        'umount:unmount path'
        'unalias:remove alias'
        'version:show version'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--version[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'multipass subcommand' sub ;;
        args)
            case $words[1] in
                launch) _arguments \
                    '1:image:' \
                    '--name=+[instance name]:str:' \
                    '-n+[instance name]:str:' \
                    '--cpus=+[cpus]:n:' \
                    '-c+[cpus]:n:' \
                    '--disk=+[disk size]:str:' \
                    '-d+[disk size]:str:' \
                    '--memory=+[memory]:str:' \
                    '-m+[memory]:str:' \
                    '--mount=+[host path:instance path]:str:' \
                    '--network=+[network spec]:str:' \
                    '--cloud-init=+[cloud-init file]:file:_files -g "*.yml *.yaml"' \
                    '--timeout=+[timeout seconds]:n:' \
                    '--bridged[use bridged network]' ;;
                shell|info|start|stop|restart|suspend|delete|recover|purge|exec) _arguments \
                    '*:instance:' ;;
                mount|umount|transfer) _arguments '*:arg:' ;;
                set|get) _arguments '*:key:' ;;
                find) _arguments \
                    '--show-unsupported[show unsupported]' \
                    '--show-images[show images]' \
                    '--show-blueprints[show blueprints]' \
                    '--format=+[format]:fmt:(table json csv yaml)' ;;
                list) _arguments \
                    '--format=+[format]:fmt:(table json csv yaml)' \
                    '--snapshots[include snapshots]' \
                    '--no-ipv4[no ipv4]' ;;
                snapshot|restore) _arguments \
                    '*:instance:' \
                    '--name=+[snapshot name]:str:' \
                    '--comment=+[comment]:str:' ;;
                alias|unalias|aliases) _arguments '*:arg:' ;;
                image) _arguments \
                    '1:cmd:(list)' \
                    '*:arg:' ;;
                clone) _arguments \
                    '1:source-instance:' \
                    '--destination=+[destination name]:str:' \
                    '-d+[destination name]:str:' ;;
            esac
            ;;
    esac
}

_multipass-cli "$@"
