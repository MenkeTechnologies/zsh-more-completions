#compdef mkfs-exfat-cli mkfs.exfat-cli mkexfatfs
# _mkfs-exfat-cli — Andrew Nayenko exfat-utils mkfs.exfat exFAT filesystem creator CLI alias (relan team, C); custom argparse
# upstream: https://github.com/relan/exfat

_mkfs-exfat-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '-V[show version]' \
        '-i+[volume id (hex)]:str:' \
        '-n+[volume name]:str:' \
        '-p+[partition first sector]:n:' \
        '-s+[sectors per cluster]:n:' \
        '*:device:_files -g "/dev/{sd,hd,nvme,mapper,loop}*"'
}

_mkfs-exfat-cli "$@"
