#compdef psmask
# Documentation: https://docs.generic-mapping-tools.org/latest/mask.html
# Source: GenericMappingTools/gmt classic-mode psmask — clip / mask map regions outside data coverage.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-I+[grid spacing dx/dy]:spacing:_default' \
    '-J+[projection]:proj:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-C[end existing clip path]' \
    '-D+[dump clipping polygons to file]:opts:_default' \
    '-F+[force polygon orientation]:dir:_default' \
    '-G+[fill color / pattern]:fill:_default' \
    '-Jz+[z-axis scaling]:scale:_default' \
    '-L+[save internal grid with constraint flags]:file:_files' \
    '-N[invert test (clip regions WITH data)]' \
    '-Q+[exclude polygons with fewer than N points]:n:_default' \
    '-S+[search radius around data points]:radius:_default' \
    '-T[plot tiles (not clip polygons)]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-bi+[binary input format]:format:_default' \
    '-di+[input nodata → NaN]:value:_default' \
    '-e+[record pattern filter]:pattern:_default' \
    '-h+[header records]:n:_default' \
    '-i+[input column selection]:cols:_default' \
    '-p+[perspective view]:perspective:_default' \
    '-qi+[input row selection]:opts:_default' \
    '-r[pixel registration (default gridline)]' \
    '-t+[transparency percent]:pct:_default' \
    '-w+[cyclical coord conversion]:opts:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
