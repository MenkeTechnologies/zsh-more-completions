#compdef minimap
# _minimap — Heng Li minimap original PacBio Nanopore long-read overlapper and seed-chain-align long-vs-long aligner predecessor of minimap2 (lh3 team, C); getopt
# upstream: https://github.com/lh3/minimap

_minimap() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-k+[k-mer length]:n:' \
        '-w+[minimizer window]:n:' \
        '-b+[bucket bits]:n:' \
        '-r+[bandwidth]:n:' \
        '-g+[max gap]:n:' \
        '-c+[chain max skip]:n:' \
        '-N+[max occurrence]:n:' \
        '-T+[score cutoff]:n:' \
        '-L+[min overlap]:n:' \
        '-m+[min minimizer count]:n:' \
        '-M+[mask level]:f:' \
        '-S[skip self-mapping]' \
        '-x[output PAF]' \
        '-X[skip read same name]' \
        '-O+[output format]:f:(0 1)' \
        '-l+[max log]:n:' \
        '-t+[threads]:n:' \
        '-d+[dump minimizers to file]:file:_files' \
        '-f+[filter threshold]:f:' \
        '-V[verbose]' \
        '*:fastq or index file:_files -g "*.fa *.fasta *.fq *.fastq *.fa.gz *.fasta.gz *.fq.gz *.fastq.gz *.mni"'
}

_minimap "$@"
