#compdef pamtopfm
# Documentation: man pamtopfm (Netpbm)
# Source: convert a Netpbm PAM to Portable Float Map (PFM).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-endian=[byte order]:endian:(big little)' \
    '-scale=[scale factor]:float:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
