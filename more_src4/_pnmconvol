#compdef pnmconvol
# Documentation: man pnmconvol (Netpbm)
# Source: apply a general convolution matrix (or per-channel matrices) to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-matrix -matrixfile)-matrix=[inline convolution matrix]:matrix:' \
    '(-matrix -matrixfile)-matrixfile=[matrix file(s) (comma-separated for per-channel)]:files:_files' \
    '-normalize[normalize matrix so coefficients sum to 1]' \
    '-bias=[bias added to convolution result]:n:' \
    '-nooffset[disable matrix-centering offset (file-arg form only)]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:netpbm file or matrix file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
