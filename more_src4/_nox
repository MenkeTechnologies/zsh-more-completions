#compdef nox
# Documentation: https://nox.thea.codes/en/stable/usage.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# zsh completions for 'nox' (https://nox.thea.codes)
local -a arguments

arguments=(
  '(- *)'{-h,--help}'[show help message and exit]'
  '(- *)--version[show version and exit]'
  {-l,--list,--list-sessions}'[list available sessions and exit]'
  '--json[output session list in JSON format]'
  '--usage[print usage for a specific session]'
  '*'{-s,-e,--session}'[which sessions to run]:session:'
  {-k,--keywords}'[only run sessions that match the given expression]:keywords:'
  '*'{-p,--python}'[run sessions with given Python versions]:python:'
  '*--extra-pythons[run additional Python versions]:python:'
  '--force-python[replace Python interpreter for sessions]:python:'
  '--download-python=[control interpreter downloading]:mode:(auto never always)'
  {-r,--reuse-existing-virtualenvs}'[re-use existing virtualenvs]'
  '--no-reuse-existing-virtualenvs[do not re-use existing virtualenvs]'
  '--reuse-venv=[fine-grained venv reuse control]:strategy:(yes no never always)'
  '-R[reuse venvs without reinstalling packages]'
  {-f,--noxfile}'[noxfile to use]:noxfile:_files -g "*.py"'
  '--envdir[directory where nox will store virtualenvs]:directory:_directories'
  '(-db --default-venv-backend)'{-db,--default-venv-backend}'[virtual environment backend to use by default]:backend:(none uv virtualenv conda mamba venv)'
  '(-fb --force-venv-backend)'{-fb,--force-venv-backend}'[force all sessions to use this backend]:backend:(none uv virtualenv conda mamba venv)'
  '--no-venv[run all sessions without creating virtualenvs]'
  '--no-install[skip install commands in all sessions]'
  '--install-only[run only installation commands]'
  '--report[output a report of all sessions to a file]:report file:_files'
  '--non-interactive[force session.interactive to False]'
  '--nocolor[disable all color output]'
  '--forcecolor[force color output]'
  '--no-error-on-missing-interpreters[do not error when an interpreter cannot be found]'
  '--error-on-missing-interpreters[error when an interpreter cannot be found]'
  '--no-error-on-external-run[do not error on external program calls]'
  '--error-on-external-run[error on external program calls]'
  {-x,--stop-on-first-error}'[stop after the first error]'
  '--no-stop-on-first-error[do not stop after the first error]'
  '*'{-t,--tags}'[only run sessions with the given tags]:tag:'
  '--verbose[enable verbose mode]'
  '*:posargs:'
)

_arguments -s -S $arguments
