#compdef pi_stress
# Documentation: https://wiki.linuxfoundation.org/realtime/documentation/howto/tools/rt-tests
# Source: rt-tests src/pi_tests/pi_stress.c — stress priority-inheritance correctness.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    '(-d --duration)'{-d+,--duration=}'[test run length (seconds, default infinite)]:seconds:_default' \
    '(-v --verbose)'{-v,--verbose}'[lots of output]' \
    '(-q --quiet)'{-q,--quiet}'[suppress running output]' \
    '(-g --groups)'{-g+,--groups=}'[number of inversion groups]:n:_default' \
    '(-i --inversions)'{-i+,--inversions=}'[inversions per group]:n:_default' \
    '(-r --rr)'{-r,--rr}'[use SCHED_RR for test threads]' \
    '(-u --uniprocessor)'{-u,--uniprocessor}'[force threads on one processor]' \
    '(-p --prompt)'{-p,--prompt}'[prompt before starting]' \
    '(-D --debug)'{-D,--debug}'[turn on debug prints]' \
    '(-m --mlockall)'{-m,--mlockall}'[lock current and future memory]' \
    && ret=0

return ret
