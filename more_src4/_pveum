#compdef pveum
# Documentation: https://pve.proxmox.com/pve-docs/pveum.1.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'acl:manage access control lists'
  'group:manage groups'
  'pool:manage pools'
  'realm:manage authentication realms'
  'role:manage roles'
  'user:manage users, tokens and TFA'
  'passwd:change password'
  'ticket:create or verify authentication ticket'
  'acldel:alias for acl delete'
  'aclmod:alias for acl modify'
  'groupadd:alias for group add'
  'groupdel:alias for group delete'
  'groupmod:alias for group modify'
  'roleadd:alias for role add'
  'roledel:alias for role delete'
  'rolemod:alias for role modify'
  'usermod:alias for user modify'
  'useradd:alias for user add'
  'userdel:alias for user delete'
  'help:show help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'pveum command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (acl) _values 'subcommand' 'delete' 'list' 'modify' && ret=0 ;;
      (group) _values 'subcommand' 'add' 'delete' 'list' 'modify' && ret=0 ;;
      (pool) _values 'subcommand' 'add' 'delete' 'list' 'modify' && ret=0 ;;
      (realm) _values 'subcommand' 'add' 'delete' 'list' 'modify' 'sync' && ret=0 ;;
      (role) _values 'subcommand' 'add' 'delete' 'list' 'modify' && ret=0 ;;
      (user)
        if (( CURRENT == 2 )); then
          _values 'subcommand' 'add' 'delete' 'list' 'modify' 'permissions' 'tfa' 'token' && ret=0
        else
          case $line[2] in
            (tfa) _values 'tfa subcommand' 'delete' 'list' 'unlock' && ret=0 ;;
            (token) _values 'token subcommand' 'add' 'delete' 'list' 'modify' 'permissions' 'remove' && ret=0 ;;
          esac
        fi
        ;;
    esac ;;
esac

return ret
