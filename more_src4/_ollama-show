#compdef ollama-show
# Documentation: https://github.com/ollama/ollama/blob/main/cmd/cmd.go
# Reference accessed: 2026-05-20
# Verified: upstream cobra source for `ollama show`.

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '--license[show license]' \
  '--modelfile[show Modelfile]' \
  '--parameters[show parameters]' \
  '--system[show system message]' \
  '--template[show template]' \
  '(-v --verbose)'{-v,--verbose}'[show detailed information]' \
  '1:model:' && return 0
