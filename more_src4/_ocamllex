#compdef ocamllex
# Documentation: ocamllex --help
# Source: OCaml ocamllex — lexer generator.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-ml[output code without Lexing-module automata interpreter]' \
    '-o+[output file]:file:_files' \
    '-q[no informational messages]' \
    '(- *)-v[show version]' \
    '(- *)-version[show version]' \
    '(- *)-vnum[show version number only]' \
    '(- *)'{-help,--help}'[show help]' \
    '*:OCaml lexer source:_files -g "*.mll"' \
    && ret=0

return ret
