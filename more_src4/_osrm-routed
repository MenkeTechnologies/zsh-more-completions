#compdef osrm-routed
# Documentation: https://github.com/Project-OSRM/osrm-backend
# Source: Project-OSRM/osrm-backend src/tools/routed.cpp — HTTP routing daemon.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '--list-inputs[list required/optional input file extensions]' \
    '--verbosity=[log verbosity]:level:_default' \
    '--trial[quit after initialization]' \
    '(-i --ip)'{-i+,--ip=}'[IP address]:addr:_default' \
    '(-p --port)'{-p+,--port=}'[TCP/IP port]:port:_default' \
    '(-t --threads)'{-t+,--threads=}'[number of threads]:n:_default' \
    '--keepalive-timeout=[keepalive timeout (sec, default 5)]:seconds:_default' \
    '(-s --shared-memory)'{-s,--shared-memory}'[load data from shared memory]' \
    '--memory_file=[DEPRECATED (same as --mmap)]:file:_files' \
    '--mmap[map datafiles (no extra memory)]' \
    '--dataset-name=[shared-memory dataset name]:name:_default' \
    '(-a --algorithm)'{-a+,--algorithm=}'[routing algorithm]:algo:(CH MLD)' \
    '--disable-feature-dataset=[disable a feature dataset]:dataset:_default' \
    '--max-viaroute-size=[max locations in viaroute query]:n:_default' \
    '--max-trip-size=[max locations in trip query]:n:_default' \
    '--max-table-size=[max locations in distance-table query]:n:_default' \
    '--max-matching-size=[max locations in map-matching query]:n:_default' \
    '--max-nearest-size=[max results in nearest query]:n:_default' \
    '--max-alternatives=[max MLD alternatives]:n:_default' \
    '--max-matching-radius=[max matching radius]:meters:_default' \
    '--default-radius=[default query radius]:meters:_default' \
    '--max-header-size=[max HTTP header size]:bytes:_default' \
    '*:input base path:_files -g "*.osrm(-.)"' \
    && ret=0

return ret
