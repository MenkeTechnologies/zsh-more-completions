#compdef mhwd
# _mhwd — Manjaro Hardware Detection tool (manjaro/mhwd)
# upstream: https://github.com/manjaro/mhwd
# Flags from src/Mhwd.cpp.

_mhwd() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-f --force)'{-f,--force}'[force action]' \
        '(-d --detail)'{-d,--detail}'[show detailed device info]' \
        '(-la --listall)'{-la,--listall}'[list all configs / drivers]' \
        '(-li --listinstalled)'{-li,--listinstalled}'[list installed configs]' \
        '(-l --list)'{-l,--list}'[list available configs for current devices]' \
        '(-lh --listhardware)'{-lh,--listhardware}'[list detected hardware]' \
        '--pci[show only PCI devices]' \
        '--usb[show only USB devices]' \
        '(-a --auto)'{-a,--auto}'[auto-install matching driver]:type:(pci usb) :nonfree:(free nonfree) :class:' \
        '(-ic --installcustom)'{-ic,--installcustom}'[install custom config]:source:' \
        '(-i --install)'{-i,--install}'[install profiles]:type:(pci usb)' \
        '(-r --remove)'{-r,--remove}'[remove profiles]:type:(pci usb)' \
        '--pmcachedir[pacman cache directory]:dir:_files -/' \
        '--pmconfig[pacman config file]:file:_files' \
        '--pmroot[pacman install root]:dir:_files -/' \
        '*:profile:'
}

_mhwd "$@"
