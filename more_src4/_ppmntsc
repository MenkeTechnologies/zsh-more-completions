#compdef ppmntsc
# Documentation: man ppmntsc (Netpbm)
# Source: clamp a PPM image to NTSC (or PAL) broadcast-safe colors.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--pal[clamp to PAL instead of NTSC]' \
    '(--legalonly --illegalonly --correctedonly)--legalonly[output legal pixels only]' \
    '(--legalonly --illegalonly --correctedonly)--illegalonly[output illegal pixels only]' \
    '(--legalonly --illegalonly --correctedonly)--correctedonly[output only corrected pixels]' \
    '--verbose[verbose output]' \
    '--debug[debug output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
