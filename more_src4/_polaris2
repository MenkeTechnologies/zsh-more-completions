#compdef polaris2
# _polaris2 — Fairwinds Polaris polaris2 CLI command-line frontend wrapping the Polaris open-source policy engine for Kubernetes that validates and remediates resource configuration helps you avoid common Kubernetes pitfalls by inspecting workloads and identifying many of the most common mistakes deploy workloads-best-practices written in Go audit deployment fix dashboard webhook dashboard-mode UI-base-path help-text validate mutate skipping CIS benchmark-based ARM-Arm64 deny-list namespace include-checks exclude-checks reporter checks (Fairwinds Polaris team Robert Brennan Maru Lango, Go); cobra
# upstream: https://polaris.docs.fairwinds.com/

_polaris2() {
    local -a sub=(
        'audit:audit Kubernetes resources'
        'dashboard:run dashboard UI'
        'webhook:run admission webhook'
        'fix:fix manifests'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[config file]:file:_files -g "*.yaml *.yml"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml"' \
        '--audit-path=+[path]:_files' \
        '--display-name=+[name]:str:' \
        '--output-file=+[file]:file:_files' \
        '--output-format=+[fmt]:f:(json yaml pretty score)' \
        '-f+[format]:f:(json yaml pretty score)' \
        '--output-url=+[url]:str:' \
        '--set-exit-code-below-score=+[N]:n:' \
        '--set-exit-code-on-danger[exit code on danger]' \
        '--set-exit-code-on-warning[exit code on warning]' \
        '--min-score=+[N]:n:' \
        '--severity=+[s]:s:(danger warning ignore)' \
        '--checks=+[ids]:str:' \
        '--exclude-checks=+[ids]:str:' \
        '--only-show-failed-tests[only show failed]' \
        '--exemptions-file=+[file]:file:_files' \
        '--mutated-yaml[mutated YAML]' \
        '--helm-chart=+[chart]:str:' \
        '--helm-values=+[file]:file:_files -g "*.yaml *.yml"' \
        '-r+[resource]:_files' \
        '--resource=+[file]:_files' \
        '--kube-context=+[name]:str:' \
        '--port=+[port]:n:' \
        '--listen-port=+[port]:n:' \
        '--base-path=+[path]:str:' \
        '--log-level=+[l]:l:(panic fatal error warning info debug trace)' \
        '--dry-run[dry run]' \
        '--load-audit-file=+[file]:file:_files' \
        '--disable-webhook-config-installer[no installer]' \
        '--openapi-disable[disable OpenAPI]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'polaris subcommand' sub ;;
        args)
            case $words[1] in
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
                fix) _arguments '*:file:_files -g "*.yaml *.yml"' ;;
            esac
            ;;
    esac
}

_polaris2 "$@"
