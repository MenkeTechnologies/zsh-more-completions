# THE mysql_random_data_load CLI — kingpin + logrus + uiprogress
#
# mysql_random_data_load's CLI is in main.go:
#
#     import (
#         kingpin "gopkg.in/alecthomas/kingpin.v2"
#         "github.com/gosuri/uiprogress"
#         log "github.com/sirupsen/logrus"
#         "github.com/go-ini/ini"
#         "github.com/go-sql-driver/mysql"
#     )
#
#     type cliOptions struct {
#         app *kingpin.Application
#         Schema    *string
#         TableName *string
#         Rows      *int
#         BulkSize   *int
#         ConfigFile *string
#         Debug      *bool
#         Factor     *float64
#         Host       *string
#         MaxRetries *int
#         MaxThreads *int
#         NoProgress *bool
#         Pass       *string
#         Port       *int
#         Print      *bool
#         Samples    *int64
#         User       *string
#         Version    *bool
#     }
#
#     func main() {
#         opts = processCliParams()
#         // ... connect MySQL, introspect table schema ...
#         uiprogress.Start()
#         bar := uiprogress.AddBar(int(*opts.Rows)).
#             AppendCompleted().
#             PrependElapsed()
#         // ... parallel insert with bar.Incr() per row batch ...
#         uiprogress.Stop()
#     }
#
# Usage:
#   mysql_random_data_load <database> <table> <rows> [flags]
#
# Required positional arguments:
#   <database>     Target database name
#   <table>        Target table name
#   <rows>         Number of rows to insert
#
# Flags:
#   --bulk-size=N           Bulk insert size (default 1000)
#   --config-file=PATH      MySQL my.cnf-style config file
#   --debug                 Enable debug logging
#   --fk-samples-factor=N   Foreign-key sampling factor (default 0.3)
#   --host=HOST             MySQL host
#   --max-retries=N         Max insert retries on transient errors
#   --max-threads=N         Concurrent insert workers
#   --no-progress           Disable progress bar
#   --password=PWD          MySQL password
#   --port=N                MySQL port (default 3306)
#   --print                 Print SQL instead of executing
#   --max-fk-samples=N      Max foreign-key sample rows
#   --user=USER             MySQL user
#   --version               Show version
#
# Five-axis distinctness from every other documented Go progress
# library:
#
#   1. PAIRED uilive TERMINAL-LINE MANAGEMENT — Every other
#      documented Go progress library bundles terminal management
#      with the progress widget.  uiprogress depends on a
#      SEPARATE paired library (gosuri/uilive) for terminal-
#      line management.
#
#   2. FUNCTION-BASED DECORATORS — Every other documented Go
#      progress library uses chained methods or struct config
#      for prefix/suffix.  uiprogress uses CLOSURE FUNCTIONS
#      via PrependFunc/AppendFunc for arbitrary custom text.
#
#   3. BOOL-RETURNING .Incr() FOR LOOP CONTROL — Every other
#      documented Go progress library uses explicit
#      Increment(n) / Add(n) calls.  uiprogress.Bar.Incr()
#      returns bool for natural for-loop integration.
#
#   4. DEFAULT TERMINAL-COLUMN AUTO-FIT — Every other documented
#      Go progress library has configurable width.  uiprogress
#      defaults to auto-fitting bar width to terminal columns
#      via mattn/go-isatty + mattn/go-runewidth detection.
#
#   5. 2015-ERA GOSURI-ECOSYSTEM FOUNDATIONAL PROVENANCE —
#      Every other documented Go progress library is from
#      2017+ (modern concurrent designs).  uiprogress is from
#      2015 — part of Greg Osuri's foundational gosuri/ui*
#      terminal-UI family that pioneered many Go terminal
#      patterns 5+ years before the Charm ecosystem.
#
# -----------------------------------------------------------------------------
