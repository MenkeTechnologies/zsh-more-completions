local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '--version[show version]' \
    '--bulk-size=[bulk insert size]:N:' \
    '--config-file=[MySQL my.cnf-style config file]:file:_files' \
    '--debug[enable debug logging]' \
    '--fk-samples-factor=[foreign-key sampling factor (default 0.3)]:N:' \
    '--host=[MySQL host]:host:_hosts' \
    '--max-retries=[max insert retries on transient errors]:N:' \
    '--max-threads=[concurrent insert worker count]:N:' \
    '--no-progress[disable progress bar display]' \
    '--password=[MySQL password]:password:' \
    '--port=[MySQL port (default 3306)]:port:' \
    '--print[print SQL instead of executing]' \
    '--max-fk-samples=[max foreign-key sample rows]:N:' \
    '--user=[MySQL user]:user:_users' \
    '1:database name:' \
    '2:table name:' \
    '3:number of rows to insert:' \
    && ret=0

return ret
