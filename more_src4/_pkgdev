#compdef pkgdev
# Documentation: https://pkgcore.github.io/pkgdev/man/pkgdev.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'commit:commit pkgcheck-clean changes'
  'manifest:regenerate manifests'
  'mask:mask packages with last rites'
  'push:push commits with pkgcheck'
  'showkw:show keywords table'
  'tatt:generate test scripts'
  'bugs:bug operations'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '*'{-v,--verbose}'[verbose]' \
  '(-q --quiet)'{-q,--quiet}'[quiet]' \
  '--version[show version]' \
  '--debug[debug]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand) _describe -t subcommands 'pkgdev subcommand' subcommands && ret=0 ;;
  (args)
    case $line[1] in
      (commit)
        _arguments -s \
          '(-b --bug)'{-b,--bug}'=[bug tag]:bug:' \
          '(-c --closes)'{-c,--closes}'=[closes bug]:bug:' \
          '*'{-T,--tag}'=[NAME:VALUE]:tag:' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '(-s --scan)'{-s,--scan}'[run pkgcheck]' \
          '(-A --ask)'{-A,--ask}'[confirm on errors]' \
          '--mangle[file mangling]' \
          '--signoff[Signed-off-by]' \
          '--gpg-sign[GPG sign]' \
          '--no-gpg-sign[no GPG sign]' \
          '(-d --distdir)'{-d,--distdir}'=[distdir]:dir:_files -/' \
          '*'{-m,--message}'=[commit message]:msg:' \
          '(-M --message-template)'{-M,--message-template}'=[template]:file:_files' \
          '(-e --edit)'{-e,--edit}'[edit message]' \
          '(-u --update)'{-u,--update}'[stage updates]' \
          '(-a --all)'{-a,--all}'[stage all]' && ret=0 ;;
      (manifest)
        _arguments -s \
          '(-d --distdir)'{-d,--distdir}'=[distdir]:dir:_files -/' \
          '(-f --force)'{-f,--force}'[force regenerate]' \
          '(-m --mirrors)'{-m,--mirrors}'[fetch from mirrors]' \
          '--if-modified[only modified]' \
          '--ignore-fetch-restricted[ignore fetch restricted]' \
          '*:target:' && ret=0 ;;
      (mask)
        _arguments -s \
          '(-r --rites)'{-r,--rites}'=[days]:n:' \
          '*'{-b,--bug,--bugs}'=[bug ids]:bugs:' \
          '--email[spawn email composer]' \
          '--file-bug[file bug]' \
          '--api-key=[API key]:key:' \
          '*:target:' && ret=0 ;;
      (push)
        _arguments -s \
          '(-A --ask)'{-A,--ask}'[confirm on errors]' \
          '(-n --dry-run)'{-n,--dry-run}'[dry run]' \
          '--pull[pull rebase before push]' && ret=0 ;;
      (showkw)
        _arguments -s \
          '(-f --format)'{-f,--format}'=[format]:fmt:(plain simple github grid fancy_grid pipe orgtbl jira presto psql rst mediawiki html latex tsv showkw)' \
          '(-c --collapse)'{-c,--collapse}'[collapsed list]' \
          '(-s --stable)'{-s,--stable}'[stable only]' \
          '(-u --unstable)'{-u,--unstable}'[unstable only]' \
          '(-o --only-unstable)'{-o,--only-unstable}'[unstable only]' \
          '(-p --prefix)'{-p,--prefix}'[show prefix arches]' \
          '(-a --arch)'{-a,--arch}'=[arches]:list:' \
          '(-r --repo)'{-r,--repo}'=[repo]:repo:' \
          '*:target:' && ret=0 ;;
      (tatt)
        _arguments -s \
          '(-j --job-name)'{-j,--job-name}'=[name template]:tmpl:' \
          '(-b --bug)'{-b,--bug}'=[bug]:bug:' \
          '--api-key=[API key]:key:' \
          '(-t --test)'{-t,--test}'[run test phase]' \
          '(-u --use-combos)'{-u,--use-combos}'=[count]:n:' \
          '*--ignore-prefixes=[prefixes]:list:' \
          '--use-default[default USE]' \
          '--use-random[random USE]' \
          '--use-expand-random[USE_EXPAND random]' \
          '*'{-p,--packages}'=[packages]:pkg:' \
          '(-s --stablereq)'{-s,--stablereq}'[stablereq]' \
          '(-k --keywording)'{-k,--keywording}'[keywording]' \
          '--template-file=[template]:file:_files' \
          '--logs-dir=[logs dir]:dir:_files -/' \
          '--emerge-opts=[emerge opts]:opts:' \
          '*--extra-env-file=[env file]:file:_files' && ret=0 ;;
      (bugs)
        _arguments -s \
          '--dot=[dot file]:file:_files' \
          '--edit-graph[edit graph]' \
          '--auto-cc-arches=[email]:list:' \
          '--find-by-maintainer=[email]:list:' \
          '--projects[include projects]' \
          '--filter-stablereqs[filter stablereqs]' \
          '*--blocks=[bug ids]:list:' \
          '(-s --stablereq)'{-s,--stablereq}'[stablereq]' \
          '(-k --keywording)'{-k,--keywording}'[keywording]' \
          '--api-key=[API key]:key:' \
          '*:target:' && ret=0 ;;
    esac
    ;;
esac

return ret
