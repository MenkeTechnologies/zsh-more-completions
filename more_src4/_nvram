#compdef nvram
# Documentation: https://www.unix.com/man-page/osx/8/nvram/
# Source: Apple macOS — read / write firmware variables (NVRAM).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-x[XML format for reading/writing]' \
    '-d[delete the named variable]:name:' \
    '-f[set variables from file (name=value)]:file:_files' \
    '(- *)-p[print all firmware variables]' \
    '(- *)-c[delete all firmware variables]' \
    '*:name or name=value:' \
    && ret=0

return ret
