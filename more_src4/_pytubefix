#compdef pytubefix
# _pytubefix — maintained YouTube downloader fork of pytube (JuanBindez/pytubefix)
# upstream: https://github.com/JuanBindez/pytubefix
# Flags from pytubefix/cli.py (argparse).

_pytubefix() {
    local -a args
    args=(
        '(- *)'{-h,--help}'[show help]'
        '(- *)'{-V,--version}'[show version]'
        '--itag=[itag for the desired stream]:itag:'
        '(-r --resolution)'{-r+,--resolution=}'[stream resolution]:res:(144p 240p 360p 480p 720p 1080p 1440p 2160p)'
        '(-l --list)'{-l,--list}'[list available streams for the URL]'
        '--oauth[authenticate via OAuth token]'
        '(-v --verbose)'{-v,--verbose}'[increase logging verbosity]'
        '--logfile=[log debug/error messages to this file]:file:_files'
        '--build-playback-report[save HTML + JS to disk for debugging]'
        '(-c --caption-code)'{-c+,--caption-code=}'[caption language code (en, es, ...)]:code:'
        '(-lc --list-captions)'{-lc,--list-captions}'[list available caption tracks]'
        '(-t --target)'{-t+,--target=}'[output directory]:dir:_files -/'
        '(-a --audio)'{-a-,--audio=-}'[download audio-only stream (optional codec)]::codec:(mp4 webm)'
        '(-f --ffmpeg)'{-f-,--ffmpeg=-}'[mux best video+audio via ffmpeg]::res:(best 144p 240p 360p 480p 720p 1080p)'
        '1:YouTube /watch or /playlist URL:'
    )
    _arguments -s $args
}

_pytubefix "$@"
