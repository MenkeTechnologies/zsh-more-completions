#compdef nbformat
# _nbformat — Jupyter nbformat Python CLI for validating Jupyter notebook JSON schema upgrading downgrading notebook format version reading/writing .ipynb files (jupyter team, Python); argparse
# upstream: https://github.com/jupyter/nbformat

_nbformat() {
    local -a sub=(
        'validate:validate notebook file'
        'upgrade:upgrade notebook to latest format'
        'downgrade:downgrade notebook format'
        'show:show notebook'
        'info:show format info'
        'completion:generate shell completion'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-q[quiet]' \
        '--quiet[quiet]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nbformat subcommand' sub ;;
        args)
            case $words[1] in
                validate) _arguments \
                    '--max-version=+[N]:n:(2 3 4)' \
                    '--repair[repair invalid metadata]' \
                    '--quiet[quiet]' \
                    '*:notebook file:_files -g "*.ipynb"' ;;
                upgrade|downgrade) _arguments \
                    '--from-version=+[N]:n:(2 3 4)' \
                    '--to-version=+[N]:n:(2 3 4)' \
                    '--inplace[modify in place]' \
                    '*:notebook file:_files -g "*.ipynb"' ;;
                show) _arguments \
                    '--cell=+[N]:n:' \
                    '--output-only[output only]' \
                    '--no-outputs[no outputs]' \
                    '*:notebook file:_files -g "*.ipynb"' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_nbformat "$@"
