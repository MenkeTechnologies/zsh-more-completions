#compdef ntpdig
# Documentation: https://docs.ntpsec.org/latest/ntpdig.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '(-4 --ipv4)'{-4,--ipv4}'[force IPv4 DNS resolution]' \
  '(-6 --ipv6)'{-6,--ipv6}'[force IPv6 DNS resolution]' \
  '(-a --authentication)'{-a+,--authentication=}'[authentication key number]:keynum:' \
  '(-c --concurrent)'{-c+,--concurrent=}'[concurrently query all IPs for host]:hostname:_hosts' \
  '(-d --debug-level)'{-d,--debug-level}'[increase debug verbosity (repeatable)]' \
  '(-D --set-debug-level)'{-D+,--set-debug-level=}'[set debug verbosity level]:level:' \
  '(-g --gap)'{-g+,--gap=}'[gap between time requests (ms)]:ms:' \
  '(-I --bindaddr)'{-I+,--bindaddr=}'[bind to specified IP]:ip:_hosts' \
  '-j[output JSON to stdout]' \
  '(-k --keyfile)'{-k+,--keyfile=}'[authentication keyfile]:file:_files' \
  '(-l --logfile)'{-l+,--logfile=}'[write log messages to file]:file:_files' \
  '(-M --steplimit)'{-M+,--steplimit=}'[ms threshold for slew vs step]:ms:' \
  '(-p --samples)'{-p+,--samples=}'[number of samples to collect]:n:' \
  '(-S --step)'{-S,--step}'[step the clock]' \
  '(-s --slew)'{-s,--slew}'[slew the clock]' \
  '(-t --timeout)'{-t+,--timeout=}'[wait time for responses (sec)]:sec:' \
  '--wait[wait for pending replies (default)]' \
  '--no-wait[do not wait for pending replies]' \
  '*:server:_hosts' && ret=0

return ret
