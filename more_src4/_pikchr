#compdef pikchr
# Documentation: https://pikchr.org/home/doc/trunk/homepage.md
# Reference accessed: 2026-05-20
# Verified: upstream pikchr.org docs at the URL above. The canonical
# pikchr binary (built from pikchr.c with -DPIKCHR_SHELL) accepts file
# arguments and reads stdin; it does not expose documented long-form
# CLI flags. Modifiers like svg-only, dark-mode are per-diagram source
# attributes, not CLI flags. STUB completion takes positional files only.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '*:input file:_files -g "*.pikchr"' && ret=0

return ret
