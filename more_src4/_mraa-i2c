#compdef mraa-i2c
# _mraa-i2c — Intel mraa-i2c CLI command-line wrapper around Intel libmraa I/O abstraction library performing list version detect get set bus device address scans on i2c buses across Intel Galileo Edison Joule MinnowBoard ARM Raspberry Pi Beaglebone boards (Intel team, C); custom argparse
# upstream: https://github.com/intel-iot-devkit/mraa

_mraa-i2c() {
    local -a sub=(
        'list:list available i2c buses'
        'detect:detect devices on bus'
        'version:print versions'
        'get:read a value from i2c register'
        'set:write a value to i2c register'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'mraa-i2c subcommand' sub ;;
        args)
            case $words[1] in
                detect) _arguments '1:bus:' ;;
                get) _arguments '1:bus:' '2:device address:' '3:register:' ;;
                set) _arguments '1:bus:' '2:device address:' '3:register:' '4:value:' ;;
            esac
            ;;
    esac
}

_mraa-i2c "$@"
