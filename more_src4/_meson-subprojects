#compdef meson-subprojects
# _meson-subprojects — Meson build system meson-subprojects manager CLI alias (Meson team, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-subprojects() {
    local -a sub=(
        'update:update subprojects'
        'checkout:checkout branch'
        'download:download all subprojects'
        'foreach:run command in each subproject'
        'purge:purge unused subprojects'
        'packagefiles:packagefiles operations'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-C+[source root]:dir:_files -/' \
        '--sourcedir=+[source root]:dir:_files -/' \
        '--types=+[subproject types csv]:str:' \
        '-t+[subproject types csv]:str:' \
        '-j+[parallel jobs]:n:' \
        '--num-processes=+[parallel jobs]:n:' \
        '--allow-insecure[allow insecure]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'meson-subprojects subcommand' sub ;;
        args)
            case $words[1] in
                update) _arguments \
                    '--rebase[rebase]' \
                    '--reset[reset]' \
                    '*:subproject:' ;;
                checkout) _arguments \
                    '-b[create branch]' \
                    '*:branch-and-subprojects:' ;;
                download|purge) _arguments \
                    '*:subproject:' ;;
                foreach) _arguments \
                    '*:cmd:_command_names -e' ;;
                packagefiles) _arguments \
                    '--apply[apply patches]' \
                    '--save[save patches]' \
                    '*:subproject:' ;;
            esac
            ;;
    esac
}

_meson-subprojects "$@"
