#compdef pyftmerge
# Documentation: https://fonttools.readthedocs.io/
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '-o+[output file]:file:_files -g "*.(otf|ttf)"' \
  '-v[verbose]' \
  '*:font file:_files -g "*.(otf|ttf)"' && ret=0

return ret
