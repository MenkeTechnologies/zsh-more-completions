#compdef pr-agent
# Documentation: https://github.com/qodo-ai/pr-agent
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_pr_agent() {
    local line
    local -a subcmds
    local -a global_flags

    global_flags=(
        '--pr_url=[The URL of the pull request to analyze]:url:'
        '--config_path=[Path to a specific configuration file]:file:_files'
        '--verbosity=[Sets the logging level]:level:(DEBUG INFO WARNING ERROR)'
        '(-h --help)'{-h,--help}'[Display help for command]'
    )

    subcmds=(
        'review:Performs a full AI code review'
        'describe:Generates or updates the PR title and description'
        'improve:Suggests specific code improvements and refactors'
        'ask:Ask the AI specific questions about the PR content'
        'add_docs:Generate missing documentation for components'
        'generate_labels:Create custom labels based on code changes'
        'similar_issue:Identify similar issues in the repository'
        'update_changelog:Automatically updates the changelog file'
        'help:List available tools'
        'help_docs:Answer questions using documentation'
    )

    _arguments -C \
        $global_flags \
        '1: :->cmds' \
        '*::arg:->args'

    case $state in
        cmds)
            _describe -t commands 'pr-agent commands' subcmds
            ;;
        args)
            _arguments '*:config override: '
            ;;
    esac
}

_pr_agent "$@"
