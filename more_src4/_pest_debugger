#compdef pest_debugger
# _pest_debugger — interactive debugger for pest grammars (pest-parser/pest)
# upstream: https://github.com/pest-parser/pest
# Commands from debugger/src/main.rs (REPL help text).

_pest_debugger() {
    if (( CURRENT == 2 )); then
        local -a cmds
        cmds=(
            'g:load a .pest grammar file (alias of grammar)'
            'grammar:load a .pest grammar file'
            'i:load input from a file (alias of input)'
            'input:load input from a file'
            'id:load input directly from a single-line string'
            'ba:add breakpoints at all rules'
            'b:add a breakpoint at a rule (alias of breakpoint)'
            'breakpoint:add a breakpoint at a rule'
            'd:delete a breakpoint at a rule (alias of delete)'
            'delete:delete a breakpoint at a rule'
            'da:delete all breakpoints'
            'r:run a rule (alias of run)'
            'run:run a rule'
            'c:continue (alias of continue)'
            'continue:continue execution from the current breakpoint'
            'l:list breakpoints (alias of list)'
            'list:list breakpoints'
            'h:show help (alias of help)'
            'help:show the command summary'
            'q:quit (alias of quit)'
            'quit:exit the debugger'
        )
        _describe -t commands 'pest_debugger command' cmds
        return
    fi

    case $words[2] in
        g|grammar)   _files -g '*.pest' ;;
        i|input)     _files ;;
        *) ;;
    esac
}

_pest_debugger "$@"
