#compdef manifest-tool
# Documentation: https://github.com/estesp/manifest-tool
# Reference accessed: 2026-05-19
# Verified: upstream README at the URL above.

# Zsh completion for manifest-tool - container manifest list tool

local curcontext="$curcontext" state line ret=1

local -a commands
commands=(
  'inspect:inspect images on a registry'
  'push:push a manifest list/OCI index'
)

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '--debug[enable debug output]' \
  '--docker-cfg=[docker config directory]:dir:_directories' \
  '--insecure[allow insecure registry communication]' \
  '--plain-http[use plain HTTP for registry communication]' \
  '--username=[registry username]:username' \
  '--password=[registry password]:password' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0

case "$state" in
  cmd)
    _describe -t commands 'manifest-tool command' commands && ret=0
    ;;
  args)
    case "${line[1]}" in
      inspect)
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--raw[raw JSON output]' \
          '1:image' && ret=0
        ;;
      push)
        local -a push_modes=(
          'from-spec:assemble from YAML spec'
          'from-args:assemble from command-line args'
        )
        _arguments \
          '(-h --help)'{-h,--help}'[show help]' \
          '--ignore-missing[ignore missing platform entries]' \
          '--platforms=[platforms to include]:platforms' \
          '--target=[target image reference]:image' \
          '--template=[image reference template]:template' \
          '--tags=[additional tags for target image]:tags' \
          '--type=[manifest type]:type:(oci docker)' \
          '1:mode:->mode' \
          '*::rest:->push_rest' && ret=0
        case $state in
          mode) _describe -t push_modes 'push mode' push_modes && ret=0 ;;
          push_rest)
            case ${line[1]} in
              from-spec) _arguments '1:spec file:_files' && ret=0 ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
