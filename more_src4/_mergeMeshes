#compdef mergeMeshes
# Documentation: https://www.openfoam.com/documentation/user-guide/4-mesh-generation-and-conversion/4.5-mesh-manipulation
# Source: OpenFOAM/OpenFOAM-12 applications/utilities/mesh/manipulation/mergeMeshes/mergeMeshes.C — merge regions/cases into a single mesh.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-help[show help]' \
    '-doc[show application documentation]' \
    '-srcDoc[show source documentation]' \
    '-case+[case directory]:dir:_directories' \
    '-parallel[run in parallel]' \
    '-roots+[slave root directories]:dirs:_default' \
    '-noFunctionObjects[do not execute functionObjects]' \
    '-fileHandler+[override fileHandler]:handler:_default' \
    '-libs+[pre-load libraries]:libs:_default' \
    '-region+[mesh region]:region:_default' \
    '-overwrite[overwrite existing mesh data]' \
    '-addRegions+[regions to merge (region1 region2 ...)]:regions:_default' \
    '-addCases+[cases to merge ("casePath1" "casePath2" ...)]:cases:_default' \
    '-addCaseRegions+[case-region pairs (("path1" region1) ...)]:case_regions:_default' \
    && ret=0

return ret
