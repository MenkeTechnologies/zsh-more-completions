#compdef mcptools mcp
# Documentation: https://github.com/f/mcptools
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'version:print version'
  'tools:list or invoke MCP tools'
  'resources:list MCP resources'
  'prompts:list MCP prompts'
  'call:call tool with JSON params'
  'get-prompt:fetch a prompt'
  'read-resource:read a resource'
  'shell:stdio MCP subprocess REPL'
  'web:web transport helpers'
  'mock:generate mock MCP definitions'
  'proxy:stdio⇄HTTP proxy helpers'
  'alias:manage command aliases'
  'configs:manage known server configs'
  'new:create project skeletons'
  'guard:wrap commands with allow/deny patterns'
)

_arguments -s -S \
  '(-f --format)'{-f+,--format=}'[output format]:format:(table json pretty)' \
  '(-p --params)'{-p+,--params=}'[JSON params for call]:json:' \
  '(-h --help)'{-h,--help}'[help]' \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd) _describe -t commands 'mcptools command' commands && ret=0 ;;
  args) _default && ret=0 ;;
esac
