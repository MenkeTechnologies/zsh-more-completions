#compdef mongocompass
# Documentation: https://www.mongodb.com/docs/compass/current/settings/command-line-options/
# Reference accessed: 2026-05-19
# Verified: upstream Compass CLI options page documents these flags.

# MongoDB Compass: official GUI for MongoDB.
# Note: STUB-ish wrapper — the canonical executable name varies by OS
# (mongodb-compass on Linux/macOS app bundle). Flags below are the documented
# Compass CLI options.

local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show MongoDB Compass options]' \
  '(- *)--version[show MongoDB Compass version]' \
  '--exportConnections=[export favorite connections to file]:file:_files' \
  '--importConnections=[import favorite connections from file]:file:_files' \
  '--passphrase=[encrypt/decrypt exported connection files]:passphrase:' \
  '--showExampleConfig[display example configuration file]' \
  '--trustedConnectionString[allow auto connection with trusted connection strings]' \
  '--file=[load connections from file]:file:_files' \
  '--username=[authentication username]:user:' \
  '--password=[authentication password]:pass:' \
  '--theme=[UI theme]:theme:(LIGHT DARK OS_THEME)' \
  '--autoUpdates[enable automatic updates]' \
  '--no-autoUpdates[disable automatic updates]' \
  '--enableDevTools[enable Chrome DevTools]' \
  '--enableFeedbackPanel[enable feedback panel]' \
  '--no-enableFeedbackPanel[disable feedback panel]' \
  '--enableGenAIFeatures[enable generative AI features]' \
  '--enableGenAISampleDocumentPassing[allow sending sample docs to AI]' \
  '--enableMaps[enable mapping service requests]' \
  '--no-enableMaps[disable mapping service requests]' \
  '--enableShell[enable embedded MongoDB Shell]' \
  '--forceConnectionOptions[assign forced connection options]' \
  '--ignoreAdditionalCommandLineFlags[allow additional CLI flags]' \
  '--installURLHandlers[register as mongodb:// URL handler]' \
  '--maxTimeMS=[upper time limit for operations]:ms:' \
  '--networkTraffic[configure outgoing network operations]' \
  '--persistOIDCTokens[persist OIDC session tokens]' \
  '--protectConnectionStrings[make all connection strings read-only]' \
  '--protectConnectionStringsForNewConnections[make new connection strings read-only]' \
  '--readOnly[prevent write operations]' \
  '--showInsights[enable performance insights]' \
  '--showKerberosPasswordField[show Kerberos password field]' \
  '--showOIDCDeviceAuthFlow[enable device authorization flow for OIDC]' \
  '--trackUsageStatistics[enable usage statistics]' \
  '--no-trackUsageStatistics[disable usage statistics]' \
  '--browserCommandForOIDCAuth=[shell command for browser OIDC auth]:command:' \
  '*:URI or file:_files' && ret=0
return ret
