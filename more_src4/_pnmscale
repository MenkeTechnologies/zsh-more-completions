#compdef pnmscale pamscale
# Documentation: pamscale(1) (Netpbm)
# Source: scale a Netpbm image by factor or to given dimensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-width=[width in pixels]:px:' \
    '-height=[height in pixels]:px:' \
    '-xsize=[width in pixels]:px:' \
    '-ysize=[height in pixels]:px:' \
    '-xscale=[width scaling factor]:factor:' \
    '-yscale=[height scaling factor]:factor:' \
    '-reduce=[reduce by integer factor]:factor:' \
    '-xyfit=[fit within W H]:cols rows:' \
    '-xyfill=[fill at least W H]:cols rows:' \
    '-pixels=[approximate target pixel count]:n:' \
    '-xysize=[old-style fit within W H]:cols rows:' \
    '-nomix[do not blend pixels]' \
    '-filter=[filter function]:name:(point box triangle quadratic cubic catrom mitchell gauss sinc bessel hanning hamming blackman kaiser normal hermite lanczos)' \
    '-window=[window function]:name:(box triangle quadratic cubic catrom mitchell gauss sinc bessel hanning hamming blackman kaiser normal hermite lanczos)' \
    '-linear[work in linear sample space]' \
    '-reportonly[only report computed dimensions]' \
    '-verbose[verbose output]' \
    '-quiet[suppress informational messages]' \
    ':image:_files' \
    && ret=0

return ret
