#compdef interpreter
# Documentation: https://github.com/OpenInterpreter/open-interpreter
# Reference accessed: 2026-05-21
# Verified: upstream README at the URL above.

# Zsh completion for open-interpreter (interpreter) - natural-language code execution

_arguments \
  '--model[language model to use]:model:' \
  '--api_base[API base URL for local/custom inference servers]:url:' \
  '--api_key[API key for authentication]:key:' \
  '--local[run models locally using Llamafile]' \
  '--max_tokens[maximum tokens for model output]:n:' \
  '--context_window[context window size in tokens]:n:' \
  '--verbose[enable verbose/debug output]' \
  '--profile[load a YAML profile]:profile:_files' \
  '--profiles[open the profiles directory]' \
  '-y[auto-run code without confirmation]' \
  '--version[display version information]' \
  '(-h --help)'{-h,--help}'[show help message]'
