#compdef newfs_ext2fs
# Documentation: man newfs_ext2fs(8)
# Source: netbsd/src sbin/newfs_ext2fs — construct an ext2 file system (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-b+[block size in bytes (power of two, min 1024)]:block size:_default' \
    '-D+[inode size (128, or 256 for ext4 compat)]:inodesize:(128 256)' \
    '-F[create filesystem image in file (requires -s)]' \
    '-f+[fragment size in bytes]:fragment size:_default' \
    '-I[skip disklabel fstype check]' \
    '-i+[bytes per inode (density)]:bytes-per-inode:_default' \
    '-m+[reserved free space percentage (default 5)]:percent:_default' \
    '-N[print parameters without creating]' \
    '-n+[exact number of inodes]:inodes:_default' \
    '-O+[filesystem format revision (default 1)]:format:(0 1)' \
    '-S+[sector size in bytes (default 512)]:sector size:_default' \
    '-s+[filesystem size in sectors]:size:_default' \
    '-V+[verbosity level 0-4 (default 3)]:level:(0 1 2 3 4)' \
    '-v+[volume name]:volname:_default' \
    '-Z[pre-zero filesystem image (with -F)]' \
    '1:special device:_files' \
    && ret=0

return ret
