#compdef pithos
# Documentation: https://github.com/pithos/pithos
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Args verified against pithos/application.py add_main_option() calls.

# pithos: GTK Pandora Radio client (GUI)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-v --verbose)'{-v,--verbose}'[show info messages]' \
  '(-d --debug)'{-d,--debug}'[show debug messages]' \
  '(-t --test)'{-t,--test}'[use a mock service instead of the real Pandora server]' \
  '--last-logs[show logs for Pithos since the last reboot]' && ret=0
return ret
