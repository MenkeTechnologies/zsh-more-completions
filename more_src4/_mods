#compdef mods
# Documentation: https://github.com/charmbracelet/mods
# Reference accessed: 2026-05-19
# Verified: upstream main.go flag definitions.

# Zsh completion for mods (charmbracelet) - AI on the command line

_arguments -s -S \
  '(-m --model)'{-m,--model}'[LLM to use]:model:' \
  '(-M --ask-model)'{-M,--ask-model}'[interactive model selection]' \
  '(-a --api)'{-a,--api}'[API provider]:api:' \
  '(-x --http-proxy)'{-x,--http-proxy}'[HTTP proxy URL]:proxy:' \
  '(-f --format)'{-f,--format}'[ask for formatted response]' \
  '--format-as=[output format]:format:(json markdown)' \
  '(-r --raw)'{-r,--raw}'[print response without syntax highlighting]' \
  '(-P --prompt)'{-P,--prompt}'[include prompt; truncate stdin lines]:lines:' \
  '(-p --prompt-args)'{-p,--prompt-args}'[include prompt args in response]' \
  '(-c --continue)'{-c,--continue}'[continue from response/title/SHA-1]:title:' \
  '(-C --continue-last)'{-C,--continue-last}'[continue last conversation]' \
  '(-l --list)'{-l,--list}'[list saved conversations]' \
  '(-t --title)'{-t,--title}'[set conversation title]:title:' \
  '*'{-d+,--delete=}'[delete saved conversations]:title:' \
  '--delete-older-than=[delete conversations older than duration]:duration:' \
  '(-s --show)'{-s,--show}'[show saved conversation]:title:' \
  '(-S --show-last)'{-S,--show-last}'[show last conversation]' \
  '(-q --quiet)'{-q,--quiet}'[output errors to stderr only]' \
  '(-R --role)'{-R,--role}'[custom system role/prompt]:role:' \
  '--list-roles[list available roles]' \
  '(-e --editor)'{-e,--editor}'[open prompt in editor]' \
  '--max-retries=[max retries]:n:' \
  '--no-limit[remove response token limit]' \
  '--max-tokens=[max response tokens]:n:' \
  '--word-wrap=[output wrap width]:n:' \
  '--temp=[sampling temperature]:temp:' \
  '*--stop=[stop sequence]:stop:' \
  '--topp=[top-p sampling]:topp:' \
  '--topk=[top-k sampling]:topk:' \
  '--fanciness=[UI fanciness level]:n:' \
  '--status-text=[status text while generating]:text:' \
  '--no-cache[do not save conversations]' \
  '--reset-settings[restore defaults]' \
  '--settings[open settings in editor]' \
  '--dirs[print config and cache directories]' \
  '--theme=[UI theme]:theme:(charm catppuccin dracula base16)' \
  '--mcp-list[list available MCP servers]' \
  '--mcp-list-tools[list tools from enabled MCP servers]' \
  '*--mcp-disable=[disable an MCP server]:server:' \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '*:prompt:' && return 0
