#compdef ppmtoacad
# Documentation: man ppmtoacad (Netpbm)
# Source: convert a PPM image to AutoCAD DXF (or DXB) drawing-exchange format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-dxb[binary DXB output]' \
    '-poly[output polygons instead of points]' \
    '-background+[background color]:color:' \
    '-white[treat white as background]' \
    '-aspect+[aspect ratio]:ratio:' \
    '-8[use 8 colors only]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
