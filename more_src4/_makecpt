#compdef makecpt
# Documentation: https://docs.generic-mapping-tools.org/latest/makecpt.html
# Source: GenericMappingTools/gmt classic-mode makecpt — build / transform / write a CPT (color palette table).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[constant transparency (0-100)]:pct:_default' \
    '-C+[input CPT / color list / master palette]:cpt:_default' \
    '-D+[match back/foreground to lowest/highest z]:opts:_default' \
    '-E+[derive z-range from data table]:opts:_default' \
    '-F+[output CPT format]:format:(R r h c gray)' \
    '-G+[truncate CPT to z-level bounds]:opts:_default' \
    '-H[write CPT to stdout (not current session)]' \
    '-I[reverse color progression or z-values]' \
    '-M[override back/fore/NaN colors via gmt.conf]' \
    '-N[omit back/fore/NaN-color fields]' \
    '-Q[logarithmic interpolation]' \
    '-S+[derive -T range from input table]:opts:_default' \
    '-T+[output CPT range (min/max/inc or file)]:range:_default' \
    '*-V[verbose (stackable)]' \
    '-W+[skip interpolation / wrapped cyclic CPT]:opts:_default' \
    '-Z[force continuous CPT from color list]' \
    '*:input table:_files' \
    && ret=0

return ret
