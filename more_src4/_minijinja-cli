#compdef minijinja-cli
# Documentation: https://github.com/mitsuhiko/minijinja/tree/main/minijinja-cli
# Source: mitsuhiko/minijinja minijinja-cli/src/command.rs — CLI for rendering MiniJinja/Jinja2 templates.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--config-file=[alternative path to the config file]:file:_files' \
    '(-f --format)'{-f+,--format=}'[format of the input data]:format:(auto cbor ini json querystring toml yaml)' \
    '(-a --autoescape)'{-a+,--autoescape=}'[autoescape behavior]:mode:(auto html json none)' \
    '(-D --define)*'{-D+,--define=}'[define an input variable (key, key=value, key:=json)]:expr:_default' \
    '--strict[disallow undefined variables in templates]' \
    '--no-include[disallow includes and extending]' \
    '*--safe-path=[only allow includes from this path]:path:_files -/' \
    '--fuel=[configure the maximum fuel a template can consume]:amount:_default' \
    '(-n --no-newline)'{-n,--no-newline}'[do not output a trailing newline]' \
    '--trim-blocks[enable the trim-blocks flag]' \
    '--lstrip-blocks[enable the lstrip-blocks flag]' \
    '--py-compat[enable improved Python compatibility]' \
    '*'{-s+,--syntax=}'[change a syntax feature (feature=value)]:pair:_default' \
    '--env[pass environment variables as ENV to the template]' \
    '(-t --template)'{-t+,--template=}'[render a string template]:template:_default' \
    '(-E --expr)'{-E+,--expr=}'[evaluate a template expression]:expr:_default' \
    '--expr-out=[expression output mode]:mode:(print json json-pretty status)' \
    '--dump=[dump internals of a template]:kind:(instructions ast tokens)' \
    '--repl[start the read-eval loop with the given data]' \
    '(-o --output)'{-o+,--output=}'[path to the output file (or "-" for stdout)]:file:_files' \
    '--select=[select a subset of the input data]:selector:_default' \
    '--print-config[print out the loaded config]' \
    '(- *)'{-h,--help}'[print short help]' \
    '(- *)--long-help[print extended help]' \
    '--syntax-help[print syntax help]' \
    '(- *)'{-V,--version}'[show version]' \
    '--generate-completion=[generate a completion script]:shell:(bash elvish fig fish nushell powershell zsh)' \
    '1::template-file:_files' \
    '*:data-file:_files' \
    && ret=0

return ret
