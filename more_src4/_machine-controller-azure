#compdef machine-controller-azure
# _machine-controller-azure — Gardener MCM Azure provider (machine-controller binary)
# upstream: https://github.com/gardener/machine-controller-manager-provider-azure
# Flags from MCServer.AddFlags (machine-controller-manager pkg/util/provider/app/options/options.go) on tip.

_machine-controller-azure() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '--port=[HTTP listen port]:port:' \
        '--address=[IP address to serve on (0.0.0.0 for all)]:ip:' \
        '--cloud-provider=[cloud provider name]:name:' \
        '--concurrent-syncs=[concurrent node syncs]:n:' \
        '--min-resync-period=[informer min resync period]:dur:' \
        '--profiling=[enable pprof endpoint]:bool:(true false)' \
        '--contention-profiling=[enable lock contention profiling]:bool:(true false)' \
        '--target-kubeconfig=[target cluster kubeconfig]:file:_files' \
        '--control-kubeconfig=[control cluster kubeconfig]:file:_files' \
        '--namespace=[control cluster namespace]:ns:' \
        '--kube-api-content-type=[apiserver request content type]:type:' \
        '--kube-api-qps=[apiserver QPS]:f:' \
        '--kube-api-burst=[apiserver burst]:n:' \
        '--controller-start-interval=[interval between starting controllers]:dur:' \
        '--machine-creation-timeout=[machine creation timeout]:dur:' \
        '--machine-health-timeout=[machine health timeout]:dur:' \
        '--machine-drain-timeout=[machine drain timeout]:dur:' \
        '--machine-inplace-update-timeout=[machine in-place update timeout]:dur:' \
        '--machine-max-evict-retries=[max pod evict retries during drain]:n:' \
        '--machine-pv-detach-timeout=[PV detach wait]:dur:' \
        '--machine-pv-reattach-timeout=[PV reattach wait]:dur:' \
        '--machine-safety-apiserver-statuscheck-timeout=[apiserver-down freeze timeout]:dur:' \
        '--machine-preserve-timeout=[failed-machine preserve duration]:dur:' \
        '--machine-safety-orphan-vms-period=[orphan-VM poll period]:dur:' \
        '--machine-safety-apiserver-statuscheck-period=[apiserver health poll period]:dur:' \
        '--node-conditions=[csv of node conditions that trigger failure]:csv:' \
        '--bootstrap-token-auth-extra-groups=[csv of bootstrap-token auth-extra-groups]:csv:' \
        '--resource-exhausted-retry=[retry duration after ResourceExhausted]:dur:' \
        '-v[klog verbosity level]:n:'
}

_machine-controller-azure "$@"
