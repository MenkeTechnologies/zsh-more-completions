#compdef mii-tool
# Documentation: man mii-tool(8)
# Source: ecki/net-tools mii-tool.c (master) — view/manipulate media-independent interface (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a media=(
    1000baseTx-HD 1000baseTx-FD 1000baseTx
    100baseT4 100baseTx-FD 100baseTx-HD 100baseTx
    10baseT-FD 10baseT-HD 10baseT
)

_arguments -s \
    '(-V --version)'{-V,--version}'[show version]' \
    '*'{-v,--verbose}'[more verbose output (stackable)]' \
    '(-R --reset)'{-R,--reset}'[reset MII to power-on state]' \
    '(-r --restart)'{-r,--restart}'[restart autonegotiation]' \
    '(-w --watch)'{-w,--watch}'[monitor for link changes]' \
    '(-l --log)'{-l,--log}'[with -w, log via syslog]' \
    '(-A --advertise -F --force)'{-A+,--advertise=}'[advertise only specified media]:media:_values -s , "media" $media' \
    '(-A --advertise -F --force)'{-F+,--force=}'[force specified media]:media:($media)' \
    '*:interface:_net_interfaces' \
    && ret=0

return ret
