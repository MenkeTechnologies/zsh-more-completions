#compdef pamtoavs
# Documentation: man pamtoavs (Netpbm)
# Source: convert a Netpbm image to AVS X (Stardent visualization) format.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pam file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
