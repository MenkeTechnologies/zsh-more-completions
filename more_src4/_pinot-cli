#compdef pinot-cli pinot-admin
# _pinot-cli — Apache Pinot pinot-cli CLI command-line frontend wrapping the Apache Pinot real-time distributed OLAP datastore providing StartZookeeper StartKafka StartController StartServer StartBroker StartMinion StartServiceManager AddTable UploadSegment DeleteSegment GetTableConfig PostQuery LaunchDataIngestionJob ImportData ChangeNumReplicas DataPreparationHelper (ASF Pinot LinkedIn team, Java); custom argparse
# upstream: https://pinot.apache.org/

_pinot-cli() {
    local -a sub=(
        'StartZookeeper:start ZooKeeper'
        'StartKafka:start Kafka'
        'StartController:start controller'
        'StartServer:start server'
        'StartBroker:start broker'
        'StartMinion:start minion'
        'StartServiceManager:start service manager'
        'AddTable:add table'
        'UpdateTable:update table'
        'DeleteTable:delete table'
        'GetTableConfig:get table config'
        'AddSchema:add schema'
        'UpdateSchema:update schema'
        'DeleteSchema:delete schema'
        'UploadSegment:upload segment'
        'DeleteSegment:delete segment'
        'LaunchDataIngestionJob:launch ingestion job'
        'PostQuery:post a query'
        'ImportData:import data'
        'ChangeNumReplicas:change replicas'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-zkAddress+[zk]:_hosts' \
        '-clusterName+[name]:str:' \
        '-controllerHost+[host]:_hosts' \
        '-controllerPort+[port]:n:' \
        '-controllerProtocol+[p]:p:(http https)' \
        '-brokerHost+[host]:_hosts' \
        '-brokerPort+[port]:n:' \
        '-serverHost+[host]:_hosts' \
        '-serverPort+[port]:n:' \
        '-serverAdminPort+[port]:n:' \
        '-tableConfigFile+[file]:file:_files -g "*.json"' \
        '-schemaFile+[file]:file:_files -g "*.json"' \
        '-tableName+[name]:str:' \
        '-segmentName+[name]:str:' \
        '-segmentDir+[dir]:dir:_files -/' \
        '-jobSpecFile+[file]:file:_files -g "*.yaml *.yml"' \
        '-query+[sql]:str:' \
        '-exec[execute]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pinot subcommand' sub ;;
        args) _arguments '*:arg:' ;;
    esac
}

_pinot-cli "$@"
