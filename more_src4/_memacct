#compdef memacct
# Documentation: /usr/bin/memacct (macOS) --help and per-subcommand help
# Reference accessed: 2026-05-19
# Verified: live `memacct --help`, `memacct get --help`,
# `memacct set --help`, `memacct monitor --help` on macOS Darwin 25.4.0.

local curcontext="$curcontext" state line ret=1
local -a subcommands

subcommands=(
  'get:fetch memory usage statistics'
  'set:set memory usage limits'
  'monitor:monitor memory usage for a given subsystem in real time'
  'help:show subcommand help'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  {-v,--verbose}'[enable verbose mode]' \
  '--list[list names for all active memory accounting subsystems]' \
  '1: :->subcommand' \
  '*::arg:->args' && ret=0

case $state in
  (subcommand)
    _describe -t subcommands 'memacct subcommand' subcommands && ret=0
    ;;
  (args)
    case ${words[1]} in
      (get)
        _arguments \
          {-v,--verbose}'[enable verbose mode]' \
          '(-n --name)'{-n,--name}'[subsystem name]:name:' \
          '(-p --peak)'{-p,--peak}'[return peak values]' \
          '(-a --allocated)'{-a,--allocated}'[return allocation values]' \
          '--hard-limit[return memory hard-limit]' \
          '(-s --soft-limit)'{-s,--soft-limit}'[return memory soft-limit]' \
          '--csv[export data in CSV]' \
          '--help[show help]' && ret=0
        ;;
      (set)
        _arguments \
          {-v,--verbose}'[enable verbose mode]' \
          '(-n --name)'{-n,--name}'[subsystem name]:name:' \
          '--hard-limit[set hard limit, e.g. 1GB/128MB/1024]:value:' \
          '--reset-peak[reset peak memory usage to 0]' \
          '--help[show help]' && ret=0
        ;;
      (monitor)
        _arguments \
          {-v,--verbose}'[enable verbose mode]' \
          '(-n --name)'{-n,--name}'[subsystem name]:name:' \
          '(-i --interval)'{-i,--interval}'[interval in ms (default 1000)]:ms:' \
          '(-s --summary)'{-s,--summary}'[collect summary stats]' \
          '(-f --file)'{-f,--file}'[absolute path for summary metrics]:file:_files' \
          '--help[show help]' && ret=0
        ;;
    esac
    ;;
esac

return ret
