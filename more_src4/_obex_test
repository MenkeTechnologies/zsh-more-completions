#compdef obex_test
# Documentation: https://manpages.ubuntu.com/manpages/bionic/man1/obex_test.1.html
# Reference accessed: 2026-05-19
# Verified: upstream openobex apps/obex_test. Real flags:
# -s [port], -r [port], -i, -b [addr] [chan], -u [iface].
# Corrected from prior file: was -h/-s/-c (none of which exist;
# -s means cable obex not server, no -c).

local curcontext="$curcontext" ret=1

_arguments -C \
  '-s[cable OBEX]:port:_files -g "/dev/tty*"' \
  '-r[cable OBEX for Ericsson R320]:port:_files -g "/dev/tty*"' \
  '-i[OBEX over IrDA]' \
  '-b[OBEX over Bluetooth]:address:' \
  '-u[USB OBEX (CDC)]:interface:' \
  '*: :_default' && ret=0

return ret
