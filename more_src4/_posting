#compdef posting
# Documentation: https://posting.sh/guide/
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

_posting_commands() {
  local -a commands=(
    'default:Run the TUI (default command)'
    'locate:Show config/collection/themes paths'
    'import:Import an OpenAPI or Postman spec into a collection'
    'sponsors:Show the list of sponsors'
  )
  _describe 'command' commands
}

_posting() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  _arguments -C \
    '(-h --help)'{-h,--help}'[show help]' \
    '1:command:_posting_commands' \
    '*::arg:->args'

  case $state in
    args)
      case $line[1] in
        default)
          _arguments \
            '(-c --collection)'{-c,--collection=}'[path to collection directory]:directory:_directories' \
            '(-e --env)'{-e,--env=}'[path to .env environment file]:file:_files' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        locate)
          _arguments \
            '1:thing:(config collection themes)' \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
        import)
          _arguments \
            '(-o --output)'{-o,--output=}'[path to save imported collection]:path:_files' \
            '(-t --type)'{-t,--type=}'[spec type]:type:(openapi postman)' \
            '(-h --help)'{-h,--help}'[show help]' \
            '1:spec file:_files'
          ;;
        sponsors)
          _arguments \
            '(-h --help)'{-h,--help}'[show help]'
          ;;
      esac
      ;;
  esac
}

_posting "$@"
