#compdef nkt
# Documentation: https://github.com/fjebaker/nkt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# nkt is a terminal note-taking tool by fjebaker (NOT a biblatex TUI as
# the prior file claimed). Subcommands per README: init, log, edit,
# read, find (alias f), task, ls, new, tag, select, compile, completion.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'init:set up the nkt home directory'
  'log:add an entry to a journal'
  'edit:create or modify a note'
  'read:display journal entries and tasks'
  'find:fuzzy search across notes'
  'f:alias for find'
  'task:add an item to the task list'
  'ls:list items (todo, notes, tags, compilers)'
  'new:create a new tag'
  'tag:assign tags to items'
  'select:test what a selector matches'
  'compile:render notes using text compilers'
  'completion:generate shell completions'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--version[show version]' \
  '--journal=[journal name]:journal' \
  '--directory=[directory name]:directory' \
  '--time=[time HH:MM:SS]:time' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t commands 'nkt command' commands && ret=0 ;;
esac

return ret
