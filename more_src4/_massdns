#compdef massdns
# Documentation: https://github.com/blechschmidt/massdns
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '-b+[bind to IP address and port]:addr:' \
  '--bindto=[bind to IP address and port]:addr:' \
  '-r+[text file containing DNS resolvers]:file:_files' \
  '--resolvers=[text file containing DNS resolvers]:file:_files' \
  '-t+[record type to query]:type:(A AAAA ANY CNAME DNAME MX NS PTR SOA SRV TXT CAA TLSA SVCB HTTPS)' \
  '--type=[record type to query]:type:(A AAAA ANY CNAME DNAME MX NS PTR SOA SRV TXT CAA TLSA SVCB HTTPS)' \
  '-o+[output format flags]:flags:' \
  '--output=[output format flags]:flags:' \
  '-s+[number of concurrent lookups (hashmap size)]:size' \
  '--hashmap-size=[number of concurrent lookups (hashmap size)]:size' \
  '-w+[write results to file]:file:_files' \
  '--outfile=[write results to file]:file:_files' \
  '-q[quiet mode, no status output]' \
  '--quiet[quiet mode, no status output]' \
  '-c+[number of resolves before giving up]:count' \
  '--resolve-count=[number of resolves before giving up]:count' \
  '-l+[error log file]:file:_files' \
  '--error-log=[error log file]:file:_files' \
  '-i+[interval in milliseconds between resolves]:ms' \
  '--interval=[interval in milliseconds between resolves]:ms' \
  '--retry=[behaviour for failed lookups]:rcode:' \
  '--processes=[number of parallel processes]:count' \
  '--socket-count=[number of sockets per process]:count' \
  '--sticky[do not switch to next resolver on failure]' \
  '--flush[flush output after every record]' \
  '--root[allow running as root without dropping privileges]' \
  '--predictable[use a predictable name server ordering]' \
  '--filter=[filter query replies]:rcode:' \
  '--ignore=[ignore certain replies]:rcode:' \
  '--norecurse[do not set the recursion-desired bit]' \
  '--extended-input[expect extended input format]' \
  '--status-format=[status format]:format:' \
  '--sndbuf=[socket send buffer size]:size' \
  '--rcvbuf=[socket receive buffer size]:size' \
  '--busy-poll[use busy polling for sockets]' \
  '--rand-src-ipv6[randomize IPv6 source address]' \
  '--rand-src-ipv6-file=[file of IPv6 source addresses]:file:_files' \
  '--drop-group=[drop privileges to this group]:group:_groups' \
  '--drop-user=[drop privileges to this user]:user:_users' \
  '--verify-ip[verify IP addresses of incoming replies]' \
  '*:domain list file:_files' && ret=0

return ret
