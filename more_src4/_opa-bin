#compdef opa
# _opa-bin — Open Policy Agent CLI (Open Policy Agent + CNCF, Go); Rego policy engine for k8s / microservices / IaC
# upstream: https://github.com/open-policy-agent/opa

_opa-bin() {
    local -a sub=(
        'bench:benchmark a policy'
        'build:build a policy bundle'
        'check:check Rego syntax'
        'completion:print shell completion'
        'deps:print rule deps'
        'eval:evaluate a Rego query'
        'exec:execute against input docs'
        'fmt:format Rego source'
        'help:show help'
        'inspect:inspect a bundle'
        'parse:parse Rego module'
        'refactor:refactor commands'
        'run:run OPA server / REPL'
        'sign:sign a bundle'
        'test:run policy unit tests'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'opa subcommand' sub ;;
        args)
            case $words[1] in
                eval) _arguments \
                    '-b+[bundle]:path:_files' \
                    '--bundle+[bundle]:path:_files' \
                    '-d+[data]:path:_files' \
                    '--data+[data]:path:_files' \
                    '-i+[input file]:file:_files' \
                    '--input+[input file]:file:_files' \
                    '-f+[output format]:fmt:(json pretty values bindings raw discard)' \
                    '--format+[output format]:fmt:' \
                    '--explain+[explain]:level:(off full notes fails debug)' \
                    '--instrument[instrument]' \
                    '--profile[show profile]' \
                    '--metrics[show metrics]' \
                    '--coverage[show coverage]' \
                    '--strict-builtin-errors[strict builtin errors]' \
                    '--fail[fail on undefined]' \
                    '--fail-defined[fail if defined]' \
                    '*:query:' ;;
                test) _arguments \
                    '-b+[bundle]:path:_files' \
                    '-c+[coverage]' \
                    '--coverage[show coverage]' \
                    '--explain+[explain]:level:(off full notes fails debug)' \
                    '--threshold+[coverage threshold]:f:' \
                    '--timeout+[timeout]:duration:' \
                    '-v[verbose]' \
                    '--verbose[verbose]' \
                    '--ignore+[ignore glob]:glob:' \
                    '*:path:_files' ;;
                run) _arguments \
                    '-s[run server]' \
                    '--server[run server]' \
                    '-a+[listen addr]:addr:' \
                    '--addr+[listen addr]:addr:' \
                    '-l+[log level]:level:(debug info error)' \
                    '--log-level+[log level]:level:' \
                    '--log-format+[log format]:fmt:(json json-pretty text)' \
                    '-b+[bundle]:path:_files' \
                    '--bundle+[bundle]:path:_files' \
                    '*:source:_files' ;;
                build) _arguments \
                    '-b[bundle mode]' \
                    '--bundle[bundle mode]' \
                    '-o+[output file]:file:_files' \
                    '--output+[output file]:file:_files' \
                    '-r+[revision]:str:' \
                    '--revision+[revision]:str:' \
                    '-O[optimize]' \
                    '--optimize+[optimize level]:n:' \
                    '*:source:_files' ;;
                completion) _arguments '1:shell:(bash zsh fish powershell)' ;;
            esac
            ;;
    esac
}

_opa-bin "$@"
