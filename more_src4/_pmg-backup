#compdef pmg-backup pmgbackup
# _pmg-backup — Proxmox Server Solutions pmgbackup Proxmox Mail Gateway database and config backup tool (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pmg-api.git

_pmg-backup() {
    local -a sub=(
        'backup:create a backup'
        'restore:restore from a backup'
        'list:list available backups'
        'delete:delete a backup'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pmgbackup subcommand' sub ;;
        args)
            case $words[1] in
                backup) _arguments \
                    '--notify=+[notify]:n:(always error never)' \
                    '--statistic=+[bool]:b:(0 1)' \
                    '--remove=+[bool]:b:(0 1)' \
                    '--keep-last=+[N]:n:' ;;
                restore) _arguments \
                    '--config[restore config]' \
                    '--database[restore database]' \
                    '--statistic[restore statistics]' \
                    '*:archive:_files -g "*.tgz *.tar.gz *.tar"' ;;
                delete) _arguments '*:archive:_files -g "*.tgz *.tar.gz *.tar"' ;;
                list) _arguments \
                    '--node=+[node name]:str:' ;;
            esac
            ;;
    esac
}

_pmg-backup "$@"
