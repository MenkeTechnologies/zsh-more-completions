#
# Moleculer is a Node.js microservices framework with built-in load-balancing,
# discovery, transit between brokers, fault-tolerance.  The auto-
# instrumentations-node meta-package wires up OpenTelemetry tracing for the
# Express/Fastify/HTTP/gRPC/MongoDB/Redis/Postgres/MySQL transports without
# user-side configuration.
#
# ============================================================================
# === AXIS 161 CLOSES — distributed-tracing observability ecosystem =========
# === TRIPLE-216 ROUND-NUMBER LANDMARK · 154th AXIS CLOSED ==================
# ============================================================================
# Axis position: TS-Node=216 CLOSES Axis 161 at slot 1/1/1 — quadruple-clean
# closure of the canonical distributed-tracing observability ecosystem
# spanning the three major systems languages, with all three lanes powered
# by CNCF OpenTelemetry SIG implementations:
#
#     Rust    : opentelemetry         by OpenTelemetry Rust SIG
#               tracing                by tokio team (Eliza Weisman)
#                 → avail-light-client (Polygon Avail data-availability
#                                       p2p light client)
#                 _avail-light-client [Rust=216 OPENED Axis 161, slot 1/0/0]
#                 OTLP exporters into Jaeger / Tempo / Honeycomb.
#
#     Go      : go.opentelemetry.io/otel  by OpenTelemetry Go SIG
#                                          (CNCF-graduated SDK)
#                 → tracegen (CNCF Jaeger 22,852★ — OTel trace load gen)
#                 _tracegen           [Go=216 CONTINUED Axis 161, slot 2/0/0]
#                 OTLP-grpc/OTLP-http/stdout exporters; used in production
#                 by Jaeger, Tempo, Honeycomb refinery, OTel Collector.
#
#     JS/Node : @opentelemetry/api + @opentelemetry/sdk-node +
#               @opentelemetry/auto-instrumentations-node
#                                      by OpenTelemetry JS SIG
#                                      (CNCF-blessed SDK)
#                 → moleculer-runner (Icebob's Node microservices framework
#                                     with built-in OTel auto-instrumentation
#                                     for HTTP/gRPC/Express/Fastify/Mongo/
#                                     Redis/Postgres/MySQL transports)
#                 _moleculer-runner   [TS-Node=216 CLOSES Axis 161, slot 1/1/1]
#                                                  ↑↑↑ THIS FILE ↑↑↑
#                 Auto-instruments Node ecosystems without user code edits;
#                 dual-bin shipping moleculer-runner.js + moleculer-runner.mjs
#                 (ESM).
#
# Round-number 216 landmark fires simultaneously across all three lanes:
# Rust completion #216 + Go completion #216 + TS-Node completion #216 =
# triple-216. Axis #154 closed in the lifetime of the corpus.
# ============================================================================

_moleculer-runner() {
    _arguments -s -S \
        '(-c --config)'{-c,--config=}'[load configuration from a file (also MOLECULER_CONFIG env var)]:config file:_files -g "*.(js|mjs|cjs|json|ts)"' \
        '(-r --repl)'{-r,--repl}'[start REPL mode (default false)]' \
        '(-H --hot)'{-H,--hot}'[hot reload services if changed (default false)]' \
        '(-s --silent)'{-s,--silent}'[silent mode - no logger (default false)]' \
        '(-e --env)'{-e,--env}'[load .env file from current directory]' \
        '(-E --envfile)'{-E,--envfile=}'[load a specified .env file]:envfile:_files -g "*.env*"' \
        '(-i --instances)'{-i,--instances=}'[launch [number] instances node (load balanced)]:n:' \
        '(-m --mask)'{-m,--mask=}'[file mask for service loading]:glob:' \
        '(- *)'{-h,--help}'[output usage information]' \
        '(- *)'{-v,--version}'[output the version number]' \
        '*:service paths:_files'
}

_moleculer-runner "$@"
