# upstream: https://www.oilshell.org/

_oil-cli() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-c+[command]:str:' \
        '-i[interactive]' \
        '-l[login shell]' \
        '--rcfile=+[file]:file:_files -g "*.osh *.ysh"' \
        '--norc[no rc]' \
        '--rcdir=+[dir]:dir:_files -/' \
        '-n[noexec]' \
        '--ast-format=+[fmt]:f:(abbrev-text none text html)' \
        '--print-config[print config]' \
        '--print-status[print status]' \
        '--debug-file=+[file]:file:_files' \
        '--trace-file=+[file]:file:_files' \
        '--xtrace-details[xtrace details]' \
        '--xtrace-rich[xtrace rich]' \
        '--show-options[show options]' \
        '--eval=+[code]:str:' \
        '*--eval=+[code]:str:' \
        '--tool=+[t]:t:(syntax-tree tokens cat ysh-ify deps cat-em translate flatten parse syntax)' \
        '--no-env[no env]' \
        '-o+[option]:o:(errexit nounset pipefail noglob nullglob globstar debug noexec hashall histexpand interactive monitor notify privileged verbose vi emacs xtrace allexport ignoreeof posix one_pass_parse parse_at simple_word_eval parse_paren parse_brace parse_amp parse_func parse_at_all parse_proc parse_triple_quote sourceful_yshrc)' \
        '+o+[option]:o:(errexit nounset pipefail noglob nullglob globstar debug noexec hashall histexpand interactive monitor notify privileged verbose vi emacs xtrace allexport ignoreeof posix one_pass_parse parse_at simple_word_eval parse_paren parse_brace parse_amp parse_func parse_at_all parse_proc parse_triple_quote sourceful_yshrc)' \
        '+O+[shopt]:str:' \
        '-O+[shopt]:str:' \
        '*:script:_files -g "*.osh *.ysh *.sh"'
}

_oil-cli "$@"
