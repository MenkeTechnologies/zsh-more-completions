_nsite-cli() {
    local curcontext="$curcontext" state line ret=1
    typeset -A opt_args

    _arguments -C \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-V,--version}'[print version]' \
        '1: :->cmd' \
        '*:: :->args' && ret=0

    case $state in
        cmd)
            local -a _nsite_commands=(
                'upload:upload files from a directory to nsite (kind:34128) + blossom'
                'ls:list all files available online for an npub'
                'download:download all files available online for an npub'
            )
            _describe -t commands 'nsite-cli command' _nsite_commands && ret=0
            ;;
        args)
            case $words[1] in
                upload)
                    _arguments \
                        '1:folder to publish:_files -/' \
                        '(-f --force)'{-f,--force}'[force publishing even if no changes detected]' \
                        '(-s --servers)'{-s,--servers}'=[comma-separated blossom servers]:servers:' \
                        '(-r --relays)'{-r,--relays}'=[comma-separated Nostr relays]:relays:' \
                        '(-k --privatekey)'{-k,--privatekey}'=[nsec/hex private key to sign with]:nsec:' \
                        '(-p --purge)'{-p,--purge}'[delete online file events that are not used anymore]' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output (file lists)]' \
                        '--publish-server-list[publish the list of blossom servers (Kind 10063)]' \
                        '--publish-relay-list[publish the list of Nostr relays (Kind 10002)]' \
                        '--publish-profile[publish the npub profile (Kind 0)]' \
                        '--fallback=[HTML file to copy and publish as 404.html]:file:_files -g "*.html *.htm"' && ret=0
                    ;;
                ls)
                    _arguments \
                        '1:npub of web content to list:' \
                        '(-r --relays)'{-r,--relays}'=[comma-separated Nostr relays]:relays:' \
                        '(-k --privatekey)'{-k,--privatekey}'=[nsec/hex private key]:nsec:' && ret=0
                    ;;
                download)
                    _arguments \
                        '1:target folder:_files -/' \
                        '2:npub of web content:' \
                        '(-s --servers)'{-s,--servers}'=[comma-separated blossom servers]:servers:' \
                        '(-r --relays)'{-r,--relays}'=[comma-separated Nostr relays]:relays:' \
                        '(-v --verbose)'{-v,--verbose}'[verbose output]' \
                        '(-p --purge)'{-p,--purge}'[delete extra local files]' && ret=0
                    ;;
            esac
            ;;
    esac

    return ret
}

_nsite-cli "$@"
