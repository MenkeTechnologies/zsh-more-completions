#compdef ntfs-3g mount.ntfs-3g mount.ntfs
# _ntfs-3g — Tuxera ntfs-3g (FUSE-based read-write NTFS driver; usually invoked via mount(8) as mount.ntfs / mount.ntfs-3g; -o ntfs-3g/FUSE options (uid,gid,umask,big_writes,locale,utf8,permissions,acl,allow_other,no_def_opts,windows_names,streams_interface,inherit,silent), -o ro/rw, -o ignore_case, -o remove_hiberfile)
# upstream: https://github.com/tuxera/ntfs-3g
# Flags from ntfs-3g src/ntfs-3g.c on tip.

_ntfs-3g() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-o+[mount options]:options:(ro rw uid gid umask fmask dmask big_writes locale utf8 permissions acl allow_other allow_root no_def_opts hide_hid_files hide_dot_files ignore_case windows_names remove_hiberfile streams_interface inherit show_sys_files silent recover norecover usermapping debug compression nocompression)' \
        '-v[verbose]' \
        '-f[foreground]' \
        '-d[debug]' \
        '-s[single threaded]' \
        '1:NTFS volume:_files -g "/dev/*"' \
        '2:mountpoint:_files -/'
}

_ntfs-3g "$@"
