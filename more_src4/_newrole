#compdef newrole
# Documentation: man newrole(1)
# Source: SELinuxProject/selinux policycoreutils/newrole/newrole.c (main) — run shell with new SELinux role/type (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-r --role)'{-r+,--role=}'[SELinux role]:role:_default' \
    '(-t --type)'{-t+,--type=}'[SELinux type]:type:_default' \
    '(-l --level)'{-l+,--level=}'[MLS/MCS level]:level:_default' \
    '(-p --preserve-environment)'{-p,--preserve-environment}'[preserve environment]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '-c+[command to run]:command:_command_names -e' \
    '*::command args:_default' \
    && ret=0

return ret
