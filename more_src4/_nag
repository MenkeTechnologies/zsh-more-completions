#compdef nag
# Documentation: https://github.com/ayanalamMOON/Nagari
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Replaces the previously-pasted setup-nagpkg.sh shell script body
# with a real zsh completion derived from the Nagari CLI subcommand set.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'run:run a Nagari file'
  'build:build / compile Nagari code'
  'transpile:transpile to JavaScript'
  'bundle:bundle for distribution'
  'format:format source code'
  'lint:lint source code'
  'test:run tests'
  'repl:start interactive REPL'
  'doc:generate documentation'
  'package:package management'
  'lsp:Language Server Protocol'
  'init:initialize project'
  'serve:development server'
)

_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd)
    _describe -t commands 'nag command' commands && ret=0
    ;;
  (args)
    case $line[1] in
      (package)
        local -a pkg_cmds=(
          'init:initialize package'
          'install:install packages'
          'uninstall:uninstall packages'
          'update:update packages'
          'list:list packages'
          'search:search packages'
          'info:package information'
          'publish:publish package'
          'unpublish:unpublish package'
          'login:login to registry'
          'logout:logout from registry'
        )
        _describe -t pkgcmds 'package command' pkg_cmds && ret=0
        ;;
      (repl)
        _arguments \
          '--script=[load a script]:file:_files' \
          '--load=[load file]:file:_files' \
          '--save=[save session]:file:_files' \
          '--session=[session name]:name:' && ret=0
        ;;
      (run)
        _arguments \
          '--watch[watch mode]' \
          '*:file:_files -g "*.nag"' && ret=0
        ;;
      (build|transpile|bundle|format|lint|test|init|serve|doc|lsp)
        _arguments '*:file:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
