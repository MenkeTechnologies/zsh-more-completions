#compdef pnmcrop
# Documentation: man pnmcrop (Netpbm)
# Source: crop borders of uniform color off a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-white -black -sides -bg-color -bg-corner)-white[crop white border]' \
    '(-white -black -sides -bg-color -bg-corner)-black[crop black border]' \
    '(-white -black -sides -bg-color -bg-corner)-sides[crop only left/right]' \
    '(-white -black -sides -bg-color -bg-corner)-bg-color=[crop pixels of given color]:color:' \
    '(-white -black -sides -bg-color -bg-corner)-bg-corner=[take corner color as background]:corner:(topleft topright bottomleft bottomright)' \
    '-left[crop left edge]' \
    '-right[crop right edge]' \
    '-top[crop top edge]' \
    '-bottom[crop bottom edge]' \
    '-margin=[keep N pixels of margin]:pixels:' \
    '-closeness=[match closeness percent]:percent:' \
    '-borderfile=[reference border file]:file:_files' \
    '-blank-image=[blank-image behaviour]:mode:(abort pass minimize maxcrop)' \
    '(-reportfull -reportsize)-reportfull[report rectangle to keep]' \
    '(-reportfull -reportsize)-reportsize[report size only]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
