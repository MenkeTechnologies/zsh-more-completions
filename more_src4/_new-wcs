#compdef new-wcs
# Documentation: https://astrometry.net
# Source: dstndstn/astrometry.net man/new-wcs.1 — merge WCS solution with existing FITS header cards (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-i+[input FITS file]:file:_files -g "*.{fits,fit,fts}"' \
    '-w+[WCS file]:file:_files -g "*.{wcs,fits}"' \
    '-o+[output file]:file:_files' \
    '-d[also copy the data segment]' \
    '-v[verbose]' \
    && ret=0

return ret
