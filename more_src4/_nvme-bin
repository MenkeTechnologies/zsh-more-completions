#compdef nvme
# _nvme-bin — NVMe management CLI (Keith Busch + linux-nvme team, C); identify/format/sanitize/firmware/log for NVMe devices
# upstream: https://github.com/linux-nvme/nvme-cli

_nvme-bin() {
    local -a sub=(
        'list:list all NVMe controllers'
        'list-subsys:list NVMe subsystems'
        'list-ns:list namespaces'
        'list-ctrl:list controllers'
        'id-ctrl:show controller identify data'
        'id-ns:show namespace identify data'
        'id-ns-granularity:NS granularity'
        'id-nvmset:NVM Set info'
        'id-iocs:I/O command set info'
        'id-uuid:UUID list'
        'list-features:list features'
        'get-feature:get feature value'
        'set-feature:set feature value'
        'get-log:retrieve log'
        'get-property:read property'
        'set-property:write property'
        'get-lba-status:LBA status'
        'fw-log:firmware log'
        'changed-ns-log:changed namespace log'
        'persistent-event-log:persistent event log'
        'self-test-log:self-test log'
        'smart-log:SMART log'
        'predictable-lat-event-log:predictable latency events'
        'ana-log:ANA group log'
        'lba-status-log:LBA status info log'
        'endurance-log:endurance log'
        'effects-log:command effects log'
        'pred-lat-event-log:predictable latency events'
        'create-ns:create namespace'
        'delete-ns:delete namespace'
        'attach-ns:attach namespace to controller'
        'detach-ns:detach namespace from controller'
        'format:format namespace'
        'sanitize:start sanitize'
        'sanitize-log:show sanitize log'
        'security-recv:security receive'
        'security-send:security send'
        'fw-download:download firmware image'
        'fw-commit:commit firmware image'
        'fw-activate:activate firmware image'
        'reset:reset controller'
        'subsystem-reset:reset subsystem'
        'ns-rescan:rescan namespaces'
        'flush:flush data'
        'write:write data'
        'read:read data'
        'compare:compare data'
        'write-zeroes:write zeros'
        'write-uncor:write uncorrectable'
        'verify:verify LBA range'
        'dsm:dataset management (TRIM)'
        'copy:simple copy'
        'discover:NVMe-oF discover'
        'connect:NVMe-oF connect'
        'connect-all:NVMe-oF connect all'
        'disconnect:NVMe-oF disconnect'
        'disconnect-all:disconnect all NVMe-oF'
        'gen-hostnqn:generate Host NQN'
        'show-hostnqn:print Host NQN'
        'show-topology:show topology'
        'show-regs:show controller registers'
        'show-hmb:show HMB info'
        'subsys-version:show NVMe-oF version'
        'help:show help'
        'version:show version'
    )
    _arguments -C \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'nvme subcommand' sub ;;
        args)
            case $words[1] in
                id-ctrl|id-ns|smart-log|fw-log|format|sanitize|reset|subsystem-reset|ns-rescan|list-ns) _arguments \
                    '-o+[output format]:fmt:(normal json binary)' \
                    '-n+[namespace id]:n:' \
                    '*:device:_files' ;;
                discover|connect|connect-all) _arguments \
                    '-t+[transport]:transport:(rdma fc tcp loop)' \
                    '-n+[NQN]:nqn:' \
                    '-a+[target address]:addr:' \
                    '-s+[service id]:str:' \
                    '-q+[host NQN]:nqn:' \
                    '*:args:' ;;
            esac
            ;;
    esac
}

_nvme-bin "$@"
