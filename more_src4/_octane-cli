#compdef octane-cli
# _octane-cli — Taylor Otwell Laravel Octane high-perf application server CLI alias (laravel team, PHP); artisan-based
# upstream: https://github.com/laravel/octane

_octane-cli() {
    local -a sub=(
        'octane:install:install octane'
        'octane:reload:reload workers'
        'octane:start:start server'
        'octane:status:show status'
        'octane:stop:stop server'
        'octane:frankenphp:start frankenphp server'
        'octane:swoole:start swoole server'
        'octane:roadrunner:start roadrunner server'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '--env=+[env]:str:' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'octane subcommand' sub ;;
        args)
            case $words[1] in
                octane:install) _arguments \
                    '--server=+[server]:s:(swoole roadrunner frankenphp)' \
                    '--force[force]' ;;
                octane:start|octane:frankenphp|octane:swoole|octane:roadrunner) _arguments \
                    '--server=+[server]:s:(swoole roadrunner frankenphp)' \
                    '--host=+[host]:host:_hosts' \
                    '--port=+[port]:port:' \
                    '--admin-port=+[admin port]:port:' \
                    '--rpc-port=+[rpc port]:port:' \
                    '--workers=+[workers]:n:' \
                    '--task-workers=+[task workers]:n:' \
                    '--max-requests=+[max requests]:n:' \
                    '--watch[watch for file changes]' \
                    '--poll[poll for file changes]' \
                    '--log-level=+[log level]:l:(debug info notice warning error critical alert emergency)' \
                    '--https[serve over https]' \
                    '--http-redirect[redirect http to https]' \
                    '--caddyfile=+[caddyfile]:file:_files' ;;
            esac
            ;;
    esac
}

_octane-cli "$@"
