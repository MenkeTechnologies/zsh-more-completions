#compdef phar
# _phar — PHP Phar archive packager CLI (PHP / phar contributors, PHP); custom argparse
# upstream: https://github.com/php/php-src/tree/master/ext/phar

_phar() {
    local -a sub=(
        'add:add file to phar'
        'delete:delete file from phar'
        'extract:extract phar'
        'help:show help'
        'info:show phar info'
        'list:list phar contents'
        'meta-del:delete metadata'
        'meta-get:get metadata'
        'meta-set:set metadata'
        'pack:create new phar'
        'sign:sign phar'
        'stub-get:get phar stub'
        'stub-set:set phar stub'
        'tree:show phar tree'
        'version:show version'
        'compress:compress phar'
        'decompress:decompress phar'
        'convert:convert phar format'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'phar subcommand' sub ;;
        args)
            case $words[1] in
                add) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '-i+[input file]:file:_files' \
                    '-c+[compression]:c:(gz bz2 none)' \
                    '-y+[private key file]:file:_files' \
                    '*:arg:' ;;
                delete) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '-e+[entry to delete]:str:' \
                    '*:arg:' ;;
                extract) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '-i+[input pattern]:str:' \
                    '-o+[output dir]:dir:_files -/' ;;
                info|list|tree|sign|stub-get|stub-set) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '*:arg:' ;;
                pack) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '-a+[alias]:str:' \
                    '-c+[compression]:c:(gz bz2 none)' \
                    '-i+[input pattern]:str:' \
                    '-x+[exclude pattern]:str:' \
                    '-s+[stub file]:file:_files' \
                    '-y+[private key file]:file:_files' \
                    '-h+[hash algo]:str:(md5 sha1 sha256 sha512)' \
                    '-l+[loader]:str:' \
                    '*:input-paths:_files' ;;
                compress|decompress) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '-c+[compression]:c:(gz bz2)' ;;
                convert) _arguments \
                    '-f+[phar file]:file:_files -g "*.phar"' \
                    '-c+[compression]:c:(gz bz2 0)' \
                    '-t+[format]:t:(0 1 2)' ;;
            esac
            ;;
    esac
}

_phar "$@"
