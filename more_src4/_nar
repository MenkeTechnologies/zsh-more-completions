#compdef nar
# Documentation: https://github.com/LittleSound/nai
# Reference accessed: 2026-05-23
# Verified: upstream README nar command section.

# Zsh completion for nar - interactive package.json script runner (@rizumu/nai)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '1:script:' \
  '*:args:' && ret=0

return ret
