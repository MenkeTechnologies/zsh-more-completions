#compdef micro-editor
# _micro-editor — micro modern terminal editor alias (Zachary Yedidia, Go); spf13/cobra-style flat flags
# upstream: https://github.com/zyedidia/micro

_micro-editor() {
    _arguments \
        '-help[show help]' \
        '--help[show help]' \
        '-version[show version]' \
        '--version[show version]' \
        '-clean[clean stale settings]' \
        '-config-dir=+[config dir]:dir:_files -/' \
        '-debug[debug logs]' \
        '-options[print options]' \
        '-plugin+[plugin command]:cmd:(install remove list update available search)' \
        '-startpos=+[start position line[,col\]]:str:' \
        '-multiopen=+[open multiple files]:str:' \
        '-headless[headless]' \
        '-+[option setter]:str:' \
        '*:file:_files'
}

_micro-editor "$@"
