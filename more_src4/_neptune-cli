#compdef neptune-cli neptune2
# _neptune-cli — Neptune.ai neptune-cli CLI command-line frontend wrapping the Neptune.ai experiment tracker model registry MLOps platform managing projects runs experiments models notebooks artifacts datasets dashboards monitoring tracking parameters metrics plots tags users teams workspace UI login logout init sync (Neptune.ai team, Python); click
# upstream: https://neptune.ai/

_neptune-cli() {
    local -a sub=(
        'login:authenticate'
        'logout:revoke session'
        'init:initialize a project'
        'sync:sync offline runs'
        'list:list resources'
        'project:project operations'
        'run:run operations'
        'experiment:experiment operations'
        'model:model registry'
        'notebook:notebook operations'
        'artifact:artifact operations'
        'dashboard:dashboard operations'
        'user:user operations'
        'team:team operations'
        'workspace:workspace operations'
        'status:show status'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--api-token=+[token]:str:' \
        '--project=+[workspace/project]:str:' \
        '--name=+[name]:str:' \
        '--workspace=+[name]:str:' \
        '--mode=+[m]:m:(async sync read-only debug offline)' \
        '--source-files=+[list]:str:' \
        '--tags=+[list]:str:' \
        '--description=+[text]:str:' \
        '--with-id=+[id]:str:' \
        '--monitoring-namespace=+[name]:str:' \
        '--flush-period=+[sec]:str:' \
        '-c+[config file]:file:_files -g "*.yaml *.yml *.json *.ini"' \
        '--config=+[file]:file:_files -g "*.yaml *.yml *.json *.ini"' \
        '-f+[format]:f:(json yaml csv table)' \
        '--format=+[format]:f:(json yaml csv table)' \
        '-o+[output file]:file:_files' \
        '--output=+[file]:file:_files' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'neptune-cli subcommand' sub ;;
        args)
            case $words[1] in
                project|run|experiment|model|notebook|artifact|dashboard|user|team|workspace) _arguments '1:op:(list get create update delete stop)' '*:id:' ;;
            esac
            ;;
    esac
}

_neptune-cli "$@"
