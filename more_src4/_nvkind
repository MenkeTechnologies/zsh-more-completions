#compdef nvkind
# Documentation: upstream cmd/nvkind/*.go at github.com/NVIDIA/nvkind
# Reference accessed: 2026-05-30 via gh api inspection of every
# urfave/cli.Command Name:/Usage:/StringFlag/BoolFlag.
# NVIDIA nvkind R68 — create and manage kind clusters with NVIDIA
# GPU support. Single-tree CLI: `cluster` group with 3 subcommands.

local curcontext="$curcontext" state line ret=1

local -a _subcmds _cluster_subs
_subcmds=(
  'cluster:perform operations on cluster with NVIDIA GPUs'
)
_cluster_subs=(
  'list:list all kind clusters (whether they have GPUs on them or not)'
  'create:create a cluster with support for NVIDIA GPUs'
  'print-gpus:print all NVIDIA GPUs available in a cluster'
)

_arguments -C \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  '(-): :->subcmd' \
  '(-)*:: :->subcmd_args' \
  && ret=0

case $state in
  subcmd)
    _describe -t commands 'nvkind subcommand' _subcmds && ret=0
    ;;
  subcmd_args)
    case $words[1] in
      cluster)
        _arguments -C \
          '(-): :->cluster_sub' \
          '(-)*:: :->cluster_sub_args' && ret=0
        case $state in
          cluster_sub) _describe -t commands 'nvkind cluster subcommand' _cluster_subs && ret=0 ;;
          cluster_sub_args)
            case $words[1] in
              create)
                _arguments -s -S \
                  '--name=[name of the cluster to create (default nvkind-<random>)]:name:' \
                  '--image=[node docker image to use for booting the cluster]:image:' \
                  '--retain[retain nodes for debugging when cluster creation fails]' \
                  '--wait=[wait for control plane node to be ready]:duration:' \
                  '--config-template=[path to a custom kind config template]:file:_files' \
                  '--config-values=[path to a values file to fill in template variables]:file:_files' \
                  '--kubeconfig=[absolute path to the KUBECONFIG file]:file:_files' \
                  '--skip-gpu-setup[skip GPU node setup even if GPUs are present]' \
                  && ret=0
                ;;
              print-gpus)
                _arguments -s -S \
                  '--name=[the name of the cluster to print GPUs for]:name:' \
                  '--kubeconfig=[absolute path to the KUBECONFIG file]:file:_files' \
                  && ret=0
                ;;
              list)
                _arguments '--help[show help]' && ret=0
                ;;
            esac
            ;;
        esac
        ;;
    esac
    ;;
esac

return ret
