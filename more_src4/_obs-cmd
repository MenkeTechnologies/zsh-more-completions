#compdef obs-cmd
# Documentation: source-direct extraction from upstream
# grigio/obs-cmd src/cli.rs clap-derive structs
# (`#[derive(Parser)] pub struct Cli` + 16 `#[derive(Subcommand)]`
# enums).  Enum variant names CamelCase -> kebab-case via clap's
# default `to_kebab_case()` rename rule.
# Reference accessed: 2026-05-30 via gh api.
# grigio obs-cmd R167 — OBS WebSocket v5 CLI client.  The
# canonical headless OBS Studio remote-control tool on Wayland
# Linux (where OBS's native UI scripting is constrained) and
# the de-facto bridge for REAPER/Keyboard-Maestro/HyperKey
# integrations.  Sister tool to the already-covered obs/
# obs-studio/obs-cli stack and the streamlink/yt-dlp media-
# capture family.

local -a top_cmds=(
  'info:get OBS Studio version + WebSocket info'
  'scene:scene-related subcommands'
  'scene-collection:scene-collection subcommands'
  'profile:OBS profile subcommands'
  'video-settings:get/set video output settings'
  'stream-service:get/set the streaming service config'
  'record-directory:get/set the recording output directory'
  'replay:replay-buffer subcommands'
  'virtual-camera:virtual-camera subcommands'
  'streaming:streaming start/stop/status/toggle'
  'recording:recording start/stop/status/pause/resume/chapter'
  'save-screenshot:write a screenshot of a source to file'
  'audio:run an audio command on a device'
  'filter:run a filter command on a source filter'
  'scene-item:scene-item (source-in-scene) subcommands'
  'list-hotkeys:list all OBS hotkeys'
  'trigger-hotkey:trigger a named OBS hotkey'
  'fullscreen-projector:open a fullscreen program-output projector'
  'source-projector:open a fullscreen source projector'
  'media-input:media-input set-cursor/play/pause/stop/restart'
  'input:input list/create/remove/rename/settings/volume/mute/...'
  'completion:emit a shell-completion script'
)

_arguments -C \
  '(-w --websocket)'{-w+,--websocket=}'[OBS WebSocket URL (obsws://host:port/password)]:url:' \
  '(-h --help)'{-h,--help}'[print help]' \
  '(-V --version)'{-V,--version}'[print version]' \
  '1: :->cmd' \
  '*:: :->sub'

case $state in
  cmd)
    _describe -t commands 'obs-cmd subcommand' top_cmds
    ;;
  sub)
    case $words[1] in
      scene)
        _arguments -C ':scene action:((
          current\:get\ current\ program\ scene
          switch\:switch\ program\ scene\ to\ named
          list\:list\ all\ scenes
          create\:create\ a\ new\ scene
          remove\:remove\ a\ scene
          rename\:rename\ a\ scene
          transition-list\:list\ all\ transitions
          transition-current\:get\ current\ transition
          transition-set\:set\ current\ transition
          transition-duration\:set\ transition\ duration\ ms
          transition-trigger\:trigger\ a\ studio-mode\ transition
          studio-mode-status\:report\ studio\ mode\ status
          studio-mode-enable\:enable\ studio\ mode
          studio-mode-disable\:disable\ studio\ mode
          studio-mode-toggle\:toggle\ studio\ mode
          studio-mode-transition\:trigger\ studio-mode\ transition
          preview-current\:get\ current\ preview\ scene
          preview-set\:set\ preview\ scene
        ))' \
          '*::arg:'
        ;;
      scene-collection)
        _values 'scene-collection action' current list create switch
        ;;
      profile)
        _values 'profile action' current list create remove switch
        ;;
      video-settings)
        _arguments -C ':video-settings action:(get set)' \
          '--base-width=[base canvas width]:px:' \
          '--base-height=[base canvas height]:px:' \
          '--output-width=[output width]:px:' \
          '--output-height=[output height]:px:' \
          '--fps-num=[fps numerator]:n:' \
          '--fps-den=[fps denominator]:n:'
        ;;
      stream-service)
        _arguments -C ':stream-service action:(get set)' \
          '--service-type=[streaming service type]:type:' \
          '--server=[server URL]:url:' \
          '--key=[stream key]:key:'
        ;;
      record-directory)
        _values 'record-directory action' get set
        ;;
      replay)
        _values 'replay-buffer action' start stop toggle save status last-replay
        ;;
      virtual-camera)
        _values 'virtual-camera action' start stop toggle
        ;;
      streaming)
        _values 'streaming action' start stop status toggle
        ;;
      recording)
        _values 'recording action' start stop toggle status status-active pause resume toggle-pause create-chapter
        ;;
      save-screenshot)
        _arguments \
          '1:source name:' \
          '2:image format (png|jpg|...):(png jpg jpeg bmp)' \
          '3:file path:_files' \
          '--width=[width]:px:' \
          '--height=[height]:px:' \
          '--compression-quality=[compression quality]:n:'
        ;;
      audio)
        _arguments \
          '1:audio command:' \
          '2:device name:'
        ;;
      filter)
        _arguments \
          '1:filter command:' \
          '2:source name:' \
          '3:filter name:'
        ;;
      scene-item)
        _values 'scene-item action' list create remove duplicate enable disable toggle lock unlock get-transform set-transform get-index set-index get-blend-mode set-blend-mode
        ;;
      trigger-hotkey)
        _arguments '1:hotkey name:'
        ;;
      fullscreen-projector)
        _arguments '--monitor-index=[monitor index (default 0)]:n:'
        ;;
      source-projector)
        _arguments \
          '1:source name:' \
          '--monitor-index=[monitor index (default 0)]:n:'
        ;;
      media-input)
        _values 'media-input action' set-cursor play pause stop restart
        ;;
      input)
        _values 'input action' list list-kinds create remove rename settings volume mute audio-balance audio-sync-offset audio-monitor-type audio-tracks default-settings specials
        ;;
      completion)
        _arguments '1:shell:(bash elvish fish powershell zsh)'
        ;;
    esac
    ;;
esac
