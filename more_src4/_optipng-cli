#compdef optipng-cli
# _optipng-cli — Cosmin Truta OptiPNG PNG optimizer CLI alias (optipng team, C); custom argparse
# upstream: https://sourceforge.net/projects/optipng/

_optipng-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-?[show help]' \
        '-backup[backup original]' \
        '-clobber[overwrite]' \
        '-debug[debug]' \
        '-fix[fix incorrect images]' \
        '-force[force optimization]' \
        '-full[full report]' \
        '-keep[same as backup]' \
        '-log+[log file]:file:_files' \
        '-no-bit-depth-reduction[no bit depth reduction]' \
        '-no-color-type-reduction[no color type reduction]' \
        '-no-create[no create]' \
        '-no-out[no save output]' \
        '-no-palette-reduction[no palette reduction]' \
        '-no-reductions[no reductions]' \
        '-out+[output file]:file:_files -g "*.png"' \
        '-preserve[preserve attributes]' \
        '-quiet[quiet]' \
        '-q[quiet]' \
        '-snip[cut one image out of multi-image file]' \
        '-strip=+[chunks]:m:(all)' \
        '-verbose[verbose]' \
        '-v[verbose]' \
        '-o+[optimization level 0-7]:n:' \
        '-i+[interlace 0|1]:n:' \
        '-f+[filter 0-5]:n:' \
        '-zc+[zlib compression level]:n:' \
        '-zm+[zlib memory level]:n:' \
        '-zs+[zlib strategy 0-3]:n:' \
        '-zw+[zlib window size]:str:' \
        '-paranoid[paranoid]' \
        '-zonly[zlib only]' \
        '*:files:_files -g "*.{png,PNG,bmp,gif,pnm,tiff}"'
}

_optipng-cli "$@"
