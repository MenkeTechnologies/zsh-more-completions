#compdef makedbz
# Documentation: man makedbz(8)
# Source: InterNetNews/inn expire/makedbz.c — rebuild dbz history index (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-f+[text history file]:file:_files' \
    '-s+[expected database size]:size:_default' \
    '-i[ignore old database, build new]' \
    '-o[overwrite existing files]' \
    && ret=0

return ret
