#compdef nvr
# Documentation: https://github.com/mhinz/neovim-remote
# Reference accessed: 2026-05-19
# Verified: upstream README documents the flags listed below.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '--serverlist[list addresses of running nvim processes]' \
  '--servername=[connect to a specific server]:address' \
  '-cc+[execute command before other options]:command' \
  '-c+[execute command after other options]:command' \
  '-d[enable diff mode]' \
  '-l[change to previous window]' \
  '-o+[open files via :split]:*:file:_files' \
  '-O+[open files via :vsplit]:*:file:_files' \
  '-p+[open files via :tabedit]:*:file:_files' \
  '-t+[jump to tag location]:tag' \
  '-q+[load errorfile into quickfix]:file:_files' \
  '--remote[open files with :edit]' \
  '--remote-wait[open and block until buffers deleted]' \
  '--remote-silent[open without error if no server]' \
  '--remote-wait-silent[open, wait, silence errors]' \
  '--remote-tab[open files with :tabedit]' \
  '--remote-tab-wait[open in tabs and wait]' \
  '--remote-tab-silent[open in tabs silently]' \
  '--remote-tab-wait-silent[open in tabs, wait, silence]' \
  '--remote-send=[send key sequences]:keys' \
  '--remote-expr=[evaluate expression]:expression' \
  '--nostart[do not start nvim if none found]' \
  '-s[silence "no server found" message]' \
  '*:file:_files' && ret=0

return ret
