#compdef primer3
# Documentation: https://primer3.org/manual.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.
# Notes: primer3 manual allows either single- or double-dash forms and either
# `=` or space separators; --io_version only legal value is 4.

# primer3: PCR primer/probe design (Boulder-IO format on stdin)
local curcontext="$curcontext" ret=1
_arguments -C \
  '--about[print release info]' \
  '--default_version=[input default format version]:n:(1 2)' \
  '--format_output[user-oriented output]' \
  '--strict_tags[unrecognized tags fatal]' \
  '--p3_settings_file=[settings file]:file:_files' \
  '--echo_settings_file[echo settings tags]' \
  '--io_version=[Boulder-IO version (4 only)]:n:(4)' \
  '--output=[output file]:file:_files' \
  '--error=[error file]:file:_files' \
  '*:input boulder-IO file:_files' && ret=0
return ret
