#compdef nsd-checkzone
# Documentation: https://manpages.debian.org/bookworm/nsd/nsd-checkzone.8.en.html
# Reference accessed: 2026-05-16
# Verified: Debian bookworm nsd-checkzone(8) manpage.

# nsd-checkzone: NSD zone file syntax checker
local curcontext="$curcontext" ret=1
_arguments -C \
  '-h[show help]' \
  '-p[print zone contents to stdout if ok]' \
  '-i[old zone file for IXFR generation]:file:_files' \
  '-n[max IXFR versions to store (default 5)]:n:' \
  '-s[max bytes for IXFR storage (default 1048576)]:bytes:' \
  '1:zone name:' \
  '2:zone file:_files' && ret=0
return ret
