#compdef pywal16 wal
# _pywal16 — 16-color pywal fork generating colorschemes from images (eylles/pywal16)
# upstream: https://github.com/eylles/pywal16
# Flags from pywal/__main__.py (argparse).

_pywal16() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)-v[show version]' \
        '-a+[alpha (terminal bg transparency 0-100)]:n:' \
        '-b+[custom background color]:color:' \
        '--fg=[custom foreground color]:color:' \
        '--backend=[color backend]:backend:(wal colorz colorthief haishoku schemer2 fast_colorthief)' \
        '--out-dir=[cache/export directory]:dir:_files -/' \
        '(-f --theme)'{-f+,--theme=}'[theme name or file]:theme:' \
        '--iterative[iterate over images in a directory]' \
        '--recursive[recurse subdirectories]' \
        '--saturate=[set color saturation -1.0..1.0]:f:' \
        '--preview[preview generated colorscheme]' \
        '--vte[fix VTE terminal palette]' \
        '-c[delete all cached colorschemes]' \
        '-i+[input image or directory]:file:_files' \
        '-l[generate a light colorscheme]' \
        '-n[skip setting the wallpaper]' \
        '-o+[external script to run]:cmd:_command_names -e' \
        '-p+[set palette name]:name:' \
        '-q[quiet mode]' \
        '-r[restore previous colorscheme (compat)]' \
        '-R[restore previous colorscheme]' \
        '-s[skip changing terminal colors]' \
        '-t[skip changing tty colors]' \
        '-w[use last used image]' \
        '-e[skip wallpaper reload]' \
        '--contrast=[contrast value]:f:'
}

_pywal16 "$@"
