#compdef mautrix-bluesky
# _mautrix-bluesky — Matrix↔Bluesky puppeting bridge (mautrix/bluesky)
# upstream: https://github.com/mautrix/bluesky
# Flags from mautrix/go bridgev2/matrix/mxmain/main.go (shared across mautrix bridges).

_mautrix-bluesky() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '--version-json[print version as JSON]' \
        '(-c --config)'{-c+,--config=}'[config file path]:file:_files -g "*.(yml|yaml)"' \
        '(-e --generate-example-config)'{-e,--generate-example-config}'[save example config and quit]' \
        '(-n --no-update)'{-n,--no-update}'[do not save updated config to disk]' \
        '(-r --registration)'{-r+,--registration=}'[appservice registration path]:file:_files -g "*.(yml|yaml)"' \
        '(-g --generate-registration)'{-g,--generate-registration}'[generate registration and quit]' \
        '--ignore-unsupported-database[run even if DB schema is too new]' \
        '--ignore-foreign-tables[run even if DB contains tables from other programs]' \
        '--ignore-unsupported-server[run even if Matrix homeserver is outdated]'
}

_mautrix-bluesky "$@"
