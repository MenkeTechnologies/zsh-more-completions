#compdef phonopy
# phonopy — phonon calculation and analysis package

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)--version[show version]' \
  '-d[create displacements]' \
  '-f[calculate force constants from forces]:force files:_files' \
  '--fc[read force constants from file]:file:_files' \
  '-p[plot band structure or DOS]' \
  '-s[save plot to file]' \
  '--pdos[calculate projected DOS]:atom indices:' \
  '--mesh[sampling mesh]:mesh (e.g. 8 8 8):' \
  '--band[band path]:band path:' \
  '--band-labels[labels for band points]:labels:' \
  '--dim[supercell dimension]:dimensions (e.g. 2 2 2):' \
  '--pa[primitive axis]:axes:' \
  '--mp[Monkhorst-Pack mesh]:mesh:' \
  '--tmin[minimum temperature]:temperature:' \
  '--tmax[maximum temperature]:temperature:' \
  '--tstep[temperature step]:step:' \
  '--sigma[smearing width]:sigma:' \
  '--tolerance[symmetry tolerance]:tolerance:' \
  '--nac[non-analytical term correction]' \
  '--born[Born effective charges file]:file:_files' \
  '-c[crystal structure file]:file:_files' \
  '--qpoints[q-points]:q-points:' \
  '--anime[create animation]:q-points:' \
  '--modulation[create modulated structure]:q-point:' \
  '--irreps[show irreducible representations]:q-point:' \
  '--show-irreps[show full irreducible representations]:q-point:' \
  '--writedm[write dynamical matrix]' \
  '--writefc[write force constants]' \
  '--readfc[read force constants]' \
  '-v[verbose output]' \
  '-q[quiet mode]' \
  '*:configuration file:_files -g "*.conf"'
