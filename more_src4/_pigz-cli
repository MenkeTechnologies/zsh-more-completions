#compdef pigz-cli unpigz
# _pigz-cli — Mark Adler pigz parallel implementation of gzip CLI alias (madler team, C); custom argparse
# upstream: https://github.com/madler/pigz

_pigz-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--alias=+[name]:str:' \
        '-A+[name]:str:' \
        '--blocksize=+[kbytes]:n:' \
        '-b+[kbytes]:n:' \
        '--comment=+[comment]:str:' \
        '-C+[comment]:str:' \
        '--decompress[decompress]' \
        '-d[decompress]' \
        '--force[force overwrite]' \
        '-f[force overwrite]' \
        '--first[force first level]' \
        '-F[force first level]' \
        '--huffman[huffman only]' \
        '-H[huffman only]' \
        '--independent[independent blocks]' \
        '-i[independent blocks]' \
        '--iterations=+[count]:n:' \
        '-I+[count]:n:' \
        '--keep[keep input files]' \
        '-k[keep input files]' \
        '--license[show license]' \
        '-L[show license]' \
        '--list[list info]' \
        '-l[list info]' \
        '--maxsplits=+[count]:n:' \
        '-M+[count]:n:' \
        '--no-name[no name]' \
        '-n[no name]' \
        '--name[save name and time]' \
        '-N[save name and time]' \
        '--oneblock[one block]' \
        '-O[one block]' \
        '--processes=+[count]:n:' \
        '-p+[count]:n:' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--rsyncable[rsyncable]' \
        '-R[rsyncable]' \
        '--recursive[recursive]' \
        '-r[recursive]' \
        '--suffix=+[suffix]:str:' \
        '-S+[suffix]:str:' \
        '--synchronous[synchronous]' \
        '-Y[synchronous]' \
        '--stdout[output to stdout]' \
        '-c[output to stdout]' \
        '--test[test integrity]' \
        '-t[test integrity]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--fast[fast compression]' \
        '-1[fast compression]' \
        '-2[level 2]' \
        '-3[level 3]' \
        '-4[level 4]' \
        '-5[level 5]' \
        '-6[level 6]' \
        '-7[level 7]' \
        '-8[level 8]' \
        '-9[best compression]' \
        '-11[zopfli compression]' \
        '--zip[zip format]' \
        '-K[zip format]' \
        '--zlib[zlib format]' \
        '-z[zlib format]' \
        '*:files:_files'
}

_pigz-cli "$@"
