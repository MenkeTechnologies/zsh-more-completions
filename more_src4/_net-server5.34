#compdef net-server5.34
# Documentation: https://metacpan.org/dist/Net-Server/view/bin/net-server
# Reference accessed: 2026-05-19
# Verified: Net::Server CPAN distribution's net-server bin POD lists the
# accepted Net::Server flavor as the optional first argument; remaining
# arguments are key/value pairs (e.g. ipv '*', port 80, app foo.cgi).

local curcontext="$curcontext" state line ret=1

_arguments -s \
  '1:server flavor:(Fork PreFork PreForkSimple INET MultiType SIG Single HTTP PSGI Thread)' \
  '*:: :_default' && ret=0

return ret
