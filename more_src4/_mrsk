#compdef mrsk kamal
# Documentation: https://kamal-deploy.org/docs/commands/view-all-commands/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Kamal (formerly MRSK) deploy CLI.

local curcontext="$curcontext" state line ret=1

local -a commands=(
  'deploy:deploy app to servers'
  'redeploy:deploy without bootstrapping, proxy setup, pruning, or registry login'
  'rollback:rollback to a specific version'
  'details:show container information'
  'setup:setup accessories, push env, and deploy app'
  'audit:show audit log from servers'
  'config:show combined config'
  'init:create config stub'
  'remove:remove proxy, app, accessories, and registry session'
  'version:show Kamal version'
  'accessory:manage accessories (db/redis/search)'
  'app:manage application'
  'build:build application image'
  'env:manage environment variables'
  'healthcheck:manage healthchecks'
  'lock:manage deploy lock'
  'prune:prune old images and containers'
  'registry:login/logout container registry'
  'server:bootstrap servers with curl and Docker'
  'proxy:manage kamal-proxy'
  'secrets:extract secrets helpers'
  'docs:show documentation'
  'help:describe commands'
)

_arguments -s -S \
  '(-v --verbose)'{-v,--verbose}'[detailed logging]' \
  '(-q --quiet)'{-q,--quiet}'[minimal logging]' \
  '--version=[run against specific app version]:version:' \
  '(-p --primary)'{-p,--primary}'[run only on primary host]' \
  '(-h --hosts)'{-h+,--hosts=}'[run on specific hosts (comma/wildcards)]:hosts:' \
  '(-r --roles)'{-r+,--roles=}'[run on specific roles]:roles:' \
  '(-c --config-file)'{-c+,--config-file=}'[path to config file]:file:_files -g "*.yml"' \
  '(-d --destination)'{-d+,--destination=}'[specify destination for config file]:destination:' \
  '(-H --skip-hooks)'{-H,--skip-hooks}'[do not run hooks]' \
  '1:command:->command' \
  '*::args:->args' && ret=0

case "$state" in
  command)
    _describe -t commands 'kamal command' commands && ret=0
    ;;
esac

return ret
