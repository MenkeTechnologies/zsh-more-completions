#compdef paperless
# Documentation: https://github.com/paperless-ngx/paperless-ngx
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above. There is no `paperless`
# binary; the CLI is the Django manage.py wrapper. Subcommands listed
# below are from src/documents/management/commands/.

# paperless: Django manage.py wrapper for paperless-ngx
local curcontext="$curcontext" ret=1
local -a commands
commands=(
  'document_consumer:run the document consumer'
  'document_exporter:export documents and metadata'
  'document_importer:import previously exported documents'
  'document_archiver:re-create archive files'
  'document_index:reindex or rebuild Whoosh index'
  'document_renamer:rename documents per filename format'
  'document_retagger:re-apply matching rules'
  'document_thumbnails:regenerate thumbnails'
  'document_create_classifier:train ML classifier'
  'document_fuzzy_match:find near-duplicate documents'
  'document_sanity_checker:sanity-check document storage'
  'decrypt_documents:decrypt encrypted documents'
  'convert_mariadb_uuid:convert UUID columns for MariaDB'
  'manage_superuser:create/update the admin user'
  'prune_audit_logs:prune old audit log entries'
  'loaddata_stdin:loaddata from stdin'
)
_arguments -C \
  '--help[show help]' \
  '1:command:->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'paperless command' commands && ret=0 ;;
esac
return ret
