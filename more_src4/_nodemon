#compdef nodemon
# Documentation: https://github.com/remy/nodemon
# Source: remy/nodemon — automatic Node.js dev-server restart on file change.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-v,--version}'[show version]' \
    '--inspect[pass --inspect to Node.js]' \
    '*--watch=[directory or file to watch]:path:_files' \
    '*'{-e,--ext=}'[file extensions to watch (comma-separated)]:ext:' \
    '*--ignore=[file/pattern to exclude]:glob:_files' \
    '--config=[config file location]:file:_files' \
    '(-L --legacy-watch)'{-L,--legacy-watch}'[poll for file changes (NFS-friendly)]' \
    '--delay=[throttle delay before restart (ms or 2.5s)]:duration:' \
    '--signal=[signal sent to the app on restart]:sig:(SIGHUP SIGINT SIGUSR2 SIGTERM SIGKILL)' \
    '--exec=[executable for non-Node scripts]:exec:_command_names -e' \
    '--no-stdin[do not forward stdin to child]' \
    '--verbose[verbose output]' \
    '-q[quiet]' \
    '--exitcrash[exit on crash instead of restarting]' \
    '-x[execute script]:script:_files' \
    '*:script or args:_files' \
    && ret=0

return ret
