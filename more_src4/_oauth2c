#compdef oauth2c
# Documentation: https://github.com/cloudentity/oauth2c
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# Zsh completion for oauth2c OAuth2 CLI (cloudentity/oauth2c)

local curcontext="$curcontext" ret=1

_oauth2c_issuer() {
  local -a commands=(
    'version:print CLI build metadata'
    'docs:print markdown documentation'
  )
  _describe -t commands 'oauth2c command' commands
  _files -g '*.json'
  _urls
}

_arguments -s -S \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-s --silent)'{-s,--silent}'[silent / non-interactive]' \
  '--no-browser[do not open system browser]' \
  '--no-prompt[disable interactive prompts]' \
  '--no-origin[omit Origin header]' \
  '--insecure[skip TLS verification]' \
  '--http-timeout[HTTP client timeout]:duration' \
  '--browser-timeout[browser wait timeout]:duration' \
  '--redirect-url[OAuth redirect URL]:url' \
  '--client-id[client identifier]:id' \
  '--client-secret[client secret]:secret' \
  '--grant-type[OAuth grant type]:grant' \
  '--auth-method[token endpoint auth method]:method' \
  '--username[ROPC username]:user' \
  '--password[ROPC password]:pass' \
  '--refresh-token[refresh token]:token' \
  '*--response-types[OIDC response types]:type' \
  '--response-mode[OIDC response mode]:mode' \
  '*--scopes[requested scopes]:scope' \
  '*--audience[resource server audience]:aud' \
  '--pkce[enable PKCE]' \
  '--par[enable Pushed Authorization Requests]' \
  '--request-object[send request as signed JWT]' \
  '--encrypted-request-object[send encrypted request object]' \
  '--assertion[JWT bearer assertion claims]:json' \
  '--signing-key[JWKS signing key path or URL]:uri:_files' \
  '--encryption-key[JWKS encryption key path or URL]:uri:_files' \
  '--subject-token[token exchange subject token]:token' \
  '--subject-token-type[subject token type]:type' \
  '--actor-token[token exchange actor token]:token' \
  '--actor-token-type[actor token type]:type' \
  '--id-token-hint[OIDC id_token_hint]:jwt' \
  '--login-hint[login hint]:hint' \
  '--idp-hint[IdP hint]:hint' \
  '--tls-cert[mutual TLS client cert]:file:_files' \
  '--tls-key[mutual TLS client key]:file:_files' \
  '--tls-root-ca[custom TLS trust anchor]:file:_files' \
  '--callback-tls-cert[HTTPS callback cert]:file:_files' \
  '--callback-tls-key[HTTPS callback key]:file:_files' \
  '--callback-addr[callback listener address]:hostport' \
  '--token-endpoint[override token URL]:url' \
  '--authorization-endpoint[override authorize URL]:url' \
  '--device-authorization-endpoint[override device URL]:url' \
  '--pushed-authorization-request-endpoint[override PAR URL]:url' \
  '--mtls-token-endpoint[mTLS token endpoint]:url' \
  '--mtls-pushed-authorization-request-endpoint[mTLS PAR endpoint]:url' \
  '--claims[OIDC claims JSON parameter]:json' \
  '--rar[Rich Authorization Request JSON]:json' \
  '*--acr-values[ACR values]:acr' \
  '--purpose[authorization purpose string]:text' \
  '*--prompt[OIDC prompt values]:value' \
  '--max-age[max authentication age seconds]:secs' \
  '--authentication-code[passwordless auth code]:code' \
  '--dpop[use DPoP sender-constrained tokens]' \
  '1:issuer / config / subcommand:_oauth2c_issuer' && ret=0

return ret
