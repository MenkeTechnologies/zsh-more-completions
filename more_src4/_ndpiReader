#compdef ndpiReader ndpi-reader
# _ndpiReader — ntop nDPI ndpiReader Deep Packet Inspection reference CLI for L7 protocol fingerprinting reading live or pcap-recorded traffic identifying 250+ protocols TLS QUIC HTTP/3 SMB DNS Skype Tor (ntop team, C); getopt
# upstream: https://github.com/ntop/nDPI

_ndpiReader() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v+[verbose level]:n:(0 1 2 3 4)' \
        '-i+[interface or pcap]:str:' \
        '--interface=+[interface or pcap]:str:' \
        '-f+[BPF filter]:str:' \
        '--filter=+[BPF filter]:str:' \
        '-s+[scan duration sec]:n:' \
        '--duration=+[scan duration sec]:n:' \
        '-m+[idle time sec]:n:' \
        '-b+[stat report sec]:n:' \
        '-w+[write pcap]:file:_files -g "*.pcap *.pcapng"' \
        '--write=+[write pcap]:file:_files -g "*.pcap *.pcapng"' \
        '-p+[protocol file]:file:_files -g "*.txt *.protos"' \
        '--protos=+[protocol file]:file:_files -g "*.txt *.protos"' \
        '-c+[category file]:file:_files -g "*.txt"' \
        '--categories=+[category file]:file:_files -g "*.txt"' \
        '-r+[risk file]:file:_files -g "*.txt"' \
        '-q[quiet]' \
        '-d+[dissect]' \
        '--quiet[quiet]' \
        '-e+[CSV out]:file:_files -g "*.csv"' \
        '-S+[stats file]:file:_files' \
        '-l+[loglevel]:l:(0 1 2 3 4 5)' \
        '--loglevel=+[level]:l:(0 1 2 3 4 5)' \
        '-o+[output file]:file:_files' \
        '-j+[json file]:file:_files -g "*.json"' \
        '--json=+[json file]:file:_files -g "*.json"' \
        '-A[stop on unknown protocol]' \
        '-x+[xml file]:file:_files -g "*.xml"' \
        '-T+[trace level]:n:' \
        '-n+[N threads]:n:' \
        '*:input file:_files -g "*.pcap *.pcapng *.cap"'
}

_ndpiReader "$@"
