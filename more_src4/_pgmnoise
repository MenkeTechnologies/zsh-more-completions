#compdef pgmnoise
# Documentation: man pgmnoise (Netpbm)
# Source: generate a white-noise PGM image of the given dimensions.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxval=[max sample value]:n:' \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:width:' \
    '2:height:' \
    && ret=0

return ret
