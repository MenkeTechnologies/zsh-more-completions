#compdef pgmmorphconv
# Documentation: man pgmmorphconv (Netpbm)
# Source: apply a morphological-convolution operator to a PGM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-erode -dilate -open -close -gradient)-erode[morphological erosion]' \
    '(-erode -dilate -open -close -gradient)-dilate[morphological dilation]' \
    '(-erode -dilate -open -close -gradient)-open[morphological opening (erode then dilate)]' \
    '(-erode -dilate -open -close -gradient)-close[morphological closing (dilate then erode)]' \
    '(-erode -dilate -open -close -gradient)-gradient[morphological gradient]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:template file:_files -g "*.(pgm|pnm|pam)"' \
    '2:pgm file:_files -g "*.(pgm|pnm|pam)"' \
    && ret=0

return ret
