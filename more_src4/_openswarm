#compdef openswarm
# Documentation: https://github.com/VRSEN/OpenSwarm
# Reference accessed: 2026-05-22
# Verified: bin/openswarm delegates to @vrsen/agentswarm with passthrough argv.

# Zsh completion for openswarm - OpenSwarm multi-agent TUI launcher

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '*:argument:' && ret=0

return ret
