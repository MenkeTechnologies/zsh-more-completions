#compdef ocsptool
# Documentation: ocsptool --help (GnuTLS OCSP tool)
# Source: query and parse OCSP requests/responses.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-\!,--more-help}'[extended help via pager]' \
    '(- *)'{-v-,--version=-}'[show version]::level:(v c n)' \
    {-d+,--debug=}'[debug level 0-9999]:level:' \
    {-V,--verbose}'[more verbose output]' \
    '--infile=[input file]:file:_files' \
    '--outfile=[output file]:file:_files' \
    '--ask=-[ask OCSP server about certificate]::host:_hosts' \
    {-e,--verify-response}'[verify response]' \
    {-i,--request-info}'[print OCSP request info]' \
    {-j,--response-info}'[print OCSP response info]' \
    {-q,--generate-request}'[generate an OCSP request]' \
    '--nonce[use nonce in OCSP request]' \
    '--no-nonce[do not use nonce]' \
    '--load-chain=[certificate chain]:file:_files' \
    '--load-issuer=[issuer certificate]:file:_files' \
    '--load-cert=[certificate to check]:file:_files' \
    '(--load-signer)--load-trust=[OCSP trust anchors]:file:_files' \
    '(--load-trust)--load-signer=[OCSP response signer]:file:_files' \
    '--load-request=[OCSP request file]:file:_files' \
    '--load-response=[OCSP response file]:file:_files' \
    '--inder[input is DER]' \
    '--outder[output as DER]' \
    '--outpem[output as PEM]' \
    '--ignore-errors[ignore errors when verifying]' \
    '--port=[port for --ask]:port:_ports' \
    && ret=0

return ret
