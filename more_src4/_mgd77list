#compdef mgd77list
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77list.html
# Source: GenericMappingTools/gmt supplements/mgd77 — extract data records from MGD77 cruise files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-F+[comma-sep abbreviations + logic + bittests]:cols:_default' \
    '-A+[apply corrections (c/d/f/m/t code)]:opts:_default' \
    '-D+[date range (a=start, b=stop)]:opts:_default' \
    '-E[require exact match of all columns]' \
    '-G+[record-number range (a/b)]:opts:_default' \
    '-I+[ignore file formats]:formats:(a c m t)' \
    '-L+[apply optimal correction table]:file:_files' \
    '-N+[distance/speed units]:opts:_default' \
    '-Q+[filter by azimuth/course/velocity]:opts:_default' \
    '-R+[region west/east/south/north]:region:_default' \
    '-S+[distance-along-track range (a/b)]:opts:_default' \
    '-T+[disable auto correction adjustments]:what:(m e)' \
    '*-V[verbose (stackable)]' \
    '-W+[data weight]:value:_default' \
    '-Z+[depth sign convention]:sign:(n p)' \
    '-bo+[binary output format]:format:_default' \
    '-h+[header records]:n:_default' \
    '-j+[distance computation mode]:mode:_default' \
    '*:GEODAS-ID:_default' \
    && ret=0

return ret
