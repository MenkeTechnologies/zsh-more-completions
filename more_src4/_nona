#compdef nona
# Documentation: https://manpages.debian.org/bookworm/hugin-tools/nona.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-v[quiet, no progress indicators]' \
  '-d[detailed output for GPU processing]' \
  '-g[remap on the GPU]' \
  '-c[create coordinate images (TIFF_m only)]' \
  '-o+[output prefix]:prefix:' \
  '-i+[remap only the image with this number]:n:' \
  '-m+[output format]:fmt:(TIFF TIFF_m TIFF_multilayer EXR EXR_m JPEG JPEG_m PNG PNG_m)' \
  '-r+[output mode]:mode:(ldr hdr)' \
  '-e+[exposure for ldr mode]:val:' \
  '-p+[pixel type]:type:(UINT8 UINT16 INT16 UINT32 INT32 FLOAT)' \
  '(-z --compression)'{-z+,--compression=}'[TIFF compression or JPEG quality]:val:(NONE PACKBITS LZW DEFLATE)' \
  '--ignore-exposure[do not correct exposure]' \
  '--save-intermediate-images[preserve intermediate images]' \
  '--intermediate-suffix=[custom suffix for intermediate files]:suffix:' \
  '--create-exposure-layers[create all exposure layers]' \
  '--clip-exposure=[mask dark/bright pixels with optional lower:upper]:range:' \
  '*:pto_file:_files -g "*.pto"' && ret=0

return ret
