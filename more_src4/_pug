#compdef pug
# Documentation: https://github.com/leg100/pug
# Reference accessed: 2026-05-20
# Verified: upstream pug README/help output.

# pug: terraform/tofu/terragrunt task runner TUI

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[print version]' \
  '(-p --program)'{-p+,--program=}'[default program (terraform/tofu/terragrunt)]:program:(terraform tofu terragrunt)' \
  '(-w --workdir)'{-w+,--workdir=}'[working directory containing modules]:dir:_directories' \
  '(-t --max-tasks)'{-t+,--max-tasks=}'[max number of parallel tasks]:n:' \
  '--data-dir=[directory in which to store plan files]:dir:_directories' \
  '(-e --env)*'{-e+,--env=}'[environment variable to pass to terraform process]:env:' \
  '(-a --arg)*'{-a+,--arg=}'[CLI arg to pass to terraform process]:arg:' \
  '(-d --debug)'{-d,--debug}'[log bubbletea messages to messages.log]' \
  '(-c --config)'{-c+,--config=}'[path to config file]:file:_files' \
  '--disable-reload-after-apply[disable automatic state reload following an apply]' \
  '(-l --log-level)'{-l+,--log-level=}'[logging level]:level:(info debug error warn)' && return 0
