#compdef meson-dist
# _meson-dist — Meson build system meson-dist distribution tarball CLI alias (Meson team / Jussi Pakkanen, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-dist() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-C+[build dir]:dir:_files -/' \
        '--allow-dirty[allow dirty source]' \
        '--formats=+[archive formats]:f:(xztar gztar zip)' \
        '--include-subprojects[include subprojects]' \
        '--no-tests[no tests]' \
        '*:arg:'
}

_meson-dist "$@"
