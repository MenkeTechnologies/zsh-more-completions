#compdef phdiinfo
# Documentation: https://github.com/libyal/libphdi
# Source: libyal/libphdi manuals/phdiinfo.1 — display info about a Parallels Hard Disk Image (.hdd / .hds).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-h[show help]' \
    '-v[verbose output to stderr]' \
    '-V[print version]' \
    '*:Parallels HDD image:_files' \
    && ret=0

return ret
