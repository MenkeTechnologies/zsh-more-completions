#compdef magento-cli
# _magento-cli — Adobe Magento Commerce bin/magento CLI alias (magento team, PHP); symfony console
# upstream: https://github.com/magento/magento2

_magento-cli() {
    local -a sub=(
        'cache:clean:clean cache'
        'cache:flush:flush cache'
        'cache:disable:disable cache'
        'cache:enable:enable cache'
        'cache:status:show cache status'
        'admin:user:create:create admin user'
        'admin:user:unlock:unlock admin user'
        'app:config:dump:dump config'
        'app:config:import:import config'
        'app:config:status:show config status'
        'config:set:set config value'
        'config:show:show config value'
        'config:sensitive:set:set sensitive config'
        'cron:install:install cron jobs'
        'cron:remove:remove cron jobs'
        'cron:run:run cron jobs'
        'customer:hash:upgrade:upgrade customer hash'
        'deploy:mode:set:set deploy mode'
        'deploy:mode:show:show deploy mode'
        'dev:di:info:show DI info'
        'dev:profiler:disable:disable profiler'
        'dev:profiler:enable:enable profiler'
        'dev:query-log:disable:disable query log'
        'dev:query-log:enable:enable query log'
        'dev:source-theme:deploy:deploy source theme'
        'dev:template-hints:disable:disable template hints'
        'dev:template-hints:enable:enable template hints'
        'dev:tests:run:run tests'
        'dev:urn-catalog:generate:generate URN catalog'
        'dev:xml:convert:convert xml'
        'i18n:collect-phrases:collect phrases'
        'i18n:pack:pack translations'
        'i18n:uninstall:uninstall translations'
        'indexer:info:show indexer info'
        'indexer:reindex:reindex'
        'indexer:reset:reset indexer'
        'indexer:set-mode:set indexer mode'
        'indexer:show-mode:show indexer mode'
        'indexer:status:show indexer status'
        'maintenance:allow-ips:allow ips'
        'maintenance:disable:disable maintenance'
        'maintenance:enable:enable maintenance'
        'maintenance:status:show maintenance status'
        'module:disable:disable module'
        'module:enable:enable module'
        'module:status:show module status'
        'module:uninstall:uninstall module'
        'newrelic:create:deploy-marker:create newrelic marker'
        'queue:consumers:list:list consumers'
        'queue:consumers:start:start consumer'
        'sampledata:deploy:deploy sample data'
        'sampledata:remove:remove sample data'
        'sampledata:reset:reset sample data'
        'security:recaptcha:disable-for-user-forgot-password:disable recaptcha user forgot password'
        'security:tfa:disable:disable tfa'
        'security:tfa:providers:list tfa providers'
        'security:tfa:reset:reset tfa'
        'setup:backup:backup setup'
        'setup:config:set:set setup config'
        'setup:cron:run:run setup cron'
        'setup:db-data:upgrade:upgrade db data'
        'setup:db-declaration:generate-patch:generate db patch'
        'setup:db-declaration:generate-whitelist:generate whitelist'
        'setup:db-schema:add-slave:add slave'
        'setup:db-schema:split-quote:split quote tables'
        'setup:db-schema:split-sales:split sales tables'
        'setup:db-schema:upgrade:upgrade db schema'
        'setup:db:status:show db status'
        'setup:di:compile:compile DI'
        'setup:install:install magento'
        'setup:performance:generate-fixtures:generate perf fixtures'
        'setup:rollback:rollback setup'
        'setup:static-content:deploy:deploy static content'
        'setup:store-config:set:set store config'
        'setup:uninstall:uninstall magento'
        'setup:upgrade:upgrade magento'
        'store:list:list stores'
        'store:website:list:list websites'
        'theme:uninstall:uninstall theme'
        'varnish:vcl:generate:generate varnish vcl'
        'completion:dump completion'
        'help:show help'
        'list:list commands'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '--quiet[quiet]' \
        '-q[quiet]' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ansi[ansi]' \
        '--no-ansi[no ansi]' \
        '--no-interaction[no interaction]' \
        '-n[no interaction]' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'magento subcommand' sub ;;
        args)
            case $words[1] in
                module:disable|module:enable|module:uninstall) _arguments \
                    '*:module:' \
                    '--force[force]' \
                    '-f[force]' \
                    '--clear-static-content[clear static content]' \
                    '-c[clear static content]' \
                    '--all[all]' ;;
                indexer:reindex|indexer:set-mode|indexer:reset|indexer:status) _arguments '*:indexer:' ;;
                cache:clean|cache:flush|cache:enable|cache:disable) _arguments '*:cache type:' ;;
                deploy:mode:set) _arguments '1:mode:(default developer production)' '--skip-compilation[skip compilation]' '-s[skip compilation]' ;;
                completion) _arguments '1:shell:(bash zsh fish)' ;;
            esac
            ;;
    esac
}

_magento-cli "$@"
