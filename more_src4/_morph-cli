#compdef morph-cli
# Documentation: https://www.npmjs.com/package/@morphllm/morph-cli
# Reference accessed: 2026-05-23
# Verified: npx @morphllm/morph-cli -h.

# Zsh completion for morph-cli - Morph MCP server (@morphllm/morphmcp)

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --version)'{-v,--version}'[show version]' \
  '--api-key[Morph API key]:key:' \
  '*:allowed directory:_directories' && ret=0

return ret
