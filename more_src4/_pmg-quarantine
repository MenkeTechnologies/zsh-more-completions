#compdef pmgqm pmg-quarantine
# _pmg-quarantine — Proxmox Server Solutions pmgqm Proxmox Mail Gateway quarantine notification and cleanup tool (proxmox team, Perl); custom argparse
# upstream: https://git.proxmox.com/?p=pmg-api.git

_pmg-quarantine() {
    local -a sub=(
        'send:send quarantine notifications'
        'cleanup:clean quarantine database'
        'whitelist:whitelist subcommands'
        'blacklist:blacklist subcommands'
        'stats:show quarantine statistics'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '--verbose[verbose]' \
        '--output-format=+[format]:f:(text json json-pretty)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pmg-quarantine subcommand' sub ;;
        args)
            case $words[1] in
                send) _arguments \
                    '--timespan=+[hours]:n:' \
                    '--receiver=+[receiver]:str:' \
                    '--debug[debug]' ;;
                cleanup) _arguments \
                    '--keep-days=+[N]:n:' \
                    '--purge[purge all]' ;;
                whitelist|blacklist) _arguments '1:cmd:(list add remove)' '*:address:_email_addresses' ;;
            esac
            ;;
    esac
}

_pmg-quarantine "$@"
