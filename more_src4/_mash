#compdef mash
# Documentation: https://github.com/marbl/Mash
# Reference accessed: 2026-05-27
# Verified: upstream marbl/Mash src/mash/mash.cpp (subcommand registration) and src/mash/Command*.cpp (per-subcommand options).

# Zsh completion for mash (fast genome / metagenome distance estimator).

local curcontext="$curcontext" state line ret=1

local -a _mash_subcommands
_mash_subcommands=(
  'sketch:create sketches (reduced representations) of sequences'
  'dist:estimate the distance of sequences or sketches'
  'screen:identify containment of a sketch by query sequences'
  'triangle:estimate a lower-triangular distance matrix'
  'info:display information about sketch files'
  'paste:combine sketch files into a single sketch file'
  'bounds:print Mash error bound table for given sketch parameters'
)

_arguments -C \
  '1: :->cmd' \
  '*:: :->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'mash subcommand' _mash_subcommands && ret=0
    ;;
  args)
    case $line[1] in
      sketch)
        _arguments \
          '-h[show help]' \
          '-l[input files are lists of paths]' \
          '-o+[output sketch prefix]:prefix:' \
          '-I+[sketch ID field]:id:' \
          '-C+[sketch comment field]:comment:' \
          '-M[store k-mer multiplicities (counts)]' \
          '-p+[parallel threads]:threads:' \
          '-k+[k-mer size]:int:' \
          '-n[preserve strand (non-canonical k-mers)]' \
          '-a[use amino acid alphabet]' \
          '-z+[custom alphabet]:alphabet:' \
          '-Z[case-sensitive k-mers]' \
          '-W[windowed sketching mode]' \
          '-L+[window length]:int:' \
          '-s+[sketch size (non-redundant min-hashes)]:int:' \
          '-i[sketch individual sequences instead of whole files]' \
          '-S+[hash seed]:int:' \
          '-w+[k-mer warning probability]:float:' \
          '-r[input is read sets (FASTQ)]' \
          '-b+[bloom filter size (e.g. 1G)]:size:' \
          '-m+[minimum copies of each k-mer]:int:' \
          '-c+[target coverage]:float:' \
          '-g+[genome size estimate]:size:' \
          '*:files:_files' && ret=0
        ;;
      dist)
        _arguments \
          '-h[show help]' \
          '-l[query files are lists of paths]' \
          '-t[output tab-separated table]' \
          '-v+[max p-value to report]:float:' \
          '-d+[max distance to report]:float:' \
          '-C[include comment fields]' \
          '-p+[parallel threads]:threads:' \
          '-k+[k-mer size]:int:' \
          '-s+[sketch size]:int:' \
          '-S+[hash seed]:int:' \
          '-w+[warning probability]:float:' \
          '-r[input is read sets]' \
          '-n[non-canonical k-mers]' \
          '-a[amino acid alphabet]' \
          '-Z[case-sensitive]' \
          '*:files:_files' && ret=0
        ;;
      screen)
        _arguments \
          '-h[show help]' \
          '-p+[parallel threads]:threads:' \
          '-w[winner-takes-all identity strategy]' \
          '-i+[minimum identity threshold (-1..1)]:float:' \
          '-v+[max p-value (0..1)]:float:' \
          '*:files:_files' && ret=0
        ;;
      triangle)
        _arguments \
          '-h[show help]' \
          '-l[input files are lists of paths]' \
          '-E[output edge-list format]' \
          '-C[include comment fields]' \
          '-p+[parallel threads]:threads:' \
          '-k+[k-mer size]:int:' \
          '-s+[sketch size]:int:' \
          '-S+[hash seed]:int:' \
          '*:files:_files' && ret=0
        ;;
      info)
        _arguments \
          '-h[show help]' \
          '-H[show header info only]' \
          '-t[output tab-separated table]' \
          '-d[output sketches as JSON]' \
          '-c[show sketch counts only]' \
          '*:sketch:_files' && ret=0
        ;;
      paste)
        _arguments \
          '-h[show help]' \
          '-l[input files are lists of paths]' \
          '1:output prefix:' \
          '*:sketches:_files' && ret=0
        ;;
      bounds)
        _arguments \
          '-h[show help]' \
          '-k+[k-mer size]:int:' \
          '-p+[p-value cutoff]:float:' && ret=0
        ;;
      *)
        _arguments '*:path:_files' && ret=0
        ;;
    esac
    ;;
esac

return ret
