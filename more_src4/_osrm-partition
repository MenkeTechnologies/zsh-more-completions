#compdef osrm-partition
# Documentation: https://github.com/Project-OSRM/osrm-backend
# Source: Project-OSRM/osrm-backend src/tools/partition.cpp — multi-level Dijkstra graph partitioning.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)--version[show version]' \
    '(- *)--help[show help]' \
    '--list-inputs[list required/optional input file extensions]' \
    '--verbosity=[log verbosity]:level:_default' \
    '(-t --threads)'{-t+,--threads=}'[number of threads]:n:_default' \
    '--balance=[left/right balance for single bisection]:value:_default' \
    '--boundary=[percent of embedded nodes contracted as sources/sinks]:pct:_default' \
    '--optimizing-cuts=[cuts to optimize per bisection]:n:_default' \
    '--small-component-size=[size threshold for small components]:n:_default' \
    '--max-cell-sizes=[max cell sizes per level (comma-separated)]:sizes:_default' \
    '*:input base path:_files -g "*.osrm(-.)"' \
    && ret=0

return ret
