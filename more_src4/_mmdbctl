#compdef mmdbctl
# Documentation: https://github.com/ipinfo/mmdbctl
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1
local -a commands=(
  'read:retrieve data for IPs in an MMDB file'
  'import:convert CSV/TSV/JSON to MMDB'
  'export:convert MMDB to CSV/TSV/JSON'
  'metadata:display MMDB metadata'
  'verify:validate MMDB file integrity'
  'completion:install/get shell autocompletion'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '--nocolor[disable colored output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mmdbctl command' commands && ret=0 ;;
esac
return ret
