#compdef nicotine
# _nicotine — Nicotine+ Soulseek client (nicotine-plus/nicotine-plus)
# upstream: https://github.com/nicotine-plus/nicotine-plus
# Flags from pynicotine/__init__.py (argparse).

_nicotine() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(- *)'{-v,--version}'[show version]' \
        '(-c --config)'{-c+,--config=}'[config file]:file:_files' \
        '(-u --user-data)'{-u+,--user-data=}'[user data folder]:dir:_files -/' \
        '(-s --hidden)'{-s,--hidden}'[start hidden in tray]' \
        '(-b --bindip)'{-b+,--bindip=}'[bind to local IP]:ip:' \
        '(-l --port)'{-l+,--port=}'[listen port]:port:' \
        '(-r --rescan)'{-r,--rescan}'[rescan shares and exit]' \
        '(-n --headless)'{-n,--headless}'[run without GUI]'
}

_nicotine "$@"
