#compdef pip3
# Documentation: https://pip.pypa.io/en/stable/
# Source: pypa/pip src/pip/_internal/commands — Python package manager (Python, click).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-v,--verbose}'[verbose output (stackable)]' \
    {-q,--quiet}'[quiet output (stackable)]' \
    '--log=-[log file]:file:_files' \
    '--isolated[ignore environment variables and user configuration]' \
    '--require-virtualenv[require virtual env]' \
    '--no-color[disable colors]' \
    '--no-python-version-warning[silence Python deprecation warnings]' \
    '--debug[show traceback on errors]' \
    '--cache-dir=-[cache directory]:dir:_files -/' \
    '--no-cache-dir[disable cache]' \
    '--disable-pip-version-check[disable pip version check]' \
    '--proxy=-[proxy URL]:url:_default' \
    '--retries=-[max retries per connection]:n:_default' \
    '--timeout=-[socket timeout]:seconds:_default' \
    '--exists-action=-[action when path exists]:action:(s i w b a)' \
    '--trusted-host=-[trusted host]:host:_hosts' \
    '--cert=-[CA bundle path]:file:_files' \
    '--client-cert=-[client cert path]:file:_files' \
    '--use-feature=-[enable new feature]:feature:_default' \
    '--use-deprecated=-[enable deprecated feature]:feature:_default' \
    '1:command:(install download uninstall freeze inspect list show check config search wheel hash completion debug help index)' \
    '*::command args:->cmdargs' \
    && ret=0

return ret
