#compdef offpunk
# Documentation: https://offpunk.net
# Reference accessed: 2026-05-17
# Verified: upstream docs at the URL above.

_arguments -s \
  '*--sync=[sync named list]:list:(bookmarks tour to_fetch)' \
  '--cache-validity=[cache validity seconds]:s:' \
  '--assume-yes[assume yes]' \
  '--fetch-later[queue for later fetching]' \
  '--tour[start tour mode]' \
  '*:url or file:_files'
