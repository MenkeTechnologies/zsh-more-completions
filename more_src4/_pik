#compdef pik
# Documentation: https://github.com/jacek-kurlit/pik
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# Zsh completion for pik (process interactive kill)

_arguments -s -S \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(- *)'{-P,--print-config}'[print resolved configuration]' \
  '1:process filter query (name, /path, -arg, :port, ~all, !pid, @family)'
