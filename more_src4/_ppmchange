#compdef ppmchange
# Documentation: man ppmchange (Netpbm)
# Source: change one or more colors in a PPM image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-closeness=[match-closeness percent]:percent:' \
    '-remainder=[color for non-matched pixels]:color:' \
    '-closeok[approximate match is OK]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:oldcolor newcolor ... ppm:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
