#compdef marble marble-qt
# Documentation: https://docs.kde.org/stable5/en/marble/marble/commandline.html
# Reference accessed: 2026-05-16
# Verified: KDE Marble Handbook command-line reference + upstream KDE
# marble/src/apps/marble-kde/main.cpp QCommandLineParser.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated --enable-file-view long-form (real KDE flag is --enableFileView).

# marble: KDE virtual globe / world atlas
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '--help-all[show all options (including Qt/KDE)]' \
  '--author[show author info]' \
  '--license[show license info]' \
  '--debug-info[enable debug output]' \
  '--enableFileView[show file view tab]' \
  '--latlon=[start at LAT,LON]:lat,lon:' \
  '--distance=[start distance to surface (km)]:n:' \
  '--map=[map theme]:theme:' \
  '--tile-id[show tile IDs]' \
  '--timedemo[start timing demo]' \
  '--marbledatapath=[Marble data path]:dir:_files -/' \
  '--display=[X display]:disp:' \
  '*:file:_files -g "*.(kml|gpx|osm|pn2)(-.)"' && ret=0
return ret
