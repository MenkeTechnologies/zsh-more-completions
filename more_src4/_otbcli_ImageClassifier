#compdef otbcli_ImageClassifier
# Documentation: https://www.orfeo-toolbox.org/CookBook/Applications/app_ImageClassifier.html
# Source: orfeotoolbox/OTB ImageClassifier — apply a trained TrainImagesClassifier model to a raster.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-in+[input image to classify]:image:_files' \
    '-mask+[optional mask (classify where >0)]:image:_files' \
    '-model+[model file from TrainImagesClassifier]:file:_files' \
    '-imstat+[XML stats file (mean/stddev for normalization)]:file:_files -g "*.xml(-.)"' \
    '-nodatalabel+[label for masked pixels (default 0)]:label:_default' \
    '-out+[output class-label image]:image:_files' \
    '-confmap+[output confidence map]:image:_files' \
    '-probamap+[output probability map (Shark RF only)]:image:_files' \
    '-ram+[available RAM (MB, default 256)]:mb:_default' \
    '-nbclasses+[expected number of classes (default 20)]:n:_default' \
    '-progress[show progress]' \
    '(- *)-help[show help]' \
    && ret=0

return ret
