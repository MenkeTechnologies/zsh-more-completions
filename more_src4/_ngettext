#compdef ngettext
# Documentation: ngettext --help (GNU gettext)
# Source: display native language plural-form translation.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)'{-V,--version}'[show version]' \
    {-d+,--domain=}'[retrieve from textdomain]:domain:' \
    {-c+,--context=}'[context for MSGID]:context:' \
    '-e[expand some escape sequences]' \
    '-E[ignored for compatibility]' \
    '*::textdomain or args:' \
    && ret=0

return ret
