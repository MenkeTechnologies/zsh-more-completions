#compdef opendkim
# Documentation: https://manpages.debian.org/bookworm/opendkim/opendkim.8.en.html
# Reference accessed: 2026-05-20
# Verified: Debian bookworm opendkim(8) manpage.

# opendkim: DKIM milter (signing/verification daemon)
local curcontext="$curcontext" ret=1
_arguments -C \
  '-A[automatically re-start on failures]' \
  '-b[operation modes (s, v, or sv)]:modes:(s v sv)' \
  '-c[canonicalization method]:canon:(simple relaxed simple/simple simple/relaxed relaxed/simple relaxed/relaxed)' \
  '-d[domains to sign]:dataset:' \
  '-D[include subdomains of -d list]' \
  '-e[extract configuration value by name]:name:' \
  '-f[run in foreground]' \
  '-F[fixed UNIX timestamp for signatures]:time:' \
  '-k[PEM private key file]:file:_files' \
  '-l[log to syslog]' \
  '-L[fail messages with partial signatures below threshold]:min:' \
  '-n[parse config/args, report errors, exit]' \
  '-o[headers to omit from signature]:dataset:' \
  '-p[milter socket]:socketspec:' \
  '-P[PID file]:file:_files' \
  '-Q[query test mode]' \
  '-r[reject messages non-compliant with RFC5322]' \
  '-s[selector name]:selector:' \
  '-S[signing algorithm]:signalg:(rsa-sha1 rsa-sha256 ed25519-sha256)' \
  '-t[evaluate (verify) RFC5322 message files]:testfiles:_files' \
  '-T[DNS timeout in seconds]:secs:' \
  '-u[run as user[:group]]:userid:_users' \
  '-v[increase verbose output during test mode]' \
  '-V[show version]' \
  '-W[detailed logging about decisions]' \
  '-x[config file]:file:_files' \
  '-X[allow deprecated configuration items]' \
  '*::opendkim args:_files' && ret=0
return ret
