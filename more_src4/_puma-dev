#compdef puma-dev
# _puma-dev — Puma-dev local Rails dev proxy; serves *.test domains on port 80/443 with auto-app start via launchd/systemd
# upstream: https://github.com/puma/puma-dev

_puma-dev() {
    _arguments \
        '-install[install puma-dev]' \
        '-uninstall[uninstall puma-dev]' \
        '-setup[setup current dir as puma-dev app]' \
        '-install-port+[install port]:port:' \
        '-install-https-port+[install HTTPS port]:port:' \
        '-d+[dev domain (suffix)]:domains:' \
        '-dir+[app dir to scan]:dir:_files -/' \
        '-launchd[launchd helper]' \
        '-systemd[systemd helper]' \
        '-stop[stop daemon]' \
        '-status[show status]' \
        '-pow[behave like Pow]' \
        '-no-serve-public-paths[disable public path serving]' \
        '-timeout+[app timeout]:duration:' \
        '-debug[debug log]' \
        '-tcp+[bind to TCP port]:port:' \
        '-r+[restart rules file]:file:_files' \
        '-V[show version]' \
        '*:cmd:'
}

_puma-dev "$@"
