#compdef meson-compile
# _meson-compile — Meson build system meson-compile CLI alias (Meson team / Jussi Pakkanen, Python); argparse
# upstream: https://github.com/mesonbuild/meson

_meson-compile() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-j+[parallel jobs]:n:' \
        '--jobs=+[parallel jobs]:n:' \
        '-l+[load average max]:f:' \
        '--load-average=+[load average max]:f:' \
        '--clean[clean]' \
        '-C+[build dir]:dir:_files -/' \
        '--verbose[verbose]' \
        '-v[verbose]' \
        '--ninja-args=+[pass args to ninja]:str:' \
        '--vs-args=+[pass args to msbuild]:str:' \
        '--xcode-args=+[pass args to xcodebuild]:str:' \
        '*:target:'
}

_meson-compile "$@"
