#compdef pamslice
# Documentation: man pamslice (Netpbm)
# Source: Netpbm pamslice — extract one line (row or column) of values out of a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-row -column)-row=[horizontal slice row number]:rownumber:' \
    '(-row -column)-column=[vertical slice column number]:columnnumber:' \
    '-plane=[plane number]:planenumber:' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:Netpbm image file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
