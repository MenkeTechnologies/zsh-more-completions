#compdef mfsmetalogger
# Documentation: https://manpages.debian.org/bookworm/moosefs-metalogger/mfsmetalogger.8.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mfsmetalogger: MooseFS metadata logger daemon
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)-v[print version and exit]' \
  '(- *)-h[print usage and exit]' \
  '-f[force run, do not kill previous instance]' \
  '-s[stop metalogger process]' \
  '-c[alternative config file]:file:_files -g "*.cfg"' \
  '-u[log undefined config values]' \
  '-d[run in foreground, do not daemonize]' \
  '-t[lockfile timeout (seconds)]:seconds:' \
  '*:action:(start stop restart reload test kill)' && ret=0
return ret
