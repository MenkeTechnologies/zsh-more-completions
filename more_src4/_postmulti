#compdef postmulti
# _postmulti — Postfix multi-instance manager (iterator + life-cycle controller for running several Postfix instances side-by-side on one host)
# upstream: https://github.com/vdukhovni/postfix
# Flags from postfix/man/man1/postmulti.1 on tip; usage forms are -e (lifecycle), -l/-p/-x (iterator), or just `-l`.

_postmulti() {
    _arguments \
        '*-v[verbose logging (repeat for more)]' \
        '-a[apply to all instances]' \
        '-R[exit on first error during iteration]' \
        '-j[JSON output for -l]' \
        '-g+[only act on instances in group]:group:' \
        '-i+[only act on this instance name]:name:' \
        '-G+[set/move instance to this group]:group:' \
        '-I+[set instance name (with -e create/import/assign)]:name:' \
        '(-e -l -p -x)-l[iterator: list instances]' \
        '(-e -l -p -x)-p[iterator: run a postfix(1) command for each instance]' \
        '(-e -l -p -x)-x[iterator: run a unix command for each instance]' \
        '(-e -l -p -x)-e+[lifecycle action]:action:(init create import destroy deport enable disable assign)' \
        '*::postfix-or-unix-command:'
}

_postmulti "$@"
