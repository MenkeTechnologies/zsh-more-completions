#compdef pamscale pnmscale
# Documentation: man pamscale (Netpbm)
# Source: scale a Netpbm image by factor, target size, fit, fill, or pixel budget.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-xyfit -xyfill -xysize -reduce -xsize -width -xscale -ysize -height -yscale -pixels)-xyfit[fit into cols x rows]' \
    '(-xyfit -xyfill -xysize -reduce -xsize -width -xscale -ysize -height -yscale -pixels)-xyfill[fill cols x rows]' \
    '(-xyfit -xyfill -xysize -reduce -xsize -width -xscale -ysize -height -yscale -pixels)-xysize[scale to exact cols x rows]' \
    '(-xyfit -xyfill -xysize -reduce -xsize -width -xscale -ysize -height -yscale -pixels)-reduce=[reduce by factor]:reduction_factor:' \
    '(-xyfit -xyfill -xysize)'{-xsize=,-width=,-xscale=}'[target columns / scale factor]:cols:' \
    '(-xyfit -xyfill -xysize)'{-ysize=,-height=,-yscale=}'[target rows / scale factor]:rows:' \
    '(-xyfit -xyfill -xysize -reduce -xsize -width -xscale -ysize -height -yscale)-pixels=[total output pixel budget]:n:' \
    '(-filter -window)-nomix[do not mix samples; use nearest neighbour]' \
    '(-nomix)-filter=[interpolation filter name]:fn:(point box triangle quadratic cubic catrom mitchell gauss sinc bessel hanning hamming blackman kaiser normal hermite lanczos)' \
    '(-nomix)-window=[filter window function]:fn:(box triangle quadratic cubic catrom mitchell gauss sinc bessel hanning hamming blackman kaiser normal hermite lanczos)' \
    '-linear[treat samples as linear, not gamma-corrected]' \
    '-reportonly[report scale, do not produce output]' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:scale factor or pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
