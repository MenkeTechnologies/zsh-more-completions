#compdef packer-cli
# _packer-cli — HashiCorp Packer machine image builder CLI alias (HashiCorp, Go); custom argparse
# upstream: https://github.com/hashicorp/packer

_packer-cli() {
    local -a sub=(
        'build:build image from template'
        'console:start console'
        'fix:fix template'
        'fmt:format hcl files'
        'hcl2_upgrade:upgrade json to hcl2'
        'inspect:see components of a template'
        'init:install/upgrade plugins'
        'plugins:plugin management'
        'validate:validate template syntax'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-v[show version]' \
        '-machine-readable[machine-readable output]' \
        '-color=+[colored output]:b:(true false)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'packer subcommand' sub ;;
        args)
            case $words[1] in
                build) _arguments \
                    '-debug[debug builds]' \
                    '-force[force builds]' \
                    '-machine-readable[machine readable]' \
                    '-on-error=+[on error]:s:(cleanup abort ask run-cleanup-provisioner)' \
                    '-parallel-builds=+[parallel builds]:n:' \
                    '-timestamp-ui[timestamp ui]' \
                    '-warn-on-undeclared-var[warn on undeclared var]' \
                    '-color=+[colored output]:b:(true false)' \
                    '-except=+[except builds]:list:' \
                    '-only=+[only builds]:list:' \
                    '-var+[set variable]:str:' \
                    '-var-file=+[var file]:file:_files' \
                    '*:template:_files -g "*.json *.pkr.json *.pkr.hcl"' ;;
                validate) _arguments \
                    '-syntax-only[only check syntax]' \
                    '-machine-readable[machine readable]' \
                    '-var+[set variable]:str:' \
                    '-var-file=+[var file]:file:_files' \
                    '*:template:_files -g "*.json *.pkr.json *.pkr.hcl"' ;;
                init) _arguments \
                    '-upgrade[upgrade plugins]' \
                    '*:template:_files -g "*.pkr.hcl *.pkr.json *.json"' ;;
                fmt) _arguments \
                    '-recursive[recursive]' \
                    '-write=+[write]:b:(true false)' \
                    '-diff[show diff]' \
                    '-check[check format]' \
                    '*:file:_files' ;;
                fix) _arguments \
                    '-validate=+[validate]:b:(true false)' \
                    '*:template:_files -g "*.json"' ;;
                inspect|hcl2_upgrade) _arguments '*:file:_files' ;;
                plugins) _arguments \
                    '1:cmd:(install uninstall installed required)' \
                    '*:arg:' ;;
                console) _arguments \
                    '-var+[set variable]:str:' \
                    '-var-file=+[var file]:file:_files' \
                    '*:template:_files' ;;
            esac
            ;;
    esac
}

_packer-cli "$@"
