#compdef pcp_watchdog_info
# Documentation: https://www.pgpool.net/docs/latest/en/html/pcp-watchdog-info.html
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

# pcp_watchdog_info: print watchdog info
local curcontext="$curcontext" ret=1
_arguments -C \
  "(- *)--help[show help]" \
  "(- *)-\\?[show help]" \
  "(- *)-V[show version]" \
  "(- *)--version[show version]" \
  "-w[no password prompt]" \
  "--no-password[no password prompt]" \
  "-W[force password prompt]" \
  "--password[force password prompt]" \
  "-d[enable debug message]" \
  "--debug[enable debug message]" \
  "-v[verbose output]" \
  "--verbose[verbose output]" \
  "-U[PCP user name]:user:_users" \
  "--username=[PCP user name]:user:_users" \
  "-h[pgpool host]:host:_hosts" \
  "--host=[pgpool host]:host:_hosts" \
  "-p[PCP port number]:port:" \
  "--port=[PCP port number]:port:" \
  "-n[watchdog id]:watchdog id:" \
  "--node-id=[watchdog id]:watchdog id:" \
  '*::pcp_watchdog_info args:_files' && ret=0
return ret
