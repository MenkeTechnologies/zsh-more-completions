#compdef pamrecolor
# Documentation: man pamrecolor (Netpbm)
# Source: recolor a PAM image with channel multipliers / target color / colorspace mapping.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '--colorspace=[colorspace name]:name:(ntsc rec709)' \
    '--rmult=[red multiplier]:fraction:' \
    '--gmult=[green multiplier]:fraction:' \
    '--bmult=[blue multiplier]:fraction:' \
    '--targetcolor=[target color (recolor toward this)]:color:' \
    '--colorfile=[file of target colors]:file:_files' \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:input image:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
