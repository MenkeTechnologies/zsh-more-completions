#compdef metals
# Documentation: https://scalameta.org/metals/docs/integrations/new-editor/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# STUB: the `metals` binary is a stdio LSP server invoked by editors; the
# upstream README and integration docs document no end-user command-line
# flag set. A separate `metals-mcp` binary (HTTP MCP server) exists with
# its own flags and is not handled here.

local curcontext="$curcontext" state line ret=1

_arguments -s -S \
  '(- *)--help[show help]' \
  '(- *)--version[show version]' \
  && ret=0

return ret
