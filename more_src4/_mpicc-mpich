#compdef mpicc-mpich
# Documentation: https://manpages.debian.org/testing/mpich/mpicc.mpich.1.en.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. Pass-through to underlying
# C compiler. MPICH uses single-dash long options (-show, -compile_info,
# -link_info, -echo, -config=, -cc=, -profile=, -static, -help).
# Removed from prior file: -nativelinker (not documented).

# mpicc-mpich: MPICH C compiler wrapper
local curcontext="$curcontext" ret=1
_arguments -C \
  '-show[display commands without executing them]' \
  '-compile_info[show compilation steps and options]' \
  '-link_info[show linking steps and libraries]' \
  '-echo[display exactly what the program is doing]' \
  '-config=[load compiler-specific configuration]:name:' \
  '-cc=[underlying C compiler override]:compiler:_command_names' \
  '-profile=[apply MPI profiling library]:lib:' \
  '-static[use statically compiled MPI library]' \
  '-help[show help]' \
  '*:C source:_files -g "*.(c|h|o|a|so)(-.)"' && ret=0
return ret
