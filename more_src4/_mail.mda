#compdef mail.mda
# _mail.mda — OpenSMTPD mail.mda delivery helper (exec a user-supplied program with the message piped to its stdin; used as a generic MDA bridge from smtpd.conf)
# upstream: https://github.com/OpenSMTPD/OpenSMTPD
# Source: usr.sbin/smtpd/mail.mda.8 on tip; no flags — argv is the program + its arguments.

_mail.mda() {
    _arguments '*::program-and-args:_command_names -e'
}

_mail.mda "$@"
