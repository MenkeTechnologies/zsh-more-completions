#compdef otf2-print
# _otf2-print — Open Trace Format 2 print utility (Score-P / Scalasca toolchain); dumps OTF2 trace archive records to text
# upstream: https://www.vi-hps.org/projects/score-p

_otf2-print() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-A --show-all)'{-A,--show-all}'[show all event records]' \
        '(-G --show-global)'{-G,--show-global}'[show global definitions only]' \
        '(-L --show-local)'{-L,--show-local}'[show local definitions only]' \
        '(-M --show-mapping)'{-M,--show-mapping}'[show mapping tables]' \
        '(-l --location)'{-l,--location}'+[print location id]:id:' \
        '(-c --comm)'{-c,--comm}'+[comm id]:id:' \
        '(-s --silent)'{-s,--silent}'[silent (only errors)]' \
        '(-t --thumbnail)'{-t,--thumbnail}'[print thumbnail data]' \
        '*:OTF2 anchor file:_files -g "*.otf2"'
}

_otf2-print "$@"
