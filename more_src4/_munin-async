#compdef munin-async
# Documentation: https://manpages.debian.org/experimental/munin-async/munin-async.1.en.html
# Reference accessed: 2026-05-16
# Verified: Debian experimental munin-async(1) manpage.

# munin-async: query Munin async spool (client)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(-h --help)'{-h,--help}'[show help]' \
  '(-v --verbose)'{-v,--verbose}'[verbose]' \
  '(-s --spooldir)'{-s,--spooldir=}'[spool directory]:dir:_files -/' \
  '--hostname=[override greeting hostname]:host:' \
  '--cleanup[clean spooldir after interactive session]' \
  '--cleanupandexit[clean spooldir and exit]' \
  '--spoolfetch[enable spool capability]' \
  '--vectorfetch[enable vectorized fetching]' && ret=0
return ret
