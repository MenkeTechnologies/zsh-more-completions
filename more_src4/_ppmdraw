#compdef ppmdraw
# Documentation: man ppmdraw (Netpbm)
# Source: draw lines and shapes onto a PPM via a small drawing script.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-script -scriptfile)-script=[inline drawing script]:script:' \
    '(-script -scriptfile)-scriptfile=[drawing script file]:file:_files' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
