#compdef mount_msdos
# Documentation: mount_msdos usage (macOS 26)
# Source: mount a FAT/exFAT filesystem.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-o+[mount options]:options:(rdonly noexec nosuid nodev union async sync noatime)' \
    '-u+[file owner]:user:_users' \
    '-g+[file group]:group:_groups' \
    '-m+[file mode mask]:mask:' \
    '-s[truncate filenames to 8.3]' \
    '-l[long names allowed (Windows 95-style)]' \
    '-9[allow non-standard Windows-95-long-name encoding]' \
    '1:block device:_files -g "/dev/disk*"' \
    '2:mount point:_files -/' \
    && ret=0

return ret
