#compdef modetest
# modetest - DRM/KMS mode testing and display configuration

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
  '-M+[use specified DRM module]:module name:' \
  '-D+[use specified DRM device]:device:_files -W /dev/dri' \
  '-a[test all connectors]' \
  '-c[list connectors]' \
  '-e[list encoders]' \
  '-f[list framebuffers]' \
  '-p[list CRTCs and planes]' \
  '-P+[set plane]:plane config:' \
  '-s+[set connector mode]:mode config:' \
  '-C[test hw cursor]' \
  '-v[test VSync]' \
  '-w+[set property]:property:' \
  '-d[drop master after mode set]' \
  '-F+[specify pixel format]:format:(XR24 AR24 NV12 YU12 YUYV)' \
  '-j[list properties in JSON format]' \
  && ret=0

return ret
