#compdef ppmcolors
# Documentation: man ppmcolors (Netpbm, wraps pamseq)
# Source: legacy wrapper — produce a PPM ramp of N values per channel.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-maxval=[max sample value]:maxval:' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:steps:' \
    && ret=0

return ret
