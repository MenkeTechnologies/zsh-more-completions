#compdef obsidian
# Documentation: https://obsidian.md/help/cli
# Reference accessed: 2026-05-19
# Verified: official Obsidian CLI documentation. Commands use
# colon-namespaces (e.g. daily:append, tags:rename) and key=value
# positional parameters rather than --flags. Global pseudo-flags:
# --copy. Global key=value selectors: vault=, file=, path=.
# Corrected from prior file: 'tag' is a real subcmd (was 'tag
# operations'), no global --help/-h/-v flags — Obsidian uses
# 'help' and 'version' subcommands.

local curcontext="$curcontext" state line ret=1
local -a commands

commands=(
  'help:show help'
  'version:show version'
  'reload:reload vault'
  'restart:restart Obsidian'
  'open:open a note'
  'create:create a new note'
  'read:read a note'
  'append:append content to a note'
  'prepend:prepend content to a note'
  'move:move a note'
  'rename:rename a note'
  'delete:delete a note'
  'file:operate on a file'
  'files:list files'
  'folder:operate on a folder'
  'folders:list folders'
  'search:search vault'
  'search\:open:open a search'
  'search\:context:search with context'
  'tags:list tags'
  'tag:tag operations'
  'tasks:list tasks'
  'task:task operations'
  'daily:open daily note'
  'daily\:append:append to daily note'
  'daily\:prepend:prepend to daily note'
  'daily\:read:read daily note'
  'daily\:path:show daily note path'
  'backlinks:show backlinks'
  'links:show links'
  'unresolved:show unresolved links'
  'orphans:show orphan notes'
  'deadends:show deadend notes'
  'outline:show outline'
  'properties:list properties'
  'aliases:list aliases'
  'property\:set:set property'
  'property\:remove:remove property'
  'property\:read:read property'
  'plugins:list plugins'
  'plugin\:enable:enable plugin'
  'plugin\:disable:disable plugin'
  'plugin\:install:install plugin'
  'plugin\:uninstall:uninstall plugin'
  'plugin\:reload:reload plugin'
  'themes:list themes'
  'theme\:set:set theme'
  'theme\:install:install theme'
  'theme\:uninstall:uninstall theme'
  'snippets:list snippets'
  'snippet\:enable:enable snippet'
  'snippet\:disable:disable snippet'
  'workspace:show workspace'
  'workspaces:list workspaces'
  'workspace\:save:save workspace'
  'workspace\:load:load workspace'
  'workspace\:delete:delete workspace'
  'vault:show vault'
  'vaults:list vaults'
  'vault\:open:open vault'
  'sync:sync vault'
  'sync\:status:show sync status'
  'random:open a random note'
  'templates:list templates'
  'template\:insert:insert template'
  'commands:list commands'
  'hotkeys:list hotkeys'
  'bookmarks:list bookmarks'
  'wordcount:show word count'
  'web:open web viewer'
  'history:show file history'
  'diff:show file diff'
)

_arguments -C \
  '--copy[copy command output to clipboard]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  (cmd) _describe -t cmds 'obsidian command' commands && ret=0 ;;
  (args)
    case $line[1] in
      (create)
        _arguments \
          '*:key\=value:(name= content= template= silent vault= path=)' && ret=0 ;;
      (append|prepend|read)
        _arguments \
          '*:key\=value:(file= path= content= vault=)' && ret=0 ;;
      (search)
        _arguments \
          '*:key\=value:(query= limit= total vault=)' && ret=0 ;;
    esac ;;
esac

return ret
