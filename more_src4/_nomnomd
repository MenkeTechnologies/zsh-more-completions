# -----------------------------------------------------------------------------
#
# THE nomnomd CLI — arg + markdown-it + nomnoml + highlight.js
#
# nomnomd's CLI is in src/index.ts.  Uses Vercel's `arg`
# package (minimal Node argv parser; not yargs / commander /
# oclif).
#
# Source:
#     const parsed = arg(
#         {
#             "--help": Boolean,
#             "--out": String,
#             "--theme": String,
#             "--hltheme": String,
#             "--serve": Number,
#             "-r": Boolean,
#             "--recursive": Boolean,
#         },
#         { argv: args }
#     );
#
# Flags:
#       --help              show usage and exit
#       --out DIR           output directory (default "build")
#       --theme FILE        custom CSS theme file
#       --hltheme HLJS_THEME
#                           highlight.js theme name
#                           (atom-one-dark, github-dark, nord, etc.)
#       --serve PORT        live-reload dev server on PORT
#       -r, --recursive     recursively process directories
#
# Positional:
#   FILES...               Markdown files (.md) to process
#
# markdown-it is used in src/index.ts:
#     import MarkdownIt from "markdown-it";
#     import Highlight from "highlight.js";
#     import Frontmatter from "markdown-it-front-matter";
#     import MarkdownItEmoji from "markdown-it-emoji";
#     ...
#     const md = new MarkdownIt({ html: true })
#       .use(Frontmatter, callback)
#       .use(MarkdownItEmoji)
#       .use(nomnomlIt)  // custom plugin for nomnoml fences
#       .use(makeInclude(...))
#       .use(markdownLinks);
#
# Five-axis distinctness from pulldown-cmark (R665) +
# goldmark (R666):
#
#   1. TOKEN-BASED INTERMEDIATE — markdown-it's md.parse()
#      returns a flat Token[] array; not events (pulldown-
#      cmark) or AST nodes (goldmark).
#
#   2. RULE-PIPELINE EXTENSION MODEL — plugins manipulate
#      individual core / block / inline rules; not Options
#      bitflags or Extender interfaces.
#
#   3. 400+ NPM PLUGIN ECOSYSTEM — emoji, footnote, anchor,
#      attrs, container, deflist, abbr, image-figures, sub,
#      sup, ins, del, etc.  Largest Markdown plugin ecosystem
#      across all languages.
#
#   4. PRESETS — markdownit('commonmark' | 'default' | 'zero')
#      configures pre-built rule sets.
#
#   5. VITALY-PUZRIN / NODECA / markdown-it-ORG ECOSYSTEM
#      PROVENANCE — distinct maintainer lineage (Russian
#      scientific JS).
#
# -----------------------------------------------------------------------------
#
# COMMAND-LINE OPTIONS (sourced directly from
# https://github.com/erkkah/nomnomd/blob/master/src/index.ts
# Vercel arg package configuration.)
# -----------------------------------------------------------------------------

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s -S \
    '--help[show usage and exit]' \
    '--out=[output directory]:directory:_files -/' \
    '--theme=[custom CSS theme file]:file:_files -g "*.css"' \
    '--hltheme=[highlight.js theme name]:theme:_default' \
    '--serve=[live-reload dev server port]:port:_default' \
    '(-r --recursive)'{-r,--recursive}'[recursively process directories]' \
    '*:markdown file:_files -g "*.md"' \
    && ret=0

return ret
