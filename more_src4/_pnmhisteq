#compdef pnmhisteq
# Documentation: man pnmhisteq (Netpbm)
# Source: histogram-equalize a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-gray[work on V channel only (HSV equalisation)]' \
    '-noblack[do not map black]' \
    '-nowhite[do not map white]' \
    '-rmap+[read pre-computed mapping from PGM]:file:_files -g "*.(pgm|pnm|pam)"' \
    '-wmap+[write mapping to PGM]:file:_files -g "*.pgm"' \
    '-verbose[verbose output]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:pnm file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
