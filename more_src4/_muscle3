#compdef muscle3
# Documentation: https://muscle3.readthedocs.io/en/latest/
# Reference accessed: 2026-05-19
# Verified: upstream muscle3/muscle3.py click CLI definitions.
# muscle3 here is the MUltiScale Coupling Library tool (multiscale/muscle3),
# NOT the drive5 multiple-sequence-alignment program (that one is `muscle`).

local curcontext="$curcontext" ret=1 state line
typeset -A opt_args

local -a commands
commands=(
  'profile:visualise profiling information from performance.sqlite'
  'resources:calculate resources needed for a simulation'
  'snapshot:display details of a stored snapshot'
)

_arguments -C \
  '(- *)--help[show help]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0

case $state in
  cmd)
    _describe -t commands 'muscle3 command' commands && ret=0
    ;;
  args)
    case $words[1] in
      profile)
        _arguments -s -S \
          '(-i --instances)'{-i,--instances}'[show per-instance statistics]' \
          '(-r --resources)'{-r,--resources}'[show per-resource statistics]' \
          '(-t --timeline)'{-t,--timeline}'[show a timeline of events]' \
          '--help[show help]' \
          '1:performance file:_files -g "*.sqlite"' && ret=0
        ;;
      resources)
        _arguments -s -S \
          '(-c --cores-per-node)'{-c,--cores-per-node}'[cores per cluster node]:n:' \
          '(-v --verbose)'{-v,--verbose}'[show instance allocations]' \
          '--help[show help]' \
          '*:yMMSL file:_files -g "*.(ymmsl|yaml|yml)"' && ret=0
        ;;
      snapshot)
        _arguments -s -S \
          '--help[show help]' \
          '*:snapshot file:_files' && ret=0
        ;;
      *)
        _default && ret=0
        ;;
    esac
    ;;
esac

return ret
