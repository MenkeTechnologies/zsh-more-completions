#compdef ouster-cli
# Documentation: https://static.ouster.dev/sdk-docs/cli/overview.html
# Source: ouster-lidar/ouster-sdk — Python CLI for Ouster LiDAR sensors.
# Reference accessed: 2026-06-02

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a _oc_cmds
_oc_cmds=(
    'discover:locate Ouster sensors on local networks via mDNS'
    'source:read lidar data from a sensor or file and pipe through subcommands'
    'util:miscellaneous utilities (benchmarking, diagnostics, network)'
    'help:show help'
)

local -a _oc_source
_oc_source=(
    'viz:visualize data in a 3D point-cloud viewer'
    'slice:extract a subset of lidar frames by index or duration'
    'clip:limit the range of scan field values'
    'filter:suppress or replace field measurements by predicate'
    'mask:mask pixels from lidar frames'
    'reduce:downsample vertical resolution'
    'slam:compute trajectories from pose changes'
    'stats:calculate source data statistics'
    'metadata:display sensor information'
    'save:save source data (optional format conversion)'
    'save_raw:save raw sensor packets'
    'save_trajectory:save sensor movement trajectory'
    'normals:compute surface normals per scan'
    'localize:run localization against a mapping output'
    'plumb:calculate extrinsic matrix for gravity alignment'
    'live_zones:query/set sensor zone lists'
    'info:print file information (pcap/osf only)'
    'config:configure sensor settings (sensors only)'
    'userdata:display sensor userdata (sensors only)'
    'restart:soft-restart the sensor (sensors only)'
    'firmware:retrieve or update firmware (sensors only)'
    'dump:print OSF metadata (osf only)'
    'parse:print OSF message types (osf only)'
)

_arguments -C \
    '(- *)'{-h,--help}'[show help]' \
    '(- *)--version[show version]' \
    '(-): :->command' \
    '(-)*:: :->args' \
    && ret=0

case $state in
    command)
        _describe -t commands 'ouster-cli command' _oc_cmds && ret=0
        ;;
    args)
        case $line[1] in
            source)
                _arguments -s -S \
                    '1:source (sensor address or file):_default' \
                    '2:subcommand:->source-sub' \
                    '*::positional:_default' && ret=0
                case $state in
                    source-sub) _describe -t source 'source subcommand' _oc_source && ret=0 ;;
                esac
                ;;
        esac
        ;;
esac

return ret
