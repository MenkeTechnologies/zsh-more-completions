#compdef nodm
# Documentation: https://www.systutorials.com/docs/linux/man/8-nodm/
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.
# Per nodm(8) man page: --help, --version, --verbose, --quiet, --nested,
# --[no-]syslog, --[no-]stderr.

local curcontext="$curcontext" state line ret=1

_arguments -C \
  '--help[show help]' \
  '--version[show version]' \
  '--verbose[verbose logging]' \
  '--quiet[only log warnings and errors]' \
  '--nested[run nested X server (no root needed)]' \
  '--syslog[enable syslog logging]' \
  '--no-syslog[disable syslog logging]' \
  '--stderr[enable stderr logging]' \
  '--no-stderr[disable stderr logging]' && ret=0

return ret
