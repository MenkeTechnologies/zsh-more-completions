#compdef pigpiod
# _pigpiod — joan2937 pigpio pigpiod daemon CLI for the Raspberry Pi GPIO PWM I2C SPI servo bit-bang serial-bridge accepting socket and pipe connections from local pigs CLI or remote networked clients (joan2937 team, C); getopt
# upstream: https://github.com/joan2937/pigpio

_pigpiod() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '-a+[primary alert]:n:(0 1 2)' \
        '-b+[gpio bank]:n:' \
        '-c+[sample rate]:n:(1 2 4 5 8 10)' \
        '-d+[debug level]:n:' \
        '-f[disable fifos]' \
        '-g[run in foreground]' \
        '-k[disable socket]' \
        '-l[disable local IP socket]' \
        '-m+[memory allocation]:n:' \
        '-n+[network access csv]:str:' \
        '-p+[port]:n:' \
        '-s+[sample rate]:n:' \
        '-t+[clock source]:c:(0 1)' \
        '-x+[GPIO mask hex]:str:'
}

_pigpiod "$@"
