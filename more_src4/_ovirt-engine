#compdef ovirt-engine
# _ovirt-engine — oVirt Engine boot wrapper (privileged shell script that loads the ovirt-engine WildFly server with the JBoss management socket bound to the engine config in /etc/ovirt-engine; start/stop/restart/status/reload subcommands; --foreground keeps it attached, --logfile picks the log file)
# upstream: https://github.com/oVirt/ovirt-engine
# Subcommands from ovirt-engine packaging/services/ovirt-engine/ovirt-engine.in on tip.

_ovirt-engine() {
    _arguments \
        '--help[show help]' \
        '--foreground[stay foreground]' \
        '--logfile+[log file]:file:_files' \
        '--pid-file+[pidfile]:file:_files' \
        '--config+[config file]:file:_files' \
        '1:command:(start stop restart status reload)'
}

_ovirt-engine "$@"
