#compdef paste-cli
# _paste-cli — GNU coreutils paste merge lines of files CLI alias (GNU team, C); custom argparse
# upstream: https://github.com/coreutils/coreutils

_paste-cli() {
    _arguments \
        '--help[show help]' \
        '-h[show help]' \
        '--version[show version]' \
        '-V[show version]' \
        '-d+[delimiter list]:str:' \
        '--delimiters=+[delimiter list]:str:' \
        '-s[paste one file at a time]' \
        '--serial[paste one file at a time]' \
        '-z[NUL terminator]' \
        '--zero-terminated[NUL terminator]' \
        '*:files:_files'
}

_paste-cli "$@"
