#compdef mupdf mupdf-x11 mupdf-gl mupdf-wayland
# _mupdf — Artifex MuPDF mupdf CLI lightweight PDF XPS EPUB CBZ FB2 SVG viewer renderer for X11 OpenGL Wayland Cocoa rendering documents at high speed with key-driven navigation pageturn zoom rotate text-search invert color-mode anti-aliasing for the GhostPDL family (Artifex Software team, C); custom argparse
# upstream: https://mupdf.com/

_mupdf() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-v[show version]' \
        '--version[show version]' \
        '-p+[password]:str:' \
        '-r+[resolution dpi]:n:' \
        '-W+[page width pts]:n:' \
        '-H+[page height pts]:n:' \
        '-X+[force resolution]:n:' \
        '-A+[set anti-aliasing]:l:(0 2 4 6 8)' \
        '-I[invert colors]' \
        '-C+[tint hex]:str:' \
        '-T+[fitz log level]:l:(0 1 2 3 4)' \
        '-S+[fit-page subset]:str:' \
        '-U+[stylesheet]:file:_files -g "*.css"' \
        '-X+[icc-disabled]:str:' \
        '-J[disable javascript]' \
        '-V[viewer aspectfit]' \
        '-Y+[layout em]:n:' \
        '*:document:_files -g "*.pdf *.xps *.epub *.cbz *.fb2 *.svg *.txt *.png *.jpg *.tif *.tiff"'
}

_mupdf "$@"
