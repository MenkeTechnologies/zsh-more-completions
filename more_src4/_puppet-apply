#compdef puppet-apply
# _puppet-apply — Puppet puppet-apply CLI for stand-alone Puppet manifest application without a server compiling and enforcing manifests locally with detailed-exit-codes noop verbose modulepath hiera config-dir trace (puppetlabs team, Ruby); getopt
# upstream: https://github.com/puppetlabs/puppet

_puppet-apply() {
    _arguments \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '-d[debug]' \
        '--debug[debug]' \
        '-t[test mode]' \
        '--test[test mode]' \
        '-l+[log dest]:str:' \
        '--logdest=+[log dest]:str:' \
        '--logger=+[backend]:b:(file syslog console eventlog stdout)' \
        '--detailed-exitcodes[detailed exit codes]' \
        '--noop[noop]' \
        '-n[noop]' \
        '--no-noop[no noop]' \
        '--catalog=+[file]:file:_files -g "*.json"' \
        '-e+[code]:str:' \
        '--execute=+[code]:str:' \
        '--modulepath=+[dirs]:str:' \
        '--environment=+[env]:str:' \
        '--environmentpath=+[dirs]:str:' \
        '--render-as=+[fmt]:f:(json yaml string pp)' \
        '--show_diff[show diff]' \
        '--no-show_diff[no show diff]' \
        '--summarize[summarize]' \
        '-s[summarize]' \
        '--evaltrace[eval trace]' \
        '--trace[stack trace]' \
        '--graph[graph]' \
        '--graphdir=+[dir]:dir:_files -/' \
        '--no-color[no color]' \
        '--color=+[mode]:m:(auto on off)' \
        '--write-catalog-summary[write catalog summary]' \
        '--strict=+[mode]:m:(off warning error)' \
        '--strict_variables[strict variables]' \
        '--debugger[debugger]' \
        '--tags=+[csv]:str:' \
        '--skip_tags=+[csv]:str:' \
        '--hiera_config=+[file]:file:_files -g "*.yaml *.yml hiera.yaml"' \
        '--confdir=+[dir]:dir:_files -/' \
        '--codedir=+[dir]:dir:_files -/' \
        '--vardir=+[dir]:dir:_files -/' \
        '--rundir=+[dir]:dir:_files -/' \
        '--logdir=+[dir]:dir:_files -/' \
        '--certname=+[name]:str:' \
        '--node_terminus=+[t]:t:(plain rest exec yaml json)' \
        '--no-disable_warnings[no disable warnings]' \
        '--disable_warnings=+[csv]:str:' \
        '*:manifest file:_files -g "*.pp"'
}

_puppet-apply "$@"
