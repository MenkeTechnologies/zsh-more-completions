#compdef mblaze
# Documentation: https://github.com/leahneukirchen/mblaze
# Reference accessed: 2026-05-16
# Verified: leahneukirchen/mblaze upstream README. NOTE: mblaze itself
# is not a binary — it's a suite of ~26 commands (maddr, magrep, mbnc,
# mcom, mdeliver, mdirs, mexport, mflag, mflow, mfwd, mgenmid, mhdr,
# minc, mless, mlist, mmime, mmkdir, mpick, mrefile, mrep, mscan, msed,
# mseq, mshow, msort, mthread). Each has its own flag table and ideally
# its own completion file.
# Removed from prior file: bogus man.archlinux.org search URL;
# fabricated `mblaze` umbrella binary (does not exist).

# mblaze: meta-completion for the mblaze mail suite
local curcontext="$curcontext" ret=1
local -a commands=(
  'maddr:extract addresses'
  'magrep:search messages'
  'mbnc:bounce messages'
  'mcom:compose messages'
  'mdeliver:deliver to maildirs'
  'mdirs:list maildirs'
  'mexport:export as mbox'
  'mflag:manipulate flags'
  'mflow:reformat flowed text'
  'mfwd:forward messages'
  'mgenmid:generate Message-IDs'
  'mhdr:show headers'
  'minc:incorporate new messages'
  'mless:less wrapper for mshow'
  'mlist:list messages'
  'mmime:create MIME messages'
  'mmkdir:create maildirs'
  'mpick:filter by expression'
  'mrefile:refile to maildir'
  'mrep:reply'
  'mscan:one-line summaries'
  'msed:edit headers'
  'mseq:manage sequences'
  'mshow:render messages'
  'msort:sort messages'
  'mthread:thread messages'
)
_arguments -C \
  '1:mblaze subcommand:->cmd' && ret=0
case $state in
  (cmd) _describe -t commands 'mblaze suite command' commands && ret=0 ;;
esac
return ret
