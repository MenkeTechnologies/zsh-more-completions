#compdef mppdec mpcdec
# Documentation: https://www.musepack.net/
# Reference accessed: 2026-05-19
# Verified: local mpcdec --help output (v1.0.0). Real flags: -i (info),
# -c (check stream errors), -h (help). Input may be .mpc/.mp+/.mpp;
# output is wav. Use - for stdin/stdout.
# Removed from prior file: fabricated --silent/--prev/--info/--version.

local curcontext="$curcontext" ret=1

_arguments -C \
  '-h[show help]' \
  '-i[print file information on stdout]' \
  '-c[check the file for stream errors (outfile ignored)]' \
  '1:input file:_files -g "*.(mpc|mp+|mpp)"' \
  '2:output wav file:_files -g "*.wav"' && ret=0

return ret
