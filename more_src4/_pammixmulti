#compdef pammixmulti
# Documentation: man pammixmulti (Netpbm)
# Source: blend multiple Netpbm images into one.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-blend=[blend mode]:mode:(average alpha-weighted random mask)' \
    '-maskfile=[mask file]:file:_files' \
    '-stdev=[standard deviation (for random)]:number:' \
    '-randomseed=[random seed]:integer:' \
    '-quiet[suppress libnetpbm chatter]' \
    '*:input file:_files -g "*.(pam|pnm|pbm|pgm|ppm)"' \
    && ret=0

return ret
