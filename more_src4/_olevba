#compdef olevba

_olevba() {
    local curcontext="$curcontext" state line ret=1

    _arguments \
        '(- *)--help[show help message and exit]' \
        '(-r --recursive)'{-r,--recursive}'[scan files recursively in directories]' \
        '(-z --zip)'{-z,--zip}'[zip password for encrypted files]:password:' \
        '(-f --filename)'{-f,--filename}'[use provided filename instead of path]:filename:' \
        '(-a --analysis)'{-a,--analysis}'[display only analysis results]' \
        '--reveal[reveal obfuscated strings]' \
        '--decode[decode obfuscated strings]' \
        '--attr[display attributes of VBA modules]' \
        '--deobf[attempt to deobfuscate VBA expressions]' \
        '(-c --code)'{-c,--code}'[display only VBA source code]' \
        '--show-pcode[display p-code disassembly]' \
        '--no-pcode[do not attempt p-code disassembly]' \
        '(-t --triage)'{-t,--triage}'[triage mode, short summary of all files]' \
        '--json[output results in JSON format]' \
        '--detailed[display detailed information]' \
        '--no-deobf[do not attempt deobfuscation]' \
        '--relaxed[do not raise errors on non-OLE files]' \
        '*:file:_files' && ret=0

    return ret
}

_olevba "$@"
