#compdef nats-kafka
# _nats-kafka — bridge between NATS and Kafka (nats-io/nats-kafka)
# upstream: https://github.com/nats-io/nats-kafka
# Flags from main.go (flag).

_nats-kafka() {
    _arguments \
        '-c+[configuration file]:file:_files' \
        '-D[turn on debug logging]' \
        '-V[turn on verbose logging]' \
        '-DV[debug and verbose logging]'
}

_nats-kafka "$@"
