#compdef mysql-router mysqlrouter
# Documentation: https://dev.mysql.com/doc/mysql-router/8.4/en/mysqlrouter.html
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mysqlrouter: MySQL Router (HA / sharding routing proxy)
local curcontext="$curcontext" ret=1
_arguments -C \
  '(- *)'{-\?,--help}'[show help]' \
  '(- *)'{-V,--version}'[show version]' \
  '(-c --config)'{-c+,--config=}'[config file]:file:_files -g "*.conf"' \
  '(-a --extra-config)'{-a+,--extra-config=}'[extra config]:file:_files' \
  '(-u --user)'{-u+,--user=}'[run as user]:user:_users' \
  '--core-file[dump core on crash]' \
  '--pid-file=[PID file location]:file:_files' \
  '(-B --bootstrap)'{-B+,--bootstrap=}'[bootstrap against URI]:uri:' \
  '--bootstrap-socket=[bootstrap via unix socket]:file:_files' \
  '(-d --directory)'{-d+,--directory=}'[self-contained directory]:dir:_files -/' \
  '--name=[router name]:name:' \
  '--force[force reconfiguration]' \
  '--strict[bootstrap strict mode]' \
  '--account=[MySQL user account]:account:' \
  '--account-create=[account creation behavior]:mode:(if-not-exists always never)' \
  '--account-host=[host pattern]:host:' \
  '--force-password-validation[do not skip validate_password]' \
  '--password-retries=[password retries]:n:' \
  '--report-host=[override hostname]:host:_hosts' \
  '--master-key-reader=[master key reader cmd]:cmd:' \
  '--master-key-writer=[master key writer cmd]:cmd:' \
  '--conf-base-port=[base listening port]:port:' \
  '--conf-bind-address=[listen address]:addr:' \
  '--conf-skip-tcp[disable TCP binding]' \
  '--conf-use-sockets[enable unix sockets]' \
  '--conf-use-gr-notifications[enable GR notifications]' \
  '--connect-timeout=[connect timeout secs]:s:' \
  '--read-timeout=[read timeout secs]:s:' \
  '--https-port=[REST API port]:port:' \
  '--conf-target-cluster=[target cluster]:t:(current primary)' \
  '--conf-target-cluster-by-name=[target cluster name]:name:' \
  '*--conf-set-option=[generated config option]:opt:' \
  '--ssl-mode=[SSL mode]:mode:(DISABLED PREFERRED REQUIRED VERIFY_CA VERIFY_IDENTITY)' \
  '--ssl-cert=[SSL cert file]:file:_files' \
  '--ssl-key=[SSL key file]:file:_files' \
  '--ssl-ca=[CA file]:file:_files' \
  '--ssl-capath=[CA directory]:dir:_files -/' \
  '--ssl-cipher=[SSL ciphers]:c:' \
  '--ssl-crl=[CRL file]:file:_files' \
  '--ssl-crlpath=[CRL directory]:dir:_files -/' \
  '--tls-version=[TLS versions csv]:v:' \
  '--client-ssl-mode=[client SSL mode]:mode:(PREFERRED DISABLED PASSTHROUGH REQUIRED)' \
  '--client-ssl-cert=[client cert]:file:_files' \
  '--client-ssl-key=[client key]:file:_files' \
  '--client-ssl-ca=[client CA]:file:_files' \
  '--client-ssl-capath=[client CA dir]:dir:_files -/' \
  '--client-ssl-cipher=[client ciphers]:c:' \
  '--client-ssl-crl=[client CRL]:file:_files' \
  '--client-ssl-crlpath=[client CRL dir]:dir:_files -/' \
  '--client-ssl-curves=[client curves]:c:' \
  '--client-ssl-dh-params=[client DH params]:file:_files' \
  '--server-ssl-mode=[server SSL mode]:mode:(AS_CLIENT DISABLED PREFERRED REQUIRED)' \
  '--server-ssl-cipher=[server ciphers]:c:' \
  '--server-ssl-ca=[server CA]:file:_files' \
  '--server-ssl-capath=[server CA dir]:dir:_files -/' \
  '--server-ssl-crl=[server CRL]:file:_files' \
  '--server-ssl-crlpath=[server CRL dir]:dir:_files -/' \
  '--server-ssl-curves=[server curves]:c:' \
  '--server-ssl-verify=[server cert verify]:mode:(DISABLED VERIFY_CA VERIFY_IDENTITY)' \
  '--disable-rw-split[disable rw split config]' \
  '--disable-rest[disable REST API config]' \
  '--service[run as Windows service]' \
  '--install-service[install Windows service]' \
  '--install-service-manual[install service for manual start]' \
  '--remove-service[remove Windows service]' \
  '--update-credentials-section=[update keyring section]:section:' \
  '--remove-credentials-section=[remove keyring section]:section:' \
  '--clear-all-credentials[clear stored credentials]' && ret=0
return ret
