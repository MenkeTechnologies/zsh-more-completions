#compdef mstconfig mlxconfig
# Documentation: https://www.mankier.com/1/mstconfig
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above.

# mstconfig (a.k.a. mlxconfig): configure Mellanox device firmware options.
local curcontext="$curcontext" ret=1 state line
typeset -A opt_args
local -a commands=(
  'i:show information about all configurations'
  'show_confs:show information about all configurations'
  'q:query supported configurations'
  'query:query supported configurations'
  'r:reset all configurations to defaults'
  'reset:reset all configurations to defaults'
  's:set configurations on a device'
  'set:set configurations on a device'
  'apply:apply configuration without reboot'
  'show:show configuration parameters'
  'clear_semaphore:clear flash semaphore'
  'create_conf:create configuration file'
  'backup:backup current configuration'
  'restore:restore configuration from backup'
  'gen_tlvs_dump:dump TLVs'
  'set_raw:set raw TLV'
  'get_raw:get raw TLV'
)
_arguments -C \
  '(- *)'{-h,--help}'[show help]' \
  '(- *)'{-v,--version}'[show version]' \
  '(-d --dev)'{-d,--dev}'[device specification]:dev:' \
  '(-b --db)'{-b,--db}'[use a specific database file]:file:_files' \
  '(-f --file)'{-f,--file}'[raw configuration file]:file:_files' \
  '(-e --enable_verbosity)'{-e,--enable_verbosity}'[show default and current configurations]' \
  '(-y --yes)'{-y,--yes}'[answer yes in prompt]' \
  '-x[hex output]' \
  '1: :->cmd' \
  '*::arg:->args' && ret=0
case $state in
  cmd) _describe -t commands 'mstconfig command' commands && ret=0 ;;
esac
return ret
