#compdef oneko
local curcontext="$curcontext" state line ret=1
_arguments -s -S \
  '-time[animation speed in milliseconds]:milliseconds' \
  '-speed[movement speed in pixels]:pixels' \
  '-idle[idle time before sleeping]:seconds' \
  '-name[window name to chase]:window name' \
  '-towindow[chase a window instead of cursor]' \
  '-position[starting position]:position (x,y)' \
  '-rv[reverse video]' \
  '-fg[foreground color]:color' \
  '-bg[background color]:color' \
  '-display[X display]:display' \
  '-tora[use tora-neko cat]' \
  '-dog[use a dog]' \
  '-bsd[use BSD daemon]' \
  '-sakura[use sakura]' \
  '-tomoyo[use tomoyo]' \
  '-help[show help]' && ret=0
return ret
