#compdef psxy
# Documentation: https://docs.generic-mapping-tools.org/latest/plot.html
# Source: GenericMappingTools/gmt classic-mode plot — plot lines / polygons / symbols on a map.
# Reference accessed: 2026-06-10
#
# GMT classic syntax: -<letter>[mod] inline. Modern equivalent is `gmt plot`.

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-R+[region west/east/south/north]:region:_default' \
    '-J+[projection (e.g. M15c, X10c)]:proj:_default' \
    '-B+[basemap frame/axes]:basemap:_default' \
    '-A+[geodesic / great-circle line type]:type:_default' \
    '-C+[CPT (color palette table)]:cpt:_files -g "*.cpt(-.)"' \
    '-D+[symbol/line offset dx/dy]:offset:_default' \
    '-E+[error bars / box-and-whisker]:errspec:_default' \
    '-F+[group/connect modifiers]:opts:_default' \
    '-G+[fill color/pattern]:fill:_default' \
    '-H+[per-record symbol-size scaling]:scale:_default' \
    '-I+[fill modulation by illumination]:value:_default' \
    '-L+[force closed polygon]:opts:_default' \
    '-M+[fill area between two curves]:opts:_default' \
    '-N[do not clip symbols at map boundary]' \
    '-S+[symbol spec (e.g. c0.2c)]:symbol:_default' \
    '-T[no input expected]' \
    '-W+[pen (width/color/style)]:pen:_default' \
    '-X+[X offset of plot origin]:offset:_default' \
    '-Y+[Y offset of plot origin]:offset:_default' \
    '-Z+[color/transparency control]:opts:_default' \
    '-K[multi-page: more pages follow]' \
    '-O[multi-page: this is overlay]' \
    '-P[portrait orientation]' \
    '-U+[GMT timestamp logo]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-t+[transparency percent]:pct:_default' \
    '-p+[perspective view]:perspective:_default' \
    '*:input data file:_files' \
    && ret=0

return ret
