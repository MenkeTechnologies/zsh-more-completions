#compdef mgd77magref
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77magref.html
# Source: GenericMappingTools/gmt supplements/mgd77 — evaluate IGRF / CM4 geomagnetic field models.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[altitude/time/time-format settings]:opts:_default' \
    '-C+[alternate CM4 coefficient file]:file:_files' \
    '-D+[Dst index file (CM4 magnetospheric)]:file:_files' \
    '-E+[F10.7 solar flux file (CM4 ionospheric)]:file:_files' \
    '-F+[output fields (total/horizontal/components/dec/inc)]:fields:_default' \
    '-G[geocentric coordinates (not geodetic)]' \
    '-L+[current density J vectors from external sources]:opts:_default' \
    '-S+[restrict wavelength bands (core/lithosphere)]:opts:_default' \
    '*-V[verbose (stackable)]' \
    '-bi+[binary input format]:format:_default' \
    '-bo+[binary output format]:format:_default' \
    '-h+[header records]:n:_default' \
    '-o+[output column selection]:cols:_default' \
    '-:[swap first two columns]' \
    '*:input table:_files' \
    && ret=0

return ret
