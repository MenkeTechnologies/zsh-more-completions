#compdef pit
# Documentation: https://github.com/michaeldv/pit
# Reference accessed: 2026-05-20
# Verified: upstream docs at the URL above.

local curcontext="$curcontext" state line ret=1 expl
_arguments -C '1: :->cmd' '*:: :->rest' && ret=0
case $state in
cmd)
  _wanted commands expl 'pit command' compadd -- \
    init project task note log info help version
  ;;
rest)
  _normal && ret=0
  ;;
esac
return ret
