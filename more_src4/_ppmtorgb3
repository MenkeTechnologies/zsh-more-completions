#compdef ppmtorgb3
# Documentation: man ppmtorgb3 (Netpbm)
# Source: split a PPM image into three PGM files (basename.red, .grn, .blu).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-quiet[suppress libnetpbm chatter]' \
    '1:ppm file:_files -g "*.(ppm|pnm|pam)"' \
    && ret=0

return ret
