#compdef mrftopbm
# Documentation: man mrftopbm (Netpbm)
# Source: convert a Monochrome Recursive Format (MRF) file to PBM.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[print average row instead of image]' \
    '-quiet[suppress libnetpbm chatter]' \
    '1:mrf file:_files -g "*.mrf"' \
    && ret=0

return ret
