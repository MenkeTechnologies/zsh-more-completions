#compdef pgo pgo-cli
# _pgo — Crunchy Data pgo CLI command-line frontend wrapping the Crunchy PostgreSQL Operator PGO Kubernetes-native PostgreSQL administration operator managing clusters backups restores connection-pooler PGBouncer pgAdmin4 high-availability replication monitoring failover scheduling for production PostgreSQL workloads (Crunchy Data team, Go); cobra
# upstream: https://access.crunchydata.com/documentation/postgres-operator/

_pgo() {
    local -a sub=(
        'create:create resources'
        'delete:delete resources'
        'show:show resources'
        'update:update resources'
        'apply:apply policies'
        'backup:backup cluster'
        'restore:restore cluster'
        'cat:cat a file from pod'
        'clone:clone a cluster'
        'failover:failover'
        'reload:reload configuration'
        'restart:restart cluster'
        'scaledown:scaledown replicas'
        'cli:cli operations'
        'df:df utility'
        'label:label resources'
        'load:load data'
        'ls:list resources'
        'status:show status'
        'test:test cluster connection'
        'completion:generate shell completion'
        'version:show version'
        'help:show help'
    )
    _arguments -C \
        '-h[show help]' \
        '--help[show help]' \
        '-V[show version]' \
        '--version[show version]' \
        '-v[verbose]' \
        '--verbose[verbose]' \
        '--apiserver-url=+[url]:str:' \
        '--username=+[user]:str:' \
        '--password=+[password]:str:' \
        '--namespace=+[name]:str:' \
        '-n+[namespace]:str:' \
        '--all-namespaces[all namespaces]' \
        '--selector=+[k=v]:str:' \
        '-l+[selector]:str:' \
        '--exclude-namespace=+[name]:str:' \
        '--disable-tls[disable TLS]' \
        '-o+[format]:f:(json yaml text)' \
        '--output=+[format]:f:(json yaml text)' \
        '1:subcommand:->sub' \
        '*::args:->args'

    case $state in
        sub) _describe -t commands 'pgo subcommand' sub ;;
        args)
            case $words[1] in
                create|delete|show|update|apply|status|backup|restore|clone|failover|reload|restart|scaledown|label) _arguments '1:resource:(cluster pgouser pgorole policy schedule namespace pgbouncer ingest etcd-cluster watch backup restore)' '*:name:' ;;
            esac
            ;;
    esac
}

_pgo "$@"
