# New Relic infrastructure agent main process

_arguments -s -S \
  '-config=[overrides default configuration file location]:file:_files' \
  '-debug[enable agent debugging functionality]' \
  '-version[show version details]' \
  '-validate[validate agent config and exit]' \
  '-dry_run[run the agent in dry_run mode]' \
  '-integration_config_path=[integrations config path for dry-run]:path:_files' \
  '-cpuprofile=[write CPU profile to file]:file:_files' \
  '-memprofile=[write memory profile to file]:file:_files' \
  '-verbose=[logging verbosity level]:level:' && return 0
