#compdef mopprobe
# Documentation: man mopprobe(1)
# Source: netbsd/src usr.sbin/mopd/mopprobe — show MOP SID broadcasters (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-a[listen on all Ethernet interfaces]' \
    '1::interface:_net_interfaces' \
    && ret=0

return ret
