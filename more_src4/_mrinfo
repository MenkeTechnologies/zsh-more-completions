#compdef mrinfo
# Documentation: https://mrtrix.readthedocs.io/en/latest/reference/commands/mrinfo.html
# Source: MRtrix3/mrtrix3 cmd/mrinfo.cpp — display header information of input image(s) (C++).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(- *)'{-h,--help}'[show help]' \
    '-all[print all properties (not just first/last 2 of each)]' \
    '-name[print file system path of image]' \
    '-format[print image file format]' \
    '-ndim[print number of dimensions]' \
    '-size[print image size along each axis]' \
    '-spacing[print voxel spacing along each dimension]' \
    '-datatype[print data type]' \
    '-strides[print data strides]' \
    '-offset[print image intensity offset]' \
    '-multiplier[print image intensity multiplier]' \
    '-transform[print image-to-scanner transformation]' \
    '-dwgrad[print interpreted DW gradient table]' \
    '-shell_bvalues[list average b-value of each shell]' \
    '-shell_sizes[list number of volumes per shell]' \
    '-shell_indices[list volume indices per b-value shell]' \
    '-petable[print phase encoding table]' \
    '-nodelete[do not delete temp/piped images]' \
    '-property+[print a header property]:key:_default' \
    '-json_keyval+[write key-value header to JSON]:file:_files -g "*.json"' \
    '-json_all+[write full header to JSON]:file:_files -g "*.json"' \
    '-grad+[MRtrix gradient table]:file:_files' \
    '-fslgrad+[FSL bvecs bvals pair]:files:_files' \
    '-export_grad_mrtrix+[export MRtrix gradient table]:file:_files' \
    '-export_grad_fsl+[export FSL bvecs bvals]:files:_files' \
    '-export_pe_table+[export phase encoding table]:file:_files' \
    '-export_pe_eddy+[export PE config in eddy format]:files:_files' \
    '*:images:_files -g "*.{nii,nii.gz,mif,mih}"' \
    && ret=0

return ret
