#compdef mpdringtest
# Documentation: https://www.mpich.org/static/downloads/1.2.1p1/mpich2-1.2.1p1-README.txt
# Reference accessed: 2026-05-19
# Verified: upstream docs at the URL above. MPICH2 MPD ring test utility
# (legacy, replaced by Hydra). Takes a single positional <n_loops>
# argument (e.g. mpdringtest 1000).

# mpdringtest: MPD ring test utility (legacy Intel MPI; positional only)
local curcontext="$curcontext" ret=1
_arguments -C \
  '1:n_loops:' && ret=0
return ret
