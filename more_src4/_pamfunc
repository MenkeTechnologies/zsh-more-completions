#compdef pamfunc
# Documentation: man pamfunc (Netpbm)
# Source: Netpbm pamfunc — apply a simple monadic arithmetic function to a Netpbm image.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

local -a fns
fns=(
    -multiplier -divisor -adder -subtractor -min -max
    -andmask -ormask -xormask -not
    -shiftleft -shiftright
)

_arguments -s \
    "(${fns[*]})-multiplier=[multiply by realnum]:realnum:" \
    "(${fns[*]})-divisor=[divide by realnum]:realnum:" \
    "(${fns[*]})-adder=[add integer]:integer:" \
    "(${fns[*]})-subtractor=[subtract integer]:integer:" \
    "(${fns[*]})-min=[per-sample minimum (whole)]:wholenum:" \
    "(${fns[*]})-max=[per-sample maximum (whole)]:wholenum:" \
    "(${fns[*]})-andmask=[bitwise AND with hex mask]:hexmask:" \
    "(${fns[*]})-ormask=[bitwise OR with hex mask]:hexmask:" \
    "(${fns[*]})-xormask=[bitwise XOR with hex mask]:hexmask:" \
    "(${fns[*]})-not[bitwise NOT]" \
    "(${fns[*]})-shiftleft=[shift bits left by N]:count:" \
    "(${fns[*]})-shiftright=[shift bits right by N]:count:" \
    '-changemaxval[adjust maxval to fit result]' \
    '-quiet[suppress informational messages (libnetpbm common)]' \
    '*:input PAM/PNM file:_files -g "*.{pam,pnm,ppm,pgm,pbm}"' \
    && ret=0

return ret
