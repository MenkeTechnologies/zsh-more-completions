#compdef meinproc5 meinproc6 meinproc
# _meinproc5 — KDE meinproc (DocBook XML -> HTML for KHelpCenter and offline docs; --stdout dumps to stdout, --check just validates, --stylesheet picks an alternate XSL, --output sets output dir)
# upstream: https://invent.kde.org/frameworks/kdoctools (src/meinproc.cpp)
# Flags from kdoctools src/meinproc.cpp on tip.

_meinproc5() {
    _arguments \
        '--help[show help]' \
        '--version[show version]' \
        '--stdout[output to stdout]' \
        '--check[validate without writing output]' \
        '--htdig[generate htdig index input]' \
        '--cache+[index.cache.bz2 output]:file:_files' \
        '--stylesheet+[XSL stylesheet]:file:_files -g "*.xsl"' \
        '--output+[output directory]:dir:_files -/' \
        '*--param+[XSL parameter]:name=value:' \
        '*:docbook file:_files -g "*.(docbook|xml)"'
}

_meinproc5 "$@"
