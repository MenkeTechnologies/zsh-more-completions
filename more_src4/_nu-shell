#compdef nu nushell
# _nu-shell — Nushell structured-data shell (Sophia Turner, Jonathan Turner, Yehuda Katz, JT, Rust); pipelines of typed tables/records
# upstream: https://github.com/nushell/nushell

_nu-shell() {
    _arguments \
        '(-h --help)'{-h,--help}'[show help]' \
        '(-V --version)'{-V,--version}'[show version]' \
        '(-c --commands)'{-c,--commands}'+[command]:code:' \
        '(-e --execute)'{-e,--execute}'+[execute]:code:' \
        '(-l --login)'{-l,--login}'[login shell]' \
        '(-i --interactive)'{-i,--interactive}'[interactive]' \
        '(-m --table-mode)'{-m,--table-mode}'+[table mode]:mode:(basic compact light thin rounded reinforced heavy none with_love)' \
        '(-s --stdin)'{-s,--stdin}'[read code from stdin]' \
        '(-t --testbin)'{-t,--testbin}'+[testbin]:tool:' \
        '(-n --no-config-file)'{-n,--no-config-file}'[skip config files]' \
        '--no-newline[no trailing newline in -c output]' \
        '--no-history[no history file]' \
        '--no-std-lib[no stdlib]' \
        '--config+[config file]:file:_files' \
        '--env-config+[env config file]:file:_files' \
        '--log-level+[log level]:level:(trace debug info warn error)' \
        '--log-target+[log target]:target:(stderr stdout mixed file)' \
        '--log-include+[log filter include]:str:' \
        '--log-exclude+[log filter exclude]:str:' \
        '--threads+[max threads]:n:' \
        '--plugins+[plugins file]:file:_files' \
        '--plugin-config+[plugin config]:file:_files' \
        '--include-path+[NUSHELL_INCLUDE_PATH]:paths:' \
        '--lsp[run as LSP server]' \
        '--ide-check+[ide check at line]:n:' \
        '--ide-goto-def+[ide goto def]:n:' \
        '--ide-hover+[ide hover]:n:' \
        '--ide-complete+[ide completions]:n:' \
        '--ide-ast[ide ast]' \
        '*:script:_files -g "*.nu"'
}

_nu-shell "$@"
