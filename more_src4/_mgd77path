#compdef mgd77path
# Documentation: https://docs.generic-mapping-tools.org/latest/supplements/mgd77/mgd77path.html
# Source: GenericMappingTools/gmt supplements/mgd77 — resolve full paths to MGD77 cruise files.
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '-A+[full path / just cruise IDs (-Ac)]:opts:_default' \
    '-D[show MGD77 search directories]' \
    '-I+[exclude file formats]:formats:(a c m t)' \
    '*-V[verbose (stackable)]' \
    '(- *)-\?[show help]' \
    '*:GEODAS-ID or cruise file:_files' \
    && ret=0

return ret
