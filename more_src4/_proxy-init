#compdef proxy-init linkerd-proxy-init
# _proxy-init — Linkerd proxy-init initContainer (programs iptables/nftables to redirect pod traffic through the linkerd-proxy sidecar)
# upstream: https://github.com/linkerd/linkerd2-proxy-init
# Flags from proxy-init/cmd/root.go on tip (cobra).

_proxy-init() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '(-p --incoming-proxy-port)'{-p,--incoming-proxy-port}'=[port to redirect incoming traffic]:port:' \
        '(-o --outgoing-proxy-port)'{-o,--outgoing-proxy-port}'=[port to redirect outgoing traffic]:port:' \
        '(-u --proxy-uid)'{-u,--proxy-uid}'=[UID the proxy runs as (traffic from this UID is ignored)]:uid:' \
        '(-g --proxy-gid)'{-g,--proxy-gid}'=[GID the proxy runs as (traffic from this GID is ignored)]:gid:' \
        '*'{-r,--ports-to-redirect}'=[csv of inbound ports to redirect]:csv:' \
        '*--inbound-ports-to-ignore=[csv of inbound ports to ignore]:csv:' \
        '*--outbound-ports-to-ignore=[csv of outbound ports to ignore]:csv:' \
        '*--subnets-to-ignore=[csv of subnet CIDRs whose traffic is ignored]:csv:' \
        '--simulate[do not execute commands, just print what would run]' \
        '--netns=[network namespace to run iptables commands in]:ns:' \
        '(-w --use-wait-flag)'{-w,--use-wait-flag}'[pass -w to iptables commands]' \
        '--timeout-close-wait-secs=[sets nf_conntrack_tcp_timeout_close_wait]:s:' \
        '--log-format=[log format]:fmt:(plain json)' \
        '--log-level=[log level]:level:(trace debug info warn error fatal panic)' \
        '--iptables-mode=[iptables variant]:mode:(legacy nft plain)' \
        '--ipv6=[also set rules via ip6tables for dual-stack]:bool:(true false)' \
        '--firewall-bin-path=[path to the iptables binary]:file:_files' \
        '--firewall-save-bin-path=[path to the iptables-save binary]:file:_files'
}

_proxy-init "$@"
