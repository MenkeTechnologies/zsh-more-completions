#compdef markdown2tex
# Documentation: https://github.com/witiko/markdown
# Reference accessed: 2026-05-19
# Verified: markdown2tex --help on installed binary (witiko/markdown
# CTAN package). Usage: markdown2tex [OPTIONS] -- [INPUT_FILE] [OUTPUT_FILE].
# OPTIONS are documented in Section 2.2.1 of the Markdown Package User
# Manual at https://ctan.org/pkg/markdown and not enumerated upstream
# in a single canonical list.
# Removed from prior file: fabricated -h/-o/-s flags (none exist in the
# `markdown2tex --help` output) and bogus man.archlinux.org URL.

# markdown2tex: convert Markdown to TeX using the witiko/markdown package
local curcontext="$curcontext" ret=1
_arguments -C \
  '*:Markdown or TeX file:_files -g "*.(md|markdown|txt|tex)(-.)"' && ret=0
return ret
