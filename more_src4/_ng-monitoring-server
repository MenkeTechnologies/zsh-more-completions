#compdef ng-monitoring-server
# _ng-monitoring-server — PingCAP Next Generation Monitoring server (NGM)
# upstream: https://github.com/pingcap/ng-monitoring
# Flags from main.go on tip.

_ng-monitoring-server() {
    _arguments \
        '(- *)'{-h,--help}'[show help]' \
        '-V[print version and exit]' \
        '--address=[HTTP TCP listen address]:host\:port:' \
        '--pd.endpoints=[PD endpoints (csv)]:csv:' \
        '--log.path=[log file path]:file:_files' \
        '--storage.path=[storage data directory]:dir:_files -/' \
        '--config=[config file path]:file:_files' \
        '--advertise-address=[NGM advertised host\:port]:host\:port:' \
        '--retention-period=[data retention (e.g. 4w, 6m, 1y; default months)]:spec:'
}

_ng-monitoring-server "$@"
