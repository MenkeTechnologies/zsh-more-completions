#compdef pdf2dsc
# Documentation: man pdf2dsc(1)
# Source: Ghostscript ghostpdl pdf2dsc (master) — generate DSC index of PDF (sh).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1

_arguments \
    '1:PDF file:_files -g "*.pdf"' \
    '2::output DSC file:_files -g "*.dsc"' \
    && ret=0

return ret
