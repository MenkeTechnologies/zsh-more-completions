#compdef mhn
# Documentation: man mhn(1)
# Source: nmh uip/mhn.c (master) — legacy MIME handler (deprecated for mhbuild/mhshow/mhstore) (C).
# Reference accessed: 2026-06-10

local curcontext="$curcontext" state line ret=1
typeset -A opt_args

_arguments -s \
    '(-auto -noauto)-auto[auto-process MIME content]' \
    '(-auto -noauto)-noauto[do not auto-process]' \
    '(-cache -nocache)-cache[use external content cache]' \
    '(-cache -nocache)-nocache[no cache]' \
    '(-check -nocheck)-check[check MIME structure]' \
    '(-check -nocheck)-nocheck[no check]' \
    '(-headers -noheaders)-headers[show headers]' \
    '(-headers -noheaders)-noheaders[hide headers]' \
    '(-list -nolist)-list[list parts]' \
    '(-list -nolist)-nolist[no list]' \
    '(-realsize -norealsize)-realsize[show real size]' \
    '(-realsize -norealsize)-norealsize[no real size]' \
    '(-show -noshow)-show[display message]' \
    '(-show -noshow)-noshow[do not display]' \
    '(-store -nostore)-store[store parts]' \
    '(-store -nostore)-nostore[do not store]' \
    '(-verbose -noverbose)-verbose[verbose]' \
    '(-verbose -noverbose)-noverbose[no verbose]' \
    '-file+[message file]:file:_files' \
    '-form+[format file]:file:_files' \
    '*-part+[part number]:N:_default' \
    '*-type+[content type filter]:type:_default' \
    '-rcache+[read cache policy]:policy:(public private never ask)' \
    '-wcache+[write cache policy]:policy:(public private never ask)' \
    '-version[show version]' \
    '-help[show help]' \
    '-debug[debug output]' \
    '-moreproc+[pager program]:cmd:_command_names -e' \
    '-nomoreproc[no pager]' \
    '-length+[output length]:N:_default' \
    '-width+[output width]:N:_default' \
    '(-build -nobuild)-build[build MIME message]' \
    '(-build -nobuild)-nobuild[no build]' \
    '(-rfc934mode -norfc934mode)-rfc934mode[RFC 934 encapsulation]' \
    '(-rfc934mode -norfc934mode)-norfc934mode[no RFC 934]' \
    '1::+folder:_default' \
    '*::msgs:_default' \
    && ret=0

return ret
